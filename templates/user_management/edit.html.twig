{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'user' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_tabs.html.twig' as _fa_tabs %}

{% block title %}{{ 'user.edit'|trans({}, 'user') }} - {{ user.fullName }}{% endblock %}

{% block admin_content %}
<div class="container-fluid">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.admin'|trans({}, 'nav'), url: path('admin_dashboard') },
            { label: 'nav.users'|trans({}, 'nav'), url: path('user_management_index') },
            { label: user.fullName, url: path('user_management_show', {id: user.id}) },
            { label: 'common.edit'|trans({}, 'messages') }
        ]
    } %}

    {{ _fa_page_header.render({
        title: ('user.edit'|trans({}, 'user')),
        badge: { icon: 'ui-edit', label: '' },
        actions: [
            { label: 'common.view'|trans({}, 'messages'), href: path('user_management_show', {'id': user.id}), variant: 'ghost', icon: 'util-arrow-left' }
        ]
    }) }}

    <div class="row">
        <div class="col-md-10 offset-md-1">
            {# Role Help Component - explains system vs custom roles #}
            {{ include('_components/_role_help.html.twig') }}

            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">{{ user.fullName }} {{ 'user.edit_suffix'|trans({}, 'user') }}</h2>
                </div>
                <div class="fa-section__body">
                    {{ form_start(form) }}

                    {{ _fa_tabs.render({
                        id: 'user-settings',
                        urlHashSync: true,
                        initialTab: 'tab-profile',
                        tabs: [
                            {
                                id: 'tab-profile',
                                label: 'user.tab.profile'|trans({}, 'user'),
                                icon: 'ui-person',
                                body: include('user_management/tabs/_tab_profile.html.twig', { form: form })
                            },
                            {
                                id: 'tab-access',
                                label: 'user.tab.access'|trans({}, 'user'),
                                icon: 'nav-shield-lock',
                                body: include('user_management/tabs/_tab_access.html.twig', { form: form })
                            },
                            {
                                id: 'tab-security',
                                label: 'user.tab.security'|trans({}, 'user'),
                                icon: 'ui-lock',
                                body: include('user_management/tabs/_tab_security.html.twig', { form: form })
                            }
                        ]
                    }) }}

                    {# CSRF token — outside tab panels so it is always submitted #}
                    {% if form._token is defined %}
                        {{ form_row(form._token) }}
                    {% endif %}

                    {# Auth Provider Info (Edit Mode Only) #}
                    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info' } } %}
                        {% block alert_body %}
                        <strong>{{ 'user.field.auth_provider'|trans({}, 'user') }}:</strong>
                        {% if user.authProvider == 'azure_oauth' %}
                            Azure OAuth
                        {% elseif user.authProvider == 'azure_saml' %}
                            Azure SAML
                        {% else %}
                            {{ 'user.auth_provider.local'|trans({}, 'user') }}
                        {% endif %}
                        {% endblock %}
                    {% endembed %}

                    {# Metadata (Edit Mode Only) #}
                    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info' } } %}
                        {% block alert_body %}
                        <small>
                            <strong>{{ 'user.field.created_at'|trans({}, 'user') }}:</strong> {{ user.createdAt|date('d.m.Y H:i') }}<br>
                            {% if user.updatedAt %}
                                <strong>{{ 'user.field.updated_at'|trans({}, 'user') }}:</strong> {{ user.updatedAt|date('d.m.Y H:i') }}<br>
                            {% endif %}
                            {% if user.lastLoginAt %}
                                <strong>{{ 'user.field.last_login'|trans({}, 'user') }}:</strong> {{ user.lastLoginAt|date('d.m.Y H:i') }}
                            {% endif %}
                        </small>
                        {% endblock %}
                    {% endembed %}

                    {# Form Actions #}
                    <div class="form-actions d-flex gap-2 justify-content-between mt-4">
                        <a href="{{ path('user_management_show', {'id': user.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                            <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i>
                            {{ 'common.cancel'|trans({}, 'messages') }}
                        </a>
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                            <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i>
                            {{ 'user.save_changes'|trans({}, 'user') }}
                        </button>
                    </div>

                    {{ form_end(form, {render_rest: false}) }}
                </div>
            </section>
        </div>
    </div>
</div>
{% endblock admin_content %}

{% block javascripts %}
{{ parent() }}
<script>
    // Turbo re-eval guard: wrap in IIFE so top-level symbols are not re-declared on body-swap
    (function () {
    // Initialize Bootstrap tooltips for role checkboxes
    function initUserEditTooltips() {
        if (!window.bootstrap || !window.bootstrap.Tooltip) { return; }
        const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]');
        tooltipTriggerList.forEach(function(el) {
            bootstrap.Tooltip.getInstance(el)?.dispose();
            new bootstrap.Tooltip(el);
        });
    }
    document.addEventListener('DOMContentLoaded', initUserEditTooltips);
    document.addEventListener('turbo:load', initUserEditTooltips);
    })();
</script>
{% endblock %}
