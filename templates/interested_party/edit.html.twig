{% extends 'base.html.twig' %}
{% trans_default_domain 'interested_parties' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'interested_party.page.edit_title'|trans({}, 'interested_parties') }}: {{ interested_party.name }}{% endblock %}

{% block body %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.interested_parties'|trans({}, 'nav'), url: path('app_interested_party_index') },
            { label: interested_party.name, url: path('app_interested_party_show', {id: interested_party.id}) },
            { label: 'common.edit'|trans({}, 'messages') }
        ]
    } %}

    {{ _fa_page_header.render({
        title: 'interested_party.page.edit_title'|trans({}, 'interested_parties') ~ ': ' ~ interested_party.name,
        badge: { icon: 'ui-edit', label: '' },
        actions: [
            { label: 'common.view'|trans({}, 'messages'), href: path('app_interested_party_show', {id: interested_party.id}), variant: 'ghost', icon: 'util-arrow-left' }
        ]
    }) }}

    {{ form_start(form) }}
    {% include '_components/_auto_form.html.twig' with {
        'form': form,
        'layout': 'outline-rail',
        'eyebrow': 'ISO 27001 Cl. 4.2 · Interested Parties',
        'title': interested_party.name,
        'sections': {
            'overview': {
                'label': 'form.section.overview'|trans({}, 'messages'),
                'fields': ['name', 'partyType', 'importance', 'description']
            },
            'contact': {
                'label': 'form.section.contact'|trans({}, 'messages'),
                'fields': ['contactPerson', 'email', 'phone']
            },
            'requirements': {
                'label': 'form.section.requirements'|trans({}, 'messages'),
                'fields': ['requirements', 'howAddressed']
            },
            'communication': {
                'label': 'form.section.communication'|trans({}, 'messages'),
                'fields': ['communicationFrequency', 'communicationMethod', 'lastCommunication', 'nextCommunication']
            },
            'monitoring': {
                'label': 'form.section.monitoring'|trans({}, 'messages'),
                'fields': ['feedback', 'satisfactionLevel', 'issues']
            }
        },
        'col_widths': {
            'name': 4,
            'partyType': 4,
            'importance': 4,
            'description': 12,
            'contactPerson': 4,
            'email': 4,
            'phone': 4,
            'requirements': 12,
            'howAddressed': 12,
            'communicationFrequency': 6,
            'communicationMethod': 6,
            'lastCommunication': 6,
            'nextCommunication': 6,
            'feedback': 12,
            'satisfactionLevel': 6,
            'issues': 6
        },
        'tooltips': {
            'satisfactionLevel': 'interested_party.tooltip.satisfaction_level',
            'importance': 'interested_party.tooltip.importance'
        },
        'translation_domain': 'interested_parties',
        'actions': {
            'close': { 'label': 'common.cancel'|trans({}, 'messages'), 'variant': 'ghost' },
            'submit': { 'label': 'common.save_changes'|trans({}, 'messages'), 'variant': 'primary' }
        }
    } %}
    {{ form_end(form) }}
</div>
{% endblock %}
