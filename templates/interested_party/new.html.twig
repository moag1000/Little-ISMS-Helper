{% extends 'base.html.twig' %}
{% trans_default_domain 'interested_parties' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_norm_bridge.html.twig' as _fa_norm_bridge %}

{% block title %}{{ 'interested_party.page.new_title'|trans({}, 'interested_parties')}}{% endblock %}

{% block body %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.interested_parties'|trans({}, 'nav'), url: path('app_interested_party_index') },
            { label: 'interested_party.page.new_title'|trans({}, 'interested_parties')}
        ]
    } %}

    {{ _fa_page_header.render({
    title: ('interested_party.page.new_title'|trans({}, 'interested_parties')),
    badge: { icon: 'plus', label: '' },
    actions: [
        { label: 'common.back_to_list'|trans({}, 'messages'), href: path('app_interested_party_index'), variant: 'ghost', icon: 'arrow-left' }
    ]
}) }}

    {# 9001-bridge for users with previousQmsBackground = iso_9001. P-12 rollout. #}
    {{ _fa_norm_bridge.render({
        from_norm: 'ISO 27001 4.2',
        to_norm:   'ISO 9001 4.2',
        bridge_text: ('iso_9001_bridge.party'|trans({}, 'interested_parties')),
        prominence: 'subtle'
    }) }}

    {% embed '_components/_card.html.twig' %}
        {% block card_body %}
            {{ form_start(form) }}
                {% include '_components/_auto_form.html.twig' with {
                    'form': form,
                    'sections': {
                        'basic_info': {
                            'label': 'interested_party.section.basic_info'|trans({}, 'interested_parties'),
                            'fields': ['name', 'partyType', 'importance', 'description']
                        },
                        'contact_info': {
                            'label': 'interested_party.section.contact_info'|trans({}, 'interested_parties'),
                            'fields': ['contactPerson', 'email', 'phone']
                        },
                        'requirements': {
                            'label': 'interested_party.section.requirements'|trans({}, 'interested_parties'),
                            'fields': ['requirements', 'howAddressed']
                        },
                        'communication': {
                            'label': 'interested_party.section.communication'|trans({}, 'interested_parties'),
                            'fields': ['communicationFrequency', 'communicationMethod', 'lastCommunication', 'nextCommunication']
                        },
                        'feedback': {
                            'label': 'interested_party.section.feedback'|trans({}, 'interested_parties'),
                            'fields': ['feedback', 'satisfactionLevel', 'issues']
                        }
                    },
                    'col_widths': {
                        'name': 4,
                        'partyType': 4,
                        'importance': 4,
                        'description': 12,
                        'contactPerson': 4,
                        'email': 4,
                        'phone': 4,
                        'requirements': 12,
                        'howAddressed': 12,
                        'communicationFrequency': 6,
                        'communicationMethod': 6,
                        'lastCommunication': 6,
                        'nextCommunication': 6,
                        'feedback': 12,
                        'satisfactionLevel': 6,
                        'issues': 6
                    },
                    'tooltips': {
                        'satisfactionLevel': 'interested_party.tooltip.satisfaction_level',
                        'importance': 'interested_party.tooltip.importance'
                    },
                    'translation_domain': 'interested_parties'
                } %}

                <div class="d-flex justify-content-between mt-4">
                    <a href="{{ path('app_interested_party_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                        {{ 'common.cancel'|trans({}, 'messages') }}
                    </a>
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                        {{ 'interested_party.action.create'|trans({}, 'interested_parties')}}
                    </button>
                </div>
            {{ form_end(form) }}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
