{% extends 'base.html.twig' %}
{% trans_default_domain 'interested_parties' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block title %}{{ 'interested_party.title'|trans({}, 'interested_parties') }}{% endblock %}

{% block body %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.interested_parties'|trans({}, 'nav') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'people', label: 'nav.interested_parties'|trans({}, 'nav') },
        title: 'interested_party.page.title'|trans({}, 'interested_parties'),
        subtitle: 'interested_party.iso_reference'|trans({}, 'interested_parties'),
        actions: [
            { label: 'interested_party.action.add_new'|trans({}, 'interested_parties'), variant: 'primary', icon: 'plus-lg', href: path('app_interested_party_new') }
        ]
    }) }}

    <main class="fa-aurora-surface">

    {{ _fa_alert.render({ variant: 'info', class: 'mb-3', body: 'interested_party.hint.clause_context'|trans({}, 'interested_parties') ~ ' <a href="' ~ path('app_context_index') ~ '" class="fa-alert__link">' ~ 'interested_party.link.isms_context'|trans({}, 'interested_parties') ~ '</a>' }) }}

    {% if overdue_communications|length > 0 %}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning' } } %}
        {% block alert_body %}
            <div class="fa-alert__title">{{ 'interested_party.alert.overdue_communications'|trans({}, 'interested_parties') }}</div>
            <ul>
                {% for party in overdue_communications %}
                <li>
                    <a href="{{ path('app_interested_party_show', {id: party.id}) }}" class="fa-alert__link">{{ party.name }}</a>
                    ({{ party.partyType }}) - {{ 'interested_party.next_communication'|trans({}, 'interested_parties') }}: {{ party.nextCommunication|date('Y-m-d') }}
                </li>
                {% endfor %}
            </ul>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {% if high_importance|length > 0 %}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info' } } %}
        {% block alert_body %}
            <div class="fa-alert__title">{{ 'interested_party.high_importance.title'|trans({}, 'interested_parties') }}</div>
            <ul>
                {% for party in high_importance %}
                <li>
                    <a href="{{ path('app_interested_party_show', {id: party.id}) }}">{{ party.name }}</a>
                    ({{ party.partyType }}) - {{ 'interested_party.engagement_score'|trans({}, 'interested_parties') }}: {{ party.getEngagementScore() }}
                </li>
                {% endfor %}
            </ul>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {% embed '_components/_card.html.twig' %}
        {% block card_header %}
            <div class="card-header">
                {%- set partyCount = interested_parties|length -%}
                <h2>{{ 'interested_party.list.title'|trans({'count': partyCount}, 'interested_parties') }}</h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% if interested_parties|length > 0 %}
            {% embed '_components/_table.html.twig' with {
                'wrapperClass': 'card-body',
                'noMargin': true
            } %}
                {% block table_head %}
                    <tr>
                        <th scope="col">{{ 'interested_party.table.name'|trans({}, 'interested_parties') }}</th>
                        <th scope="col">{{ 'interested_party.table.type'|trans({}, 'interested_parties') }}</th>
                        <th scope="col">{{ 'interested_party.table.importance'|trans({}, 'interested_parties') }}</th>
                        <th scope="col">{{ 'interested_party.table.engagement_score'|trans({}, 'interested_parties') }}</th>
                        <th scope="col">{{ 'interested_party.table.last_communication'|trans({}, 'interested_parties') }}</th>
                        <th scope="col">{{ 'interested_party.table.actions'|trans({}, 'interested_parties') }}</th>
                    </tr>
                {% endblock %}
                {% block table_body %}
                    {% for party in interested_parties %}
                    <tr>
                        <td><a href="{{ path('app_interested_party_show', {id: party.id}) }}">{{ party.name }}</a></td>
                        <td>{% include '_components/_badge.html.twig' with { variant: 'info', content: party.partyType } %}</td>
                        <td>{% include '_components/_badge.html.twig' with { variant: party.importance == 'high' ? 'warning' : (party.importance == 'low' ? 'success' : 'info'), content: party.importance|upper } %}</td>
                        <td>{{ party.getEngagementScore() }}</td>
                        <td>{{ party.lastCommunication ? party.lastCommunication|date('Y-m-d') : ('interested_party.never'|trans({}, 'interested_parties')) }}</td>
                        <td>
                            <a href="{{ path('app_interested_party_show', {id: party.id}) }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost">{{ 'interested_party.action.view'|trans({}, 'interested_parties') }}</a>
                            <a href="{{ path('app_interested_party_edit', {id: party.id}) }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--primary">{{ 'interested_party.action.edit'|trans({}, 'interested_parties') }}</a>
                        </td>
                    </tr>
                    {% endfor %}
                {% endblock %}
            {% endembed %}
            {% else %}
            <p>{{ 'interested_party.empty.message'|trans({}, 'interested_parties') }} <a href="{{ path('app_interested_party_new') }}">{{ 'interested_party.empty.add_first'|trans({}, 'interested_parties') }}</a>.</p>
            {% endif %}
        {% endblock %}
    {% endembed %}
    </main>
</div>
{% endblock %}
