{#
 FairyAurora v3.0 — Auth-Layout (Login / MFA / Password-Reset / Verify-Email)
 2-Col wie Setup-Wizard, aber ohne Flow-Array: statische Alva-Begleitung
 via auth_mood-Block (Default: focused) + authAlvaLine-Block.

 Verwendung:
   extends 'base_auth.html.twig'
   block auth_mood          (optional — idle|focused|thinking|happy|warning)
   block auth_alva_line     (z.B. 'Nur noch ein Passwort, dann geht's los.')
   block auth_alva_sub      (optionaler Untertext)
   block body               (der eigentliche Form-Content rechts)

 Plan § 13 Pattern-Source-of-Truth (Login-Pattern).
#}
<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="turbo-cache-control" content="no-cache">
    <title>{% block title %}{{ 'app.title'|trans({}, 'messages') }}{% endblock %}</title>
    <link rel="icon" type="image/svg+xml" href="{{ asset('favicon.svg') }}">
    <link rel="icon" type="image/x-icon" href="{{ asset('favicon.ico') }}">
    <meta name="theme-color" content="#0284c7" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#38bdf8" media="(prefers-color-scheme: dark)">

    <link rel="preload" href="{{ asset('fonts/inter-500.woff2') }}" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="{{ asset('fonts/inter-600.woff2') }}" as="font" type="font/woff2" crossorigin>

    <script>
        (function () {
            try {
                var saved = localStorage.getItem('fa-theme');
                var theme = (saved === 'light' || saved === 'dark' || saved === 'system') ? saved : 'light';
                document.documentElement.setAttribute('data-theme', theme);
            } catch (e) {
                document.documentElement.setAttribute('data-theme', 'light');
            }
        })();
    </script>

    {% block stylesheets %}
        {# Bootstrap zuerst — Aurora-Styles kommen via importmap danach und überschreiben. #}
        <link href="{{ asset('vendor/bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">
        <link rel="stylesheet" href="{{ asset('vendor/bootstrap-icons/font/bootstrap-icons.min.css') }}">
        {{ importmap(['app', 'styles']) }}
    {% endblock %}
</head>
<body class="fa-auth-body">

{% import '_components/_brand.html.twig' as faBrand %}
{% import '_components/_tech_backdrop.html.twig' as techBg %}
{% import '_components/_onboarding_fairy.html.twig' as onFairy %}

<div class="fa-auth-shell">
    <aside class="fa-auth-left" aria-label="{{ 'auth.companion'|trans({}, 'messages')|default('Alva — Begleiterin') }}">
        {{ techBg.render(0.75)|raw }}
        <span class="fa-setup-left__tick fa-setup-left__tick--tl" aria-hidden="true"></span>
        <span class="fa-setup-left__tick fa-setup-left__tick--tr" aria-hidden="true"></span>
        <span class="fa-setup-left__tick fa-setup-left__tick--bl" aria-hidden="true"></span>
        <span class="fa-setup-left__tick fa-setup-left__tick--br" aria-hidden="true"></span>

        <div class="fa-auth-left__brand">
            {{ faBrand.render(size='lg', link=path('app_home'))|raw }}
        </div>

        <div class="fa-auth-left__middle">
            {{ onFairy.render((block('auth_mood') ?: 'focused')|trim)|raw }}
            <div>
                <div class="fa-setup-left__alva-label">Alva · {{ 'auth.companion_short'|trans({}, 'messages')|default('Begleiterin') }}</div>
                <div class="fa-auth-left__line">
                    {% block auth_alva_line %}{{ 'auth.alva.default_line'|trans({}, 'messages')|default('Willkommen zurück.') }}{% endblock %}
                </div>
                <div class="fa-auth-left__sub">
                    {% block auth_alva_sub %}{{ 'auth.alva.default_sub'|trans({}, 'messages')|default('') }}{% endblock %}
                </div>
            </div>
        </div>

        <div class="fa-auth-left__footer">
            <p>{{ 'app.footer'|trans({}, 'messages') }}</p>
        </div>
    </aside>

    <main class="fa-auth-right" role="main">
        <div class="fa-auth-right__inner">
            {% block body %}{% endblock %}
        </div>
    </main>
</div>

{% block javascripts %}
    <script>
        window.addEventListener('error', function(event) {
            if (event.message && (
                event.message.includes('runtime.lastError') ||
                event.message.includes('extension port') ||
                event.message.includes('back/forward cache') ||
                event.message.includes('Receiving end does not exist')
            )) { event.preventDefault(); return true; }
        });
        window.addEventListener('unhandledrejection', function(event) {
            const message = event.reason?.message || String(event.reason);
            if (message.includes('Could not establish connection') ||
                message.includes('Receiving end does not exist')) {
                event.preventDefault();
            }
        });
        window.addEventListener('pagehide', function(event) { event.persisted = false; });
    </script>
{% endblock %}
</body>
</html>
