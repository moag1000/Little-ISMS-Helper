{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'audit_log' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_audit_row.html.twig' as _fa_audit_row %}

{% block admin_title %}{{ 'audit_log.user_activity.title'|trans({}, 'audit_log') }}{% endblock %}
{% block admin_subtitle %}
    <p class="text-muted">{{ 'audit_log.user_activity.subtitle'|trans({}, 'audit_log') }}</p>
{% endblock %}

{% block admin_content %}
<p>
    <a href="{{ path('app_audit_log_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
        <i class="fa-icon fa-icon--util-arrow-left" aria-hidden="true"></i> {{ 'common.back_to_overview'|trans({}, 'messages') }}
    </a>
</p>

{% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info' } } %}
    {% block alert_body %}
        <div class="fa-alert__title">{{ 'audit_log.user_activity.header'|trans({userName: userName}, 'audit_log') }}</div>
        <p><strong>{{ 'audit_log.user_activity.count_label'|trans({}, 'audit_log') }}:</strong> {{ auditLogs|length }}</p>
    {% endblock %}
{% endembed %}

{% if auditLogs|length > 0 %}
<div class="mt-4">
    <h2>{{ 'audit_log.user_activity.section_title'|trans({}, 'audit_log') }}</h2>

    {# Aurora fa-audit-feed (CRUD change-log per #480 canonical pattern) #}
    <div class="fa-audit-feed mt-3">
        {% for log in auditLogs %}
            {%- set sev = log.action in ['delete', 'force_delete'] ? 'danger'
                : (log.action in ['error', 'failed'] ? 'danger'
                : (log.action in ['update', 'login_failed'] ? 'warning'
                : 'info')) -%}
            {{ _fa_audit_row.render({
                ts:     log.createdAt|date('Y-m-d H:i:s'),
                sev:    sev,
                actor:  log.userName|default('system'),
                action: log.action,
                target: log.entityType ~ (log.entityId ? '#' ~ log.entityId : ''),
                pill:   log.description|default('')|slice(0, 60),
                hash:   log.id|default('')|slice(0, 12)
            }) }}
            {# Entity + detail navigation rendered below each row #}
            <div class="small ps-1 pb-1 d-flex gap-3">
                {% if log.entityId %}
                <a href="{{ path('app_audit_log_entity', {entityType: log.entityType, entityId: log.entityId}) }}" class="link-primary">
                    {{ log.entityType }} #{{ log.entityId }}
                </a>
                {% endif %}
                <a href="{{ path('app_audit_log_detail', {id: log.id}) }}" class="link-primary">
                    {{ 'audit_log.action.view_details'|trans({}, 'audit_log') }}
                </a>
            </div>
        {% endfor %}
    </div>
</div>
{% else %}
{{ _fa_alert.render({ variant: 'info', class: 'mt-4', body: 'audit_log.message.no_user_activities'|trans({}, 'audit_log') }) }}
{% endif %}

{% endblock %}
