{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block admin_title %}{{ 'entity_history.title'|trans({}, 'messages') }}{% endblock %}
{% block admin_subtitle %}
    <p class="text-muted">{{ 'entity_history.subtitle'|trans({}, 'messages') }}</p>
{% endblock %}

{% block admin_content %}
<p>
    <a href="{{ path('app_audit_log_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
        <i class="fa-icon fa-icon--util-arrow-left" aria-hidden="true"></i> {{ 'common.back_to_overview'|trans({}, 'messages') }}
    </a>
</p>

{% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info' } } %}
    {% block alert_body %}
        <div class="fa-alert__title">{{ entityType }} #{{ entityId }}</div>
        <p><strong>{{ 'entity_history.entry_count'|trans({}, 'messages') }}</strong> {{ auditLogs|length }}</p>
    {% endblock %}
{% endembed %}

{% if auditLogs|length > 0 %}
<div class="mt-4">
    <h2>{{ 'entity_history.section'|trans({}, 'messages') }}</h2>

    {# Aurora ISMS-Trail Timeline (per docs/design_system/sections/isms-patterns.html § Audit-Trail) #}
    <div class="isms-trail mt-4">
        {% for log in auditLogs %}
            {% set tone = log.action == 'create' ? 'success'
                : (log.action == 'delete' ? 'danger'
                : (log.action in ['update', 'modify', 'change'] ? 'warning' : 'neutral')) %}
            {% set icon = log.action == 'create' ? 'fa-icon--ui-plus'
                : (log.action == 'delete' ? 'fa-icon--ui-delete'
                : (log.action in ['update', 'modify', 'change'] ? 'fa-icon--ui-edit'
                : (log.action == 'login' ? 'fa-icon--ui-lock' : 'fa-icon--ui-circle'))) %}
            <article class="isms-trail__entry">
                <span class="isms-trail__dot isms-trail__dot--{{ tone }}" aria-hidden="true">
                    <i class="fa-icon {{ icon }}"></i>
                </span>
                <div class="isms-trail__head">
                    <span class="isms-trail__title">{{ log.action|capitalize }}</span>
                    <span class="isms-trail__meta">{{ log.createdAt|date('d.m.Y H:i:s') }}</span>
                </div>
                <div class="isms-trail__body">
                    <a href="{{ path('app_audit_log_user', {userName: log.userName}) }}" class="isms-trail__actor">
                        <i class="fa-icon fa-icon--nav-users" aria-hidden="true"></i>
                        {{ log.userName }}
                    </a>
                    {{ log.description|default('—') }}
                    <a href="{{ path('app_audit_log_detail', {id: log.id}) }}"
                       class="ms-2 link-primary small">
                        {{ 'entity_history.show_details'|trans({}, 'messages') }}
                    </a>
                </div>
            </article>
        {% endfor %}
    </div>
</div>
{% else %}
{{ _fa_alert.render({ variant: 'info', class: 'mt-4', body: 'entity_history.no_entries'|trans({}, 'messages') }) }}
{% endif %}

{% endblock %}
