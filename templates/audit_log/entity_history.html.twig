{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'audit_log' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_audit_row.html.twig' as _fa_audit_row %}

{% block admin_title %}{{ 'entity_history.title'|trans({}, 'messages') }}{% endblock %}
{% block admin_subtitle %}
    <p class="text-muted">{{ 'entity_history.subtitle'|trans({}, 'messages') }}</p>
{% endblock %}

{% block admin_content %}
<p>
    <a href="{{ path('app_audit_log_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
        <i class="fa-icon fa-icon--util-arrow-left" aria-hidden="true"></i> {{ 'common.back_to_overview'|trans({}, 'messages') }}
    </a>
</p>

{% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info' } } %}
    {% block alert_body %}
        <div class="fa-alert__title">{{ entityType }} #{{ entityId }}</div>
        <p><strong>{{ 'entity_history.entry_count'|trans({}, 'messages') }}</strong> {{ auditLogs|length }}</p>
    {% endblock %}
{% endembed %}

{% if auditLogs|length > 0 %}
<div class="mt-4">
    <h2>{{ 'entity_history.section'|trans({}, 'messages') }}</h2>

    {# Aurora fa-audit-feed (CRUD change-log per #480 canonical pattern) #}
    <div class="fa-audit-feed mt-4">
        {% for log in auditLogs %}
            {%- set sev = log.action in ['delete', 'force_delete'] ? 'danger'
                : (log.action in ['error', 'failed'] ? 'danger'
                : (log.action in ['update', 'modify', 'change', 'login_failed'] ? 'warning'
                : 'info')) -%}
            {{ _fa_audit_row.render({
                ts:     log.createdAt|date('Y-m-d H:i:s'),
                sev:    sev,
                actor:  log.userName,
                action: log.action,
                target: log.entityType ~ '#' ~ log.entityId,
                pill:   log.description|default('')|slice(0, 60),
                hash:   log.id|default('')|slice(0, 12)
            }) }}
            {# Actor profile + detail navigation rendered below each row #}
            <div class="small ps-1 pb-1 d-flex gap-3">
                <a href="{{ path('app_audit_log_user', {userName: log.userName}) }}" class="link-primary">
                    <i class="fa-icon fa-icon--nav-users" aria-hidden="true"></i>
                    {{ log.userName }}
                </a>
                <a href="{{ path('app_audit_log_detail', {id: log.id}) }}" class="link-primary">
                    {{ 'entity_history.show_details'|trans({}, 'messages') }}
                </a>
            </div>
        {% endfor %}
    </div>
</div>
{% else %}
{{ _fa_alert.render({ variant: 'info', class: 'mt-4', body: 'entity_history.no_entries'|trans({}, 'messages') }) }}
{% endif %}

{% endblock %}
