{# V3 W2-H4 — Auto-Training-Assignment notification.
   ISO 27001 Cl. 7.4 (Communication) + A.6.3 (Awareness). #}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <title>{{ 'emails.auto_reaction.training.subject'|trans({}, 'emails')|default('Mandatory training assigned') }}</title>
</head>
<body style="font-family: Arial, sans-serif; line-height: 1.6; color: #333;">
    <div style="max-width: 600px; margin: 0 auto; padding: 20px;">
        <div style="background: #0891b2; color: white; padding: 20px; border-radius: 6px 6px 0 0;">
            <h1 style="margin: 0; font-size: 18px;">
                {{ 'emails.auto_reaction.training.title'|trans({}, 'emails')|default('Mandatory Training Assigned') }}
            </h1>
        </div>

        <div style="background: #f9fafb; padding: 20px; border: 1px solid #e5e7eb; border-radius: 0 0 6px 6px;">
            <p>{{ 'emails.auto_reaction.training.greeting'|trans({}, 'emails')|default('Welcome,') }} {{ user.firstName|default(user.email) }},</p>
            <p>{{ 'emails.auto_reaction.training.intro'|trans({}, 'emails')|default('You have been auto-enrolled in the following mandatory training(s):') }}</p>

            <ul style="background: white; padding: 12px 12px 12px 32px; border-left: 4px solid #0891b2; margin: 16px 0;">
                {% for training in trainings %}
                    <li style="margin: 4px 0;">
                        <strong>{{ training.title|default('—') }}</strong>
                        {% if training.dueDate is defined and training.dueDate %}
                            — Due {{ training.dueDate|date('Y-m-d') }}
                        {% endif %}
                    </li>
                {% endfor %}
            </ul>

            <p style="font-size: 13px; color: #666; margin-top: 16px;">
                {{ 'emails.auto_reaction.training.footer'|trans({}, 'emails')|default('Please log in and complete the assigned training within the deadline.') }}
            </p>
        </div>
    </div>
</body>
</html>
