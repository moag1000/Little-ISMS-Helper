{# V3 W2-FV-7 — DPIA review-frist reminder. #}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <title>{{ 'emails.dpia.reminder.subject'|trans({}, 'emails')|default('DPIA review approaching') }}</title>
</head>
<body style="font-family: Arial, sans-serif; line-height: 1.6; color: #333;">
    <div style="max-width: 600px; margin: 0 auto; padding: 20px;">
        <div style="background: #d97706; color: white; padding: 20px; border-radius: 6px 6px 0 0;">
            <h1 style="margin: 0; font-size: 18px;">
                {{ 'emails.dpia.reminder.title'|trans({}, 'emails')|default('DPIA review-date approaching') }}
            </h1>
        </div>

        <div style="background: #f9fafb; padding: 20px; border: 1px solid #e5e7eb; border-radius: 0 0 6px 6px;">
            <p>{{ 'emails.dpia.reminder.intro'|trans({}, 'emails')|default('GDPR Art. 35 (11) requires the DPO to keep DPIAs current. The following DPIA has its next review-date approaching:') }}</p>

            <div style="background: white; padding: 12px; border-left: 4px solid #d97706; margin: 16px 0;">
                <p style="margin: 0;"><strong>DPIA:</strong> {{ dpia.title|default('—') }}</p>
                {% if dpia.nextReviewDate %}
                    <p style="margin: 4px 0 0 0;"><strong>Next Review:</strong> {{ dpia.nextReviewDate|date('Y-m-d') }}</p>
                {% endif %}
                <p style="margin: 4px 0 0 0;"><strong>Days remaining:</strong> {{ days_remaining }}</p>
                <p style="margin: 4px 0 0 0;"><strong>Reminder window:</strong> {{ matched_window }} days</p>
            </div>

            <p style="font-size: 13px; color: #666; margin-top: 16px;">
                {{ 'emails.dpia.reminder.footer'|trans({}, 'emails')|default('Open the DPIA in the ISMS, refresh the risk picture, and update nextReviewDate after the review.') }}
            </p>
        </div>
    </div>
</body>
</html>
