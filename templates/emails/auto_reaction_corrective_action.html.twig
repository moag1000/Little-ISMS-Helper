{# V3 W2-H4 — Auto-CorrectiveAction notification.
   ISO 27001 Cl. 7.4 (Communication) + Cl. 10.1 on major/critical finding. #}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <title>{{ 'emails.auto_reaction.ca.subject'|trans({}, 'emails')|default('Corrective Action 30-day target') }}</title>
</head>
<body style="font-family: Arial, sans-serif; line-height: 1.6; color: #333;">
    <div style="max-width: 600px; margin: 0 auto; padding: 20px;">
        <div style="background: #f59e0b; color: white; padding: 20px; border-radius: 6px 6px 0 0;">
            <h1 style="margin: 0; font-size: 18px;">
                {{ 'emails.auto_reaction.ca.title'|trans({}, 'emails')|default('Auto-Generated Corrective Action — 30-day Target') }}
            </h1>
        </div>

        <div style="background: #f9fafb; padding: 20px; border: 1px solid #e5e7eb; border-radius: 0 0 6px 6px;">
            <p>{{ 'emails.auto_reaction.ca.intro'|trans({}, 'emails')|default('A major/critical Audit-Finding triggered the auto-creation of a Corrective Action skeleton. ISO 27001 Cl. 10.1 expects timely closure:') }}</p>

            <div style="background: white; padding: 12px; border-left: 4px solid #f59e0b; margin: 16px 0;">
                <p style="margin: 0;"><strong>Finding:</strong> {{ finding.title|default('—') }}</p>
                {% if finding.severity is defined %}<p style="margin: 4px 0 0 0;"><strong>Severity:</strong> {{ finding.severity|upper }}</p>{% endif %}
                <p style="margin: 4px 0 0 0;"><strong>Corrective Action:</strong> {{ ca.title|default('—') }}</p>
                {% if plannedCompletionDate %}
                    <p style="margin: 4px 0 0 0;"><strong>Planned Completion:</strong> {{ plannedCompletionDate|date('Y-m-d') }} ({{ 'emails.auto_reaction.ca.target_30d'|trans({}, 'emails')|default('30-day target') }})</p>
                {% endif %}
            </div>

            <p style="font-size: 13px; color: #666; margin-top: 16px;">
                {{ 'emails.auto_reaction.ca.footer'|trans({}, 'emails')|default('Please confirm root-cause analysis and update the target date if needed.') }}
            </p>
        </div>
    </div>
</body>
</html>
