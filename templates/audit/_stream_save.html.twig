{# Turbo Stream after a successful in-modal InternalAudit save. #}
{% if is_new %}
    <turbo-stream action="append" target="audit-rows">
        <template>{% include 'audit/_row.html.twig' with { audit: audit } %}</template>
    </turbo-stream>
{% else %}
    <turbo-stream action="replace" target="audit-row-{{ audit.id }}">
        <template>{% include 'audit/_row.html.twig' with { audit: audit } %}</template>
    </turbo-stream>
{% endif %}
