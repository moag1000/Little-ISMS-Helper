<!DOCTYPE html>
<html lang="{{ app.request.locale|default('de') }}">
<head>
    <meta charset="UTF-8">
    <title>{{ audit.title }} - {{ 'pdf.title'|trans({}, 'audit') }}</title>
    <style>
        :root {
            --primary:       #0ea5e9;
            --surface:       #ffffff;
            --surface-2:     #f1f5f9;
            --fg:            #0f172a;
            --fg-2:          #475569;
            --fg-3:          #94a3b8;
            --border:        #cbd5e1;
            --success:       #166534;
            --success-tint:  #dcfce7;
            --danger:        #991b1b;
            --danger-tint:   #fecaca;
            --warning:       #92400e;
            --warning-tint:  #fef3c7;
            --info-tint:     #dbeafe;
            --info-text:     #1e40af;
            --violet-tint:   #e0e7ff;
            --violet-text:   #3730a3;
        }
        * { box-sizing: border-box; }
        body {
            font-family: 'DejaVu Sans', Arial, sans-serif;
            font-size: 10pt;
            line-height: 1.4;
            color: var(--fg);
            background: var(--surface);
            margin: 0;
            padding: 20px;
        }

        /* ── Cover ── */
        .report-cover {
            text-align: center;
            margin-bottom: 18px;
            border-bottom: 3px solid var(--primary);
            padding-bottom: 12px;
        }
        .report-cover h1        { color: var(--fg); margin: 0 0 4px; font-size: 16pt; text-transform: uppercase; letter-spacing: 0.5pt; }
        .report-cover .audit-nr { font-size: 11pt; color: var(--primary); font-weight: bold; }
        .report-cover .subtitle { color: var(--fg-2); font-size: 9pt; margin-top: 6px; }

        /* ── Sections ── */
        .section { margin: 14px 0; page-break-inside: avoid; }
        .section-title {
            background: var(--fg);
            color: var(--surface);
            padding: 6px 10px;
            font-size: 10pt;
            text-transform: uppercase;
            letter-spacing: 0.3pt;
            margin-bottom: 8px;
        }

        /* ── Info grid (CSS table for dompdf) ── */
        .info-grid  { display: table; width: 100%; border-collapse: collapse; }
        .info-row   { display: table-row; }
        .info-label { display: table-cell; width: 30%; padding: 5px 8px; background: var(--surface-2); font-weight: bold; border: 1px solid var(--border); font-size: 8.5pt; }
        .info-value { display: table-cell; padding: 5px 8px; border: 1px solid var(--border); font-size: 8.5pt; }

        /* ── Status badges ── */
        .status-badge { display: inline-block; padding: 2px 7px; border-radius: 3px; font-size: 7.5pt; font-weight: bold; text-transform: uppercase; }
        .status-planned     { background: var(--warning-tint); color: var(--warning); }
        .status-in_progress { background: var(--info-tint);   color: var(--info-text); }
        .status-completed   { background: var(--success-tint); color: var(--success); }
        .status-reported    { background: var(--violet-tint);  color: var(--violet-text); }

        /* ── Content boxes ── */
        .content-box { background: var(--surface-2); border: 1px solid var(--border); padding: 8px; margin: 4px 0; font-size: 8.5pt; }

        /* ── Findings ── */
        .findings-section   { margin-top: 12px; }
        .finding-type       { font-weight: bold; color: var(--fg); margin-bottom: 4px; font-size: 9.5pt; }
        .finding-type.non-conformities { color: var(--danger); }
        .finding-type.observations     { color: var(--warning); }
        .finding-type.recommendations  { color: var(--primary); }

        /* ── Assets table ── */
        table.assets-table         { width: 100%; border-collapse: collapse; margin: 8px 0; font-size: 8.5pt; }
        table.assets-table th      { background: var(--fg); color: var(--surface); padding: 5px; text-align: left; border: 1px solid var(--border); }
        table.assets-table td      { padding: 4px 5px; border: 1px solid var(--border); }
        table.assets-table tr:nth-child(even) { background: var(--surface-2); }

        /* ── Helpers ── */
        .page-break { page-break-before: always; }

        /* ── Footer ── */
        .report-footer { position: fixed; bottom: 0; left: 0; right: 0; text-align: center; font-size: 7.5pt; color: var(--fg-3); padding: 8px; border-top: 1px solid var(--border); }
    </style>
</head>
<body>
    <div class="report-cover">
        <h1>{{ 'pdf.title'|trans({}, 'audit') }}</h1>
        <div class="audit-nr">{{ audit.auditNumber }}</div>
        <div class="subtitle">{{ audit.title }}</div>
    </div>

    {# Basic Information #}
    <div class="section">
        <div class="section-title">{{ 'pdf.section.audit_information'|trans({}, 'audit') }}</div>
        <div class="info-grid">
            <div class="info-row">
                <div class="info-label">{{ 'pdf.label.audit_number'|trans({}, 'audit') }}</div>
                <div class="info-value">{{ audit.auditNumber }}</div>
            </div>
            <div class="info-row">
                <div class="info-label">{{ 'pdf.label.title'|trans({}, 'audit') }}</div>
                <div class="info-value">{{ audit.title }}</div>
            </div>
            <div class="info-row">
                <div class="info-label">{{ 'pdf.label.status'|trans({}, 'audit') }}</div>
                <div class="info-value">
                    <span class="status-badge status-{{ audit.status }}">{{ ('audit.status.' ~ audit.status)|trans({}, 'audit') }}</span>
                </div>
            </div>
            <div class="info-row">
                <div class="info-label">{{ 'pdf.label.scope_type'|trans({}, 'audit') }}</div>
                <div class="info-value">{{ audit.scopeType ? ('audit.scope_type.' ~ audit.scopeType)|trans({}, 'audit') : ('pdf.default_scope'|trans({}, 'audit')) }}</div>
            </div>
            <div class="info-row">
                <div class="info-label">{{ 'pdf.label.lead_auditor'|trans({}, 'audit') }}</div>
                <div class="info-value">{{ audit.leadAuditor }}</div>
            </div>
            {% if audit.auditTeam %}
            <div class="info-row">
                <div class="info-label">{{ 'pdf.label.audit_team'|trans({}, 'audit') }}</div>
                <div class="info-value">{{ audit.auditTeam }}</div>
            </div>
            {% endif %}
        </div>
    </div>

    {# Dates #}
    <div class="section">
        <div class="section-title">{{ 'pdf.section.schedule'|trans({}, 'audit') }}</div>
        <div class="info-grid">
            <div class="info-row">
                <div class="info-label">{{ 'pdf.label.planned_date'|trans({}, 'audit') }}</div>
                <div class="info-value">{{ audit.plannedDate|date('d.m.Y') }}</div>
            </div>
            {% if audit.actualDate %}
            <div class="info-row">
                <div class="info-label">{{ 'pdf.label.actual_date'|trans({}, 'audit') }}</div>
                <div class="info-value">{{ audit.actualDate|date('d.m.Y') }}</div>
            </div>
            {% endif %}
            {% if audit.reportDate %}
            <div class="info-row">
                <div class="info-label">{{ 'pdf.label.report_date'|trans({}, 'audit') }}</div>
                <div class="info-value">{{ audit.reportDate|date('d.m.Y') }}</div>
            </div>
            {% endif %}
        </div>
    </div>

    {# Scope #}
    {% if audit.scope or audit.objectives or audit.auditedDepartments %}
    <div class="section">
        <div class="section-title">{{ 'pdf.section.scope_objectives'|trans({}, 'audit') }}</div>
        {% if audit.scope %}
        <div class="content-box">
            <strong>{{ 'pdf.label.scope'|trans({}, 'audit') }}:</strong><br>
            {{ audit.scope|nl2br }}
        </div>
        {% endif %}
        {% if audit.objectives %}
        <div class="content-box">
            <strong>{{ 'pdf.label.objectives'|trans({}, 'audit') }}:</strong><br>
            {{ audit.objectives|nl2br }}
        </div>
        {% endif %}
        {% if audit.auditedDepartments %}
        <div class="content-box">
            <strong>{{ 'pdf.label.audited_departments'|trans({}, 'audit') }}:</strong><br>
            {{ audit.auditedDepartments|nl2br }}
        </div>
        {% endif %}
    </div>
    {% endif %}

    {# Scoped Framework #}
    {% if audit.scopedFramework %}
    <div class="section">
        <div class="section-title">{{ 'pdf.section.compliance_framework'|trans({}, 'audit') }}</div>
        <div class="info-grid">
            <div class="info-row">
                <div class="info-label">{{ 'pdf.label.framework'|trans({}, 'audit') }}</div>
                <div class="info-value">{{ audit.scopedFramework.name }}</div>
            </div>
            {% if audit.scopedFramework.version %}
            <div class="info-row">
                <div class="info-label">{{ 'pdf.label.version'|trans({}, 'audit') }}</div>
                <div class="info-value">{{ audit.scopedFramework.version }}</div>
            </div>
            {% endif %}
        </div>
    </div>
    {% endif %}

    {# Scoped Assets #}
    {% if audit.scopedAssets|length > 0 %}
    <div class="section">
        <div class="section-title">{{ 'pdf.section.audited_assets'|trans({}, 'audit') }} ({{ audit.scopedAssets|length }})</div>
        <table class="assets-table">
            <thead>
                <tr>
                    <th scope="col">{{ 'pdf.label.asset_name'|trans({}, 'audit') }}</th>
                    <th scope="col">{{ 'pdf.label.type'|trans({}, 'audit') }}</th>
                    <th scope="col">{{ 'pdf.label.status'|trans({}, 'audit') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for asset in audit.scopedAssets %}
                <tr>
                    <td>{{ asset.name }}</td>
                    <td>{{ asset.assetType|default('-')|replace({'_': ' '})|title }}</td>
                    <td>{{ asset.status|default('-') }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% endif %}

    {# Findings #}
    {% if audit.findings or audit.nonConformities or audit.observations or audit.recommendations %}
    <div class="section page-break">
        <div class="section-title">{{ 'pdf.section.audit_findings'|trans({}, 'audit') }}</div>

        {% if audit.findings %}
        <div class="findings-section">
            <div class="finding-type">{{ 'pdf.findings.general'|trans({}, 'audit') }}</div>
            <div class="content-box">{{ audit.findings|nl2br }}</div>
        </div>
        {% endif %}

        {% if audit.nonConformities %}
        <div class="findings-section">
            <div class="finding-type non-conformities">{{ 'pdf.findings.non_conformities'|trans({}, 'audit') }}</div>
            <div class="content-box">{{ audit.nonConformities|nl2br }}</div>
        </div>
        {% endif %}

        {% if audit.observations %}
        <div class="findings-section">
            <div class="finding-type observations">{{ 'pdf.findings.observations'|trans({}, 'audit') }}</div>
            <div class="content-box">{{ audit.observations|nl2br }}</div>
        </div>
        {% endif %}

        {% if audit.recommendations %}
        <div class="findings-section">
            <div class="finding-type recommendations">{{ 'pdf.findings.recommendations'|trans({}, 'audit') }}</div>
            <div class="content-box">{{ audit.recommendations|nl2br }}</div>
        </div>
        {% endif %}
    </div>
    {% endif %}

    {# Conclusion #}
    {% if audit.conclusion %}
    <div class="section">
        <div class="section-title">{{ 'pdf.section.conclusion'|trans({}, 'audit') }}</div>
        <div class="content-box">{{ audit.conclusion|nl2br }}</div>
    </div>
    {% endif %}

    {# Metadata #}
    <div class="section">
        <div class="section-title">{{ 'pdf.section.document_information'|trans({}, 'audit') }}</div>
        <div class="info-grid">
            <div class="info-row">
                <div class="info-label">{{ 'pdf.label.generated'|trans({}, 'audit') }}</div>
                <div class="info-value">{{ "now"|date('d.m.Y H:i') }}</div>
            </div>
            <div class="info-row">
                <div class="info-label">{{ 'pdf.label.created'|trans({}, 'audit') }}</div>
                <div class="info-value">{{ audit.createdAt|date('d.m.Y H:i') }}</div>
            </div>
            {% if audit.updatedAt %}
            <div class="info-row">
                <div class="info-label">{{ 'pdf.label.last_updated'|trans({}, 'audit') }}</div>
                <div class="info-value">{{ audit.updatedAt|date('d.m.Y H:i') }}</div>
            </div>
            {% endif %}
        </div>
    </div>

    <div class="report-footer">
        {{ 'pdf.footer'|trans({'%audit_number%': audit.auditNumber, '%datetime%': "now"|date('d.m.Y H:i')}, 'audit') }}
    </div>
</body>
</html>
