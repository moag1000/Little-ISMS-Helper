{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% trans_default_domain 'audit' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'audit.new'|trans({}, 'audit') }} - {{ parent() }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="row">
        <div class="col-lg-10 col-xl-9 mx-auto">
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="{{ path('app_audit_index') }}" data-turbo-action="advance">
                            <i class="fa-icon fa-icon--sop" aria-hidden="true"></i> {{ 'audit_management.title'|trans({}, 'audit') }}
                        </a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">{{ 'audit.new'|trans({}, 'audit') }}</li>
                </ol>
            </nav>

            {{ _fa_page_header.render({
    title: ('audit.new'|trans({}, 'audit')),
    badge: { icon: 'plus', label: '' },
    actions: [
        { label: 'common.back'|trans({}, 'messages'), href: path('app_audit_index'), variant: 'ghost', icon: 'util-arrow-left' }
    ]
}) }}

            {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', icon: 'status-info', class: 'mb-4' } } %}
                {% block alert_body %}<div class="fw-bold mb-2"> <i class="fa-icon fa-icon--status-info" aria-hidden="true"></i> {{ 'audit.iso_27001_requirement'|trans({}, 'audit') }} </div> <p class="mb-0 small"> {{ 'audit.iso_27001_clause_info'|trans({}, 'audit') }} </p>{% endblock %}
            {% endembed %}

            {# C5-05 — Audit-Program Templates (ISO 19011 Cl. 5.4). Lets junior
               implementers start from a standard ISO27001 / GDPR / BCM audit
               instead of a blank form. Uses the P-14 SystemTemplateRegistry. #}
            {% set _audit_program_templates = system_templates('App\\Entity\\InternalAudit') %}
            {% if _audit_program_templates|length > 0 %}
                <div class="fa-template-cta my-3 p-3 border rounded bg-body-tertiary d-flex flex-wrap align-items-center gap-3">
                    <div class="flex-grow-1">
                        <div class="fw-semibold">
                            <i class="fa-icon fa-icon--nav-collection" aria-hidden="true"></i>
                            {{ 'system_templates.cta.button'|trans({}, 'system_templates') }}
                        </div>
                        <div class="small text-body-secondary">
                            {{ 'system_templates.cta.hint'|trans({}, 'system_templates') }}
                        </div>
                    </div>
                    <button type="button" class="btn btn-outline-primary"
                            data-controller="fa-modal-dispatcher"
                            data-action="click->fa-modal-dispatcher#open"
                            data-fa-modal-id="systemTemplateModalAuditNew">
                        {{ 'system_templates.cta.button'|trans({}, 'system_templates') }}
                    </button>
                </div>
                {% include '_components/_system_template_selector.html.twig' with {
                    templates: _audit_program_templates,
                    entity_class: 'App\\Entity\\InternalAudit',
                    redirect_to: 'app_audit_index',
                    modal_id: 'systemTemplateModalAuditNew'
                } %}
            {% endif %}

            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header">
                        <h2 class="mb-0"><i class="fa-icon fa-icon--ui-copy" aria-hidden="true"></i> {{ 'audit.new'|trans({}, 'audit') }}</h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {# C5-04 — `conditional-fields` controller toggles the scoped-assets row
                       when scopeType=asset (ISO 19011 Cl. 5.5.2). The existing
                       audit-subsidiaries controller continues to manage subsidiaries. #}
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'id': 'audit-form', 'data-controller': 'audit-subsidiaries conditional-fields'}}) }}

                    {# Basic Information Section #}
                    <fieldset class="mb-4">
                        <legend class="h3 mb-3">
                            <i class="fa-icon fa-icon--ui-info" aria-hidden="true"></i>
                            {{ 'audit.section.basic_info'|trans({}, 'audit') }}
                        </legend>

                        <div class="row">
                            <div class="col-md-12">
                                {% include '_components/_form_field.html.twig' with {
                                    'field': form.title,
                                    'label_key': form.title.vars.label,
                                    'translation_domain': 'audit',
                                    'required': true
                                } %}
                            </div>
                            <div class="col-md-12">
                                {% include '_components/_form_field.html.twig' with {
                                    'field': form.scope,
                                    'label_key': form.scope.vars.label,
                                    'translation_domain': 'audit'
                                } %}
                            </div>
                            <div class="col-md-6">
                                {% include '_components/_form_field.html.twig' with {
                                    'field': form.scopeType,
                                    'label_key': form.scopeType.vars.label,
                                    'translation_domain': 'audit'
                                } %}
                            </div>
                            <div class="col-md-6">
                                {% include '_components/_form_field.html.twig' with {
                                    'field': form.scopedFramework,
                                    'label_key': form.scopedFramework.vars.label,
                                    'translation_domain': 'audit'
                                } %}
                            </div>
                            <div class="col-md-12 d-none" id="subsidiaries-container">
                                {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', icon: 'status-info' } } %}
                                    {% block alert_body %}<strong>{{ 'audit.corporate_audit_note_title'|trans({}, 'audit') }}:</strong> {{ 'audit.corporate_audit_note'|trans({}, 'audit') }}{% endblock %}
                                {% endembed %}
                                {% include '_components/_form_field.html.twig' with {
                                    'field': form.auditedSubsidiaries,
                                    'label_key': form.auditedSubsidiaries.vars.label,
                                    'translation_domain': 'audit'
                                } %}
                            </div>
                            {# C5-04 — scopedAssets row, toggled by conditional-fields controller when scopeType=asset (ISO 19011 Cl. 5.5.2). #}
                            <div class="col-md-12">
                                {% include '_components/_form_field.html.twig' with {
                                    'field': form.scopedAssets,
                                    'label_key': form.scopedAssets.vars.label,
                                    'translation_domain': 'audit'
                                } %}
                            </div>
                        </div>
                    </fieldset>

                    {% include '_components/_auto_form.html.twig' with {
                        'form': form,
                        'sections': {
                            'schedule': {
                                'label': 'audit.section.schedule'|trans({}, 'audit'),
                                'fields': ['plannedDate', 'actualDate']
                            },
                            'team': {
                                'label': 'audit.section.team'|trans({}, 'audit'),
                                'fields': ['leadAuditor', 'status', 'auditTeam']
                            },
                            'objectives': {
                                'label': 'audit.section.objectives'|trans({}, 'audit'),
                                'fields': ['objectives']
                            },
                            'findings': {
                                'label': 'audit.section.findings'|trans({}, 'audit'),
                                'fields': ['findings', 'recommendations', 'conclusion']
                            }
                        },
                        'col_widths': {
                            'plannedDate': 6,
                            'actualDate': 6,
                            'leadAuditor': 6,
                            'status': 6
                        },
                        'exclude': ['title', 'scope', 'scopeType', 'scopedFramework', 'auditedSubsidiaries', 'scopedAssets']
                    } %}

                    {# Form Actions #}
                    <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                        <a href="{{ path('app_audit_index') }}"
                           class="fa-cyber-btn fa-cyber-btn--ghost"
                           data-turbo-action="advance">
                            <i class="fa-icon fa-icon--util-arrow-left" aria-hidden="true"></i> {{ 'common.back'|trans({}, 'messages') }}
                        </a>
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--lg">
                            <i class="fa-icon fa-icon--ui-save" aria-hidden="true"></i> {{ 'audit.create'|trans({}, 'audit') }}
                        </button>
                    </div>

                    {{ form_end(form) }}
                {% endblock %}
            {% endembed %}
        </div>
    </div>
</div>

<style>
    .form-check-input {
        cursor: pointer;
    }
    .form-check-label {
        cursor: pointer;
    }
    select[multiple] {
        min-height: 150px;
    }
</style>

{% endblock %}
