{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_status_pill.html.twig' as pill %}
{% import '_components/_fa_status_chip.html.twig' as _fa_status_chip %}
{% import '_components/_lifecycle_actions.html.twig' as _lifecycle_actions %}
{% import '_components/_lifecycle_history_tab.html.twig' as _lifecycle_history %}
{% trans_default_domain 'audit' %}

{% block title %}{{ audit.title }} - {{ parent() }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'audit_management.title'|trans({}, 'audit'), url: path('app_audit_index') },
            { label: audit.title }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'nav-clipboard-check', label: audit.auditNumber|default('audit_management.title'|trans({}, 'audit')) },
        title: audit.title,
        subtitle: ('audit.status.' ~ audit.status)|trans({}, 'audit')
    }) }}

    {# Lifecycle X.3b — status chip + transition dropdown #}
    <div class="d-flex align-items-center gap-2 mb-3" data-testid="lifecycle-toolbar">
        {{ _fa_status_chip.render({ entity_class: 'App\\Entity\\Audit', status_key: audit.status }) }}
        {{ _lifecycle_actions.dropdown(audit, 'internal-audit', 'internal_audit_lifecycle') }}
    </div>

    {# S3 P0-26 — Audit-Bericht 4-Augen-Approval-Workflow (ISO 27001 Cl. 9.2.2 d) #}
    <div class="mb-3 d-flex align-items-center gap-2 flex-wrap">
        <span class="text-muted small">{{ 'audit.field.status'|trans({}, 'audit') }}:</span>
        {{ pill.render(('audit.status.' ~ audit.status)|trans({}, 'audit'), audit.statusTone) }}
        {% if audit.reportedAt %}
            <span class="text-muted small ms-2">
                <i class="fa-icon fa-icon--ui-calendar-event" aria-hidden="true"></i>
                {{ 'audit.field.reported_at'|trans({}, 'audit') }}: {{ audit.reportedAt|date('d.m.Y H:i') }}
            </span>
        {% endif %}
        {% if audit.approvedAt %}
            <span class="text-muted small ms-2">
                <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
                {{ 'audit.field.approved_at'|trans({}, 'audit') }}: {{ audit.approvedAt|date('d.m.Y H:i') }}
            </span>
        {% endif %}
    </div>

    <div class="row">
        <div class="col-lg-8">
            {# Main Audit Information #}
            {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
                {% block card_header %}
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h2 class="mb-0">
                            <i class="fa-icon fa-icon--sop" aria-hidden="true"></i> {{ audit.title }}
                        </h2>
                        <span class="{{ badge_status(audit.status) }} fs-6">
                            {{ ('audit.status.' ~ audit.status)|trans({}, 'audit') }}
                        </span>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {# Audit Number #}
                    <div class="mb-3">
                        {% include '_components/_badge.html.twig' with { variant: 'dark', size: 'lg', content: audit.auditNumber } %}
                    </div>

                    {# Scope #}
                    <div class="mb-4">
                        <h3><i class="fa-icon fa-icon--nav-bullseye" aria-hidden="true"></i> {{ 'audit.scope'|trans({}, 'audit') }}</h3>
                        <p class="text-muted">{{ audit.scope ? audit.scope|nl2br : '-' }}</p>
                        <div class="mt-2">
                            {% include '_components/_badge.html.twig' with { variant: 'secondary', content: ('audit.scope_type.' ~ audit.scopeType)|trans({}, 'audit') } %}
                        </div>

                        {# Corporate Audit Subsidiaries #}
                        {% if audit.auditedSubsidiaries|length > 0 %}
                        <div class="mt-3 p-3 border border-primary rounded bg-body-secondary">
                            <div class="text-primary mb-2 fw-bold">
                                <i class="fa-icon fa-icon--nav-building" aria-hidden="true"></i> {{ 'audit.field.audited_subsidiaries'|trans({}, 'audit') }}
                            </div>
                            <div class="d-flex flex-wrap gap-2">
                                {% for subsidiary in audit.auditedSubsidiaries %}
                                {% include '_components/_badge.html.twig' with { variant: 'primary', content: subsidiary.name } %}
                                {% endfor %}
                            </div>
                            <small class="text-muted d-block mt-2">
                                <i class="fa-icon fa-icon--status-info" aria-hidden="true"></i>
                                {{ 'audit.message.corporate_subsidiaries_info'|trans({'%count%': audit.auditedSubsidiaries|length}, 'audit') }}
                            </small>
                        </div>
                        {% endif %}

                        {# Scoped Assets #}
                        {% if audit.scopedAssets|length > 0 %}
                        <div class="mt-3 p-3 border border-info rounded bg-body-secondary">
                            <div class="text-info mb-2 fw-bold">
                                <i class="fa-icon fa-icon--nav-hdd" aria-hidden="true"></i> {{ 'audit.field.scoped_assets'|trans({}, 'audit') }}
                            </div>
                            <div class="d-flex flex-wrap gap-2">
                                {% for asset in audit.scopedAssets %}
                                {% include '_components/_badge.html.twig' with { variant: 'info', content: asset.name } %}
                                {% endfor %}
                            </div>
                        </div>
                        {% endif %}
                    </div>
                    <hr>

                    {# Framework & Objectives #}
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="text-muted mb-2 fw-semibold">
                                <i class="fa-icon fa-icon--compliance-shield" aria-hidden="true"></i> {{ 'audit.field.scoped_framework'|trans({}, 'audit') }}
                            </div>
                            <p>
                                {% if audit.scopedFramework %}
                                    {% include '_components/_badge.html.twig' with { variant: 'primary', size: 'lg', content: audit.scopedFramework.name } %}
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </p>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted mb-2 fw-semibold">{{ 'audit.field.audited_departments'|trans({}, 'audit') }}</div>
                            <p>{{ audit.auditedDepartments ?? '-' }}</p>
                        </div>
                    </div>

                    {# Dates #}
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="text-muted mb-2 fw-semibold">
                                <i class="fa-icon fa-icon--ui-calendar-event" aria-hidden="true"></i> {{ 'audit.planned_date'|trans({}, 'audit') }}
                            </div>
                            <p class="fs-5">{{ audit.plannedDate|date('d.m.Y') }}</p>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted mb-2 fw-semibold">
                                <i class="fa-icon fa-icon--nav-calendar-check" aria-hidden="true"></i> {{ 'audit.actual_date'|trans({}, 'audit') }}
                            </div>
                            <p class="fs-5">{{ audit.actualDate ? audit.actualDate|date('d.m.Y') : '-' }}</p>
                        </div>
                    </div>

                    {# Team #}
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="text-muted mb-2 fw-semibold">
                                <i class="fa-icon fa-icon--ui-person" aria-hidden="true"></i> {{ 'audit.lead_auditor'|trans({}, 'audit') }}
                            </div>
                            <p>{{ audit.leadAuditor ?? '-' }}</p>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted mb-2 fw-semibold">
                                <i class="fa-icon fa-icon--group" aria-hidden="true"></i> {{ 'audit.audit_team'|trans({}, 'audit') }}
                            </div>
                            <p>{{ audit.auditTeam ? audit.auditTeam|nl2br : '-' }}</p>
                        </div>
                    </div>

                    {# Objectives #}
                    {% if audit.objectives %}
                    <div class="mb-4">
                        <div class="text-muted mb-2 fw-semibold">
                            <i class="fa-icon fa-icon--nav-bullseye" aria-hidden="true"></i> {{ 'audit.field.objectives'|trans({}, 'audit') }}
                        </div>
                        <p>{{ audit.objectives|nl2br }}</p>
                    </div>
                    {% endif %}
                {% endblock %}
            {% endembed %}

            {# Findings Section #}
            {# V3 B3: Structured Findings (preferred over free-text) #}
            {% if audit.structuredFindings is defined and audit.structuredFindings|length > 0 %}
                {% set _severity_variants = {
                    'major_nc': 'danger', 'minor_nc': 'warning',
                    'observation': 'info', 'opportunity': 'success'
                } %}
                {% set _status_variants = {
                    'open': 'warning', 'in_progress': 'info',
                    'closed': 'success', 'wont_fix': 'secondary'
                } %}
                {% embed '_components/_card.html.twig' with { 'class': 'mb-4 border-warning' } %}
                    {% block card_header %}
                        {% import '_components/_status_pill.html.twig' as pill %}
                        <div class="card-header">
                            <h2 class="mb-0">
                                <i class="fa-icon fa-icon--status-warning text-warning" aria-hidden="true"></i>
                                {{ 'audit.section.structured_findings'|trans({}, 'audit') }}
                                {{ pill.render(audit.structuredFindings|length, 'warning') }}
                            </h2>
                        </div>
                    {% endblock %}
                    {% block card_body %}
                        <p class="text-muted small mb-3">{{ 'audit.section.structured_findings_help'|trans({}, 'audit') }}</p>
                        <div class="d-flex flex-column gap-2">
                            {% for finding in audit.structuredFindings %}
                                <div class="card fa-section">
                                    <div class="card-body py-2 px-3">
                                        <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                                            <a href="{{ path('app_audit_finding_show', {id: finding.id}) }}" class="text-decoration-none flex-grow-1">
                                                <strong>{{ finding.findingNumber|default('#' ~ finding.id) }} — {{ finding.title }}</strong>
                                            </a>
                                            <div class="d-flex gap-2 align-items-center">
                                                {% if finding.severity is defined and finding.severity %}
                                                    {% set _sv = _severity_variants[finding.severity]|default('secondary') %}
                                                    {% set _sv_pill = _sv == 'secondary' ? 'neutral' : (_sv == 'info' ? 'primary' : _sv) %}
                                                    {{ pill.render(('audit_finding.severity.' ~ finding.severity)|trans({}, 'audits'), _sv_pill) }}
                                                {% endif %}
                                                {% if finding.status is defined and finding.status %}
                                                    {% set _stv = _status_variants[finding.status]|default('secondary') %}
                                                    {% set _stv_pill = _stv == 'secondary' ? 'neutral' : (_stv == 'info' ? 'primary' : _stv) %}
                                                    {{ pill.render(('audit_finding.status.' ~ finding.status)|trans({}, 'audits'), _stv_pill) }}
                                                {% endif %}
                                            </div>
                                        </div>
                                        {% if finding.description %}
                                            <small class="text-muted d-block mt-1">{{ finding.description|u.truncate(160, '…') }}</small>
                                        {% endif %}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                        <div class="mt-3">
                            <a href="{{ path('app_audit_finding_new', {audit: audit.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                <i class="fa-icon fa-icon--ui-plus" aria-hidden="true"></i>
                                {{ 'audit_finding.action.new'|trans({}, 'audits') }}
                            </a>
                        </div>
                    {% endblock %}
                {% endembed %}
            {% endif %}

            {% if audit.findings or audit.nonConformities or audit.observations %}
            {% embed '_components/_card.html.twig' with { 'class': 'mb-4 border-warning' } %}
                {% block card_header %}
                    <div class="card-header">
                        <h2 class="mb-0">
                            <i class="fa-icon fa-icon--status-warning text-warning" aria-hidden="true"></i> {{ 'audit.section.findings'|trans({}, 'audit') }}
                        </h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {% if audit.findings %}
                    <div class="mb-3">
                        <h3 class="h6">{{ 'audit.findings'|trans({}, 'audit') }}</h3>
                        <p>{{ audit.findings|nl2br }}</p>
                    </div>
                    {% endif %}

                    {% if audit.nonConformities %}
                    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'danger', class: 'mb-3' } } %}
                        {% block alert_body %}<h3 class="h6 alert-heading">{{ 'audit.nonconformities'|trans({}, 'audit') }}</h3> <p class="mb-0">{{ audit.nonConformities|nl2br }}</p>{% endblock %}
                    {% endembed %}
                    {% endif %}

                    {% if audit.observations %}
                    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', class: 'mb-0' } } %}
                        {% block alert_body %}<h3 class="h6 alert-heading">{{ 'audit.observations'|trans({}, 'audit') }}</h3> <p class="mb-0">{{ audit.observations|nl2br }}</p>{% endblock %}
                    {% endembed %}
                    {% endif %}
                {% endblock %}
            {% endembed %}
            {% endif %}

            {# Recommendations & Conclusion #}
            {% if audit.recommendations or audit.conclusion %}
            {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
                {% block card_header %}
                    <div class="card-header bg-body-secondary">
                        <h2 class="mb-0">
                            <i class="fa-icon fa-icon--ui-lightbulb" aria-hidden="true"></i> {{ 'audit.section.recommendations'|trans({}, 'audit') }}
                        </h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {% if audit.recommendations %}
                    <div class="mb-3">
                        <h3 class="h6">{{ 'audit.recommendations'|trans({}, 'audit') }}</h3>
                        <p>{{ audit.recommendations|nl2br }}</p>
                    </div>
                    {% endif %}

                    {% if audit.conclusion %}
                    <div class="mb-0">
                        <h3 class="h6">{{ 'audit.conclusion'|trans({}, 'audit') }}</h3>
                        <p>{{ audit.conclusion|nl2br }}</p>
                    </div>
                    {% endif %}
                {% endblock %}
            {% endembed %}
            {% endif %}
        </div>

        <div class="col-lg-4">
            {# S3 P0-26 — Audit-Bericht 4-Augen-Approval-Workflow (ISO 27001 Cl. 9.2.2 d) #}
            {% set _current_user_id = app.user ? app.user.id : null %}
            {% set _reported_by_current = audit.reportedBy and _current_user_id and audit.reportedBy.id == _current_user_id %}
            {% set _can_submit  = audit.canTransitionTo('reported') and audit.status in ['planned', 'conducted', 'in_progress', 'completed'] %}
            {% set _can_resubmit = audit.status == 'rejected' %}
            {% set _can_approve = audit.status == 'reported' and not _reported_by_current %}
            {% set _can_reject  = audit.status == 'reported' and not _reported_by_current %}
            {% set _can_close   = audit.status == 'approved' %}

            {% if audit.status == 'rejected' and audit.rejectionReason %}
                {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'danger', class: 'mb-4' } } %}
                    {% block alert_body %}
                        <h3 class="h6 alert-heading">
                            <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i>
                            {{ 'audit.field.rejection_reason'|trans({}, 'audit') }}
                        </h3>
                        <p class="mb-0">{{ audit.rejectionReason|nl2br }}</p>
                    {% endblock %}
                {% endembed %}
            {% endif %}

            {% if _can_submit or _can_resubmit or _can_approve or _can_reject or _can_close %}
            {% embed '_components/_card.html.twig' with { 'class': 'mb-4 border-accent' } %}
                {% block card_header %}
                    <div class="card-header">
                        <h2 class="h6 mb-0">
                            <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
                            {{ 'audit.section.approval_workflow'|trans({}, 'audit') }}
                        </h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <p class="text-muted small mb-3">
                        {{ 'audit.help.approval_workflow'|trans({}, 'audit') }}
                    </p>
                    <div class="d-grid gap-2">
                        {% if _can_submit and is_granted('ROLE_USER') %}
                            <form method="post" action="{{ path('app_audit_submit_report', {id: audit.id}) }}" class="d-grid">
                                <input type="hidden" name="_token" value="{{ csrf_token('audit_submit_report') }}">
                                <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary" data-turbo="false">
                                    <i class="fa-icon fa-icon--ui-send" aria-hidden="true"></i>
                                    {{ 'audit.action.submit_report'|trans({}, 'audit') }}
                                </button>
                            </form>
                        {% endif %}

                        {% if _can_resubmit and is_granted('ROLE_USER') %}
                            <form method="post" action="{{ path('app_audit_resubmit_report', {id: audit.id}) }}" class="d-grid">
                                <input type="hidden" name="_token" value="{{ csrf_token('audit_resubmit_report') }}">
                                <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary" data-turbo="false">
                                    <i class="fa-icon fa-icon--ui-send" aria-hidden="true"></i>
                                    {{ 'audit.action.resubmit_report'|trans({}, 'audit') }}
                                </button>
                            </form>
                        {% endif %}

                        {% if _can_approve and is_granted('ROLE_AUDITOR') %}
                            <form method="post" action="{{ path('app_audit_approve_report', {id: audit.id}) }}" class="d-grid">
                                <input type="hidden" name="_token" value="{{ csrf_token('audit_approve_report') }}">
                                <button type="submit" class="fa-cyber-btn fa-cyber-btn--success" data-turbo="false">
                                    <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
                                    {{ 'audit.action.approve_report'|trans({}, 'audit') }}
                                </button>
                            </form>
                        {% endif %}

                        {% if _can_reject and is_granted('ROLE_AUDITOR') %}
                            <button type="button"
                                    class="fa-cyber-btn fa-cyber-btn--danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#rejectModal">
                                <i class="fa-icon fa-icon--ui-x" aria-hidden="true"></i>
                                {{ 'audit.action.reject_report'|trans({}, 'audit') }}
                            </button>
                        {% endif %}

                        {% if _can_close and is_granted('ROLE_MANAGER') %}
                            <form method="post" action="{{ path('app_audit_close', {id: audit.id}) }}" class="d-grid">
                                <input type="hidden" name="_token" value="{{ csrf_token('audit_close') }}">
                                <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost" data-turbo="false">
                                    <i class="fa-icon fa-icon--archive" aria-hidden="true"></i>
                                    {{ 'audit.action.close_audit'|trans({}, 'audit') }}
                                </button>
                            </form>
                        {% endif %}

                        {% if audit.status == 'reported' and _reported_by_current %}
                            {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', class: 'mb-0 mt-2' } } %}
                                {% block alert_body %}
                                    <small class="mb-0">{{ 'audit.error.same_user_approve'|trans({}, 'audit') }}</small>
                                {% endblock %}
                            {% endembed %}
                        {% endif %}
                    </div>

                    {# Approval metadata #}
                    {% if audit.reportedBy or audit.approvedBy or audit.closedBy %}
                        <hr>
                        <dl class="row mb-0 small">
                            {% if audit.reportedBy %}
                                <dt class="col-sm-6 text-muted">{{ 'audit.field.reported_by'|trans({}, 'audit') }}</dt>
                                <dd class="col-sm-6 text-end">{{ audit.reportedBy.email|default('—') }}</dd>
                            {% endif %}
                            {% if audit.approvedBy %}
                                <dt class="col-sm-6 text-muted">{{ 'audit.field.approved_by'|trans({}, 'audit') }}</dt>
                                <dd class="col-sm-6 text-end">{{ audit.approvedBy.email|default('—') }}</dd>
                            {% endif %}
                            {% if audit.closedBy %}
                                <dt class="col-sm-6 text-muted">{{ 'audit.field.closed_by'|trans({}, 'audit') }}</dt>
                                <dd class="col-sm-6 text-end">{{ audit.closedBy.email|default('—') }}</dd>
                                <dt class="col-sm-6 text-muted">{{ 'audit.field.closed_at'|trans({}, 'audit') }}</dt>
                                <dd class="col-sm-6 text-end">{{ audit.closedAt|date('d.m.Y H:i') }}</dd>
                            {% endif %}
                        </dl>
                    {% endif %}
                {% endblock %}
            {% endembed %}
            {% endif %}

            {# Action Buttons #}
            {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
                {% block card_header %}
                    <div class="card-header bg-body-secondary">
                        <h2 class="h6 mb-0"><i class="fa-icon fa-icon--nav-tools" aria-hidden="true"></i> {{ 'common.actions'|trans({}, 'messages') }}</h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="d-grid gap-2">
                        {% if is_granted('ROLE_USER') %}
                        <a href="{{ path('app_audit_edit', {id: audit.id}) }}"
                           class="fa-cyber-btn fa-cyber-btn--primary"
                           data-turbo-action="advance">
                            <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i> {{ 'common.edit'|trans({}, 'messages') }}
                        </a>
                        {% if audit.isComplianceAudit() %}
                        <a href="{{ path('app_audit_checklist', {id: audit.id}) }}" class="fa-cyber-btn fa-cyber-btn--primary">
                            <i class="fa-icon fa-icon--ui-checklist" aria-hidden="true"></i>
                            {{ 'checklist.title'|trans({}, 'audit') }}
                        </a>
                        {% endif %}
                        {% endif %}

                        <div>
                            <a href="{{ path('app_audit_export_pdf', {id: audit.id}) }}"
                               class="fa-cyber-btn fa-cyber-btn--danger"
                               data-turbo="false">
                                <i class="fa-icon fa-icon--nav-file-pdf" aria-hidden="true"></i> {{ 'audit.export_pdf'|trans({}, 'audit') }}
                            </a>
                            {% include '_components/_fa_pdf_locale_switch.html.twig' with {route: 'app_audit_export_pdf', route_params: {id: audit.id}} only %}
                        </div>

                        {% if is_granted('ROLE_MANAGER') %}
                            <form method="post" action="{{ path('app_audit_clone', {id: audit.id}) }}" class="d-grid">
                                <input type="hidden" name="_token" value="{{ csrf_token('clone_audit_' ~ audit.id) }}">
                                <button type="submit" class="fa-cyber-btn fa-cyber-btn--success" data-turbo="false">
                                    <i class="fa-icon fa-icon--ui-copy" aria-hidden="true"></i>
                                    {{ 'audit.action.clone'|trans({}, 'audits') }}
                                </button>
                            </form>
                        {% endif %}

                        <a href="{{ path('app_audit_index') }}"
                           class="fa-cyber-btn fa-cyber-btn--ghost"
                           data-turbo-action="advance">
                            <i class="fa-icon fa-icon--util-arrow-left" aria-hidden="true"></i> {{ 'common.back_to_list'|trans({}, 'messages') }}
                        </a>

                        {% if is_granted('ROLE_ADMIN') %}
                        <hr>
                        <button type="button"
                                class="fa-cyber-btn fa-cyber-btn--danger"
                                data-bs-toggle="modal"
                                data-bs-target="#deleteModal">
                            <i class="fa-icon fa-icon--ui-trash" aria-hidden="true"></i> {{ 'common.delete'|trans({}, 'messages') }}
                        </button>
                        {% endif %}
                    </div>
                {% endblock %}
            {% endembed %}

            {# Quick Stats #}
            {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
                {% block card_header %}
                    <div class="card-header bg-body-secondary">
                        <h2 class="h6 mb-0"><i class="fa-icon fa-icon--nav-bar-chart" aria-hidden="true"></i> {{ 'audit.quick_stats'|trans({}, 'audit') }}</h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <dl class="row mb-0 small">
                        <dt class="col-sm-6 text-muted">{{ 'audit.field.scoped_framework'|trans({}, 'audit') }}</dt>
                        <dd class="col-sm-6 text-end">
                            {% if audit.scopedFramework %}
                                {% include '_components/_badge.html.twig' with { variant: 'primary', content: audit.scopedFramework.name } %}
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </dd>

                        <dt class="col-sm-6 text-muted">{{ 'audit.field.scope_type'|trans({}, 'audit') }}</dt>
                        <dd class="col-sm-6 text-end">
                            {% include '_components/_badge.html.twig' with { variant: 'secondary', content: ('audit.scope_type.' ~ audit.scopeType)|trans({}, 'audit') } %}
                        </dd>

                        {% if audit.reportDate %}
                        <dt class="col-sm-6 text-muted">{{ 'audit.report_date'|trans({}, 'audit') }}</dt>
                        <dd class="col-sm-6 text-end">{{ audit.reportDate|date('d.m.Y') }}</dd>
                        {% endif %}
                    </dl>
                {% endblock %}
            {% endembed %}

            {# Metadata #}
            {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
                {% block card_header %}
                    <div class="card-header bg-body-secondary">
                        <h2 class="h6 mb-0"><i class="fa-icon fa-icon--status-info" aria-hidden="true"></i> {{ 'common.metadata'|trans({}, 'messages') }}</h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <dl class="row mb-0 small">
                        <dt class="col-sm-5 text-muted">{{ 'common.created_at'|trans({}, 'messages') }}</dt>
                        <dd class="col-sm-7">{{ audit.createdAt|date('d.m.Y H:i') }}</dd>

                        {% if audit.updatedAt %}
                        <dt class="col-sm-5 text-muted">{{ 'common.updated_at'|trans({}, 'messages') }}</dt>
                        <dd class="col-sm-7">{{ audit.updatedAt|date('d.m.Y H:i') }}</dd>
                        {% endif %}

                        <dt class="col-sm-5 text-muted">{{ 'common.id'|trans({}, 'messages') }}</dt>
                        <dd class="col-sm-7"><code>{{ audit.id }}</code></dd>
                    </dl>
                {% endblock %}
            {% endembed %}
        </div>
    </div>
</div>

{# Audit Log History #}
{% if auditLogs is defined and auditLogs|length > 0 %}
<div class="container-fluid py-4">
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
        {% block card_header %}
            <div class="card-header bg-body-secondary">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--audit-trail" aria-hidden="true"></i> {{ 'audit.section.history'|trans({}, 'audit') }}
                    ({{ totalAuditLogs }} {{ 'audit_log.entries'|trans({}, 'audit_log') }})
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            <div class="fa-audit-feed">
                {% for log in auditLogs %}
                <div class="fa-audit-row{% if log.isSealed is defined and log.isSealed %} fa-audit-row--sealed{% endif %}">
                    <span class="fa-audit-row__ts">{{ log.createdAt|date('Y-m-d H:i:s') }}</span>
                    <span class="fa-audit-row__sev fa-audit-row__sev--{% if log.action in ['create', 'read'] %}info{% elseif log.action == 'update' %}warning{% elseif log.action in ['error', 'failed'] %}danger{% else %}critical{% endif %}"></span>
                    <span class="fa-audit-row__actor">{{ log.userName|default('System') }}</span>
                    <span class="fa-audit-row__action">{{ log.action|upper }}</span>
                    <span class="fa-audit-row__target">{{ log.entityType|default('Audit') }}#{{ log.entityId|default('') }}</span>
                    <span class="fa-audit-row__hash">{{ log.hash is defined ? log.hash|slice(0,12) : '' }}</span>
                </div>
                {% endfor %}
            </div>
            {% if totalAuditLogs > 10 %}
            <div class="text-center mt-3">
                <small class="text-muted">
                    {{ 'audit_log.showing_recent'|trans({'%count%': 10, '%total%': totalAuditLogs}, 'audit') }}
                </small>
            </div>
            {% endif %}
        {% endblock %}
    {% endembed %}
</div>
{# Audit log styles: .fa-audit-feed / .fa-audit-row — handled centrally in fairy-aurora-components.css #}
{% endif %}

{# S3 P0-26 — Reject Modal with rejection_reason form (only when current state allows reject) #}
{% if audit.status == 'reported' and is_granted('ROLE_AUDITOR') and not _reported_by_current %}
<div class="modal fade" id="rejectModal" tabindex="-1" aria-labelledby="rejectModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" action="{{ path('app_audit_reject_report', {id: audit.id}) }}">
                <div class="modal-header">
                    <h2 class="h5 modal-title" id="rejectModalLabel">
                        <i class="fa-icon fa-icon--status-warning text-danger" aria-hidden="true"></i>
                        {{ 'audit.action.reject_report'|trans({}, 'audit') }}
                    </h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'common.close'|trans({}, 'messages') }}"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted">{{ 'audit.help.rejection_reason'|trans({}, 'audit') }}</p>
                    <div class="mb-3">
                        <label for="rejection_reason_input" class="form-label">
                            {{ 'audit.field.rejection_reason_required'|trans({}, 'audit') }}
                        </label>
                        <textarea id="rejection_reason_input"
                                  name="rejection_reason"
                                  class="form-control"
                                  rows="5"
                                  required
                                  minlength="10"
                                  placeholder="{{ 'audit.help.rejection_reason'|trans({}, 'audit') }}"></textarea>
                    </div>
                    <input type="hidden" name="_token" value="{{ csrf_token('audit_reject_report') }}">
                </div>
                <div class="modal-footer">
                    <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost" data-bs-dismiss="modal">
                        {{ 'common.cancel'|trans({}, 'messages') }}
                    </button>
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger" data-turbo="false">
                        <i class="fa-icon fa-icon--ui-x" aria-hidden="true"></i>
                        {{ 'audit.action.reject_report'|trans({}, 'audit') }}
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endif %}

{# Delete Confirmation Modal #}
{% if is_granted('ROLE_ADMIN') %}
<div  class="modal fade"  id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="h5 modal-title" id="deleteModalLabel">
                    <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> {{ 'audit.confirm_delete'|trans({}, 'audit') }}
                </h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'common.close'|trans({}, 'messages') }}"></button>
            </div>
            <div class="modal-body">
                <p>{{ 'audit.delete_warning'|trans({'%title%': audit.title}, 'audit') }}</p>
                <p class="text-muted"><small>{{ 'common.action_irreversible'|trans({}, 'messages') }}</small></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost" data-bs-dismiss="modal">
                    {{ 'common.cancel'|trans({}, 'messages') }}
                </button>
                <form method="post" action="{{ path('app_audit_delete', {id: audit.id}) }}" class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ audit.id) }}">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger">
                        <i class="fa-icon fa-icon--ui-trash" aria-hidden="true"></i> {{ 'common.delete'|trans({}, 'messages') }}
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endif %}

{# Lifecycle X.3b — transition history tab #}
{{ _lifecycle_history.history('internal-audit', audit.id) }}
{% endblock %}
