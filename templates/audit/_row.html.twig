{# Single InternalAudit table row — shared by the index and the Turbo Stream
   that replaces/appends a row after an in-modal save. The title cell opens the
   read-only detail in the fa-form-modal frame; the eye/edit actions do the same.
   PDF/Excel export links are excluded from Turbo navigation (data-turbo="false"). #}
{% trans_default_domain 'audit' %}
{% set typeIcons = {
    'full_isms': 'nav-building',
    'compliance_framework': 'shield-check',
    'asset': 'asset-server',
    'asset_type': 'nav-collection',
    'asset_group': 'nav-collection',
    'location': 'nav-building',
    'department': 'nav-people',
    'corporate_wide': 'nav-building',
    'corporate_subsidiaries': 'nav-collection'
} %}
<tr id="audit-row-{{ audit.id }}"
    class="audit-row"
    data-status="{{ audit.status }}"
    data-title="{{ audit.title|lower }}"
    data-number="{{ audit.auditNumber|lower }}">
    <td>
        {% include '_components/_badge.html.twig' with { variant: 'secondary', content: audit.auditNumber } %}
    </td>
    <td>
        <a href="{{ path('app_audit_show', {id: audit.id}) }}"
           data-turbo-frame="fa-form-modal"
           class="fa-row-link"><strong>{{ audit.title }}</strong></a>
        {% if audit.scope %}
        <br>
        <small class="text-muted">{{ audit.scope|length > 60 ? audit.scope|slice(0, 60) ~ '...' : audit.scope }}</small>
        {% endif %}
    </td>
    <td>
        <i class="fa-icon fa-icon--{{ typeIcons[audit.scopeType] ?? 'status-info' }}"></i>
        {{ ('audit.scope_type.' ~ audit.scopeType)|trans({}, 'audit') }}
    </td>
    <td>
        {% if audit.plannedDate %}
        <i class="fa-icon fa-icon--ui-calendar" aria-hidden="true"></i>
        {{ audit.plannedDate|date('d.m.Y') }}
        {% else %}
        <span class="text-muted">-</span>
        {% endif %}
    </td>
    <td>
        <span class="{{ badge_status(audit.status) }}">
            {% if audit.status == 'planned' %}
                <i class="fa-icon fa-icon--ui-calendar" aria-hidden="true"></i>
            {% elseif audit.status == 'in_progress' %}
                <i class="fa-icon fa-icon--status-pending" aria-hidden="true"></i>
            {% elseif audit.status == 'completed' %}
                <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
            {% elseif audit.status == 'reported' %}
                <i class="fa-icon fa-icon--policy" aria-hidden="true"></i>
            {% endif %}
            {{ ('audit.status.' ~ audit.status)|trans({}, 'audit') }}
        </span>
    </td>
    <td class="w-text-right">
        <div class="btn-group btn-group-sm" role="group" aria-label="{{ 'common.actions'|trans({}, 'messages') }}">
            <a href="{{ path('app_audit_show', {id: audit.id}) }}"
               class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost"
               data-turbo-frame="fa-form-modal"
               title="{{ 'common.view'|trans({}, 'messages') }}" aria-label="{{ 'common.view'|trans({}, 'messages') }}">
                <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
            </a>
            {% if is_granted('ROLE_USER') %}
            <a href="{{ path('app_audit_edit', {id: audit.id}) }}"
               class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost"
               data-turbo-frame="fa-form-modal"
               title="{{ 'common.edit'|trans({}, 'messages') }}" aria-label="{{ 'common.edit'|trans({}, 'messages') }}">
                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
            </a>
            {% endif %}
            <a href="{{ path('app_audit_export_pdf', {id: audit.id}) }}"
               class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--success"
               data-turbo-prefetch="false"
               data-turbo="false"
               title="{{ 'common.export_pdf'|trans({}, 'messages') }}" aria-label="{{ 'common.export_pdf'|trans({}, 'messages') }}">
                <i class="fa-icon fa-icon--nav-file-pdf" aria-hidden="true"></i>
            </a>
        </div>
    </td>
</tr>
