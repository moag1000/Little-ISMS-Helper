{# InternalAudit read-only detail — rendered inside the fa-form-modal Turbo Frame.
   Uses the drawer chrome (header/body/footer/kv) which renders cleanly as a
   flex column; condensed, with a "Vollansicht" link to the full page. #}
{% trans_default_domain 'audit' %}
<turbo-frame id="fa-form-modal">
    <div class="fa-drawer__header">
        <div class="fa-drawer__header-text">
            <div class="fa-drawer__eyebrow">ISO 27001 Cl. 9.2 · Internal Audit</div>
            <div class="fa-drawer__title">{{ audit.title }}</div>
        </div>
        <button type="button" class="fa-drawer__close" data-action="fa-form-modal#close"
                aria-label="{{ 'common.close'|trans({}, 'messages') }}">
            <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i>
        </button>
    </div>
    <div class="fa-drawer__body">
        <div class="fa-drawer__section">
            {% include '_components/_badge.html.twig' with { variant: 'secondary', content: audit.auditNumber } %}
            <span class="{{ badge_status(audit.status) }}">
                {{ ('audit.status.' ~ audit.status)|trans({}, 'audit') }}
            </span>
        </div>

        <div class="fa-drawer__kv">
            <span class="label">{{ 'audit.field.scope_type'|trans({}, 'audit') }}</span>
            <span>{{ ('audit.scope_type.' ~ audit.scopeType)|trans({}, 'audit') }}</span>
        </div>

        {% if audit.plannedDate %}
        <div class="fa-drawer__kv">
            <span class="label">{{ 'audit.field.planned_date'|trans({}, 'audit') }}</span>
            <span><i class="fa-icon fa-icon--ui-calendar" aria-hidden="true"></i> {{ audit.plannedDate|date('d.m.Y') }}</span>
        </div>
        {% endif %}

        {% if audit.leadAuditorUser %}
        <div class="fa-drawer__kv">
            <span class="label">{{ 'audit.field.lead_auditor_user'|trans({}, 'audit') }}</span>
            <span>{{ audit.leadAuditorUser.fullName }}</span>
        </div>
        {% elseif audit.leadAuditorPerson %}
        <div class="fa-drawer__kv">
            <span class="label">{{ 'audit.field.lead_auditor_person'|trans({}, 'audit') }}</span>
            <span>{{ audit.leadAuditorPerson.fullName }}</span>
        </div>
        {% elseif audit.leadAuditor %}
        <div class="fa-drawer__kv">
            <span class="label">{{ 'audit.field.lead_auditor'|trans({}, 'audit') }}</span>
            <span>{{ audit.leadAuditor }}</span>
        </div>
        {% endif %}

        {% if audit.scope %}
        <div class="fa-drawer__section">
            <span class="label">{{ 'audit.field.scope'|trans({}, 'audit') }}</span>
            <p class="fa-drawer__desc">{{ audit.scope|u.truncate(280, '…') }}</p>
        </div>
        {% endif %}

        <div class="fa-drawer__section">
            <a href="{{ path('app_audit_show', {id: audit.id}) }}" data-turbo="false" class="fa-row-link">
                {{ 'common.open_full_view'|trans({}, 'messages') }} →
            </a>
        </div>
    </div>
    <div class="fa-drawer__footer" style="display:flex;gap:10px;justify-content:flex-end">
        <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--md" data-action="fa-form-modal#close">
            <span class="fa-cyber-btn__label">{{ 'common.close'|trans({}, 'messages') }}</span>
        </button>
        {% if is_granted('ROLE_USER') %}
            <a href="{{ path('app_audit_edit', {id: audit.id}) }}" data-turbo-frame="fa-form-modal"
               class="fa-cyber-btn fa-cyber-btn--md">
                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                <span class="fa-cyber-btn__label">{{ 'common.edit'|trans({}, 'messages') }}</span>
            </a>
        {% endif %}
    </div>
</turbo-frame>
