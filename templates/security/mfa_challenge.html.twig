{% extends 'base_auth.html.twig' %}
{% trans_default_domain 'mfa' %}

{% block title %}{{ 'mfa.challenge.title'|trans({}, 'mfa') }} — Little ISMS Helper{% endblock %}

{% block auth_mood %}thinking{% endblock %}
{% block auth_alva_line %}{{ 'mfa.alva_line'|trans({}, 'mfa')|default('Zweiter Faktor.') }}{% endblock %}
{% block auth_alva_sub %}{{ 'mfa.alva_sub'|trans({}, 'mfa')|default('Ich warte auf deinen Code.') }}{% endblock %}

{% block body %}
{% import '_components/_cyber_input.html.twig' as ci %}
{% import '_components/_cyber_button.html.twig' as btn %}
{% import '_components/_alert.html.twig' as faAlert %}

<div class="fa-auth-form">
    <header class="fa-auth-form__head">
        <div class="fa-auth-form__eyebrow">
            <i class="fa-icon fa-icon--control" aria-hidden="true"></i>
            {{ 'mfa.challenge.eyebrow'|trans({}, 'mfa')|default('2-Faktor-Authentifizierung') }}
        </div>
        <h1 class="fa-auth-form__title">{{ 'mfa.challenge.title'|trans({}, 'mfa') }}</h1>
        <p class="fa-auth-form__desc">{{ 'mfa.challenge.description'|trans({}, 'mfa') }}</p>
    </header>

    {% if error %}
        {{ faAlert.render(error, 'danger', { withAlva: true })|raw }}
    {% endif %}

    <form method="post"
          action="{{ path('app_mfa_verify', {_locale: app.request.locale}) }}"
          class="fa-auth-form__form">

        {% set deviceOptions = [] %}
        {% for token in mfaTokens %}
            {% set label = token.deviceName %}
            {% if token.isPrimary %}{% set label = label ~ ' (' ~ 'mfa.token.primary'|trans({}, 'mfa') ~ ')' %}{% endif %}
            {% set deviceOptions = deviceOptions|merge([{ value: token.id, label: label }]) %}
        {% endfor %}

        {{ ci.select({
            name: 'token_id',
            label: 'mfa.challenge.device'|trans({}, 'mfa'),
            options: deviceOptions,
            required: true,
            hint: 'mfa.challenge.device_help'|trans({}, 'mfa')
        }) }}

        {{ ci.render({
            name: 'code',
            label: 'mfa.challenge.code'|trans({}, 'mfa'),
            type: 'text',
            required: true,
            placeholder: '000000',
            autocomplete: 'one-time-code',
            attrs: { autofocus: 'autofocus', inputmode: 'numeric', pattern: '[0-9]{6}|[A-Za-z0-9]{8}', maxlength: '8' },
            hint: 'mfa.challenge.code_help'|trans({}, 'mfa')
        }) }}

        {{ btn.submit('mfa.challenge.verify'|trans({}, 'mfa'), {
            variant: 'primary',
            fullWidth: true,
            icon: 'bi-check-lg',
            attrs: { 'data-controller': 'button-loading', 'data-action': 'button-loading#start' }
        }) }}
    </form>

    <details class="fa-auth-details">
        <summary>{{ 'mfa.challenge.using_backup_code'|trans({}, 'mfa') }}</summary>
        <p class="fa-auth-details__body">{{ 'mfa.challenge.backup_code_info'|trans({}, 'mfa') }}</p>
    </details>

    <div class="fa-auth-form__footer-link">
        <a href="{{ path('app_logout') }}" class="fa-auth-cancel-link">
            <i class="bi bi-x-lg" aria-hidden="true"></i>
            {{ 'mfa.challenge.cancel'|trans({}, 'mfa') }}
        </a>
    </div>
</div>
{% endblock %}
