{% extends 'base_auth.html.twig' %}

{% block title %}{{ 'login.title'|trans({}, 'messages') }} — Little ISMS Helper{% endblock %}

{% block auth_mood %}focused{% endblock %}
{% block auth_alva_line %}{{ 'login.alva_line'|trans({}, 'messages')|default('Willkommen zurück.') }}{% endblock %}
{% block auth_alva_sub %}{{ 'login.alva_sub'|trans({}, 'messages')|default("Kurz anmelden, dann geht's weiter.") }}{% endblock %}

{% block body %}
{% import '_components/_cyber_input.html.twig' as ci %}
{% import '_components/_cyber_button.html.twig' as btn %}
{% import '_components/_alert.html.twig' as faAlert %}

<div class="fa-auth-form">
    <header class="fa-auth-form__head">
        <div class="fa-auth-form__eyebrow">{{ 'login.eyebrow'|trans({}, 'messages')|default('Anmeldung') }}</div>
        <h1 class="fa-auth-form__title">{{ 'login.title'|trans({}, 'messages') }}</h1>
    </header>

    {% if error %}
        {{ faAlert.render(error.messageKey|trans(error.messageData, 'security'), 'danger', { withAlva: true, dismissible: false })|raw }}
    {% endif %}

    {% if app.user %}
        {{ faAlert.render(
            'login.already_logged_in'|trans({'%user%': app.user.userIdentifier}, 'messages')
            ~ ' <a href="' ~ path('app_home') ~ '">' ~ ('common.to_home'|trans({}, 'messages')) ~ '</a>',
            'info', { withAlva: true }
        )|raw }}
    {% else %}
        <form method="post"
              action="{{ path('app_login') }}"
              novalidate
              class="fa-auth-form__form"
              data-controller="form-validation"
              data-action="submit->form-validation#handleSubmit">

            {{ ci.render({
                name: '_username',
                label: 'login.field.email'|trans({}, 'messages'),
                type: 'email',
                value: last_username,
                required: true,
                placeholder: 'login.placeholder.email'|trans({}, 'messages'),
                autocomplete: 'email',
                attrs: { autofocus: 'autofocus' },
                hint: 'login.help.email'|trans({}, 'messages')
            }) }}

            {{ ci.render({
                name: '_password',
                label: 'login.field.password'|trans({}, 'messages'),
                type: 'password',
                required: true,
                placeholder: 'login.placeholder.password'|trans({}, 'messages'),
                autocomplete: 'current-password'
            }) }}

            <label class="fa-auth-remember">
                <input type="checkbox" name="_remember_me" value="1">
                <span>{{ 'login.remember_me'|trans({}, 'messages') }}</span>
            </label>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            {{ btn.submit('login.submit'|trans({}, 'messages'), {
                variant: 'primary',
                fullWidth: true,
                icon: 'bi-box-arrow-in-right'
            }) }}
        </form>

        {% set has_sso_buttons = (sso_providers is defined and sso_providers|length > 0) %}
        {% if has_sso_buttons %}
            <div class="fa-auth-form__divider">
                <span>{{ 'login.or_divider'|trans({}, 'messages')|default('oder') }}</span>
            </div>

            <div class="fa-auth-form__oauth">
                {% for p in sso_providers %}
                    <a href="{{ path('app_sso_start', {slug: p.slug}) }}" class="fa-auth-oauth-btn"
                       {% if p.buttonColor %}style="border-color: {{ p.buttonColor }};"{% endif %}>
                        {% if p.buttonIcon %}
                            <i class="bi {{ p.buttonIcon }}" aria-hidden="true"
                               {% if p.buttonColor %}style="color: {{ p.buttonColor }};"{% endif %}></i>
                        {% else %}
                            <i class="bi bi-shield-lock" aria-hidden="true"></i>
                        {% endif %}
                        <span>{{ p.buttonLabel ?: p.name }}</span>
                    </a>
                {% endfor %}
            </div>
        {% endif %}

        <p class="fa-auth-form__help">
            {{ 'login.no_account_message'|trans({}, 'messages') }}
        </p>
    {% endif %}
</div>
{% endblock %}
