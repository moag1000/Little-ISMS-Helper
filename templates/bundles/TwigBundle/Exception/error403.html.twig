{% extends 'base_auth.html.twig' %}

{% block title %}{{ 'error.403.title'|trans({}, 'messages') }}{% endblock %}

{% block auth_mood %}sleeping{% endblock %}
{% block auth_alva_line %}{{ 'error.403.alva_line'|trans({}, 'messages')|default('Dafür fehlt dir die Berechtigung.') }}{% endblock %}
{% block auth_alva_sub %}{{ 'error.403.alva_sub'|trans({}, 'messages')|default('Wenn das falsch ist, sprich mit deinem Admin.') }}{% endblock %}

{% block body %}
    {% import '_components/_cyber_button.html.twig' as btn %}
    <div class="fa-auth-form">
        <header class="fa-auth-form__head">
            <div class="fa-auth-form__eyebrow">403 · {{ 'error.code_label_forbidden'|trans({}, 'messages')|default('Zugriff verweigert') }}</div>
            <h1 class="fa-auth-form__title">{{ 'error.403.heading'|trans({}, 'messages') }}</h1>
            <p class="fa-auth-form__desc">{{ 'error.403.message'|trans({}, 'messages') }}</p>
        </header>
        <div style="display:flex; gap: 10px; margin-top: 8px; flex-wrap: wrap;">
            {{ btn.link(path('app_home'), 'error.action.homepage'|trans({}, 'messages'), { variant: 'primary', icon: 'bi-house' }) }}
            {{ btn.link('javascript:history.back()', 'error.action.back'|trans({}, 'messages'), { variant: 'secondary', icon: 'bi-arrow-left' }) }}
        </div>
    </div>
{% endblock %}
