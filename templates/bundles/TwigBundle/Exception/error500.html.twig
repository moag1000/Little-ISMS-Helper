{% extends 'base_auth.html.twig' %}

{% block title %}{{ 'error.500.title'|trans({}, 'messages') }}{% endblock %}

{% block auth_mood %}warning{% endblock %}
{% block auth_alva_line %}{{ 'error.500.alva_line'|trans({}, 'messages')|default('Etwas ist schiefgelaufen.') }}{% endblock %}
{% block auth_alva_sub %}{{ 'error.500.alva_sub'|trans({}, 'messages')|default('Das ist nicht deine Schuld. Versuche es nochmal oder melde es dem Admin.') }}{% endblock %}

{% block body %}
    {% import '_components/_cyber_button.html.twig' as btn %}
    <div class="fa-auth-form">
        <header class="fa-auth-form__head">
            <div class="fa-auth-form__eyebrow">500 · {{ 'error.code_label_server'|trans({}, 'messages')|default('Serverfehler') }}</div>
            <h1 class="fa-auth-form__title">{{ 'error.500.heading'|trans({}, 'messages') }}</h1>
            <p class="fa-auth-form__desc">{{ 'error.500.message'|trans({}, 'messages') }}</p>
        </header>

        {% if exception is defined and request_id is defined %}
            <div style="margin: 8px 0; padding: 8px 12px; background: var(--surface-2); border-radius: var(--r-md); font-family: var(--font-mono); font-size: 11px; color: var(--fg-3); text-transform: uppercase; letter-spacing: 0.08em;">
                Request-ID: <span style="color: var(--fg);">{{ request_id }}</span>
            </div>
        {% endif %}

        <div style="display:flex; gap: 10px; margin-top: 8px; flex-wrap: wrap;">
            {{ btn.link('javascript:location.reload()', 'error.action.retry'|trans({}, 'messages')|default('Nochmal versuchen'), { variant: 'primary', icon: 'bi-arrow-clockwise' }) }}
            {{ btn.link(path('app_home'), 'error.action.homepage'|trans({}, 'messages'), { variant: 'secondary', icon: 'bi-house' }) }}
        </div>
    </div>
{% endblock %}
