{% extends 'base_auth.html.twig' %}

{# Generic fallback für alle anderen Error-Codes (502/503/504 etc.).
   Erbt Auth-Shell damit wir keine App-Abhängigkeiten brauchen, wenn die
   App selbst gerade kaputt ist. Keine Information-Disclosure — generischer
   Text unabhängig vom tatsächlichen Fehler. #}

{% block title %}{{ 'error.generic.title'|trans({}, 'messages') }}{% endblock %}

{% block auth_mood %}warning{% endblock %}
{% block auth_alva_line %}{{ 'error.generic.alva_line'|trans({}, 'messages')|default('Etwas stimmt nicht.') }}{% endblock %}
{% block auth_alva_sub %}{{ 'error.generic.alva_sub'|trans({}, 'messages')|default('Probier es gleich nochmal oder geh zurück zum Dashboard.') }}{% endblock %}

{% block body %}
    {% import '_components/_cyber_button.html.twig' as btn %}
    <div class="fa-auth-form">
        <header class="fa-auth-form__head">
            <div class="fa-auth-form__eyebrow">{{ 'error.code_label_generic'|trans({}, 'messages')|default('Fehler') }}</div>
            <h1 class="fa-auth-form__title">{{ 'error.generic.heading'|trans({}, 'messages') }}</h1>
            <p class="fa-auth-form__desc">{{ 'error.generic.message'|trans({}, 'messages') }}</p>
            {% if 'error.generic.help'|trans({}, 'messages') != 'error.generic.help' %}
                <p class="fa-auth-form__desc">{{ 'error.generic.help'|trans({}, 'messages') }}</p>
            {% endif %}
        </header>

        {% if request_id is defined %}
            <div style="margin: 8px 0; padding: 8px 12px; background: var(--surface-2); border-radius: var(--r-md); font-family: var(--font-mono); font-size: 11px; color: var(--fg-3); text-transform: uppercase; letter-spacing: 0.08em;">
                Request-ID: <span style="color: var(--fg);">{{ request_id }}</span>
            </div>
        {% endif %}

        <div style="display:flex; gap: 10px; margin-top: 8px; flex-wrap: wrap;">
            {{ btn.link('javascript:location.reload()', 'error.action.retry'|trans({}, 'messages')|default('Nochmal versuchen'), { variant: 'primary', icon: 'bi-arrow-clockwise' }) }}
            {{ btn.link(path('app_home'), 'error.action.homepage'|trans({}, 'messages'), { variant: 'secondary', icon: 'bi-house' }) }}
        </div>
    </div>
{% endblock %}
