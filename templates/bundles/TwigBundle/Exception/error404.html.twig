{% extends 'base_auth.html.twig' %}

{% block title %}{{ 'error.404.title'|trans({}, 'messages') }}{% endblock %}

{% block auth_mood %}thinking{% endblock %}
{% block auth_alva_line %}{{ 'error.404.alva_line'|trans({}, 'messages')|default('Hmm, das finde ich nicht.') }}{% endblock %}
{% block auth_alva_sub %}{{ 'error.404.alva_sub'|trans({}, 'messages')|default('Prüfe die URL oder gehe zum Dashboard.') }}{% endblock %}

{% block body %}
    {% import '_components/_cyber_button.html.twig' as btn %}
    <div class="fa-auth-form">
        <header class="fa-auth-form__head">
            <div class="fa-auth-form__eyebrow">404 · {{ 'error.code_label'|trans({}, 'messages')|default('Nicht gefunden') }}</div>
            <h1 class="fa-auth-form__title">{{ 'error.404.heading'|trans({}, 'messages') }}</h1>
            <p class="fa-auth-form__desc">{{ 'error.404.message'|trans({}, 'messages') }}</p>
        </header>
        <div style="display:flex; gap: 10px; margin-top: 8px; flex-wrap: wrap;">
            {{ btn.link(path('app_home'), 'error.action.homepage'|trans({}, 'messages'), { variant: 'primary', icon: 'bi-house' }) }}
            {{ btn.link('javascript:history.back()', 'error.action.back'|trans({}, 'messages'), { variant: 'secondary', icon: 'bi-arrow-left' }) }}
        </div>
    </div>
{% endblock %}
