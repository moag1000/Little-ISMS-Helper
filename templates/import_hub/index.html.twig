{% extends 'base.html.twig' %}
{% trans_default_domain 'data_import' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'import.hub.title'|trans({}, 'data_import') }}{% endblock %}

{% block body %}
{{ _fa_page_header.render({
    badge: { icon: 'ui-upload', label: 'import.hub.badge'|trans({}, 'data_import') },
    title: 'import.hub.title'|trans({}, 'data_import'),
    subtitle: 'import.hub.subtitle'|trans({}, 'data_import'),
}) }}

<main class="fa-aurora-surface">
    {% for area, slugs in groups %}
        <h2 class="h6 mt-4 mb-2 text-muted">{{ ('import.hub.area.' ~ area)|trans({}, 'data_import') }}</h2>
        <div class="row g-3">
            {% for slug in slugs %}
                <div class="col-md-3 col-sm-6">
                    <a href="{{ path('app_bulk_import_index', { entityType: slug }) }}"
                       class="card h-100 text-decoration-none" data-turbo-action="advance">
                        <div class="card-body d-flex align-items-center gap-2">
                            <i class="fa-icon fa-icon--ui-upload text-primary" aria-hidden="true"></i>
                            <span class="fw-semibold small">{{ ('import.entity.' ~ slug)|trans({}, 'data_import') }}</span>
                        </div>
                    </a>
                </div>
            {% endfor %}
        </div>
    {% endfor %}

    <p class="text-muted small mt-4">
        <i class="fa-icon fa-icon--ui-info" aria-hidden="true"></i>
        {{ 'import.hub.help'|trans({}, 'data_import') }}
    </p>
</main>
{% endblock %}
