{% extends 'base.html.twig' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block title %}{{ 'four_eyes.inbox.title'|trans({}, 'four_eyes') }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {{ _fa_page_header.render({
        badge: { icon: 'nav-inbox', label: 'nav.four_eyes_inbox'|trans({}, 'nav') },
        title: 'four_eyes.inbox.title'|trans({}, 'four_eyes'),
        subtitle: 'four_eyes.inbox.lead'|trans({}, 'four_eyes')
    }) }}

    {% if requests is empty %}
        {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'success', icon: 'status-ok' } } %}
            {% block alert_body %}{{ 'four_eyes.inbox.empty'|trans({}, 'four_eyes') }}{% endblock %}
        {% endembed %}
    {% else %}
        <div class="list-group">
            {% for r in requests %}
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span class="fa-status-pill fa-status-pill--primary">
                                    {{ ('four_eyes.action.' ~ r.actionType)|trans({}, 'four_eyes') }}
                                </span>
                                <strong>#{{ r.id }}</strong>
                                <span class="text-muted">·</span>
                                <small class="text-muted">
                                    {{ 'four_eyes.requested_by'|trans({}, 'four_eyes') }}
                                    {{ r.requestedBy.fullName|default(r.requestedBy.email) }}
                                </small>
                            </div>
                            <div class="small">
                                {{ 'four_eyes.expires_at'|trans({}, 'four_eyes') }}: {{ r.expiresAt|date('Y-m-d H:i') }}
                            </div>
                            <pre class="small bg-body-secondary p-2 mt-2 mb-0">{{ r.payload|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
                        </div>
                        <div class="d-flex flex-column gap-2">
                            <form method="post" action="{{ path('app_four_eyes_approve', { id: r.id }) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('four_eyes_approve_' ~ r.id) }}">
                                <button type="submit" class="fa-cyber-btn fa-cyber-btn--success fa-cyber-btn--sm">
                                    <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i>
                                    {{ 'four_eyes.approve'|trans({}, 'four_eyes') }}
                                </button>
                            </form>
                            <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
                                    data-controller="fa-modal-dispatcher" data-action="click->fa-modal-dispatcher#open" data-fa-modal-id="reject-{{ r.id }}">
                                <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i>
                                {{ 'four_eyes.reject'|trans({}, 'four_eyes') }}
                            </button>
                        </div>
                    </div>
                </div>

                <div class="fa-modal fa-modal--confirm fa-modal--danger" id="reject-{{ r.id }}"
     data-controller="fa-modal" data-fa-modal-mode-value="confirm" data-fa-modal-tone-value="danger"
     role="alertdialog" aria-modal="true" aria-labelledby="reject-{{ r.id }}-label" aria-hidden="true">
    <div class="fa-modal__backdrop" data-fa-modal-target="backdrop" data-action="click->fa-modal#backdropClick" aria-hidden="true"></div>
    <div class="fa-modal__container" data-fa-modal-target="dialog"><form method="post"
                              action="{{ path('app_four_eyes_reject', { id: r.id }) }}" data-fa-modal-target="form">
                            <input type="hidden" name="_token" value="{{ csrf_token('four_eyes_reject_' ~ r.id) }}">
                            <header class="fa-modal__header"><span class="fa-modal__icon" aria-hidden="true"><i class="fa-icon fa-icon--status-critical"></i></span><div class="fa-modal__heading"><h5 class="fa-modal__title" id="reject-{{ r.id }}-label">
                                    {{ 'four_eyes.reject_modal.title'|trans({}, 'four_eyes') }}
                                </h5></div><button type="button" class="fa-modal__close" data-action="fa-modal#cancel" aria-label="{{ 'common.close'|trans({}, 'messages') }}"><i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i></button></header>
                            <div class="fa-modal__body">
                                <label class="form-label">{{ 'four_eyes.reject_modal.reason'|trans({}, 'four_eyes') }}</label>
                                <textarea name="reason" class="form-control fa-cyber-input__field" rows="3" minlength="20" required></textarea>
                            </div>
                            <footer class="fa-modal__footer">
                                <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost" data-action="fa-modal#cancel">{{ 'common.cancel'|trans({}, 'messages') }}</button>
                                <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger">
                                    {{ 'four_eyes.reject'|trans({}, 'four_eyes') }}
                                </button>
                            </footer>
                        </form></div>
</div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
