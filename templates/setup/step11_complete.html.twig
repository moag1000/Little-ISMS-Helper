{% extends 'setup/_layout.html.twig' %}
{% trans_default_domain 'setup' %}
{% set active_step = 'complete' %}

{% block title %}{{ 'setup.complete.title'|trans({}, 'setup') }}{% endblock %}

{% block step_content %}
    {% import '_components/_step_header.html.twig' as step_header %}
    {% import '_components/_alva.html.twig' as alva %}
    {% import '_components/_alert.html.twig' as faAlert %}
    {% import '_components/_kpi_card.html.twig' as kpi %}
    {% import '_components/_status_pill.html.twig' as pill %}
    {% import '_components/_cyber_button.html.twig' as btn %}

    <div class="fa-setup-complete">
        {# Celebrating Alva #}
        <div class="fa-setup-complete__hero">
            {{ alva.render('celebrating', { size: 140, decorative: true })|raw }}
            <h1 class="fa-setup-complete__title">{{ 'setup.complete.system_ready'|trans({}, 'setup') }}</h1>
            <p class="fa-setup-complete__subtitle">{{ 'setup.complete.all_components_ready'|trans({}, 'setup') }}</p>
        </div>

        {# Stats Grid mit KPI-Cards #}
        <div class="fa-setup-complete__stats">
            <div class="fa-kpi-card fa-kpi-card--primary">
                <div class="fa-kpi-card__body">
                    <div class="fa-kpi-card__label">{{ 'setup.complete.stats.active_modules'|trans({}, 'setup') }}</div>
                    <div class="fa-kpi-card__value">
                        <span class="fa-kpi-card__number">{{ statistics.active_modules }}</span>
                    </div>
                </div>
            </div>
            <div class="fa-kpi-card fa-kpi-card--success">
                <div class="fa-kpi-card__body">
                    <div class="fa-kpi-card__label">{{ 'setup.complete.stats.available_modules'|trans({}, 'setup') }}</div>
                    <div class="fa-kpi-card__value">
                        <span class="fa-kpi-card__number">{{ statistics.total_modules }}</span>
                    </div>
                </div>
            </div>
            <div class="fa-kpi-card fa-kpi-card--accent">
                <div class="fa-kpi-card__body">
                    <div class="fa-kpi-card__label">{{ 'setup.complete.stats.core_modules'|trans({}, 'setup') }}</div>
                    <div class="fa-kpi-card__value">
                        <span class="fa-kpi-card__number">{{ statistics.required_modules }}</span>
                    </div>
                </div>
            </div>
            <div class="fa-kpi-card fa-kpi-card--warning">
                <div class="fa-kpi-card__body">
                    <div class="fa-kpi-card__label">{{ 'setup.complete.stats.optional_modules'|trans({}, 'setup') }}</div>
                    <div class="fa-kpi-card__value">
                        <span class="fa-kpi-card__number">{{ statistics.optional_modules }}</span>
                    </div>
                </div>
            </div>
        </div>

        {# Active Modules als Status-Pills #}
        <section class="fa-setup-complete__section">
            <h2 class="fa-setup-complete__section-title">
                <i class="bi bi-puzzle" aria-hidden="true"></i>
                {{ 'setup.complete.activated_modules'|trans({}, 'setup') }}
            </h2>
            <div style="display:flex; flex-wrap:wrap; gap:6px;">
                {% for moduleKey in selected_modules %}
                    {{ pill.render(moduleKey, 'primary', { size: 'sm', noDot: true })|raw }}
                {% endfor %}
            </div>
        </section>

        {# Next Steps als strukturierte Liste #}
        <section class="fa-setup-complete__section">
            <h2 class="fa-setup-complete__section-title">
                <i class="bi bi-lightbulb" aria-hidden="true"></i>
                {{ 'setup.complete.next_steps.title'|trans({}, 'setup') }}
            </h2>
            <ol class="fa-setup-complete__next-steps">
                <li>{{ 'setup.complete.next_steps.explore_dashboard'|trans({}, 'setup') }}</li>
                <li>{{ 'setup.complete.next_steps.define_context'|trans({}, 'setup') }}</li>
                <li>{{ 'setup.complete.next_steps.capture_assets'|trans({}, 'setup') }}</li>
                <li>{{ 'setup.complete.next_steps.use_compliance'|trans({}, 'setup') }}</li>
                <li>{{ 'setup.complete.next_steps.add_modules'|trans({}, 'setup') }}</li>
            </ol>
        </section>

        {# Primary CTA + Secondary Actions #}
        <div class="fa-setup-complete__actions">
            {{ btn.link(
                path('app_welcome', {'_locale': app.request.locale}),
                'setup.complete.start_using'|trans({}, 'setup'),
                { variant: 'primary', size: 'lg', icon: 'bi-rocket-takeoff', fullWidth: true }
            ) }}
            <div class="fa-setup-complete__secondary-actions">
                {{ btn.link(
                    path('module_management_index', {'_locale': app.request.locale}),
                    'setup.manage_modules'|trans({}, 'setup'),
                    { variant: 'secondary', icon: 'bi-puzzle' }
                ) }}
                {{ btn.link(
                    path('app_context_index', {'_locale': app.request.locale}),
                    'setup.complete.configure_context'|trans({}, 'setup'),
                    { variant: 'secondary', icon: 'bi-gear' }
                ) }}
            </div>
        </div>

        {{ faAlert.render(
            'setup.complete.help_documentation.description'|trans({}, 'setup'),
            'info',
            { title: 'setup.complete.help_documentation.title'|trans({}, 'setup'), icon: 'bi-question-circle' }
        )|raw }}
    </div>
{% endblock %}
