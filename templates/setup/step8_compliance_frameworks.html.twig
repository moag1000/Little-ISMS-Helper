{% extends 'setup/_layout.html.twig' %}
{% set active_step = 'frameworks' %}

{% block title %}{{ 'setup.compliance.title'|trans({}, 'setup') }} - Deployment Wizard{% endblock %}

{% block step_head %}
    {{ parent() }}
    {# Disable Turbo cache to ensure CSRF tokens are always fresh #}
    <meta name="turbo-cache-control" content="no-cache">
{% endblock %}

{# Macro: rendert eine Framework-Karte im Wizard-3-Bucket-Layout.
 # Muss top-level definiert sein, damit import via expliziter Pfad aus
 # embed-Blöcken heraus zuverlässig funktioniert. #}
{% macro framework_card(child, framework, classification, bucket) %}
    {% set variant = bucket == 'mandatory' ? 'danger' : (bucket == 'recommended' ? 'warning' : 'secondary') %}
    <div class="col-md-6 mb-3">
        {% embed '_components/_card.html.twig' with { 'class': 'h-100 border-' ~ variant } %}
            {% block card_body %}
                <div class="form-check">
                    {{ form_widget(child, {'attr': {'class': 'form-check-input'}}) }}
                    {{ form_label(child, null, {'label_attr': {'class': 'form-check-label fw-bold'}}) }}
                </div>
                <small class="text-muted d-block mt-2">{{ framework.description }}</small>
                {% if classification[framework.code] is defined and classification[framework.code].reason_key %}
                    <div class="small mt-2 p-2 rounded bg-light border">
                        <i class="bi bi-lightbulb text-warning" aria-hidden="true"></i>
                        <strong>{{ ('setup.applicability.bucket.' ~ bucket ~ '.why')|trans({}, 'setup') }}:</strong>
                        {{ classification[framework.code].reason_key|trans({}, 'setup') }}
                    </div>
                {% endif %}
            {% endblock %}
        {% endembed %}
    </div>
{% endmacro %}

{% block step_content %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            {# Flash Messages #}
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                        {{ message|raw }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="{{ 'setup.common.close'|trans({}, 'setup') }}"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {# Progress Bar #}
            {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
                {% block card_body %}
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h4 class="mb-0">{{ 'setup.progress.title'|trans({}, 'setup') }}</h4>
                        <small class="text-muted">{{ 'setup.progress.step_of'|trans({'%current%': 8, '%total%': 11}, 'setup') }}</small>
                    </div>
                    <div class="progress" style="height: 10px;">
                        <div class="progress-bar" role="progressbar" style="width: 70%;" aria-valuenow="70" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/_card.html.twig' with { 'class': 'shadow-lg' } %}
                {% block card_header %}
                    <div class="card-header bg-primary text-white">
                        <h1 class="h3 mb-0">
                            <i class="bi bi-balance me-2" aria-hidden="true"></i>
                            {{ 'setup.compliance.header'|trans({}, 'setup') }}
                        </h1>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="p-4">
                        <p class="lead mb-4">
                            {{ 'setup.compliance.description'|trans({}, 'setup') }}
                        </p>

                        {# Sprint 9: 3-Bucket-Klassifikation — *„Muss / Sollte / Kann"* #}
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2" aria-hidden="true"></i>
                            <strong>{{ 'setup.applicability.intro.title'|trans({}, 'setup') }}</strong>
                            <p class="mb-0">{{ 'setup.applicability.intro.description'|trans({}, 'setup') }}</p>
                        </div>

                        {# Compliance Framework Selection Form #}
                        {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}

                        {% import 'setup/step8_compliance_frameworks.html.twig' as wizard %}

                        {# 🔴 MANDATORY — Pflicht #}
                        {% if mandatory_codes|length > 0 %}
                            <div class="mt-4 mb-2 d-flex align-items-center gap-2">
                                <span class="badge text-bg-danger">🔴 {{ 'setup.applicability.bucket.mandatory.label'|trans({}, 'setup') }}</span>
                                <span class="small text-muted">{{ 'setup.applicability.bucket.mandatory.hint'|trans({}, 'setup') }}</span>
                            </div>
                            <div class="row">
                                {% for child in form.frameworks %}
                                    {% if child.vars.value in mandatory_codes %}
                                        {% for framework in available_frameworks|filter(f => f.code == child.vars.value) %}
                                            {{ wizard.framework_card(child, framework, classification, 'mandatory') }}
                                        {% endfor %}
                                    {% endif %}
                                {% endfor %}
                            </div>
                        {% endif %}

                        {# 🟡 RECOMMENDED — Empfehlung #}
                        {% if recommended_codes|length > 0 %}
                            <div class="mt-4 mb-2 d-flex align-items-center gap-2">
                                <span class="badge text-bg-warning">🟡 {{ 'setup.applicability.bucket.recommended.label'|trans({}, 'setup') }}</span>
                                <span class="small text-muted">{{ 'setup.applicability.bucket.recommended.hint'|trans({}, 'setup') }}</span>
                            </div>
                            <div class="row">
                                {% for child in form.frameworks %}
                                    {% if child.vars.value in recommended_codes %}
                                        {% for framework in available_frameworks|filter(f => f.code == child.vars.value) %}
                                            {{ wizard.framework_card(child, framework, classification, 'recommended') }}
                                        {% endfor %}
                                    {% endif %}
                                {% endfor %}
                            </div>
                        {% endif %}

                        {# ⚪ OPTIONAL — Kann #}
                        {% if optional_codes|length > 0 %}
                            <div class="mt-4 mb-2 d-flex align-items-center gap-2">
                                <span class="badge text-bg-secondary">⚪ {{ 'setup.applicability.bucket.optional.label'|trans({}, 'setup') }}</span>
                                <span class="small text-muted">{{ 'setup.applicability.bucket.optional.hint'|trans({}, 'setup') }}</span>
                            </div>
                            <div class="row">
                                {% for child in form.frameworks %}
                                    {% if child.vars.value in optional_codes %}
                                        {% for framework in available_frameworks|filter(f => f.code == child.vars.value) %}
                                            {{ wizard.framework_card(child, framework, classification, 'optional') }}
                                        {% endfor %}
                                    {% endif %}
                                {% endfor %}
                            </div>
                        {% endif %}

                        {# Information Box #}
                        <div class="alert alert-warning mt-4">
                            <i class="bi bi-exclamation-triangle me-2" aria-hidden="true"></i>
                            <strong>{{ 'setup.compliance.note.title'|trans({}, 'setup') }}</strong>
                            <p class="mb-0">{{ 'setup.compliance.note.message'|trans({}, 'setup') }}</p>
                        </div>

                        {# Navigation #}
                        <div class="d-flex justify-content-between mt-4">
                            <a href="{{ path('setup_step7_modules') }}" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-2" aria-hidden="true"></i>
                                {{ 'setup.navigation.back'|trans({}, 'setup') }}
                            </a>

                            <button type="submit" class="btn btn-primary">
                                {{ 'setup.navigation.next'|trans({}, 'setup') }}
                                <i class="bi bi-arrow-right ms-2" aria-hidden="true"></i>
                            </button>
                        </div>

                        {{ form_end(form) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {# Framework Details Card #}
            {% embed '_components/_card.html.twig' with { 'class': 'mt-4 border-info' } %}
                {% block card_body %}
                    <p class="h5 mb-3">
                        <i class="bi bi-book text-info me-2" aria-hidden="true"></i>
                        {{ 'setup.compliance.details.title'|trans({}, 'setup') }}
                    </p>
                    <div class="row">
                        {% for framework in available_frameworks %}
                            <div class="col-md-6 mb-3">
                                <p class="h6 mb-1">{{ framework.icon }} {{ framework.name }}</p>
                                <p class="text-muted small mb-0">{{ framework.description }}</p>
                            </div>
                        {% endfor %}
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>
</div>
{% endblock %}
