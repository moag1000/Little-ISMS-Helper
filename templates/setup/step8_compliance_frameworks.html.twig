{% extends 'setup/_layout.html.twig' %}
{% trans_default_domain 'setup' %}
{% set active_step = 'frameworks' %}

{% block title %}{{ 'setup.compliance.title'|trans({}, 'setup') }}{% endblock %}

{# Macro: rendert eine Framework-Karte im Aurora-Bucket-Layout.
 # Nutzt fa-toggle-card-Pattern mit Symfony-Form-Widget im Inneren. #}
{% macro framework_card(child, framework, classification, bucket) %}
    {% set bucketTone = bucket == 'mandatory' ? 'danger' : (bucket == 'recommended' ? 'warning' : 'neutral') %}
    <label class="fa-toggle-card fa-toggle-card--bucket fa-toggle-card--bucket-{{ bucket }}"
           for="{{ child.vars.id }}">
        <input type="checkbox"
               id="{{ child.vars.id }}"
               name="{{ child.vars.full_name }}"
               value="{{ child.vars.value }}"
               class="fa-toggle-card__input"
               {% if child.vars.checked %}checked{% endif %}
               {% if child.vars.disabled %}disabled{% endif %}>
        <span class="fa-toggle-card__box" aria-hidden="true">
            <svg viewBox="0 0 14 14" width="10" height="10" fill="none">
                <path d="M2 7 L6 11 L12 3" stroke="currentColor" stroke-width="2.5"
                      stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </span>
        <div class="fa-toggle-card__body">
            <div class="fa-toggle-card__title">
                {{ framework.icon }} {{ framework.name }}
            </div>
            <div class="fa-toggle-card__sub">{{ framework.description }}</div>
            {% if classification[framework.code] is defined and classification[framework.code].reason_key %}
                <div class="fa-toggle-card__reason">
                    <i class="bi bi-lightbulb" aria-hidden="true"></i>
                    <strong>{{ ('setup.applicability.bucket.' ~ bucket ~ '.why')|trans({}, 'setup') }}:</strong>
                    {{ classification[framework.code].reason_key|trans({}, 'setup') }}
                </div>
            {% endif %}
        </div>
    </label>
{% endmacro %}

{% block step_content %}
    {% import '_components/_step_header.html.twig' as step_header %}
    {% import '_components/_alert.html.twig' as faAlert %}
    {% import '_components/_status_pill.html.twig' as pill %}
    {% import '_components/_cyber_button.html.twig' as btn %}
    {% import _self as wizard %}

    {% for label, messages in app.flashes %}
        {% set tone = label == 'success' ? 'success' : (label in ['error','danger'] ? 'danger' : (label == 'warning' ? 'warning' : 'info')) %}
        {% for message in messages %}
            {{ faAlert.render(message|raw, tone, { dismissible: true })|raw }}
        {% endfor %}
    {% endfor %}

    {{ step_header.render(9, 12, step.kind, 'setup.compliance.header'|trans({}, 'setup'), 'setup.compliance.description'|trans({}, 'setup'))|raw }}

    {{ faAlert.render(
        'setup.applicability.intro.description'|trans({}, 'setup'),
        'info',
        { title: 'setup.applicability.intro.title'|trans({}, 'setup'), icon: 'bi-info-circle' }
    )|raw }}

    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'fa-setup-form'}}) }}

    {# 🔴 MANDATORY #}
    {% if mandatory_codes|length > 0 %}
        <div class="fa-setup-bucket-header">
            {{ pill.render('🔴 ' ~ 'setup.applicability.bucket.mandatory.label'|trans({}, 'setup'), 'danger', { size: 'sm', noDot: true })|raw }}
            <span class="fa-setup-bucket-hint">{{ 'setup.applicability.bucket.mandatory.hint'|trans({}, 'setup') }}</span>
        </div>
        <div class="fa-toggle-card-grid">
            {% for child in form.frameworks %}
                {% if child.vars.value in mandatory_codes %}
                    {% for framework in available_frameworks|filter(f => f.code == child.vars.value) %}
                        {{ wizard.framework_card(child, framework, classification, 'mandatory') }}
                    {% endfor %}
                {% endif %}
            {% endfor %}
        </div>
    {% endif %}

    {# 🟡 RECOMMENDED #}
    {% if recommended_codes|length > 0 %}
        <div class="fa-setup-bucket-header">
            {{ pill.render('🟡 ' ~ 'setup.applicability.bucket.recommended.label'|trans({}, 'setup'), 'warning', { size: 'sm', noDot: true })|raw }}
            <span class="fa-setup-bucket-hint">{{ 'setup.applicability.bucket.recommended.hint'|trans({}, 'setup') }}</span>
        </div>
        <div class="fa-toggle-card-grid">
            {% for child in form.frameworks %}
                {% if child.vars.value in recommended_codes %}
                    {% for framework in available_frameworks|filter(f => f.code == child.vars.value) %}
                        {{ wizard.framework_card(child, framework, classification, 'recommended') }}
                    {% endfor %}
                {% endif %}
            {% endfor %}
        </div>
    {% endif %}

    {# ⚪ OPTIONAL #}
    {% if optional_codes|length > 0 %}
        <div class="fa-setup-bucket-header">
            {{ pill.render('⚪ ' ~ 'setup.applicability.bucket.optional.label'|trans({}, 'setup'), 'neutral', { size: 'sm', noDot: true })|raw }}
            <span class="fa-setup-bucket-hint">{{ 'setup.applicability.bucket.optional.hint'|trans({}, 'setup') }}</span>
        </div>
        <div class="fa-toggle-card-grid">
            {% for child in form.frameworks %}
                {% if child.vars.value in optional_codes %}
                    {% for framework in available_frameworks|filter(f => f.code == child.vars.value) %}
                        {{ wizard.framework_card(child, framework, classification, 'optional') }}
                    {% endfor %}
                {% endif %}
            {% endfor %}
        </div>
    {% endif %}

    {{ faAlert.render(
        'setup.compliance.note.message'|trans({}, 'setup'),
        'warning',
        { title: 'setup.compliance.note.title'|trans({}, 'setup'), withAlva: true }
    )|raw }}

    <div class="fa-nav-bar">
        <div class="fa-nav-bar__left">
            {{ btn.link(path('setup_step7_modules'), 'setup.navigation.back'|trans({}, 'setup'), { variant: 'secondary', icon: 'bi-arrow-left' }) }}
        </div>
        <div class="fa-nav-bar__right">
            {{ btn.submit('setup.navigation.next'|trans({}, 'setup'), { variant: 'primary', icon: 'bi-arrow-right', iconAfter: true }) }}
        </div>
    </div>

    {# Explizit CSRF-Token rendern, danach form_end ohne render_rest — verhindert,
       dass Symfony die frameworks-Checkboxes ein zweites Mal ausgibt. #}
    {{ form_widget(form._token) }}
    {{ form_end(form, {'render_rest': false}) }}
{% endblock %}
