{% extends 'setup/_layout.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% set active_step = 'masterdata' %}

{% block title %}{{ 'setup.step9.title'|trans({}, 'setup') }}{% endblock %}

{% block step_content %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
{% embed '_components/_card.html.twig' with { 'class': 'shadow-lg' } %}
                {% block card_header %}
                    <div class="card-header">
                        <h1 class="h3 mb-0">
                            <i class="bi bi-file-earmark-import me-2" aria-hidden="true"></i>
                            {{ 'setup.step9.header'|trans({}, 'setup') }}
                        </h1>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="p-4">
                        <p class="lead mb-4">
                            {{ 'setup.step9.description'|trans({}, 'setup') }}
                        </p>

                        {# Base Data List #}
                        <h2 class="h5 mb-3">
                            <i class="bi bi-list-check me-2" aria-hidden="true"></i>
                            {{ 'setup.step9.data_to_import'|trans({}, 'setup') }}
                        </h2>

                        {% for data in base_data %}
                            {% embed '_components/_card.html.twig' with { 'class': 'mb-3 border-primary' } %}
                                {% block card_body %}
                                    <div class="d-flex align-items-start">
                                        <div class="flex-shrink-0 me-3">
                                            <i class="bi bi-check-circle text-primary " aria-hidden="true"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <p class="h6 mb-1">{{ data.name }}</p>
                                            <p class="text-muted mb-2">{{ data.description }}</p>
                                            {% if data.command is defined %}
                                                <small class="text-muted">
                                                    <i class="bi bi-terminal me-1" aria-hidden="true"></i>
                                                    {{ 'setup.step9.command'|trans({}, 'setup') }}: <code>{{ data.command }}</code>
                                                </small>
                                            {% endif %}
                                            {% if data.required_modules is defined %}
                                                <div class="mt-2">
                                                    <small class="text-muted">
                                                        <i class="bi bi-puzzle me-1" aria-hidden="true"></i>
                                                        {{ 'setup.step9.modules'|trans({}, 'setup') }}:
                                                        {% for module in data.required_modules %}
                                                            {% include '_components/_badge.html.twig' with { variant: 'secondary', content: module } %}
                                                        {% endfor %}
                                                    </small>
                                                </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                {% endblock %}
                            {% endembed %}
                        {% endfor %}

                        {{ _fa_alert.render({ variant: 'info', class: 'mt-4', title: 'setup.step9.note.title'|trans({}, 'setup'), body: 'setup.step9.note.message'|trans({}, 'setup') }) }}

                        {# Import Action #}
                        <form method="post" action="{{ path('setup_step9_base_data_import') }}"
                              data-controller="async-job"
                              data-async-job-status-url-value="{{ path('setup_job_status') }}?job=base_data"
                              data-async-job-poll-interval-value="2000"
                              data-async-job-message-running-value="{{ 'setup.alva.busy.base_data'|trans({}, 'setup') }}"
                              data-async-job-message-success-value="Stammdaten erfolgreich importiert."
                              data-async-job-redirect-url-value="{{ path('setup_step10_sample_data') }}"
                              data-action="submit->async-job#start">
                            <input type="hidden" name="_token" value="{{ csrf_token('setup_base_data') }}">
                            <div class="d-flex justify-content-between mt-4">
                                <a href="{{ path('setup_step8_compliance_frameworks') }}" class="btn btn-outline-secondary">
                                    <i class="bi bi-arrow-left me-2" aria-hidden="true"></i>
                                    {{ 'setup.navigation.back'|trans({}, 'setup') }}
                                </a>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-download me-2" aria-hidden="true"></i>
                                    {{ 'setup.step9.import_button'|trans({}, 'setup') }}
                                </button>
                            </div>
                        </form>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>
</div>
{% endblock %}
