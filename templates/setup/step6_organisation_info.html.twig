{% extends 'setup/_layout.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% set active_step = 'organisation' %}

{% block title %}{{ 'setup.organisation.title'|trans({}, 'setup') }} - Deployment Wizard{% endblock %}

{% block step_head %}
    {{ parent() }}
    {# Disable Turbo cache to ensure CSRF tokens are always fresh #}
    <meta name="turbo-cache-control" content="no-cache">
{% endblock %}


{% block step_content %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            {# Flash Messages #}
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    {% set faVariant = label in ['danger','error'] ? 'danger' : (label == 'success' ? 'success' : (label == 'warning' ? 'warning' : 'info')) %}
                    {{ _fa_alert.render({ variant: faVariant, dismissible: true, body: message }) }}
                {% endfor %}
            {% endfor %}


            {% embed '_components/_card.html.twig' with { 'class': 'shadow-lg' } %}
                {% block card_header %}
                    <div class="card-header">
                        <h1 class="h3 mb-0">
                            <i class="bi bi-building me-2" aria-hidden="true"></i>
                            {{ 'setup.organisation.header'|trans({}, 'setup') }}
                        </h1>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="p-4">
                        <p class="text-muted mb-4">
                            {{ 'setup.organisation.description'|trans({}, 'setup') }}
                        </p>

                        {# Organisation Info Form #}
                        {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate', 'data-controller': 'wizard-busy', 'data-wizard-busy-message-value': 'setup.alva.busy.default'|trans({}, 'setup')}}) }}

                        <div class="row">
                            <div class="col-md-12">
                                {% include '_components/_form_field.html.twig' with {
                                    'field': form.name,
                                    'label': 'setup.organisation.name'|trans({}, 'setup'),
                                    'required': true
                                } %}
                            </div>
                        </div>

                        {# Multi-Industry Selection for Corporate Structures #}
                        {{ _fa_alert.render({ variant: 'info', icon: 'bi-diagram-3', class: 'mb-2', body: '<small>{{ \'setup.organisation.industries_help\'|trans({}, \'setup\') }}</small>' }) }}
                        <div class="row">
                            <div class="col-md-12">
                                {% include '_components/_form_field.html.twig' with {
                                    'field': form.industries,
                                    'label': 'setup.organisation.industries'|trans({}, 'setup')
                                } %}
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                {% include '_components/_form_field.html.twig' with {
                                    'field': form.employee_count,
                                    'label': 'setup.organisation.employee_count'|trans({}, 'setup')
                                } %}
                            </div>
                            <div class="col-md-6">
                                {% include '_components/_form_field.html.twig' with {
                                    'field': form.country,
                                    'label': 'setup.organisation.country'|trans({}, 'setup')
                                } %}
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12">
                                {% include '_components/_form_field.html.twig' with {
                                    'field': form.description,
                                    'label': 'setup.organisation.description'|trans({}, 'setup')
                                } %}
                            </div>
                        </div>

                        {# Information Box #}
                        {{ _fa_alert.render({ variant: 'info', icon: 'bi-info-circle', body: '<strong>{{ \'setup.organisation.usage.title\'|trans({}, \'setup\') }}</strong> <p class="mb-0">{{ \'setup.organisation.usage.message\'|trans({}, \'setup\') }}</p>' }) }}

                        {# Navigation #}
                        <div class="d-flex justify-content-between mt-4">
                            <a href="{{ path('setup_step5_email_config') }}" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-2" aria-hidden="true"></i>
                                {{ 'setup.navigation.back'|trans({}, 'setup') }}
                            </a>

                            <button type="submit" class="btn btn-primary">
                                {{ 'setup.navigation.next'|trans({}, 'setup') }}
                                <i class="bi bi-arrow-right ms-2" aria-hidden="true"></i>
                            </button>
                        </div>

                        {{ form_end(form) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {# Compliance Information Card #}
            {% embed '_components/_card.html.twig' with { 'class': 'mt-4 border-info' } %}
                {% block card_body %}
                    <p class="h5 mb-3">
                        <i class="bi bi-shield text-info me-2" aria-hidden="true"></i>
                        {{ 'setup.organisation.compliance_info.title'|trans({}, 'setup') }}
                    </p>
                    <p class="text-muted mb-2">
                        {{ 'setup.organisation.compliance_info.description'|trans({}, 'setup') }}
                    </p>
                    <ul class="text-muted mb-0">
                        <li>{{ 'setup.organisation.compliance_info.scope'|trans({}, 'setup') }}</li>
                        <li>{{ 'setup.organisation.compliance_info.reporting'|trans({}, 'setup') }}</li>
                        <li>{{ 'setup.organisation.compliance_info.recommendations'|trans({}, 'setup') }}</li>
                    </ul>
                {% endblock %}
            {% endembed %}
        </div>
    </div>
</div>
{% endblock %}
