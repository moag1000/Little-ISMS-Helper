{% extends 'setup/_layout.html.twig' %}
{% trans_default_domain 'setup' %}
{% set active_step = 'welcome' %}

{% block title %}{{ 'setup.welcome.title'|trans({}, 'setup') }}{% endblock %}

{% block step_content %}
    {% import '_components/_step_header.html.twig' as step_header %}
    {% import '_components/_check_row.html.twig' as row %}
    {% import '_components/_nav_bar.html.twig' as nav %}

    {% for label, messages in app.flashes %}
        {% import '_components/_alert.html.twig' as faAlert %}
        {% for message in messages %}
            {{ faAlert.render(message|trans, label == 'success' ? 'success' : (label in ['error','danger'] ? 'danger' : (label == 'warning' ? 'warning' : 'info')), { dismissible: true })|raw }}
        {% endfor %}
    {% endfor %}

    {{ step_header.render(1, 12, step.kind, 'setup.welcome.greeting'|trans({}, 'setup'), 'setup.welcome.description'|trans({}, 'setup'))|raw }}

    <div class="fa-setup-welcome-grid">
        <section class="fa-setup-welcome-col">
            <h3 class="fa-setup-welcome-col__title">
                <i class="bi bi-list-check" aria-hidden="true"></i>
                {{ 'setup.welcome.steps.title'|trans({}, 'setup') }}
            </h3>
            {{ row.render({ status: 'idle', label: 'setup.welcome.steps.database'|trans({}, 'setup') })|raw }}
            {{ row.render({ status: 'idle', label: 'setup.welcome.steps.admin'|trans({}, 'setup') })|raw }}
            {{ row.render({ status: 'idle', label: 'setup.welcome.steps.requirements'|trans({}, 'setup') })|raw }}
            {{ row.render({ status: 'idle', label: 'setup.welcome.steps.modules'|trans({}, 'setup') })|raw }}
            {{ row.render({ status: 'idle', label: 'setup.welcome.steps.migrations'|trans({}, 'setup') })|raw }}
            {{ row.render({ status: 'idle', label: 'setup.welcome.steps.base_data'|trans({}, 'setup') })|raw }}
            {{ row.render({ status: 'idle', label: 'setup.welcome.steps.sample_data'|trans({}, 'setup') })|raw }}
        </section>

        <section class="fa-setup-welcome-col">
            <h3 class="fa-setup-welcome-col__title">
                <i class="bi bi-clock" aria-hidden="true"></i>
                {{ 'setup.welcome.requirements.title'|trans({}, 'setup') }}
            </h3>
            {{ row.render({ status: 'ok', label: 'setup.welcome.requirements.duration'|trans({}, 'setup') })|raw }}
            {{ row.render({ status: 'ok', label: 'setup.welcome.requirements.database'|trans({}, 'setup') })|raw }}
            {{ row.render({ status: 'ok', label: 'setup.welcome.requirements.php'|trans({}, 'setup') })|raw }}
            {{ row.render({ status: 'ok', label: 'setup.welcome.requirements.permissions'|trans({}, 'setup') })|raw }}
        </section>
    </div>

    <div class="fa-setup-welcome-info">
        <h4 class="fa-setup-welcome-info__title">
            <i class="bi bi-info-circle" aria-hidden="true"></i>
            {{ 'setup.welcome.info.title'|trans({}, 'setup') }}
        </h4>
        <p class="fa-setup-welcome-info__desc">{{ 'setup.welcome.info.description'|trans({}, 'setup') }}</p>
        <ul class="fa-setup-welcome-info__list">
            <li>{{ 'setup.welcome.info.point1'|trans({}, 'setup') }}</li>
            <li>{{ 'setup.welcome.info.point2'|trans({}, 'setup') }}</li>
            <li>{{ 'setup.welcome.info.point3'|trans({}, 'setup') }}</li>
        </ul>
    </div>

    {{ nav.render({
        next: {
            url: path('setup_step1_requirements'),
            label: 'setup.welcome.start_button'|trans({}, 'setup'),
            icon: 'bi-play-fill'
        }
    })|raw }}
{% endblock %}
