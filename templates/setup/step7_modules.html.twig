{% extends 'setup/_layout.html.twig' %}
{% trans_default_domain 'setup' %}
{% set active_step = 'modules' %}

{% block title %}{{ 'setup.step7.title'|trans({}, 'setup') }}{% endblock %}

{% block step_content %}
    {% import '_components/_step_header.html.twig' as step_header %}
    {% import '_components/_toggle_card.html.twig' as tc %}
    {% import '_components/_alert.html.twig' as faAlert %}
    {% import '_components/_status_pill.html.twig' as pill %}
    {% import '_components/_cyber_button.html.twig' as btn %}

    {{ step_header.render(8, 12, step.kind, 'setup.step7.header'|trans({}, 'setup'), 'setup.step7.intro'|trans({}, 'setup'))|raw }}

    {% if recommended_modules is defined and recommended_modules|length > 0 %}
        {{ faAlert.render(
            'setup.step7.recommendations.description'|trans({}, 'setup'),
            'info',
            { title: 'setup.step7.recommendations.title'|trans({}, 'setup'), icon: 'bi-lightbulb' }
        )|raw }}
    {% endif %}

    <form method="post" action="{{ path('setup_step7_modules_save') }}" class="fa-setup-modules-form">
        <input type="hidden" name="_token" value="{{ csrf_token('setup_modules') }}">

        {# Required Modules #}
        <h2 class="fa-setup-section-title">
            <i class="bi bi-star-fill" style="color: var(--warning);" aria-hidden="true"></i>
            {{ 'setup.step7.required_modules'|trans({}, 'setup') }}
        </h2>

        <div class="fa-toggle-card-grid">
            {% for key, module in all_modules %}
                {% if module.required %}
                    <label class="fa-toggle-card is-on is-disabled" for="module_{{ key }}">
                        <input type="hidden" name="modules[]" value="{{ key }}">
                        <input type="checkbox" checked disabled id="module_{{ key }}"
                               class="fa-toggle-card__input">
                        <span class="fa-toggle-card__box" aria-hidden="true">
                            <svg viewBox="0 0 14 14" width="10" height="10" fill="none">
                                <path d="M2 7 L6 11 L12 3" stroke="currentColor" stroke-width="2.5"
                                      stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                        <div class="fa-toggle-card__body">
                            <div class="fa-toggle-card__title">
                                <i class="bi bi-{{ module.icon }}" aria-hidden="true"></i>
                                {{ module.name }}
                                <span class="fa-toggle-card__badge">{{ 'setup.step7.badge.required'|trans({}, 'setup') }}</span>
                            </div>
                            <div class="fa-toggle-card__sub">{{ module.description }}</div>
                        </div>
                    </label>
                {% endif %}
            {% endfor %}
        </div>

        {# Optional Modules #}
        <h2 class="fa-setup-section-title">
            <i class="bi bi-toggle-on" style="color: var(--primary);" aria-hidden="true"></i>
            {{ 'setup.step7.optional_modules'|trans({}, 'setup') }}
        </h2>

        <div class="fa-toggle-card-grid" id="optional-modules">
            {% for key, module in optional_modules %}
                {% set isRecommended = recommended_modules is defined and key in recommended_modules %}
                {% set isChecked = key in selected_modules %}
                <label for="module_{{ key }}"
                       class="fa-toggle-card module-card {% if isChecked %}is-on{% endif %}"
                       data-module="{{ key }}"
                       data-dependencies="{{ module.dependencies|json_encode }}">
                    <input id="module_{{ key }}" type="checkbox" name="modules[]" value="{{ key }}"
                           class="fa-toggle-card__input module-checkbox"
                           {{ isChecked ? 'checked' : '' }}>
                    <span class="fa-toggle-card__box" aria-hidden="true">
                        <svg viewBox="0 0 14 14" width="10" height="10" fill="none">
                            <path d="M2 7 L6 11 L12 3" stroke="currentColor" stroke-width="2.5"
                                  stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </span>
                    <div class="fa-toggle-card__body">
                        <div class="fa-toggle-card__title">
                            <i class="bi bi-{{ module.icon }}" aria-hidden="true"></i>
                            {{ module.name }}
                            {% if isRecommended %}
                                <span class="fa-toggle-card__badge">{{ 'setup.step7.badge.recommended'|trans({}, 'setup') }}</span>
                            {% endif %}
                        </div>
                        <div class="fa-toggle-card__sub">{{ module.description }}</div>
                        {% if module.dependencies|length > 0 %}
                            <div class="fa-toggle-card__meta">
                                <i class="bi bi-link-45deg" aria-hidden="true"></i>
                                <span style="color: var(--warning-text);">{{ 'setup.step7.dependencies'|trans({}, 'setup') }}</span>
                                {% for dep in module.dependencies %}
                                    {{ pill.render(all_modules[dep].name, 'warning', { size: 'sm', noDot: true })|raw }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                </label>
            {% endfor %}
        </div>

        <div class="fa-setup-modules-summary">
            <i class="bi bi-pie-chart" aria-hidden="true"></i>
            <strong>{{ 'setup.step7.summary.title'|trans({}, 'setup') }}</strong>
            <span>
                {{ 'setup.step7.summary.selected'|trans({'%selected%': '<span id="selected-count">0</span>', '%total%': all_modules|length}, 'setup')|raw }}
            </span>
        </div>

        <div class="fa-nav-bar">
            <div class="fa-nav-bar__left">
                {{ btn.link(path('setup_step6_organisation_info'), 'setup.common.back'|trans({}, 'setup'),
                   { variant: 'secondary', icon: 'bi-arrow-left' }) }}
            </div>
            <div class="fa-nav-bar__right">
                {{ btn.submit('setup.next_step'|trans({'%step%': 8, '%name%': 'setup.steps.compliance_frameworks'|trans({}, 'setup')}, 'messages'),
                   { variant: 'primary', icon: 'bi-arrow-right', iconAfter: true }) }}
            </div>
        </div>
    </form>

    <script>
    (function() {
        function initModuleSelection() {
            const checkboxes = document.querySelectorAll('.module-checkbox');
            const selectedCount = document.getElementById('selected-count');
            if (!selectedCount) return;
            const requiredCount = {{ required_modules|length }};
            const dependencyMap = {};
            const dependentsMap = {};

            document.querySelectorAll('.module-card').forEach(card => {
                const moduleKey = card.dataset.module;
                const deps = JSON.parse(card.dataset.dependencies || '[]');
                dependencyMap[moduleKey] = deps;
                deps.forEach(dep => {
                    if (!dependentsMap[dep]) dependentsMap[dep] = [];
                    dependentsMap[dep].push(moduleKey);
                });
            });

            function updateCount() {
                const checked = document.querySelectorAll('.module-checkbox:checked').length;
                selectedCount.textContent = checked + requiredCount;
            }

            function selectDependencies(moduleKey) {
                (dependencyMap[moduleKey] || []).forEach(dep => {
                    const depCheckbox = document.getElementById('module_' + dep);
                    if (depCheckbox && !depCheckbox.checked) {
                        depCheckbox.checked = true;
                        depCheckbox.closest('.fa-toggle-card')?.classList.add('is-on');
                        selectDependencies(dep);
                    }
                });
            }

            function deselectDependents(moduleKey) {
                (dependentsMap[moduleKey] || []).forEach(dep => {
                    const depCheckbox = document.getElementById('module_' + dep);
                    if (depCheckbox && depCheckbox.checked) {
                        depCheckbox.checked = false;
                        depCheckbox.closest('.fa-toggle-card')?.classList.remove('is-on');
                        deselectDependents(dep);
                    }
                });
            }

            checkboxes.forEach(checkbox => {
                checkbox.addEventListener('change', function() {
                    const card = this.closest('.fa-toggle-card');
                    card?.classList.toggle('is-on', this.checked);
                    if (this.checked) selectDependencies(this.value);
                    else deselectDependents(this.value);
                    updateCount();
                });
            });
            updateCount();
        }
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initModuleSelection);
        } else {
            initModuleSelection();
        }
        document.addEventListener('turbo:load', initModuleSelection);
    })();
    </script>
{% endblock %}
