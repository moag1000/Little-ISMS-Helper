{#
 # Reusable Evidence Upload Widget
 #
 # Include in entity show pages to manage evidence documents.
 #
 # Parameters:
 #   entityType  - 'control', 'requirement', or 'risk_treatment_plan' (required)
 #   entityId    - integer ID of the entity (required)
 #   documents   - Collection of Document entities (required)
 #
 # Usage:
 #   {% include 'evidence/_upload_widget.html.twig' with {
 #       entityType: 'control',
 #       entityId: control.id,
 #       documents: control.evidenceDocuments
 #   } %}
 #}

{% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
    {% block card_header %}
        <div class="card-header d-flex justify-content-between align-items-center">
            <h2>
                <i class="fa-icon fa-icon--nav-list-check" aria-hidden="true"></i>
                {{ 'evidence.widget.title'|trans({}, 'evidence') }}
                {% if documents|length > 0 %}
                    {% include '_components/_badge.html.twig' with { variant: 'success', content: documents|length } %}
                {% endif %}
            </h2>
        </div>
    {% endblock %}
    {% block card_body %}
        {# Existing evidence list #}
        {% if documents|length > 0 %}
            <div class="evidence-list mb-3">
                {% for doc in documents %}
                    <div class="evidence-item d-flex justify-content-between align-items-center py-2 border-bottom">
                        <div>
                            <a href="{{ path('app_document_show', {id: doc.id}) }}">
                                <i class="bi bi-file-earmark-text" aria-hidden="true"></i>
                                {{ doc.originalFilename }}
                            </a>
                            <small class="text-muted ms-2">{{ doc.fileSizeFormatted }}</small>
                            <small class="text-muted ms-2">{{ doc.uploadedAt|date('d.m.Y') }}</small>
                        </div>
                        <div class="d-flex gap-1">
                            <a href="{{ path('app_document_download', {id: doc.id}) }}"
                               class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost"
                               title="{{ 'common.download'|trans({}, 'messages') }}">
                                <i class="bi bi-download" aria-hidden="true"></i>
                            </a>
                            <button type="button"
                                    class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost text-danger"
                                    title="{{ 'evidence.unlink'|trans({}, 'evidence') }}"
                                    onclick="unlinkEvidence({{ doc.id }}, '{{ entityType }}', {{ entityId }})">
                                <i class="bi bi-x-lg" aria-hidden="true"></i>
                            </button>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p class="text-muted mb-3">
                <i class="bi bi-info-circle" aria-hidden="true"></i>
                {{ 'evidence.widget.empty'|trans({}, 'evidence') }}
            </p>
        {% endif %}

        {# Upload form #}
        <form method="post" action="{{ path('app_evidence_upload') }}" enctype="multipart/form-data">
            <input type="hidden" name="_token" value="{{ csrf_token('evidence_upload') }}">
            <input type="hidden" name="entity_type" value="{{ entityType }}">
            <input type="hidden" name="entity_id" value="{{ entityId }}">
            <div class="d-flex gap-2 align-items-end">
                <div class="flex-grow-1">
                    <label for="evidence_file_{{ entityType }}_{{ entityId }}" class="form-label small">
                        {{ 'evidence.widget.upload_here'|trans({}, 'evidence') }}
                    </label>
                    <input type="file" name="evidence_file" id="evidence_file_{{ entityType }}_{{ entityId }}"
                           class="form-control form-control-sm" required
                           accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.csv,.jpg,.jpeg,.png,.gif,.webp,.zip,.7z">
                </div>
                <button type="submit" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--primary">
                    <i class="fa-icon fa-icon--ui-upload" aria-hidden="true"></i> {{ 'evidence.upload'|trans({}, 'evidence') }}
                </button>
            </div>
        </form>
    {% endblock %}
{% endembed %}

<script>
function unlinkEvidence(documentId, entityType, entityId) {
    if (!confirm('{{ 'evidence.unlink_confirm'|trans({}, 'evidence') }}')) {
        return;
    }

    const formData = new FormData();
    formData.append('_token', '{{ csrf_token('evidence_unlink') }}');
    formData.append('document_id', documentId);
    formData.append('entity_type', entityType);
    formData.append('entity_id', entityId);

    fetch('{{ path('app_evidence_unlink') }}', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            window.location.reload();
        } else {
            alert(data.error || 'Error unlinking evidence');
        }
    })
    .catch(error => {
        alert('Network error: ' + error.message);
    });
}
</script>
