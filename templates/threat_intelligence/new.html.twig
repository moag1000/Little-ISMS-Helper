{% extends 'base.html.twig' %}
{% trans_default_domain 'threat' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'threat.title.new'|trans({}, 'threat') }} - {{ parent() }}{% endblock %}

{% block body %}
{% include '_components/_breadcrumb.html.twig' with {
    breadcrumbs: [
        { label: 'threat.title.index'|trans({}, 'threat'), url: path('app_threat_intelligence_index'), icon: 'nav-shield-alert' },
        { label: 'threat.title.new'|trans({}, 'threat') }
    ]
} %}

{{ _fa_page_header.render({
    title: 'threat.title.new'|trans({}, 'threat'),
    badge: { icon: 'plus', label: '' },
    actions: [
        { label: 'common.back'|trans({}, 'messages'), href: path('app_threat_intelligence_index'), variant: 'secondary', icon: 'util-arrow-left' }
    ]
}) }}

{% embed '_components/_card.html.twig' %}
    {% block card_body %}
        {{ form_start(form) }}
            {% include '_components/_auto_form.html.twig' with {
                'form': form,
                'sections': {
                    'basic': {
                        'label': 'threat.section.basic'|trans({}, 'threat'),
                        'fields': ['title', 'description', 'threatType', 'severity', 'status']
                    },
                    'details': {
                        'label': 'threat.section.details'|trans({}, 'threat'),
                        'fields': ['source', 'cveId', 'cvssScore', 'detectionDate', 'mitigationDate']
                    },
                    'impact': {
                        'label': 'threat.section.impact'|trans({}, 'threat'),
                        'fields': ['affectsOrganization', 'affectedAssets', 'mitigationRecommendations', 'actionsTaken', 'references']
                    },
                    'assignment': {
                        'label': 'threat.section.assignment'|trans({}, 'threat'),
                        'fields': ['assignedTo', 'assignedPerson', 'assignedDeputyPersons']
                    }
                },
                'col_widths': {
                    'title': 8,
                    'threatType': 4,
                    'description': 12,
                    'severity': 4,
                    'status': 4,
                    'affectsOrganization': 4,
                    'source': 6,
                    'cveId': 3,
                    'cvssScore': 3,
                    'detectionDate': 6,
                    'mitigationDate': 6,
                    'affectedAssets': 12,
                    'mitigationRecommendations': 12,
                    'actionsTaken': 12,
                    'references': 12,
                    'assignedTo': 4,
                    'assignedPerson': 4,
                    'assignedDeputyPersons': 4
                },
                'translation_domain': 'threat'
            } %}

            <div class="form-actions d-flex gap-2 justify-content-end">
                <a href="{{ path('app_threat_intelligence_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                    <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i>
                    {{ 'common.cancel'|trans({}, 'messages') }}
                </a>
                <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                    <i class="fa-icon fa-icon--ui-save" aria-hidden="true"></i>
                    {{ 'threat.action.create'|trans({}, 'threat') }}
                </button>
            </div>
        {{ form_end(form) }}
    {% endblock %}
{% endembed %}
{% endblock %}
