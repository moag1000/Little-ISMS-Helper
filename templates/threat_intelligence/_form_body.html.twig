{# Shared ThreatIntelligence form body (outline-rail). Used full-page by new/edit
   and inside the fa-form-modal frame (modal: true). Caller wraps it in
   form_start/form_end and passes title/subtitle/actions. #}
{% trans_default_domain 'threat' %}
{% include '_components/_auto_form.html.twig' with {
    'form': form,
    'layout': 'outline-rail',
    'modal': modal|default(false),
    'eyebrow': 'ISO 27001 A.5.7 · Threat Intelligence',
    'title': title,
    'subtitle': subtitle|default(null),
    'sections': {
        'basic': {
            'label': 'threat.section.basic'|trans({}, 'threat'),
            'fields': ['title', 'description', 'threatType', 'severity', 'status']
        },
        'details': {
            'label': 'threat.section.details'|trans({}, 'threat'),
            'fields': ['source', 'cveId', 'cvssScore', 'detectionDate', 'mitigationDate']
        },
        'impact': {
            'label': 'threat.section.impact'|trans({}, 'threat'),
            'fields': ['affectsOrganization', 'affectedAssets', 'mitigationRecommendations', 'actionsTaken', 'references']
        },
        'assignment': {
            'label': 'threat.section.assignment'|trans({}, 'threat'),
            'fields': ['assignedTo', 'assignedPerson', 'assignedDeputyPersons']
        },
        'classification': {
            'label': 'threat.section.classification'|trans({}, 'threat'),
            'fields': ['tlpClassification', 'confidenceLevel', 'sharedExternally', 'threatActorAttribution', 'mitreAttackTactics', 'mitreAttackTechniques', 'iocsList']
        }
    },
    'col_widths': {
        'title': 8,
        'threatType': 4,
        'description': 12,
        'severity': 4,
        'status': 4,
        'affectsOrganization': 4,
        'source': 6,
        'cveId': 3,
        'cvssScore': 3,
        'detectionDate': 6,
        'mitigationDate': 6,
        'affectedAssets': 12,
        'mitigationRecommendations': 12,
        'actionsTaken': 12,
        'references': 12,
        'assignedTo': 4,
        'assignedPerson': 4,
        'assignedDeputyPersons': 4,
        'tlpClassification': 6,
        'confidenceLevel': 6,
        'sharedExternally': 6,
        'threatActorAttribution': 12,
        'mitreAttackTactics': 6,
        'mitreAttackTechniques': 6,
        'iocsList': 12
    },
    'translation_domain': 'threat',
    'actions': actions
} %}
