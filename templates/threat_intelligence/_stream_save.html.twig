{# Turbo Stream after a successful in-modal ThreatIntelligence save. #}
{% if is_new %}
    <turbo-stream action="append" target="threat-intelligence-rows">
        <template>{% include 'threat_intelligence/_row.html.twig' with { threat: threat } %}</template>
    </turbo-stream>
{% else %}
    <turbo-stream action="replace" target="threat-intelligence-row-{{ threat.id }}">
        <template>{% include 'threat_intelligence/_row.html.twig' with { threat: threat } %}</template>
    </turbo-stream>
{% endif %}
