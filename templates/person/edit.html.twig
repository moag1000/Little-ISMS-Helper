{% extends 'base.html.twig' %}
{% trans_default_domain 'people' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'person.title.edit'|trans({}, 'messages') }} - {{ person.fullName }} - Little ISMS Helper{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.people'|trans({}, 'nav'), url: path('app_person_index') },
            { label: person.fullName, url: path('app_person_show', {id: person.id}) },
            { label: 'common.edit'|trans({}, 'messages') }
        ]
    } %}
</div>

{{ _fa_page_header.render({
    title: ('person.title.edit'|trans({}, 'messages')) ~ ': ' ~ (person.fullName),
    badge: { icon: 'ui-edit', label: '' },
    actions: [
        { label: 'common.back'|trans({}, 'messages'), href: path('app_person_show', {id: person.id}), variant: 'ghost', icon: 'util-arrow-left' }
    ]
}) }}

{{ form_start(form) }}
{% include '_components/_auto_form.html.twig' with {
    'form': form,
    'layout': 'outline-rail',
    'eyebrow': 'ISO 27001 A.7.2 · People Management',
    'title': ('person.title.edit'|trans({}, 'messages')) ~ ': ' ~ person.fullName,
    'sections': {
        'identity': {
            'label': 'person.section.basic_info'|trans({}, 'messages'),
            'fields': ['fullName', 'personType', 'badgeId', 'active']
        },
        'contact': {
            'label': 'person.section.contact'|trans({}, 'messages'),
            'fields': ['email', 'phone']
        },
        'organization': {
            'label': 'person.section.organization'|trans({}, 'messages'),
            'fields': ['company', 'department', 'jobTitle', 'linkedUser']
        },
        'role': {
            'label': 'person.section.access'|trans({}, 'messages'),
            'fields': ['accessValidFrom', 'accessValidUntil', 'notes']
        }
    },
    'col_widths': {
        'fullName': 6,
        'personType': 6,
        'badgeId': 8,
        'active': 4,
        'email': 6,
        'phone': 6,
        'company': 4,
        'department': 4,
        'jobTitle': 4,
        'linkedUser': 12,
        'accessValidFrom': 6,
        'accessValidUntil': 6,
        'notes': 12
    },
    'translation_domain': 'people',
    'actions': {
        'close': { 'label': 'common.cancel'|trans({}, 'messages'), 'variant': 'ghost' },
        'submit': { 'label': 'common.save'|trans({}, 'messages'), 'variant': 'primary' }
    }
} %}
{{ form_end(form) }}
{% endblock %}
