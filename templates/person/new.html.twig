{% extends 'base.html.twig' %}
{% trans_default_domain 'people' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'person.title.create'|trans({}, 'messages') }} - Little ISMS Helper{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.people'|trans({}, 'nav'), url: path('app_person_index') },
            { label: 'person.title.create'|trans({}, 'messages') }
        ]
    } %}
</div>

{{ _fa_page_header.render({
    title: ('person.title.create'|trans({}, 'messages')),
    badge: { icon: 'plus', label: '' },
    actions: [
        { label: 'common.back_to_list'|trans({}, 'messages'), href: path('app_person_index'), variant: 'ghost', icon: 'util-arrow-left' }
    ]
}) }}

{% if available_users|default([])|length > 0 and not prefilled_from_user %}
<div class="fa-alert fa-alert--info mb-4" role="region" aria-labelledby="from-user-title">
    <i class="fa-icon fa-icon--ui-info-circle fa-alert__icon" aria-hidden="true"></i>
    <div class="fa-alert__body">
        <div class="fw-bold mb-2" id="from-user-title">{{ 'person.from_user.title'|trans({}, 'people') }}</div>
        <p class="mb-2 small">{{ 'person.from_user.help'|trans({}, 'people') }}</p>
        <form method="get" action="{{ path('app_person_new') }}" class="row g-2 align-items-end">
            <div class="col-sm-8">
                <label for="from_user" class="form-label small mb-1">{{ 'person.from_user.label'|trans({}, 'people') }}</label>
                <select id="from_user" name="from_user" class="form-select form-select-sm fa-cyber-input__field" required>
                    <option value="">{{ 'person.from_user.placeholder'|trans({}, 'people') }}</option>
                    {% for u in available_users %}
                        <option value="{{ u.id }}">{{ u.fullName }} &lt;{{ u.email }}&gt;</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-sm-4">
                <button type="submit" class="fa-cyber-btn fa-cyber-btn--secondary fa-cyber-btn--sm w-100">
                    <i class="fa-icon fa-icon--ui-arrow-right" aria-hidden="true"></i>
                    {{ 'person.from_user.submit'|trans({}, 'people') }}
                </button>
            </div>
        </form>
    </div>
</div>
{% endif %}

{% if prefilled_from_user %}
<div class="fa-alert fa-alert--success mb-4" role="status">
    <i class="fa-icon fa-icon--ui-check fa-alert__icon" aria-hidden="true"></i>
    <div class="fa-alert__body">
        <div class="fw-bold">{{ 'person.from_user.prefilled_title'|trans({}, 'people') }}</div>
        <p class="mb-0 small">{{ 'person.from_user.prefilled_help'|trans({}, 'people') }}</p>
    </div>
</div>
{% endif %}

{{ form_start(form) }}
{% include '_components/_auto_form.html.twig' with {
    'form': form,
    'layout': 'outline-rail',
    'eyebrow': 'ISO 27001 A.7.2 · People Management',
    'title': 'person.title.create'|trans({}, 'messages'),
    'sections': {
        'identity': {
            'label': 'person.section.basic_info'|trans({}, 'messages'),
            'fields': ['fullName', 'personType', 'badgeId', 'active']
        },
        'contact': {
            'label': 'person.section.contact'|trans({}, 'messages'),
            'fields': ['email', 'phone']
        },
        'organization': {
            'label': 'person.section.organization'|trans({}, 'messages'),
            'fields': ['company', 'department', 'jobTitle', 'linkedUser']
        },
        'role': {
            'label': 'person.section.access'|trans({}, 'messages'),
            'fields': ['accessValidFrom', 'accessValidUntil', 'notes']
        }
    },
    'col_widths': {
        'fullName': 6,
        'personType': 6,
        'badgeId': 8,
        'active': 4,
        'email': 6,
        'phone': 6,
        'company': 4,
        'department': 4,
        'jobTitle': 4,
        'linkedUser': 12,
        'accessValidFrom': 6,
        'accessValidUntil': 6,
        'notes': 12
    },
    'translation_domain': 'people',
    'actions': {
        'close': { 'label': 'common.cancel'|trans({}, 'messages'), 'variant': 'ghost' },
        'submit': { 'label': 'common.create'|trans({}, 'messages'), 'variant': 'primary' }
    }
} %}
{{ form_end(form) }}
{% endblock %}
