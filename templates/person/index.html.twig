{% extends 'base.html.twig' %}
{% trans_default_domain 'people' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'person.title.list'|trans({}, 'messages') }} - Little ISMS Helper{% endblock %}

{% block body %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}

<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.people'|trans({}, 'nav') }
        ]
    } %}
</div>

{{ _fa_page_header.render({
    badge: { icon: 'people', label: 'nav.people'|trans({}, 'nav') },
    title: 'person.title.list'|trans({}, 'messages'),
    subtitle: 'person.description.overview'|trans({}, 'messages'),
    actions: [
        { label: 'person.action.create'|trans({}, 'messages'), variant: 'primary', icon: 'plus-circle', href: path('app_person_new') }
    ]
}) }}

<main class="fa-aurora-surface">

{# Statistics Cards #}
<div class="kpi-grid">
    <div class="col-auto">
        {{ _fa_feature_card.render({ label: 'person.stats.total'|trans({}, 'messages'), value: persons|length, variant: 'primary' }) }}
    </div>
    <div class="col-auto">
        {{ _fa_feature_card.render({ label: 'person.stats.employees'|trans({}, 'messages'), value: persons|filter(p => p.personType == 'employee')|length, variant: 'success' }) }}
    </div>
    <div class="col-auto">
        {{ _fa_feature_card.render({ label: 'person.stats.contractors'|trans({}, 'messages'), value: persons|filter(p => p.personType == 'contractor')|length, variant: 'info' }) }}
    </div>
    <div class="col-auto">
        {{ _fa_feature_card.render({ label: 'person.stats.with_badge'|trans({}, 'messages'), value: persons|filter(p => p.badgeId)|length, variant: 'warning' }) }}
    </div>
</div>

{# Persons Table #}
{% embed '_components/_table.html.twig' with {
    'wrapperClass': 'table-container'
} %}
    {% block table_head %}
        <tr>
            <th scope="col">{{ 'person.field.name'|trans({}, 'messages') }}</th>
            <th scope="col">{{ 'person.field.type'|trans({}, 'messages') }}</th>
            <th scope="col">{{ 'person.field.badge_id'|trans({}, 'messages') }}</th>
            <th scope="col">{{ 'person.field.company'|trans({}, 'messages') }}</th>
            <th scope="col">{{ 'person.field.email'|trans({}, 'messages') }}</th>
            <th scope="col">{{ 'person.field.department'|trans({}, 'messages') }}</th>
            <th scope="col" class="text-center">{{ 'common.actions'|trans({}, 'messages') }}</th>
        </tr>
    {% endblock %}
    {% block table_body %}
        {% for person in persons %}
        <tr>
            <td>
                <strong>{{ person.fullName }}</strong>
                {% if person.jobTitle %}
                    <br><small class="text-muted-color">{{ person.jobTitle }}</small>
                {% endif %}
            </td>
            <td>
                {% set typeColors = {
                    'employee': 'success',
                    'contractor': 'info',
                    'visitor': 'warning',
                    'vendor': 'info',
                    'auditor': 'danger',
                    'consultant': 'info'
                } %}
                {% include '_components/_badge.html.twig' with { variant: typeColors[person.personType]|default('secondary'), content: ('person.type.' ~ person.personType)|trans({}, 'people') } %}
            </td>
            <td>
                {% if person.badgeId %}
                    <code>{{ person.badgeId }}</code>
                {% else %}
                    <span class="text-muted-color">-</span>
                {% endif %}
            </td>
            <td>{{ person.company ?? '-' }}</td>
            <td>
                {% if person.email %}
                    <a href="mailto:{{ person.email }}">{{ person.email }}</a>
                {% else %}
                    <span class="text-muted-color">-</span>
                {% endif %}
            </td>
            <td>{{ person.department ?? '-' }}</td>
            <td class="text-center">
                <div class="btn-group btn-group-sm" role="group" aria-label="{{ 'person.actions.label'|trans({}, 'messages') }}">
                    <a href="{{ path('app_person_show', {id: person.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost" aria-label="{{ 'common.view'|trans({}, 'messages') }} {{ person.fullName }}">
                        <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
                    </a>
                    <a href="{{ path('app_person_edit', {id: person.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost" aria-label="{{ 'common.edit'|trans({}, 'messages') }} {{ person.fullName }}">
                        <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                    </a>
                </div>
            </td>
        </tr>
        {% else %}
        <tr>
            <td colspan="7" class="text-center-p-xl-muted">
                {{ 'person.message.no_persons'|trans({}, 'messages') }}
            </td>
        </tr>
        {% endfor %}
    {% endblock %}
{% endembed %}
</main>
{% endblock %}
