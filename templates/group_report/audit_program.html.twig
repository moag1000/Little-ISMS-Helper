{# ─────────────────────────────────────────────────────────────────────────
   Group Audit Program Report — fa-report-doc 5-slot macro (web variant)
   Audience: auditor (Group Audit Committee)
   Status:   auditor-only
   ─────────────────────────────────────────────────────────────────────── #}
{% extends 'base.html.twig' %}

{% block title %}{{ 'group_report.audit_program.title'|trans({}, 'group_report') }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'group_report.title'|trans({}, 'group_report'), path: 'app_group_report_tree' },
            { label: 'group_report.audit_program.title'|trans({}, 'group_report') }
        ]
    } %}

    {% import '_components/_fa_report_doc.html.twig' as _fa_report_doc %}

    {# Build audit program matrix rows (program × subsidiaries) #}
    {% set _prog_rows = [] %}
    {% if programs is not empty and subsidiaries is not empty %}
        {% for program in programs %}
            {# First cell: program identity #}
            {% set _prog_cell = '<strong>' ~ program.title ~ '</strong>'
                ~ '<br><code style="font-size:.7em;color:var(--fg-3);">' ~ program.auditNumber ~ '</code>'
                ~ (program.plannedDate ? ' <span style="font-size:.75em;color:var(--fg-3);">· ' ~ program.plannedDate|date('Y-m-d') ~ '</span>' : '')
                ~ (program.scopeType ? ' <code style="font-size:.7em;">' ~ program.scopeType ~ '</code>' : '') %}
            {% set _row = [ _prog_cell ] %}

            {# One cell per subsidiary #}
            {% for sub in subsidiaries %}
                {% set derived = matrix[program.id][sub.code] %}
                {% if derived is null %}
                    {% set _row = _row|merge([ '<span style="color:var(--fg-3);" title="' ~ ('group_report.audit_program.cell.missing_help'|trans({}, 'group_report')) ~ '">·</span>' ]) %}
                {% else %}
                    {% set status = derived.status %}
                    {% set _chip = status == 'completed' ? 'final' : (status == 'in_progress' ? 'draft' : (status == 'planned' ? 'auditor-only' : 'confidential')) %}
                    {% set _sym = status == 'completed' ? '✓' : (status == 'in_progress' ? '◐' : (status == 'planned' ? '◯' : '–')) %}
                    {% set _row = _row|merge([ '<span class="report-doc__chip report-doc__chip--status-' ~ _chip ~ '" title="' ~ status ~ ' — ' ~ derived.auditNumber ~ '">' ~ _sym ~ '</span>' ]) %}
                {% endif %}
            {% endfor %}

            {# Last cell: derive action form — preserved as interactive element #}
            {% set _form_html = '<form method="post" action="' ~ path('app_group_report_audit_program_derive', {id: program.id}) ~ '" class="d-inline"'
                ~ ' data-controller="ui-actions"'
                ~ ' data-action="submit->ui-actions#confirm"'
                ~ ' data-ui-actions-message-param="' ~ ('group_report.audit_program.confirm_derive'|trans({'%count%': subsidiaries|length}, 'group_report')) ~ '"'
                ~ ' data-ui-actions-tone-param="danger">'
                ~ '<input type="hidden" name="_token" value="' ~ csrf_token('audit_program_derive_' ~ program.id) ~ '">'
                ~ '<button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">'
                ~ ('group_report.audit_program.action.derive'|trans({}, 'group_report'))
                ~ '</button></form>' %}
            {% set _row = _row|merge([ _form_html ]) %}

            {% set _prog_rows = _prog_rows|merge([_row]) %}
        {% endfor %}
    {% endif %}

    {# Build headers: Program + one per subsidiary + Actions #}
    {% set _headers = [ 'group_report.audit_program.col.program'|trans({}, 'group_report') ] %}
    {% if subsidiaries is defined %}
        {% for sub in subsidiaries %}
            {% set _headers = _headers|merge([ '<code>' ~ sub.code ~ '</code>' ]) %}
        {% endfor %}
    {% endif %}
    {% set _headers = _headers|merge([ 'group_report.audit_program.col.actions'|trans({}, 'group_report') ]) %}

    {# Legend body_html #}
    {% set _legend_html = '<p style="font-size:8pt;color:var(--fg-2);">'
        ~ '<strong>' ~ ('group_report.soa.legend.title'|trans({}, 'group_report')) ~ ':</strong> '
        ~ '✓ ' ~ ('group_report.audit_program.legend.completed'|trans({}, 'group_report'))
        ~ ' · ◐ ' ~ ('group_report.audit_program.legend.in_progress'|trans({}, 'group_report'))
        ~ ' · ◯ ' ~ ('group_report.audit_program.legend.planned'|trans({}, 'group_report'))
        ~ ' · · ' ~ ('group_report.audit_program.legend.missing'|trans({}, 'group_report'))
        ~ '</p>' %}

    {# Stats #}
    {% set _total_programs = programs|default([])|length %}
    {% set _total_subs = subsidiaries|default([])|length %}

    {{ _fa_report_doc.render({
        report: {
            title:        'group_report.audit_program.title'|trans({}, 'group_report'),
            subtitle:     'group_report.audit_program.subtitle'|trans({'%root%': root.name}, 'group_report'),
            kicker:       'group_report.title'|trans({}, 'group_report'),
            status:       'auditor-only',
            audience:     'auditor',
            generated_at: 'now'|date('d.m.Y H:i'),
        },
        brand_name: root.name,
        key_findings: [
            { label: ('group_report.audit_program.col.program'|trans({}, 'group_report')) ~ ': ' ~ _total_programs, tone: 'ok' },
            { label: ('group_report.kpi.col.tenant'|trans({}, 'group_report')) ~ ': ' ~ _total_subs, tone: 'ok' },
        ],
        kpis: [
            { label: 'group_report.audit_program.col.program'|trans({}, 'group_report'), value: _total_programs, tone: 'neutral' },
            { label: 'group_report.kpi.col.tenant'|trans({}, 'group_report'),            value: _total_subs,     tone: 'neutral' },
        ],
        sections: [
            {
                heading: 'group_report.audit_program.title'|trans({}, 'group_report'),
                intro: 'group_report.audit_program.intro'|trans({}, 'group_report'),
                table: _prog_rows|length > 0 ? {
                    headers: _headers,
                    rows:    _prog_rows,
                } : null,
                body_html: _prog_rows|length == 0
                    ? '<p style="color:var(--fg-3);font-style:italic;">' ~ ('group_report.audit_program.empty'|trans({}, 'group_report')) ~ '</p>'
                    : _legend_html,
            },
        ],
        appendix: {
            sources: [
                { label: 'AuditRepository', detail: 'findGroupAuditPrograms() — cross-tenant audit program × subsidiary matrix' },
            ],
            glossary: [
                { term: 'Derive',    definition: 'Propagate parent audit program to subsidiary as a linked audit instance' },
                { term: 'Completed', definition: 'Audit conducted and report finalized' },
                { term: 'Planned',   definition: 'Audit scheduled but not yet started' },
            ],
        },
        distribution: [
            { role: 'Konzern-Auditor', name: 'Group Audit Committee' },
            { role: 'Group-CISO',      name: '—' },
        ],
    }) }}
</div>
{% endblock %}
