{% extends 'base.html.twig' %}

{% block title %}{{ 'group_report.suppliers.title'|trans({}, 'group_report') }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'group_report.title'|trans({}, 'group_report'), path: 'app_group_report_tree' },
            { label: 'group_report.suppliers.title'|trans({}, 'group_report') }
        ]
    } %}

    <div class="mb-4">
        <h1 class="h2 mb-1">
            <i class="bi bi-truck text-primary" aria-hidden="true"></i>
            {{ 'group_report.suppliers.title'|trans({}, 'group_report') }}
        </h1>
        <p class="text-muted mb-0">{{ 'group_report.suppliers.subtitle'|trans({'%root%': root.name}, 'group_report') }}</p>
    </div>

    <div class="alert alert-info d-flex gap-2" role="note">
        <i class="bi bi-info-circle mt-1" aria-hidden="true"></i>
        <div class="small">{{ 'group_report.suppliers.intro'|trans({}, 'group_report')|raw }}</div>
    </div>

    <div class="row row-cols-2 row-cols-md-4 g-2 mb-4">
        <div class="col">
            <div class="card h-100 text-center">
                <div class="card-body py-2">
                    <div class="display-6 fw-bold">{{ totals.unique }}</div>
                    <div class="small text-muted">{{ 'group_report.suppliers.stat.unique'|trans({}, 'group_report') }}</div>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 text-center border-primary">
                <div class="card-body py-2">
                    <div class="display-6 fw-bold text-primary">{{ totals.shared }}</div>
                    <div class="small text-muted">{{ 'group_report.suppliers.stat.shared'|trans({}, 'group_report') }}</div>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 text-center border-success">
                <div class="card-body py-2">
                    <div class="display-6 fw-bold text-success">{{ totals.with_lei }}</div>
                    <div class="small text-muted">{{ 'group_report.suppliers.stat.with_lei'|trans({}, 'group_report') }}</div>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 text-center border-danger">
                <div class="card-body py-2">
                    <div class="display-6 fw-bold text-danger">{{ totals.critical }}</div>
                    <div class="small text-muted">{{ 'group_report.suppliers.stat.critical'|trans({}, 'group_report') }}</div>
                </div>
            </div>
        </div>
    </div>

    {% embed '_components/_card.html.twig' with { class: 'shadow-sm', noPadding: true } %}
        {% block card_body %}
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle" aria-label="{{ 'group_report.suppliers.title'|trans({}, 'group_report') }}">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">{{ 'group_report.suppliers.col.supplier'|trans({}, 'group_report') }}</th>
                            <th scope="col">{{ 'group_report.suppliers.col.identity'|trans({}, 'group_report') }}</th>
                            <th scope="col">{{ 'group_report.suppliers.col.criticality'|trans({}, 'group_report') }}</th>
                            <th scope="col">{{ 'group_report.suppliers.col.used_by'|trans({}, 'group_report') }}</th>
                            <th scope="col">{{ 'group_report.suppliers.col.service'|trans({}, 'group_report') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for group in grouped %}
                            {% set rep = group.representative %}
                            {% set refCount = group.tenant_codes|length %}
                            {% set crit = group.max_criticality %}
                            {% set critBadge = {
                                'critical': 'bg-danger',
                                'high': 'bg-warning-subtle text-warning',
                                'medium': 'bg-info',
                                'low': 'bg-secondary'
                            }[crit]|default('bg-body-secondary text-body border') %}
                            <tr>
                                <td>
                                    <strong>{{ rep.name }}</strong>
                                    {% if rep.contactPerson %}
                                        <div class="small text-muted">{{ rep.contactPerson }}</div>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if group.has_lei %}
                                        <code class="small">{{ rep.leiCode }}</code>
                                        <span class="badge bg-success ms-1">LEI</span>
                                    {% else %}
                                        <span class="badge bg-body-secondary text-body border" title="{{ 'group_report.suppliers.no_lei_help'|trans({}, 'group_report') }}">
                                            {{ 'group_report.suppliers.matched_by_name'|trans({}, 'group_report') }}
                                        </span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if crit %}
                                        <span class="badge {{ critBadge }}">{{ crit }}</span>
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if refCount >= 2 %}
                                        <span class="badge bg-primary me-1">{{ refCount }}×</span>
                                    {% endif %}
                                    {% for code in group.tenant_codes %}
                                        <code class="badge bg-body-secondary text-body border me-1">{{ code }}</code>
                                    {% endfor %}
                                </td>
                                <td class="small text-muted">{{ rep.serviceProvided|default('—')|u.truncate(80, '…') }}</td>
                            </tr>
                        {% else %}
                            <tr><td colspan="5" class="text-center text-muted py-3">{{ 'group_report.suppliers.none'|trans({}, 'group_report') }}</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
