{# ─────────────────────────────────────────────────────────────────────────
   Group Suppliers Report — fa-report-doc 5-slot macro (web variant)
   Audience: auditor (Group-CISO / Konzern-Auditor)
   Status:   final
   ─────────────────────────────────────────────────────────────────────── #}
{% extends 'base.html.twig' %}

{% block title %}{{ 'group_report.suppliers.title'|trans({}, 'group_report') }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'group_report.title'|trans({}, 'group_report'), path: 'app_group_report_tree' },
            { label: 'group_report.suppliers.title'|trans({}, 'group_report') }
        ]
    } %}

    {% import '_components/_fa_report_doc.html.twig' as _fa_report_doc %}

    {# Build grouped supplier table rows #}
    {% set _sup_rows = [] %}
    {% for group in grouped %}
        {% set rep = group.representative %}
        {% set refCount = group.tenant_codes|length %}
        {% set crit = group.max_criticality %}
        {% set _cchip = crit == 'critical' ? 'confidential' : (crit == 'high' ? 'draft' : (crit == 'medium' ? 'auditor-only' : 'final')) %}

        {# Supplier / identity cell #}
        {% set _id_cell = group.has_lei
            ? '<code>' ~ rep.leiCode ~ '</code> <span class="report-doc__chip report-doc__chip--status-final" style="font-size:.7em;">LEI</span>'
            : '<span style="color:var(--fg-3);font-size:.75em;" title="' ~ ('group_report.suppliers.no_lei_help'|trans({}, 'group_report')) ~ '">' ~ ('group_report.suppliers.matched_by_name'|trans({}, 'group_report')) ~ '</span>' %}

        {# Used-by tenants cell #}
        {% set _tenants_cell = '' %}
        {% if refCount >= 2 %}
            {% set _tenants_cell = '<span class="report-doc__chip report-doc__chip--status-auditor-only" style="font-size:.7em;">' ~ refCount ~ '×</span> ' %}
        {% endif %}
        {% for code in group.tenant_codes %}
            {% set _tenants_cell = _tenants_cell ~ '<code style="font-size:.75em;">' ~ code ~ '</code> ' %}
        {% endfor %}

        {% set _sup_rows = _sup_rows|merge([[
            '<strong>' ~ rep.name ~ '</strong>' ~ (rep.contactPerson ? '<br><span style="font-size:.75em;color:var(--fg-3);">' ~ rep.contactPerson ~ '</span>' : ''),
            _id_cell,
            crit ? '<span class="report-doc__chip report-doc__chip--status-' ~ _cchip ~ '">' ~ crit ~ '</span>' : '<span style="color:var(--fg-3);">—</span>',
            _tenants_cell,
            rep.serviceProvided ? (rep.serviceProvided|length > 80 ? rep.serviceProvided|slice(0, 80) ~ '…' : rep.serviceProvided) : '—',
        ]]) %}
    {% endfor %}

    {{ _fa_report_doc.render({
        report: {
            title:        'group_report.suppliers.title'|trans({}, 'group_report'),
            subtitle:     'group_report.suppliers.subtitle'|trans({'%root%': root.name}, 'group_report'),
            kicker:       'group_report.title'|trans({}, 'group_report'),
            status:       'final',
            audience:     'auditor',
            generated_at: 'now'|date('d.m.Y H:i'),
        },
        brand_name: root.name,
        key_findings: [
            { label: ('group_report.suppliers.stat.unique'|trans({}, 'group_report')) ~ ': ' ~ totals.unique,    tone: 'ok' },
            { label: ('group_report.suppliers.stat.shared'|trans({}, 'group_report')) ~ ': ' ~ totals.shared,    tone: totals.shared > 0 ? 'warn' : 'ok' },
            { label: ('group_report.suppliers.stat.critical'|trans({}, 'group_report')) ~ ': ' ~ totals.critical, tone: totals.critical > 0 ? 'danger' : 'ok' },
        ],
        kpis: [
            { label: 'group_report.suppliers.stat.unique'|trans({}, 'group_report'),    value: totals.unique,    tone: 'neutral' },
            { label: 'group_report.suppliers.stat.shared'|trans({}, 'group_report'),    value: totals.shared,    tone: totals.shared > 0 ? 'warning' : 'success' },
            { label: 'group_report.suppliers.stat.with_lei'|trans({}, 'group_report'),  value: totals.with_lei,  tone: 'success' },
            { label: 'group_report.suppliers.stat.critical'|trans({}, 'group_report'),  value: totals.critical,  tone: totals.critical > 0 ? 'danger' : 'success' },
        ],
        sections: [
            {
                heading: 'group_report.suppliers.title'|trans({}, 'group_report'),
                intro: 'group_report.suppliers.intro'|trans({}, 'group_report'),
                table: _sup_rows|length > 0 ? {
                    headers: [
                        'group_report.suppliers.col.supplier'|trans({}, 'group_report'),
                        'group_report.suppliers.col.identity'|trans({}, 'group_report'),
                        'group_report.suppliers.col.criticality'|trans({}, 'group_report'),
                        'group_report.suppliers.col.used_by'|trans({}, 'group_report'),
                        'group_report.suppliers.col.service'|trans({}, 'group_report'),
                    ],
                    rows: _sup_rows,
                } : null,
                body_html: _sup_rows|length == 0
                    ? '<p style="color:var(--fg-3);font-style:italic;">' ~ ('group_report.suppliers.none'|trans({}, 'group_report')) ~ '</p>'
                    : null,
            },
        ],
        appendix: {
            sources: [
                { label: 'SupplierRepository', detail: 'findGroupSuppliers() — cross-tenant supplier grouping by LEI / name match' },
            ],
            glossary: [
                { term: 'LEI',    definition: 'Legal Entity Identifier — ISO 17442, 20-char alphanumeric global company ID' },
                { term: 'Shared', definition: 'Supplier referenced by ≥2 tenants within the group' },
            ],
        },
        distribution: [
            { role: 'Group-CISO',      name: '—' },
            { role: 'Konzern-Auditor', name: 'Group Audit Committee' },
        ],
    }) }}
</div>
{% endblock %}
