{# ─────────────────────────────────────────────────────────────────────────
   Group Risks Report — fa-report-doc 5-slot macro (web variant)
   Audience: auditor (Group Audit Committee / Group-CISO)
   Status:   final
   ─────────────────────────────────────────────────────────────────────── #}
{% extends 'base.html.twig' %}

{% block title %}{{ 'group_report.risks.title'|trans({}, 'group_report') }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'group_report.title'|trans({}, 'group_report'), path: 'app_group_report_tree' },
            { label: 'group_report.risks.title'|trans({}, 'group_report') }
        ]
    } %}

    {% import '_components/_fa_report_doc.html.twig' as _fa_report_doc %}

    {# Build top-10 risks table rows #}
    {% set _top_rows = [] %}
    {% for risk in top_risks %}
        {% set _inherent = risk.inherentRiskLevel %}
        {% set _residual = risk.residualRiskLevel %}
        {% set _ibadge = _inherent >= 15 ? 'confidential' : (_inherent >= 8 ? 'draft' : 'final') %}
        {% set _rbadge = _residual >= 15 ? 'confidential' : (_residual >= 8 ? 'draft' : 'final') %}
        {% set _top_rows = _top_rows|merge([[
            loop.index,
            '<strong>' ~ risk.title ~ '</strong>' ~ (risk.category ? '<br><code style="font-size:.75em;color:var(--fg-3);">' ~ risk.category ~ '</code>' : ''),
            '<code style="font-size:.75em;">' ~ risk.tenant.code ~ '</code>',
            '<span class="report-doc__chip report-doc__chip--status-' ~ _ibadge ~ '">' ~ _inherent ~ '</span>',
            _residual > 0 ? '<span class="report-doc__chip report-doc__chip--status-' ~ _rbadge ~ '">' ~ _residual ~ '</span>' : '<span style="color:var(--fg-3);">—</span>',
        ]]) %}
    {% endfor %}

    {# Build distribution-by-tenant rows #}
    {% set _dist_rows = [] %}
    {% for tenant in tenants %}
        {% set _dist_rows = _dist_rows|merge([[
            '<strong>' ~ tenant.name ~ '</strong> <code style="font-size:.75em;color:var(--fg-3);">' ~ tenant.code ~ '</code>',
            risks_by_tenant[tenant.code]|default(0),
        ]]) %}
    {% endfor %}

    {{ _fa_report_doc.render({
        report: {
            title:        'group_report.risks.title'|trans({}, 'group_report'),
            subtitle:     'group_report.risks.subtitle'|trans({'%root%': root.name, '%count%': total_risks}, 'group_report'),
            kicker:       'group_report.title'|trans({}, 'group_report'),
            status:       'final',
            audience:     'auditor',
            generated_at: 'now'|date('d.m.Y H:i'),
        },
        brand_name: root.name,
        key_findings: [
            { label: ('group_report.risks.total'|trans({}, 'group_report')) ~ ': ' ~ total_risks, tone: total_risks > 0 ? 'warn' : 'ok' },
            { label: 'Top-10 ' ~ ('group_report.risks.col.inherent'|trans({}, 'group_report')) ~ ' listed', tone: 'ok' },
        ],
        kpis: [
            { label: 'group_report.risks.total'|trans({}, 'group_report'), value: total_risks, tone: total_risks > 0 ? 'warning' : 'success' },
            { label: 'group_report.kpi.col.tenant'|trans({}, 'group_report'), value: tenants|length, tone: 'neutral' },
        ],
        sections: [
            {
                heading: 'group_report.risks.top10'|trans({}, 'group_report'),
                table: _top_rows|length > 0 ? {
                    headers: [
                        '#',
                        'group_report.risks.col.title'|trans({}, 'group_report'),
                        'group_report.risks.col.tenant'|trans({}, 'group_report'),
                        'group_report.risks.col.inherent'|trans({}, 'group_report'),
                        'group_report.risks.col.residual'|trans({}, 'group_report'),
                    ],
                    rows: _top_rows,
                } : null,
                intro: _top_rows|length == 0 ? ('group_report.risks.none'|trans({}, 'group_report')) : null,
            },
            {
                heading: 'group_report.risks.distribution'|trans({}, 'group_report'),
                table: {
                    headers: [
                        'group_report.risks.col.tenant'|trans({}, 'group_report'),
                        'group_report.risks.col.count'|trans({}, 'group_report'),
                    ],
                    rows: _dist_rows,
                },
            },
        ],
        appendix: {
            sources: [
                { label: 'RiskRepository', detail: 'findGroupTopRisks() — cross-tenant top-10 by inherent score' },
            ],
            glossary: [
                { term: 'Inherent', definition: 'Risk score before controls are applied (L × I)' },
                { term: 'Residual', definition: 'Risk score after controls are applied' },
            ],
        },
        distribution: [
            { role: 'Konzern-Auditor', name: 'Group Audit Committee' },
            { role: 'Group-CISO',      name: '—' },
        ],
    }) }}
</div>
{% endblock %}
