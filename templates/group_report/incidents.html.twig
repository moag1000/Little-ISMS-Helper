{# ─────────────────────────────────────────────────────────────────────────
   Group Incidents Report — fa-report-doc 5-slot macro (web variant)
   Audience: auditor (Group Audit Committee)
   Status:   auditor-only
   ─────────────────────────────────────────────────────────────────────── #}
{% extends 'base.html.twig' %}

{% block title %}{{ 'group_report.incidents.title'|trans({}, 'group_report') }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'group_report.title'|trans({}, 'group_report'), path: 'app_group_report_tree' },
            { label: 'group_report.incidents.title'|trans({}, 'group_report') }
        ]
    } %}

    {% import '_components/_fa_report_doc.html.twig' as _fa_report_doc %}

    {# Build incident table rows #}
    {% set _inc_rows = [] %}
    {% for incident in incidents %}
        {% set _sev = incident.severity ? incident.severity.value : '' %}
        {% set _sbadge = _sev == 'critical' ? 'confidential' : (_sev == 'high' ? 'draft' : (_sev == 'medium' ? 'auditor-only' : 'final')) %}
        {% set _inc_rows = _inc_rows|merge([[
            incident.detectedAt|date('Y-m-d H:i'),
            '<code style="font-size:.7em;">' ~ incident.incidentNumber ~ '</code> <strong>' ~ incident.title ~ '</strong>' ~ (incident.category ? '<br><span style="font-size:.75em;color:var(--fg-3);">' ~ incident.category ~ '</span>' : ''),
            '<code style="font-size:.75em;">' ~ incident.tenant.code ~ '</code>',
            '<span class="report-doc__chip report-doc__chip--status-' ~ _sbadge ~ '">' ~ _sev ~ '</span>',
            '<code style="font-size:.75em;">' ~ (incident.status ? incident.status.value : '') ~ '</code>',
        ]]) %}
    {% endfor %}

    {{ _fa_report_doc.render({
        report: {
            title:        'group_report.incidents.title'|trans({}, 'group_report'),
            subtitle:     'group_report.incidents.subtitle'|trans({'%root%': root.name}, 'group_report'),
            kicker:       'group_report.title'|trans({}, 'group_report'),
            status:       'auditor-only',
            audience:     'auditor',
            generated_at: 'now'|date('d.m.Y H:i'),
        },
        brand_name: root.name,
        key_findings: [
            { label: ('group_report.incidents.stat.total'|trans({}, 'group_report')) ~ ': ' ~ total_visible, tone: total_visible > 0 ? 'warn' : 'ok' },
            { label: ('group_report.incidents.severity.critical'|trans({}, 'group_report')) ~ ': ' ~ severity_buckets.critical,
              tone: severity_buckets.critical > 0 ? 'danger' : 'ok' },
            { label: ('group_report.incidents.severity.high'|trans({}, 'group_report')) ~ ': ' ~ severity_buckets.high,
              tone: severity_buckets.high > 0 ? 'warn' : 'ok' },
        ],
        kpis: [
            { label: 'group_report.incidents.stat.total'|trans({}, 'group_report'),         value: total_visible,            tone: 'neutral' },
            { label: 'group_report.incidents.severity.critical'|trans({}, 'group_report'),  value: severity_buckets.critical, tone: severity_buckets.critical > 0 ? 'danger' : 'success' },
            { label: 'group_report.incidents.severity.high'|trans({}, 'group_report'),      value: severity_buckets.high,    tone: severity_buckets.high > 0 ? 'warning' : 'success' },
            { label: 'group_report.incidents.severity.medium'|trans({}, 'group_report'),    value: severity_buckets.medium,  tone: 'neutral' },
        ],
        sections: [
            {
                heading: 'group_report.incidents.title'|trans({}, 'group_report'),
                intro: 'group_report.incidents.intro'|trans({}, 'group_report'),
                table: _inc_rows|length > 0 ? {
                    headers: [
                        'group_report.incidents.col.detected_at'|trans({}, 'group_report'),
                        'group_report.incidents.col.incident'|trans({}, 'group_report'),
                        'group_report.incidents.col.tenant'|trans({}, 'group_report'),
                        'group_report.incidents.col.severity'|trans({}, 'group_report'),
                        'group_report.incidents.col.status'|trans({}, 'group_report'),
                    ],
                    rows: _inc_rows,
                } : null,
                body_html: _inc_rows|length == 0 ? '<p style="color:var(--fg-3);font-style:italic;">' ~ ('group_report.incidents.none'|trans({}, 'group_report')) ~ '</p>' : null,
            },
        ],
        appendix: {
            sources: [
                { label: 'IncidentRepository', detail: 'findGroupVisibleIncidents() — cross-tenant, current user access' },
            ],
        },
        distribution: [
            { role: 'Konzern-Auditor', name: 'Group Audit Committee' },
            { role: 'Group-CISO',      name: '—' },
        ],
    }) }}
</div>
{% endblock %}
