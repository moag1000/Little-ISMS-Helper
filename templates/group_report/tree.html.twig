{# ─────────────────────────────────────────────────────────────────────────
   Group Corporate Tree — fa-report-doc 5-slot macro (web variant)
   Audience: auditor (Group-CISO / Konzern-Auditor)
   Status:   final
   Note: renderNode macro retained for recursive tree rendering;
         tree HTML is passed via body_html slot.
   ─────────────────────────────────────────────────────────────────────── #}
{% extends 'base.html.twig' %}
{% import _self as macros %}

{% block title %}{{ 'group_report.tree.title'|trans({}, 'group_report') }}{% endblock %}

{% macro renderNode(tenant, current, depth) %}
    {% set isCurrent = tenant is same as(current) %}
    {% set class = tenant.nis2Classification|default('unknown') %}
    {% set classBadge = {
        'essential': 'bg-danger',
        'important': 'bg-warning-subtle text-warning',
        'not_regulated': 'bg-secondary',
        'unknown': 'bg-body-secondary border'
    }[class]|default('bg-body-secondary border') %}
    <li class="list-group-item {% if isCurrent %}list-group-item-primary{% endif %}">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                {% if tenant.isCorporateParent %}
                    <i class="fa-icon fa-icon--nav-building text-primary" aria-hidden="true" title="{{ 'group_report.tree.holding_marker'|trans({}, 'group_report') }}"></i>
                {% else %}
                    <i class="fa-icon fa-icon--nav-workflow text-muted" aria-hidden="true"></i>
                {% endif %}
                <strong>{{ tenant.name }}</strong>
                <code class="small text-muted ms-1">{{ tenant.code }}</code>
                {% if isCurrent %}
                    <span class="fa-status-pill fa-status-pill--primary ms-1">{{ 'group_report.tree.you_are_here'|trans({}, 'group_report') }}</span>
                {% endif %}
            </div>
            <div>
                <span class="badge {{ classBadge }}">
                    {{ ('group_report.nis2.class.' ~ class)|trans({}, 'group_report') }}
                </span>
                {% if tenant.naceCode %}
                    <code class="small">{{ tenant.naceCode }}</code>
                {% endif %}
            </div>
        </div>
        {% if tenant.subsidiaries|length > 0 %}
            <ul class="list-group list-group-flush mt-2 ms-3">
                {% for child in tenant.subsidiaries %}
                    {{ macros.renderNode(child, current, depth + 1) }}
                {% endfor %}
            </ul>
        {% endif %}
    </li>
{% endmacro %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'group_report.title'|trans({}, 'group_report'), path: 'app_group_report_tree' },
            { label: 'group_report.tree.title'|trans({}, 'group_report') }
        ]
    } %}

    {% import '_components/_fa_report_doc.html.twig' as _fa_report_doc %}

    {# Navigation shortcuts — rendered as body_html in the nav section #}
    {% set _nav_html = '<div class="d-flex flex-wrap gap-2" style="margin-bottom:1rem;">'
        ~ '<a href="' ~ path('app_group_report_nis2_registration') ~ '" class="fa-cyber-btn fa-cyber-btn--ghost">' ~ ('group_report.nis2.title'|trans({}, 'group_report')) ~ '</a>'
        ~ '<a href="' ~ path('app_group_report_risks') ~ '" class="fa-cyber-btn fa-cyber-btn--ghost">' ~ ('group_report.risks.title'|trans({}, 'group_report')) ~ '</a>'
        ~ '<a href="' ~ path('app_group_report_kpi_matrix') ~ '" class="fa-cyber-btn fa-cyber-btn--ghost">' ~ ('group_report.kpi.title'|trans({}, 'group_report')) ~ '</a>'
        ~ '<a href="' ~ path('app_group_report_soa_matrix') ~ '" class="fa-cyber-btn fa-cyber-btn--ghost">' ~ ('group_report.soa.title'|trans({}, 'group_report')) ~ '</a>'
        ~ '<a href="' ~ path('app_group_report_suppliers') ~ '" class="fa-cyber-btn fa-cyber-btn--ghost">' ~ ('group_report.suppliers.title'|trans({}, 'group_report')) ~ '</a>'
        ~ '<a href="' ~ path('app_group_report_incidents') ~ '" class="fa-cyber-btn fa-cyber-btn--ghost">' ~ ('group_report.incidents.title'|trans({}, 'group_report')) ~ '</a>'
        ~ '<a href="' ~ path('app_group_report_audit_program') ~ '" class="fa-cyber-btn fa-cyber-btn--ghost">' ~ ('group_report.audit_program.title'|trans({}, 'group_report')) ~ '</a>'
        ~ '</div>' %}

    {# Tree rendered via recursive macro — output captured into body_html slot #}
    {% set _tree_html %}
        <ul class="list-group list-group-flush">
            {{ macros.renderNode(root, current, 0) }}
        </ul>
    {% endset %}

    {{ _fa_report_doc.render({
        report: {
            title:        'group_report.tree.title'|trans({}, 'group_report'),
            subtitle:     'group_report.tree.subtitle'|trans({}, 'group_report'),
            kicker:       'group_report.title'|trans({}, 'group_report'),
            status:       'final',
            audience:     'auditor',
            generated_at: 'now'|date('d.m.Y H:i'),
        },
        brand_name: root.name,
        key_findings: [
            { label: ('group_report.kpi.col.tenant'|trans({}, 'group_report')) ~ ': ' ~ all_tenants|default([])|length, tone: 'ok' },
        ],
        kpis: [
            { label: 'group_report.kpi.col.tenant'|trans({}, 'group_report'), value: all_tenants|default([])|length, tone: 'neutral' },
        ],
        sections: [
            {
                heading: 'group_report.title'|trans({}, 'group_report'),
                body_html: _nav_html ~ _tree_html,
            },
        ],
        appendix: {
            sources: [
                { label: 'TenantRepository', detail: 'findGroupTree() — full corporate hierarchy rooted at current tenant' },
            ],
            glossary: [
                { term: 'Essential',     definition: 'NIS2 Art. 3 — Large entity in critical sectors' },
                { term: 'Important',     definition: 'NIS2 Art. 3 — Medium entity or specific sectors' },
                { term: 'Not regulated', definition: 'Entity not in scope of NIS2 Directive' },
            ],
        },
        distribution: [
            { role: 'Group-CISO',      name: '—' },
            { role: 'Konzern-Auditor', name: 'Group Audit Committee' },
        ],
    }) }}
</div>
{% endblock %}
