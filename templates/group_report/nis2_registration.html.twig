{# ─────────────────────────────────────────────────────────────────────────
   Group NIS2 Registration Report — fa-report-doc 5-slot macro (web variant)
   Audience: aufsicht (BSI / EU-NIS2 Supervisory Authority)
   Status:   final
   ─────────────────────────────────────────────────────────────────────── #}
{% extends 'base.html.twig' %}

{% block title %}{{ 'group_report.nis2.title'|trans({}, 'group_report') }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'group_report.title'|trans({}, 'group_report'), path: 'app_group_report_tree' },
            { label: 'group_report.nis2.title'|trans({}, 'group_report') }
        ]
    } %}

    {% import '_components/_fa_report_doc.html.twig' as _fa_report_doc %}

    {# Build NIS2 matrix table #}
    {% set _nis2_rows = [] %}
    {% for tenant in tenants %}
        {% set _class = tenant.nis2Classification|default('unknown') %}
        {% set _cbadge = _class == 'essential' ? 'confidential' : (_class == 'important' ? 'draft' : 'final') %}
        {% set _reg_cell = tenant.nis2RegisteredAt
            ? '<span style="color:var(--success);font-weight:700;">' ~ tenant.nis2RegisteredAt|date('Y-m-d') ~ '</span>'
            : (tenant.isNis2Regulated
                ? '<span style="color:var(--danger);font-weight:700;">' ~ ('group_report.nis2.registration.missing'|trans({}, 'group_report')) ~ '</span>'
                : '<span style="color:var(--fg-3);">—</span>') %}
        {% set _nis2_rows = _nis2_rows|merge([[
            '<strong>' ~ tenant.name ~ '</strong><br><code style="font-size:.75em;color:var(--fg-3);">' ~ tenant.code ~ '</code>',
            tenant.legalName ? (tenant.legalName ~ (tenant.legalForm ? ' (' ~ tenant.legalForm ~ ')' : '')) : '<span style="color:var(--fg-3);">—</span>',
            '<span class="report-doc__chip report-doc__chip--status-' ~ _cbadge ~ '">' ~ ('group_report.nis2.class.' ~ _class)|trans({}, 'group_report') ~ '</span>',
            tenant.nis2Sector|default('—'),
            tenant.naceCode ? '<code>' ~ tenant.naceCode ~ '</code>' : '—',
            tenant.nis2ContactPoint|default('—'),
            _reg_cell,
        ]]) %}
    {% endfor %}

    {{ _fa_report_doc.render({
        report: {
            title:        'group_report.nis2.title'|trans({}, 'group_report'),
            subtitle:     'group_report.nis2.subtitle'|trans({'%root%': root.name}, 'group_report'),
            kicker:       'NIS2 Directive · Art. 3 Registration',
            status:       'final',
            audience:     'aufsicht',
            generated_at: 'now'|date('d.m.Y H:i'),
        },
        brand_name: root.name,
        key_findings: [
            { label: ('group_report.nis2.stat.total'|trans({}, 'group_report')) ~ ': ' ~ stats.total, tone: 'ok' },
            { label: ('group_report.nis2.class.essential'|trans({}, 'group_report')) ~ ': ' ~ stats.essential,
              tone: stats.essential > 0 ? 'warn' : 'ok' },
            { label: ('group_report.nis2.stat.registered'|trans({}, 'group_report')) ~ ': ' ~ stats.registered,
              tone: stats.registered >= stats.essential ? 'ok' : 'danger' },
        ],
        kpis: [
            { label: 'group_report.nis2.stat.total'|trans({}, 'group_report'),        value: stats.total,        tone: 'neutral' },
            { label: 'group_report.nis2.class.essential'|trans({}, 'group_report'),   value: stats.essential,    tone: stats.essential > 0 ? 'danger' : 'success' },
            { label: 'group_report.nis2.class.important'|trans({}, 'group_report'),   value: stats.important,    tone: stats.important > 0 ? 'warning' : 'success' },
            { label: 'group_report.nis2.stat.registered'|trans({}, 'group_report'),   value: stats.registered,   tone: stats.registered >= stats.essential ? 'success' : 'danger' },
        ],
        sections: [
            {
                heading: 'group_report.nis2.matrix.title'|trans({}, 'group_report'),
                intro: 'group_report.nis2.intro'|trans({}, 'group_report'),
                table: {
                    headers: [
                        'group_report.nis2.col.tenant'|trans({}, 'group_report'),
                        'group_report.nis2.col.legal'|trans({}, 'group_report'),
                        'group_report.nis2.col.classification'|trans({}, 'group_report'),
                        'group_report.nis2.col.sector'|trans({}, 'group_report'),
                        'group_report.nis2.col.nace'|trans({}, 'group_report'),
                        'group_report.nis2.col.contact'|trans({}, 'group_report'),
                        'group_report.nis2.col.registered'|trans({}, 'group_report'),
                    ],
                    rows: _nis2_rows,
                },
            },
        ],
        appendix: {
            methodology: 'group_report.nis2.methodology'|trans({}, 'group_report'),
            sources: [
                { label: 'TenantRepository', detail: 'findGroupTenants() — NIS2 classification + registration fields' },
            ],
            glossary: [
                { term: 'Essential', definition: 'NIS2 Art. 3 — Large entity in critical sectors (energy, transport, banking, etc.)' },
                { term: 'Important', definition: 'NIS2 Art. 3 — Medium entity or specific sector classifications' },
                { term: 'NACE',      definition: 'EU economic activity classification code' },
            ],
        },
        distribution: [
            { role: 'Group-CISO',  name: '—' },
            { role: 'BSI/BNetzA',  name: '—' },
        ],
    }) }}
</div>
{% endblock %}
