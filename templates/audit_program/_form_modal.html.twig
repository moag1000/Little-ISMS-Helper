{# AuditProgram create/edit rendered inside the fa-form-modal Turbo Frame.
   Explicit form action (document URL stays on the list). On valid submit the
   controller returns a Turbo Stream (card replace/append). #}
{% trans_default_domain 'audit_program' %}
{% set is_edit = program is defined and program and program.id is not null %}
{% set form_action = is_edit
    ? path('app_audit_program_edit', { _locale: app.request.locale, id: program.id })
    : path('app_audit_program_new', { _locale: app.request.locale }) %}
<turbo-frame id="fa-form-modal">
    {{ form_start(form, { action: form_action, method: 'POST', attr: {
        id: 'audit-program-modal-form',
        'data-turbo-frame': 'fa-form-modal'
    } }) }}
    {% include 'audit_program/_form_body.html.twig' with {
        form: form,
        modal: true,
        title: is_edit ? program.name : 'audit_program.action.new'|trans({}, 'audit_program'),
        actions: {
            close: { label: 'common.cancel'|trans({}, 'messages'), variant: 'ghost', action: 'fa-form-modal#close' },
            submit: { label: 'common.save'|trans({}, 'messages'), variant: 'primary' }
        }
    } %}
    {{ form_end(form) }}
</turbo-frame>
