{% extends 'base.html.twig' %}
{% trans_default_domain 'audit_program' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'audit_program.action.edit'|trans({}, 'audit_program') }}: {{ program.name }} — {{ parent() }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="row">
        <div class="col-lg-10 col-xl-8 mx-auto">

            {% include '_components/_breadcrumb.html.twig' with {
                breadcrumbs: [
                    { label: 'nav.dashboard'|trans({}, 'nav'), url: path('app_dashboard') },
                    { label: 'audit_program.page.index.title'|trans({}, 'audit_program'), url: path('app_audit_program_index', {_locale: app.request.locale}) },
                    { label: program.name, url: path('app_audit_program_show', {_locale: app.request.locale, id: program.id}) },
                    { label: 'audit_program.action.edit'|trans({}, 'audit_program') }
                ]
            } %}

            {{ _fa_page_header.render({
                badge: { icon: 'ui-edit', label: '' },
                title: 'audit_program.action.edit'|trans({}, 'audit_program'),
                subtitle: program.name,
                actions: [
                    {
                        label: 'common.back'|trans({}, 'messages'),
                        href: path('app_audit_program_show', {_locale: app.request.locale, id: program.id}),
                        variant: 'ghost',
                        icon: 'util-arrow-left'
                    }
                ]
            }) }}

            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header">
                        <h2 class="mb-0">
                            <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                            {{ 'audit_program.action.edit'|trans({}, 'audit_program') }}
                        </h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                    {% include '_components/_auto_form.html.twig' with {
                        form: form,
                        sections: {
                            'basic_info': {
                                label: 'audit_program.section.basic_info'|trans({}, 'audit_program'),
                                fields: ['name', 'year', 'scope', 'objectives', 'frameworks']
                            },
                            'responsibility': {
                                label: 'audit_program.section.responsibility'|trans({}, 'audit_program'),
                                fields: ['responsiblePerson', 'responsiblePersonRef']
                            },
                            'ressourcen': {
                                label: 'audit_program.section.ressourcen'|trans({}, 'audit_program'),
                                fields: ['budget', 'notes']
                            },
                            'status': {
                                label: 'audit_program.section.status'|trans({}, 'audit_program'),
                                fields: ['status']
                            }
                        },
                        col_widths: {
                            name: 12,
                            year: 4,
                            budget: 6
                        }
                    } %}

                    <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                        <a href="{{ path('app_audit_program_show', {_locale: app.request.locale, id: program.id}) }}"
                           class="fa-cyber-btn fa-cyber-btn--ghost">
                            <i class="fa-icon fa-icon--util-arrow-left" aria-hidden="true"></i>
                            {{ 'common.back'|trans({}, 'messages') }}
                        </a>
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--lg">
                            <i class="fa-icon fa-icon--ui-save" aria-hidden="true"></i>
                            {{ 'audit_program.action.save'|trans({}, 'audit_program') }}
                        </button>
                    </div>

                    {{ form_end(form) }}
                {% endblock %}
            {% endembed %}

        </div>
    </div>
</div>
{% endblock %}
