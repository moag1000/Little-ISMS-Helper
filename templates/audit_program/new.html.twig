{% extends 'base.html.twig' %}
{% trans_default_domain 'audit_program' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'audit_program.action.new'|trans }}{% endblock %}

{% block body %}
{% include '_components/_breadcrumb.html.twig' with {
    breadcrumbs: [
        { label: 'nav.audit_programs'|trans({}, 'nav'), url: path('app_audit_program_index', {_locale: app.request.locale}) },
        { label: 'audit_program.action.new'|trans }
    ]
} %}

{{ _fa_page_header.render({
    badge: { icon: 'nav-plus-circle', label: 'audit_program.action.new'|trans },
    title: 'audit_program.action.new'|trans,
    subtitle: 'audit_program.page.subtitle'|trans
}) }}

<main class="fa-aurora-surface">
<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-xl-10">
            {{ form_start(form) }}
            {% include '_components/_auto_form.html.twig' with {
                form: form,
                exclude_fields: ['status', 'riskCategories'],
                sections: {
                    'basic_info': {
                        label: 'audit_program.section.basic_info'|trans({}, 'audit_program'),
                        fields: ['name', 'description', 'objectives', 'scope', 'frequency']
                    },
                    'dates': {
                        label: 'audit_program.section.dates'|trans({}, 'audit_program'),
                        fields: ['startDate', 'endDate']
                    },
                    'responsibility': {
                        label: 'audit_program.section.responsibility'|trans({}, 'audit_program'),
                        fields: ['programmeOwner']
                    }
                }
            } %}
            <div class="d-flex gap-2 justify-content-end mt-3">
                <a href="{{ path('app_audit_program_index', {_locale: app.request.locale}) }}" class="btn btn-outline-secondary">{{ 'common.cancel'|trans({}, 'messages') }}</a>
                <button type="submit" class="btn btn-primary">{{ 'common.save'|trans({}, 'messages') }}</button>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
</main>
{% endblock %}
