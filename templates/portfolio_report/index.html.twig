{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% trans_default_domain 'portfolio_report' %}

{% block title %}{{ 'portfolio_report.title'|trans({}, 'portfolio_report') }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.reports'|trans({}, 'nav'), path: 'app_reports_index' },
            { label: 'management_reports.title'|trans({}, 'management_reports'), path: 'app_management_reports' },
            { label: 'portfolio_report.title'|trans({}, 'portfolio_report') }
        ]
    } %}

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h1 class="h2 mb-1">
                <i class="fa-icon fa-icon--nav-grid-fill text-primary" aria-hidden="true"></i>
                {{ 'portfolio_report.title'|trans({}, 'portfolio_report') }}
            </h1>
            <p class="text-muted mb-0">
                <i class="fa-icon fa-icon--nav-building" aria-hidden="true"></i>
                <strong>{{ tenant.name }}</strong>
                <span class="mx-2">&middot;</span>
                <i class="fa-icon fa-icon--ui-calendar-event" aria-hidden="true"></i>
                {{ 'portfolio_report.header.stichtag'|trans({}, 'portfolio_report') }}:
                <strong>{{ stichtag|date('Y-m-d') }}</strong>
                {% if vorperiode %}
                    <span class="mx-2">&middot;</span>
                    <i class="fa-icon fa-icon--util-arrow-left-circle" aria-hidden="true"></i>
                    {{ 'portfolio_report.header.vorperiode'|trans({}, 'portfolio_report') }}:
                    <strong>{{ vorperiode|date('Y-m-d') }}</strong>
                {% endif %}
            </p>
        </div>
        <div class="btn-group">
            <a href="{{ path('app_management_reports_portfolio_pdf', {
                _locale: app.request.locale,
                stichtag: stichtag|date('Y-m-d'),
                vorperiode: vorperiode ? vorperiode|date('Y-m-d') : null
            }) }}" class="fa-cyber-btn fa-cyber-btn--danger">
                <i class="fa-icon fa-icon--nav-file-pdf" aria-hidden="true"></i>
                {{ 'portfolio_report.action.download_pdf'|trans({}, 'portfolio_report') }}
            </a>
            <a href="{{ path('app_management_reports_portfolio_excel', {
                _locale: app.request.locale,
                stichtag: stichtag|date('Y-m-d'),
                vorperiode: vorperiode ? vorperiode|date('Y-m-d') : null
            }) }}" class="fa-cyber-btn fa-cyber-btn--success">
                <i class="bi bi-file-earmark-excel" aria-hidden="true"></i>
                {{ 'portfolio_report.action.download_excel'|trans({}, 'portfolio_report') }}
            </a>
        </div>
    </div>

    {# FTE Executive KPI (CM-5) — 8H.4 migrated #}
    {% if fte_saved is defined %}
        {% embed '_components/_card.html.twig' with { class: 'shadow-sm mb-4 border-success' } %}
            {% block card_body %}
                <div class="text-center">
                    <div class="small text-uppercase text-muted mb-1">
                        <i class="fa-icon fa-icon--threat text-success" aria-hidden="true"></i>
                        {{ 'portfolio_report.fte_saved.title'|trans({}, 'portfolio_report') }}
                    </div>
                    <div class="display-4 fw-bold text-success mb-1">
                        {{ fte_saved|number_format(1, '.', ',') }}
                        <small class="fs-5 text-muted">{{ 'portfolio_report.fte_saved.days_suffix'|trans({}, 'portfolio_report') }}</small>
                    </div>
                    <div class="text-muted">
                        {{ 'portfolio_report.fte_saved.subtitle'|trans({}, 'portfolio_report') }}
                    </div>
                </div>
            {% endblock %}
        {% endembed %}
    {% endif %}

    {# R3 Reuse-Trend — 12-Monats-Verlauf aus ReuseTrendSnapshot — 8H.4 migrated #}
    {% if reuse_trend is defined and reuse_trend|length > 0 %}
        {% embed '_components/_card.html.twig' with { class: 'shadow-sm mb-4' } %}
            {% block card_header %}
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h2 class="h6 mb-0">
                        <i class="fa-icon fa-icon--nav-bar-chart" aria-hidden="true"></i>
                        {{ 'portfolio_report.reuse_trend.title'|trans({}, 'portfolio_report') }}
                    </h2>
                    <span class="small text-muted">{{ 'portfolio_report.reuse_trend.hint'|trans({'%count%': reuse_trend|length}, 'portfolio_report') }}</span>
                </div>
            {% endblock %}
            {% block card_body %}
                <canvas id="reuseTrendChart" height="90"
                        data-labels="{{ reuse_trend|map(p => p.day)|json_encode }}"
                        data-fte="{{ reuse_trend|map(p => p.fte_saved)|json_encode }}"
                        data-pct="{{ reuse_trend|map(p => p.inheritance_pct)|json_encode }}"></canvas>
                <p class="small text-muted mt-2 mb-0">
                    <i class="fa-icon fa-icon--ui-info" aria-hidden="true"></i>
                    {{ 'portfolio_report.reuse_trend.footer'|trans({}, 'portfolio_report') }}
                </p>
            {% endblock %}
        {% endembed %}
        <script type="module">
            import Chart from 'https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.js/+esm';
            const el = document.getElementById('reuseTrendChart');
            if (el) {
                const labels = JSON.parse(el.dataset.labels);
                const fte = JSON.parse(el.dataset.fte);
                const pct = JSON.parse(el.dataset.pct);
                new Chart(el, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [
                            { label: '{{ 'portfolio_report.reuse_trend.fte_label'|trans({}, 'portfolio_report') }}',
                              data: fte, yAxisID: 'y1', borderColor: 'var(--success)', backgroundColor: 'var(--success-glow)', tension: 0.3, fill: true },
                            { label: '{{ 'portfolio_report.reuse_trend.pct_label'|trans({}, 'portfolio_report') }}',
                              data: pct, yAxisID: 'y2', borderColor: 'var(--primary)', borderDash: [4,4], tension: 0.3 }
                        ]
                    },
                    options: {
                        responsive: true,
                        interaction: { mode: 'index', intersect: false },
                        scales: {
                            y1: { type: 'linear', position: 'left', title: { display: true, text: 'FTE-Tage' } },
                            y2: { type: 'linear', position: 'right', title: { display: true, text: '%' }, min: 0, max: 100, grid: { drawOnChartArea: false } }
                        }
                    }
                });
            }
        </script>
    {% elseif reuse_trend is defined %}
        {{ _fa_alert.render({ variant: 'info', class: 'mb-4', body: 'portfolio_report.reuse_trend.empty'|trans({}, 'portfolio_report') }) }}
    {% endif %}

    {# Stichtag / Vorperiode Picker — 8H.4 migrated #}
    {% embed '_components/_card.html.twig' with { class: 'shadow-sm mb-4' } %}
        {% block card_body %}
            <form method="get" action="{{ path('app_management_reports_portfolio', { _locale: app.request.locale }) }}" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label for="portfolio_stichtag" class="form-label">
                        <i class="fa-icon fa-icon--nav-calendar-check" aria-hidden="true"></i>
                        {{ 'portfolio_report.form.stichtag'|trans({}, 'portfolio_report') }}
                    </label>
                    <input type="date"
                           class="form-control"
                           id="portfolio_stichtag"
                           name="stichtag"
                           value="{{ stichtag|date('Y-m-d') }}"
                           aria-describedby="portfolio_stichtag_help">
                    <div id="portfolio_stichtag_help" class="form-text">
                        {{ 'portfolio_report.form.stichtag_help'|trans({}, 'portfolio_report') }}
                    </div>
                </div>
                <div class="col-md-4">
                    <label for="portfolio_vorperiode" class="form-label">
                        <i class="fa-icon fa-icon--ui-hourglass" aria-hidden="true"></i>
                        {{ 'portfolio_report.form.vorperiode'|trans({}, 'portfolio_report') }}
                    </label>
                    <input type="date"
                           class="form-control"
                           id="portfolio_vorperiode"
                           name="vorperiode"
                           value="{{ vorperiode ? vorperiode|date('Y-m-d') : '' }}"
                           aria-describedby="portfolio_vorperiode_help">
                    <div id="portfolio_vorperiode_help" class="form-text">
                        {{ 'portfolio_report.form.vorperiode_help'|trans({}, 'portfolio_report') }}
                    </div>
                </div>
                <div class="col-md-4">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                        <i class="fa-icon fa-icon--ui-refresh" aria-hidden="true"></i>
                        {{ 'portfolio_report.form.update'|trans({}, 'portfolio_report') }}
                    </button>
                </div>
            </form>
        {% endblock %}
    {% endembed %}

    {# Matrix — 8H.4 migrated #}
    {% embed '_components/_card.html.twig' with { class: 'shadow-sm', noPadding: true } %}
        {% block card_header %}
            <div class="card-header">
                <h2 class="h5 mb-0">
                    <i class="fa-icon fa-icon--nav-process" aria-hidden="true"></i>
                    {{ 'portfolio_report.matrix.title'|trans({}, 'portfolio_report') }}
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% if matrix.frameworks|length == 0 %}
                {{ _fa_alert.render({ variant: 'info', class: 'mb-0 m-3', body: 'portfolio_report.matrix.no_frameworks'|trans({}, 'portfolio_report') }) }}
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <caption class="visually-hidden">
                            {{ 'portfolio_report.matrix.caption'|trans({}, 'portfolio_report') }}
                        </caption>
                        <thead class="table-light">
                            <tr>
                                <th scope="col" class="text-nowrap">
                                    {{ 'portfolio_report.matrix.function'|trans({}, 'portfolio_report') }}
                                </th>
                                {% for framework in matrix.frameworks %}
                                    <th scope="col" class="text-nowrap text-center">
                                        <span title="{{ framework.name }}">{{ framework.code }}</span>
                                    </th>
                                {% endfor %}
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in matrix.rows %}
                                <tr>
                                    <th scope="row" class="text-nowrap">
                                        <i class="bi bi-layers-half text-muted" aria-hidden="true"></i>
                                        {{ ('portfolio_report.category.' ~ row.category|lower)|trans({}, 'portfolio_report') }}
                                    </th>
                                    {% for framework in matrix.frameworks %}
                                        {% set cell = row.cells[framework.code] %}
                                        {% set cell_variant = 'secondary' %}
                                        {% set cell_icon = 'bi-dash-circle' %}
                                        {% if cell.count == 0 %}
                                            {% set cell_variant = 'secondary' %}
                                            {% set cell_icon = 'bi-slash-circle' %}
                                        {% elseif cell.pct >= thresholds.green %}
                                            {% set cell_variant = 'success' %}
                                            {% set cell_icon = 'bi-check-circle-fill' %}
                                        {% elseif cell.pct >= thresholds.yellow %}
                                            {% set cell_variant = 'warning' %}
                                            {% set cell_icon = 'bi-exclamation-triangle-fill' %}
                                        {% else %}
                                            {% set cell_variant = 'danger' %}
                                            {% set cell_icon = 'bi-x-circle-fill' %}
                                        {% endif %}

                                        {% set aria = 'portfolio_report.cell.aria'|trans({
                                            '%category%': ('portfolio_report.category.' ~ row.category|lower)|trans({}, 'portfolio_report'),
                                            '%framework%': framework.name,
                                            '%pct%': cell.pct,
                                            '%count%': cell.count,
                                            '%gaps%': cell.gaps
                                        }, 'portfolio_report') %}

                                        {% set delta_val = cell.delta is defined ? cell.delta : null %}
                                        {% if delta_val is null %}
                                            {% set trend_icon = '—' %}
                                            {% set trend_class = 'text-muted' %}
                                            {% set trend_key = 'no_data' %}
                                        {% elseif delta_val > 5 %}
                                            {% set trend_icon = '↗' %}
                                            {% set trend_class = 'text-success' %}
                                            {% set trend_key = 'up' %}
                                        {% elseif delta_val < -5 %}
                                            {% set trend_icon = '↘' %}
                                            {% set trend_class = 'text-danger' %}
                                            {% set trend_key = 'down' %}
                                        {% else %}
                                            {% set trend_icon = '→' %}
                                            {% set trend_class = 'text-muted' %}
                                            {% set trend_key = 'stable' %}
                                        {% endif %}

                                        <td class="text-center">
                                            {% if cell.count == 0 %}
                                                {% include '_components/_badge.html.twig' with {
                                                    variant: 'secondary',
                                                    icon: cell_icon,
                                                    aria_label: aria,
                                                    title: aria,
                                                    content: 'portfolio_report.cell.na'|trans({}, 'portfolio_report')
                                                } only %}
                                            {% else %}
                                                <a href="{{ path('app_management_reports_portfolio_drill', {
                                                        frameworkCode: framework.code,
                                                        category: row.category,
                                                        _locale: app.request.locale,
                                                        stichtag: stichtag|date('Y-m-d')
                                                    }) }}"
                                                   class="text-decoration-none"
                                                   aria-label="{{ aria }}">
                                                    {% include '_components/_badge.html.twig' with {
                                                        variant: cell_variant,
                                                        icon: cell_icon,
                                                        aria_label: aria,
                                                        title: aria,
                                                        content: cell.pct ~ '%'
                                                    } only %}
                                                </a>
                                                <div class="small text-muted mt-1">
                                                    <span title="{{ 'portfolio_report.cell.count_tooltip'|trans({}, 'portfolio_report') }}">
                                                        <i class="fa-icon fa-icon--nav-list-ordered" aria-hidden="true"></i> {{ cell.count }}
                                                    </span>
                                                    {% if cell.gaps > 0 %}
                                                        <span class="ms-2 text-danger" title="{{ 'portfolio_report.cell.gaps_tooltip'|trans({}, 'portfolio_report') }}">
                                                            <i class="bi bi-exclamation-diamond" aria-hidden="true"></i> {{ cell.gaps }}
                                                        </span>
                                                    {% endif %}
                                                    <span class="ms-2 {{ trend_class }}"
                                                          aria-label="{{ ('portfolio_report.trend.' ~ trend_key)|trans({'%delta%': delta_val ?? 0}, 'portfolio_report') }}"
                                                          title="{{ ('portfolio_report.trend.' ~ trend_key)|trans({'%delta%': delta_val ?? 0}, 'portfolio_report') }}">
                                                        {{ trend_icon }}{% if delta_val is not null and delta_val != 0 %} {{ delta_val > 0 ? '+' : '' }}{{ delta_val }}{% endif %}
                                                    </span>
                                                </div>
                                            {% endif %}
                                        </td>
                                    {% endfor %}
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        {% endblock %}
        {% block card_footer %}
            <div class="card-footer small text-muted">
                <i class="fa-icon fa-icon--ui-info" aria-hidden="true"></i>
                {{ 'portfolio_report.matrix.legend'|trans({}, 'portfolio_report') }}
            </div>
        {% endblock %}
    {% endembed %}

    {# Inheritance-Rate Breakdown per Framework (CM-1) — 8H.4 migrated #}
    {% if inheritance_metrics is defined and inheritance_metrics.per_framework|length > 0 %}
        {% embed '_components/_card.html.twig' with { class: 'shadow-sm mt-4', noPadding: true } %}
            {% block card_header %}
                <div class="card-header">
                    <h2 class="h5 mb-0">
                        <i class="bi bi-share-fill text-primary" aria-hidden="true"></i>
                        {{ 'portfolio_report.inheritance.title'|trans({}, 'portfolio_report') }}
                    </h2>
                </div>
            {% endblock %}
            {% block card_body %}
                <div class="table-responsive">
                <table class="table table-sm mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">{{ 'portfolio_report.matrix.function'|trans({}, 'portfolio_report') }}</th>
                            <th scope="col" class="text-end">{{ 'portfolio_report.inheritance.total'|trans({}, 'portfolio_report') }}</th>
                            <th scope="col" class="text-end">{{ 'portfolio_report.inheritance.manual'|trans({}, 'portfolio_report') }}</th>
                            <th scope="col" class="text-end">{{ 'portfolio_report.inheritance.inherited'|trans({}, 'portfolio_report') }}</th>
                            <th scope="col" class="text-end">{{ 'portfolio_report.inheritance.pending'|trans({}, 'portfolio_report') }}</th>
                            <th scope="col" class="text-end">{{ 'portfolio_report.inheritance.rate'|trans({}, 'portfolio_report') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for row in inheritance_metrics.per_framework %}
                            {% set inherited = row.fulfillments_from_inheritance_confirmed + row.fulfillments_from_inheritance_overridden %}
                            <tr>
                                <th scope="row">{{ row.framework_code }}</th>
                                <td class="text-end">{{ row.fulfillments_total }}</td>
                                <td class="text-end">{{ row.fulfillments_manual }}</td>
                                <td class="text-end">{{ inherited }}</td>
                                <td class="text-end">
                                    {% if row.pending_review_count > 0 %}
                                        <span class="text-warning">{{ row.pending_review_count }}</span>
                                    {% else %}
                                        0
                                    {% endif %}
                                </td>
                                <td class="text-end fw-semibold">{{ row.inheritance_rate_percent }}%</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                    <tfoot class="table-light">
                        {% set total_inherited = inheritance_metrics.total.fulfillments_from_inheritance_confirmed + inheritance_metrics.total.fulfillments_from_inheritance_overridden %}
                        <tr>
                            <th scope="row">&Sigma;</th>
                            <td class="text-end fw-semibold">{{ inheritance_metrics.total.fulfillments_total }}</td>
                            <td class="text-end fw-semibold">{{ inheritance_metrics.total.fulfillments_manual }}</td>
                            <td class="text-end fw-semibold">{{ total_inherited }}</td>
                            <td class="text-end fw-semibold">{{ inheritance_metrics.total.pending_review_count }}</td>
                            <td class="text-end fw-bold text-primary">{{ inheritance_metrics.total.inheritance_rate_percent }}%</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            {% endblock %}
        {% endembed %}
    {% endif %}
</div>
{% endblock %}
