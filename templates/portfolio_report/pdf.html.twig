<!DOCTYPE html>
<html lang="{{ app.request.locale|default('de') }}">
<head>
    <meta charset="UTF-8">
    <title>{{ 'portfolio_report.title'|trans({}, 'portfolio_report') }} - {{ tenant.name }}</title>
    <style>
        :root {
            --primary:       #0ea5e9;
            --surface:       #ffffff;
            --surface-2:     #f1f5f9;
            --fg:            #0f172a;
            --fg-2:          #475569;
            --fg-3:          #94a3b8;
            --border:        #cbd5e1;
            --success:       #166534;
            --success-tint:  #dcfce7;
            --warning:       #92400e;
            --warning-tint:  #fef3c7;
            --danger:        #991b1b;
            --danger-tint:   #fecaca;
        }
        * { box-sizing: border-box; }
        body {
            font-family: 'DejaVu Sans', Arial, sans-serif;
            font-size: 10pt;
            margin: 0;
            padding: 20px;
            color: var(--fg);
            background: var(--surface);
        }

        /* ── Cover ── */
        .report-cover {
            border-bottom: 3px solid var(--primary);
            padding-bottom: 10px;
            margin-bottom: 20px;
        }
        .report-cover h1  { margin: 0 0 4px; font-size: 18pt; color: var(--fg); }
        .report-cover .meta { font-size: 9pt; color: var(--fg-2); }
        .report-cover .meta strong { color: var(--fg); }

        /* ── Table ── */
        table { width: 100%; border-collapse: collapse; margin: 10px 0; font-size: 9pt; }
        th, td { padding: 5px 8px; border: 1px solid var(--border); text-align: center; }
        thead th { background: var(--fg); color: var(--surface); }
        tbody th  { background: var(--surface-2); text-align: left; color: var(--fg); }

        /* ── Badges ── */
        .badge {
            display: inline-block;
            padding: 2px 7px;
            border-radius: 10px;
            font-size: 8pt;
            font-weight: bold;
        }
        .badge-success { background: var(--success-tint);  color: var(--success); }
        .badge-warning { background: var(--warning-tint);  color: var(--warning); }
        .badge-danger  { background: var(--danger-tint);   color: var(--danger);  }
        .badge-muted   { background: var(--surface-2);     color: var(--fg-2); border: 1px solid var(--border); }

        /* ── Cell meta ── */
        .cell-meta { font-size: 7.5pt; color: var(--fg-3); margin-top: 3px; }
        .cell-gaps { color: var(--danger); }

        /* ── Legend ── */
        .legend {
            font-size: 8pt;
            color: var(--fg-2);
            margin-top: 12px;
            padding: 7px 10px;
            background: var(--surface-2);
            border-left: 3px solid var(--primary);
        }

        /* ── Footer ── */
        .report-footer {
            margin-top: 28px;
            text-align: center;
            font-size: 8pt;
            color: var(--fg-3);
            border-top: 1px solid var(--border);
            padding-top: 7px;
        }
    </style>
</head>
<body>

    {# ── Cover ── #}
    <div class="report-cover">
        <h1>{{ 'portfolio_report.title'|trans({}, 'portfolio_report') }}</h1>
        <div class="meta">
            <strong>{{ 'portfolio_report.header.tenant'|trans({}, 'portfolio_report') }}:</strong> {{ tenant.name }}
            &nbsp;|&nbsp;
            <strong>{{ 'portfolio_report.header.stichtag'|trans({}, 'portfolio_report') }}:</strong> {{ stichtag|date('Y-m-d') }}
            {% if vorperiode %}
                &nbsp;|&nbsp;
                <strong>{{ 'portfolio_report.header.vorperiode'|trans({}, 'portfolio_report') }}:</strong> {{ vorperiode|date('Y-m-d') }}
            {% endif %}
            &nbsp;|&nbsp;
            <strong>{{ 'portfolio_report.header.generated_at'|trans({}, 'portfolio_report') }}:</strong> {{ generated_at|date('Y-m-d H:i') }}
        </div>
    </div>

    {# ── Matrix table ── #}
    {% if matrix.frameworks|length == 0 %}
        <p style="color:var(--fg-3);font-style:italic;">{{ 'portfolio_report.matrix.no_frameworks'|trans({}, 'portfolio_report') }}</p>
    {% else %}
        <table>
            <thead>
                <tr>
                    <th scope="col">{{ 'portfolio_report.matrix.function'|trans({}, 'portfolio_report') }}</th>
                    {% for framework in matrix.frameworks %}
                        <th scope="col" title="{{ framework.name }}">{{ framework.code }}</th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody>
                {% for row in matrix.rows %}
                    <tr>
                        <th scope="row">{{ ('portfolio_report.category.' ~ row.category|lower)|trans({}, 'portfolio_report') }}</th>
                        {% for framework in matrix.frameworks %}
                            {% set cell = row.cells[framework.code] %}
                            {% set badge_class = 'badge-muted' %}
                            {% if cell.count > 0 %}
                                {% if cell.pct >= thresholds.green %}
                                    {% set badge_class = 'badge-success' %}
                                {% elseif cell.pct >= thresholds.yellow %}
                                    {% set badge_class = 'badge-warning' %}
                                {% else %}
                                    {% set badge_class = 'badge-danger' %}
                                {% endif %}
                            {% endif %}
                            {% set delta_val = cell.delta is defined ? cell.delta : null %}
                            {% if delta_val is null %}
                                {% set trend_icon = '—' %}
                            {% elseif delta_val > 5 %}
                                {% set trend_icon = '↗' %}
                            {% elseif delta_val < -5 %}
                                {% set trend_icon = '↘' %}
                            {% else %}
                                {% set trend_icon = '→' %}
                            {% endif %}
                            <td>
                                {% if cell.count == 0 %}
                                    <span class="badge badge-muted">{{ 'portfolio_report.cell.na'|trans({}, 'portfolio_report') }}</span>
                                {% else %}
                                    <span class="badge {{ badge_class }}">{{ cell.pct }}%</span>
                                    <div class="cell-meta">
                                        n={{ cell.count }}
                                        {% if cell.gaps > 0 %}
                                            <span class="cell-gaps">&nbsp;· {{ cell.gaps }} {{ 'portfolio_report.cell.gaps_short'|trans({}, 'portfolio_report') }}</span>
                                        {% endif %}
                                        &nbsp;· {{ trend_icon }}{% if delta_val is not null and delta_val != 0 %} {{ delta_val > 0 ? '+' : '' }}{{ delta_val }}{% endif %}
                                    </div>
                                {% endif %}
                            </td>
                        {% endfor %}
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        <div class="legend">
            <strong>{{ 'portfolio_report.matrix.legend_title'|trans({}, 'portfolio_report') }}:</strong>
            {{ 'portfolio_report.matrix.legend'|trans({}, 'portfolio_report') }}
        </div>
    {% endif %}

    <div class="report-footer">
        {{ 'portfolio_report.pdf.footer'|trans({}, 'portfolio_report') }}
    </div>

</body>
</html>
