{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% trans_default_domain 'portfolio_report' %}

{% block title %}{{ 'portfolio_report.drill.title'|trans({'%framework%': framework.code, '%category%': category}, 'portfolio_report') }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.reports'|trans({}, 'nav'), path: 'app_reports_index' },
            { label: 'management_reports.title'|trans({}, 'management_reports'), path: 'app_management_reports' },
            { label: 'portfolio_report.title'|trans({}, 'portfolio_report'), path: 'app_management_reports_portfolio' },
            { label: 'portfolio_report.drill.title'|trans({'%framework%': framework.code, '%category%': category}, 'portfolio_report') }
        ]
    } %}

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h1 class="h2 mb-1">
                <i class="fa-icon fa-icon--util-zoom-in text-primary" aria-hidden="true"></i>
                {{ 'portfolio_report.drill.title'|trans({'%framework%': framework.code, '%category%': ('portfolio_report.category.' ~ category|lower)|trans({}, 'portfolio_report')}, 'portfolio_report') }}
            </h1>
            <p class="text-muted mb-0">
                <i class="fa-icon fa-icon--nav-building" aria-hidden="true"></i>
                <strong>{{ tenant.name }}</strong>
                <span class="mx-2">&middot;</span>
                <i class="fa-icon fa-icon--ui-calendar-event" aria-hidden="true"></i>
                {{ 'portfolio_report.header.stichtag'|trans({}, 'portfolio_report') }}:
                <strong>{{ stichtag|date('Y-m-d') }}</strong>
            </p>
        </div>
        <a href="{{ path('app_management_reports_portfolio', {
            _locale: app.request.locale,
            stichtag: stichtag|date('Y-m-d')
        }) }}" class="fa-cyber-btn fa-cyber-btn--ghost">
            <i class="fa-icon fa-icon--util-arrow-left" aria-hidden="true"></i>
            {{ 'portfolio_report.drill.back'|trans({}, 'portfolio_report') }}
        </a>
    </div>

    <div class="card fa-section shadow-sm">
        <div class="card-body p-0">
            {% if rows|length == 0 %}
                {{ _fa_alert.render({ variant: 'info', class: 'mb-0 m-3', body: 'portfolio_report.drill.empty'|trans({}, 'portfolio_report') }) }}
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">{{ 'portfolio_report.drill.table.requirement'|trans({}, 'portfolio_report') }}</th>
                                <th scope="col">{{ 'portfolio_report.drill.table.title'|trans({}, 'portfolio_report') }}</th>
                                <th scope="col" class="text-end">{{ 'portfolio_report.drill.table.fulfillment'|trans({}, 'portfolio_report') }}</th>
                                <th scope="col" class="text-center">{{ 'portfolio_report.drill.table.applicable'|trans({}, 'portfolio_report') }}</th>
                                <th scope="col" class="text-end">{{ 'portfolio_report.drill.table.link'|trans({}, 'portfolio_report') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in rows %}
                                <tr>
                                    <th scope="row" class="text-nowrap">{{ row.requirement.requirementId }}</th>
                                    <td>{{ row.requirement.title }}</td>
                                    <td class="text-end">
                                        {% if row.fulfillment is null %}
                                            <span class="text-muted">—</span>
                                        {% else %}
                                            <span class="fw-semibold">{{ row.pct }}%</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-center">
                                        {% if row.applicable %}
                                            <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
                                            <span class="visually-hidden">{{ 'portfolio_report.drill.table.applicable'|trans({}, 'portfolio_report') }}</span>
                                        {% else %}
                                            <i class="bi bi-slash-circle text-muted" aria-hidden="true"></i>
                                            <span class="visually-hidden">n/a</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-end">
                                        <a href="{{ path('app_compliance_requirement_show', { id: row.requirement.id, _locale: app.request.locale }) }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost">
                                            <i class="fa-icon fa-icon--util-external-link" aria-hidden="true"></i>
                                            {{ 'portfolio_report.drill.table.link'|trans({}, 'portfolio_report') }}
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
