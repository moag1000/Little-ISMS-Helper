{% extends 'base.html.twig' %}
{% trans_default_domain 'asset' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'asset.title.edit'|trans({}, 'asset') }} - {{ parent() }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.assets'|trans({}, 'nav'), url: path('app_asset_index'), icon: 'cpu' },
            { label: asset.name, url: path('app_asset_show', {id: asset.id}) },
            { label: 'asset.title.edit'|trans({}, 'asset') }
        ]
    } %}

    {{ _fa_page_header.render({
        title: 'asset.title.edit'|trans({}, 'asset') ~ ': ' ~ asset.name,
        badge: { icon: 'ui-edit', label: '' },
        actions: [
            { label: 'common.back'|trans({}, 'messages'), href: path('app_asset_show', {id: asset.id}), variant: 'secondary', icon: 'util-arrow-left' }
        ]
    }) }}

    {{ form_start(form) }}

    {% include '_components/_auto_form.html.twig' with {
        'form': form,
        'layout': 'outline-rail',
        'eyebrow': 'ISO 27001 A.5.9 · Asset Inventory',
        'title': 'asset.title.edit'|trans({}, 'asset') ~ ': ' ~ asset.name,
        'sections': {
            'overview': {
                'label': 'asset.section.overview'|trans({}, 'asset'),
                'fields': ['name', 'description', 'assetType']
            },
            'ownership': {
                'label': 'asset.section.ownership'|trans({}, 'asset'),
                'fields': ['ownerUser', 'ownerPerson', 'ownerDeputyPersons', 'owner', 'physicalLocation', 'dependsOn', 'processingActivities']
            },
            'classification': {
                'label': 'asset.section.classification'|trans({}, 'asset'),
                'fields': ['dataClassification', 'status', 'returnDate', 'isDoraRelevant', 'tisaxInformationClassification']
            },
            'protection_requirements': {
                'label': 'asset.section.cia_values'|trans({}, 'asset'),
                'fields': ['confidentialityValue', 'integrityValue', 'availabilityValue']
            },
            'lifecycle_status': {
                'label': 'asset.section.financial'|trans({}, 'asset'),
                'fields': ['acquisitionValue', 'currentValue', 'acceptableUsePolicy', 'handlingInstructions']
            },
            'dependencies': {
                'label': 'asset.section.ai_agent'|trans({}, 'asset'),
                'fields': ['aiAgentClassification', 'aiAgentPurpose', 'aiAgentDataSources', 'aiAgentOversightMechanism', 'aiAgentProvider', 'aiAgentModelVersion', 'aiAgentCapabilityScope', 'aiAgentThreatModelDocId', 'aiAgentExtensionAllowlist']
            }
        },
        'col_widths': {
            'name': 6,
            'assetType': 6,
            'description': 12,
            'ownerUser': 6,
            'ownerPerson': 6,
            'ownerDeputyPersons': 12,
            'owner': 6,
            'physicalLocation': 6,
            'dependsOn': 12,
            'processingActivities': 12,
            'dataClassification': 4,
            'status': 4,
            'returnDate': 4,
            'isDoraRelevant': 6,
            'tisaxInformationClassification': 6,
            'confidentialityValue': 4,
            'integrityValue': 4,
            'availabilityValue': 4,
            'acquisitionValue': 6,
            'currentValue': 6,
            'acceptableUsePolicy': 12,
            'handlingInstructions': 12,
            'aiAgentClassification': 6,
            'aiAgentProvider': 6,
            'aiAgentModelVersion': 6,
            'aiAgentOversightMechanism': 6,
            'aiAgentPurpose': 12,
            'aiAgentDataSources': 12,
            'aiAgentCapabilityScope': 12,
            'aiAgentExtensionAllowlist': 12,
            'aiAgentThreatModelDocId': 6
        },
        'tooltips': {
            'acquisitionValue': 'asset.tooltip.acquisition_value',
            'currentValue': 'asset.tooltip.current_value',
            'confidentialityValue': 'asset.tooltip.confidentiality',
            'integrityValue': 'asset.tooltip.integrity',
            'availabilityValue': 'asset.tooltip.availability'
        },
        'translation_domain': 'asset',
        'actions': {
            'close': { 'label': 'common.cancel'|trans({}, 'messages'), 'variant': 'ghost' },
            'submit': { 'label': 'asset.action.update'|trans({}, 'asset'), 'variant': 'primary' }
        }
    } %}

    {{ form_end(form) }}

    {# Delete Danger Zone (only for edit) #}
    {% embed '_components/_card.html.twig' with {borderColor: 'danger', class: 'mt-4'} %}
        {% block card_header %}
            <div class="card-header">
                <h2 class="h5 mb-0">
                    <i class="fa-icon fa-icon--status-warning text-danger" aria-hidden="true"></i>
                    {{ 'common.danger_zone'|trans({}, 'messages') }}
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            <p class="text-muted">
                {{ 'asset.warning.delete_irreversible'|trans({}, 'asset') }}
            </p>
            {{ include('asset/_delete_form.html.twig') }}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
