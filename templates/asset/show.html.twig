{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% trans_default_domain 'assets' %}
{% import '_components/_status_pill.html.twig' as pill %}

{% block title %}{{ asset.name }}{% endblock %}

{% block body %}
{% import '_components/_fa_alva_hint.html.twig' as _fa_alva_hint %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.assets'|trans({}, 'nav'), url: path('app_asset_index') },
            { label: asset.name }
        ]
    } %}

    {% set hint = alva_hint(asset) %}
    {% if hint %}{{ _fa_alva_hint.render(hint) }}{% endif %}

    {% set _show_actions = [] %}
    {% if canEdit is defined and canEdit %}
        {% set _show_actions = _show_actions|merge([{ label: 'common.edit'|trans({}, 'messages'), variant: 'primary', icon: 'pencil', href: path('app_asset_edit', {id: asset.id}) }]) %}
    {% endif %}
    {% set _show_actions = _show_actions|merge([
        { label: 'asset.action.bcm_insights'|trans({}, 'asset'), variant: 'ghost', href: path('app_asset_bcm_insights', {id: asset.id}) },
        { label: 'asset.action.qr_label'|trans({}, 'asset'), variant: 'ghost', icon: 'qr-code', href: path('app_asset_qr_label', {id: asset.id}), attrs: { 'data-turbo': 'false', title: 'asset.action.print_qr_label'|trans({}, 'asset') } },
        { label: 'common.back_to_list'|trans({}, 'messages'), variant: 'ghost', href: path('app_asset_index') }
    ]) %}
    {{ _fa_page_header.render({
        badge: (isInherited is defined and isInherited) ? { icon: 'building', label: 'corporate.inherited'|trans({}, 'messages') } : null,
        title: asset.name,
        actions: _show_actions
    }) }}

    {# Inline POST-delete and disabled-edit kept below header (cannot be expressed via _fa_page_header GET-only actions) #}
    {% if (canEdit is defined and not canEdit) or (is_granted('ROLE_ADMIN') and (canEdit is not defined or canEdit)) %}
        <div class="d-flex justify-content-end gap-2 mb-3">
            {% if canEdit is defined and not canEdit %}
                <button class="fa-cyber-btn fa-cyber-btn--primary" disabled title="{{ 'corporate.inheritance.cannot_edit_inherited'|trans({}, 'messages') }}">
                    <i class="fa-icon fa-icon--ui-lock" aria-hidden="true"></i> {{ 'common.edit'|trans({}, 'messages') }}
                </button>
            {% endif %}
            {% if is_granted('ROLE_ADMIN') and (canEdit is not defined or canEdit) %}
                <form method="post" action="{{ path('app_asset_delete', {id: asset.id}) }}" class="d-inline"
                      data-controller="ui-actions"
                      data-action="submit->ui-actions#confirm"
                      data-ui-actions-message-param="{{ 'asset.confirm.delete'|trans({}, 'asset') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ asset.id) }}">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger"><i class="fa-icon fa-icon--ui-trash" aria-hidden="true"></i> {{ 'common.delete'|trans({}, 'messages') }}</button>
                </form>
            {% endif %}
        </div>
    {% endif %}

    {% if isInherited is defined and isInherited %}
        {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', icon: 'status-info', class: 'mb-3' } } %}
            {% block alert_body %}<div class="d-flex align-items-start"> <i class="fa-icon fa-icon--status-info me-2 mt-1" aria-hidden="true"></i> <div> <strong>{{ 'corporate.inheritance.view_only_title'|trans({}, 'messages') }}</strong> <p class="mb-0">{{ 'corporate.inheritance.asset_inherited_message'|trans({}, 'messages') }}</p> </div> </div>{% endblock %}
        {% endembed %}
    {% endif %}

    {% embed '_components/_card.html.twig' %}
        {% block card_header %}
            {% import '_components/_status_pill.html.twig' as pill %}
            <div class="card-header">
                <h2>{{ 'asset.details.title'|trans({}, 'asset') }}</h2>
                {{ pill.render(asset.status|upper, pill_tone_status(asset.status)) }}
            </div>
        {% endblock %}
        {% block card_body %}
            {% import '_components/_status_pill.html.twig' as pill %}
            {# Phase 8H.1: standardised via _detail_group component #}
            {% include '_components/_detail_group.html.twig' with {
                items: [
                    { label: 'asset.label.type'|trans({}, 'asset'), value: asset.assetType },
                    { label: 'asset.label.owner'|trans({}, 'asset'), value: asset.effectiveOwner, dataReuse: true },
                    { label: 'asset.label.location'|trans({}, 'asset'), value: asset.location },
                    { label: 'asset.label.status'|trans({}, 'asset'), value: asset.status|upper }
                ]
            } only %}

            {% if asset.description %}
                <div class="detail-section">
                    <h3>{{ 'common.description'|trans({}, 'messages') }}</h3>
                    <p>{{ asset.description }}</p>
                </div>
            {% endif %}

            {% if asset.isAiAgent %}
                <div class="detail-section">
                    <h3>
                        <i class="fa-icon fa-icon--nav-robot" aria-hidden="true"></i>
                        AI-Agent (EU AI Act + ISO 42001 + MRIS MHC-13)
                    </h3>
                    <p class="small text-muted">
                        <em>Quelle: Peddi (2026) MRIS v1.5. Lizenz: CC BY 4.0.</em>
                    </p>
                    {% embed '_components/_fa_table.html.twig' with { compact: true, hover: false } %}
                        {% block table_body %}
                            <tr class="fa-table__row">
                                <th scope="row" class="fa-table__cell" style="width: 30%;">Risikoklasse <small class="text-muted">(AI Act Art. 6)</small></th>
                                <td class="fa-table__cell">
                                    {% if asset.aiAgentClassification %}
                                        <code>{{ asset.aiAgentClassification }}</code>
                                    {% else %}<span class="text-warning">— nicht klassifiziert —</span>{% endif %}
                                </td>
                            </tr>
                            <tr class="fa-table__row">
                                <th scope="row" class="fa-table__cell">Anbieter <small class="text-muted">(Art. 16)</small></th>
                                <td class="fa-table__cell">{{ asset.aiAgentProvider|default('—') }}</td>
                            </tr>
                            <tr class="fa-table__row">
                                <th scope="row" class="fa-table__cell">Modell-Version <small class="text-muted">(ISO 42001)</small></th>
                                <td class="fa-table__cell"><code>{{ asset.aiAgentModelVersion|default('—') }}</code></td>
                            </tr>
                            <tr class="fa-table__row">
                                <th scope="row" class="fa-table__cell">Zweckbestimmung <small class="text-muted">(Art. 11)</small></th>
                                <td class="fa-table__cell">{{ asset.aiAgentPurpose|default('—')|nl2br }}</td>
                            </tr>
                            <tr class="fa-table__row">
                                <th scope="row" class="fa-table__cell">Datengovernance <small class="text-muted">(Art. 10)</small></th>
                                <td class="fa-table__cell">{{ asset.aiAgentDataSources|default('—')|nl2br }}</td>
                            </tr>
                            <tr class="fa-table__row">
                                <th scope="row" class="fa-table__cell">Human Oversight <small class="text-muted">(Art. 14)</small></th>
                                <td class="fa-table__cell">{{ asset.aiAgentOversightMechanism|default('—') }}</td>
                            </tr>
                            <tr class="fa-table__row">
                                <th scope="row" class="fa-table__cell">Capability-Scope <small class="text-muted">(MHC-13)</small></th>
                                <td class="fa-table__cell">
                                    {% if asset.aiAgentCapabilityScope is not empty %}
                                        {% for cap in asset.aiAgentCapabilityScope %}
                                            <code class="me-1">{{ cap }}</code>
                                        {% endfor %}
                                    {% else %}—{% endif %}
                                </td>
                            </tr>
                            <tr class="fa-table__row">
                                <th scope="row" class="fa-table__cell">Bedrohungsmodell-Doc <small class="text-muted">(Art. 9 + MHC-13)</small></th>
                                <td class="fa-table__cell">
                                    {% if asset.aiAgentThreatModelDocId %}
                                        <a href="{{ path('app_document_show', {id: asset.aiAgentThreatModelDocId}) }}">Dokument #{{ asset.aiAgentThreatModelDocId }}</a>
                                    {% else %}<span class="text-warning">— nicht hinterlegt —</span>{% endif %}
                                </td>
                            </tr>
                            <tr class="fa-table__row">
                                <th scope="row" class="fa-table__cell">Extension-Allowlist <small class="text-muted">(MHC-13)</small></th>
                                <td class="fa-table__cell">
                                    {% if asset.aiAgentExtensionAllowlist is not empty %}
                                        {% for ext in asset.aiAgentExtensionAllowlist %}
                                            <code class="me-1">{{ ext }}</code>
                                        {% endfor %}
                                    {% else %}—{% endif %}
                                </td>
                            </tr>
                        {% endblock %}
                    {% endembed %}
                </div>

                {# DPIA-Status für Hochrisiko-AI-Agents (DSGVO Art. 35 + AI Act Art. 9). #}
                {# Soft-Failure: linkedDpias === null bedeutet, das DPIA-Modul ist nicht verfügbar. #}
                {% if asset.aiAgentClassification == 'high_risk' and linkedDpias is not null %}
                    <div class="detail-section">
                        <h3>
                            <i class="fa-icon fa-icon--control" aria-hidden="true"></i>
                            {{ 'mris.ai_agent.dpia.section_title'|trans({}, 'mris') }}
                        </h3>
                        {% if linkedDpias|length > 0 %}
                            {% embed '_components/_fa_table.html.twig' with { compact: true } %}
                                {% block table_head %}
                                    <tr>
                                        <th scope="col" class="fa-table__th">{{ 'mris.ai_agent.dpia.col_title'|trans({}, 'mris') }}</th>
                                        <th scope="col" class="fa-table__th">{{ 'mris.ai_agent.dpia.col_status'|trans({}, 'mris') }}</th>
                                        <th scope="col" class="fa-table__th fa-table__th--actions">{{ 'mris.ai_agent.dpia.col_link'|trans({}, 'mris') }}</th>
                                    </tr>
                                {% endblock %}
                                {% block table_body %}
                                    {% for dpia in linkedDpias %}
                                        <tr class="fa-table__row">
                                            <td class="fa-table__cell">{{ dpia.referenceNumber }} — {{ dpia.title }}</td>
                                            <td class="fa-table__cell"><code>{{ dpia.status }}</code></td>
                                            <td class="fa-table__cell fa-table__cell--actions">
                                                <a href="{{ path('app_dpia_show', {id: dpia.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                                    {{ 'mris.ai_agent.dpia.open'|trans({}, 'mris') }}
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                {% endblock %}
                            {% endembed %}
                        {% else %}
                            <div class="fa-alert fa-alert--warning" role="alert">
                                <i class="fa-icon fa-icon--status-warning me-1" aria-hidden="true"></i>
                                {{ 'mris.ai_agent.dpia.warning_missing'|trans({}, 'mris') }}
                                <div class="mt-2">
                                    <a href="{{ path('app_dpia_new', {related_asset: asset.id}) }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--warning">
                                        <i class="fa-icon fa-icon--ui-plus me-1" aria-hidden="true"></i>
                                        {{ 'mris.ai_agent.dpia.create_button'|trans({}, 'mris') }}
                                    </a>
                                </div>
                            </div>
                        {% endif %}
                    </div>
                {% endif %}
            {% endif %}

            <div class="detail-section">
                <h3>{{ 'asset.section.valuation'|trans({}, 'asset') }}</h3>
                {# Phase 8H.1: standardised via _detail_group component #}
                {% set valuationItems = [
                    { label: 'asset.label.acquisition_value'|trans({}, 'asset'), value: asset.acquisitionValue ? asset.acquisitionValue ~ ' EUR' : 'N/A' },
                    { label: 'asset.label.current_value'|trans({}, 'asset'), value: asset.currentValue ? asset.currentValue ~ ' EUR' : 'N/A' }
                ] %}
                {% if asset.monetaryValue %}
                    {% set valuationItems = valuationItems|merge([{ label: 'asset.label.monetary_value'|trans({}, 'asset'), value: asset.monetaryValue ~ ' EUR' }]) %}
                {% endif %}
                {% set valuationItems = valuationItems|merge([
                    { label: 'asset.label.total_value'|trans({}, 'asset'), value: asset.totalValue ~ ' EUR', dataReuse: true },
                    { label: 'asset.label.risks'|trans({}, 'asset'), raw: true, dataReuse: true, value: asset.risks|length > 0
                        ? '<a href="#related-risks" class="' ~ badge_score(asset.risks|length, 5, 3) ~ '">' ~ asset.risks|length ~ '</a>'
                        : '<span class="text-muted">0</span>' }
                ]) %}
                {% include '_components/_detail_group.html.twig' with { items: valuationItems } only %}
            </div>

            {% if asset.dataClassification or asset.returnDate %}
                <div class="detail-section">
                    <h3>{{ 'asset.section.compliance'|trans({}, 'asset') }}</h3>
                    <div class="detail-grid">
                        {% if asset.dataClassification %}
                            <div class="detail-item">
                                <span class="label">{{ 'asset.label.data_classification'|trans({}, 'asset') }}</span>
                                <span class="value">
                                    {{ pill.render(('asset.classification.' ~ asset.dataClassification)|trans({}, 'asset')|upper, pill_tone_classification(asset.dataClassification)) }}
                                </span>
                            </div>
                        {% endif %}
                        {% if asset.returnDate %}
                            <div class="detail-item">
                                <span class="label">{{ 'asset.label.return_date'|trans({}, 'asset') }}</span>
                                <span class="value">{{ asset.returnDate|date('Y-m-d') }}</span>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endif %}

            <div class="detail-section">
                <h3>{{ 'asset.section.cia_triad'|trans({}, 'asset') }}<a href="{{ path('app_help_glossary') }}#glossary-cia" class="text-muted ms-1" title="{{ 'common.glossary_link'|trans({}, 'messages') }}" data-bs-toggle="tooltip"><i class="fa-icon fa-icon--ui-help fa-icon--16" aria-hidden="true"></i></a></h3>
                <div class="cia-values">
                    <div class="cia-item">
                        <span class="label">{{ 'asset.label.confidentiality'|trans({}, 'asset') }}</span>
                        <div class="value-bar">
                            <div class="bar" style="width: {{ (asset.confidentialityValue / 5 * 100) }}%"></div>
                        </div>
                        <span class="value">{{ asset.confidentialityValue }}/5</span>
                    </div>
                    <div class="cia-item">
                        <span class="label">{{ 'asset.label.integrity'|trans({}, 'asset') }}</span>
                        <div class="value-bar">
                            <div class="bar" style="width: {{ (asset.integrityValue / 5 * 100) }}%"></div>
                        </div>
                        <span class="value">{{ asset.integrityValue }}/5</span>
                    </div>
                    <div class="cia-item">
                        <span class="label">{{ 'asset.label.availability'|trans({}, 'asset') }}</span>
                        <div class="value-bar">
                            <div class="bar" style="width: {{ (asset.availabilityValue / 5 * 100) }}%"></div>
                        </div>
                        <span class="value">{{ asset.availabilityValue }}/5</span>
                    </div>
                </div>
            </div>

            {% if inheritedProtection is defined and inheritedProtection %}
                {% set ownC = asset.confidentialityValue ?? 0 %}
                {% set ownI = asset.integrityValue ?? 0 %}
                {% set ownA = asset.availabilityValue ?? 0 %}
                {% set hasInc = inheritedProtection.confidentiality > ownC or inheritedProtection.integrity > ownI or inheritedProtection.availability > ownA %}
                {% if hasInc %}
                    <div class="detail-section">
                        <h3>
                            <i class="fa-icon fa-icon--nav-process" aria-hidden="true"></i>
                            {{ 'asset.section.inherited_protection'|trans({}, 'asset') }}
                            {# bi-diagram-3 stays — here it represents structural/dependency diagram, not a network asset #}
                        </h3>
                        {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning', icon: 'status-warning' } } %}
                            {% block alert_body %}{{ 'asset.inherited_protection.warning'|trans({}, 'asset') }}{% endblock %}
                        {% endembed %}
                        {% embed '_components/_fa_table.html.twig' with { compact: true } %}
                            {% block table_head %}
                                <tr>
                                    <th scope="col" class="fa-table__th">{{ 'asset.inherited_protection.dimension'|trans({}, 'asset') }}</th>
                                    <th scope="col" class="fa-table__th">{{ 'asset.inherited_protection.own'|trans({}, 'asset') }}</th>
                                    <th scope="col" class="fa-table__th">{{ 'asset.inherited_protection.inherited'|trans({}, 'asset') }}</th>
                                    <th scope="col" class="fa-table__th">{{ 'asset.inherited_protection.driven_by'|trans({}, 'asset') }}</th>
                                </tr>
                            {% endblock %}
                            {% block table_body %}
                                {% for dim in ['confidentiality', 'integrity', 'availability'] %}
                                    {% set own = {confidentiality: ownC, integrity: ownI, availability: ownA}[dim] %}
                                    {% set inherited = attribute(inheritedProtection, dim) %}
                                    {% set driver = inheritedProtection.drivenBy[dim] %}
                                    <tr class="fa-table__row">
                                        <td class="fa-table__cell">{{ ('asset.field.' ~ dim)|trans({}, 'asset') }}</td>
                                        <td class="fa-table__cell">{{ own }}/5</td>
                                        <td class="fa-table__cell">
                                            {% if inherited > own %}
                                                <span class="fa-status-pill fa-status-pill--warning">{{ inherited }}/5 ↑</span>
                                            {% else %}
                                                {{ inherited }}/5
                                            {% endif %}
                                        </td>
                                        <td class="fa-table__cell">
                                            {% if driver and driver.id != asset.id %}
                                                <a href="{{ path('app_asset_show', {id: driver.id}) }}">{{ driver.name }}</a>
                                            {% else %}
                                                <span class="text-muted">—</span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            {% endblock %}
                        {% endembed %}
                    </div>
                {% endif %}
            {% endif %}

            {% if asset.handlingInstructions %}
                <div class="detail-section">
                    <h3>{{ 'asset.section.handling_instructions'|trans({}, 'asset') }}</h3>
                    <div class="instruction-box">
                        {{ asset.handlingInstructions|nl2br }}
                    </div>
                </div>
            {% endif %}

            {% if asset.acceptableUsePolicy %}
                <div class="detail-section">
                    <h3>{{ 'asset.section.acceptable_use_policy'|trans({}, 'asset') }}</h3>
                    <div class="policy-box">
                        {{ asset.acceptableUsePolicy|nl2br }}
                    </div>
                </div>
            {% endif %}

            {% if analysis %}
                <div class="detail-section">
                    <h3>{{ 'asset.section.protection_analysis'|trans({}, 'asset') }}</h3>
                    <div class="protection-analysis">
                        {% set levelColors = {'very_high': 'danger', 'high': 'warning', 'normal': 'info', 'low': 'secondary'} %}

                        <div class="row mb-3">
                            {# Confidentiality #}
                            <div class="col-md-4">
                                <div class="protection-card">
                                    <div class="protection-header">
                                        <i class="fa-icon fa-icon--control" aria-hidden="true"></i>
                                        {{ 'asset.label.confidentiality'|trans({}, 'asset') }}
                                    </div>
                                    <div class="protection-level">
                                        {% include '_components/_badge.html.twig' with { variant: levelColors[analysis.confidentiality.level]|default('secondary'), content: ('bcm.level.' ~ analysis.confidentiality.level)|trans({}, 'bcm') } %}
                                        <span class="value-display">{{ analysis.confidentiality.value }}/5</span>
                                    </div>
                                    {% if analysis.confidentiality.recommendation %}
                                        <div class="protection-recommendation">
                                            <i class="fa-icon fa-icon--util-arrow-up text-warning" aria-hidden="true"></i>
                                            {{ 'asset.protection.recommended'|trans({}, 'asset') }}: {{ analysis.confidentiality.recommendation }}/5
                                        </div>
                                    {% endif %}
                                    <div class="protection-source">
                                        <small class="text-muted">
                                            <i class="fa-icon fa-icon--status-info" aria-hidden="true"></i>
                                            {{ analysis.confidentiality.reasoning }}
                                        </small>
                                    </div>
                                </div>
                            </div>

                            {# Integrity #}
                            <div class="col-md-4">
                                <div class="protection-card">
                                    <div class="protection-header">
                                        <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i>
                                        {{ 'asset.label.integrity'|trans({}, 'asset') }}
                                    </div>
                                    <div class="protection-level">
                                        {% include '_components/_badge.html.twig' with { variant: levelColors[analysis.integrity.level]|default('secondary'), content: ('bcm.level.' ~ analysis.integrity.level)|trans({}, 'bcm') } %}
                                        <span class="value-display">{{ analysis.integrity.value }}/5</span>
                                    </div>
                                    {% if analysis.integrity.recommendation %}
                                        <div class="protection-recommendation">
                                            <i class="fa-icon fa-icon--util-arrow-up text-warning" aria-hidden="true"></i>
                                            {{ 'asset.protection.recommended'|trans({}, 'asset') }}: {{ analysis.integrity.recommendation }}/5
                                        </div>
                                    {% endif %}
                                    <div class="protection-source">
                                        <small class="text-muted">
                                            <i class="fa-icon fa-icon--status-info" aria-hidden="true"></i>
                                            {{ analysis.integrity.reasoning }}
                                        </small>
                                    </div>
                                </div>
                            </div>

                            {# Availability #}
                            <div class="col-md-4">
                                <div class="protection-card">
                                    <div class="protection-header">
                                        <i class="fa-icon fa-icon--threat" aria-hidden="true"></i>
                                        {{ 'asset.label.availability'|trans({}, 'asset') }}
                                    </div>
                                    <div class="protection-level">
                                        {% include '_components/_badge.html.twig' with { variant: levelColors[analysis.availability.level]|default('secondary'), content: ('bcm.level.' ~ analysis.availability.level)|trans({}, 'bcm') } %}
                                        <span class="value-display">{{ analysis.availability.value }}/5</span>
                                    </div>
                                    {% if analysis.availability.recommendation %}
                                        <div class="protection-recommendation">
                                            <i class="fa-icon fa-icon--util-arrow-up text-warning" aria-hidden="true"></i>
                                            {{ 'asset.protection.recommended'|trans({}, 'asset') }}: {{ analysis.availability.recommendation }}/5
                                        </div>
                                    {% endif %}
                                    <div class="protection-source">
                                        <small class="text-muted">
                                            <i class="fa-icon fa-icon--status-info" aria-hidden="true"></i>
                                            {{ analysis.availability.reasoning }}
                                        </small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {# Overall Level #}
                        {% if analysis.overallLevel is defined %}
                            <div class="overall-protection">
                                <strong>{{ 'asset.protection.overall_level'|trans({}, 'asset') }}:</strong>
                                {% include '_components/_badge.html.twig' with { variant: levelColors[analysis.overallLevel]|default('secondary'), class: 'ms-2', content: ('bcm.level.' ~ analysis.overallLevel)|trans({}, 'bcm') } %}
                            </div>
                        {% endif %}

                        {# Data Reuse Info #}
                        <div class="data-reuse-info mt-3">
                            <small class="text-muted">
                                <i class="fa-icon fa-icon--archive" aria-hidden="true"></i>
                                {{ 'asset.protection.data_reuse_info'|trans({}, 'asset') }}
                            </small>
                        </div>
                    </div>
                </div>
            {% endif %}

            {# Data Reuse: Protecting Controls #}
            {% if asset.protectingControls is defined and asset.protectingControls|length > 0 %}
                <div class="detail-section">
                    <h3>{{ 'asset.section.protecting_controls'|trans({}, 'asset') }} ({{ asset.protectingControls|length }})</h3>
                    <div class="controls-list">
                        {% for control in asset.protectingControls %}
                            <div class="control-item">
                                {% include '_components/_iso_reference_label.html.twig' with { control: control, code_class: 'fw-bold' } only %}
                                {{ pill.render(control.implementationStatus|upper, pill_tone_status(control.implementationStatus)) }}
                                <small>({{ control.implementationPercentage }}%)</small>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# Data Reuse: Related Risks #}
            {% if asset.risks is defined and asset.risks|length > 0 %}
                <div class="detail-section">
                    <h3>{{ 'asset.section.related_risks'|trans({}, 'asset') }} ({{ asset.risks|length }})</h3>
                    <div class="risks-list">
                        {% for risk in asset.risks %}
                            <div class="risk-item">
                                <strong>{{ risk.title }}</strong>
                                {{ pill.render('asset.risk_item.risk_level'|trans({'%value%': risk.inherentRiskLevel}, 'asset'), pill_tone_score(risk.inherentRiskLevel, 16, 9)) }}
                                <small>{{ 'asset.risk_item.status'|trans({'%value%': (risk.status ? risk.status.value : '')|upper}, 'asset') }}</small>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# V3 W2-Bug3: Linked Processing Activities (M:N inverse) #}
            {% if asset.processingActivities is defined and asset.processingActivities|length > 0 %}
                <div class="detail-section">
                    <h3>{{ 'asset.section.processing_activities'|trans({}, 'asset') }} ({{ asset.processingActivities|length }})</h3>
                    <div class="processing-activities-list">
                        {% for activity in asset.processingActivities %}
                            <div class="processing-activity-item">
                                <a href="{{ path('app_processing_activity_show', {id: activity.id}) }}">
                                    <strong>{{ activity.name }}</strong>
                                </a>
                                {% if activity.legalBasis %}
                                    <small class="text-muted">{{ activity.legalBasis }}</small>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# Data Reuse: Related Incidents #}
            {% if asset.incidents is defined and asset.incidents|length > 0 %}
                <div class="detail-section">
                    <h3>{{ 'asset.section.related_incidents'|trans({}, 'asset') }} ({{ asset.incidents|length }})</h3>
                    <div class="incidents-list">
                        {% for incident in asset.incidents %}
                            <div class="incident-item">
                                <strong>{{ incident.title }}</strong>
                                {{ pill.render(incident.severity ? incident.severity.value|upper : '', pill_tone_severity(incident.severity)) }}
                                <small>{{ incident.detectedAt|date('Y-m-d') }}</small>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# Asset History: Audit Log #}
            {% if auditLogs is defined and auditLogs|length > 0 %}
                <div class="detail-section">
                    <h3>{{ 'asset.section.history'|trans({}, 'asset') }} ({{ totalAuditLogs }} {{ 'audit_log.entries'|trans({}, 'audit_log') }})</h3>
                    <div class="audit-log-list">
                        {% for log in auditLogs %}
                            <div class="audit-log-item">
                                <div class="audit-log-header">
                                    {{ pill.render(log.action|upper, pill_tone_action(log.action)) }}
                                    <small class="text-muted">{{ log.createdAt|date('Y-m-d H:i:s') }}</small>
                                </div>
                                <div class="audit-log-details">
                                    <strong>{{ log.userName }}</strong>
                                    {% set oldValues = log.oldValuesArray %}
                                    {% set newValues = log.newValuesArray %}
                                    {% if newValues %}
                                        <div class="audit-log-changes">
                                            {% for field, newValue in newValues %}
                                                <div class="change-item">
                                                    <span class="field-name">{{ field }}:</span>
                                                    {% if oldValues and oldValues[field] is defined %}
                                                        <span class="old-value">{{ oldValues[field] }}</span>
                                                        <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                                                    {% endif %}
                                                    <span class="new-value">{{ newValue }}</span>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                    {% if totalAuditLogs > 10 %}
                        <div class="text-center mt-3">
                            <a href="{{ path('app_audit_log_index', {entity: 'Asset', entityId: asset.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                <i class="fa-icon fa-icon--nav-calendar-check" aria-hidden="true"></i> {{ 'audit_log.view_all'|trans({}, 'audit_log') }} ({{ totalAuditLogs }})
                            </a>
                        </div>
                    {% endif %}
                </div>
            {% endif %}
        {% endblock %}
    {% endembed %}

    {# V3 B6 / EF-4: Inverse-Coverage Impact-Analyse #}
    {% include '_components/_impact_coverage.html.twig' with {
        impact: impact_coverage|default({total: 0, frameworks: []}),
        entity_label: 'asset'
    } %}

    {# V4 LB-4: Comment-Thread adoption (C7 macro). #}
    {% include '_components/_isms_comment_thread.html.twig' with {
        comments: comments|default([]),
        entityType: 'Asset',
        entityId: asset.id,
        showForm: canEdit is not defined or canEdit,
        formAction: path('app_comment_post', {entityType: 'Asset', entityId: asset.id}),
        csrfToken: csrf_token('isms-comment')
    } only %}
</div>

<style>
.cia-values { display: flex; flex-direction: column; gap: 1rem; }
.cia-item { display: flex; align-items: center; gap: 1rem; }
.cia-item .label { width: 150px; font-weight: bold; }
.value-bar { flex: 1; height: 24px; background: var(--bs-secondary-bg); border-radius: 4px; overflow: hidden; }
.value-bar .bar { height: 100%; background: linear-gradient(90deg, var(--success), var(--success-strong)); }
.cia-item .value { width: 50px; text-align: right; }
.instruction-box, .policy-box {
    padding: 1rem;
    background: var(--bs-tertiary-bg);
    color: var(--bs-body-color);
    border-left: 3px solid var(--primary);
    border-radius: 4px;
    white-space: pre-wrap;
}
/* .badge-classification-* removed: dead code (BadgeExtension renders
   "badge bg-<color>" via Aurora). */
/* Data Reuse Sections */
.controls-list, .risks-list, .incidents-list { display: flex; flex-direction: column; gap: 0.5rem; }
.control-item, .risk-item, .incident-item {
    padding: 0.75rem;
    background: var(--bs-tertiary-bg);
    color: var(--bs-body-color);
    border-left: 3px solid var(--primary);
    border-radius: 4px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}
/* Badge styles now handled by BadgeExtension helper functions */
/* Audit Log Styles */
.audit-log-list { display: flex; flex-direction: column; gap: 0.75rem; }
.audit-log-item {
    padding: 1rem;
    background: var(--bs-tertiary-bg);
    color: var(--bs-body-color);
    border-left: 3px solid var(--accent);
    border-radius: 4px;
}
.audit-log-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
}
.audit-log-details { margin-top: 0.5rem; }
.audit-log-changes {
    margin-top: 0.5rem;
    padding-left: 1rem;
    font-size: 0.875rem;
}
.change-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0.25rem 0;
}
.field-name { font-weight: bold; color: var(--bs-secondary-color); }
.old-value {
    text-decoration: line-through;
    color: var(--danger);
}
.new-value {
    color: var(--success);
    font-weight: 500;
}
/* .badge-action-* removed: dead code. */

/* Protection Analysis Styles */
.protection-analysis .protection-card {
    padding: 1rem;
    background: var(--bs-tertiary-bg);
    border-radius: 8px;
    border-left: 4px solid var(--bs-primary);
    height: 100%;
}
.protection-analysis .protection-header {
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: var(--bs-body-color);
}
.protection-analysis .protection-header i {
    margin-right: 0.5rem;
}
.protection-analysis .protection-level {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
}
.protection-analysis .value-display {
    font-weight: 500;
    color: var(--bs-secondary-color);
}
.protection-analysis .protection-recommendation {
    padding: 0.5rem;
    background: var(--warning-glow);
    border-radius: 4px;
    margin-bottom: 0.75rem;
    font-size: 0.875rem;
}
.protection-analysis .protection-source {
    font-size: 0.8rem;
    line-height: 1.4;
}
.protection-analysis .overall-protection {
    padding: 0.75rem 1rem;
    background: var(--bs-tertiary-bg);
    border-radius: 8px;
    display: flex;
    align-items: center;
}
.protection-analysis .data-reuse-info {
    padding: 0.5rem 1rem;
    background: rgba(13, 202, 240, 0.1);
    border-radius: 4px;
    border-left: 3px solid var(--primary);
}
</style>
{% endblock %}
