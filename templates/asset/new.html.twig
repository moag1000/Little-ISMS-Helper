{% extends 'base.html.twig' %}
{% trans_default_domain 'assets' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_norm_bridge.html.twig' as _fa_norm_bridge %}

{% block title %}{{ 'asset.title.new'|trans({}, 'asset') }} - {{ parent() }}{% endblock %}

{% block body %}
{# Breadcrumb Navigation #}
{% include '_components/_breadcrumb.html.twig' with {
    breadcrumbs: [
        { label: 'nav.assets'|trans({}, 'nav', 'nav'), url: path('app_asset_index'), icon: 'cpu' },
        { label: 'asset.title.new'|trans({}, 'asset') }
    ]
} %}

{# Page Header #}
{{ _fa_page_header.render({
    title: 'asset.title.new'|trans({}, 'asset'),
    badge: { icon: 'plus', label: '' },
    actions: [
        { label: 'common.back'|trans({}, 'messages'), href: path('app_asset_index'), variant: 'secondary', icon: 'util-arrow-left' }
    ]
}) }}

{{ _fa_norm_bridge.render({
    from_norm: 'ISO 27001 A.5.9-12',
    to_norm:   'ISO 9001 7.1.3 + 7.5',
    bridge_text: ('iso_9001_bridge.asset'|trans({}, 'asset')),
    prominence: 'subtle'
}) }}

{# P-19 — Form-Step-Inline-Hint controller. See assets/controllers/alva_hint_in_form_controller.js. #}
{{ form_start(form, {'attr': {
    'data-controller': 'alva-hint-in-form',
    'data-alva-hint-in-form-entity-type-value': 'asset',
    'data-alva-hint-in-form-form-name-value': 'asset',
    'data-alva-hint-in-form-endpoint-value': path('api_alva_hint_form_evaluate', {'entityType': 'asset'}),
    'data-alva-hint-in-form-csrf-token-value': csrf_token('alva_hint_form'),
    'data-action': 'input->alva-hint-in-form#scheduleEvaluate change->alva-hint-in-form#scheduleEvaluate',
}}) }}
{% include '_components/_auto_form.html.twig' with {
    'form': form,
    'layout': 'outline-rail',
    'eyebrow': 'ISO 27001 A.5.9 · Asset Inventory',
    'title': 'asset.title.new'|trans({}, 'asset'),
    'sections': {
        'basic_info': {
            'label': 'asset.section.basic_info'|trans({}, 'asset'),
            'fields': ['name', 'assetType', 'description']
        },
        'assignment': {
            'label': 'asset.section.assignment'|trans({}, 'asset'),
            'fields': ['ownerUser', 'ownerPerson', 'ownerDeputyPersons', 'owner', 'physicalLocation', 'dependsOn']
        },
        'financial': {
            'label': 'asset.section.financial'|trans({}, 'asset'),
            'fields': ['acquisitionValue', 'currentValue']
        },
        'classification': {
            'label': 'asset.section.classification'|trans({}, 'asset'),
            'fields': ['dataClassification', 'tisaxInformationClassification', 'status', 'returnDate', 'isDoraRelevant', 'processingActivities']
        },
        'cia_values': {
            'label': 'asset.section.cia_values'|trans({}, 'asset'),
            'fields': ['confidentialityValue', 'integrityValue', 'availabilityValue']
        },
        'policies': {
            'label': 'asset.section.policies'|trans({}, 'asset'),
            'fields': ['acceptableUsePolicy', 'handlingInstructions']
        },
        'ai_agent': {
            'label': 'asset.section.ai_agent'|trans({}, 'asset'),
            'fields': ['aiAgentClassification', 'aiAgentPurpose', 'aiAgentDataSources', 'aiAgentOversightMechanism', 'aiAgentProvider', 'aiAgentModelVersion', 'aiAgentCapabilityScope', 'aiAgentThreatModelDocId', 'aiAgentExtensionAllowlist']
        }
    },
    'col_widths': {
        'name': 6,
        'assetType': 6,
        'description': 12,
        'ownerUser': 6,
        'ownerPerson': 6,
        'ownerDeputyPersons': 12,
        'owner': 6,
        'physicalLocation': 6,
        'dependsOn': 12,
        'acquisitionValue': 6,
        'currentValue': 6,
        'dataClassification': 4,
        'tisaxInformationClassification': 4,
        'status': 4,
        'returnDate': 4,
        'isDoraRelevant': 4,
        'processingActivities': 12,
        'confidentialityValue': 4,
        'integrityValue': 4,
        'availabilityValue': 4,
        'acceptableUsePolicy': 12,
        'handlingInstructions': 12,
        'aiAgentClassification': 6,
        'aiAgentProvider': 6,
        'aiAgentModelVersion': 6,
        'aiAgentOversightMechanism': 6,
        'aiAgentPurpose': 12,
        'aiAgentDataSources': 12,
        'aiAgentCapabilityScope': 12,
        'aiAgentExtensionAllowlist': 12,
        'aiAgentThreatModelDocId': 6
    },
    'tooltips': {
        'acquisitionValue': 'asset.tooltip.acquisition_value',
        'currentValue': 'asset.tooltip.current_value',
        'confidentialityValue': 'asset.tooltip.confidentiality',
        'integrityValue': 'asset.tooltip.integrity',
        'availabilityValue': 'asset.tooltip.availability'
    },
    'translation_domain': 'asset',
    'actions': {
        'close': { 'label': 'common.cancel'|trans({}, 'messages'), 'variant': 'ghost' },
        'submit': { 'label': 'asset.action.create'|trans({}, 'asset'), 'variant': 'primary' }
    }
} %}
{{ form_end(form) }}
{% endblock %}
