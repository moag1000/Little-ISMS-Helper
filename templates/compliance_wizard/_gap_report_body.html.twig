{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_status_pill.html.twig' as pill %}
{#
    WS-6 Gap-Report body partial.

    Reused by:
      - compliance_wizard/results.html.twig (inline under the score)
      - compliance_wizard/gap_report.html.twig (dedicated page)

    Expected variables:
      wizard                  (string)  - wizard key, used for links
      effort_table            (array)   - rows from GapEffortCalculator::calculate()
      total_effort_days       (float)   - sum of remaining_effort_days
      quick_wins              (array)   - rows flagged as Quick-Wins
      effort_estimated_count  (int)
      effort_unestimated_count(int)
#}
{% set slider_max = total_effort_days|round(0, 'ceil') %}
{% if slider_max < 1 %}{% set slider_max = 0 %}{% endif %}

{# 8H.4 migrated — 3 summary KPI cards via _card.html.twig #}
<div class="row g-3 mb-4">
    <div class="col-md-4">
        {% embed '_components/_card.html.twig' with { class: 'border-0 shadow-sm h-100' } %}
            {% block card_body %}
                <div class="small fw-semibold text-muted mb-2">
                    <i class="fa-icon fa-icon--ui-hourglass me-1" aria-hidden="true"></i>{{ 'gap_report.summary.total_effort'|trans({}, 'gap_report') }}
                </div>
                <div class="display-6 fw-bold">{{ total_effort_days|number_format(1, '.', ',') }}</div>
                <small class="text-muted">{{ 'gap_report.unit.person_days'|trans({}, 'gap_report') }}</small>
            {% endblock %}
        {% endembed %}
    </div>
    <div class="col-md-4">
        {% embed '_components/_card.html.twig' with { class: 'border-0 shadow-sm h-100' } %}
            {% block card_body %}
                <div class="small fw-semibold text-muted mb-2">
                    <i class="fa-icon fa-icon--threat text-success me-1" aria-hidden="true"></i>{{ 'gap_report.summary.quick_wins'|trans({}, 'gap_report') }}
                </div>
                <div class="display-6 fw-bold text-success">{{ quick_wins|length }}</div>
                <small class="text-muted">{{ 'gap_report.summary.quick_wins_hint'|trans({}, 'gap_report') }}</small>
            {% endblock %}
        {% endembed %}
    </div>
    <div class="col-md-4">
        {% embed '_components/_card.html.twig' with { class: 'border-0 shadow-sm h-100' } %}
            {% block card_body %}
                <div class="small fw-semibold text-muted mb-2">
                    <i class="fa-icon fa-icon--sop me-1" aria-hidden="true"></i>{{ 'gap_report.summary.coverage'|trans({}, 'gap_report') }}
                </div>
                <div class="display-6 fw-bold">{{ effort_estimated_count }}</div>
                <small class="text-muted">
                    {{ 'gap_report.summary.coverage_hint'|trans({'%unestimated%': effort_unestimated_count}, 'gap_report') }}
                </small>
            {% endblock %}
        {% endembed %}
    </div>
</div>

{% if effort_estimated_count == 0 %}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', icon: 'bi-info-circle', class: 'mb-4' } } %}
        {% block alert_body %}{{ 'gap_report.info.no_estimates'|trans({}, 'gap_report') }}{% endblock %}
    {% endembed %}
{% else %}
    {# Budget simulator slider — 8H.4 migrated. Stimulus attrs hooked via card_attrs block #}
    {% embed '_components/_card.html.twig' with { class: 'border-0 shadow-sm mb-4' } %}
        {% block card_attrs %}data-controller="budget-simulator" data-budget-simulator-total-value="{{ slider_max }}"{% endblock %}
        {% block card_body %}
            <div class="d-flex justify-content-between align-items-center flex-wrap mb-2">
                <label for="gap-report-budget-slider" class="form-label fw-semibold mb-0">
                    <i class="fa-icon fa-icon--nav-sliders me-1" aria-hidden="true"></i>{{ 'gap_report.budget.title'|trans({}, 'gap_report') }}
                </label>
                <output for="gap-report-budget-slider"
                        class="text-muted small"
                        data-budget-simulator-target="display"
                        aria-live="polite">
                    {{ 'gap_report.budget.placeholder'|trans({'%total%': slider_max}, 'gap_report') }}
                </output>
            </div>
            <input type="range"
                   class="form-range"
                   id="gap-report-budget-slider"
                   data-budget-simulator-target="slider"
                   data-action="input->budget-simulator#update"
                   min="0" max="{{ slider_max > 0 ? slider_max : 1 }}" step="1" value="0"
                   aria-valuemin="0"
                   aria-valuemax="{{ slider_max }}"
                   aria-valuenow="0"
                   aria-valuetext="{{ 'gap_report.budget.placeholder'|trans({'%total%': slider_max}, 'gap_report') }}"
                   {% if slider_max == 0 %}disabled{% endif %}>
            <small class="text-muted">
                {{ 'gap_report.budget.help'|trans({}, 'gap_report') }}
            </small>
        </div>

        {# Table #}
        {% embed '_components/_fa_table.html.twig' %}
            {% block table_head %}
                <tr>
                    <th scope="col" class="fa-table__th">{{ 'gap_report.table.requirement'|trans({}, 'gap_report') }}</th>
                    <th scope="col" class="fa-table__th">{{ 'gap_report.table.category'|trans({}, 'gap_report') }}</th>
                    <th scope="col" class="fa-table__th fa-table__th--center">{{ 'gap_report.table.priority'|trans({}, 'gap_report') }}</th>
                    <th scope="col" class="fa-table__th fa-table__th--num">{{ 'gap_report.table.fulfillment'|trans({}, 'gap_report') }}</th>
                    <th scope="col" class="fa-table__th fa-table__th--num">{{ 'gap_report.table.base_effort'|trans({}, 'gap_report') }}</th>
                    <th scope="col" class="fa-table__th fa-table__th--num">{{ 'gap_report.table.remaining_effort'|trans({}, 'gap_report') }}</th>
                    <th scope="col" class="fa-table__th fa-table__th--center">{{ 'gap_report.table.quick_win'|trans({}, 'gap_report') }}</th>
                </tr>
            {% endblock %}
            {% block table_body %}
                {% import '_components/_status_pill.html.twig' as pill %}
                {% for row in effort_table %}
                    <tr class="fa-table__row"
                        data-budget-simulator-target="row"
                        data-effort="{{ row.remaining_effort_days ?: 0 }}">
                        <td class="fa-table__cell">
                            <a href="{{ path('app_compliance_requirement_show', {id: row.requirement.id}) }}">
                                <code>{{ row.requirement.requirementId }}</code>
                            </a>
                            <div class="small text-muted text-truncate" style="max-width: 320px;"
                                 title="{{ row.requirement.title }}">
                                {{ row.requirement.title }}
                            </div>
                        </td>
                        <td class="fa-table__cell small">{{ row.category|default('—') }}</td>
                        <td class="fa-table__cell fa-table__cell--center">
                            {% if row.priority %}
                                {% set _pp = row.priority == 'critical' ? 'danger' : (row.priority == 'high' ? 'warning' : (row.priority == 'medium' ? 'primary' : 'neutral')) %}
                                {{ pill.render(row.priority, _pp) }}
                            {% else %}—{% endif %}
                        </td>
                        <td class="fa-table__cell fa-table__cell--num">{{ row.fulfillment_percentage }}%</td>
                        <td class="fa-table__cell fa-table__cell--num">
                            {% if row.effective_effort_days is not null %}
                                {{ row.effective_effort_days }}
                                {% if row.adjusted_effort_days is not null %}
                                    <i class="fa-icon fa-icon--ui-edit text-primary ms-1"
                                       title="{{ 'gap_report.table.override_hint'|trans({}, 'gap_report') }}"
                                       aria-label="{{ 'gap_report.table.override_hint'|trans({}, 'gap_report') }}"></i>
                                {% endif %}
                            {% else %}
                                <span class="text-muted small">{{ 'gap_report.table.not_estimated'|trans({}, 'gap_report') }}</span>
                            {% endif %}
                        </td>
                        <td class="fa-table__cell fa-table__cell--num fw-semibold">
                            {% if row.effective_effort_days is not null %}
                                {{ row.remaining_effort_days|number_format(1, '.', ',') }}
                            {% else %}—{% endif %}
                        </td>
                        <td class="fa-table__cell fa-table__cell--center">
                            {% if row.is_quick_win %}
                                <span class="fa-status-pill fa-status-pill--success">
                                    <i class="fa-icon fa-icon--threat" aria-hidden="true"></i>
                                    {{ 'gap_report.table.quick_win_badge'|trans({}, 'gap_report') }}
                                </span>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            {{ 'gap_report.table.empty'|trans({}, 'gap_report') }}
                        </td>
                    </tr>
                {% endfor %}
            {% endblock %}
        {% endembed %}
        {% endblock %}
    {% endembed %}
{% endif %}
