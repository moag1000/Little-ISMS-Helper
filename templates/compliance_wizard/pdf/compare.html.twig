<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ 'wizard.export.pdf.title'|trans({}, 'wizard') }}</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            font-size: 10.5pt;
            line-height: 1.45;
            color: #333;
            padding: 20px 40px;
        }
        .header {
            border-bottom: 3px solid #0d6efd;
            padding-bottom: 18px;
            margin-bottom: 24px;
        }
        .header h1 {
            font-size: 22pt;
            color: #0d6efd;
            margin-bottom: 4px;
        }
        .header .subtitle {
            color: #666;
            font-size: 11pt;
        }
        .meta-info {
            background: #f8f9fa;
            padding: 12px 15px;
            margin-bottom: 24px;
            border-radius: 5px;
        }
        .meta-info table { width: 100%; }
        .meta-info td { padding: 4px 8px; vertical-align: top; }
        .meta-info .label {
            font-weight: bold;
            color: #666;
            width: 160px;
        }
        h2 {
            color: #0d6efd;
            font-size: 15pt;
            margin: 26px 0 12px 0;
            padding-bottom: 4px;
            border-bottom: 1px solid #dee2e6;
        }
        h3 {
            font-size: 12pt;
            margin: 14px 0 6px 0;
        }
        .framework-grid {
            display: table;
            width: 100%;
            border-collapse: separate;
            border-spacing: 8px 0;
            margin: 10px 0 20px;
        }
        .framework-card {
            display: table-cell;
            vertical-align: top;
            width: 1%;
            border: 1px solid #dee2e6;
            border-radius: 6px;
            padding: 14px;
            background: #fff;
        }
        .framework-card .fw-name {
            font-weight: bold;
            font-size: 11pt;
            color: #0d6efd;
            margin-bottom: 6px;
        }
        .framework-card .fw-score {
            font-size: 28pt;
            font-weight: bold;
            text-align: center;
            margin: 8px 0;
        }
        .framework-card .fw-status {
            text-align: center;
            margin-bottom: 10px;
        }
        .framework-card table.cat-list {
            width: 100%;
            border-collapse: collapse;
            font-size: 9pt;
        }
        .framework-card table.cat-list td {
            padding: 3px 4px;
            border-bottom: 1px solid #f1f3f5;
        }
        .framework-card table.cat-list td.pct {
            text-align: right;
            width: 50px;
            font-weight: bold;
        }
        .score-success { color: #198754; }
        .score-warning { color: #b58900; }
        .score-danger { color: #dc3545; }
        table.matrix {
            width: 100%;
            border-collapse: collapse;
            margin: 12px 0 20px;
            font-size: 9.5pt;
        }
        table.matrix th,
        table.matrix td {
            border: 1px solid #dee2e6;
            padding: 6px 8px;
            text-align: left;
        }
        table.matrix th {
            background: #f8f9fa;
            font-weight: bold;
        }
        table.matrix td.num {
            text-align: center;
            width: 110px;
        }
        .badge {
            display: inline-block;
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 9pt;
            font-weight: bold;
            min-width: 50px;
            text-align: center;
        }
        .badge.success  { background: #d1e7dd; color: #0f5132; }
        .badge.warning  { background: #fff3cd; color: #856404; }
        .badge.danger   { background: #f8d7da; color: #842029; }
        .badge.muted    { background: #e9ecef; color: #6c757d; }
        tfoot .badge { font-size: 10pt; }
        .footer {
            margin-top: 36px;
            padding-top: 16px;
            border-top: 1px solid #dee2e6;
            font-size: 8.5pt;
            color: #666;
            text-align: center;
        }
        @media print {
            body { padding: 0; }
        }
    </style>
</head>
<body>

    {# Header #}
    <div class="header">
        <h1>{{ 'wizard.export.pdf.title'|trans({}, 'wizard') }}</h1>
        <div class="subtitle">{{ 'wizard.compare_subtitle'|trans({}, 'wizard') }}</div>
    </div>

    {# Meta Information #}
    <div class="meta-info">
        <table>
            <tr>
                <td class="label">{{ 'wizard.export.pdf.tenant'|trans({}, 'wizard') }}:</td>
                <td>{{ tenant ? tenant.name : 'N/A' }}</td>
                <td class="label">{{ 'wizard.export.pdf.cutoff_date'|trans({}, 'wizard') }}:</td>
                <td>{{ generated_at|date('d.m.Y H:i') }}</td>
            </tr>
            <tr>
                <td class="label">{{ 'wizard.export.pdf.frameworks'|trans({}, 'wizard') }}:</td>
                <td colspan="3">
                    {% for key in selected_wizards %}
                        {% if available_wizards[key] is defined %}
                            <span class="badge muted">{{ available_wizards[key].code }}</span>
                        {% else %}
                            <span class="badge muted">{{ key|upper }}</span>
                        {% endif %}
                    {% endfor %}
                </td>
            </tr>
        </table>
    </div>

    {% if results|length > 0 %}

    {# Per-framework cards #}
    <h2>{{ 'wizard.export.pdf.per_framework'|trans({}, 'wizard') }}</h2>
    <div class="framework-grid">
        {% for key, result in results %}
            {% set score = result.overall_score %}
            {% set cls = score >= 80 ? 'score-success' : (score >= 60 ? 'score-warning' : 'score-danger') %}
            {% set bcls = score >= 80 ? 'success' : (score >= 60 ? 'warning' : 'danger') %}
            <div class="framework-card">
                <div class="fw-name">{{ result.framework_name ?? (available_wizards[key].name ?? key|upper) }}</div>
                <div class="fw-score {{ cls }}">{{ score }}%</div>
                <div class="fw-status">
                    <span class="badge {{ bcls }}">
                        {{ ('wizard.status.' ~ result.status)|trans({}, 'wizard') }}
                    </span>
                </div>
                <table class="cat-list">
                    {% for cat_key, cat in result.categories %}
                        {% set cscore = cat.score %}
                        {% set ccls = cscore >= 80 ? 'score-success' : (cscore >= 60 ? 'score-warning' : 'score-danger') %}
                        <tr>
                            <td>{{ cat.name|trans({}, 'wizard') }}</td>
                            <td class="pct {{ ccls }}">{{ cscore }}%</td>
                        </tr>
                    {% endfor %}
                </table>
            </div>
        {% endfor %}
    </div>

    {# Cross-framework category matrix #}
    <h2>{{ 'wizard.export.pdf.matrix'|trans({}, 'wizard') }}</h2>
    <table class="matrix">
        <thead>
            <tr>
                <th scope="col">{{ 'wizard.category'|trans({}, 'wizard') }}</th>
                {% for key, result in results %}
                    <th scope="col" class="num">
                        {{ available_wizards[key].code ?? key|upper }}
                    </th>
                {% endfor %}
            </tr>
        </thead>
        <tbody>
            {% set all_categories = {} %}
            {% for key, result in results %}
                {% for cat_key, cat in result.categories %}
                    {% set all_categories = all_categories|merge({(cat_key): cat.name}) %}
                {% endfor %}
            {% endfor %}

            {% for cat_key, cat_name in all_categories %}
                <tr>
                    <td><strong>{{ cat_name|trans({}, 'wizard') }}</strong></td>
                    {% for key, result in results %}
                        <td class="num">
                            {% if result.categories[cat_key] is defined %}
                                {% set s = result.categories[cat_key].score %}
                                {% set b = s >= 80 ? 'success' : (s >= 60 ? 'warning' : 'danger') %}
                                <span class="badge {{ b }}">{{ s }}%</span>
                            {% else %}
                                <span class="badge muted">-</span>
                            {% endif %}
                        </td>
                    {% endfor %}
                </tr>
            {% endfor %}
        </tbody>
        <tfoot>
            <tr>
                <th scope="col">{{ 'wizard.overall'|trans({}, 'wizard') }}</th>
                {% for key, result in results %}
                    {% set s = result.overall_score %}
                    {% set b = s >= 80 ? 'success' : (s >= 60 ? 'warning' : 'danger') %}
                    <th scope="col" class="num">
                        <span class="badge {{ b }}">{{ s }}%</span>
                    </th>
                {% endfor %}
            </tr>
        </tfoot>
    </table>

    {% else %}
        <p>{{ 'wizard.select_frameworks_hint'|trans({}, 'wizard') }}</p>
    {% endif %}

    {# Footer #}
    <div class="footer">
        <p>
            {{ 'wizard.export.pdf.generated_at'|trans({}, 'wizard') }}: {{ generated_at|date('d.m.Y H:i') }}<br>
            {{ 'wizard.export.pdf.audit_notice'|trans({}, 'wizard') }}
        </p>
    </div>

</body>
</html>
