{% extends 'base.html.twig' %}
{% trans_default_domain 'wizard' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% block title %}{{ 'wizard.results'|trans({}, 'wizard') }} - {{ result.framework_name }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {# Aurora Breadcrumb #}
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'wizard.title'|trans({}, 'wizard'), url: path('app_compliance_wizard_index') },
            { label: result.framework_name, url: path('app_compliance_wizard_start', {wizard: wizard}) },
            { label: 'wizard.results'|trans({}, 'wizard') }
        ]
    } %}

    {# Aurora Page Header #}
    {{ _fa_page_header.render({
        title: result.framework_name,
        subtitle: ('wizard.assessed_at'|trans({}, 'wizard')) ~ ': ' ~ (result.assessed_at|date('d.m.Y H:i')),
        badge: { icon: 'clipboard2-check', label: ('wizard.results'|trans({}, 'wizard')) ~ ' · ' ~ result.overall_score ~ '%' },
        actions: [
            { label: 'wizard.history.title'|trans({}, 'wizard'), href: path('app_compliance_wizard_history', {wizard: wizard}), variant: 'ghost', icon: 'clock-history' },
            { label: 'wizard.export_pdf'|trans({}, 'wizard'), href: path('app_compliance_wizard_export_pdf', {wizard: wizard}), variant: 'primary', icon: 'file-pdf' }
        ]
    }) }}

    {# V3 B5 / EF-2: Snapshot CTA #}
    <div class="d-flex justify-content-end mb-3">
        <form method="post" action="{{ path('app_compliance_wizard_snapshot', {wizard: wizard}) }}" class="d-inline">
            <input type="hidden" name="_token" value="{{ csrf_token('wizard_snapshot_' ~ wizard) }}">
            <button type="submit" class="fa-cyber-btn fa-cyber-btn--info">
                <i class="fa-icon fa-icon--ui-camera" aria-hidden="true"></i>
                {{ 'wizard.snapshot.cta'|trans({}, 'wizard') }}
            </button>
        </form>
    </div>

    {# Score summary card #}
    <div class="row mb-4">
        <div class="col-lg-8">
            {% embed '_components/_card.html.twig' with { 'class': 'border-0 shadow-sm' } %}
                {% block card_body %}
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-0">
                                {{ 'wizard.assessed_at'|trans({}, 'wizard') }}: {{ result.assessed_at|date('d.m.Y H:i') }}
                            </p>
                        </div>
                        <div class="text-end">
                            <div class="display-4 fw-bold
                                {% if result.overall_score >= 80 %}text-success
                                {% elseif result.overall_score >= 60 %}text-warning
                                {% else %}text-danger{% endif %}">
                                {{ result.overall_score }}%
                            </div>
                            <span class="badge
                                {% if result.status == 'compliant' %}bg-success
                                {% elseif result.status == 'partial' %}bg-warning-subtle text-warning
                                {% elseif result.status == 'in_progress' %}bg-info
                                {% else %}bg-danger{% endif %}">
                                {{ ('wizard.status.' ~ result.status)|trans({}, 'wizard') }}
                            </span>
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-lg-4">
            {% embed '_components/_card.html.twig' with { 'class': 'border-0 shadow-sm h-100' } %}
                {% block card_body %}
                    <div class="d-flex flex-column justify-content-center h-100">
                        <div class="d-grid gap-2">
                            <a href="{{ path('app_compliance_wizard_export_pdf', {wizard: wizard}) }}" class="fa-cyber-btn fa-cyber-btn--primary">
                                <i class="fa-icon fa-icon--nav-file-pdf me-2" aria-hidden="true"></i>{{ 'wizard.export_pdf'|trans({}, 'wizard') }}
                            </a>
                            {% include '_components/_fa_pdf_locale_switch.html.twig' with {route: 'app_compliance_wizard_export_pdf', route_params: {wizard: wizard}} only %}
                            <a href="{{ path('app_compliance_wizard_start', {wizard: wizard}) }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                                <i class="fa-icon fa-icon--ui-refresh me-2" aria-hidden="true"></i>{{ 'wizard.run_again'|trans({}, 'wizard') }}
                            </a>
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    {# Catalogue-Coverage KPI #}
    {% if result.catalogue_coverage is defined and result.catalogue_coverage.total > 0 %}
    <div class="row mb-4">
        <div class="col-12">
            {% embed '_components/_card.html.twig' with { 'class': 'border-0 shadow-sm' } %}
                {% block card_body %}
    {% import '_components/_fa_progress.html.twig' as _fa_progress %}
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                        <div>
                            <h2 class="h6 text-muted mb-1">
                                <i class="fa-icon me-1 fa-icon--nav-list-check" aria-hidden="true"></i>
                                {{ 'wizard.catalogue_coverage.title'|trans({}, 'wizard') }}
                            </h2>
                            <div class="h4 fw-bold mb-0">
                                {{ result.catalogue_coverage.covered }} / {{ result.catalogue_coverage.total }}
                                <span class="text-muted small fw-normal ms-2">
                                    {{ 'wizard.catalogue_coverage.subtitle'|trans({'%framework%': result.framework_name}, 'wizard') }}
                                </span>
                            </div>
                        </div>
                        <div class="text-end" style="min-width: 200px;">
                            {{ _fa_progress.render({ value: result.catalogue_coverage.percent, tone: result.catalogue_coverage.percent >= 80 ? 'success' : (result.catalogue_coverage.percent >= 50 ? 'warning' : 'danger'), showText: true }) }}
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>
    {% endif %}

    {# Critical Gaps Alert #}
    {% if result.critical_gap_count > 0 %}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'danger', icon: 'bi-exclamation-octagon', class: 'mb-4' } } %}
        {% block alert_body %}
            <div class="fa-alert__title">{{ 'wizard.critical_gaps_found'|trans({'%count%': result.critical_gap_count}, 'wizard') }}</div>
            <ul class="mb-0">
                {% for gap in result.critical_gaps|slice(0, 5) %}
                <li>
                    <strong>{{ gap.title|trans({}, 'wizard') }}</strong>
                    {% if gap.route is defined and gap.route is not null and gap.route is not empty %}
                        - <a href="{{ path(gap.route) }}" class="fa-alert__link">{{ 'wizard.go_to_module'|trans({}, 'wizard') }}</a>
                    {% endif %}
                </li>
                {% endfor %}
                {% if result.critical_gap_count > 5 %}
                <li class="text-muted">{{ 'wizard.and_more'|trans({'%count%': result.critical_gap_count - 5}, 'wizard') }}</li>
                {% endif %}
            </ul>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {# Categories #}
    <div class="row">
        <div class="col-12">
            <h2 class="h5 mb-3">{{ 'wizard.categories_detail'|trans({}, 'wizard') }}</h2>
        </div>
    </div>

    <div class="row">
        {% for key, category in result.categories %}
        <div class="col-md-6 col-lg-4 mb-4">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100 ' ~ (category.score >= 80 ? 'border-success' : (category.score >= 60 ? 'border-warning' : 'border-danger')) } %}
                {% block card_header %}
                    <div class="card-header d-flex justify-content-between align-items-center {% if category.score >= 80 %}bg-success bg-opacity-10 {% elseif category.score >= 60 %}bg-warning bg-opacity-10 {% else %}{% endif %}" style="background-color: var(--danger-tint); border: 1px solid var(--danger);">
                        <div class="d-flex align-items-center">
                            <i class="{{ category.icon|default('fa-icon--status-ok') }} me-2"></i>
                            <span class="fw-semibold">{{ category.name|trans({}, 'wizard') }}</span>
                        </div>
                        <span class="badge
                            {% if category.score >= 80 %}bg-success
                            {% elseif category.score >= 60 %}bg-warning-subtle text-warning
                            {% else %}bg-danger{% endif %}">
                            {{ category.score }}%
                        </span>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {# Progress Bar #}
                    {{ _fa_progress.render({ value: category.score, tone: category.score >= 80 ? 'success' : (category.score >= 60 ? 'warning' : 'danger'), class: 'mb-3' }) }}

                    {# Items Summary #}
                    <div class="small mb-3">
                        {% set completed = 0 %}
                        {% set partial = 0 %}
                        {% set failed = 0 %}
                        {% for item in category.items %}
                            {% if item.score >= 100 %}
                                {% set completed = completed + 1 %}
                            {% elseif item.score > 0 %}
                                {% set partial = partial + 1 %}
                            {% else %}
                                {% set failed = failed + 1 %}
                            {% endif %}
                        {% endfor %}

                        {% if completed > 0 %}
                            <span class="text-success me-2">
                                <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i> {{ completed }}
                            </span>
                        {% endif %}
                        {% if partial > 0 %}
                            <span class="text-warning me-2">
                                <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> {{ partial }}
                            </span>
                        {% endif %}
                        {% if failed > 0 %}
                            <span class="text-danger">
                                <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i> {{ failed }}
                            </span>
                        {% endif %}
                    </div>

                    {# Gaps #}
                    {% if category.gaps|length > 0 %}
                    <div class="small">
                        <strong class="text-danger">{{ 'wizard.gaps'|trans({}, 'wizard') }}: {{ category.gap_count }}</strong>
                        <ul class="list-unstyled mt-1 mb-0">
                            {% for gap in category.gaps|slice(0, 2) %}
                            <li class="text-truncate" title="{{ gap.title|trans({}, 'wizard') }}">
                                <i class="fa-icon fa-icon--ui-flag text-danger me-1" aria-hidden="true"></i>
                                {{ gap.title|trans({}, 'wizard') }}
                            </li>
                            {% endfor %}
                        </ul>
                    </div>
                    {% endif %}
                {% endblock %}
                {% block card_footer %}
                    <div class="card-footer bg-transparent">
                        <a href="{{ path('app_compliance_wizard_category', {wizard: wizard, category: key}) }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost w-100">
                            <i class="fa-icon fa-icon--ui-eye me-1" aria-hidden="true"></i>{{ 'wizard.view_details'|trans({}, 'wizard') }}
                        </a>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        {% endfor %}
    </div>

    {# Missing Modules Info #}
    {% if result.missing_modules|length > 0 %}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', icon: 'bi-lightbulb', class: 'mt-4' } } %}
        {% block alert_body %}
            <div class="fa-alert__title">{{ 'wizard.improve_coverage'|trans({}, 'wizard') }}</div>
            <p class="mb-2">{{ 'wizard.activate_for_better'|trans({}, 'wizard') }}</p>
            <ul class="mb-0">
                {% for mod in result.missing_modules %}
                <li><strong>{{ mod }}</strong></li>
                {% endfor %}
            </ul>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {# Navigation #}
    <div class="d-flex justify-content-between mt-4">
        <a href="{{ path('app_compliance_wizard_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
            <i class="fa-icon fa-icon--util-arrow-left me-1" aria-hidden="true"></i>{{ 'wizard.back_to_wizards'|trans({}, 'wizard') }}
        </a>
        <a href="{{ path('app_compliance_wizard_compare', {wizards: [wizard]}) }}" class="fa-cyber-btn fa-cyber-btn--ghost">
            <i class="fa-icon me-1 fa-icon--nav-grid" aria-hidden="true"></i>{{ 'wizard.compare_with_others'|trans({}, 'wizard') }}
        </a>
    </div>
</div>
{% endblock %}
