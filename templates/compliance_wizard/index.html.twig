{% extends 'base.html.twig' %}
{% trans_default_domain 'wizard' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block title %}{{ 'wizard.title'|trans({}, 'wizard') }} - {{ parent() }}{% endblock %}

{% block body %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{{ _fa_page_header.render({
    badge: { icon: 'compass', label: 'wizard.title'|trans({}, 'wizard') },
    title: 'wizard.title'|trans({}, 'wizard'),
    subtitle: 'wizard.subtitle'|trans({}, 'wizard'),
    actions: available_wizards|length > 1 ? [
        { label: 'wizard.compare_frameworks'|trans({}, 'wizard'), href: path('app_compliance_wizard_compare'), variant: 'ghost', icon: 'columns-gap' }
    ] : []
}) }}
<main class="fa-aurora-surface fa-aurora-surface--dots">
<div class="container-fluid py-4">

    {# Available Wizards #}
    {% if available_wizards|length > 0 %}
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="h5 mb-3">
                <i class="fa-icon fa-icon--status-ok me-2" aria-hidden="true"></i>{{ 'wizard.available_wizards'|trans({}, 'wizard') }}
            </h2>
        </div>
        {% for key, wizard in available_wizards %}
        <div class="col-md-6 col-lg-4 mb-4">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100 border-' ~ wizard.color ~ ' wizard-card' } %}
                {% block card_header %}
                    <div class="card-header bg-{{ wizard.color }} bg-opacity-10 border-{{ wizard.color }}">
                        <div class="d-flex align-items-center">
                            <i class="{{ wizard.icon }} fs-3 text-{{ wizard.color }} me-3"></i>
                            <div>
                                <h3 class="card-title h5 mb-0">{{ wizard.name }}</h3>
                                {% include '_components/_badge.html.twig' with { variant: wizard.color, content: wizard.code } %}
                            </div>
                        </div>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <p class="card-text text-muted">{{ wizard.description|trans({}, 'wizard') }}</p>

                    <div class="mb-3">
                        <small class="text-muted d-block mb-1">{{ 'wizard.required_modules'|trans({}, 'wizard') }}:</small>
                        {% for mod in wizard.required_modules %}
                            {% include '_components/_badge.html.twig' with { variant: 'success', icon: 'bi-check-circle', class: 'me-1', content: mod } %}
                        {% endfor %}
                    </div>

                    {% if wizard.recommended_modules|default([])|length > 0 %}
                    <div class="mb-3">
                        <small class="text-muted d-block mb-1">{{ 'wizard.recommended_modules'|trans({}, 'wizard') }}:</small>
                        {% for mod in wizard.recommended_modules %}
                            {% if mod in active_modules %}
                                {% include '_components/_badge.html.twig' with { variant: 'success', icon: 'bi-check-circle', class: 'me-1', content: mod } %}
                            {% else %}
                                {% include '_components/_badge.html.twig' with { variant: 'warning', icon: 'bi-exclamation-triangle', class: 'me-1', content: mod } %}
                            {% endif %}
                        {% endfor %}
                    </div>
                    {% endif %}

                    <div class="small text-muted">
                        <i class="fa-icon fa-icon--nav-list-check me-1" aria-hidden="true"></i>
                        {{ wizard.categories|length }} {{ 'wizard.categories_count'|trans({}, 'wizard') }}
                    </div>
                {% endblock %}
                {% block card_footer %}
                    <div class="card-footer bg-transparent border-{{ wizard.color }}">
                        <a href="{{ path('app_compliance_wizard_start', {wizard: key}) }}" class="btn btn-{{ wizard.color }} w-100">
                            <i class="bi bi-play-circle me-1" aria-hidden="true"></i>{{ 'wizard.start_wizard'|trans({}, 'wizard') }}
                        </a>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        {% endfor %}
    </div>
    {% endif %}

    {# Unavailable Wizards #}
    {% if unavailable_wizards|length > 0 %}
    <div class="row">
        <div class="col-12">
            <h2 class="h5 text-muted mb-3">
                <i class="fa-icon fa-icon--ui-lock text-secondary me-2" aria-hidden="true"></i>{{ 'wizard.unavailable_wizards'|trans({}, 'wizard') }}
            </h2>
            <p class="text-muted small mb-3">{{ 'wizard.unavailable_hint'|trans({}, 'wizard') }}</p>
        </div>
        {% for key, wizard in unavailable_wizards %}
        <div class="col-md-6 col-lg-4 mb-4">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100 border-secondary opacity-75' } %}
                {% block card_header %}
                    <div class="card-header bg-secondary bg-opacity-10">
                        <div class="d-flex align-items-center">
                            <i class="{{ wizard.icon }} fs-3 text-secondary me-3"></i>
                            <div>
                                <h3 class="card-title h5 mb-0 text-muted">{{ wizard.name }}</h3>
                                {% include '_components/_badge.html.twig' with { variant: 'secondary', content: wizard.code } %}
                            </div>
                        </div>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning', class: 'py-2 mb-3' } } %}
                        {% block alert_body %}
                            <small>
                                {{ 'wizard.missing_modules'|trans({}, 'wizard') }}:
                                {% for mod in wizard.missing_modules %}
                                    <strong>{{ mod }}</strong>{% if not loop.last %}, {% endif %}
                                {% endfor %}
                            </small>
                        {% endblock %}
                    {% endembed %}
                {% endblock %}
                {% block card_footer %}
                    <div class="card-footer bg-transparent">
                        <a href="{{ path('admin_modules_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm w-100">
                            <i class="fa-icon fa-icon--ui-settings me-1" aria-hidden="true"></i>{{ 'wizard.activate_modules'|trans({}, 'wizard') }}
                        </a>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        {% endfor %}
    </div>
    {% endif %}

    {# Info Section #}
    <div class="row mt-4">
        <div class="col-12">
            {% embed '_components/_card.html.twig' with { 'class': 'bg-body-secondary border-0' } %}
                {% block card_body %}
                    <h4 class="h6 mb-3">
                        <i class="fa-icon fa-icon--ui-info text-info me-2" aria-hidden="true"></i>{{ 'wizard.how_it_works'|trans({}, 'wizard') }}
                    </h4>
                    <div class="row">
                        <div class="col-md-4 mb-3 mb-md-0">
                            <div class="d-flex">
                                <div class="badge bg-primary rounded-circle me-2" style="width: 24px; height: 24px; line-height: 16px;">1</div>
                                <div>
                                    <strong>{{ 'wizard.step1_title'|trans({}, 'wizard') }}</strong>
                                    <p class="small text-muted mb-0">{{ 'wizard.step1_desc'|trans({}, 'wizard') }}</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3 mb-md-0">
                            <div class="d-flex">
                                <div class="badge bg-primary rounded-circle me-2" style="width: 24px; height: 24px; line-height: 16px;">2</div>
                                <div>
                                    <strong>{{ 'wizard.step2_title'|trans({}, 'wizard') }}</strong>
                                    <p class="small text-muted mb-0">{{ 'wizard.step2_desc'|trans({}, 'wizard') }}</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="d-flex">
                                <div class="badge bg-primary rounded-circle me-2" style="width: 24px; height: 24px; line-height: 16px;">3</div>
                                <div>
                                    <strong>{{ 'wizard.step3_title'|trans({}, 'wizard') }}</strong>
                                    <p class="small text-muted mb-0">{{ 'wizard.step3_desc'|trans({}, 'wizard') }}</p>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>
</div>
</main>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.wizard-card {
    transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
}
.wizard-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
}
</style>
{% endblock %}
