{% extends 'base.html.twig' %}
{% trans_default_domain 'wizard' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_section.html.twig' as _fa_section %}
{% import '_components/_fa_alva_hint.html.twig' as _fa_alva_hint %}

{% block title %}{{ config.name }} - {{ 'wizard.title'|trans }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {# Aurora Breadcrumb #}
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'wizard.title'|trans({}, 'wizard'), url: path('app_compliance_wizard_index') },
            { label: config.name }
        ]
    } %}

    {# Aurora Page Header #}
    {{ _fa_page_header.render({
        title: config.name,
        subtitle: config.description|trans,
        badge: { icon: 'shield-check', label: config.code },
        actions: [
            { label: 'wizard.back'|trans({}, 'wizard'), href: path('app_compliance_wizard_index'), variant: 'ghost', icon: 'arrow-left' },
            { label: 'wizard.run_assessment'|trans({}, 'wizard'), href: path('app_compliance_wizard_assess', {wizard: wizard}), variant: 'primary', icon: 'play-fill' }
        ]
    }) }}
{% set _global_hints = alva_hints('compliance_wizard_start') %}
{% if _global_hints|length > 0 %}
    {% for _h in _global_hints %}
        {{ _fa_alva_hint.render(_h) }}
    {% endfor %}
{% endif %}


    <div class="row">
        <div class="col-lg-8">
            {# Wizard scope/categories overview #}
            {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
                {% block card_body %}
                    <h2 class="h5 mb-3">{{ 'wizard.assessment_scope'|trans }}</h2>
                    <p class="text-muted">{{ 'wizard.assessment_scope_desc'|trans({'%framework%': config.name}, 'wizard') }}</p>

                    {# Categories Overview #}
                    <div class="row mt-4">
                        {% for key, category in config.categories %}
                        <div class="col-md-6 col-lg-4 mb-3">
                            <div class="d-flex align-items-start">
                                <i class="{{ category.icon|default('fa-icon--status-ok') }} text-{{ config.color }} me-2 mt-1"></i>
                                <div>
                                    <strong>{{ category.name|trans }}</strong>
                                    {% if category.clause is defined %}
                                        {% include '_components/_badge.html.twig' with { variant: 'secondary', class: 'ms-1', content: category.clause } %}
                                    {% elseif category.article is defined %}
                                        {% include '_components/_badge.html.twig' with { variant: 'secondary', class: 'ms-1', content: 'Art. ' ~ category.article } %}
                                    {% endif %}
                                    <br>
                                    <small class="text-muted">{{ category.checks|length }} {{ 'wizard.checks'|trans }}</small>
                                </div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                {% endblock %}
            {% endembed %}

            {# Alva-fairy: shipped YAML mapping libraries available, no DB mappings yet (Data-Reuse) #}
            {% if inheritance_source_frameworks|default([])|length == 0 and available_mapping_libraries|default([])|length > 0 %}
            {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info' } } %}
                {% block alert_body %}
                    <div class="fa-alert__title">{{ 'wizard.mapping_library.fairy_title'|trans({}, 'wizard') }}</div>
                    <p class="mb-2">
                        {{ 'wizard.mapping_library.fairy_desc'|trans({
                            '%count%': available_mapping_libraries|length,
                            '%target%': config.name
                        }, 'wizard') }}
                    </p>
                    <ul class="mb-2 list-unstyled">
                        {% for lib in available_mapping_libraries %}
                            <li class="mb-2">
                                <form method="post" action="{{ path('app_compliance_wizard_import_mapping_library', {wizard: wizard}) }}" class="d-flex flex-wrap align-items-center gap-2">
                                    <input type="hidden" name="_token" value="{{ csrf_token('mapping-lib-' ~ config.code) }}">
                                    <input type="hidden" name="path" value="{{ lib.path }}">
                                    <span>
                                        <strong>{{ lib.source_framework_name ?? lib.source_framework }}</strong>
                                        <span class="text-muted">— {{ 'wizard.mapping_library.mapping_count'|trans({'%count%': lib.mapping_count}, 'wizard') }}</span>
                                    </span>
                                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--info fa-cyber-btn--sm ms-auto">
                                        <i class="fa-icon fa-icon--ui-arrow-right" aria-hidden="true"></i>
                                        {{ 'wizard.mapping_library.import'|trans({}, 'wizard') }}
                                    </button>
                                </form>
                            </li>
                        {% endfor %}
                    </ul>
                    <p class="small text-muted mb-0">{{ 'wizard.mapping_library.fairy_hint'|trans({}, 'wizard') }}</p>
                {% endblock %}
            {% endembed %}
            {% endif %}

            {# On-demand data takeover from already-mapped frameworks (Data-Reuse) #}
            {% if inheritance_source_frameworks|default([])|length > 0 %}
            {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info' } } %}
                {% block alert_body %}
                    <div class="fa-alert__title">{{ 'wizard.inheritance.title'|trans({}, 'wizard') }}</div>
                    <p class="mb-2">
                        {{ 'wizard.inheritance.desc'|trans({
                            '%count%': inheritance_source_frameworks|length,
                            '%target%': config.name
                        }, 'wizard') }}
                    </p>
                    <ul class="mb-2">
                        {% for source_framework in inheritance_source_frameworks %}
                            <li><strong>{{ source_framework.name }}</strong></li>
                        {% endfor %}
                    </ul>
                    <p class="small text-muted mb-2">{{ 'wizard.inheritance.hint'|trans({}, 'wizard') }}</p>
                    <form method="post" action="{{ path('app_compliance_inheritance_activate', {frameworkCode: config.code}) }}" class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('inherit-' ~ config.code) }}">
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--info fa-cyber-btn--sm">
                            <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                            {{ 'wizard.inheritance.activate'|trans({}, 'wizard') }}
                        </button>
                    </form>
                {% endblock %}
            {% endembed %}
            {% endif %}

            {# Missing Recommended Modules Warning #}
            {% if missing_recommended|length > 0 %}
            {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning' } } %}
                {% block alert_body %}
                    <div class="fa-alert__title">{{ 'wizard.missing_recommended_title'|trans }}</div>
                    <p class="mb-2">{{ 'wizard.missing_recommended_desc'|trans }}</p>
                    <ul class="mb-0">
                        {% for mod in missing_recommended %}
                        <li><strong>{{ mod }}</strong></li>
                        {% endfor %}
                    </ul>
                    <hr>
                    <a href="{{ path('admin_modules_index') }}" class="fa-cyber-btn fa-cyber-btn--warning fa-cyber-btn--sm">
                        <i class="fa-icon fa-icon--ui-settings" aria-hidden="true"></i>{{ 'wizard.activate_modules'|trans }}
                    </a>
                {% endblock %}
            {% endembed %}
            {% endif %}

            {# Start Button (duplicate of header CTA for accessibility / scroll convenience) #}
            <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                <a href="{{ path('app_compliance_wizard_assess', {wizard: wizard}) }}" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--lg">
                    <i class="fa-icon fa-icon--status-info" aria-hidden="true"></i>{{ 'wizard.run_assessment'|trans }}
                </a>
            </div>
        </div>

        {# Sidebar #}
        <div class="col-lg-4">
            {# Active Modules #}
            {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
                {% block card_header %}
                    <div class="card-header">
                        <h3 class="card-title h6 mb-0">
                            <i class="fa-icon me-2 fa-icon--nav-puzzle" aria-hidden="true"></i>{{ 'wizard.active_modules'|trans }}
                        </h3>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <p class="small text-muted mb-3">{{ 'wizard.data_sources_info'|trans }}</p>
                    {% for mod in active_modules %}
                        {% include '_components/_badge.html.twig' with { variant: 'success', class: 'me-1 mb-1', icon: 'bi-check-circle', content: mod } %}
                    {% endfor %}
                {% endblock %}
            {% endembed %}

            {# What to expect #}
            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header">
                        <h3 class="card-title h6 mb-0">
                            <i class="fa-icon fa-icon--ui-lightbulb me-2" aria-hidden="true"></i>{{ 'wizard.what_to_expect'|trans }}
                        </h3>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">
                            <i class="fa-icon fa-icon--ui-clock me-2" aria-hidden="true"></i>
                            <span class="small">{{ 'wizard.duration_hint'|trans }}</span>
                        </li>
                        <li class="mb-2">
                            <i class="fa-icon fa-icon--nav-bar-chart me-2" aria-hidden="true"></i>
                            <span class="small">{{ 'wizard.score_hint'|trans }}</span>
                        </li>
                        <li class="mb-2">
                            <i class="fa-icon fa-icon--ui-flag me-2" aria-hidden="true"></i>
                            <span class="small">{{ 'wizard.gap_hint'|trans }}</span>
                        </li>
                        <li>
                            <i class="fa-icon fa-icon--nav-file-pdf me-2" aria-hidden="true"></i>
                            <span class="small">{{ 'wizard.export_hint'|trans }}</span>
                        </li>
                    </ul>
                {% endblock %}
            {% endembed %}
        </div>
    </div>
</div>
{% endblock %}
