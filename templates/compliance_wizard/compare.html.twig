{% extends 'base.html.twig' %}
{% trans_default_domain 'wizard' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% block title %}{{ 'wizard.compare_title'|trans({}, 'wizard') }} - {{ 'wizard.title'|trans({}, 'wizard') }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {# Aurora Breadcrumb #}
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'wizard.title'|trans({}, 'wizard'), url: path('app_compliance_wizard_index') },
            { label: 'wizard.compare_title'|trans({}, 'wizard') }
        ]
    } %}

    {# Aurora Page Header #}
    {{ _fa_page_header.render({
        title: 'wizard.compare_title'|trans({}, 'wizard'),
        subtitle: 'wizard.compare_subtitle'|trans({}, 'wizard'),
        badge: { icon: 'columns-gap', label: 'wizard.title'|trans({}, 'wizard') },
        actions: [
            { label: 'wizard.back'|trans({}, 'wizard'), href: path('app_compliance_wizard_index'), variant: 'ghost', icon: 'arrow-left' }
        ]
    }) }}

    {# Framework Selection #}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
        {% block card_body %}
            <form method="get" action="{{ path('app_compliance_wizard_compare') }}" class="row g-3 align-items-end">
                <div class="col-auto">
                    <label class="form-label">{{ 'wizard.select_frameworks'|trans({}, 'wizard') }}:</label>
                </div>
                {% for key, wizard in available_wizards %}
                <div class="col-auto">
                    <div class="form-check form-check-inline">
                        <input type="checkbox"
                               class="form-check-input"
                               name="wizards[]"
                               value="{{ key }}"
                               id="wizard_{{ key }}"
                               {% if key in selected_wizards %}checked{% endif %}>
                        <label class="form-check-label" for="wizard_{{ key }}">
                            <i class="{{ wizard.icon }} text-{{ wizard.color }} me-1"></i>{{ wizard.code }}
                        </label>
                    </div>
                </div>
                {% endfor %}
                <div class="col-auto">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                        <i class="fa-icon fa-icon--nav-workflow me-1" aria-hidden="true"></i>{{ 'wizard.update_comparison'|trans({}, 'wizard') }}
                    </button>
                </div>
            </form>
        {% endblock %}
    {% endembed %}

    {% if results|length > 0 %}
    {# Comparison Overview #}
    <div class="row mb-4">
        {% for key, result in results %}
        <div class="col-md-{{ 12 // results|length }} mb-3">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100 border-' ~ available_wizards[key].color|default('secondary') } %}
                {% block card_header %}
                    <div class="card-header bg-{{ available_wizards[key].color|default('secondary') }} bg-opacity-10 text-center">
                        <h3 class="h5 mb-0">
                            <i class="{{ available_wizards[key].icon|default('fa-icon--status-ok') }} me-2"></i>
                            {{ result.framework_name }}
                        </h3>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="text-center">
                        <div class="display-3 fw-bold
                            {% if result.overall_score >= 80 %}text-success
                            {% elseif result.overall_score >= 60 %}text-warning
                            {% else %}text-danger{% endif %}">
                            {{ result.overall_score }}%
                        </div>
                        {% set status_variant = {
                            'compliant': 'success',
                            'partial': 'warning',
                            'in_progress': 'info'
                        }[result.status]|default('danger') %}
                        {% include '_components/_badge.html.twig' with { variant: status_variant, content: ('wizard.status.' ~ result.status)|trans({}, 'wizard') } %}
                        <div class="mt-3">
                            <small class="text-muted">
                                <i class="fa-icon fa-icon--ui-flag text-danger me-1" aria-hidden="true"></i>
                                {{ result.critical_gap_count }} {{ 'wizard.critical_gaps'|trans({}, 'wizard') }}
                            </small>
                        </div>
                    </div>
                {% endblock %}
                {% block card_footer %}
                    <div class="card-footer bg-transparent text-center">
                        <a href="{{ path('app_compliance_wizard_assess', {wizard: key}) }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                            {{ 'wizard.view_details'|trans({}, 'wizard') }}
                        </a>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        {% endfor %}
    </div>

    {# Category Comparison Table #}
    {% embed '_components/_card.html.twig' with { 'noPadding': true } %}
        {% block card_header %}
            <div class="card-header">
                <h2 class="card-title h5 mb-0">{{ 'wizard.category_comparison'|trans({}, 'wizard') }}</h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% embed '_components/_fa_table.html.twig' %}
                {% block table_head %}
                    <tr>
                        <th scope="col" class="fa-table__th">{{ 'wizard.category'|trans({}, 'wizard') }}</th>
                        {% for key, result in results %}
                        <th scope="col" class="fa-table__th fa-table__th--center" style="min-width: 120px;">
                            {% include '_components/_badge.html.twig' with { variant: available_wizards[key].color|default('secondary'), content: result.framework } %}
                        </th>
                        {% endfor %}
                    </tr>
                {% endblock %}
                {% block table_body %}
    {% import '_components/_fa_progress.html.twig' as _fa_progress %}
                    {# Collect all unique categories #}
                    {% set all_categories = {} %}
                    {% for key, result in results %}
                        {% for cat_key, cat in result.categories %}
                            {% set all_categories = all_categories|merge({(cat_key): cat.name}) %}
                        {% endfor %}
                    {% endfor %}

                    {% for cat_key, cat_name in all_categories %}
                    <tr class="fa-table__row">
                        <td class="fa-table__cell"><strong>{{ cat_name|trans({}, 'wizard') }}</strong></td>
                        {% for key, result in results %}
                        <td class="fa-table__cell fa-table__cell--center">
                            {% if result.categories[cat_key] is defined %}
                                {% set score = result.categories[cat_key].score %}
                                <div class="d-flex align-items-center justify-content-center">
                                    {{ _fa_progress.render({ value: score, tone: score >= 80 ? 'success' : (score >= 60 ? 'warning' : 'danger'), size: 'sm', class: 'me-2' }) }}
                                    <span class="{% if score >= 80 %}text-success{% elseif score >= 60 %}text-warning{% else %}text-danger{% endif %} fw-semibold">{{ score }}%</span>
                                </div>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        {% endfor %}
                    </tr>
                    {% endfor %}
                {% endblock %}
                {% block table_foot %}
                    <tr>
                        <th scope="col" class="fa-table__cell">{{ 'wizard.overall'|trans({}, 'wizard') }}</th>
                        {% for key, result in results %}
                        <th scope="col" class="fa-table__cell fa-table__cell--center">
                            <span class="fs-5 fw-bold {% if result.overall_score >= 80 %}text-success{% elseif result.overall_score >= 60 %}text-warning{% else %}text-danger{% endif %}">
                                {{ result.overall_score }}%
                            </span>
                        </th>
                        {% endfor %}
                    </tr>
                {% endblock %}
            {% endembed %}
        {% endblock %}
    {% endembed %}

    {# Cross-Framework Insights #}
    {% embed '_components/_card.html.twig' with { 'class': 'mt-4' } %}
        {% block card_header %}
            <div class="card-header">
                <h2 class="card-title h5 mb-0">
                    <i class="fa-icon fa-icon--ui-lightbulb me-2" aria-hidden="true"></i>{{ 'wizard.insights'|trans({}, 'wizard') }}
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {# Calculate average and best/worst #}
            {% set total_score = 0 %}
            {% set best_score = 0 %}
            {% set worst_score = 100 %}
            {% set best_framework = '' %}
            {% set worst_framework = '' %}

            {% for key, result in results %}
                {% set total_score = total_score + result.overall_score %}
                {% if result.overall_score > best_score %}
                    {% set best_score = result.overall_score %}
                    {% set best_framework = result.framework_name %}
                {% endif %}
                {% if result.overall_score < worst_score %}
                    {% set worst_score = result.overall_score %}
                    {% set worst_framework = result.framework_name %}
                {% endif %}
            {% endfor %}

            {% set avg_score = (total_score / results|length)|round %}

            <div class="row">
                <div class="col-md-4 text-center mb-3">
                    <div class="display-5 fw-bold text-primary">{{ avg_score }}%</div>
                    <p class="text-muted mb-0">{{ 'wizard.average_compliance'|trans({}, 'wizard') }}</p>
                </div>
                <div class="col-md-4 text-center mb-3">
                    <div class="display-5 fw-bold text-success">{{ best_score }}%</div>
                    <p class="text-muted mb-0">{{ 'wizard.best_framework'|trans({}, 'wizard') }}: {{ best_framework }}</p>
                </div>
                <div class="col-md-4 text-center mb-3">
                    <div class="display-5 fw-bold text-danger">{{ worst_score }}%</div>
                    <p class="text-muted mb-0">{{ 'wizard.needs_attention'|trans({}, 'wizard') }}: {{ worst_framework }}</p>
                </div>
            </div>

            <hr>

            <h3 class="h6">{{ 'wizard.recommendations'|trans({}, 'wizard') }}</h3>
            <ul>
                {% if worst_score < 60 %}
                <li>{{ 'wizard.rec_priority_framework'|trans({'%framework%': worst_framework}, 'wizard') }}</li>
                {% endif %}
                {% if avg_score < 80 %}
                <li>{{ 'wizard.rec_improve_controls'|trans({}, 'wizard') }}</li>
                {% endif %}
                <li>{{ 'wizard.rec_regular_assessment'|trans({}, 'wizard') }}</li>
            </ul>
        {% endblock %}
    {% endembed %}
    {% else %}
    {{ _fa_alert.render({ variant: 'info', body: 'wizard.select_frameworks_hint'|trans({}, 'wizard') }) }}
    {% endif %}

    {# Navigation #}
    <div class="d-flex justify-content-between mt-4">
        <a href="{{ path('app_compliance_wizard_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
            <i class="fa-icon fa-icon--util-arrow-left me-1" aria-hidden="true"></i>{{ 'wizard.back_to_wizards'|trans({}, 'wizard') }}
        </a>
    </div>
</div>
{% endblock %}
