{% trans_default_domain 'mris' %}
{#
  MRIS-Audit-Report (PDF)

  Print-optimiert, A4, schwarz auf weiß. Selbstständiges Template (kein
  Extends), damit DomPDF stabil rendert. Keine _fa_alert/_fa_empty_state
  Macros (Embed-Issues mit DomPDF).

  Quelle Fachkonzept (CC BY 4.0):
    Peddi, R. (2026). MRIS — Mythos-resistente Informationssicherheit, v1.5.
#}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
    <title>{{ 'mris.audit_report.title'|trans({}, 'mris') }} — {{ tenant_name }}</title>
    <style>
        :root {
            --primary:       var(--primary);
            --surface:       var(--surface);
            --surface-2:     var(--surface-2);
            --fg:            #0f172a;
            --fg-2:          var(--fg-2);
            --fg-3:          var(--fg-3);
            --border:        var(--border);
            --success:       var(--success);
            --success-tint:  var(--success-tint);
            --danger:        var(--danger);
            --danger-tint:   var(--danger-tint);
            --warning:       var(--warning);
            --warning-tint:  var(--warning-tint);
            --info-tint:     var(--info-tint);
            --info-text:     var(--info-text);
        }

        @page {
            size: A4 portrait;
            margin: 2.2cm 1.8cm 2.6cm 1.8cm;
            @bottom-left {
                content: "{{ 'mris.audit_report.title'|trans({}, 'mris') }} · {{ tenant_name }}";
                font-family: DejaVu Sans, sans-serif;
                font-size: 7pt;
                color: var(--fg);
            }
            @bottom-center {
                content: "{{ 'mris.audit_report.footer_source'|trans({}, 'mris') }}: {{ source_label }}";
                font-family: DejaVu Sans, sans-serif;
                font-size: 7pt;
                color: var(--fg);
            }
            @bottom-right {
                content: "Seite " counter(page) " / " counter(pages);
                font-family: DejaVu Sans, sans-serif;
                font-size: 7pt;
                color: var(--fg);
            }
        }

        * { box-sizing: border-box; }

        body {
            font-family: DejaVu Sans, sans-serif;
            font-size: 9.5pt;
            line-height: 1.4;
            color: var(--fg);
            background: var(--surface);
            margin: 0;
            padding: 0;
        }

        h1 {
            font-size: 18pt;
            margin: 0 0 6pt 0;
            border-bottom: 2pt solid var(--fg);
            padding-bottom: 4pt;
        }

        h2 {
            font-size: 12pt;
            margin: 14pt 0 6pt 0;
            padding: 2pt 0 2pt 6pt;
            border-left: 3pt solid var(--fg);
            background: var(--surface-2);
            page-break-after: avoid;
        }

        h3 {
            font-size: 10pt;
            margin: 10pt 0 4pt 0;
            page-break-after: avoid;
        }

        p { margin: 0 0 6pt 0; }

        .meta {
            border: 1pt solid var(--fg);
            padding: 8pt;
            margin-bottom: 14pt;
            font-size: 9pt;
        }

        .meta-row { display: table; width: 100%; }
        .meta-cell { display: table-cell; padding: 2pt 8pt 2pt 0; vertical-align: top; }
        .meta-label { font-weight: bold; width: 28%; }

        .disclaimer {
            border: 1pt solid var(--fg);
            background: var(--surface-2);
            padding: 6pt 8pt;
            font-size: 8.5pt;
            margin: 8pt 0 12pt 0;
        }

        .disclaimer strong { text-transform: uppercase; }

        table {
            width: 100%;
            border-collapse: collapse;
            margin: 4pt 0 10pt 0;
            font-size: 9pt;
            page-break-inside: auto;
        }

        thead { display: table-header-group; }
        tr { page-break-inside: avoid; }

        th, td {
            border: 0.5pt solid var(--fg);
            padding: 4pt 6pt;
            text-align: left;
            vertical-align: top;
        }

        th {
            background: var(--fg);
            color: var(--surface);
            font-weight: bold;
            font-size: 8.5pt;
            text-transform: uppercase;
            letter-spacing: 0.3pt;
        }

        tbody tr:nth-child(even) td { background: var(--surface-2); }

        .num { text-align: right; font-variant-numeric: tabular-nums; }

        .score-row { display: table; width: 100%; margin-bottom: 8pt; }
        .score-cell-left {
            display: table-cell;
            width: 26%;
            vertical-align: middle;
            text-align: center;
            border: 1pt solid var(--fg);
            padding: 12pt 8pt;
        }
        .score-cell-right {
            display: table-cell;
            vertical-align: top;
            padding-left: 12pt;
        }
        .score-value {
            font-size: 36pt;
            font-weight: bold;
            line-height: 1;
        }
        .score-label {
            font-size: 8pt;
            text-transform: uppercase;
            letter-spacing: 0.3pt;
            margin-top: 4pt;
        }

        .badge {
            display: inline-block;
            padding: 1pt 5pt;
            border: 0.5pt solid var(--fg);
            font-size: 8pt;
            font-weight: bold;
            text-transform: uppercase;
        }
        .badge-inv { background: var(--fg); color: var(--surface); }

        .small { font-size: 8pt; }
        .muted { color: var(--fg-2); }
        .nowrap { white-space: nowrap; }

        .signature {
            margin-top: 18pt;
            border: 1pt solid var(--fg);
            padding: 10pt 12pt;
            page-break-inside: avoid;
        }
        .signature-line {
            margin-top: 16pt;
            border-top: 0.5pt solid var(--fg);
            padding-top: 4pt;
            font-size: 8pt;
        }

        .footer-source {
            margin-top: 14pt;
            font-size: 8pt;
            text-align: center;
            border-top: 0.5pt solid var(--fg);
            padding-top: 4pt;
        }

        .sparkline { display: inline-block; vertical-align: middle; }

        .pagebreak { page-break-before: always; }
    </style>
</head>
<body>

{# === Cover / Meta ============================================== #}
<h1>{{ 'mris.audit_report.title'|trans({}, 'mris') }}</h1>
<p class="small muted">
    {{ 'mris.audit_report.subtitle'|trans({}, 'mris') }}
</p>

<div class="meta">
    <div class="meta-row">
        <div class="meta-cell meta-label">{{ 'mris.audit_report.meta.tenant'|trans({}, 'mris') }}:</div>
        <div class="meta-cell">{{ tenant_name }}</div>
    </div>
    <div class="meta-row">
        <div class="meta-cell meta-label">{{ 'mris.audit_report.meta.created_at'|trans({}, 'mris') }}:</div>
        <div class="meta-cell">{{ generated_at|date('d.m.Y H:i') }} {{ 'mris.audit_report.meta.local'|trans({}, 'mris') }}</div>
    </div>
    <div class="meta-row">
        <div class="meta-cell meta-label">{{ 'mris.audit_report.meta.created_by'|trans({}, 'mris') }}:</div>
        <div class="meta-cell">{{ generated_by }}</div>
    </div>
    <div class="meta-row">
        <div class="meta-cell meta-label">{{ 'mris.audit_report.meta.report_type'|trans({}, 'mris') }}:</div>
        <div class="meta-cell">{{ 'mris.audit_report.meta.report_type_value'|trans({}, 'mris') }}</div>
    </div>
    <div class="meta-row">
        <div class="meta-cell meta-label">{{ 'mris.audit_report.meta.source_cc'|trans({}, 'mris') }}:</div>
        <div class="meta-cell">{{ source_label }}</div>
    </div>
</div>

{# === Section 1: MRI Score + Decomposition ===================== #}
<h2>{{ 'mris.audit_report.section_1'|trans({}, 'mris') }}</h2>

<div class="disclaimer">
    <strong>{{ 'mris.audit_report.disclaimer_label'|trans({}, 'mris') }}:</strong>
    {{ score.disclaimer }}
</div>

<div class="score-row">
    <div class="score-cell-left">
        <div class="score-value">{{ score.score }}</div>
        <div class="score-label">{{ 'mris.audit_report.score_label'|trans({}, 'mris') }}</div>
    </div>
    <div class="score-cell-right">
        <table>
            <thead>
                <tr>
                    <th style="width: 26%;">{{ 'mris.audit_report.breakdown_col.dimension'|trans({}, 'mris') }}</th>
                    <th style="width: 32%;">{{ 'mris.audit_report.breakdown_col.source'|trans({}, 'mris') }}</th>
                    <th class="num" style="width: 14%;">{{ 'mris.audit_report.breakdown_col.value'|trans({}, 'mris') }}</th>
                    <th class="num" style="width: 14%;">{{ 'mris.audit_report.breakdown_col.weight'|trans({}, 'mris') }}</th>
                    <th class="num" style="width: 14%;">{{ 'mris.audit_report.breakdown_col.contribution'|trans({}, 'mris') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for key, dim in score.breakdown %}
                    <tr>
                        <td><strong>{{ key }}</strong></td>
                        <td class="small">{{ dim.source }}</td>
                        <td class="num">{{ dim.value }}</td>
                        <td class="num">{{ dim.weight }} %</td>
                        <td class="num"><strong>{{ dim.contribution }}</strong></td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# === Section 2: 4-Kategorien-Verteilung ======================= #}
<h2>{{ 'mris.audit_report.section_2'|trans({}, 'mris') }}</h2>
<p class="small muted">
    {{ 'mris.audit_report.section_2_intro'|trans({}, 'mris') }}
</p>

<table>
    <thead>
        <tr>
            <th style="width: 50%;">{{ 'mris.audit_report.section_col.category'|trans({}, 'mris') }}</th>
            <th class="num" style="width: 25%;">{{ 'mris.audit_report.section_col.count'|trans({}, 'mris') }}</th>
            <th class="num" style="width: 25%;">{{ 'mris.audit_report.section_col.share'|trans({}, 'mris') }}</th>
        </tr>
    </thead>
    <tbody>
        {% for row in category_distribution.rows %}
            <tr>
                <td>{{ row.label }}</td>
                <td class="num">{{ row.count }}</td>
                <td class="num">{{ row.share }} %</td>
            </tr>
        {% endfor %}
        <tr>
            <td><strong>{{ 'mris.audit_report.section_col.total'|trans({}, 'mris') }}</strong></td>
            <td class="num"><strong>{{ category_distribution.total }}</strong></td>
            <td class="num"><strong>100,0 %</strong></td>
        </tr>
    </tbody>
</table>

{# === Section 3: Reine-Reibung-Controls ======================== #}
<h2>{{ 'mris.audit_report.section_3'|trans({}, 'mris') }}</h2>
<p class="small muted">
    {{ 'mris.audit_report.section_3_intro'|trans({}, 'mris') }}
</p>

{% if friction_controls is empty %}
    <p class="small"><em>{{ 'mris.audit_report.section_3_empty'|trans({}, 'mris') }}</em></p>
{% else %}
    <table>
        <thead>
            <tr>
                <th style="width: 14%;">{{ 'mris.audit_report.friction_col.control_id'|trans({}, 'mris') }}</th>
                <th style="width: 38%;">{{ 'mris.audit_report.friction_col.name'|trans({}, 'mris') }}</th>
                <th style="width: 12%;">{{ 'mris.audit_report.friction_col.category'|trans({}, 'mris') }}</th>
                <th style="width: 36%;">{{ 'mris.audit_report.friction_col.flanking_mhcs'|trans({}, 'mris') }}</th>
            </tr>
        </thead>
        <tbody>
            {% for fc in friction_controls %}
                <tr>
                    <td class="nowrap"><strong>{{ fc.control_id }}</strong></td>
                    <td>{{ fc.name }}</td>
                    <td class="small">{{ fc.category }}</td>
                    <td class="small">
                        {% if fc.flanking is empty %}
                            <em class="muted">{{ 'mris.audit_report.friction_col.none'|trans({}, 'mris') }}</em>
                        {% else %}
                            {% for mhc in fc.flanking %}
                                <span class="badge">{{ mhc }}</span>{% if not loop.last %} {% endif %}
                            {% endfor %}
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endif %}

{# === Section 4: Reifegrad-Statusübersicht aller MHCs ========== #}
<h2>{{ 'mris.audit_report.section_4'|trans({}, 'mris') }}</h2>
<p class="small muted">
    {{ 'mris.audit_report.section_4_intro'|trans({}, 'mris') }}
</p>

{% if maturity_rows is empty %}
    <p class="small"><em>{{ 'mris.audit_report.section_4_empty'|trans({}, 'mris') }}</em></p>
{% else %}
    <table>
        <thead>
            <tr>
                <th style="width: 10%;">{{ 'mris.audit_report.maturity_col.mhc'|trans({}, 'mris') }}</th>
                <th style="width: 46%;">{{ 'mris.audit_report.maturity_col.title'|trans({}, 'mris') }}</th>
                <th style="width: 14%;">{{ 'mris.audit_report.maturity_col.target'|trans({}, 'mris') }}</th>
                <th style="width: 14%;">{{ 'mris.audit_report.maturity_col.actual'|trans({}, 'mris') }}</th>
                <th class="num" style="width: 8%;">{{ 'mris.audit_report.maturity_col.delta'|trans({}, 'mris') }}</th>
                <th style="width: 8%;">{{ 'mris.audit_report.maturity_col.status'|trans({}, 'mris') }}</th>
            </tr>
        </thead>
        <tbody>
            {% for row in maturity_rows %}
                <tr>
                    <td class="nowrap"><strong>{{ row.mhc }}</strong></td>
                    <td class="small">{{ row.title }}</td>
                    <td class="small">{{ row.target ?? '—' }}</td>
                    <td class="small">{{ row.current ?? '—' }}</td>
                    <td class="num">
                        {% if row.delta is null %}
                            —
                        {% else %}
                            {{ row.delta > 0 ? '+' : '' }}{{ row.delta }}
                        {% endif %}
                    </td>
                    <td class="small">
                        {% if row.gap_status == 'gap' %}
                            <span class="badge badge-inv">{{ 'mris.audit_report.maturity_col.gap'|trans({}, 'mris') }}</span>
                        {% elseif row.gap_status == 'on_target' %}
                            <span class="badge">{{ 'mris.audit_report.maturity_col.on_target'|trans({}, 'mris') }}</span>
                        {% elseif row.gap_status == 'exceeded' %}
                            <span class="badge">{{ 'mris.audit_report.maturity_col.exceeded'|trans({}, 'mris') }}</span>
                        {% else %}
                            <span class="badge muted">{{ 'mris.audit_report.maturity_col.unset'|trans({}, 'mris') }}</span>
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endif %}

{# === Section 5: AI-Agent-Inventar ============================ #}
<h2>{{ 'mris.audit_report.section_5'|trans({}, 'mris') }}</h2>
<p class="small muted">
    {{ 'mris.audit_report.section_5_intro'|trans({}, 'mris') }}
</p>

<table>
    <thead>
        <tr>
            <th style="width: 60%;">{{ 'mris.audit_report.ai_col.metric'|trans({}, 'mris') }}</th>
            <th class="num" style="width: 40%;">{{ 'mris.audit_report.ai_col.value'|trans({}, 'mris') }}</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>{{ 'mris.audit_report.ai_col.total'|trans({}, 'mris') }}</td>
            <td class="num">{{ ai_inventory.total }}</td>
        </tr>
        <tr>
            <td>{{ 'mris.audit_report.ai_col.prohibited'|trans({}, 'mris') }}</td>
            <td class="num">{{ ai_inventory.by_classification.prohibited|default(0) }}</td>
        </tr>
        <tr>
            <td>{{ 'mris.audit_report.ai_col.high_risk'|trans({}, 'mris') }}</td>
            <td class="num">{{ ai_inventory.by_classification.high_risk|default(0) }}</td>
        </tr>
        <tr>
            <td>{{ 'mris.audit_report.ai_col.limited_risk'|trans({}, 'mris') }}</td>
            <td class="num">{{ ai_inventory.by_classification.limited_risk|default(0) }}</td>
        </tr>
        <tr>
            <td>{{ 'mris.audit_report.ai_col.minimal_risk'|trans({}, 'mris') }}</td>
            <td class="num">{{ ai_inventory.by_classification.minimal_risk|default(0) }}</td>
        </tr>
        <tr>
            <td>{{ 'mris.audit_report.ai_col.unclassified'|trans({}, 'mris') }}</td>
            <td class="num">{{ ai_inventory.unclassified }}</td>
        </tr>
        <tr>
            <td><strong>{{ 'mris.audit_report.ai_col.avg_completeness'|trans({}, 'mris') }}</strong></td>
            <td class="num"><strong>{{ ai_inventory.avg_completeness }} %</strong></td>
        </tr>
    </tbody>
</table>

{# === Section 6: 8 MRIS-KPIs ================================== #}
<h2 class="pagebreak">{{ 'mris.audit_report.section_6'|trans({}, 'mris') }}</h2>
<p class="small muted">
    {{ 'mris.audit_report.section_6_intro'|trans({}, 'mris') }}
</p>

<table>
    <thead>
        <tr>
            <th style="width: 8%;">{{ 'mris.audit_report.kpi_col.mhc'|trans({}, 'mris') }}</th>
            <th style="width: 30%;">{{ 'mris.audit_report.kpi_col.metric'|trans({}, 'mris') }}</th>
            <th class="num" style="width: 12%;">{{ 'mris.audit_report.kpi_col.value'|trans({}, 'mris') }}</th>
            <th style="width: 6%;">{{ 'mris.audit_report.kpi_col.unit'|trans({}, 'mris') }}</th>
            <th style="width: 8%;">{{ 'mris.audit_report.kpi_col.type'|trans({}, 'mris') }}</th>
            <th style="width: 16%;">{{ 'mris.audit_report.kpi_col.trend'|trans({}, 'mris') }}</th>
            <th style="width: 20%;">{{ 'mris.audit_report.kpi_col.source'|trans({}, 'mris') }}</th>
        </tr>
    </thead>
    <tbody>
        {% for kpi in kpis %}
            {% set sparkKey = spark_kpi_ids[kpi.id]|default(null) %}
            {% set sparkVals = (sparkKey and trends[sparkKey] is defined) ? trends[sparkKey] : [] %}
            <tr>
                <td class="nowrap"><strong>{{ kpi.mhc }}</strong></td>
                <td>{{ kpi.name }}</td>
                <td class="num">
                    {% if kpi.value is null %}
                        <em class="muted">—</em>
                    {% else %}
                        <strong>{{ kpi.value }}</strong>
                    {% endif %}
                </td>
                <td class="small">{{ kpi.unit }}</td>
                <td class="small">
                    {% if kpi.computable %}
                        <span class="badge badge-inv">{{ 'mris.audit_report.kpi_col.auto'|trans({}, 'mris') }}</span>
                    {% else %}
                        <span class="badge">{{ 'mris.audit_report.kpi_col.manual'|trans({}, 'mris') }}</span>
                    {% endif %}
                </td>
                <td>
                    {# Sparkline nur wenn ≥ 2 Trendpunkte vorhanden #}
                    {% if sparkVals|length >= 2 %}
                        {% set maxVal = max(sparkVals) %}
                        {% set minVal = min(sparkVals) %}
                        {% set range = (maxVal - minVal) > 0 ? (maxVal - minVal) : 1 %}
                        {% set step = 100 / (sparkVals|length - 1) %}
                        {% set points = [] %}
                        {% for i, v in sparkVals %}
                            {% set y = 22 - ((v - minVal) / range * 20) %}
                            {% set points = points|merge([(i * step)|round(1) ~ ',' ~ y|round(1)]) %}
                        {% endfor %}
                        <svg viewBox="0 0 100 24" width="80" height="20" class="sparkline" preserveAspectRatio="none">
                            <polyline fill="none" stroke="var(--fg)" stroke-width="1.2" points="{{ points|join(' ') }}"/>
                        </svg>
                        <div class="small muted">n={{ sparkVals|length }} · {{ minVal }}–{{ maxVal }}</div>
                    {% else %}
                        <span class="small muted">—</span>
                    {% endif %}
                </td>
                <td class="small">{{ kpi.source }}</td>
            </tr>
        {% endfor %}
    </tbody>
</table>

{# === Section 7: Signature ==================================== #}
<div class="signature">
    <h3 style="margin-top: 0;">{{ 'mris.audit_report.signature.title'|trans({}, 'mris') }}</h3>
    <p class="small">
        {{ 'mris.audit_report.signature.text'|trans({
            '%date%': generated_at|date('d.m.Y'),
            '%time%': generated_at|date('H:i'),
            '%user%': generated_by,
            '%tenant%': tenant_name
        }, 'mris') }}
    </p>
    <p class="small muted">
        {{ 'mris.audit_report.signature.note'|trans({}, 'mris') }}
    </p>
    <div class="signature-line">
        {{ 'mris.audit_report.signature.signature_line'|trans({}, 'mris') }}
    </div>
</div>

<div class="footer-source">
    {{ 'mris.audit_report.footer_source'|trans({}, 'mris') }}: {{ source_label }}
</div>

</body>
</html>
