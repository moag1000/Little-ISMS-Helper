{% extends 'base.html.twig' %}

{% block title %}MRIS-Wizard — Reine Reibung{% endblock %}

{% block body %}
<div class="container">

    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_mris_kpis') }}">MRIS-KPIs</a></li>
            <li class="breadcrumb-item active" aria-current="page">Wizard: Reine Reibung</li>
        </ol>
    </nav>

    <div class="page-header mb-4">
        <div>
            <h1>
                <i class="bi bi-cone-striped" aria-hidden="true"></i>
                {{ routine.title|default('5-Schritt-Entscheidungsroutine — Reine Reibung') }}
            </h1>
            <p class="text-muted small mb-0">
                {{ routine.intro|default('Audit-taugliche Routine fuer Annex-A-Controls, die als „Reine Reibung" markiert sind.') }}
            </p>
        </div>
    </div>

    {% if fallback_used %}
        <div class="alert alert-info small">
            <i class="bi bi-info-circle" aria-hidden="true"></i>
            <strong>Hinweis:</strong>
            Wizard-Daten in <code>fixtures/mris/help-texts.yaml</code> unter
            <code>blocker_solutions:</code> pflegen, damit dieser Inhalt
            zentral aus YAML geladen wird. Aktuell wird der eingebettete
            Default angezeigt.
        </div>
    {% endif %}

    {# 5 Steps als nummerierte Karten — Bootstrap-Grid, je 1 Schritt pro Reihe. #}
    <ol class="list-unstyled">
        {% for step in routine.steps %}
            <li class="mb-3">
                {% embed '_components/_card.html.twig' with { 'class': 'shadow-sm' } %}
                    {% block card_body %}
                        <div class="d-flex">
                            <div class="me-3">
                                <span class="badge bg-primary rounded-pill fs-5" style="min-width: 2.5rem;">
                                    {{ step.no }}
                                </span>
                            </div>
                            <div class="flex-grow-1">
                                <h2 class="h5 mb-2">{{ step.title }}</h2>
                                <p class="mb-2">{{ step.detail }}</p>
                                {% if step.evidence is defined and step.evidence %}
                                    <p class="small text-muted mb-0">
                                        <i class="fa-icon fa-icon--attachment" aria-hidden="true"></i>
                                        <strong>Audit-Evidenz:</strong> {{ step.evidence }}
                                    </p>
                                {% endif %}
                            </div>
                        </div>
                    {% endblock %}
                {% endembed %}
            </li>
        {% endfor %}
    </ol>

    {% if routine.example is defined and routine.example %}
        {% embed '_components/_card.html.twig' with { 'class': 'mt-4' } %}
            {% block card_header %}
                <div class="card-header">
                    <h2 class="h6 mb-0">
                        <i class="bi bi-lightbulb" aria-hidden="true"></i>
                        Beispiel
                    </h2>
                </div>
            {% endblock %}
            {% block card_body %}
                <p class="mb-0 small">{{ routine.example }}</p>
            {% endblock %}
        {% endembed %}
    {% endif %}

    {% if routine.norm_refs is defined and routine.norm_refs|length > 0 %}
        {% embed '_components/_card.html.twig' with { 'class': 'mt-3' } %}
            {% block card_header %}
                <div class="card-header">
                    <h2 class="h6 mb-0">
                        <i class="bi bi-bookmark-star" aria-hidden="true"></i>
                        Norm-Verweise
                    </h2>
                </div>
            {% endblock %}
            {% block card_body %}
                <ul class="small mb-0">
                    {% for ref in routine.norm_refs %}
                        <li>{{ ref }}</li>
                    {% endfor %}
                </ul>
            {% endblock %}
        {% endembed %}
    {% endif %}

    <footer class="text-center text-muted small mt-4 pt-3 border-top">
        Quelle: Peddi (2026) MRIS v1.5.
        <a href="https://creativecommons.org/licenses/by/4.0/" rel="noopener" target="_blank">CC BY 4.0</a>.
    </footer>

</div>
{% endblock %}
