{% trans_default_domain 'audits' %}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <title>{{ 'audits.audit_package.cover.title'|trans }} — {{ framework.name }}</title>
    <style>
        @page { size: A4; margin: 18mm 15mm; }
        body { font-family: 'DejaVu Sans', sans-serif; font-size: 10pt; color: #222; }
        h1 { font-size: 18pt; color: #1b3a57; margin: 0 0 3mm 0; }
        h2 { font-size: 12pt; color: #1b3a57; border-bottom: 1px solid #1b3a57; padding-bottom: 1mm; margin: 6mm 0 2mm 0; }
        table { width: 100%; border-collapse: collapse; margin: 2mm 0 4mm 0; }
        th, td { padding: 1.5mm 2mm; border: 1px solid var(--border); vertical-align: top; text-align: left; }
        th { background: #eef3f8; font-weight: bold; }
        .small { font-size: 8.5pt; color: #555; }
        .st-fulfilled { color: #166534; font-weight: bold; }
        .st-open      { color: #991b1b; font-weight: bold; }
        .cover { border: 1mm solid #1b3a57; padding: 5mm 7mm; margin-bottom: 6mm; background: #f7f9fc; }
        .badge { display: inline-block; padding: 0.5mm 2mm; border-radius: 2mm; font-size: 8.5pt; background: #e5eaf0; color: #1b3a57; }
    </style>
</head>
<body>
    <div class="cover">
        <h1>{{ 'audits.audit_package.cover.title'|trans }}</h1>
        <div><strong>{{ 'audits.audit_package.cover.label.framework'|trans }}:</strong> {{ framework.name }} ({{ framework.code }}{% if framework.version %} — {{ framework.version }}{% endif %})</div>
        <div><strong>{{ 'audits.audit_package.cover.label.tenant'|trans }}:</strong> {{ tenant.name }}</div>
        <div><strong>{{ 'audits.audit_package.cover.label.generated'|trans }}:</strong> {{ generated_at|date('d.m.Y H:i') }}</div>
    </div>

    <h2>{{ 'audits.audit_package.section.summary'|trans }}</h2>
    <table>
        <tr>
            <th>{{ 'audits.audit_package.table.requirements_total'|trans }}</th>
            <td>{{ requirements|length }}</td>
        </tr>
        <tr>
            <th>{{ 'audits.audit_package.table.evidence_docs'|trans }}</th>
            <td>{{ document_count }}</td>
        </tr>
        <tr>
            <th>{{ 'audits.audit_package.table.requirements_without_evidence'|trans }}</th>
            <td>
                {% if missing_count > 0 %}
                    <span class="st-open">{{ missing_count }} — {{ 'audits.audit_package.status.missing'|trans }}</span>
                {% else %}
                    <span class="st-fulfilled">0 — {{ 'audits.audit_package.status.complete'|trans }}</span>
                {% endif %}
            </td>
        </tr>
    </table>

    <h2>{{ 'audits.audit_package.section.requirements_detail'|trans }}</h2>
    <table>
        <thead>
            <tr>
                <th style="width: 15%;">{{ 'audits.audit_package.col.id'|trans }}</th>
                <th>{{ 'audit.field.title'|trans }}</th>
                <th style="width: 12%;">{{ 'audits.audit_package.col.category'|trans }}</th>
                <th style="width: 10%;">{{ 'audit.field.status'|trans }}</th>
                <th style="width: 10%;">{{ 'audits.audit_package.col.fulfillment'|trans }}</th>
                <th style="width: 10%;">{{ 'audits.audit_package.col.evidence'|trans }}</th>
            </tr>
        </thead>
        <tbody>
            {% for req in requirements %}
                {% set pct = req.calculateFulfillmentFromControls() %}
                {% set evCount = req.evidenceDocuments|length %}
                <tr>
                    <td><code>{{ req.requirementId }}</code></td>
                    <td>{{ req.title }}</td>
                    <td class="small">{{ req.category|default('—') }}</td>
                    <td>
                        {% if pct >= 80 %}
                            <span class="st-fulfilled">{{ 'audits.audit_package.status.fulfilled'|trans }}</span>
                        {% else %}
                            <span class="st-open">{{ 'audits.audit_package.status.open'|trans }}</span>
                        {% endif %}
                    </td>
                    <td>{{ pct }}%</td>
                    <td>
                        {% if evCount == 0 %}
                            <span class="st-open">0</span>
                        {% else %}
                            {{ evCount }}
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <p class="small">{{ 'audits.audit_package.footer.note'|trans }}</p>
</body>
</html>
