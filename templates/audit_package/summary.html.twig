<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <title>Audit-Paket — {{ framework.name }}</title>
    <style>
        @page { size: A4; margin: 18mm 15mm; }
        body { font-family: 'DejaVu Sans', sans-serif; font-size: 10pt; color: #222; }
        h1 { font-size: 18pt; color: #1b3a57; margin: 0 0 3mm 0; }
        h2 { font-size: 12pt; color: #1b3a57; border-bottom: 1px solid #1b3a57; padding-bottom: 1mm; margin: 6mm 0 2mm 0; }
        table { width: 100%; border-collapse: collapse; margin: 2mm 0 4mm 0; }
        th, td { padding: 1.5mm 2mm; border: 1px solid var(--border); vertical-align: top; text-align: left; }
        th { background: #eef3f8; font-weight: bold; }
        .small { font-size: 8.5pt; color: #555; }
        .st-fulfilled { color: #166534; font-weight: bold; }
        .st-open      { color: #991b1b; font-weight: bold; }
        .cover { border: 1mm solid #1b3a57; padding: 5mm 7mm; margin-bottom: 6mm; background: #f7f9fc; }
        .badge { display: inline-block; padding: 0.5mm 2mm; border-radius: 2mm; font-size: 8.5pt; background: #e5eaf0; color: #1b3a57; }
    </style>
</head>
<body>
    <div class="cover">
        <h1>Audit-Paket</h1>
        <div><strong>Framework:</strong> {{ framework.name }} ({{ framework.code }}{% if framework.version %} — {{ framework.version }}{% endif %})</div>
        <div><strong>Tenant:</strong> {{ tenant.name }}</div>
        <div><strong>Generiert:</strong> {{ generated_at|date('d.m.Y H:i') }}</div>
    </div>

    <h2>Zusammenfassung</h2>
    <table>
        <tr>
            <th>Anforderungen gesamt</th>
            <td>{{ requirements|length }}</td>
        </tr>
        <tr>
            <th>Evidence-Dokumente im Paket</th>
            <td>{{ document_count }}</td>
        </tr>
        <tr>
            <th>Anforderungen ohne Evidence</th>
            <td>
                {% if missing_count > 0 %}
                    <span class="st-open">{{ missing_count }} — Nachweis fehlt</span>
                {% else %}
                    <span class="st-fulfilled">0 — vollständig</span>
                {% endif %}
            </td>
        </tr>
    </table>

    <h2>Anforderungen im Detail</h2>
    <table>
        <thead>
            <tr>
                <th style="width: 15%;">ID</th>
                <th>Titel</th>
                <th style="width: 12%;">Kategorie</th>
                <th style="width: 10%;">Status</th>
                <th style="width: 10%;">Füllung</th>
                <th style="width: 10%;">Evidence</th>
            </tr>
        </thead>
        <tbody>
            {% for req in requirements %}
                {% set pct = req.calculateFulfillmentFromControls() %}
                {% set evCount = req.evidenceDocuments|length %}
                <tr>
                    <td><code>{{ req.requirementId }}</code></td>
                    <td>{{ req.title }}</td>
                    <td class="small">{{ req.category|default('—') }}</td>
                    <td>
                        {% if pct >= 80 %}
                            <span class="st-fulfilled">erfüllt</span>
                        {% else %}
                            <span class="st-open">offen</span>
                        {% endif %}
                    </td>
                    <td>{{ pct }}%</td>
                    <td>
                        {% if evCount == 0 %}
                            <span class="st-open">0</span>
                        {% else %}
                            {{ evCount }}
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <p class="small">Das vorliegende Paket enthält pro Anforderung einen Ordner mit README.txt und allen verknüpften Evidence-Dokumenten. INDEX.csv im Root führt das komplette Mapping zusammen.</p>
</body>
</html>
