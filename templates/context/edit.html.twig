{% extends 'base.html.twig' %}
{% trans_default_domain 'context' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'context.edit.title'|trans({}, 'context') }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'context_management.title'|trans({}, 'context'), url: path('app_context_index'), icon: 'nav-building' },
            { label: context.organizationName, url: path('app_context_index') },
            { label: 'common.edit'|trans({}, 'messages') }
        ]
    } %}

    {{ _fa_page_header.render({
        title: 'context.edit.title'|trans({}, 'context'),
        subtitle: 'context.info.subtitle'|trans({}, 'context'),
        badge: { icon: 'nav-building', label: '' },
        actions: [
            { label: 'common.back'|trans({}, 'messages'), href: path('app_context_index'), variant: 'secondary', icon: 'util-arrow-left' }
        ]
    }) }}

    {% if tenant is defined and tenant %}
        {{ _fa_alert.render({ variant: 'info', class: 'mb-4', body: '<strong>' ~ 'tenant.isms_context.linked_to'|trans({}, 'tenant') ~ ':</strong> ' ~ tenant.name ~ ' (' ~ tenant.code ~ ')' }) }}
    {% endif %}

    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
    {% include '_components/_auto_form.html.twig' with {
        'form': form,
        'layout': 'outline-rail',
        'eyebrow': 'ISO 27001 Cl. 4 · Organizational Context',
        'title': context.organizationName,
        'sections': {
            'overview': {
                'label': 'form.section.overview'|trans({}, 'messages'),
                'fields': ['organizationName']
            },
            'scope_definition': {
                'label': 'form.section.scope_definition'|trans({}, 'messages'),
                'fields': ['ismsScope', 'scopeExclusions']
            },
            'internal_issues': {
                'label': 'form.section.internal_issues'|trans({}, 'messages'),
                'fields': ['internalIssues']
            },
            'external_issues': {
                'label': 'form.section.external_issues'|trans({}, 'messages'),
                'fields': ['externalIssues']
            },
            'interested_parties_link': {
                'label': 'form.section.interested_parties_link'|trans({}, 'messages'),
                'fields': ['interestedPartiesRequirements']
            },
            'details': {
                'label': 'form.section.details'|trans({}, 'messages'),
                'fields': ['legalRequirements', 'regulatoryRequirements', 'contractualObligations', 'ismsPolicy', 'rolesAndResponsibilities']
            },
            'audit_metadata': {
                'label': 'form.section.audit_metadata'|trans({}, 'messages'),
                'fields': ['lastReviewDate', 'nextReviewDate']
            }
        },
        'col_widths': {
            'organizationName': 12,
            'ismsScope': 12,
            'scopeExclusions': 12,
            'internalIssues': 12,
            'externalIssues': 12,
            'interestedPartiesRequirements': 12,
            'legalRequirements': 12,
            'regulatoryRequirements': 12,
            'contractualObligations': 12,
            'ismsPolicy': 12,
            'rolesAndResponsibilities': 12,
            'lastReviewDate': 6,
            'nextReviewDate': 6
        },
        'tooltips': {
            'externalIssues': 'context.tooltip.external_issues',
            'internalIssues': 'context.tooltip.internal_issues',
            'scopeExclusions': 'context.tooltip.scope_exclusions',
            'interestedPartiesRequirements': 'context.tooltip.interested_parties_requirements'
        },
        'translation_domain': 'context',
        'actions': {
            'close': { 'label': 'common.cancel'|trans({}, 'messages'), 'variant': 'ghost' },
            'submit': { 'label': 'common.save'|trans({}, 'messages'), 'variant': 'primary' }
        }
    } %}
    {{ form_end(form) }}
</div>
{% endblock %}
