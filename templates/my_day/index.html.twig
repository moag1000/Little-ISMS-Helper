{% extends 'base.html.twig' %}
{% trans_default_domain 'my_day' %}

{% block title %}{{ 'my_day.title'|trans({}, 'my_day') }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
{% import '_components/_status_pill.html.twig' as pill %}

{% block body %}
{# Category metadata — single source for both the KPI tiles and the accordion
   sections. tone drives the tile colour AND whether the section auto-expands
   (danger = urgent → open by default; everything else collapsed to a counter,
   so a junior is not faced with 20 open lists). Display density is the global
   body[data-density] toggle. #}
{% set meta = {
    'workflows_pending':                  { icon: 'ui-undo',                tone: 'warning' },
    'workflows_overdue':                  { icon: 'status-critical',        tone: 'danger'  },
    'four_eyes':                          { icon: 'nav-people',             tone: 'warning' },
    'acknowledgements':                   { icon: 'ui-check',               tone: 'primary' },
    'findings':                           { icon: 'ui-search',              tone: 'warning' },
    'dsrs':                               { icon: 'file-person',            tone: 'danger'  },
    'corrective_actions_overdue':         { icon: 'ui-hourglass',           tone: 'danger'  },
    'risk_acceptance_expiring':           { icon: 'nav-shield-alert',       tone: 'warning' },
    'documents_review_overdue':           { icon: 'nav-file-earmark-text',  tone: 'danger'  },
    'trainings_pending':                  { icon: 'nav-mortarboard',        tone: 'primary' },
    'incidents_open_assigned':            { icon: 'status-critical',        tone: 'danger'  },
    'data_breaches_72h_ticking':          { icon: 'nav-shield-alert',       tone: 'danger'  },
    'vulnerabilities_critical_unpatched': { icon: 'bug',                    tone: 'warning' },
    'audit_checklist_due':                { icon: 'nav-clipboard-check',    tone: 'primary' },
    'change_requests_pending_approval':   { icon: 'util-refresh',           tone: 'primary' },
    'management_review_upcoming':         { icon: 'nav-clipboard-data',     tone: 'primary' },
    'evidence_reverification_due':        { icon: 'nav-clipboard-check',    tone: 'danger'  },
    'control_effectiveness_overdue':      { icon: 'ui-search',              tone: 'danger'  },
    'supplier_reassessment_due':          { icon: 'nav-truck',              tone: 'warning' },
    'dpia_review_overdue':                { icon: 'file-person',            tone: 'danger'  },
    'bc_plan_review_overdue':             { icon: 'util-refresh',           tone: 'warning' },
    'risk_review_overdue':                { icon: 'nav-shield-alert',       tone: 'warning' },
    'risk_acceptance_no_expiry':          { icon: 'nav-shield-alert',       tone: 'danger'  },
    'documents_pending_approval_for_me':  { icon: 'nav-file-check',         tone: 'warning' },
    'wizard_overdue':                     { icon: 'ui-hourglass',           tone: 'warning' },
    'framework_gaps_critical':            { icon: 'nav-bar-chart',          tone: 'danger'  },
} %}
{# Ordered category list. Items come from inbox.<key>; the three CM-only buckets
   default to [] when the aggregator did not provide them. #}
{% set order = ['workflows_pending','workflows_overdue','four_eyes','acknowledgements','findings','dsrs','corrective_actions_overdue','risk_acceptance_expiring','risk_acceptance_no_expiry','risk_review_overdue','documents_review_overdue','evidence_reverification_due','control_effectiveness_overdue','supplier_reassessment_due','dpia_review_overdue','bc_plan_review_overdue','trainings_pending','incidents_open_assigned','data_breaches_72h_ticking','vulnerabilities_critical_unpatched','audit_checklist_due','change_requests_pending_approval','management_review_upcoming','documents_pending_approval_for_me','wizard_overdue','framework_gaps_critical'] %}
{# Build the active list and the zero counter in one pass — avoids relying on a
   lazy |filter iterator being consumed twice. #}
{% set activeCategories = [] %}
{% set zeroCount = 0 %}
{% for key in order %}
    {% set items = attribute(inbox, key) ?? [] %}
    {% if items|length > 0 %}
        {% set activeCategories = activeCategories|merge([{
            key: key,
            anchor: key|replace({'_': '-'}),
            icon: meta[key].icon,
            tone: meta[key].tone,
            items: items,
            count: items|length,
        }]) %}
    {% else %}
        {% set zeroCount = zeroCount + 1 %}
    {% endif %}
{% endfor %}

<main class="fa-aurora-surface my-day">
    {{ _fa_page_header.render({
        badge:    { icon: 'nav-inbox', label: 'my_day.badge'|trans },
        title:    'my_day.title'|trans,
        subtitle: 'my_day.subtitle'|trans({'%generated_at%': inbox.generated_at|date('d.m.Y H:i')}, 'my_day'),
        actions: [
            { label: 'my_day.action.standard_dashboard'|trans, variant: 'ghost', icon: 'nav-home', href: path('app_dashboard') }
        ]
    }) }}

    {% if inbox.total == 0 %}
        <div class="my-4">
            {{ _fa_empty_state.render({
                mood: 'happy',
                title: 'my_day.empty.title'|trans,
                text: 'my_day.empty.text'|trans,
            }) }}
        </div>
    {% else %}

    {# KPI tiles — only categories WITH open actions are shown prominently.
       Zero-action categories are folded into one quiet line below, so the
       page leads with what actually needs doing (no 20-tile green wall). #}
    <div class="kpi-grid d-grid grid-responsive-250 gap-4 my-2rem">
        {% for c in activeCategories %}
            {{ _fa_feature_card.render({
                icon: c.icon,
                label: ('my_day.kpi.' ~ c.key)|trans,
                value: c.count,
                variant: c.tone,
                href: '#' ~ c.anchor,
            }) }}
        {% endfor %}
    </div>
    {% if zeroCount > 0 %}
        <p class="text-muted small mb-4">
            <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i>
            {{ 'my_day.tiles.all_clear'|trans({'%count%': zeroCount}) }}
        </p>
    {% endif %}

    {# Accordion sections. Urgent (danger) categories open by default so the ISB
       sees them immediately; the rest stay collapsed to a title + counter so a
       junior gets a compact overview and expands only what they want. Native
       <details> — keyboard-accessible, works without JavaScript. #}
    {% for c in activeCategories %}
        {% set hasHigh = c.items|filter(i => i.priority == 'high')|length > 0 %}
        <details class="fa-section my-day-section mb-3" id="{{ c.anchor }}"{{ (c.tone == 'danger' or hasHigh) ? ' open' : '' }}>
            <summary class="fa-section__header my-day-section__summary">
                <span class="fa-section__title d-flex align-items-center gap-2">
                    <i class="fa-icon fa-icon--{{ c.icon }}" aria-hidden="true"></i>
                    {{ ('my_day.section.' ~ c.key)|trans }}
                    {{ pill.render(c.count, c.tone == 'danger' ? 'danger' : 'neutral', {class: 'ms-1'}) }}
                </span>
            </summary>
            <div class="fa-section__body">
                <div class="list-group">
                    {% for item in c.items %}
                        <a href="{{ item.link }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-start">
                            <div class="ms-2 me-auto">
                                <div class="fw-bold">
                                    {% set entityIcon = {
                                        'workflow': 'ui-refresh', 'four_eyes': 'nav-people', 'acknowledgement': 'ui-check',
                                        'audit_finding': 'ui-search', 'dsr': 'ui-file-person', 'corrective_action': 'ui-hourglass',
                                        'risk_acceptance': 'nav-shield-alert', 'document_review': 'nav-document', 'training': 'nav-mortarboard',
                                        'incident': 'status-critical', 'data_breach': 'nav-shield-alert', 'vulnerability': 'util-bug',
                                        'audit_checklist': 'nav-clipboard-check', 'change_request': 'ui-refresh', 'management_review': 'nav-clipboard-data',
                                        'document_pending_approval': 'nav-file-check', 'wizard_overdue': 'ui-hourglass', 'framework_gap': 'nav-bar-chart',
                                        'evidence_reverification': 'nav-clipboard-check', 'control': 'ui-search', 'supplier': 'nav-truck',
                                        'dpia': 'ui-file-person', 'bc_plan': 'util-refresh', 'risk_review': 'nav-shield-alert'
                                    } %}
                                    {% if entityIcon[item.entity_type] is defined %}
                                        <i class="fa-icon fa-icon--{{ entityIcon[item.entity_type] }}" aria-hidden="true"></i>
                                    {% endif %}
                                    {{ item.title }}
                                </div>
                                <small class="text-muted">{{ item.subtitle }}</small>
                                {% if item.due_date %}
                                    <small class="d-block text-muted">{{ 'my_day.item.due'|trans }}: {{ item.due_date|date('d.m.Y') }}</small>
                                {% endif %}
                            </div>
                            <div class="text-end">
                                {% if item.badge %}
                                    {% set pillTone = item.tone == 'danger' ? 'danger'
                                        : (item.tone == 'warning' ? 'warning'
                                        : (item.tone == 'success' ? 'success'
                                        : 'primary')) %}
                                    {{ pill.render(item.badge, pillTone) }}
                                {% endif %}
                                {% if item.priority == 'high' %}
                                    {{ pill.render('my_day.priority.high'|trans, 'danger', {class: 'ms-1'}) }}
                                {% elseif item.priority == 'medium' %}
                                    {{ pill.render('my_day.priority.medium'|trans, 'warning', {class: 'ms-1'}) }}
                                {% endif %}
                            </div>
                        </a>
                    {% endfor %}
                </div>
            </div>
        </details>
    {% endfor %}

    {% endif %}
</main>

<style>
/* My-Day accordion — collapsed sections show only the summary (title + count).
   Density-aware spacing comes from the global body[data-density] tokens. */
.my-day-section { border: 1px solid var(--border); border-radius: var(--radius-md, .5rem); overflow: hidden; }
.my-day-section__summary { cursor: pointer; list-style: none; display: flex; align-items: center; justify-content: space-between; gap: .75rem; padding: .75rem 1rem; }
.my-day-section__summary::-webkit-details-marker { display: none; }
.my-day-section__summary::after { content: '\203A'; font-size: 1.25rem; line-height: 1; color: var(--fg-2); transition: transform .15s ease; }
.my-day-section[open] > .my-day-section__summary::after { transform: rotate(90deg); }
.my-day-section__summary:hover { background: var(--surface-2); }
body[data-density='compact'] .my-day-section__summary { padding: .4rem .75rem; }
</style>
{% endblock %}
