{% extends 'base.html.twig' %}

{% block title %}{{ 'my_day.title'|trans }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
{% import '_components/_status_pill.html.twig' as pill %}

{% block body %}
<main class="fa-aurora-surface my-day">
    {{ _fa_page_header.render({
        badge:    { icon: 'nav-inbox', label: 'my_day.badge'|trans },
        title:    'my_day.title'|trans,
        subtitle: 'my_day.subtitle'|trans({'%generated_at%': inbox.generated_at|date('d.m.Y H:i')}, 'my_day'),
        actions: [
            { label: 'my_day.action.standard_dashboard'|trans, variant: 'ghost', icon: 'nav-home', href: path('app_dashboard') }
        ]
    }) }}

    {# KPI tile bar — Counts per category #}
    <div class="kpi-grid d-grid grid-responsive-250 gap-4 my-2rem">
        {{ _fa_feature_card.render({
            icon: 'ui-undo',
            label: 'my_day.kpi.workflows_pending'|trans,
            value: inbox.summary.workflows_pending,
            variant: inbox.summary.workflows_pending > 0 ? 'warning' : 'success',
            href: '#workflows-pending'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'status-critical',
            label: 'my_day.kpi.workflows_overdue'|trans,
            value: inbox.summary.workflows_overdue,
            variant: inbox.summary.workflows_overdue > 0 ? 'danger' : 'success',
            href: '#workflows-overdue'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'nav-people',
            label: 'my_day.kpi.four_eyes'|trans,
            value: inbox.summary.four_eyes,
            variant: inbox.summary.four_eyes > 0 ? 'warning' : 'success',
            href: '#four-eyes'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'ui-check',
            label: 'my_day.kpi.acknowledgements'|trans,
            value: inbox.summary.acknowledgements,
            variant: inbox.summary.acknowledgements > 0 ? 'primary' : 'success',
            href: '#acknowledgements'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'ui-search',
            label: 'my_day.kpi.findings'|trans,
            value: inbox.summary.findings,
            variant: inbox.summary.findings > 0 ? 'warning' : 'success',
            href: '#findings'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'file-person',
            label: 'my_day.kpi.dsrs'|trans,
            value: inbox.summary.dsrs,
            variant: inbox.summary.dsrs > 0 ? 'danger' : 'success',
            href: '#dsrs'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'ui-hourglass',
            label: 'my_day.kpi.corrective_actions_overdue'|trans,
            value: inbox.summary.corrective_actions_overdue,
            variant: inbox.summary.corrective_actions_overdue > 0 ? 'danger' : 'success',
            href: '#corrective-actions'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'nav-shield-alert',
            label: 'my_day.kpi.risk_acceptance_expiring'|trans,
            value: inbox.summary.risk_acceptance_expiring,
            variant: inbox.summary.risk_acceptance_expiring > 0 ? 'warning' : 'success',
            href: '#risk-acceptance-expiring'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'nav-file-earmark-text',
            label: 'my_day.kpi.documents_review_overdue'|trans,
            value: inbox.summary.documents_review_overdue,
            variant: inbox.summary.documents_review_overdue > 0 ? 'danger' : 'success',
            href: '#documents-review-overdue'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'nav-mortarboard',
            label: 'my_day.kpi.trainings_pending'|trans,
            value: inbox.summary.trainings_pending,
            variant: inbox.summary.trainings_pending > 0 ? 'primary' : 'success',
            href: '#trainings-pending'
        }) }}
        {# Audit V4 V4-LB-1 Round-2 — 6 ISB-Tagesgeschäft tiles #}
        {{ _fa_feature_card.render({
            icon: 'status-critical',
            label: 'my_day.kpi.incidents_open_assigned'|trans,
            value: inbox.summary.incidents_open_assigned,
            variant: inbox.summary.incidents_open_assigned > 0 ? 'danger' : 'success',
            href: '#incidents-open-assigned'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'nav-shield-alert',
            label: 'my_day.kpi.data_breaches_72h_ticking'|trans,
            value: inbox.summary.data_breaches_72h_ticking,
            variant: inbox.summary.data_breaches_72h_ticking > 0 ? 'danger' : 'success',
            href: '#data-breaches-72h-ticking'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'bug',
            label: 'my_day.kpi.vulnerabilities_critical_unpatched'|trans,
            value: inbox.summary.vulnerabilities_critical_unpatched,
            variant: inbox.summary.vulnerabilities_critical_unpatched > 0 ? 'warning' : 'success',
            href: '#vulnerabilities-critical-unpatched'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'nav-clipboard-check',
            label: 'my_day.kpi.audit_checklist_due'|trans,
            value: inbox.summary.audit_checklist_due,
            variant: inbox.summary.audit_checklist_due > 0 ? 'primary' : 'success',
            href: '#audit-checklist-due'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'util-refresh',
            label: 'my_day.kpi.change_requests_pending_approval'|trans,
            value: inbox.summary.change_requests_pending_approval,
            variant: inbox.summary.change_requests_pending_approval > 0 ? 'primary' : 'success',
            href: '#change-requests-pending-approval'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'nav-clipboard-data',
            label: 'my_day.kpi.management_review_upcoming'|trans,
            value: inbox.summary.management_review_upcoming,
            variant: inbox.summary.management_review_upcoming > 0 ? 'success' : 'success',
            href: '#management-review-upcoming'
        }) }}
        {# V4-EF-7 — Compliance-Manager CM-Buckets (only shown when non-zero) #}
        {% if inbox.summary.documents_pending_approval_for_me is defined %}
        {{ _fa_feature_card.render({
            icon: 'nav-file-check',
            label: 'my_day.kpi.documents_pending_approval_for_me'|trans,
            value: inbox.summary.documents_pending_approval_for_me,
            variant: inbox.summary.documents_pending_approval_for_me > 0 ? 'warning' : 'success',
            href: '#documents-pending-approval'
        }) }}
        {% endif %}
        {% if inbox.summary.wizard_overdue is defined %}
        {{ _fa_feature_card.render({
            icon: 'ui-hourglass',
            label: 'my_day.kpi.wizard_overdue'|trans,
            value: inbox.summary.wizard_overdue,
            variant: inbox.summary.wizard_overdue > 0 ? 'warning' : 'success',
            href: '#wizard-overdue'
        }) }}
        {% endif %}
        {% if inbox.summary.framework_gaps_critical is defined %}
        {{ _fa_feature_card.render({
            icon: 'nav-bar-chart',
            label: 'my_day.kpi.framework_gaps_critical'|trans,
            value: inbox.summary.framework_gaps_critical,
            variant: inbox.summary.framework_gaps_critical > 0 ? 'danger' : 'success',
            href: '#framework-gaps-critical'
        }) }}
        {% endif %}
    </div>

    {% if inbox.total == 0 %}
        <div class="my-4">
            {{ _fa_empty_state.render({
                mood: 'happy',
                title: 'my_day.empty.title'|trans,
                text: 'my_day.empty.text'|trans,
            }) }}
        </div>
    {% else %}

    {% set sections = [
        { id: 'workflows-pending', title: 'my_day.section.workflows_pending'|trans, items: inbox.workflows_pending },
        { id: 'workflows-overdue', title: 'my_day.section.workflows_overdue'|trans, items: inbox.workflows_overdue },
        { id: 'four-eyes', title: 'my_day.section.four_eyes'|trans, items: inbox.four_eyes },
        { id: 'acknowledgements', title: 'my_day.section.acknowledgements'|trans, items: inbox.acknowledgements },
        { id: 'findings', title: 'my_day.section.findings'|trans, items: inbox.findings },
        { id: 'dsrs', title: 'my_day.section.dsrs'|trans, items: inbox.dsrs },
        { id: 'corrective-actions', title: 'my_day.section.corrective_actions_overdue'|trans, items: inbox.corrective_actions_overdue },
        { id: 'risk-acceptance-expiring', title: 'my_day.section.risk_acceptance_expiring'|trans, items: inbox.risk_acceptance_expiring },
        { id: 'documents-review-overdue', title: 'my_day.section.documents_review_overdue'|trans, items: inbox.documents_review_overdue },
        { id: 'trainings-pending', title: 'my_day.section.trainings_pending'|trans, items: inbox.trainings_pending },
        { id: 'incidents-open-assigned', title: 'my_day.section.incidents_open_assigned'|trans, items: inbox.incidents_open_assigned },
        { id: 'data-breaches-72h-ticking', title: 'my_day.section.data_breaches_72h_ticking'|trans, items: inbox.data_breaches_72h_ticking },
        { id: 'vulnerabilities-critical-unpatched', title: 'my_day.section.vulnerabilities_critical_unpatched'|trans, items: inbox.vulnerabilities_critical_unpatched },
        { id: 'audit-checklist-due', title: 'my_day.section.audit_checklist_due'|trans, items: inbox.audit_checklist_due },
        { id: 'change-requests-pending-approval', title: 'my_day.section.change_requests_pending_approval'|trans, items: inbox.change_requests_pending_approval },
        { id: 'management-review-upcoming', title: 'my_day.section.management_review_upcoming'|trans, items: inbox.management_review_upcoming },
        { id: 'documents-pending-approval', title: 'my_day.section.documents_pending_approval_for_me'|trans, items: inbox.documents_pending_approval_for_me ?? [] },
        { id: 'wizard-overdue', title: 'my_day.section.wizard_overdue'|trans, items: inbox.wizard_overdue ?? [] },
        { id: 'framework-gaps-critical', title: 'my_day.section.framework_gaps_critical'|trans, items: inbox.framework_gaps_critical ?? [] },
    ] %}

    {% for section in sections %}
        {% if section.items|length > 0 %}
        <section class="fa-section mb-4" id="{{ section.id }}">
            <div class="fa-section__header">
                <h2 class="fa-section__title">{{ section.title }}
                    {{ pill.render(section.items|length, 'neutral', {class: 'ms-2'}) }}
                </h2>
            </div>
            <div class="fa-section__body">
                <div class="list-group">
                    {% for item in section.items %}
                        <a href="{{ item.link }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-start">
                            <div class="ms-2 me-auto">
                                <div class="fw-bold">
                                    {% if item.entity_type == 'workflow' %}
                                        <i class="fa-icon fa-icon--ui-refresh" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'four_eyes' %}
                                        <i class="fa-icon fa-icon--nav-people" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'acknowledgement' %}
                                        <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'audit_finding' %}
                                        <i class="fa-icon fa-icon--ui-search" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'dsr' %}
                                        <i class="fa-icon fa-icon--ui-file-person" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'corrective_action' %}
                                        <i class="fa-icon fa-icon--ui-hourglass" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'risk_acceptance' %}
                                        <i class="fa-icon fa-icon--nav-shield-alert" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'document_review' %}
                                        <i class="fa-icon fa-icon--nav-document" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'training' %}
                                        <i class="fa-icon fa-icon--nav-mortarboard" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'incident' %}
                                        <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'data_breach' %}
                                        <i class="fa-icon fa-icon--nav-shield-alert" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'vulnerability' %}
                                        <i class="fa-icon fa-icon--util-bug" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'audit_checklist' %}
                                        <i class="fa-icon fa-icon--nav-clipboard-check" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'change_request' %}
                                        <i class="fa-icon fa-icon--ui-refresh" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'management_review' %}
                                        <i class="fa-icon fa-icon--nav-clipboard-data" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'document_pending_approval' %}
                                        <i class="fa-icon fa-icon--nav-file-check" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'wizard_overdue' %}
                                        <i class="fa-icon fa-icon--ui-hourglass" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'framework_gap' %}
                                        <i class="fa-icon fa-icon--nav-bar-chart" aria-hidden="true"></i>
                                    {% endif %}
                                    {{ item.title }}
                                </div>
                                <small class="text-muted">{{ item.subtitle }}</small>
                                {% if item.due_date %}
                                    <small class="d-block text-muted">{{ 'my_day.item.due'|trans }}: {{ item.due_date|date('d.m.Y') }}</small>
                                {% endif %}
                            </div>
                            <div class="text-end">
                                {% if item.badge %}
                                    {% set pillTone = item.tone == 'danger' ? 'danger'
                                        : (item.tone == 'warning' ? 'warning'
                                        : (item.tone == 'success' ? 'success'
                                        : 'primary')) %}
                                    {{ pill.render(item.badge, pillTone) }}
                                {% endif %}
                                {% if item.priority == 'high' %}
                                    {{ pill.render('my_day.priority.high'|trans, 'danger', {class: 'ms-1'}) }}
                                {% elseif item.priority == 'medium' %}
                                    {{ pill.render('my_day.priority.medium'|trans, 'warning', {class: 'ms-1'}) }}
                                {% endif %}
                            </div>
                        </a>
                    {% endfor %}
                </div>
            </div>
        </section>
        {% endif %}
    {% endfor %}

    {% endif %}
</main>
{% endblock %}
