{% extends 'base.html.twig' %}
{% trans_default_domain 'my_day' %}

{% block title %}{{ 'title'|trans }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}

{% block body %}
<main class="fa-aurora-surface my-day">
    {{ _fa_page_header.render({
        badge:    { icon: 'inboxes', label: 'badge'|trans },
        title:    'title'|trans,
        subtitle: 'subtitle'|trans({'%generated_at%': inbox.generated_at|date('d.m.Y H:i')}),
        actions: [
            { label: 'action.standard_dashboard'|trans, variant: 'ghost', icon: 'house', href: path('app_dashboard') }
        ]
    }) }}

    {# KPI tile bar — Counts per category #}
    <div class="kpi-grid d-grid grid-responsive-250 gap-4 my-2rem">
        {{ _fa_feature_card.render({
            icon: 'arrow-counterclockwise',
            label: 'kpi.workflows_pending'|trans,
            value: inbox.summary.workflows_pending,
            variant: inbox.summary.workflows_pending > 0 ? 'warning' : 'success',
            href: '#workflows-pending'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'exclamation-octagon',
            label: 'kpi.workflows_overdue'|trans,
            value: inbox.summary.workflows_overdue,
            variant: inbox.summary.workflows_overdue > 0 ? 'danger' : 'success',
            href: '#workflows-overdue'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'people',
            label: 'kpi.four_eyes'|trans,
            value: inbox.summary.four_eyes,
            variant: inbox.summary.four_eyes > 0 ? 'warning' : 'success',
            href: '#four-eyes'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'check2-square',
            label: 'kpi.acknowledgements'|trans,
            value: inbox.summary.acknowledgements,
            variant: inbox.summary.acknowledgements > 0 ? 'primary' : 'success',
            href: '#acknowledgements'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'search',
            label: 'kpi.findings'|trans,
            value: inbox.summary.findings,
            variant: inbox.summary.findings > 0 ? 'warning' : 'success',
            href: '#findings'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'file-person',
            label: 'kpi.dsrs'|trans,
            value: inbox.summary.dsrs,
            variant: inbox.summary.dsrs > 0 ? 'danger' : 'success',
            href: '#dsrs'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'hourglass-bottom',
            label: 'kpi.corrective_actions_overdue'|trans,
            value: inbox.summary.corrective_actions_overdue,
            variant: inbox.summary.corrective_actions_overdue > 0 ? 'danger' : 'success',
            href: '#corrective-actions'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'shield-exclamation',
            label: 'kpi.risk_acceptance_expiring'|trans,
            value: inbox.summary.risk_acceptance_expiring,
            variant: inbox.summary.risk_acceptance_expiring > 0 ? 'warning' : 'success',
            href: '#risk-acceptance-expiring'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'file-earmark-text',
            label: 'kpi.documents_review_overdue'|trans,
            value: inbox.summary.documents_review_overdue,
            variant: inbox.summary.documents_review_overdue > 0 ? 'danger' : 'success',
            href: '#documents-review-overdue'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'mortarboard',
            label: 'kpi.trainings_pending'|trans,
            value: inbox.summary.trainings_pending,
            variant: inbox.summary.trainings_pending > 0 ? 'primary' : 'success',
            href: '#trainings-pending'
        }) }}
        {# Audit V4 V4-LB-1 Round-2 — 6 ISB-Tagesgeschäft tiles #}
        {{ _fa_feature_card.render({
            icon: 'exclamation-octagon',
            label: 'kpi.incidents_open_assigned'|trans,
            value: inbox.summary.incidents_open_assigned,
            variant: inbox.summary.incidents_open_assigned > 0 ? 'danger' : 'success',
            href: '#incidents-open-assigned'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'shield-exclamation',
            label: 'kpi.data_breaches_72h_ticking'|trans,
            value: inbox.summary.data_breaches_72h_ticking,
            variant: inbox.summary.data_breaches_72h_ticking > 0 ? 'danger' : 'success',
            href: '#data-breaches-72h-ticking'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'bug',
            label: 'kpi.vulnerabilities_critical_unpatched'|trans,
            value: inbox.summary.vulnerabilities_critical_unpatched,
            variant: inbox.summary.vulnerabilities_critical_unpatched > 0 ? 'warning' : 'success',
            href: '#vulnerabilities-critical-unpatched'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'clipboard-check',
            label: 'kpi.audit_checklist_due'|trans,
            value: inbox.summary.audit_checklist_due,
            variant: inbox.summary.audit_checklist_due > 0 ? 'primary' : 'success',
            href: '#audit-checklist-due'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'arrow-repeat',
            label: 'kpi.change_requests_pending_approval'|trans,
            value: inbox.summary.change_requests_pending_approval,
            variant: inbox.summary.change_requests_pending_approval > 0 ? 'primary' : 'success',
            href: '#change-requests-pending-approval'
        }) }}
        {{ _fa_feature_card.render({
            icon: 'clipboard-data',
            label: 'kpi.management_review_upcoming'|trans,
            value: inbox.summary.management_review_upcoming,
            variant: inbox.summary.management_review_upcoming > 0 ? 'success' : 'success',
            href: '#management-review-upcoming'
        }) }}
        {# V4-EF-7 — Compliance-Manager CM-Buckets (only shown when non-zero) #}
        {% if inbox.summary.documents_pending_approval_for_me is defined %}
        {{ _fa_feature_card.render({
            icon: 'file-earmark-check',
            label: 'kpi.documents_pending_approval_for_me'|trans,
            value: inbox.summary.documents_pending_approval_for_me,
            variant: inbox.summary.documents_pending_approval_for_me > 0 ? 'warning' : 'success',
            href: '#documents-pending-approval'
        }) }}
        {% endif %}
        {% if inbox.summary.wizard_overdue is defined %}
        {{ _fa_feature_card.render({
            icon: 'hourglass-split',
            label: 'kpi.wizard_overdue'|trans,
            value: inbox.summary.wizard_overdue,
            variant: inbox.summary.wizard_overdue > 0 ? 'warning' : 'success',
            href: '#wizard-overdue'
        }) }}
        {% endif %}
        {% if inbox.summary.framework_gaps_critical is defined %}
        {{ _fa_feature_card.render({
            icon: 'bar-chart-line',
            label: 'kpi.framework_gaps_critical'|trans,
            value: inbox.summary.framework_gaps_critical,
            variant: inbox.summary.framework_gaps_critical > 0 ? 'danger' : 'success',
            href: '#framework-gaps-critical'
        }) }}
        {% endif %}
    </div>

    {% if inbox.total == 0 %}
        <div class="my-4">
            {{ _fa_empty_state.render({
                mood: 'happy',
                title: 'empty.title'|trans,
                text: 'empty.text'|trans,
            }) }}
        </div>
    {% else %}

    {% set sections = [
        { id: 'workflows-pending', title: 'section.workflows_pending'|trans, items: inbox.workflows_pending },
        { id: 'workflows-overdue', title: 'section.workflows_overdue'|trans, items: inbox.workflows_overdue },
        { id: 'four-eyes', title: 'section.four_eyes'|trans, items: inbox.four_eyes },
        { id: 'acknowledgements', title: 'section.acknowledgements'|trans, items: inbox.acknowledgements },
        { id: 'findings', title: 'section.findings'|trans, items: inbox.findings },
        { id: 'dsrs', title: 'section.dsrs'|trans, items: inbox.dsrs },
        { id: 'corrective-actions', title: 'section.corrective_actions_overdue'|trans, items: inbox.corrective_actions_overdue },
        { id: 'risk-acceptance-expiring', title: 'section.risk_acceptance_expiring'|trans, items: inbox.risk_acceptance_expiring },
        { id: 'documents-review-overdue', title: 'section.documents_review_overdue'|trans, items: inbox.documents_review_overdue },
        { id: 'trainings-pending', title: 'section.trainings_pending'|trans, items: inbox.trainings_pending },
        { id: 'incidents-open-assigned', title: 'section.incidents_open_assigned'|trans, items: inbox.incidents_open_assigned },
        { id: 'data-breaches-72h-ticking', title: 'section.data_breaches_72h_ticking'|trans, items: inbox.data_breaches_72h_ticking },
        { id: 'vulnerabilities-critical-unpatched', title: 'section.vulnerabilities_critical_unpatched'|trans, items: inbox.vulnerabilities_critical_unpatched },
        { id: 'audit-checklist-due', title: 'section.audit_checklist_due'|trans, items: inbox.audit_checklist_due },
        { id: 'change-requests-pending-approval', title: 'section.change_requests_pending_approval'|trans, items: inbox.change_requests_pending_approval },
        { id: 'management-review-upcoming', title: 'section.management_review_upcoming'|trans, items: inbox.management_review_upcoming },
        { id: 'documents-pending-approval', title: 'section.documents_pending_approval_for_me'|trans, items: inbox.documents_pending_approval_for_me ?? [] },
        { id: 'wizard-overdue', title: 'section.wizard_overdue'|trans, items: inbox.wizard_overdue ?? [] },
        { id: 'framework-gaps-critical', title: 'section.framework_gaps_critical'|trans, items: inbox.framework_gaps_critical ?? [] },
    ] %}

    {% for section in sections %}
        {% if section.items|length > 0 %}
        <section class="fa-section mb-4" id="{{ section.id }}">
            <div class="fa-section__header">
                <h2 class="fa-section__title">{{ section.title }}
                    <span class="badge bg-secondary ms-2">{{ section.items|length }}</span>
                </h2>
            </div>
            <div class="fa-section__body">
                <div class="list-group">
                    {% for item in section.items %}
                        <a href="{{ item.link }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-start">
                            <div class="ms-2 me-auto">
                                <div class="fw-bold">
                                    {% if item.entity_type == 'workflow' %}
                                        <i class="bi bi-arrow-counterclockwise" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'four_eyes' %}
                                        <i class="bi bi-people" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'acknowledgement' %}
                                        <i class="bi bi-check2-square" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'audit_finding' %}
                                        <i class="bi bi-search" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'dsr' %}
                                        <i class="bi bi-file-person" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'corrective_action' %}
                                        <i class="bi bi-hourglass-bottom" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'risk_acceptance' %}
                                        <i class="bi bi-shield-exclamation" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'document_review' %}
                                        <i class="bi bi-file-earmark-text" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'training' %}
                                        <i class="bi bi-mortarboard" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'incident' %}
                                        <i class="bi bi-exclamation-octagon" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'data_breach' %}
                                        <i class="bi bi-shield-exclamation" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'vulnerability' %}
                                        <i class="bi bi-bug" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'audit_checklist' %}
                                        <i class="bi bi-clipboard-check" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'change_request' %}
                                        <i class="bi bi-arrow-repeat" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'management_review' %}
                                        <i class="bi bi-clipboard-data" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'document_pending_approval' %}
                                        <i class="bi bi-file-earmark-check" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'wizard_overdue' %}
                                        <i class="bi bi-hourglass-split" aria-hidden="true"></i>
                                    {% elseif item.entity_type == 'framework_gap' %}
                                        <i class="bi bi-bar-chart-line" aria-hidden="true"></i>
                                    {% endif %}
                                    {{ item.title }}
                                </div>
                                <small class="text-muted">{{ item.subtitle }}</small>
                                {% if item.due_date %}
                                    <small class="d-block text-muted">{{ 'item.due'|trans }}: {{ item.due_date|date('d.m.Y') }}</small>
                                {% endif %}
                            </div>
                            <div class="text-end">
                                {% if item.badge %}
                                    {% set badgeClass = item.tone == 'danger' ? 'bg-danger'
                                        : (item.tone == 'warning' ? 'bg-warning text-dark'
                                        : (item.tone == 'success' ? 'bg-success'
                                        : 'bg-info text-dark')) %}
                                    <span class="badge {{ badgeClass }}">{{ item.badge }}</span>
                                {% endif %}
                                {% if item.priority == 'high' %}
                                    <span class="badge bg-danger ms-1">{{ 'priority.high'|trans }}</span>
                                {% elseif item.priority == 'medium' %}
                                    <span class="badge bg-warning text-dark ms-1">{{ 'priority.medium'|trans }}</span>
                                {% endif %}
                            </div>
                        </a>
                    {% endfor %}
                </div>
            </div>
        </section>
        {% endif %}
    {% endfor %}

    {% endif %}
</main>
{% endblock %}
