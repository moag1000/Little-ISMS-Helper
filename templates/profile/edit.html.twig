{% extends 'base.html.twig' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'user.profile.action.edit'|trans({}, 'user') }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {{ _fa_page_header.render({
    title: ('user.profile.action.edit'|trans({}, 'user')),
    badge: { icon: 'ui-edit', label: '' },
    actions: [
        { label: 'common.back'|trans({}, 'messages'), href: path('app_profile'), variant: 'ghost', icon: 'util-arrow-left' }
    ]
}) }}

    <div class="row">
        <div class="col-md-8 offset-md-2">
            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header">
                        <h2 class="mb-0">{{ 'user.profile.title'|trans({}, 'user') }}</h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {{ form_start(form) }}
                        {# H-03: strict_whitelist is CRITICAL here — the profile
                           controller passes is_profile_edit=true, but the
                           catch-all would still render any field the FormType
                           accidentally added (e.g. roles, tenant, isActive),
                           letting a regular user POST role-elevation. #}
                        {% include '_components/_auto_form.html.twig' with {
                            'form': form,
                            'strict_whitelist': true,
                            'sections': {
                                'basic_info': {
                                    'label': 'user.section.basic_info'|trans({}, 'user'),
                                    'fields': ['firstName', 'lastName', 'email', 'department', 'jobTitle', 'phoneNumber']
                                },
                                'avatar': {
                                    'label': 'user.section.avatar'|trans({}, 'user'),
                                    'fields': ['avatarFile']
                                },
                                'preferences': {
                                    'label': 'user.profile.section.preferences'|trans({}, 'user'),
                                    'fields': ['language', 'timezone', 'previousQmsBackground']
                                },
                                'competence': {
                                    'label': 'user.section.competence'|trans({}, 'user'),
                                    'fields': ['competencies']
                                },
                                'security': {
                                    'label': 'user.profile.section.security'|trans({}, 'user'),
                                    'fields': ['plainPassword']
                                }
                            },
                            'col_widths': {
                                'firstName': 6,
                                'lastName': 6,
                                'email': 12,
                                'department': 6,
                                'jobTitle': 6,
                                'phoneNumber': 6,
                                'avatarFile': 12,
                                'language': 6,
                                'timezone': 6,
                                'previousQmsBackground': 12,
                                'competencies': 12,
                                'plainPassword': 12
                            },
                            'translation_domain': 'user'
                        } %}

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a href="{{ path('app_profile') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                                <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i>
                                {{ 'common.cancel'|trans({}, 'messages') }}
                            </a>
                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                                <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
                                {{ 'user.save_changes'|trans({}, 'user') }}
                            </button>
                        </div>
                    {{ form_end(form) }}
                {% endblock %}
            {% endembed %}

            {# Current Avatar Display #}
            {% if user.profilePicture %}
                {% embed '_components/_card.html.twig' with { 'class': 'mt-4' } %}
                    {% block card_header %}
                        <div class="card-header">
                            <h2 class="mb-0">{{ 'user.profile.section.current_avatar'|trans({}, 'user') }}</h2>
                        </div>
                    {% endblock %}
                    {% block card_body %}
                        <div class="text-center">
                            <img src="{{ asset(user.profilePicture) }}"
                                 alt="{{ user.fullName }}"
                                 class="rounded-circle mb-3"
                                 style="width: 120px; height: 120px; object-fit: cover;">

                            <form method="post" action="{{ path('app_profile_avatar_delete') }}" class="d-inline"
                                  data-controller="ui-actions"
                                  data-action="submit->ui-actions#confirm"
                                  data-ui-actions-message-param="{{ 'user.profile.confirm.delete_avatar'|trans({}, 'user') }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_avatar' ~ user.id) }}">
                                <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger fa-cyber-btn--sm">
                                    <i class="fa-icon fa-icon--ui-trash" aria-hidden="true"></i>
                                    {{ 'user.profile.action.delete_avatar'|trans({}, 'user') }}
                                </button>
                            </form>
                        </div>
                    {% endblock %}
                {% endembed %}
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
