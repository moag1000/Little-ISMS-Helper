{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block title %}{{ 'mfa.title'|trans({}, 'mfa') }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="fa-icon fa-icon--mfa" aria-hidden="true"></i>
            {{ 'mfa.title'|trans({}, 'mfa') }}
        </h1>
        <a href="{{ path('app_profile') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
            <i class="bi bi-arrow-left" aria-hidden="true"></i>
            {{ 'common.back'|trans({}, 'messages') }}
        </a>
    </div>

    {# MFA Status #}
    <div class="fa-alert fa-alert--{{ mfa_enabled ? 'success' : 'warning' }} mb-4" role="alert">
        <div class="d-flex align-items-center">
            {# TODO(aurora-migration): dynamic MFA status icon — keep bi-* #}
            <i class="fa-icon {{ mfa_enabled ? 'fa-icon--compliance-shield' : 'fa-icon--breach' }} fs-1 me-3" aria-hidden="true"></i>
            <div>
                <p class="fw-bold mb-1">
                    {% if mfa_enabled %}
                        {{ 'mfa.enabled'|trans({}, 'mfa') }}
                    {% else %}
                        {{ 'mfa.disabled'|trans({}, 'mfa') }}
                    {% endif %}
                </p>
                <p class="mb-0">
                    {% if mfa_enabled %}
                        {{ 'mfa.enabled_description'|trans({}, 'mfa') }}
                    {% else %}
                        {{ 'mfa.disabled_description'|trans({}, 'mfa') }}
                    {% endif %}
                </p>
            </div>
            {% if not mfa_enabled %}
                <div class="ms-auto">
                    <a href="{{ path('app_profile_mfa_setup_totp') }}" class="fa-cyber-btn fa-cyber-btn--success">
                        <i class="fa-icon fa-icon--mfa" aria-hidden="true"></i>
                        {{ 'mfa.action.setup'|trans({}, 'mfa') }}
                    </a>
                </div>
            {% endif %}
        </div>
    </div>

    {# MFA Statistics #}
    <div class="row mb-4">
        <div class="col-md-4">
            {% embed '_components/_card.html.twig' with { 'variant': 'bordered', 'borderColor': 'primary' } %}
                {% block card_body %}
                    <div class="text-center">
                        <p class="card-title text-muted fw-semibold">{{ 'mfa.statistics.active_tokens'|trans({}, 'mfa') }}</p>
                        <p class="display-6 text-primary">{{ active_tokens_count }}</p>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-4">
            {% embed '_components/_card.html.twig' with { 'variant': 'bordered', 'borderColor': 'info' } %}
                {% block card_body %}
                    <div class="text-center">
                        <p class="card-title text-muted fw-semibold">{{ 'mfa.statistics.total_tokens'|trans({}, 'mfa') }}</p>
                        <p class="display-6 text-info">{{ mfa_tokens|length }}</p>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-4">
            {% embed '_components/_card.html.twig' with { 'variant': 'bordered', 'borderColor': 'success' } %}
                {% block card_body %}
                    <p class="card-title text-muted fw-semibold">{{ 'mfa.statistics.by_type'|trans({}, 'mfa') }}</p>
                    {% if tokens_by_type|length > 0 %}
                        {% for type, count in tokens_by_type %}
                            <div class="d-flex justify-content-between">
                                <span>{{ ('mfa.token_type.' ~ type)|trans({}, 'mfa') }}</span>
                                {% include '_components/_badge.html.twig' with { variant: 'secondary', content: count } %}
                            </div>
                        {% endfor %}
                    {% else %}
                        <p class="text-muted mb-0">{{ 'mfa.no_tokens'|trans({}, 'mfa') }}</p>
                    {% endif %}
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    {# MFA Tokens List #}
    {% embed '_components/_card.html.twig' %}
        {% block card_header %}
            <div class="card-header d-flex justify-content-between align-items-center">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--mfa" aria-hidden="true"></i>
                    {{ 'mfa.my_tokens'|trans({}, 'mfa') }}
                </h2>
                {% if mfa_enabled %}
                    <a href="{{ path('app_profile_mfa_setup_totp') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                        <i class="bi bi-plus-circle" aria-hidden="true"></i>
                        {{ 'mfa.action.add_token'|trans({}, 'mfa') }}
                    </a>
                {% endif %}
            </div>
        {% endblock %}
        {% block card_body %}
            {% if mfa_tokens|length > 0 %}
                {% embed '_components/_table.html.twig' with {
                    'class': 'table-hover',
                    'noMargin': true,
                    'responsive': true
                } %}
                    {% block table_head %}
                        <tr>
                            <th scope="col">{{ 'mfa.token_type_label'|trans({}, 'mfa') }}</th>
                            <th scope="col">{{ 'mfa.device_name'|trans({}, 'mfa') }}</th>
                            <th scope="col">{{ 'mfa.enrolled_at'|trans({}, 'mfa') }}</th>
                            <th scope="col">{{ 'mfa.last_used'|trans({}, 'mfa') }}</th>
                            <th scope="col" class="text-center">{{ 'mfa.usage_count'|trans({}, 'mfa') }}</th>
                            <th scope="col" class="text-center">{{ 'common.status'|trans({}, 'messages') }}</th>
                            <th scope="col" class="text-end">{{ 'common.actions'|trans({}, 'messages') }}</th>
                        </tr>
                    {% endblock %}
                    {% block table_body %}
                        {% for token in mfa_tokens %}
                            <tr class="{{ not token.isActive ? 'table-secondary' : '' }}">
                                <td>
                                    {% if token.tokenType == 'totp' %}
                                        <i class="bi bi-phone" aria-hidden="true"></i> {{ 'mfa.token_type.totp'|trans({}, 'mfa') }}
                                    {% elseif token.tokenType == 'webauthn' %}
                                        <i class="bi bi-fingerprint" aria-hidden="true"></i> {{ 'mfa.token_type.webauthn'|trans({}, 'mfa') }}
                                    {% elseif token.tokenType == 'sms' %}
                                        <i class="bi bi-chat" aria-hidden="true"></i> {{ 'mfa.token_type.sms'|trans({}, 'mfa') }}
                                    {% elseif token.tokenType == 'hardware' %}
                                        <i class="bi bi-cpu" aria-hidden="true"></i> {{ 'mfa.token_type.hardware'|trans({}, 'mfa') }}
                                    {% elseif token.tokenType == 'backup' %}
                                        <i class="bi bi-lock" aria-hidden="true"></i> {{ 'mfa.token_type.backup'|trans({}, 'mfa') }}
                                    {% else %}
                                        <i class="bi bi-question-circle" aria-hidden="true"></i> {{ token.tokenType }}
                                    {% endif %}
                                </td>
                                <td>
                                    {{ token.deviceName ?? '-' }}
                                    {% if token.isPrimary %}
                                        {% include '_components/_badge.html.twig' with { variant: 'primary', content: 'mfa.is_primary'|trans({}, 'mfa') } %}
                                    {% endif %}
                                </td>
                                <td>{{ token.enrolledAt|date('d.m.Y H:i') }}</td>
                                <td>
                                    {% if token.lastUsedAt %}
                                        {{ token.lastUsedAt|date('d.m.Y H:i') }}
                                    {% else %}
                                        <span class="text-muted">{{ 'mfa.never_used'|trans({}, 'mfa') }}</span>
                                    {% endif %}
                                </td>
                                <td class="text-center">
                                    {% include '_components/_badge.html.twig' with { variant: 'info', content: token.usageCount } %}
                                </td>
                                <td class="text-center">
                                    {% if token.isActive %}
                                        {% if token.isExpired %}
                                            {% include '_components/_badge.html.twig' with { variant: 'danger', content: 'mfa.status.expired'|trans({}, 'mfa') } %}
                                        {% else %}
                                            {% include '_components/_badge.html.twig' with { variant: 'success', content: 'mfa.status.active'|trans({}, 'mfa') } %}
                                        {% endif %}
                                    {% else %}
                                        {% include '_components/_badge.html.twig' with { variant: 'secondary', content: 'mfa.status.inactive'|trans({}, 'mfa') } %}
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    <div class="d-flex gap-1">
                                        <a href="{{ path('app_profile_mfa_show', {id: token.id}) }}"
                                           class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
                                           title="{{ 'common.view'|trans({}, 'messages') }}">
                                            <i class="bi bi-eye" aria-hidden="true"></i>
                                        </a>
                                        {% if token.isActive %}
                                            <form method="post"
                                                  action="{{ path('app_profile_mfa_disable', {id: token.id}) }}"
                                                  class="d-inline"
                                                  data-controller="ui-actions"
                                                  data-action="submit->ui-actions#confirm"
                                                  data-ui-actions-message-param="{{ 'mfa.confirm.disable'|trans({}, 'mfa') }}">
                                                <input type="hidden" name="_token"
                                                       value="{{ csrf_token('disable_' ~ token.id) }}">
                                                <button type="submit"
                                                        class="fa-cyber-btn fa-cyber-btn--warning fa-cyber-btn--sm"
                                                        title="{{ 'mfa.action.disable'|trans({}, 'mfa') }}">
                                                    <i class="bi bi-pause-circle" aria-hidden="true"></i>
                                                </button>
                                            </form>
                                        {% endif %}
                                        <form method="post"
                                              action="{{ path('app_profile_mfa_delete', {id: token.id}) }}"
                                              class="d-inline"
                                              data-controller="ui-actions"
                                              data-action="submit->ui-actions#confirm"
                                              data-ui-actions-message-param="{{ 'mfa.confirm.delete'|trans({}, 'mfa') }}">
                                            <input type="hidden" name="_token"
                                                   value="{{ csrf_token('delete_' ~ token.id) }}">
                                            <button type="submit"
                                                    class="fa-cyber-btn fa-cyber-btn--danger fa-cyber-btn--sm"
                                                    title="{{ 'common.delete'|trans({}, 'messages') }}">
                                                <i class="bi bi-trash" aria-hidden="true"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            {% else %}
                {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', class: 'mb-0' } } %}
                    {% block alert_body %}
                    {{ 'mfa.no_tokens_registered'|trans({}, 'mfa') }}
                    <a href="{{ path('app_profile_mfa_setup_totp') }}" class="fa-alert__link">
                        {{ 'mfa.setup_now'|trans({}, 'mfa') }}
                    </a>
                    {% endblock %}
                {% endembed %}
            {% endif %}
        {% endblock %}
    {% endembed %}

    {# Security Recommendations #}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', class: 'mt-4' } } %}
        {% block alert_body %}
        <div class="fa-alert__title">
            <i class="fa-icon fa-icon--mfa" aria-hidden="true"></i>
            {{ 'mfa.security_recommendations.title'|trans({}, 'mfa') }}
        </div>
        <ul class="mb-0">
            <li>{{ 'mfa.security_recommendations.item1'|trans({}, 'mfa') }}</li>
            <li>{{ 'mfa.security_recommendations.item2'|trans({}, 'mfa') }}</li>
            <li>{{ 'mfa.security_recommendations.item3'|trans({}, 'mfa') }}</li>
        </ul>
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
