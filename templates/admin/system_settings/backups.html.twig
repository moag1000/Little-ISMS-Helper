{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'admin' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_cyber_field.html.twig' as _fa_cyber %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block admin_title %}{{ 'admin.backups.title'|trans({}, 'admin') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('admin_settings_index') }}">{{ 'admin.settings.title'|trans({}, 'admin') }}</a></li>
    <li class="breadcrumb-item active" aria-current="page">{{ 'admin.backups.title'|trans({}, 'admin') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'ui-upload', label: 'Backups' },
        title: 'admin.backups.title'|trans({}, 'admin'),
        subtitle: 'admin.backups.subtitle'|trans({}, 'admin'),
    }) }}

    {{ _fa_alert.render({
        variant: 'info',
        title: 'admin.backups.wave2_note.title'|trans({}, 'admin'),
        body: 'admin.backups.wave2_note.body'|trans({}, 'admin')
    }) }}

    <div class="row g-4 mt-2">
        <div class="col-lg-8">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="fa-icon fa-icon--nav-database text-primary" aria-hidden="true"></i>
                        {{ 'admin.backups.settings_title'|trans({}, 'admin') }}
                    </h2>
                </div>
                <div class="fa-section__body">
                    <form method="post" action="{{ path('admin_settings_backups') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('admin_settings_backups') }}">

                        <div class="mb-4">
                            {{ _fa_cyber.text('retention_days', {
                                id: 'retention_days',
                                label: 'admin.backups.retention_days.label'|trans({}, 'admin'),
                                value: current.retention_days,
                                type: 'number',
                                help: 'admin.backups.retention_days.help'|trans({}, 'admin'),
                                attrs: 'min="1" max="3650"'
                            }) }}
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold" for="schedule">
                                {{ 'admin.backups.schedule.label'|trans({}, 'admin') }}
                            </label>
                            <select class="form-select" id="schedule" name="schedule">
                                <option value="off" {% if current.schedule == 'off' %}selected{% endif %}>
                                    {{ 'admin.backups.schedule.off'|trans({}, 'admin') }}
                                </option>
                                <option value="daily" {% if current.schedule == 'daily' %}selected{% endif %}>
                                    {{ 'admin.backups.schedule.daily'|trans({}, 'admin') }}
                                </option>
                                <option value="weekly" {% if current.schedule == 'weekly' %}selected{% endif %}>
                                    {{ 'admin.backups.schedule.weekly'|trans({}, 'admin') }}
                                </option>
                            </select>
                            <div class="form-text">{{ 'admin.backups.schedule.help'|trans({}, 'admin') }}</div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold text-muted">
                                {{ 'admin.backups.storage_path.label'|trans({}, 'admin') }}
                            </label>
                            <div class="form-control bg-body-secondary text-muted" aria-readonly="true">
                                <code>{{ current.storage_path }}</code>
                            </div>
                            <div class="form-text">{{ 'admin.backups.storage_path.help'|trans({}, 'admin') }}</div>
                        </div>

                        <div class="d-flex gap-2">
                            <a href="{{ path('admin_settings_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                                <i class="fa-icon fa-icon--util-arrow-left" aria-hidden="true"></i> {{ 'common.back'|trans({}, 'messages') }}
                            </a>
                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                                <i class="fa-icon fa-icon--ui-save" aria-hidden="true"></i> {{ 'common.save'|trans({}, 'messages') }}
                            </button>
                        </div>
                    </form>
                </div>
            </section>
        </div>

        <div class="col-lg-4">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">{{ 'admin.settings.help'|trans({}, 'admin') }}</h2>
                </div>
                <div class="fa-section__body">
                    <p class="small mb-0">{{ 'admin.backups.help_text'|trans({}, 'admin') }}</p>
                </div>
            </section>
        </div>
    </div>
{% endblock %}
