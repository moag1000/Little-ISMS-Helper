{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'admin' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_settings_table.html.twig' as _fa_settings %}

{% block admin_title %}{{ 'admin.data_retention.title'|trans({}, 'admin') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('admin_settings_index') }}">{{ 'admin.settings.title'|trans({}, 'admin') }}</a></li>
    <li class="breadcrumb-item active" aria-current="page">{{ 'admin.data_retention.title'|trans({}, 'admin') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'archive', label: 'Retention' },
        title: 'admin.data_retention.title'|trans({}, 'admin'),
        subtitle: 'admin.data_retention.subtitle'|trans({}, 'admin'),
    }) }}

    {{ _fa_alert.render({
        variant: 'warning',
        title: 'admin.data_retention.warning.title'|trans({}, 'admin'),
        body: 'admin.data_retention.warning.body'|trans({}, 'admin')
    }) }}

    <div class="row g-4 mt-2">
        <div class="col-lg-10">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="fa-icon fa-icon--nav-archive text-danger" aria-hidden="true"></i>
                        {{ 'admin.data_retention.policies_title'|trans({}, 'admin') }}
                    </h2>
                </div>
                <div class="fa-section__body">
                    <form method="post" action="{{ path('admin_settings_data_retention') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('admin_settings_data_retention') }}">

                        {%- set retention_rows = [] -%}
                        {%- for entity_type in entity_types -%}
                            {%- set entry = current[entity_type] -%}
                            {%- set cap = gdpr_max_days[entity_type] -%}
                            {%- set retention_rows = retention_rows|merge([{
                                kind:  'number',
                                label: ('admin.data_retention.entity.' ~ entity_type)|trans({}, 'admin'),
                                name:  'retention_days_' ~ entity_type,
                                value: entry.retention_days,
                                min:   30,
                                max:   cap > 0 ? cap : null,
                                hint:  cap > 0 ? ('admin.data_retention.gdpr_cap'|trans({'%days%': cap}, 'admin')) : null
                            }]) -%}
                            {%- set retention_rows = retention_rows|merge([{
                                kind:  'toggle',
                                label: 'admin.data_retention.col.auto_delete'|trans({}, 'admin'),
                                name:  'auto_delete_' ~ entity_type,
                                value: entry.auto_delete
                            }]) -%}
                        {%- endfor -%}

                        {{ _fa_settings.render({
                            title: 'admin.data_retention.policies_title'|trans({}, 'admin'),
                            rows:  retention_rows
                        }) }}

                        <div class="d-flex gap-2 mt-4">
                            <a href="{{ path('admin_settings_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                                <i class="fa-icon fa-icon--util-arrow-left" aria-hidden="true"></i> {{ 'common.back'|trans({}, 'messages') }}
                            </a>
                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                                <i class="fa-icon fa-icon--ui-save" aria-hidden="true"></i> {{ 'common.save'|trans({}, 'messages') }}
                            </button>
                        </div>
                    </form>
                </div>
            </section>
        </div>
    </div>
{% endblock %}
