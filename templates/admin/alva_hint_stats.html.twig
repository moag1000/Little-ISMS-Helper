{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'alva' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}

{% block admin_title %}{{ 'alva.stats.title'|trans({}, 'alva') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item active" aria-current="page">{{ 'alva.stats.title'|trans({}, 'alva') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'ui-stars', label: 'Alva' },
        title: 'alva.stats.title'|trans({}, 'alva'),
        subtitle: 'alva.stats.description'|trans({}, 'alva'),
    }) }}

    {% if stats|length == 0 %}
        {{ _fa_empty_state.render({
            mood: 'thinking',
            title: 'alva.stats.empty'|trans({}, 'alva')
        }) }}
    {% else %}
        {% set chart_labels = stats|map(r => r.hintKey) %}
        {% set chart_renders = stats|map(r => r.rendered) %}
        {% set chart_dismiss = stats|map(r => r.total) %}

        <section class="fa-section">
            <div class="fa-section__body">
                <div class="chart-container mb-4" style="max-height:360px;">
                    <canvas data-controller="chart"
                            data-chart-type-value="bar"
                            data-chart-data-value='{"labels":{{ chart_labels|json_encode|raw }},"datasets":[{"label":"{{ 'alva.stats.col.rendered'|trans({}, 'alva')|escape('js') }}","data":{{ chart_renders|json_encode|raw }},"backgroundColor":"#0ea5e9"},{"label":"{{ 'alva.stats.col.total'|trans({}, 'alva')|escape('js') }}","data":{{ chart_dismiss|json_encode|raw }},"backgroundColor":"#7c3aed"}]}'
                            data-chart-options-value='{"indexAxis":"y","scales":{"x":{"beginAtZero":true,"ticks":{"precision":0}}},"plugins":{"legend":{"position":"bottom"}}}'></canvas>
                </div>
            </div>
        </section>

        <section class="fa-section">
            <div class="fa-section__header">
                <h2 class="fa-section__title">{{ 'alva.stats.title'|trans({}, 'alva') }}</h2>
            </div>
            <div class="fa-section__body">
                {% embed '_components/_fa_table.html.twig' with { striped: true } %}
                    {% block table_head %}
                        <tr>
                            <th scope="col" class="fa-table__th">{{ 'alva.stats.col.hint_key'|trans({}, 'alva') }}</th>
                            <th scope="col" class="fa-table__th fa-table__th--num">{{ 'alva.stats.col.rendered'|trans({}, 'alva') }}</th>
                            <th scope="col" class="fa-table__th fa-table__th--num">{{ 'alva.stats.col.total'|trans({}, 'alva') }}</th>
                            <th scope="col" class="fa-table__th fa-table__th--num">{{ 'alva.stats.col.snoozed'|trans({}, 'alva') }}</th>
                            <th scope="col" class="fa-table__th fa-table__th--num">{{ 'alva.stats.col.distinct_users'|trans({}, 'alva') }}</th>
                            <th scope="col" class="fa-table__th fa-table__th--num">{{ 'alva.stats.col.dismiss_rate'|trans({}, 'alva') }}</th>
                        </tr>
                    {% endblock %}
                    {% block table_body %}
                        {% for row in stats %}
                            <tr class="fa-table__row">
                                <td class="fa-table__cell"><code>{{ row.hintKey }}</code></td>
                                <td class="fa-table__cell fa-table__cell--num">{{ row.rendered }}</td>
                                <td class="fa-table__cell fa-table__cell--num">{{ row.total }}</td>
                                <td class="fa-table__cell fa-table__cell--num">{{ row.snoozed }}</td>
                                <td class="fa-table__cell fa-table__cell--num">{{ row.distinctUsers }}</td>
                                <td class="fa-table__cell fa-table__cell--num">{{ row.dismissRate }} %</td>
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            </div>
        </section>
    {% endif %}
{% endblock %}
