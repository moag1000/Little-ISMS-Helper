{% extends 'base.html.twig' %}

{% block title %}{{ 'alva.stats.title'|trans({}, 'alva') }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.admin'|trans({}, 'nav'), url: path('admin_dashboard') },
            { label: 'alva.stats.title'|trans({}, 'alva') }
        ]
    } %}

    <h1 class="h3 mb-4">{{ 'alva.stats.title'|trans({}, 'alva') }}</h1>
    <p class="text-muted small">{{ 'alva.stats.description'|trans({}, 'alva') }}</p>

    {% if stats|length == 0 %}
        <div class="fa-alert fa-alert--info">
            <i class="fa-icon fa-icon--ui-info-circle fa-alert__icon" aria-hidden="true"></i>
            <div class="fa-alert__body">{{ 'alva.stats.empty'|trans({}, 'alva') }}</div>
        </div>
    {% else %}
        <table class="table table-striped">
            <thead>
                <tr>
                    <th scope="col">{{ 'alva.stats.col.hint_key'|trans({}, 'alva') }}</th>
                    <th scope="col" class="text-end">{{ 'alva.stats.col.total'|trans({}, 'alva') }}</th>
                    <th scope="col" class="text-end">{{ 'alva.stats.col.snoozed'|trans({}, 'alva') }}</th>
                    <th scope="col" class="text-end">{{ 'alva.stats.col.distinct_users'|trans({}, 'alva') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for row in stats %}
                    <tr>
                        <td><code>{{ row.hintKey }}</code></td>
                        <td class="text-end">{{ row.total }}</td>
                        <td class="text-end">{{ row.snoozed }}</td>
                        <td class="text-end">{{ row.distinctUsers }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
</div>
{% endblock %}
