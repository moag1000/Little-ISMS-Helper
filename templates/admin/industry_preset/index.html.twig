{% extends 'base.html.twig' %}
{% trans_default_domain 'admin' %}
{% import '_components/_status_pill.html.twig' as pill %}

{% block title %}{{ 'industry_preset.title'|trans }} · {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}

{% block body %}
<main class="fa-aurora-surface">
    {{ _fa_page_header.render({
        badge:    { icon: 'collection', label: 'industry_preset.badge'|trans },
        title:    'industry_preset.title'|trans,
        subtitle: 'industry_preset.subtitle'|trans,
        actions: [
            { label: 'industry_preset.action.admin_hub'|trans, variant: 'ghost', icon: 'arrow-left', href: path('admin_hub_index') }
        ]
    }) }}

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            {% include '_components/_fa_alert.html.twig' with { variant: label == 'error' ? 'danger' : label, content: message } only %}
        {% endfor %}
    {% endfor %}

    {% if presets|length == 0 %}
        {{ _fa_empty_state.render({
            mood: 'idle',
            title: 'industry_preset.empty.title'|trans,
            text: 'industry_preset.empty.text'|trans
        }) }}
    {% else %}
        {# V3 W3-Aurora: Bootstrap .card → Aurora .fa-section per preset. #}
        <div class="row g-3">
            {% for preset in presets %}
                <div class="col-12 col-md-6 col-xl-4">
                    <section class="fa-section h-100">
                        <div class="fa-section__header">
                            <h2 class="fa-section__title mb-1">{{ preset.name }}</h2>
                            <small class="text-muted">{{ preset.id }} · {{ preset.locale|upper }}</small>
                        </div>
                        <div class="fa-section__body">
                            <p class="text-muted small mb-3">{{ preset.description|nl2br }}</p>
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                {{ pill.render(preset.modules_count ~ ' ' ~ 'industry_preset.badge_label.modules'|trans, 'primary', {size: 'sm', icon: 'bi-box'}) }}
                                {{ pill.render(preset.frameworks_count ~ ' ' ~ 'industry_preset.badge_label.frameworks'|trans, 'primary', {size: 'sm', icon: 'bi-shield-check'}) }}
                                {{ pill.render(preset.controls_count ~ ' ' ~ 'industry_preset.badge_label.controls'|trans, 'success', {size: 'sm', icon: 'bi-check2-square'}) }}
                                {{ pill.render(preset.documents_count ~ ' ' ~ 'industry_preset.badge_label.documents'|trans, 'warning', {size: 'sm', icon: 'bi-file-earmark-text'}) }}
                            </div>
                        </div>
                        <div class="fa-section__footer d-flex gap-2 justify-content-end">
                            <a href="{{ path('app_admin_industry_preset_preview', { preset: preset.id }) }}"
                               class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                <i class="bi bi-eye"></i> {{ 'industry_preset.action.preview'|trans }}
                            </a>
                            <form method="post" action="{{ path('app_admin_industry_preset_apply', { preset: preset.id }) }}"
                                  data-controller="ui-actions"
                                  data-action="submit->ui-actions#confirm"
                                  data-ui-actions-message-param="{{ 'industry_preset.confirm.apply_full'|trans }}"
                                  class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('industry_preset_' ~ preset.id) }}">
                                <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--sm">
                                    <i class="bi bi-rocket-takeoff"></i> {{ 'industry_preset.action.apply'|trans }}
                                </button>
                            </form>
                        </div>
                    </section>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</main>
{% endblock %}
