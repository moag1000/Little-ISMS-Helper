{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'admin' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block admin_title %}{{ 'admin.workflows.show.title'|trans({ '%workflow%': workflowName }) }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item">
        <a href="{{ path('admin_workflow_overlay_index') }}">{{ 'admin.workflows.title'|trans }}</a>
    </li>
    <li class="breadcrumb-item active" aria-current="page">{{ workflowName }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'nav-workflow', label: isRegulatory ? 'Regulatory' : 'Lifecycle' },
        title: workflowName,
        subtitle: 'admin.workflows.show.subtitle'|trans,
        actions: [
            {
                label: 'admin.workflows.action.back'|trans,
                href: path('admin_workflow_overlay_index'),
                icon: 'ui-arrow-left',
                variant: 'ghost',
            }
        ],
    }) }}

    <div class="row">
        <div class="col-lg-10">
            {% if steps is empty %}
                {{ _fa_alert.render({
                    variant: 'warning',
                    icon: 'status-warning',
                    body: 'admin.workflows.no_steps'|trans,
                }) }}
                {% if not isRegulatory %}
                    {{ _fa_alert.render({
                        variant: 'info',
                        icon: 'status-info',
                        class: 'mt-2',
                        body: 'admin.workflows.hint.lifecycle_has_transitions'|trans,
                    }) }}
                    <div class="mt-3">
                        <a href="{{ path('admin_lifecycle_overrides_show', {workflowName: workflowName}) }}"
                           class="fa-cyber-btn fa-cyber-btn--primary">
                            <i class="fa-icon fa-icon--nav-workflow" aria-hidden="true"></i>
                            {{ 'admin.workflows.action.edit_transitions'|trans }}
                        </a>
                    </div>
                {% endif %}
            {% else %}
                <section class="fa-section">
                    <div class="fa-section__header">
                        <h2 class="fa-section__title">
                            <i class="fa-icon fa-icon--nav-list-ordered" aria-hidden="true"></i>
                            {{ 'admin.workflows.section.steps'|trans }}
                        </h2>
                        <p class="fa-section__desc text-muted small mb-0">
                            {{ 'admin.workflows.section.steps_desc'|trans({ '%count%': steps|length }) }}
                        </p>
                    </div>
                    <div class="fa-section__body">
                        {% embed '_components/_fa_table.html.twig' with { hover: true } %}
                            {% block table_head %}
                                {% trans_default_domain 'admin' %}
                                <tr>
                                    <th class="fa-table__th fa-table__th--num" style="width:3rem">#</th>
                                    <th class="fa-table__th">{{ 'admin.workflows.col.step_name'|trans }}</th>
                                    <th class="fa-table__th">{{ 'admin.workflows.col.approver_role'|trans }}</th>
                                    <th class="fa-table__th fa-table__th--num">{{ 'admin.workflows.col.days'|trans }}</th>
                                    <th class="fa-table__th">{{ 'admin.workflows.col.overridden_keys'|trans }}</th>
                                    <th class="fa-table__th fa-table__th--actions">{{ 'common.actions'|trans({}, 'messages') }}</th>
                                </tr>
                            {% endblock %}
                            {% block table_body %}
                                {% trans_default_domain 'admin' %}
                                {% for step in steps %}
                                    <tr class="fa-table__row{% if step.has_overrides %} fa-table__row--highlighted{% endif %}">
                                        <td class="fa-table__cell fa-table__cell--num text-muted">
                                            {{ step.index + 1 }}
                                        </td>
                                        <td class="fa-table__cell">
                                            <strong>{{ step.effective.name ?? step.yaml.name ?? ('admin.workflows.step.unnamed'|trans) }}</strong>
                                            {% if step.has_overrides %}
                                                <span class="badge bg-warning text-dark ms-1 small">
                                                    {{ 'admin.workflows.step.overridden'|trans }}
                                                </span>
                                            {% endif %}
                                        </td>
                                        <td class="fa-table__cell">
                                            {% set role = step.effective.approver_role ?? step.effective.approverRole ?? null %}
                                            {% if role %}
                                                <code class="text-primary small">{{ role }}</code>
                                            {% else %}
                                                <span class="fa-table__cell--muted">—</span>
                                            {% endif %}
                                            {% if step.overrides.approverRole is defined %}
                                                <i class="fa-icon fa-icon--status-warning ms-1" aria-label="{{ 'admin.workflows.step.override_active'|trans }}" title="{{ 'admin.workflows.step.override_active'|trans }}"></i>
                                            {% endif %}
                                        </td>
                                        <td class="fa-table__cell fa-table__cell--num">
                                            {% set days = step.effective.days_to_complete ?? step.effective.daysToComplete ?? null %}
                                            {% if days is not null %}
                                                {{ days }}
                                                {% if step.overrides.daysToComplete is defined %}
                                                    <i class="fa-icon fa-icon--status-warning ms-1" aria-label="{{ 'admin.workflows.step.override_active'|trans }}"></i>
                                                {% endif %}
                                            {% else %}
                                                <span class="fa-table__cell--muted">—</span>
                                            {% endif %}
                                        </td>
                                        <td class="fa-table__cell">
                                            {% if step.overrides is not empty %}
                                                {% for key, val in step.overrides %}
                                                    <span class="badge bg-warning text-dark me-1 small">{{ key }}</span>
                                                {% endfor %}
                                            {% else %}
                                                <span class="fa-table__cell--muted">{{ 'admin.workflows.yaml_baseline'|trans }}</span>
                                            {% endif %}
                                        </td>
                                        <td class="fa-table__cell fa-table__cell--actions d-flex gap-1">
                                            <a href="{{ path('admin_workflow_overlay_edit', {name: workflowName, stepIndex: step.index}) }}"
                                               class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
                                               aria-label="{{ 'common.edit'|trans({}, 'messages') }}">
                                                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                                            </a>
                                            {% if step.has_overrides %}
                                                <form method="post"
                                                      action="{{ path('admin_workflow_overlay_reset', {name: workflowName, stepIndex: step.index}) }}"
                                                      onsubmit="return confirm({{ 'admin.workflows.reset_confirm'|trans|json_encode|raw }})">
                                                    <input type="hidden" name="_token"
                                                           value="{{ csrf_token('workflow_step_reset_' ~ workflowName ~ '_' ~ step.index) }}">
                                                    <button type="submit"
                                                            class="fa-cyber-btn fa-cyber-btn--danger fa-cyber-btn--sm"
                                                            aria-label="{{ 'admin.workflows.action.reset'|trans }}">
                                                        <i class="fa-icon fa-icon--ui-trash" aria-hidden="true"></i>
                                                    </button>
                                                </form>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            {% endblock %}
                        {% endembed %}
                        {{ _fa_alert.render({
                            variant: 'info',
                            icon: 'status-info',
                            class: 'mt-3 small',
                            body: 'admin.workflows.hint.yaml_baseline'|trans,
                        }) }}
                    </div>
                </section>
            {% endif %}
        </div>
    </div>
{% endblock %}
