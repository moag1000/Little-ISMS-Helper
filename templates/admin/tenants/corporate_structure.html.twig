{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_kpi_card.html.twig' as _fa_kpi_card %}

{% block admin_title %}{{ 'corporate.title'|trans({}, 'tenant') }}{% endblock %}
{% block admin_subtitle %}
    <p class="text-muted">{{ 'corporate.subtitle'|trans({}, 'tenant') }}</p>
{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('tenant_management_index') }}">{{ 'tenant.title'|trans({}, 'tenant') }}</a></li>
    <li class="breadcrumb-item active">{{ 'corporate.title'|trans({}, 'tenant') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'diagram-3', label: 'corporate.title'|trans({}, 'tenant') },
        title: 'corporate.title'|trans({}, 'tenant'),
        subtitle: 'corporate.subtitle'|trans({}, 'tenant')
    }) }}

    {# Info message when only one tenant exists #}
    {% if not isMultiTenant %}
        {{ _fa_alert.render({ variant: 'info', class: 'mb-4', title: 'corporate.single_tenant.title'|trans({}, 'tenant'), body: 'corporate.single_tenant.message'|trans({'%count%': activeTenantCount}, 'tenant') ~ ' ' ~ 'corporate.single_tenant.hint'|trans({}, 'tenant') }) }}
    {% endif %}

    {# Statistics Cards #}
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            {{ _fa_kpi_card.render({ value: corporateGroups|length, label: 'corporate.stats.groups'|trans({}, 'tenant') }) }}
        </div>
        <div class="col-md-4">
            {{ _fa_kpi_card.render({ value: standaloneTenants|length, label: 'corporate.stats.standalone'|trans({}, 'tenant') }) }}
        </div>
        <div class="col-md-4">
            {{ _fa_kpi_card.render({ value: allTenants|length, label: 'corporate.stats.total'|trans({}, 'tenant') }) }}
        </div>
    </div>

    {# Corporate Groups #}
    {% if corporateGroups is not empty %}
        <section class="fa-section mb-4">
            <div class="fa-section__header">
                <h2 class="fa-section__title">
                    <i class="fa-icon fa-icon--nav-process text-primary" aria-hidden="true"></i>
                    {{ 'corporate.section.groups'|trans({}, 'tenant') }}
                </h2>
            </div>
            <div class="fa-section__body">
                {% for group in corporateGroups %}
                    <section class="fa-section mb-3">
                        <div class="fa-section__header">
                            <div class="d-flex justify-content-between align-items-center w-100">
                                <div>
                                    <h3 class="fa-section__title h6 mb-0">
                                        <i class="fa-icon fa-icon--nav-building text-primary" aria-hidden="true"></i>
                                        <strong>{{ group.name }}</strong>
                                        <code class="text-muted ms-2">{{ group.code }}</code>
                                    </h3>
                                    <small class="text-muted">{{ 'corporate.role.parent'|trans({}, 'tenant') }}</small>
                                </div>
                                <a href="{{ path('tenant_management_show', {id: group.id}) }}"
                                   class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost">
                                    <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i> {{ 'common.view'|trans({}, 'messages') }}
                                </a>
                            </div>
                        </div>
                        <div class="fa-section__body">
                            {% if group.children is not empty %}
                                <div class="list-group list-group-flush">
                                    {% for subsidiary in group.children %}
                                        {{ _self.render_subsidiary(subsidiary, 1) }}
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                    </section>
                {% endfor %}
            </div>
        </section>
    {% endif %}

    {# Standalone Tenants #}
    {% if standaloneTenants is not empty %}
        <section class="fa-section mb-4">
            <div class="fa-section__header">
                <h2 class="fa-section__title">
                    <i class="fa-icon fa-icon--nav-building text-success" aria-hidden="true"></i>
                    {{ 'corporate.section.standalone'|trans({}, 'tenant') }}
                </h2>
            </div>
            <div class="fa-section__body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th scope="col">{{ 'tenant.field.code'|trans({}, 'tenant') }}</th>
                                <th scope="col">{{ 'tenant.field.name'|trans({}, 'tenant') }}</th>
                                <th scope="col">{{ 'corporate.field.actions'|trans({}, 'tenant') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for tenant in standaloneTenants %}
                                <tr>
                                    <td><code class="text-primary">{{ tenant.code }}</code></td>
                                    <td>{{ tenant.name }}</td>
                                    <td>
                                        <button type="button"
                                                class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost"
                                                data-controller="corporate-modals"
                                                data-corporate-modals-tenant-id-value="{{ tenant.id }}"
                                                data-corporate-modals-tenant-name-value="{{ tenant.name }}"
                                                data-action="corporate-modals#showSetParent"
                                                aria-label="{{ 'corporate.action.set_parent'|trans({}, 'tenant') }}">
                                            <i class="fa-icon fa-icon--nav-process" aria-hidden="true"></i> {{ 'corporate.action.set_parent'|trans({}, 'tenant') }}
                                        </button>
                                        <a href="{{ path('tenant_management_show', {id: tenant.id}) }}"
                                           class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost" aria-label="{{ 'common.view'|trans({}, 'messages') }}">
                                            <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    {% endif %}

    {# Info Box #}
    {{ _fa_alert.render({ variant: 'info', title: 'corporate.info.title'|trans({}, 'tenant'), body: 'corporate.info.text'|trans({}, 'tenant') }) }}

    {# Set Parent Modal #}
    <div class="modal fade" id="setParentModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 class="modal-title h5">{{ 'corporate.modal.set_parent.title'|trans({}, 'tenant') }}</h3>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'action.close'|trans({}, 'messages') }}"></button>
                </div>
                <form method="post" id="setParentForm">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label" for="subsidiaryName">{{ 'corporate.field.subsidiary'|trans({}, 'tenant') }}</label>
                            <input type="text" class="form-control fa-cyber-input__field" id="subsidiaryName" readonly>
                            <input type="hidden" id="subsidiaryId">
                        </div>

                        <div class="mb-3">
                            <label for="parentId" class="form-label">{{ 'corporate.field.parent'|trans({}, 'tenant') }}</label>
                            <select class="form-select fa-cyber-input__field" name="parent_id" id="parentId" required>
                                <option value="">{{ 'corporate.select.parent'|trans({}, 'tenant') }}</option>
                                {% for tenant in allTenants %}
                                    <option value="{{ tenant.id }}">{{ tenant.name }} ({{ tenant.code }})</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="governanceModel" class="form-label">{{ 'corporate.field.governance_model'|trans({}, 'tenant') }}</label>
                            <select class="form-select fa-cyber-input__field" name="governance_model" id="governanceModel" required>
                                <option value="">{{ 'corporate.select.governance'|trans({}, 'tenant') }}</option>
                                {% for model in governanceModels %}
                                    <option value="{{ model.value }}">{{ model.label }}</option>
                                {% endfor %}
                            </select>
                            <div class="form-text" id="governanceHelp"></div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost" data-bs-dismiss="modal">
                            {{ 'common.cancel'|trans({}, 'messages') }}
                        </button>
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                            <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i> {{ 'common.save'|trans({}, 'messages') }}
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    {# Update Governance Modal #}
    <div class="modal fade" id="updateGovernanceModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h4 class="modal-title h5">{{ 'corporate.modal.update_governance.title'|trans({}, 'tenant') }}</h4>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'action.close'|trans({}, 'messages') }}"></button>
                </div>
                <form method="post" id="updateGovernanceForm">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label" for="governanceTenantName">{{ 'tenant.field.name'|trans({}, 'tenant') }}</label>
                            <input type="text" class="form-control fa-cyber-input__field" id="governanceTenantName" readonly>
                            <input type="hidden" id="governanceTenantId">
                        </div>

                        <div class="mb-3">
                            <label for="updateGovernanceModel" class="form-label">{{ 'corporate.field.governance_model'|trans({}, 'tenant') }}</label>
                            <select class="form-select fa-cyber-input__field" name="governance_model" id="updateGovernanceModel" required>
                                <option value="">{{ 'corporate.select.governance'|trans({}, 'tenant') }}</option>
                                {% for model in governanceModels %}
                                    <option value="{{ model.value }}">{{ model.label }}</option>
                                {% endfor %}
                            </select>
                            <div class="form-text" id="updateGovernanceHelp"></div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost" data-bs-dismiss="modal">
                            {{ 'common.cancel'|trans({}, 'messages') }}
                        </button>
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                            <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i> {{ 'common.save'|trans({}, 'messages') }}
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        // Global governance descriptions for Stimulus controller access
        window.governanceDescriptions = {
            {% for model in governanceModels %}
            '{{ model.value }}': '{{ model.description|e('js') }}'{{ not loop.last ? ',' : '' }}
            {% endfor %}
        };

        function initCorporateStructure() {
            // Update governance help text when model changes (for setParent modal)
            const governanceModel = document.getElementById('governanceModel');
            if (governanceModel) {
                governanceModel.addEventListener('change', function() {
                    const helpText = document.getElementById('governanceHelp');
                    const description = window.governanceDescriptions[this.value] || '';
                    helpText.textContent = description;
                });
            }

            // Update governance help text when model changes (for update modal)
            const updateGovernanceModel = document.getElementById('updateGovernanceModel');
            if (updateGovernanceModel) {
                updateGovernanceModel.addEventListener('change', function() {
                    const helpText = document.getElementById('updateGovernanceHelp');
                    const description = window.governanceDescriptions[this.value] || '';
                    helpText.textContent = description;
                });
            }
        }

        // Initialize on page load and Turbo navigation
        document.addEventListener('DOMContentLoaded', initCorporateStructure);
        document.addEventListener('turbo:load', initCorporateStructure);
    </script>
{% endblock %}

{# Macro for rendering subsidiaries recursively #}
{% macro render_subsidiary(subsidiary, depth) %}
    <div class="list-group-item" style="padding-left: {{ depth * 2 }}rem;">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                {% for i in 1..depth %}
                    <i class="bi bi-arrow-return-right text-muted" aria-hidden="true"></i>
                {% endfor %}
                <strong>{{ subsidiary.name }}</strong>
                <code class="text-muted ms-2">{{ subsidiary.code }}</code>
                {% if subsidiary.governanceLabel %}
                    {% set governance_variant = {'hierarchical': 'primary', 'shared': 'warning'}[subsidiary.governanceModel]|default('secondary') %}
                    {% if governance_variant == 'warning' %}
                        <span class="fa-status-pill fa-status-pill--warning ms-2">{{ subsidiary.governanceLabel }}</span>
                    {% else %}
                        <span class="badge bg-{{ governance_variant }} ms-2">{{ subsidiary.governanceLabel }}</span>
                    {% endif %}
                {% endif %}
            </div>
            <div class="btn-group btn-group-sm" role="group" aria-label="{{ 'common.actions'|trans({}, 'messages') }}">
                <button type="button"
                        class="fa-cyber-btn fa-cyber-btn--warning"
                        data-controller="corporate-modals"
                        data-corporate-modals-tenant-id-value="{{ subsidiary.id }}"
                        data-corporate-modals-tenant-name-value="{{ subsidiary.name }}"
                        data-corporate-modals-governance-model-value="{{ subsidiary.governanceModel }}"
                        data-action="corporate-modals#showUpdateGovernance"
                        title="{{ 'corporate.action.update_governance'|trans({}, 'tenant') }}"
                        aria-label="{{ 'corporate.action.update_governance'|trans({}, 'tenant') }}">
                    <i class="fa-icon fa-icon--ui-settings" aria-hidden="true"></i>
                </button>
                <a href="{{ path('tenant_management_show', {id: subsidiary.id}) }}"
                   class="fa-cyber-btn fa-cyber-btn--ghost"
                   title="{{ 'common.view'|trans({}, 'messages') }}" aria-label="{{ 'common.view'|trans({}, 'messages') }}">
                    <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
                </a>
                <form method="post" action="{{ path('tenant_management_set_parent', {id: subsidiary.id}) }}" class="d-inline"
                      data-controller="ui-actions"
                      data-action="submit->ui-actions#confirm"
                      data-ui-actions-message-param="{{ 'corporate.confirm.remove_parent'|trans({}, 'tenant') }}">
                    <input type="hidden" name="parent_id" value="">
                    <button type="submit"
                            class="fa-cyber-btn fa-cyber-btn--danger"
                            title="{{ 'corporate.action.remove_parent'|trans({}, 'tenant') }}"
                            aria-label="{{ 'common.close'|trans({}, 'messages') }}">
                        <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>

    {% if subsidiary.children is not empty %}
        {% for child in subsidiary.children %}
            {{ _self.render_subsidiary(child, depth + 1) }}
        {% endfor %}
    {% endif %}
{% endmacro %}
