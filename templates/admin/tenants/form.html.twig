{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'tenant' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_tabs.html.twig' as _fa_tabs %}

{% block admin_title %}
    {% if isEdit %}
        {{ 'tenant.title.edit'|trans({}, 'tenant') }}
    {% else %}
        {{ 'tenant.title.create'|trans({}, 'tenant') }}
    {% endif %}
{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('tenant_management_index') }}">{{ 'tenant.title'|trans({}, 'tenant') }}</a></li>
    {% if isEdit %}
        <li class="breadcrumb-item"><a href="{{ path('tenant_management_show', {id: tenant.id}) }}">{{ tenant.code }}</a></li>
        <li class="breadcrumb-item active">{{ 'common.edit'|trans({}, 'messages') }}</li>
    {% else %}
        <li class="breadcrumb-item active">{{ 'common.create'|trans({}, 'messages') }}</li>
    {% endif %}
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'nav-building', label: isEdit ? 'tenant.title.edit'|trans({}, 'tenant') : 'tenant.title.create'|trans({}, 'tenant') },
        title: isEdit ? 'tenant.form.edit_title'|trans({}, 'tenant') : 'tenant.form.create_title'|trans({}, 'tenant'),
    }) }}

    <div class="row g-4">
        <div class="col-lg-8">
            <section class="fa-section">
                <div class="fa-section__body">
                    {{ form_start(form) }}

                    {{ _fa_tabs.render({
                        id: 'tenant-settings',
                        urlHashSync: true,
                        initialTab: 'tab-general',
                        tabs: [
                            {
                                id: 'tab-general',
                                label: 'tenant.tab.general'|trans({}, 'tenant'),
                                icon: 'ui-settings',
                                body: include('admin/tenants/tabs/_tab_general.html.twig', { form: form, isEdit: isEdit, tenant: tenant is defined ? tenant : null })
                            },
                            {
                                id: 'tab-corporate',
                                label: 'tenant.tab.corporate'|trans({}, 'tenant'),
                                icon: 'nav-building',
                                body: include('admin/tenants/tabs/_tab_corporate.html.twig', { form: form })
                            },
                            {
                                id: 'tab-integration',
                                label: 'tenant.tab.integration'|trans({}, 'tenant'),
                                icon: 'nav-link',
                                body: include('admin/tenants/tabs/_tab_integration.html.twig', { form: form })
                            },
                            {
                                id: 'tab-settings',
                                label: 'tenant.tab.settings'|trans({}, 'tenant'),
                                icon: 'nav-gear',
                                body: include('admin/tenants/tabs/_tab_settings.html.twig', { form: form, isEdit: isEdit, tenant: tenant is defined ? tenant : null })
                            }
                        ]
                    }) }}

                    {# CSRF token — rendered outside tab panels so it is always submitted #}
                    {% if form._token is defined %}
                        {{ form_row(form._token) }}
                    {% endif %}

                    {# Form Actions #}
                    <div class="d-flex justify-content-between mt-4">
                        <a href="{% if isEdit %}{{ path('tenant_management_show', {id: tenant.id}) }}{% else %}{{ path('tenant_management_index') }}{% endif %}"
                           class="fa-cyber-btn fa-cyber-btn--ghost">
                            <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i> {{ 'common.cancel'|trans({}, 'messages') }}
                        </a>
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                            <i class="fa-icon fa-icon--ui-save" aria-hidden="true"></i>
                            {% if isEdit %}
                                {{ 'common.save'|trans({}, 'messages') }}
                            {% else %}
                                {{ 'tenant.action.create'|trans({}, 'tenant') }}
                            {% endif %}
                        </button>
                    </div>

                    {{ form_end(form, {render_rest: false}) }}
                </div>
            </section>
        </div>

        {# Help Sidebar #}
        <div class="col-lg-4">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">{{ 'tenant.help.title'|trans({}, 'tenant') }}</h2>
                </div>
                <div class="fa-section__body">
                    <h3 class="small mb-2 fw-semibold">{{ 'tenant.help.code_title'|trans({}, 'tenant') }}</h3>
                    <p class="small">{{ 'tenant.help.code_text'|trans({}, 'tenant') }}</p>

                    <hr>

                    <h3 class="small mb-2 fw-semibold">{{ 'tenant.help.azure_title'|trans({}, 'tenant') }}</h3>
                    <p class="small">{{ 'tenant.help.azure_text'|trans({}, 'tenant') }}</p>

                    <hr>

                    <h3 class="small mb-2 fw-semibold">{{ 'tenant.help.settings_title'|trans({}, 'tenant') }}</h3>
                    <p class="small">{{ 'tenant.help.settings_text'|trans({}, 'tenant') }}</p>
                </div>
            </section>

            {% if isEdit %}
                <section class="fa-section mt-3">
                    <div class="fa-section__header">
                        <h2 class="fa-section__title">{{ 'tenant.info.metadata'|trans({}, 'tenant') }}</h2>
                    </div>
                    <div class="fa-section__body">
                        {% embed '_components/_fa_table.html.twig' with { compact: true, hover: false } %}
                            {% block table_body %}
                                <tr class="fa-table__row">
                                    <th scope="row" class="fa-table__cell text-muted small">{{ 'common.created'|trans({}, 'messages') }}</th>
                                    <td class="fa-table__cell small">{{ tenant.createdAt|date('d.m.Y H:i') }}</td>
                                </tr>
                                {% if tenant.updatedAt %}
                                    <tr class="fa-table__row">
                                        <th scope="row" class="fa-table__cell text-muted small">{{ 'common.updated'|trans({}, 'messages') }}</th>
                                        <td class="fa-table__cell small">{{ tenant.updatedAt|date('d.m.Y H:i') }}</td>
                                    </tr>
                                {% endif %}
                                <tr class="fa-table__row">
                                    <th scope="row" class="fa-table__cell text-muted small">{{ 'tenant.field.users'|trans({}, 'tenant') }}</th>
                                    <td class="fa-table__cell small">
                                        <span class="fa-status-pill fa-status-pill--primary">{{ tenant.users|length }}</span>
                                    </td>
                                </tr>
                            {% endblock %}
                        {% endembed %}
                    </div>
                </section>
            {% endif %}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script type="text/javascript">
        function initTenantForm() {
            if (window.tenantFormInitialized) return;
            window.tenantFormInitialized = true;

            // Find fields by name attribute instead of ID (more reliable)
            const nameField = document.querySelector('input[name="tenant[name]"]');
            const codeField = document.querySelector('input[name="tenant[code]"]');

            if (!nameField || !codeField) {
                return;
            }

            // Only auto-generate for new tenants (when code is empty)
            const isNewTenant = !codeField.value || codeField.value.trim() === '';

            if (isNewTenant) {
                nameField.addEventListener('input', function() {
                    const name = this.value;
                    let code = name
                        .replace(/ä/g, 'ae')
                        .replace(/ö/g, 'oe')
                        .replace(/ü/g, 'ue')
                        .replace(/Ä/g, 'Ae')
                        .replace(/Ö/g, 'Oe')
                        .replace(/Ü/g, 'Ue')
                        .replace(/ß/g, 'ss')
                        .replace(/\s+/g, '_')
                        .toLowerCase()
                        .replace(/[^a-z0-9_-]/g, '');
                    codeField.value = code;
                });
            }
        }

        // Turbo-compatible initialization
        document.addEventListener('turbo:load', function() {
            window.tenantFormInitialized = false;
            initTenantForm();
        });

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initTenantForm);
        } else {
            initTenantForm();
        }
    </script>
{% endblock %}
