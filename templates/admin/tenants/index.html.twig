{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block admin_title %}{{ 'tenant.title'|trans({}, 'tenant') }}{% endblock %}
{% block admin_subtitle %}
    <p class="text-muted">{{ 'tenant.subtitle'|trans({}, 'tenant') }}</p>
{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item active">{{ 'tenant.title'|trans({}, 'tenant') }}</li>
{% endblock %}

{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}

{% block admin_content %}
    {# Statistics Cards #}
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            {% embed '_components/_card.html.twig' %}
                {% block card_body %}
                    <div class="d-flex align-items-center">
                        <div class="bg-primary bg-opacity-10 p-3 rounded me-3">
                            <i class="bi bi-building text-primary fs-3" aria-hidden="true"></i>
                        </div>
                        <div>
                            <div class="text-muted mb-1 small fw-semibold">{{ 'tenant.stats.total'|trans({}, 'tenant') }}</div>
                            <h2 class="mb-0 h3">{{ totalCount }}</h2>
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-4">
            {% embed '_components/_card.html.twig' %}
                {% block card_body %}
                    <div class="d-flex align-items-center">
                        <div class="bg-success bg-opacity-10 p-3 rounded me-3">
                            <i class="fa-icon fa-icon--status-ok text-success fs-3" aria-hidden="true"></i>
                        </div>
                        <div>
                            <div class="text-muted mb-1 small fw-semibold">{{ 'tenant.stats.active'|trans({}, 'tenant') }}</div>
                            <h2 class="mb-0 h3">{{ activeCount }}</h2>
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-4">
            {% embed '_components/_card.html.twig' %}
                {% block card_body %}
                    <div class="d-flex align-items-center">
                        <div class="bg-secondary bg-opacity-10 p-3 rounded me-3">
                            <i class="fa-icon fa-icon--status-critical text-secondary fs-3" aria-hidden="true"></i>
                        </div>
                        <div>
                            <div class="text-muted mb-1 small fw-semibold">{{ 'tenant.stats.inactive'|trans({}, 'tenant') }}</div>
                            <h2 class="mb-0 h3">{{ inactiveCount }}</h2>
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    {# Toolbar #}
    {% embed '_components/_card.html.twig' with {class: 'mb-4'} %}
        {% block card_body %}
            <div class="d-flex justify-content-between align-items-center">
                {# Filters #}
                <div class="btn-group btn-group-sm" role="group">
                    <a href="{{ path('tenant_management_index', {filter: 'all'}) }}"
                       class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm {% if filter == 'all' %}active{% endif %}">
                        <i class="bi bi-list" aria-hidden="true"></i> {{ 'tenant.filter.all'|trans({}, 'tenant') }}
                    </a>
                    <a href="{{ path('tenant_management_index', {filter: 'active'}) }}"
                       class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm {% if filter == 'active' %}active{% endif %}">
                        <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i> {{ 'tenant.filter.active'|trans({}, 'tenant') }}
                    </a>
                    <a href="{{ path('tenant_management_index', {filter: 'inactive'}) }}"
                       class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm {% if filter == 'inactive' %}active{% endif %}">
                        <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i> {{ 'tenant.filter.inactive'|trans({}, 'tenant') }}
                    </a>
                </div>

                {# Create Button #}
                <a href="{{ path('tenant_management_new') }}" class="fa-cyber-btn fa-cyber-btn--primary">
                    <i class="bi bi-plus-circle" aria-hidden="true"></i> {{ 'tenant.action.create'|trans({}, 'tenant') }}
                </a>
            </div>
        {% endblock %}
    {% endembed %}

    {# Tenant Table #}
    {% embed '_components/_card.html.twig' %}
        {% block card_body %}
            {% if tenants is empty %}
                {{ _fa_empty_state.render({
                    mood: 'sleeping',
                    title: 'tenant.empty'|trans({}, 'tenant'),
                    actions: [
                        { label: 'tenant.action.create_first'|trans({}, 'tenant'), variant: 'primary', icon: 'plus-circle', href: path('tenant_management_new') }
                    ]
                }) }}
            {% else %}
                {% embed '_components/_table.html.twig' with {
                    'class': 'align-middle',
                    'noMargin': true
                } %}
                    {% block table_head %}
                        <tr>
                            <th scope="col" style="width: 60px;">{{ 'tenant.field.logo'|trans({}, 'tenant') }}</th>
                            <th scope="col">{{ 'tenant.field.code'|trans({}, 'tenant') }}</th>
                            <th scope="col">{{ 'tenant.field.name'|trans({}, 'tenant') }}</th>
                            <th scope="col">{{ 'tenant.field.users'|trans({}, 'tenant') }}</th>
                            <th scope="col">{{ 'tenant.field.azure_tenant_id'|trans({}, 'tenant') }}</th>
                            <th scope="col">{{ 'tenant.field.status'|trans({}, 'tenant') }}</th>
                            <th scope="col">{{ 'tenant.field.created'|trans({}, 'tenant') }}</th>
                            <th scope="col" class="text-end">{{ 'common.actions'|trans({}, 'messages') }}</th>
                        </tr>
                    {% endblock %}
                    {% block table_body %}
                        {% for item in tenants %}
                            {% set tenant = item.tenant %}
                            <tr>
                                <td>
                                    {% if tenant.logoPath %}
                                        <img src="{{ asset(tenant.logoPath) }}"
                                             alt="{{ tenant.name }}"
                                             class="rounded"
                                             style="width: 40px; height: 40px; object-fit: contain;">
                                    {% else %}
                                        <div class="bg-body-secondary rounded d-flex align-items-center justify-content-center"
                                             style="width: 40px; height: 40px;">
                                            <i class="bi bi-building text-muted" aria-hidden="true"></i>
                                        </div>
                                    {% endif %}
                                </td>
                                <td>
                                    <code class="text-primary">{{ tenant.code }}</code>
                                </td>
                                <td>
                                    <strong>{{ tenant.name }}</strong>
                                    {% if tenant.description %}
                                        <br><small class="text-muted">{{ tenant.description|u.truncate(50, '...') }}</small>
                                    {% endif %}
                                </td>
                                <td>
                                    {% include '_components/_badge.html.twig' with { variant: 'info', icon: 'bi-people', content: item.userCount } %}
                                </td>
                                <td>
                                    {% if tenant.azureTenantId %}
                                        <small class="font-monospace text-muted">{{ tenant.azureTenantId|u.truncate(20, '...') }}</small>
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if tenant.isActive %}
                                        {% include '_components/_badge.html.twig' with { variant: 'success', icon: 'bi-check-circle', content: 'tenant.status.active'|trans({}, 'tenant') } %}
                                    {% else %}
                                        {% include '_components/_badge.html.twig' with { variant: 'secondary', icon: 'bi-x-circle', content: 'tenant.status.inactive'|trans({}, 'tenant') } %}
                                    {% endif %}
                                </td>
                                <td>
                                    <small class="text-muted">{{ tenant.createdAt|date('d.m.Y') }}</small>
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a href="{{ path('tenant_management_show', {id: tenant.id}) }}"
                                           class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
                                           title="{{ 'common.view'|trans({}, 'messages') }}" aria-label="{{ 'common.view'|trans({}, 'messages') }}">
                                            <i class="bi bi-eye" aria-hidden="true"></i>
                                        </a>
                                        <a href="{{ path('tenant_management_edit', {id: tenant.id}) }}"
                                           class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
                                           title="{{ 'common.edit'|trans({}, 'messages') }}" aria-label="{{ 'common.edit'|trans({}, 'messages') }}">
                                            <i class="bi bi-pencil" aria-hidden="true"></i>
                                        </a>
                                        <form method="post" action="{{ path('tenant_management_toggle', {id: tenant.id}) }}" class="d-inline"
                                              data-controller="ui-actions"
                                              data-action="submit->ui-actions#confirm"
                                              data-ui-actions-message-param="{{ 'tenant.confirm.toggle'|trans({}, 'tenant') }}">
                                            <button type="submit"
                                                    class="fa-cyber-btn fa-cyber-btn--{{ tenant.isActive ? 'warning' : 'ghost' }} fa-cyber-btn--sm"
                                                    title="{{ (tenant.isActive ? 'tenant.action.deactivate' : 'tenant.action.activate')|trans({}, 'tenant') }}"
                                                    aria-label="{{ 'common.view'|trans({}, 'messages') }}">
                                                <i class="fa-icon {% if tenant.isActive %}fa-icon--status-pending{% else %}fa-icon--status-ok{% endif %}" aria-hidden="true"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            {% endif %}
        {% endblock %}
    {% endembed %}

    {# Info Box #}
    {{ _fa_alert.render({ variant: 'info', class: 'mt-4', title: 'tenant.info.title'|trans({}, 'tenant'), body: 'tenant.info.text'|trans({}, 'tenant') }) }}
{% endblock %}
