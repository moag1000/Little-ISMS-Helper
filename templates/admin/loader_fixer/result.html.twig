{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'loader_fixer' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block admin_title %}{{ 'loader_fixer.result.title'|trans({}, 'loader_fixer') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('admin_loader_fixer_index') }}">{{ 'admin.nav.loader_fixer'|trans({}, 'admin') }}</a></li>
    <li class="breadcrumb-item active" aria-current="page">{{ 'loader_fixer.result.title'|trans({}, 'loader_fixer') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'tools', label: 'Loader Fixer' },
        title: 'loader_fixer.result.title'|trans({}, 'loader_fixer'),
        subtitle: 'loader_fixer.result.total_added'|trans({ '%total%': total_added }, 'loader_fixer'),
        actions: [
            { label: 'loader_fixer.action.back'|trans({}, 'loader_fixer'), variant: 'ghost', icon: 'arrow-left', href: path('admin_loader_fixer_index') }
        ]
    }) }}

    {% for code, r in results %}
        <section class="fa-section mb-3">
            <div class="fa-section__header">
                <h2 class="fa-section__title">
                    <code>{{ code }}</code>
                    {% if r.success %}
                        <span class="badge bg-success ms-2">
                            <i class="bi bi-check-circle" aria-hidden="true"></i>
                            {{ 'loader_fixer.result.ok'|trans({}, 'loader_fixer') }}
                        </span>
                    {% else %}
                        <span class="badge bg-danger ms-2">
                            <i class="bi bi-exclamation-triangle" aria-hidden="true"></i>
                            {{ 'loader_fixer.result.failed'|trans({}, 'loader_fixer') }}
                        </span>
                    {% endif %}
                </h2>
                <div class="fa-section__tools small text-muted">
                    {{ 'loader_fixer.result.before'|trans({}, 'loader_fixer') }}: <strong>{{ r.before }}</strong>
                    &middot;
                    {{ 'loader_fixer.result.after'|trans({}, 'loader_fixer') }}: <strong>{{ r.after }}</strong>
                    &middot;
                    {{ 'loader_fixer.result.added'|trans({}, 'loader_fixer') }}:
                    <strong class="{% if r.added > 0 %}text-success{% endif %}">+{{ r.added }}</strong>
                </div>
            </div>
            {% if r.output|trim is not empty %}
                <div class="fa-section__body p-2">
                    <pre class="small bg-body-secondary p-2 mb-0"
                         style="max-height: 200px; overflow: auto;">{{ r.output }}</pre>
                </div>
            {% endif %}
        </section>
    {% endfor %}
{% endblock %}
