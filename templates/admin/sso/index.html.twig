{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'sso' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}

{% block admin_title %}{{ 'sso.admin.title'|trans }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item active" aria-current="page">{{ 'sso.admin.title'|trans }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'shield-lock', label: 'SSO' },
        title: 'sso.admin.title'|trans,
        subtitle: 'sso.admin.subtitle'|trans,
        actions: [
            { label: 'sso.admin.approvals'|trans ~ (pending_count > 0 ? ' (' ~ pending_count ~ ')' : ''), variant: 'ghost', icon: 'person-check', href: path('admin_sso_approvals') },
            { label: 'sso.admin.new_provider'|trans, variant: 'primary', icon: 'plus-lg', href: path('admin_sso_new') }
        ]
    }) }}

    {% if providers|length == 0 %}
        {{ _fa_empty_state.render({
            mood: 'thinking',
            title: 'sso.admin.empty'|trans,
            actions: [
                { label: 'sso.admin.new_provider'|trans, variant: 'primary', icon: 'plus-lg', href: path('admin_sso_new') }
            ]
        }) }}
    {% else %}
        <section class="fa-section">
            <div class="fa-section__body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>{{ 'sso.admin.col.name'|trans }}</th>
                                <th>{{ 'sso.admin.col.slug'|trans }}</th>
                                <th>{{ 'sso.admin.col.scope'|trans }}</th>
                                <th>{{ 'sso.admin.col.type'|trans }}</th>
                                <th>{{ 'sso.admin.col.domains'|trans }}</th>
                                <th>{{ 'sso.admin.col.status'|trans }}</th>
                                <th class="text-end">{{ 'sso.admin.col.actions'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for p in providers %}
                            <tr>
                                <td>
                                    <strong>{{ p.name }}</strong>
                                    {% if p.buttonLabel %}
                                        <div class="text-muted small">{{ p.buttonLabel }}</div>
                                    {% endif %}
                                </td>
                                <td><code>{{ p.slug }}</code></td>
                                <td>
                                    {% if p.global %}
                                        <span class="badge bg-primary">{{ 'sso.scope.global'|trans }}</span>
                                    {% else %}
                                        <span class="badge bg-secondary">{{ p.tenant.name }}</span>
                                    {% endif %}
                                </td>
                                <td><code class="small">{{ p.type }}</code></td>
                                <td class="small">
                                    {% if p.domainBindings|length > 0 %}
                                        {{ p.domainBindings|join(', ') }}
                                        <span class="badge bg-light text-dark border ms-1">{{ ('sso.domain_mode.' ~ p.domainBindingMode)|trans }}</span>
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if p.enabled %}
                                        <span class="badge bg-success">{{ 'sso.status.enabled'|trans }}</span>
                                    {% else %}
                                        <span class="badge bg-secondary">{{ 'sso.status.disabled'|trans }}</span>
                                    {% endif %}
                                    {% if p.autoApprove %}
                                        <span class="badge bg-info ms-1" title="{{ 'sso.field.auto_approve'|trans }}">A</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    <a href="{{ path('admin_sso_edit', {id: p.id}) }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost">
                                        <i class="bi bi-pencil" aria-hidden="true"></i> {{ 'common.edit'|trans({}, 'messages') }}
                                    </a>
                                    <form method="post" action="{{ path('admin_sso_toggle', {id: p.id}) }}" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('sso_provider_toggle') }}">
                                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost">
                                            {{ p.enabled ? 'sso.action.disable'|trans : 'sso.action.enable'|trans }}
                                        </button>
                                    </form>
                                    <form method="post" action="{{ path('admin_sso_delete', {id: p.id}) }}" class="d-inline"
                                          data-confirm="{{ 'sso.confirm.delete'|trans({'%name%': p.name}, 'sso') }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('sso_provider_delete') }}">
                                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--danger">
                                            <i class="bi bi-trash" aria-hidden="true"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    {% endif %}

    {% from '_components/_fa_alert.html.twig' import render as fa_alert %}
    {{ fa_alert({ variant: 'info', body: 'sso.admin.help'|trans|raw, class: 'mt-4 small' }) }}
{% endblock %}
