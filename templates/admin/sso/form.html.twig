{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'sso' %}
{# Aurora form-theme used globally (config/packages/twig.yaml) — no override needed. #}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block admin_title %}{{ (is_new ? 'sso.admin.new_provider' : 'sso.admin.edit_provider')|trans }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('admin_sso_index') }}">{{ 'sso.admin.title'|trans }}</a></li>
    <li class="breadcrumb-item active" aria-current="page">
        {{ (is_new ? 'sso.admin.new_provider' : 'sso.admin.edit_provider')|trans }}
    </li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'shield-lock', label: 'SSO' },
        title: (is_new ? 'sso.admin.new_provider' : 'sso.admin.edit_provider')|trans,
    }) }}

    {{ form_start(form) }}
    <div class="row g-3">
        <div class="col-md-6">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">{{ 'sso.section.identity'|trans }}</h2>
                </div>
                <div class="fa-section__body">
                    {{ form_row(form.slug) }}
                    {{ form_row(form.name) }}
                    {{ form_row(form.type) }}
                    {{ form_row(form.enabled) }}
                    {% if form.tenant is defined %}
                        {{ form_row(form.tenant) }}
                    {% endif %}
                </div>
            </section>
        </div>

        <div class="col-md-6">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">{{ 'sso.section.credentials'|trans }}</h2>
                </div>
                <div class="fa-section__body">
                    {{ form_row(form.clientId) }}
                    {{ form_row(form.clientSecretPlain) }}
                </div>
            </section>
        </div>

        <div class="col-12">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">{{ 'sso.section.endpoints'|trans }}</h2>
                    {% if not is_new %}
                        <div class="fa-section__tools">
                            <form method="post" action="{{ path('admin_sso_test', {id: provider.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('sso_provider_test') }}">
                                <button type="submit" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost">
                                    <i class="bi bi-cloud-arrow-down" aria-hidden="true"></i> {{ 'sso.action.discover'|trans }}
                                </button>
                            </form>
                        </div>
                    {% endif %}
                </div>
                <div class="fa-section__body">
                    {{ form_row(form.discoveryUrl) }}
                    <div class="row g-3">
                        <div class="col-md-6">{{ form_row(form.issuer) }}</div>
                        <div class="col-md-6">{{ form_row(form.jwksUri) }}</div>
                        <div class="col-md-6">{{ form_row(form.authorizationEndpoint) }}</div>
                        <div class="col-md-6">{{ form_row(form.tokenEndpoint) }}</div>
                        <div class="col-md-12">{{ form_row(form.userinfoEndpoint) }}</div>
                    </div>
                </div>
            </section>
        </div>

        <div class="col-md-6">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">{{ 'sso.section.claims'|trans }}</h2>
                </div>
                <div class="fa-section__body">
                    {{ form_row(form.scopesCsv) }}
                    {{ form_row(form.attributeMapJson) }}
                </div>
            </section>
        </div>

        <div class="col-md-6">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">{{ 'sso.section.button'|trans }}</h2>
                </div>
                <div class="fa-section__body">
                    {{ form_row(form.buttonLabel) }}
                    {{ form_row(form.buttonIcon) }}
                    {{ form_row(form.buttonColor) }}
                </div>
            </section>
        </div>

        <div class="col-md-6">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">{{ 'sso.section.domain_binding'|trans }}</h2>
                </div>
                <div class="fa-section__body">
                    {{ form_row(form.domainBindingsCsv) }}
                    {{ form_row(form.domainBindingMode) }}
                </div>
            </section>
        </div>

        <div class="col-md-6">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">{{ 'sso.section.provisioning'|trans }}</h2>
                </div>
                <div class="fa-section__body">
                    {{ form_row(form.jitProvisioning) }}
                    {{ form_row(form.autoApprove) }}
                    {{ form_row(form.defaultRole) }}
                </div>
            </section>
        </div>
    </div>

    <div class="d-flex justify-content-between mt-4">
        <a href="{{ path('admin_sso_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
            <i class="bi bi-arrow-left" aria-hidden="true"></i> {{ 'common.cancel'|trans({}, 'messages') }}
        </a>
        <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
            <i class="bi bi-check-lg" aria-hidden="true"></i> {{ 'common.save'|trans({}, 'messages') }}
        </button>
    </div>
    {{ form_end(form) }}
{% endblock %}
