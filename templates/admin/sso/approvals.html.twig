{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'sso' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}

{% block admin_title %}{{ 'sso.admin.approvals'|trans }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('admin_sso_index') }}">{{ 'sso.admin.title'|trans }}</a></li>
    <li class="breadcrumb-item active" aria-current="page">{{ 'sso.admin.approvals'|trans }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'approve', label: 'SSO' },
        title: 'sso.admin.approvals'|trans,
    }) }}

    {% if approvals|length == 0 %}
        {{ _fa_empty_state.render({
            mood: 'idle',
            title: 'sso.approvals.empty'|trans,
        }) }}
    {% else %}
        {# V3 W3-UX: migrated to fa-table Aurora pattern #}
        {% embed '_components/_fa_table.html.twig' with { hover: true, sortable: true } %}
            {% block table_head %}
                {% trans_default_domain 'sso' %}
                <tr>
                    <th class="fa-table__th fa-table__th--sortable" data-sort-key="email" tabindex="0" role="columnheader" aria-sort="none" data-action="click->fa-table-sort#sort keydown.enter->fa-table-sort#sort keydown.space->fa-table-sort#sort">{{ 'sso.approvals.col.email'|trans }}</th>
                    <th class="fa-table__th">{{ 'sso.approvals.col.provider'|trans }}</th>
                    <th class="fa-table__th">{{ 'sso.approvals.col.tenant'|trans }}</th>
                    <th class="fa-table__th fa-table__th--sortable" data-sort-key="requested" tabindex="0" role="columnheader" aria-sort="none" data-action="click->fa-table-sort#sort keydown.enter->fa-table-sort#sort keydown.space->fa-table-sort#sort">{{ 'sso.approvals.col.requested_at'|trans }}</th>
                    <th class="fa-table__th">{{ 'sso.approvals.col.claims'|trans }}</th>
                    <th class="fa-table__th fa-table__th--actions">{{ 'sso.approvals.col.actions'|trans }}</th>
                </tr>
            {% endblock %}
            {% block table_body %}
                {% trans_default_domain 'sso' %}
                {% for a in approvals %}
                    <tr class="fa-table__row">
                        <td class="fa-table__cell" data-sort-value="{{ a.email }}"><strong>{{ a.email }}</strong></td>
                        <td class="fa-table__cell">{{ a.provider.name }} <code class="small text-muted">{{ a.provider.slug }}</code></td>
                        <td class="fa-table__cell">
                            {% if a.tenant %}
                                {{ a.tenant.name }}
                            {% else %}
                                <span class="fa-status-pill fa-status-pill--primary">{{ 'sso.scope.global'|trans }}</span>
                            {% endif %}
                        </td>
                        <td class="fa-table__cell fa-table__cell--muted" data-sort-value="{{ a.requestedAt ? a.requestedAt|date('Y-m-d H:i') : '' }}">{{ a.requestedAt|date('Y-m-d H:i') }}</td>
                        <td class="fa-table__cell">
                            <details>
                                <summary class="small text-primary" style="cursor: pointer;">{{ 'sso.approvals.show_claims'|trans }}</summary>
                                <pre class="small bg-light p-2 mt-1 mb-0" style="max-width: 480px; overflow-x: auto;">{{ a.claims|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
                            </details>
                        </td>
                        <td class="fa-table__cell fa-table__cell--actions">
                            <form method="post" action="{{ path('admin_sso_approval_approve', {id: a.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('sso_approval') }}">
                                <button type="submit" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--success">
                                    <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i> {{ 'sso.action.approve'|trans }}
                                </button>
                            </form>
                            <form method="post" action="{{ path('admin_sso_approval_reject', {id: a.id}) }}" class="d-inline ms-1"
                                  onsubmit="this.querySelector('[name=reason]').value = prompt('{{ 'sso.prompt.reject_reason'|trans }}') || '';">
                                <input type="hidden" name="_token" value="{{ csrf_token('sso_approval') }}">
                                <input type="hidden" name="reason" value="">
                                <button type="submit" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--danger">
                                    <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i> {{ 'sso.action.reject'|trans }}
                                </button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
            {% endblock %}
        {% endembed %}
    {% endif %}
{% endblock %}
