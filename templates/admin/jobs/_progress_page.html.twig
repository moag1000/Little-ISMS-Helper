{#
 # Shared async-job progress page (admin domain).
 #
 # Reached via 303 redirect from any POST handler that dispatches an
 # async job via JobDispatcher. The PRG (Post/Redirect/Get) pattern is
 # required because Hotwire Turbo refuses to render a 200+HTML body
 # in response to a form submission ("Form responses must redirect to
 # another location"). Returning the redirect lets Turbo follow it
 # naturally to this GET endpoint, which renders the polling card.
 #
 # All per-controller variation (label, subtitle, return URL, optional
 # download link) is stored in the JobStatusService payload under
 # reserved keys (`_label`, `_subtitle`, `_download_url`, `_download_label`)
 # so this single template can serve every async dispatch in the app.
 #
 # Variables (resolved in JobStatusController::progressPage):
 #   jobId          (string)  UUID v4
 #   job_name       (string)  Internal slug from JobStatusService::create()
 #   job_label      (string)  Human-readable title (defaults to job_name)
 #   job_subtitle   (string|null) Optional sub-line above the polling card
 #   cancel_url     (string)  Where the "Back" button returns to
 #   download_url   (string|null) Optional download link revealed on success
 #   download_label (string|null) Optional label for the download button
 #}
{% extends 'base.html.twig' %}
{% trans_default_domain 'admin' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ job_label }} — {{ 'admin.job.progress_page_title'|trans({}, 'admin') }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.admin'|trans({}, 'nav'), url: path('admin_dashboard') },
            { label: job_label }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'nav-tools', label: 'admin.job.badge'|trans({}, 'admin') },
        title: job_label,
        subtitle: job_subtitle|default('admin.job.progress_subtitle_generic'|trans({}, 'admin')),
    }) }}

    {# Turbo cache disabled — live status changes every 3 s #}
    <meta name="turbo-cache-control" content="no-cache">

    <div class="row justify-content-center mt-4">
        <div class="col-lg-8 col-xl-6">
            {% include '_components/_async_job_progress.html.twig' with {
                job_id:         jobId,
                job_name:       job_name,
                job_label:      job_label,
                cancel_url:     cancel_url,
                download_url:   download_url|default(null),
                download_label: download_label|default(null),
            } %}

            <div class="mt-3 text-center text-muted small">
                <i class="fa-icon fa-icon--status-info" aria-hidden="true"></i>
                {{ 'admin.job.worker_hint'|trans({}, 'admin') }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
