{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'tags' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block admin_title %}{{ 'tags.admin.edit.title'|trans({'%name%': tag.name}, 'tags') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('admin_tag_index') }}">{{ 'admin.nav.tags'|trans({}, 'admin') }}</a></li>
    <li class="breadcrumb-item active">{{ tag.name }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'tag', label: 'Tags' },
        title: 'tags.admin.edit.title'|trans({'%name%': tag.name}, 'tags'),
        subtitle: 'tags.admin.page.lead'|trans({}, 'tags'),
    }) }}

    {{ form_start(form) }}
        <section class="fa-section">
            <div class="fa-section__header">
                <h2 class="fa-section__title">{{ 'tags.admin.edit.title'|trans({'%name%': tag.name}, 'tags') }}</h2>
            </div>
            <div class="fa-section__body">
                {{ form_row(form.name) }}
                {{ form_row(form.type) }}
                {{ form_row(form.frameworkCode) }}
                {{ form_row(form.color) }}
                {{ form_row(form.description) }}
            </div>
            <div class="fa-section__footer d-flex gap-2">
                <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                    <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i>
                    {{ 'tags.admin.action.save'|trans({}, 'tags') }}
                </button>
                <a href="{{ path('admin_tag_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                    {{ 'tags.admin.action.cancel'|trans({}, 'tags') }}
                </a>
            </div>
        </section>
    {{ form_end(form) }}
{% endblock %}
