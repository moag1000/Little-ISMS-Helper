{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'admin' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block admin_title %}{{ 'admin.lifecycle_overrides.title'|trans }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item active" aria-current="page">{{ 'admin.lifecycle_overrides.title'|trans }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'nav-flow', label: 'Lifecycle' },
        title: 'admin.lifecycle_overrides.title'|trans,
        subtitle: 'admin.lifecycle_overrides.subtitle'|trans,
    }) }}

    <div class="row">
        <div class="col-lg-10">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="fa-icon fa-icon--nav-flow" aria-hidden="true"></i>
                        {{ 'admin.lifecycle_overrides.section.workflows'|trans }}
                    </h2>
                </div>
                <div class="fa-section__body">
                    {% if workflows is empty %}
                        {{ _fa_alert.render({ variant: 'info', icon: 'status-info', body: 'admin.lifecycle_overrides.no_workflows'|trans }) }}
                    {% else %}
                        {% embed '_components/_fa_table.html.twig' with { hover: true } %}
                            {% block table_head %}
                                {% trans_default_domain 'admin' %}
                                <tr>
                                    <th class="fa-table__th">{{ 'admin.lifecycle_overrides.col.workflow'|trans }}</th>
                                    <th class="fa-table__th">{{ 'admin.lifecycle_overrides.col.description'|trans }}</th>
                                    <th class="fa-table__th fa-table__th--num">{{ 'admin.lifecycle_overrides.col.overrides'|trans }}</th>
                                    <th class="fa-table__th fa-table__th--actions">{{ 'common.actions'|trans({}, 'messages') }}</th>
                                </tr>
                            {% endblock %}
                            {% block table_body %}
                                {% trans_default_domain 'admin' %}
                                {% for wf in workflows %}
                                    {% set desc_key = 'lifecycle.workflow_desc.' ~ wf.name %}
                                    {% set desc = desc_key|trans({}, 'lifecycle') %}
                                    <tr class="fa-table__row">
                                        <td class="fa-table__cell">
                                            <code class="text-primary">{{ wf.name }}</code>
                                        </td>
                                        <td class="fa-table__cell fa-table__cell--muted small">
                                            {{ desc != desc_key ? desc : '—' }}
                                        </td>
                                        <td class="fa-table__cell fa-table__cell--num">
                                            {% if wf.override_count > 0 %}
                                                <span class="badge bg-warning text-dark">{{ wf.override_count }}</span>
                                            {% else %}
                                                <span class="fa-table__cell--muted">—</span>
                                            {% endif %}
                                        </td>
                                        <td class="fa-table__cell fa-table__cell--actions">
                                            <a href="{{ path('admin_lifecycle_overrides_show', {workflowName: wf.name}) }}"
                                               class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
                                               aria-label="{{ 'admin.lifecycle_overrides.action.manage'|trans }}">
                                                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                                                {{ 'admin.lifecycle_overrides.action.manage'|trans }}
                                            </a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            {% endblock %}
                        {% endembed %}
                        {{ _fa_alert.render({
                            variant: 'info',
                            icon: 'status-info',
                            class: 'mt-3 small',
                            body: 'admin.lifecycle_overrides.hint.yaml_baseline'|trans,
                        }) }}
                    {% endif %}
                </div>
            </section>
        </div>
    </div>
{% endblock %}
