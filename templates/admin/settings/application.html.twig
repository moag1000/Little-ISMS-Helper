{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'admin'%}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% block admin_title %}{{ 'admin.settings.application.title'|trans({}, 'admin') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('admin_settings_index') }}">{{ 'admin.settings.title'|trans({}, 'admin') }}</a></li>
    <li class="breadcrumb-item active">{{ 'admin.settings.application.title'|trans({}, 'admin') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'nav-sliders', label: 'Settings' },
        title: 'admin.settings.application.title'|trans({}, 'admin'),
        subtitle: 'admin.settings.application.help_text'|trans({}, 'admin'),
    }) }}

    <div class="row g-4">
        <div class="col-lg-8">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="fa-icon fa-icon--ui-settings text-primary" aria-hidden="true"></i>
                        {{ 'admin.settings.application.title'|trans({}, 'admin') }}
                    </h2>
                </div>
                <div class="fa-section__body">
                    {{ form_start(form) }}
                        {% include '_components/_auto_form.html.twig' with {
                            'form': form,
                            'sections': {
                                'locale_settings': {
                                    'label': 'admin.settings.application.locale_settings'|trans({}, 'admin'),
                                    'fields': ['default_locale', 'supported_locales']
                                },
                                'display_settings': {
                                    'label': 'admin.settings.application.display_settings'|trans({}, 'admin'),
                                    'fields': ['items_per_page', 'timezone', 'date_format', 'datetime_format']
                                }
                            },
                            'col_widths': {
                                'default_locale': 12,
                                'supported_locales': 12,
                                'items_per_page': 12,
                                'timezone': 12,
                                'date_format': 12,
                                'datetime_format': 12
                            },
                            'translation_domain': 'admin'
                        } %}

                        <div class="d-flex justify-content-between mt-4">
                            <a href="{{ path('admin_settings_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                                <i class="fa-icon fa-icon--util-arrow-left" aria-hidden="true"></i> {{ 'common.back'|trans({}, 'messages') }}
                            </a>
                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                                <i class="fa-icon fa-icon--ui-save" aria-hidden="true"></i> {{ 'common.save'|trans({}, 'messages') }}
                            </button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </section>
        </div>

        <div class="col-lg-4">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">{{ 'admin.settings.help'|trans({}, 'admin') }}</h2>
                </div>
                <div class="fa-section__body">
                    <p class="small mb-0">{{ 'admin.settings.application.help_text'|trans({}, 'admin') }}</p>
                </div>
            </section>
        </div>
    </div>
{% endblock %}
