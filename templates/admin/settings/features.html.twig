{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'admin'%}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% block admin_title %}{{ 'admin.settings.features.title'|trans({}, 'admin') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('admin_settings_index') }}">{{ 'admin.settings.title'|trans({}, 'admin') }}</a></li>
    <li class="breadcrumb-item active">{{ 'admin.settings.features.title'|trans({}, 'admin') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'nav-sliders', label: 'Features' },
        title: 'admin.settings.features.title'|trans({}, 'admin'),
        subtitle: 'admin.settings.features.intro'|trans({}, 'admin'),
    }) }}

    <div class="row g-4">
        <div class="col-lg-8">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="fa-icon fa-icon--ui-flag text-success" aria-hidden="true"></i>
                        {{ 'admin.settings.features.title'|trans({}, 'admin') }}
                    </h2>
                </div>
                <div class="fa-section__body">
                    {{ form_start(form) }}
                        {% include '_components/_auto_form.html.twig' with {
                            'form': form,
                            'sections': {
                                'feature_toggles': {
                                    'label': 'admin.settings.features.feature_toggles'|trans({}, 'admin'),
                                    'fields': ['enable_dark_mode', 'enable_global_search', 'enable_quick_view', 'enable_notifications', 'enable_audit_log']
                                }
                            },
                            'col_widths': {
                                'enable_dark_mode': 12,
                                'enable_global_search': 12,
                                'enable_quick_view': 12,
                                'enable_notifications': 12,
                                'enable_audit_log': 12
                            },
                            'translation_domain': 'admin'
                        } %}

                        <div class="d-flex justify-content-between mt-4">
                            <a href="{{ path('admin_settings_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                                <i class="fa-icon fa-icon--util-arrow-left" aria-hidden="true"></i> {{ 'common.back'|trans({}, 'messages') }}
                            </a>
                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--success">
                                <i class="fa-icon fa-icon--ui-save" aria-hidden="true"></i> {{ 'common.save'|trans({}, 'messages') }}
                            </button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </section>
        </div>

        <div class="col-lg-4">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">{{ 'admin.settings.info'|trans({}, 'admin') }}</h2>
                </div>
                <div class="fa-section__body">
                    <p class="small mb-0">{{ 'admin.settings.features.info_text'|trans({}, 'admin') }}</p>
                </div>
            </section>
        </div>
    </div>
{% endblock %}
