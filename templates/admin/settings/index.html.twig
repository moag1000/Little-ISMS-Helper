{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'admin'%}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% block admin_title %}{{ 'admin.settings.title'|trans({}, 'admin') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item active">{{ 'admin.settings.title'|trans({}, 'admin') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'sliders', label: 'Settings' },
        title: 'admin.settings.title'|trans({}, 'admin'),
        subtitle: 'admin.settings.subtitle'|trans({}, 'admin'),
    }) }}

    <div class="row g-4">
        {# Application Settings Card #}
        <div class="col-md-6 col-lg-4">
            <section class="fa-section h-100">
                <div class="fa-section__body">
                    <div class="d-flex align-items-start mb-3">
                        <div class="bg-primary bg-opacity-10 p-3 rounded me-3">
                            <i class="fa-icon fa-icon--ui-settings text-primary fs-2" aria-hidden="true"></i>
                        </div>
                        <div class="flex-grow-1">
                            <h2 class="card-title h5">{{ 'admin.settings.application.title'|trans({}, 'admin') }}</h2>
                            <p class="card-text text-muted small">
                                {{ 'admin.settings.application.description'|trans({}, 'admin') }}
                            </p>
                        </div>
                    </div>
                    {% if settings.application is defined %}
                        <ul class="list-unstyled small">
                            <li><strong>{{ 'admin.settings.application.locale'|trans({}, 'admin') }}:</strong> {{ settings.application.default_locale ?? 'de' }}</li>
                            <li><strong>{{ 'admin.settings.application.timezone'|trans({}, 'admin') }}:</strong> {{ settings.application.timezone ?? 'Europe/Berlin' }}</li>
                            <li><strong>{{ 'admin.settings.application.items_per_page'|trans({}, 'admin') }}:</strong> {{ settings.application.items_per_page ?? 25 }}</li>
                        </ul>
                    {% endif %}
                </div>
                <div class="fa-section__footer">
                    <a href="{{ path('admin_settings_application') }}" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--sm w-100">
                        <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i> {{ 'admin.settings.configure'|trans({}, 'admin') }}
                    </a>
                </div>
            </section>
        </div>

        {# Security Settings Card #}
        <div class="col-md-6 col-lg-4">
            <section class="fa-section h-100">
                <div class="fa-section__body">
                    <div class="d-flex align-items-start mb-3">
                        <div class="bg-danger bg-opacity-10 p-3 rounded me-3">
                            <i class="fa-icon fa-icon--mfa text-danger fs-2" aria-hidden="true"></i>
                        </div>
                        <div class="flex-grow-1">
                            <h2 class="card-title h5">{{ 'admin.settings.security.title'|trans({}, 'admin') }}</h2>
                            <p class="card-text text-muted small">
                                {{ 'admin.settings.security.description'|trans({}, 'admin') }}
                            </p>
                        </div>
                    </div>
                    {% if settings.security is defined %}
                        {% set _session_min = (settings.security.session_timeout_minutes is defined)
                            ? settings.security.session_timeout_minutes
                            : ((settings.security.session_lifetime ?? 3600) / 60) %}
                        {% set _pw_len = settings.security.password_min_length ?? 12 %}
                        {% set _mfa = settings.security.mfa_required_roles is defined
                            ? settings.security.mfa_required_roles
                            : (settings.security.require_2fa ?? false) %}
                        <ul class="list-unstyled small">
                            <li><strong>{{ 'admin.settings.security.session_lifetime'|trans({}, 'admin') }}:</strong> {{ _session_min }} min</li>
                            <li><strong>{{ 'admin.settings.security.password_min_length'|trans({}, 'admin') }}:</strong> {{ _pw_len }}</li>
                            <li><strong>{{ 'admin.settings.security.require_2fa'|trans({}, 'admin') }}:</strong>
                                {% if _mfa is iterable %}
                                    {{ _mfa|length > 0 ? _mfa|join(', ') : ('common.no'|trans({}, 'messages')) }}
                                {% else %}
                                    {{ _mfa ? 'Yes' : 'No' }}
                                {% endif %}
                            </li>
                        </ul>
                    {% endif %}
                </div>
                <div class="fa-section__footer">
                    <a href="{{ path('admin_settings_security') }}" class="fa-cyber-btn fa-cyber-btn--danger fa-cyber-btn--sm w-100">
                        <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i> {{ 'admin.settings.configure'|trans({}, 'admin') }}
                    </a>
                </div>
            </section>
        </div>

        {# Feature Flags Card #}
        <div class="col-md-6 col-lg-4">
            <section class="fa-section h-100">
                <div class="fa-section__body">
                    <div class="d-flex align-items-start mb-3">
                        <div class="bg-success bg-opacity-10 p-3 rounded me-3">
                            <i class="fa-icon text-success fs-2 fa-icon--nav-sliders" aria-hidden="true"></i>
                        </div>
                        <div class="flex-grow-1">
                            <h2 class="card-title h5">{{ 'admin.settings.features.title'|trans({}, 'admin') }}</h2>
                            <p class="card-text text-muted small">
                                {{ 'admin.settings.features.description'|trans({}, 'admin') }}
                            </p>
                        </div>
                    </div>
                    {% if settings.features is defined %}
                        <ul class="list-unstyled small">
                            <li>
                                {% if settings.features.enable_dark_mode|default(false) %}
                                    <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
                                {% else %}
                                    <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i>
                                {% endif %}
                                {{ 'admin.settings.features.dark_mode'|trans({}, 'admin') }}
                            </li>
                            <li>
                                {% if settings.features.enable_global_search|default(false) %}
                                    <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
                                {% else %}
                                    <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i>
                                {% endif %}
                                {{ 'admin.settings.features.global_search'|trans({}, 'admin') }}
                            </li>
                            <li>
                                {% if settings.features.enable_audit_log|default(false) %}
                                    <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
                                {% else %}
                                    <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i>
                                {% endif %}
                                {{ 'admin.settings.features.audit_log'|trans({}, 'admin') }}
                            </li>
                        </ul>
                    {% endif %}
                </div>
                <div class="fa-section__footer">
                    <a href="{{ path('admin_settings_features') }}" class="fa-cyber-btn fa-cyber-btn--success fa-cyber-btn--sm w-100">
                        <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i> {{ 'admin.settings.configure'|trans({}, 'admin') }}
                    </a>
                </div>
            </section>
        </div>
    </div>

    {# Info Alert #}
    {{ _fa_alert.render({ variant: 'info', class: 'mt-4', title: 'admin.settings.info_title'|trans({}, 'admin'), body: 'admin.settings.info_text'|trans({}, 'admin') }) }}
{% endblock %}
