{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_kpi_card.html.twig' as _fa_kpi_card %}
{% block title %}Lizenz-Zusammenfassung{% endblock %}

{% block admin_content %}
<div class="container-fluid">
    {# Breadcrumb Navigation #}
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'Reports', url: path('app_reports_overview') },
            { label: 'Lizenzen', url: path('admin_licensing_index') },
            { label: 'Zusammenfassung' }
        ]
    } %}

    {# Page Header #}
    {{ _fa_page_header.render({
        badge: { icon: 'patch-check', label: 'Licensing' },
        title: 'Lizenz-Compliance Zusammenfassung',
        subtitle: 'Schnellübersicht über die Lizenz-Compliance',
    }) }}

    <div class="row">
        <div class="col-lg-3 mb-4">
            {# Navigation Sidebar #}
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="fa-icon fa-icon--ui-list me-2" aria-hidden="true"></i>Navigation
                    </h2>
                </div>
                <div class="fa-section__body p-0">
                    <div class="list-group list-group-flush">
                        <a href="{{ path('admin_licensing_index') }}" class="list-group-item list-group-item-action">
                            <i class="fa-icon fa-icon--policy me-2" aria-hidden="true"></i>NOTICE
                        </a>
                        <a href="{{ path('admin_licensing_report') }}" class="list-group-item list-group-item-action">
                            <i class="fa-icon fa-icon--nav-reports me-2" aria-hidden="true"></i>Detaillierter Bericht
                        </a>
                        <a href="{{ path('admin_licensing_summary') }}" class="list-group-item list-group-item-action active">
                            <i class="fa-icon fa-icon--nav-bar-chart me-2" aria-hidden="true"></i>Zusammenfassung
                        </a>
                    </div>
                </div>
            </section>
        </div>

        <div class="col-lg-9">
            {% if stats.total > 0 %}
                {# Compliance Status #}
                <div class="row mb-4">
                    <div class="col-12">
                        {% set compliance_percentage = (stats.allowed / stats.total * 100)|round(1) %}
                        {% if compliance_percentage >= 95 %}
                            {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'success' } } %}
                                {% block alert_body %}
                                <div class="d-flex align-items-center">
                                    <div class="flex-shrink-0">
                                        <i class="fa-icon fa-icon--status-ok fs-3 me-3" aria-hidden="true"></i>
                                    </div>
                                    <div>
                                        <div class="fa-alert__title"><i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i> Hervorragend Lizenzkonform</div>
                                        <p class="mb-0">
                                            {{ compliance_percentage }}% der Pakete haben permissive Lizenzen.
                                            Das Projekt ist für kommerzielle Nutzung freigegeben.
                                        </p>
                                    </div>
                                </div>
                                {% endblock %}
                            {% endembed %}
                        {% elseif compliance_percentage >= 80 %}
                            {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info' } } %}
                                {% block alert_body %}
                                <div class="d-flex align-items-center">
                                    <div class="flex-shrink-0">
                                        <i class="fa-icon fa-icon--ui-info fs-3 me-3" aria-hidden="true"></i>
                                    </div>
                                    <div>
                                        <div class="fa-alert__title">✓ Überwiegend Lizenzkonform</div>
                                        <p class="mb-0">
                                            {{ compliance_percentage }}% der Pakete haben permissive Lizenzen.
                                            Einzelne Pakete erfordern besondere Aufmerksamkeit.
                                        </p>
                                    </div>
                                </div>
                                {% endblock %}
                            {% endembed %}
                        {% else %}
                            {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning' } } %}
                                {% block alert_body %}
                                <div class="d-flex align-items-center">
                                    <div class="flex-shrink-0">
                                        <i class="fa-icon fa-icon--status-warning fs-3 me-3" aria-hidden="true"></i>
                                    </div>
                                    <div>
                                        <div class="fa-alert__title"><i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> Prüfung erforderlich</div>
                                        <p class="mb-0">
                                            {{ compliance_percentage }}% der Pakete haben permissive Lizenzen.
                                            Bitte prüfen Sie problematische Lizenzen im Detail.
                                        </p>
                                    </div>
                                </div>
                                {% endblock %}
                            {% endembed %}
                        {% endif %}
                    </div>
                </div>

                {# Statistics Cards #}
                <div class="row mb-4">
                    <div class="col-md-4 mb-3">
                        {{ _fa_kpi_card.render({
                            value: stats.total,
                            label: 'Pakete Gesamt',
                            sublabel: stats.generated_at ? 'Stand: ' ~ stats.generated_at : null,
                        }) }}
                    </div>

                    <div class="col-md-4 mb-3">
                        {{ _fa_kpi_card.render({
                            value: stats.allowed,
                            label: 'Erlaubt',
                            sublabel: (stats.allowed / stats.total * 100)|round(1) ~ '%',
                        }) }}
                    </div>

                    <div class="col-md-4 mb-3">
                        {{ _fa_kpi_card.render({
                            value: stats.restricted + stats.copyleft + stats.not_allowed + stats.unknown,
                            label: 'Prüfung erforderlich',
                            sublabel: ((stats.restricted + stats.copyleft + stats.not_allowed + stats.unknown) / stats.total * 100)|round(1) ~ '%',
                            valueDanger: stats.unknown > 0 or stats.not_allowed > 0,
                        }) }}
                    </div>
                </div>

                {# Detailed Breakdown #}
                <section class="fa-section mb-4">
                    <div class="fa-section__header">
                        <h2 class="fa-section__title">
                            <i class="fa-icon fa-icon--nav-pie-chart me-2" aria-hidden="true"></i>Lizenzverteilung
                        </h2>
                    </div>
                    <div class="fa-section__body">
                        {% embed '_components/_fa_table.html.twig' with { compact: true } %}
                            {% block table_head %}
                                <tr>
                                    <th scope="col" class="fa-table__th">Status</th>
                                    <th scope="col" class="fa-table__th">Beschreibung</th>
                                    <th scope="col" class="fa-table__th fa-table__th--num">Anzahl</th>
                                    <th scope="col" class="fa-table__th fa-table__th--num">Anteil</th>
                                    <th scope="col" class="fa-table__th" style="width: 200px;">Verteilung</th>
                                </tr>
                            {% endblock %}
                            {% block table_body %}
    {% import '_components/_fa_progress.html.twig' as _fa_progress %}
                                <tr class="fa-table__row">
                                    <td class="fa-table__cell"><span class="fa-status-pill fa-status-pill--success"><i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i> Erlaubt</span></td>
                                    <td class="fa-table__cell"><small>Permissive Lizenzen (MIT, BSD, Apache)</small></td>
                                    <td class="fa-table__cell fa-table__cell--num"><strong>{{ stats.allowed }}</strong></td>
                                    <td class="fa-table__cell fa-table__cell--num">{{ (stats.allowed / stats.total * 100)|round(1) }}%</td>
                                    <td class="fa-table__cell">
                                        {{ _fa_progress.render({ value: stats.allowed, max: stats.total, tone: 'success' }) }}
                                    </td>
                                </tr>
                                <tr class="fa-table__row">
                                    <td class="fa-table__cell"><span class="fa-status-pill fa-status-pill--warning"><i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> Eingeschränkt</span></td>
                                    <td class="fa-table__cell"><small>Weak copyleft (MPL, EPL, CC-BY)</small></td>
                                    <td class="fa-table__cell fa-table__cell--num"><strong>{{ stats.restricted }}</strong></td>
                                    <td class="fa-table__cell fa-table__cell--num">{{ (stats.restricted / stats.total * 100)|round(1) }}%</td>
                                    <td class="fa-table__cell">
                                        {{ _fa_progress.render({ value: stats.restricted, max: stats.total, tone: 'warning' }) }}
                                    </td>
                                </tr>
                                <tr class="fa-table__row">
                                    <td class="fa-table__cell"><span class="fa-status-pill fa-status-pill--primary"><i class="fa-icon fa-icon--ui-refresh" aria-hidden="true"></i> Copyleft</span></td>
                                    <td class="fa-table__cell"><small>Strong copyleft (GPL, LGPL, AGPL)</small></td>
                                    <td class="fa-table__cell fa-table__cell--num"><strong>{{ stats.copyleft }}</strong></td>
                                    <td class="fa-table__cell fa-table__cell--num">{{ (stats.copyleft / stats.total * 100)|round(1) }}%</td>
                                    <td class="fa-table__cell">
                                        {{ _fa_progress.render({ value: stats.copyleft, max: stats.total, tone: 'info' }) }}
                                    </td>
                                </tr>
                                <tr class="fa-table__row">
                                    <td class="fa-table__cell"><span class="fa-status-pill fa-status-pill--danger"><i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i> Nicht erlaubt</span></td>
                                    <td class="fa-table__cell"><small>Non-commercial Lizenzen</small></td>
                                    <td class="fa-table__cell fa-table__cell--num"><strong>{{ stats.not_allowed }}</strong></td>
                                    <td class="fa-table__cell fa-table__cell--num">{{ (stats.not_allowed / stats.total * 100)|round(1) }}%</td>
                                    <td class="fa-table__cell">
                                        {{ _fa_progress.render({ value: stats.not_allowed, max: stats.total, tone: 'danger' }) }}
                                    </td>
                                </tr>
                                <tr class="fa-table__row">
                                    <td class="fa-table__cell"><span class="fa-status-pill fa-status-pill--neutral">❓ Unbekannt</span></td>
                                    <td class="fa-table__cell"><small>Manuelle Prüfung erforderlich</small></td>
                                    <td class="fa-table__cell fa-table__cell--num"><strong>{{ stats.unknown }}</strong></td>
                                    <td class="fa-table__cell fa-table__cell--num">{{ (stats.unknown / stats.total * 100)|round(1) }}%</td>
                                    <td class="fa-table__cell">
                                        {{ _fa_progress.render({ value: stats.unknown, max: stats.total, tone: 'neutral' }) }}
                                    </td>
                                </tr>
                            {% endblock %}
                        {% endembed %}
                    </div>
                </section>

                {# Actions Required #}
                {% if stats.unknown > 0 or stats.not_allowed > 0 %}
                    <section class="fa-section mb-4">
                        <div class="fa-section__header">
                            <h2 class="fa-section__title text-warning">
                                <i class="fa-icon fa-icon--status-warning me-2" aria-hidden="true"></i>Handlungsbedarf
                            </h2>
                        </div>
                        <div class="fa-section__body">
                            <ul class="mb-0">
                                {% if stats.unknown > 0 %}
                                    <li><strong>{{ stats.unknown }}</strong> Pakete mit unbekannter Lizenz müssen manuell geprüft werden</li>
                                {% endif %}
                                {% if stats.not_allowed > 0 %}
                                    <li><strong>{{ stats.not_allowed }}</strong> Pakete mit nicht-kommerziellen Lizenzen müssen ersetzt werden</li>
                                {% endif %}
                                {% if stats.copyleft > 0 %}
                                    <li><strong>{{ stats.copyleft }}</strong> Copyleft-Pakete erfordern Quelloffenlegung</li>
                                {% endif %}
                            </ul>
                            <div class="mt-3">
                                <a href="{{ path('admin_licensing_report') }}" class="fa-cyber-btn fa-cyber-btn--warning">
                                    <i class="fa-icon fa-icon--nav-reports" aria-hidden="true"></i>Detailbericht anzeigen
                                </a>
                            </div>
                        </div>
                    </section>
                {% endif %}

                {# Next Steps #}
                <section class="fa-section">
                    <div class="fa-section__header">
                        <h2 class="fa-section__title">
                            <i class="fa-icon fa-icon--nav-list-check me-2" aria-hidden="true"></i>Nächste Schritte
                        </h2>
                    </div>
                    <div class="fa-section__body">
                        <ol class="mb-0">
                            <li>Vollständigen Bericht prüfen: <a href="{{ path('admin_licensing_report') }}">Detailbericht öffnen</a></li>
                            <li>Problematische Lizenzen identifizieren und dokumentieren</li>
                            <li>NOTICE-Datei prüfen: <a href="{{ path('admin_licensing_index') }}">NOTICE anzeigen</a></li>
                            <li>{{ 'admin.licensing.attributions_provided'|trans({}, 'admin') }}</li>
                            <li>Regelmäßig aktualisieren: <code>./license-report.sh</code> ausführen</li>
                        </ol>
                    </div>
                </section>

            {% else %}
                {# No Report Found #}
                {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning' } } %}
                    {% block alert_body %}
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <i class="fa-icon fa-icon--status-warning fs-3 me-3" aria-hidden="true"></i>
                        </div>
                        <div>
                            <div class="fa-alert__title">Kein Bericht gefunden</div>
                            <p class="mb-3">
                                Der Lizenzbericht wurde noch nicht generiert. Bitte führen Sie das folgende Kommando aus:
                            </p>
                            <code>./license-report.sh</code>
                            <p class="mt-3 mb-0">
                                <a href="{{ path('admin_licensing_report') }}" class="fa-cyber-btn fa-cyber-btn--warning">
                                    <i class="fa-icon fa-icon--ui-refresh" aria-hidden="true"></i>Bericht generieren
                                </a>
                            </p>
                        </div>
                    </div>
                    {% endblock %}
                {% endembed %}
            {% endif %}
        </div>
    </div>
</div>
{% endblock admin_content %}
