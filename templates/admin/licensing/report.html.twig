{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block admin_title %}Lizenzbericht - Detailliert{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('app_reports_overview') }}">Reports</a></li>
    <li class="breadcrumb-item"><a href="{{ path('admin_licensing_index') }}">Lizenzen</a></li>
    <li class="breadcrumb-item active" aria-current="page">Detaillierter Bericht</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'nav-patch-check', label: 'Lizenzen' },
        title: 'Detaillierter Lizenzbericht',
        subtitle: 'Vollständige Compliance-Analyse aller Dependencies',
    }) }}

    <div class="row">
        <div class="col-lg-3 mb-4">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="fa-icon fa-icon--ui-list" aria-hidden="true"></i> Navigation
                    </h2>
                </div>
                <div class="fa-section__body p-0">
                    <div class="list-group list-group-flush">
                        <a href="{{ path('admin_licensing_index') }}" class="list-group-item list-group-item-action">
                            <i class="fa-icon fa-icon--policy me-2" aria-hidden="true"></i>NOTICE
                        </a>
                        <a href="{{ path('admin_licensing_report') }}" class="list-group-item list-group-item-action active">
                            <i class="fa-icon fa-icon--nav-reports me-2" aria-hidden="true"></i>Detaillierter Bericht
                        </a>
                        <a href="{{ path('admin_licensing_summary') }}" class="list-group-item list-group-item-action">
                            <i class="fa-icon fa-icon--nav-bar-chart me-2" aria-hidden="true"></i>Zusammenfassung
                        </a>
                    </div>
                </div>
            </section>

            <section class="fa-section mt-3">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="fa-icon fa-icon--nav-tools" aria-hidden="true"></i> Aktionen
                    </h2>
                </div>
                <div class="fa-section__body">
                    <div class="d-grid gap-2">
                        <button data-controller="ui-actions" data-action="ui-actions#print" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                            <i class="fa-icon fa-icon--ui-printer" aria-hidden="true"></i>Drucken
                        </button>
                        <a href="{{ asset('docs/reports/license-report.md') }}" download class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                            <i class="fa-icon fa-icon--nav-download" aria-hidden="true"></i>Report.md
                        </a>
                        <button class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
                                data-controller="report-regenerate"
                                data-action="click->report-regenerate#regenerate"
                                data-report-regenerate-url-value="{{ path('app_licenses_generate') }}"
                                data-report-regenerate-loading-text-value="{{ 'common.generating_reports'|trans({}, 'messages') }}"
                                data-report-regenerate-success-text-value="{{ 'common.report_regenerated'|trans({}, 'messages') }}">
                            <i class="fa-icon fa-icon--ui-refresh me-1" aria-hidden="true"></i>{{ 'common.regenerate'|trans({}, 'messages') }}
                        </button>
                    </div>
                    <div class="mt-3">
                        <small class="text-muted">
                            <i class="fa-icon fa-icon--ui-info me-1" aria-hidden="true"></i>
                            Bericht lokal mit <code>./license-report.sh</code> aktualisieren
                        </small>
                    </div>
                </div>
            </section>
        </div>

        <div class="col-lg-9">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="fa-icon fa-icon--nav-reports" aria-hidden="true"></i> Vollständiger Compliance-Report
                    </h2>
                    <div class="fa-section__tools">
                        <div class="btn-group btn-group-sm" role="group" data-controller="ui-actions">
                            <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm" data-action="ui-actions#setFontSize" data-ui-actions-size-param="13px" data-ui-actions-target-param="#report-content">
                                <i class="fa-icon fa-icon--util-zoom-out" aria-hidden="true"></i>
                            </button>
                            <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm" data-action="ui-actions#setFontSize" data-ui-actions-size-param="14px" data-ui-actions-target-param="#report-content">
                                <i class="fa-icon fa-icon--util-zoom-in" aria-hidden="true"></i>
                            </button>
                        </div>
                    </div>
                </div>
                <div class="fa-section__body p-0">
                    <div id="report-content" class="markdown-content p-4" style="font-size: 13px; max-height: 80vh; overflow-y: auto;">
                        {{ report_content|raw|nl2br }}
                    </div>
                </div>
            </section>

            <section class="fa-section mt-3">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="fa-icon fa-icon--nav-help" aria-hidden="true"></i> Legende
                    </h2>
                </div>
                <div class="fa-section__body">
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <span class="fa-status-pill fa-status-pill--success me-2"><i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i> Erlaubt</span>
                            <small>Permissive Lizenzen (MIT, BSD, Apache-2.0)</small>
                        </div>
                        <div class="col-md-6 mb-2">
                            <span class="fa-status-pill fa-status-pill--warning me-2"><i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> Eingeschränkt</span>
                            <small>Weak copyleft (MPL-2.0, EPL, CC-BY)</small>
                        </div>
                        <div class="col-md-6 mb-2">
                            <span class="fa-status-pill fa-status-pill--primary me-2"><i class="fa-icon fa-icon--ui-refresh" aria-hidden="true"></i> Copyleft</span>
                            <small>Strong copyleft (GPL/LGPL/AGPL)</small>
                        </div>
                        <div class="col-md-6 mb-2">
                            <span class="fa-status-pill fa-status-pill--danger me-2"><i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i> Nicht erlaubt</span>
                            <small>Non-commercial licenses</small>
                        </div>
                        <div class="col-md-6 mb-2">
                            <span class="fa-status-pill fa-status-pill--neutral me-2">❓ Unbekannt</span>
                            <small>Manuelle Prüfung erforderlich</small>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </div>

<style>
.markdown-content {
    line-height: 1.6;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.markdown-content h1 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-top: 1.5rem;
    margin-bottom: 1rem;
    border-bottom: 2px solid var(--border);
    padding-bottom: 0.5rem;
}

.markdown-content h2 {
    font-size: 1.4rem;
    font-weight: 600;
    margin-top: 1.25rem;
    margin-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.25rem;
}

.markdown-content h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-top: 1rem;
    margin-bottom: 0.5rem;
}

.markdown-content p {
    margin-bottom: 0.75rem;
}

.markdown-content code {
    background-color: var(--surface-2);
    padding: 0.2rem 0.4rem;
    border-radius: 3px;
    font-size: 0.85em;
}

.markdown-content pre {
    background-color: var(--surface-2);
    padding: 0.75rem;
    border-radius: 5px;
    overflow-x: auto;
    font-size: 0.85em;
}

.markdown-content table {
    width: 100%;
    margin-bottom: 1rem;
    border-collapse: collapse;
    font-size: 0.9em;
}

.markdown-content table th,
.markdown-content table td {
    padding: 0.5rem;
    border: 1px solid var(--border);
}

.markdown-content table th {
    background-color: var(--surface-2);
    font-weight: 600;
}

.markdown-content ul,
.markdown-content ol {
    margin-bottom: 0.75rem;
    padding-left: 1.5rem;
}

.markdown-content blockquote {
    border-left: 4px solid var(--primary);
    padding-left: 1rem;
    margin-left: 0;
    color: var(--fg-3);
    font-style: italic;
}

.markdown-content details {
    margin-bottom: 1rem;
    border: 1px solid var(--border);
    border-radius: 0.25rem;
    padding: 0.5rem;
}

.markdown-content details summary {
    cursor: pointer;
    font-weight: 600;
    padding: 0.5rem;
    background-color: var(--surface-2);
    border-radius: 0.25rem;
}

.markdown-content details summary:hover {
    background-color: var(--surface-3);
}

@media print {
    .breadcrumb,
    .page-header-actions,
    .fa-section:not(.fa-section:has(.markdown-content)),
    .btn,
    .fa-cyber-btn {
        display: none !important;
    }

    #report-content {
        max-height: none !important;
        overflow-y: visible !important;
    }
}
</style>
{% endblock %}
