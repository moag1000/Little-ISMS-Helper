{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_cyber_field.html.twig' as _fa_cyber %}
{% import '_components/_status_pill.html.twig' as pill %}

{% block admin_title %}{{ 'admin.tour_completion.title'|trans({}, 'admin') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item active" aria-current="page">{{ 'admin.tour_completion.title'|trans({}, 'admin') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'compass', label: 'Tours' },
        title: 'admin.tour_completion.title'|trans({}, 'admin'),
        subtitle: 'admin.tour_completion.description'|trans({}, 'admin'),
        actions: [
            { label: 'admin.tour_completion.export_csv'|trans({}, 'admin'), variant: 'ghost', icon: 'download', href: path('admin_tour_completion_export') }
        ]
    }) }}

    {# Stats strip #}
    <div class="row g-3 mb-3">
        <div class="col-md-6">
            <section class="fa-section h-100">
                <div class="fa-section__body">
                    <div class="py-2 px-3">
                        <div class="small text-muted">{{ 'admin.tour_completion.stats.total_users'|trans({}, 'admin') }}</div>
                        <div class="h4 mb-0">{{ total_users }}</div>
                    </div>
                </div>
            </section>
        </div>
        <div class="col-md-6">
            {% set _rate = total_users > 0 ? (completion_count * 100 / total_users)|round : 0 %}
            {% set _variant = _rate >= 80 ? 'success' : (_rate >= 50 ? 'warning' : 'danger') %}
            <section class="fa-section h-100 border-{{ _variant }}">
                <div class="fa-section__body">
                    <div class="py-2 px-3">
                        <div class="small text-muted">{{ 'admin.tour_completion.stats.completion_rate'|trans({}, 'admin') }}</div>
                        <div class="h4 mb-0 text-{{ _variant }}">
                            {{ _rate }} %
                            <small class="fs-6 text-muted">({{ completion_count }}/{{ total_users }})</small>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </div>

    {# Filter-Bar #}
    <section class="fa-section mb-3">
        <div class="fa-section__body">
            <form method="get">
                <div class="row g-2">
                    <div class="col-md-5">
                        {{ _fa_cyber.text('q', {
                            type: 'search',
                            value: search,
                            placeholder: 'admin.tour_completion.filter.search_placeholder'|trans({}, 'admin')
                        }) }}
                    </div>
                    <div class="col-md-3">
                        <select name="role" class="form-select form-select-sm fa-cyber-input__field">
                            <option value="">{{ 'admin.tour_completion.filter.role_all'|trans({}, 'admin') }}</option>
                            {% for t in tours %}
                                <option value="{{ t }}" {% if role_filter == t %}selected{% endif %}>
                                    {{ ('guided_tour.' ~ t ~ '.meta.label')|trans({}, 'guided_tour') }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-3 d-flex align-items-center">
                        <div class="form-check">
                            <input type="checkbox" id="only-incomplete" name="only_incomplete"
                                   value="1" class="form-check-input"
                                   {% if only_incomplete %}checked{% endif %}>
                            <label for="only-incomplete" class="form-check-label small">
                                {{ 'admin.tour_completion.filter.only_incomplete'|trans({}, 'admin') }}
                            </label>
                        </div>
                    </div>
                    <div class="col-md-1">
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--sm w-100">
                            <i class="fa-icon fa-icon--filter" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </section>

    {# Table #}
    <section class="fa-section">
        <div class="fa-section__body">
            {% embed '_components/_fa_table.html.twig' %}
                {% block table_head %}
                    <tr>
                        <th scope="col" class="fa-table__th">{{ 'admin.tour_completion.col.user'|trans({}, 'admin') }}</th>
                        <th scope="col" class="fa-table__th">{{ 'admin.tour_completion.col.auto_role'|trans({}, 'admin') }}</th>
                        {% for t in tours %}
                            <th scope="col" class="fa-table__th fa-table__th--center small">
                                {{ ('guided_tour.' ~ t ~ '.meta.label')|trans({}, 'guided_tour')|split(' ')|first }}
                            </th>
                        {% endfor %}
                        <th scope="col" class="fa-table__th fa-table__th--actions">{{ 'admin.tour_completion.col.actions'|trans({}, 'admin') }}</th>
                    </tr>
                {% endblock %}
                {% block table_body %}
                    {% import '_components/_status_pill.html.twig' as pill %}
                    {% if rows|length == 0 %}
                        <tr class="fa-table__row">
                            <td colspan="{{ 3 + tours|length }}" class="fa-table__empty">
                                {{ 'admin.tour_completion.empty'|trans({}, 'admin') }}
                            </td>
                        </tr>
                    {% else %}
                        {% for row in rows %}
                            <tr class="fa-table__row">
                                <td class="fa-table__cell">
                                    <div class="fw-semibold">{{ row.user.fullName|default(row.user.email) }}</div>
                                    <div class="small text-muted">{{ row.user.email }}</div>
                                </td>
                                <td class="fa-table__cell">
                                    {{ pill.render(row.auto_role, 'neutral', {size: 'sm'}) }}
                                </td>
                                {% for t in tours %}
                                    <td class="fa-table__cell fa-table__cell--center">
                                        {% if t in row.completed_tours %}
                                            <i class="fa-icon fa-icon--status-ok" aria-label="{{ 'admin.tour_completion.completed'|trans({}, 'admin') }}"></i>
                                        {% else %}
                                            <i class="fa-icon text-muted fa-icon--status-pending" aria-label="{{ 'admin.tour_completion.not_completed'|trans({}, 'admin') }}"></i>
                                        {% endif %}
                                    </td>
                                {% endfor %}
                                <td class="fa-table__cell fa-table__cell--actions">
                                    {% if row.completed_tours|length > 0 %}
                                        <form method="post"
                                              action="{{ path('admin_tour_completion_reset', {id: row.user.id, role: 'all'}) }}"
                                              class="d-inline"
                                              data-controller="ui-actions"
                                              data-action="submit->ui-actions#confirm"
                                              data-ui-actions-message-param="{{ 'admin.tour_completion.confirm_reset'|trans({'%user%': row.user.email}, 'admin') }}"
                                              data-ui-actions-tone-param="danger">
                                            <input type="hidden" name="_token" value="{{ csrf_token('admin_tour_reset_' ~ row.user.id) }}">
                                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost"
                                                    title="{{ 'admin.tour_completion.reset_all'|trans({}, 'admin') }}">
                                                <i class="fa-icon fa-icon--ui-refresh" aria-hidden="true"></i>
                                            </button>
                                        </form>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    {% endif %}
                {% endblock %}
            {% endembed %}
        </div>
    </section>

    {{ _fa_alert.render({ variant: 'info', class: 'small mt-3', body: 'admin.tour_completion.audit_hint'|trans({}, 'admin')|raw }) }}
{% endblock %}
