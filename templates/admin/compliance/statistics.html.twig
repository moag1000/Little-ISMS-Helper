{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block admin_title %}<i class="bi bi-graph-up" aria-hidden="true"></i> {{ 'admin.compliance.statistics'|trans({}, 'admin') }}{% endblock %}

{% block title %}{{ 'admin.compliance.statistics'|trans({}, 'admin') }} - {{ 'admin.panel.title'|trans({}, 'admin') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('admin_compliance_index') }}">{{ 'admin.nav.compliance_management'|trans({}, 'admin') }}</a></li>
    <li class="breadcrumb-item active" aria-current="page">{{ 'admin.compliance.statistics'|trans({}, 'admin') }}</li>
{% endblock %}

{% block admin_content %}
<div class="container-fluid">
    <div class="d-flex justify-content-end mb-4">
        <a href="{{ path('admin_compliance_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
            <i class="bi bi-arrow-left" aria-hidden="true"></i> {{ 'common.back'|trans({}, 'messages') }}
        </a>
    </div>

    {# Overall Statistics #}
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' with { 'class': 'border-primary' } %}
                {% block card_body %}
                    <div class="text-center">
                        <div class="small fw-semibold text-muted mb-1">{{ 'admin.compliance.total_available'|trans({}, 'admin') }}</div>
                        <p class="mb-0 h2">{{ statistics.total_available }}</p>
                        <i class="bi bi-box fs-3 text-primary opacity-25" aria-hidden="true"></i>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' with { 'class': 'border-success' } %}
                {% block card_body %}
                    <div class="text-center">
                        <div class="small fw-semibold text-muted mb-1">{{ 'admin.compliance.loaded'|trans({}, 'admin') }}</div>
                        <p class="mb-0 text-success h2">{{ statistics.total_loaded }}</p>
                        <i class="fa-icon fa-icon--status-ok fs-3 text-success opacity-25" aria-hidden="true"></i>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' with { 'class': 'border-secondary' } %}
                {% block card_body %}
                    <div class="text-center">
                        <div class="small fw-semibold text-muted mb-1">{{ 'admin.compliance.not_loaded'|trans({}, 'admin') }}</div>
                        <p class="mb-0 text-secondary h2">{{ statistics.total_not_loaded }}</p>
                        <i class="fa-icon fa-icon--status-critical fs-3 text-secondary opacity-25" aria-hidden="true"></i>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' with { 'class': 'border-danger' } %}
                {% block card_body %}
                    <div class="text-center">
                        <div class="small fw-semibold text-muted mb-1">{{ 'admin.compliance.mandatory_missing'|trans({}, 'admin') }}</div>
                        <p class="mb-0 text-danger h2">{{ statistics.mandatory_not_loaded }}</p>
                        <i class="fa-icon fa-icon--status-warning fs-3 text-danger opacity-25" aria-hidden="true"></i>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    {# Compliance per Framework #}
    {% if compliance_data|length > 0 %}
        {% embed '_components/_card.html.twig' %}
            {% block card_header %}
                <div class="card-header">
                    <h2 class="mb-0">
                        <i class="bi bi-bar-chart" aria-hidden="true"></i> {{ 'admin.compliance.compliance_overview'|trans({}, 'admin') }}
                    </h2>
                </div>
            {% endblock %}
            {% block card_body %}
                {% embed '_components/_table.html.twig' with {
                    'class': 'table-hover',
                    'noMargin': true,
                    'responsive': true
                } %}
                    {% block table_head %}
                        <tr>
                            <th scope="col">{{ 'admin.compliance.framework'|trans({}, 'admin') }}</th>
                            <th scope="col" class="text-center">{{ 'admin.compliance.total_requirements'|trans({}, 'admin') }}</th>
                            <th scope="col" class="text-center">{{ 'admin.compliance.assessed'|trans({}, 'admin') }}</th>
                            <th scope="col" class="text-center">{{ 'admin.compliance.compliant'|trans({}, 'admin') }}</th>
                            <th scope="col" class="text-center">{{ 'admin.compliance.compliance_rate'|trans({}, 'admin') }}</th>
                            <th scope="col" class="text-center">{{ 'admin.compliance.progress'|trans({}, 'admin') }}</th>
                        </tr>
                    {% endblock %}
                    {% block table_body %}
                        {% for data in compliance_data %}
                            <tr>
                                <td>
                                    <strong>{{ data.framework.name }}</strong><br>
                                    <small class="text-muted">{{ data.framework.code }}</small>
                                </td>
                                <td class="text-center">
                                    {% include '_components/_badge.html.twig' with { variant: 'secondary', content: data.total_requirements } %}
                                </td>
                                <td class="text-center">
                                    {% include '_components/_badge.html.twig' with { variant: 'info', content: data.assessed_requirements } %}
                                </td>
                                <td class="text-center">
                                    {% include '_components/_badge.html.twig' with { variant: 'success', content: data.compliant_requirements } %}
                                </td>
                                <td class="text-center">
                                    <strong class="{% if data.compliance_percentage >= 75 %}text-success{% elseif data.compliance_percentage >= 50 %}text-warning{% else %}text-danger{% endif %}">
                                        {{ data.compliance_percentage }}%
                                    </strong>
                                </td>
                                <td>
                                    <div class="progress progress-h-25">
                                        <div class="progress-bar {% if data.compliance_percentage >= 75 %}bg-success{% elseif data.compliance_percentage >= 50 %}bg-warning{% else %}bg-danger{% endif %}"
                                             role="progressbar"
                                             style="width: {{ data.compliance_percentage }}%"
                                             aria-valuenow="{{ data.compliance_percentage }}"
                                             aria-valuemin="0"
                                             aria-valuemax="100">
                                            {{ data.compliance_percentage }}%
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            {% endblock %}
        {% endembed %}
    {% else %}
        {{ _fa_alert.render({ variant: 'info', body: 'admin.compliance.no_frameworks_loaded'|trans({}, 'admin') }) }}
    {% endif %}
</div>
{% endblock admin_content %}
