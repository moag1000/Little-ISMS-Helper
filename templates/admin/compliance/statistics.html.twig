{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_kpi_card.html.twig' as _fa_kpi_card %}
{% block admin_title %}{{ 'admin.compliance.statistics'|trans({}, 'admin') }}{% endblock %}

{% block title %}{{ 'admin.compliance.statistics'|trans({}, 'admin') }} - {{ 'admin.panel.title'|trans({}, 'admin') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('admin_compliance_index') }}">{{ 'admin.nav.compliance_management'|trans({}, 'admin') }}</a></li>
    <li class="breadcrumb-item active" aria-current="page">{{ 'admin.compliance.statistics'|trans({}, 'admin') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'nav-bar-chart', label: 'Statistics' },
        title: 'admin.compliance.statistics'|trans({}, 'admin'),
        actions: [
            { label: 'common.back'|trans({}, 'messages'), variant: 'ghost', icon: 'util-arrow-left', href: path('admin_compliance_index') }
        ]
    }) }}

    {# Overall Statistics #}
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            {{ _fa_kpi_card.render({
                value: statistics.total_available,
                label: 'admin.compliance.total_available'|trans({}, 'admin')
            }) }}
        </div>
        <div class="col-md-3">
            {{ _fa_kpi_card.render({
                value: statistics.total_loaded,
                label: 'admin.compliance.loaded'|trans({}, 'admin')
            }) }}
        </div>
        <div class="col-md-3">
            {{ _fa_kpi_card.render({
                value: statistics.total_not_loaded,
                label: 'admin.compliance.not_loaded'|trans({}, 'admin')
            }) }}
        </div>
        <div class="col-md-3">
            {{ _fa_kpi_card.render({
                value: statistics.mandatory_not_loaded,
                label: 'admin.compliance.mandatory_missing'|trans({}, 'admin'),
                valueDanger: statistics.mandatory_not_loaded > 0
            }) }}
        </div>
    </div>

    {# Compliance per Framework #}
    {% if compliance_data|length > 0 %}
        <section class="fa-section">
            <div class="fa-section__header">
                <h2 class="fa-section__title">
                    <i class="fa-icon fa-icon--nav-bar-chart" aria-hidden="true"></i> {{ 'admin.compliance.compliance_overview'|trans({}, 'admin') }}
                </h2>
            </div>
            <div class="fa-section__body">
                {% embed '_components/_fa_table.html.twig' %}
                    {% block table_head %}
                        <tr>
                            <th scope="col" class="fa-table__th">{{ 'admin.compliance.framework'|trans({}, 'admin') }}</th>
                            <th scope="col" class="fa-table__th fa-table__th--center">{{ 'admin.compliance.total_requirements'|trans({}, 'admin') }}</th>
                            <th scope="col" class="fa-table__th fa-table__th--center">{{ 'admin.compliance.assessed'|trans({}, 'admin') }}</th>
                            <th scope="col" class="fa-table__th fa-table__th--center">{{ 'admin.compliance.compliant'|trans({}, 'admin') }}</th>
                            <th scope="col" class="fa-table__th fa-table__th--center">{{ 'admin.compliance.compliance_rate'|trans({}, 'admin') }}</th>
                            <th scope="col" class="fa-table__th fa-table__th--center">{{ 'admin.compliance.progress'|trans({}, 'admin') }}</th>
                        </tr>
                    {% endblock %}
                    {% block table_body %}
    {% import '_components/_fa_progress.html.twig' as _fa_progress %}
                        {% for data in compliance_data %}
                            <tr class="fa-table__row">
                                <td class="fa-table__cell">
                                    <strong>{{ data.framework.name }}</strong><br>
                                    <small class="text-muted">{{ data.framework.code }}</small>
                                </td>
                                <td class="fa-table__cell fa-table__cell--center">
                                    <span class="fa-status-pill fa-status-pill--neutral">{{ data.total_requirements }}</span>
                                </td>
                                <td class="fa-table__cell fa-table__cell--center">
                                    <span class="fa-status-pill fa-status-pill--primary">{{ data.assessed_requirements }}</span>
                                </td>
                                <td class="fa-table__cell fa-table__cell--center">
                                    <span class="fa-status-pill fa-status-pill--success">{{ data.compliant_requirements }}</span>
                                </td>
                                <td class="fa-table__cell fa-table__cell--center">
                                    <strong class="{% if data.compliance_percentage >= 75 %}text-success{% elseif data.compliance_percentage >= 50 %}text-warning{% else %}text-danger{% endif %}">
                                        {{ data.compliance_percentage }}%
                                    </strong>
                                </td>
                                <td class="fa-table__cell">
                                    {{ _fa_progress.render({ value: data.compliance_percentage, tone: data.compliance_percentage >= 75 ? 'success' : (data.compliance_percentage >= 50 ? 'warning' : 'danger'), showText: true }) }}
                                </td>
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            </div>
        </section>
    {% else %}
        {{ _fa_alert.render({ variant: 'info', body: 'admin.compliance.no_frameworks_loaded'|trans({}, 'admin') }) }}
    {% endif %}
{% endblock admin_content %}
