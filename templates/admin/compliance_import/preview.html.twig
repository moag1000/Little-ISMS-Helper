{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'compliance_import.preview.title'|trans({}, 'compliance_import') }}{% endblock %}

{% block admin_title %}{{ 'compliance_import.wizard.title'|trans({}, 'compliance_import') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('admin_compliance_index') }}">{{ 'compliance.manage_frameworks'|trans({}, 'compliance') }}</a></li>
    <li class="breadcrumb-item"><a href="{{ path('admin_compliance_import_upload') }}">{{ 'compliance_import.wizard.title'|trans({}, 'compliance_import') }}</a></li>
    <li class="breadcrumb-item active" aria-current="page">{{ 'compliance_import.preview.breadcrumb'|trans({}, 'compliance_import') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'cloud-arrow-up', label: 'Import' },
        title: 'compliance_import.wizard.title'|trans({}, 'compliance_import'),
        subtitle: 'compliance_import.preview.breadcrumb'|trans({}, 'compliance_import')
    }) }}

    {% include 'admin/compliance_import/_stepper.html.twig' with { active_step: active_step } only %}

    {% if header_error %}
        {% set parts = header_error|split(':', 2) %}
        {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'danger' } } %}
            {% block alert_body %}
            <strong>{{ ('compliance_import.' ~ parts[0])|trans({}, 'compliance_import') }}</strong>
            {% if parts[1] is defined %}
                <code>{{ parts[1] }}</code>
            {% endif %}
            <div class="mt-2">
                <a href="{{ path('admin_compliance_import_upload') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                    <i class="fa-icon fa-icon--util-arrow-left" aria-hidden="true"></i>
                    {{ 'compliance_import.common.back_to_upload'|trans({}, 'compliance_import') }}
                </a>
            </div>
            {% endblock %}
        {% endembed %}
    {% else %}
        {# Summary chips #}
        <section class="fa-section mb-3">
            <div class="fa-section__header">
                <h2 class="fa-section__title">
                    <i class="fa-icon fa-icon--ui-copy" aria-hidden="true"></i>
                    {{ 'compliance_import.preview.summary_title'|trans({}, 'compliance_import') }}
                    <small class="text-muted ms-2">
                        {{ session_info.original_name|default('') }}
                    </small>
                </h2>
            </div>
            <div class="fa-section__body">
                <div class="d-flex flex-wrap gap-2" role="list" aria-label="{{ 'compliance_import.preview.summary_aria'|trans({}, 'compliance_import') }}">
                    <div role="listitem">
                        <span class="fa-status-pill fa-status-pill--success">{{ 'compliance_import.status.new'|trans({}, 'compliance_import') }}: {{ summary.new|default(0) }}</span>
                    </div>
                    <div role="listitem">
                        <span class="fa-status-pill fa-status-pill--primary">{{ 'compliance_import.status.update'|trans({}, 'compliance_import') }}: {{ summary.update|default(0) }}</span>
                    </div>
                    <div role="listitem">
                        <span class="fa-status-pill fa-status-pill--warning">{{ 'compliance_import.status.conflict'|trans({}, 'compliance_import') }}: {{ summary.conflict|default(0) }}</span>
                    </div>
                    <div role="listitem">
                        <span class="fa-status-pill fa-status-pill--danger">{{ 'compliance_import.status.error'|trans({}, 'compliance_import') }}: {{ summary.error|default(0) }}</span>
                    </div>
                </div>
            </div>
        </section>

        {# Rows table #}
        <section class="fa-section mb-3">
            <div class="fa-section__header">
                <h2 class="fa-section__title">
                    <i class="fa-icon fa-icon--nav-grid" aria-hidden="true"></i>
                    {{ 'compliance_import.preview.table_title'|trans({}, 'compliance_import') }}
                </h2>
            </div>
            <div class="fa-section__body">
                {% if rows is empty %}
                    <p class="text-muted mb-0">
                        {{ 'compliance_import.preview.empty'|trans({}, 'compliance_import') }}
                    </p>
                {% else %}
                    {% embed '_components/_fa_table.html.twig' %}
                        {% block table_head %}
                            <tr>
                                <th scope="col" class="fa-table__th">{{ 'compliance_import.preview.col_line'|trans({}, 'compliance_import') }}</th>
                                <th scope="col" class="fa-table__th">{{ 'compliance_import.preview.col_source'|trans({}, 'compliance_import') }}</th>
                                <th scope="col" class="fa-table__th">{{ 'compliance_import.preview.col_target'|trans({}, 'compliance_import') }}</th>
                                <th scope="col" class="fa-table__th">{{ 'compliance_import.preview.col_percentage'|trans({}, 'compliance_import') }}</th>
                                <th scope="col" class="fa-table__th">{{ 'compliance_import.preview.col_status'|trans({}, 'compliance_import') }}</th>
                            </tr>
                        {% endblock %}
                        {% block table_body %}
                            {% for row in rows %}
                                {% set status_variant = {
                                    'new': 'success',
                                    'update': 'primary',
                                    'conflict': 'warning',
                                    'error': 'danger'
                                }[row.status]|default('secondary') %}
                                <tr class="fa-table__row">
                                    <th scope="row" class="fa-table__cell">{{ row.line }}</th>
                                    <td class="fa-table__cell">
                                        <code>{{ row.source_framework }}</code>
                                        <span class="text-muted">/</span>
                                        <code>{{ row.source_requirement_id }}</code>
                                    </td>
                                    <td class="fa-table__cell">
                                        <code>{{ row.target_framework }}</code>
                                        <span class="text-muted">/</span>
                                        <code>{{ row.target_requirement_id }}</code>
                                    </td>
                                    <td class="fa-table__cell">{{ row.percentage }}{% if row.percentage %} %{% endif %}</td>
                                    <td class="fa-table__cell">
                                        <span class="badge bg-{{ status_variant }}{% if status_variant == 'warning' %} text-dark{% endif %}"
                                              aria-label="{{ ('compliance_import.status.' ~ row.status)|trans({}, 'compliance_import') }}">
                                            {{ ('compliance_import.status.' ~ row.status)|trans({}, 'compliance_import') }}
                                        </span>
                                        {% if row.message %}
                                            <div class="small text-muted mt-1">
                                                {{ row.message|trans({}, 'compliance_import') }}
                                            </div>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endblock %}
                    {% endembed %}
                {% endif %}
            </div>
        </section>

        {% if requires_four_eyes|default(false) %}
            {{ _fa_alert.render({ variant: 'warning', class: 'd-flex gap-2', title: 'compliance_import.preview.four_eyes_warning_title'|trans({}, 'compliance_import'), body: 'compliance_import.preview.four_eyes_warning_body'|trans({'%rows%': rows|length, '%threshold%': four_eyes_threshold}, 'compliance_import') }) }}
        {% endif %}

        {# Action bar #}
        <div class="d-flex gap-2 justify-content-end">
            <form method="post" action="{{ path('admin_compliance_import_cancel') }}" class="d-inline">
                <input type="hidden" name="_token" value="{{ csrf_token('compliance_import_cancel') }}">
                <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost">
                    <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i>
                    {{ 'compliance_import.common.cancel'|trans({}, 'compliance_import') }}
                </button>
            </form>
            <form method="post" action="{{ path('admin_compliance_import_commit') }}" class="d-inline">
                <input type="hidden" name="_token" value="{{ csrf_token('compliance_import_commit') }}">
                <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary"
                        {% if rows is empty %}disabled aria-disabled="true"{% endif %}>
                    <i class="fa-icon fa-icon--approve" aria-hidden="true"></i>
                    {{ 'compliance_import.preview.commit'|trans({}, 'compliance_import') }}
                </button>
            </form>
        </div>
    {% endif %}
{% endblock %}
