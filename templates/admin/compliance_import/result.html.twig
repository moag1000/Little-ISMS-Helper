{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'compliance_import.result.title'|trans({}, 'compliance_import') }}{% endblock %}

{% block admin_title %}{{ 'compliance_import.wizard.title'|trans({}, 'compliance_import') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('admin_compliance_index') }}">{{ 'compliance.manage_frameworks'|trans({}, 'compliance') }}</a></li>
    <li class="breadcrumb-item"><a href="{{ path('admin_compliance_import_upload') }}">{{ 'compliance_import.wizard.title'|trans({}, 'compliance_import') }}</a></li>
    <li class="breadcrumb-item active" aria-current="page">{{ 'compliance_import.result.breadcrumb'|trans({}, 'compliance_import') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'ui-upload', label: 'Import' },
        title: 'compliance_import.wizard.title'|trans({}, 'compliance_import'),
        subtitle: 'compliance_import.result.breadcrumb'|trans({}, 'compliance_import')
    }) }}

    {% include 'admin/compliance_import/_stepper.html.twig' with { active_step: active_step } only %}

    <section class="fa-section mb-3">
        <div class="fa-section__header">
            <h2 class="fa-section__title">
                <i class="fa-icon fa-icon--approve" aria-hidden="true"></i>
                {{ 'compliance_import.result.summary_title'|trans({}, 'compliance_import') }}
            </h2>
        </div>
        <div class="fa-section__body">
            <div class="row g-3" role="list" aria-label="{{ 'compliance_import.result.summary_aria'|trans({}, 'compliance_import') }}">
                <div class="col-md-4" role="listitem">
                    <div class="border rounded p-3 text-center">
                        <div class="h2 mb-1 text-success">
                            <i class="fa-icon fa-icon--ui-plus" aria-hidden="true"></i> {{ imported|default(0) }}
                        </div>
                        <div class="text-muted small">
                            {{ 'compliance_import.result.imported'|trans({}, 'compliance_import') }}
                        </div>
                    </div>
                </div>
                <div class="col-md-4" role="listitem">
                    <div class="border rounded p-3 text-center">
                        <div class="h2 mb-1 text-primary">
                            <i class="fa-icon fa-icon--nav-workflow" aria-hidden="true"></i> {{ superseded|default(0) }}
                        </div>
                        <div class="text-muted small">
                            {{ 'compliance_import.result.superseded'|trans({}, 'compliance_import') }}
                        </div>
                    </div>
                </div>
                <div class="col-md-4" role="listitem">
                    <div class="border rounded p-3 text-center">
                        <div class="h2 mb-1 {% if skipped|default(0) > 0 %}text-danger{% else %}text-muted{% endif %}">
                            <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i> {{ skipped|default(0) }}
                        </div>
                        <div class="text-muted small">
                            {{ 'compliance_import.result.skipped'|trans({}, 'compliance_import') }}
                        </div>
                    </div>
                </div>
            </div>

            {% if errors is defined and errors|length > 0 %}
                {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning', class: 'mt-3' } } %}
                    {% block alert_body %}
                    <div class="fa-alert__title">{{ 'compliance_import.result.errors_title'|trans({ '%count%': errors|length }, 'compliance_import') }}</div>
                    <ul class="mb-0 small">
                        {% for err in errors|slice(0, 20) %}
                            <li><code>{{ err }}</code></li>
                        {% endfor %}
                    </ul>
                    {% if errors|length > 20 %}
                        <p class="small text-muted mt-2 mb-0">
                            {{ 'compliance_import.result.errors_truncated'|trans({ '%remaining%': errors|length - 20 }, 'compliance_import') }}
                        </p>
                    {% endif %}
                    {% endblock %}
                {% endembed %}
            {% endif %}
        </div>
    </section>

    <div class="d-flex gap-2 justify-content-end">
        <a href="{{ path('admin_compliance_import_upload') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
            <i class="fa-icon fa-icon--ui-refresh" aria-hidden="true"></i>
            {{ 'compliance_import.result.start_again'|trans({}, 'compliance_import') }}
        </a>
        <a href="{{ path('admin_compliance_index') }}" class="fa-cyber-btn fa-cyber-btn--primary">
            <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
            {{ 'compliance_import.result.back_to_admin'|trans({}, 'compliance_import') }}
        </a>
    </div>
{% endblock %}
