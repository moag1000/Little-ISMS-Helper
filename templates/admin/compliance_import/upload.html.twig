{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'compliance_import.upload.title'|trans({}, 'compliance_import') }}{% endblock %}

{% block admin_title %}{{ 'compliance_import.wizard.title'|trans({}, 'compliance_import') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('admin_compliance_index') }}">{{ 'compliance.manage_frameworks'|trans({}, 'compliance') }}</a></li>
    <li class="breadcrumb-item active" aria-current="page">{{ 'compliance_import.wizard.title'|trans({}, 'compliance_import') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'cloud-arrow-up', label: 'Import' },
        title: 'compliance_import.wizard.title'|trans({}, 'compliance_import'),
        subtitle: 'compliance_import.upload.intro'|trans({}, 'compliance_import')
    }) }}

    {% include 'admin/compliance_import/_stepper.html.twig' with { active_step: active_step } only %}

    <section class="fa-section mb-4">
        <div class="fa-section__header">
            <h2 class="fa-section__title">
                <i class="fa-icon fa-icon--nav-upload" aria-hidden="true"></i>
                {{ 'compliance_import.upload.card_title'|trans({}, 'compliance_import') }}
            </h2>
        </div>
        <div class="fa-section__body">
            <p class="text-muted">
                {{ 'compliance_import.upload.intro'|trans({}, 'compliance_import') }}
            </p>

            {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', class: 'd-flex align-items-start gap-2' } } %}
                {% block alert_body %}
                <div>
                    <strong>{{ 'compliance_import.upload.template_label'|trans({}, 'compliance_import') }}</strong>
                    <div>
                        <a href="{{ template_url|default('#') }}" download
                           class="fa-alert__link"
                           aria-label="{{ 'compliance_import.upload.template_download_aria'|trans({}, 'compliance_import') }}">
                            {{ 'compliance_import.upload.template_download'|trans({}, 'compliance_import') }}
                        </a>
                    </div>
                </div>
                {% endblock %}
            {% endembed %}

            {{ form_start(form, { attr: { 'novalidate': 'novalidate', 'aria-label': 'compliance_import.upload.form_aria'|trans({}, 'compliance_import') } }) }}
                <div class="mb-3">
                    {{ form_label(form.format, null, { label_attr: { 'class': 'form-label' } }) }}
                    {{ form_widget(form.format, { attr: { 'class': 'form-select' } }) }}
                    <div id="compliance_import_format_help" class="form-text">
                        {{ 'compliance_import.upload.format_help'|trans({}, 'compliance_import') }}
                    </div>
                    {{ form_errors(form.format) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.file, null, { label_attr: { 'class': 'form-label' } }) }}
                    {{ form_widget(form.file, { attr: { 'class': 'form-control' } }) }}
                    <div id="compliance_import_file_help" class="form-text">
                        {{ 'compliance_import.upload.file_help'|trans({}, 'compliance_import') }}
                    </div>
                    {{ form_errors(form.file) }}
                </div>

                <div class="d-flex gap-2 justify-content-end mt-4">
                    <a href="{{ path('admin_compliance_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                        <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i>
                        {{ 'compliance_import.common.cancel'|trans({}, 'compliance_import') }}
                    </a>
                    {{ form_widget(form.submit, { label: 'compliance_import.upload.submit'|trans({}, 'compliance_import') }) }}
                </div>
            {{ form_end(form) }}
        </div>
    </section>
{% endblock %}
