{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'compliance_import' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
{% import '_components/_status_pill.html.twig' as pill %}

{% block title %}{{ 'compliance_import.history.title'|trans({}, 'compliance_import') }}{% endblock %}

{% block admin_title %}{{ 'compliance_import.history.title'|trans({}, 'compliance_import') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('admin_compliance_index') }}">{{ 'compliance.manage_frameworks'|trans({}, 'compliance') }}</a></li>
    <li class="breadcrumb-item active" aria-current="page">{{ 'compliance_import.history.title'|trans({}, 'compliance_import') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'cloud-arrow-up', label: 'Import' },
        title: 'compliance_import.history.title'|trans({}, 'compliance_import'),
        actions: [
            { label: 'compliance_import.wizard.title'|trans({}, 'compliance_import'), variant: 'primary', icon: 'cloud-arrow-up', href: path('admin_compliance_import_upload') }
        ]
    }) }}

    {% if sessions is empty %}
        {{ _fa_empty_state.render({
            mood: 'thinking',
            title: 'compliance_import.history.empty'|trans({}, 'compliance_import'),
            actions: [
                { label: 'compliance_import.wizard.title'|trans({}, 'compliance_import'), variant: 'primary', icon: 'cloud-arrow-up', href: path('admin_compliance_import_upload') }
            ]
        }) }}
    {% else %}
        <section class="fa-section">
            <div class="fa-section__header">
                <h2 class="fa-section__title">
                    <i class="fa-icon fa-icon--nav-calendar-check" aria-hidden="true"></i>
                    {{ 'compliance_import.history.sessions_list'|trans({}, 'compliance_import') }}
                </h2>
            </div>
            <div class="fa-section__body">
                {% embed '_components/_fa_table.html.twig' with { striped: true } %}
                    {% block table_head %}
                        <tr>
                            <th scope="col" class="fa-table__th">{{ 'compliance_import.history.col_filename'|trans({}, 'compliance_import') }}</th>
                            <th scope="col" class="fa-table__th">{{ 'compliance_import.history.col_hash'|trans({}, 'compliance_import') }}</th>
                            <th scope="col" class="fa-table__th">{{ 'compliance_import.history.col_uploader'|trans({}, 'compliance_import') }}</th>
                            <th scope="col" class="fa-table__th">{{ 'compliance_import.history.col_committed_at'|trans({}, 'compliance_import') }}</th>
                            <th scope="col" class="fa-table__th fa-table__th--num">{{ 'compliance_import.history.col_imported'|trans({}, 'compliance_import') }}</th>
                            <th scope="col" class="fa-table__th fa-table__th--num">{{ 'compliance_import.history.col_superseded'|trans({}, 'compliance_import') }}</th>
                            <th scope="col" class="fa-table__th fa-table__th--num">{{ 'compliance_import.history.col_skipped'|trans({}, 'compliance_import') }}</th>
                            <th scope="col" class="fa-table__th">{{ 'compliance_import.history.col_status'|trans({}, 'compliance_import') }}</th>
                            <th scope="col" class="fa-table__th fa-table__th--actions">{{ 'compliance_import.history.col_actions'|trans({}, 'compliance_import') }}</th>
                        </tr>
                    {% endblock %}
                    {% block table_body %}
                        {% import '_components/_status_pill.html.twig' as pill %}
                        {% for session in sessions %}
                            {% set status_variant = {
                                'committed': 'success',
                                'preview': 'warning',
                                'cancelled': 'secondary'
                            }[session.status]|default('secondary') %}
                            <tr class="fa-table__row">
                                <td class="fa-table__cell">
                                    <code>{{ session.originalFilename }}</code>
                                    <div class="small text-muted">{{ session.format }}</div>
                                </td>
                                <td class="fa-table__cell">
                                    <code title="{{ session.fileSha256 }}">{{ session.shortHash }}</code>
                                </td>
                                <td class="fa-table__cell">
                                    {% if session.uploadedBy %}
                                        {{ session.uploadedBy.email }}
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                </td>
                                <td class="fa-table__cell">
                                    {% if session.committedAt %}
                                        {{ session.committedAt|date('Y-m-d H:i') }}
                                    {% else %}
                                        {{ session.uploadedAt|date('Y-m-d H:i') }}
                                        <div class="small text-muted">
                                            ({{ 'compliance_import.history.uploaded'|trans({}, 'compliance_import') }})
                                        </div>
                                    {% endif %}
                                </td>
                                <td class="fa-table__cell fa-table__cell--num">{{ session.rowCountImported }}</td>
                                <td class="fa-table__cell fa-table__cell--num">{{ session.rowCountSuperseded }}</td>
                                <td class="fa-table__cell fa-table__cell--num">{{ session.rowCountSkipped }}</td>
                                <td class="fa-table__cell">
                                    {% set _stone = status_variant in ['info'] ? 'primary' : (status_variant in ['secondary','light','dark'] ? 'neutral' : status_variant) %}
                                    {{ pill.render(('compliance_import.history.status.' ~ session.status)|trans({}, 'compliance_import'), _stone, {size: 'sm'}) }}
                                </td>
                                <td class="fa-table__cell fa-table__cell--actions">
                                    <a href="{{ path('admin_import_history_show', { id: session.id }) }}"
                                       class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                        <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
                                        {{ 'compliance_import.history.view_detail'|trans({}, 'compliance_import') }}
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}

                {% if page_count > 1 %}
                    <nav aria-label="{{ 'compliance_import.history.pagination_aria'|trans({}, 'compliance_import') }}">
                        <ul class="pagination">
                            {% for p in 1..page_count %}
                                <li class="page-item {% if p == page %}active{% endif %}">
                                    <a class="page-link"
                                       href="{{ path('admin_import_history_index', { page: p }) }}">{{ p }}</a>
                                </li>
                            {% endfor %}
                        </ul>
                    </nav>
                {% endif %}
            </div>
        </section>
    {% endif %}
{% endblock %}
