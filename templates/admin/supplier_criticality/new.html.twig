{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'supplier_criticality' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block admin_title %}{{ 'supplier_criticality.action.new'|trans({}, 'supplier_criticality') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item">
        <a href="{{ path('app_admin_supplier_criticality_index') }}">
            {{ 'supplier_criticality.title'|trans({}, 'supplier_criticality') }}
        </a>
    </li>
    <li class="breadcrumb-item active">{{ 'supplier_criticality.action.new'|trans({}, 'supplier_criticality') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'building', label: 'Suppliers' },
        title: 'supplier_criticality.action.new'|trans({}, 'supplier_criticality'),
        subtitle: 'supplier_criticality.subtitle'|trans({}, 'supplier_criticality'),
    }) }}

    <div class="row">
        <div class="col-lg-8">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="fa-icon fa-icon--ui-plus" aria-hidden="true"></i>
                        {{ 'supplier_criticality.action.new'|trans({}, 'supplier_criticality') }}
                    </h2>
                </div>
                <div class="fa-section__body">
                    {{ form_start(form) }}
                        <div class="mb-3">
                            {{ form_label(form.code) }}
                            {{ form_widget(form.code) }}
                            {{ form_help(form.code) }}
                            {{ form_errors(form.code) }}
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.labelDe) }}
                                {{ form_widget(form.labelDe) }}
                                {{ form_errors(form.labelDe) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.labelEn) }}
                                {{ form_widget(form.labelEn) }}
                                {{ form_errors(form.labelEn) }}
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.sortOrder) }}
                                {{ form_widget(form.sortOrder) }}
                                {{ form_help(form.sortOrder) }}
                                {{ form_errors(form.sortOrder) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.color) }}
                                {{ form_widget(form.color) }}
                                {{ form_errors(form.color) }}
                            </div>
                        </div>
                        <div class="mb-3 form-check">
                            {{ form_widget(form.isDefault) }}
                            {{ form_label(form.isDefault) }}
                            {{ form_help(form.isDefault) }}
                        </div>
                        <div class="mb-3 form-check">
                            {{ form_widget(form.isActive) }}
                            {{ form_label(form.isActive) }}
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                                <i class="fa-icon fa-icon--ui-save" aria-hidden="true"></i>
                                {{ 'common.save'|trans({}, 'messages') }}
                            </button>
                            <a href="{{ path('app_admin_supplier_criticality_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                                {{ 'common.cancel'|trans({}, 'messages') }}
                            </a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </section>
        </div>
    </div>
{% endblock %}
