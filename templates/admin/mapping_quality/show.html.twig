{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'admin' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_cyber_field.html.twig' as _fa_cyber %}

{% block title %}{{ 'admin.mapping_quality.detail_title'|trans({}, 'admin') }}{% endblock %}

{% block admin_title %}
    <i class="fa-icon fa-icon--compliance-shield" aria-hidden="true"></i> {{ 'admin.mapping_quality.detail_title'|trans({}, 'admin') }}
{% endblock %}

{% block admin_content %}
<div class="container-fluid">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.admin'|trans({}, 'nav'), url: path('admin_dashboard') },
            { label: 'admin.mapping_quality.title'|trans({}, 'admin'), url: path('admin_mapping_quality_index') },
            { label: '#' ~ mapping.id }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'diagram-3', label: 'Mapping' },
        title: 'admin.mapping_quality.detail_title'|trans({}, 'admin'),
        subtitle: '#' ~ mapping.id,
    }) }}

    <div class="row mb-4">
        <div class="col-md-8">
            <section class="fa-section">
                <div class="fa-section__header">
                    <div>
                        <h2 class="fa-section__title">
                            <code>{{ mapping.sourceRequirement.requirementId }}</code>
                            <i class="fa-icon fa-icon--util-arrow-right small" aria-hidden="true"></i>
                            <code>{{ mapping.targetRequirement.requirementId }}</code>
                        </h2>
                        <div class="small text-muted mt-1">
                            {{ mapping.sourceRequirement.framework.name }} → {{ mapping.targetRequirement.framework.name }}
                        </div>
                    </div>
                </div>
                <div class="fa-section__body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">{{ 'admin.mapping_quality.field.relationship'|trans({}, 'admin') }}</dt>
                        <dd class="col-sm-8">{% if mapping.relationship %}<span class="fa-status-pill fa-status-pill--neutral">{{ mapping.relationship|replace({'_': ' '}) }}</span>{% else %}—{% endif %}</dd>

                        <dt class="col-sm-4">{{ 'admin.mapping_quality.field.confidence'|trans({}, 'admin') }}</dt>
                        <dd class="col-sm-8"><span class="badge bg-{{ mapping.confidence == 'high' ? 'success' : (mapping.confidence == 'medium' ? 'warning' : 'secondary') }}">{{ mapping.confidence }}</span></dd>

                        <dt class="col-sm-4">{{ 'admin.mapping_quality.field.lifecycle'|trans({}, 'admin') }}</dt>
                        <dd class="col-sm-8"><span class="badge bg-{{ mapping.lifecycleBadgeClass }}">{{ mapping.lifecycleState }}</span></dd>

                        <dt class="col-sm-4">{{ 'admin.mapping_quality.field.provenance'|trans({}, 'admin') }}</dt>
                        <dd class="col-sm-8">
                            {{ mapping.provenanceSource ?: '—' }}
                            {% if mapping.provenanceUrl %}<a href="{{ mapping.provenanceUrl }}" class="ms-2" rel="noopener" target="_blank"><i class="fa-icon fa-icon--export" aria-hidden="true"></i></a>{% endif %}
                        </dd>

                        <dt class="col-sm-4">{{ 'admin.mapping_quality.field.methodology'|trans({}, 'admin') }}</dt>
                        <dd class="col-sm-8">
                            <code class="small">{{ mapping.methodologyType ?: '—' }}</code>
                            {% if mapping.methodologyDescription %}<p class="text-muted small mb-0 mt-1">{{ mapping.methodologyDescription|nl2br }}</p>{% endif %}
                        </dd>

                        <dt class="col-sm-4">{{ 'admin.mapping_quality.field.rationale'|trans({}, 'admin') }}</dt>
                        <dd class="col-sm-8">{% if mapping.mappingRationale %}{{ mapping.mappingRationale|nl2br }}{% else %}—{% endif %}</dd>

                        {% if mapping.gapWarning %}
                            <dt class="col-sm-4">{{ 'admin.mapping_quality.field.gap_warning'|trans({}, 'admin') }}</dt>
                            <dd class="col-sm-8">
                                {{ _fa_alert.render({ variant: 'warning', class: 'mb-0 small', body: mapping.gapWarning|nl2br }) }}
                            </dd>
                        {% endif %}

                        {% if mapping.auditEvidenceHint %}
                            <dt class="col-sm-4">{{ 'admin.mapping_quality.field.audit_evidence'|trans({}, 'admin') }}</dt>
                            <dd class="col-sm-8">{{ _fa_alert.render({ variant: 'info', class: 'mb-0 small', body: mapping.auditEvidenceHint|nl2br }) }}</dd>
                        {% endif %}

                        <dt class="col-sm-4">{{ 'admin.mapping_quality.field.version'|trans({}, 'admin') }}</dt>
                        <dd class="col-sm-8">v{{ mapping.version }} (gültig ab {{ mapping.validFrom|date('Y-m-d') }}{% if mapping.validUntil %} bis {{ mapping.validUntil|date('Y-m-d') }}{% endif %})</dd>

                        <dt class="col-sm-4">{{ 'admin.mapping_quality.field.source_id'|trans({}, 'admin') }}</dt>
                        <dd class="col-sm-8"><code class="small">{{ mapping.source }}</code></dd>
                    </dl>
                </div>
            </section>
        </div>

        <div class="col-md-4">
            {% set scoreClass = mapping.qualityScore >= 80 ? 'success' : (mapping.qualityScore >= 60 ? 'warning' : 'danger') %}
            <section class="fa-section">
                <div class="fa-section__header">
                    <h3 class="fa-section__title">{{ 'admin.mapping_quality.mqs_score'|trans({}, 'admin') }}</h3>
                </div>
                <div class="fa-section__body">
                    <div class="text-center mb-3">
                        <h1 class="display-4 mb-0 text-{{ scoreClass }}">{{ mapping.qualityScore ?? '–' }}</h1>
                        <small class="text-muted">{{ 'admin.mapping_quality.mqs_max'|trans({}, 'admin') }}</small>
                    </div>
                    {% if mapping.mqsBreakdown %}
                        {% embed '_components/_fa_table.html.twig' with { compact: true, hover: false } %}
                            {% block table_body %}
                                <tr class="fa-table__row"><td class="fa-table__cell small">Provenance</td><td class="fa-table__cell fa-table__cell--num small">{{ mapping.mqsBreakdown.provenance }} / 25</td></tr>
                                <tr class="fa-table__row"><td class="fa-table__cell small">Methodology</td><td class="fa-table__cell fa-table__cell--num small">{{ mapping.mqsBreakdown.methodology }} / 20</td></tr>
                                <tr class="fa-table__row"><td class="fa-table__cell small">Confidence</td><td class="fa-table__cell fa-table__cell--num small">{{ mapping.mqsBreakdown.confidence }} / 15</td></tr>
                                <tr class="fa-table__row"><td class="fa-table__cell small">Coverage</td><td class="fa-table__cell fa-table__cell--num small">{{ mapping.mqsBreakdown.coverage }} / 15</td></tr>
                                <tr class="fa-table__row"><td class="fa-table__cell small">Bidirectional</td><td class="fa-table__cell fa-table__cell--num small">{{ mapping.mqsBreakdown.bidirectional }} / 15</td></tr>
                                <tr class="fa-table__row"><td class="fa-table__cell small">Lifecycle</td><td class="fa-table__cell fa-table__cell--num small">{{ mapping.mqsBreakdown.lifecycle }} / 10</td></tr>
                            {% endblock %}
                        {% endembed %}
                    {% endif %}
                </div>
            </section>

            {# Lifecycle-Transitions #}
            {% if allowedTransitions|length > 0 %}
                <section class="fa-section mt-3">
                    <div class="fa-section__header">
                        <h3 class="fa-section__title">{{ 'admin.mapping_quality.lifecycle_actions'|trans({}, 'admin') }}</h3>
                    </div>
                    <div class="fa-section__body">
                        <p class="small text-muted">{{ 'admin.mapping_quality.transition_hint'|trans({}, 'admin') }}</p>
                        {% for state in allowedTransitions %}
                            <form method="post" action="{{ path('admin_mapping_quality_transition', {id: mapping.id}) }}" class="mb-2"
                                  data-controller="ui-actions"
                                  data-action="submit->ui-actions#confirm"
                                  data-ui-actions-message-param="{{ 'admin.mapping_quality.transition_confirm'|trans({'%state%': state}, 'admin') }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('mapping_lifecycle_' ~ mapping.id) }}">
                                <input type="hidden" name="to" value="{{ state }}">
                                {% if state in ['approved', 'published', 'deprecated'] %}
                                    <div class="mb-1">
                                        {{ _fa_cyber.text('reason', {
                                            placeholder: 'admin.mapping_quality.transition_reason_placeholder'|trans({}, 'admin')
                                        }) }}
                                    </div>
                                {% endif %}
                                {% set btnClass = state == 'published' ? 'success' : (state == 'deprecated' ? 'danger' : (state == 'approved' ? 'primary' : 'secondary')) %}
                                <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost -{{ btnClass }} w-100">
                                    <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i> {{ state }}
                                </button>
                            </form>
                        {% endfor %}
                    </div>
                </section>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
