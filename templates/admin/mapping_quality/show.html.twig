{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'admin' %}

{% block title %}{{ 'admin.mapping_quality.detail_title'|trans({}, 'admin') }}{% endblock %}

{% block admin_title %}
    <i class="bi bi-shield-check" aria-hidden="true"></i> {{ 'admin.mapping_quality.detail_title'|trans({}, 'admin') }}
{% endblock %}

{% block admin_content %}
<div class="container-fluid">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.admin'|trans({}, 'nav'), url: path('admin_dashboard') },
            { label: 'admin.mapping_quality.title'|trans({}, 'admin'), url: path('admin_mapping_quality_index') },
            { label: '#' ~ mapping.id }
        ]
    } %}

    <div class="row mb-4">
        <div class="col-md-8">
            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header">
                        <h2 class="h5 mb-0">
                            <code>{{ mapping.sourceRequirement.requirementId }}</code>
                            <i class="bi bi-arrow-right small" aria-hidden="true"></i>
                            <code>{{ mapping.targetRequirement.requirementId }}</code>
                        </h2>
                        <div class="small text-muted mt-1">
                            {{ mapping.sourceRequirement.complianceFramework.name }} → {{ mapping.targetRequirement.complianceFramework.name }}
                        </div>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <dl class="row mb-0">
                        <dt class="col-sm-4">{{ 'admin.mapping_quality.field.relationship'|trans({}, 'admin') }}</dt>
                        <dd class="col-sm-8">{% if mapping.relationship %}{% include '_components/_badge.html.twig' with { variant: 'secondary', content: mapping.relationship|replace({'_': ' '}) } %}{% else %}—{% endif %}</dd>

                        <dt class="col-sm-4">{{ 'admin.mapping_quality.field.confidence'|trans({}, 'admin') }}</dt>
                        <dd class="col-sm-8">{% include '_components/_badge.html.twig' with { variant: mapping.confidence == 'high' ? 'success' : (mapping.confidence == 'medium' ? 'warning' : 'secondary'), content: mapping.confidence } %}</dd>

                        <dt class="col-sm-4">{{ 'admin.mapping_quality.field.lifecycle'|trans({}, 'admin') }}</dt>
                        <dd class="col-sm-8">{% include '_components/_badge.html.twig' with { variant: mapping.lifecycleBadgeClass, content: mapping.lifecycleState } %}</dd>

                        <dt class="col-sm-4">{{ 'admin.mapping_quality.field.provenance'|trans({}, 'admin') }}</dt>
                        <dd class="col-sm-8">
                            {{ mapping.provenanceSource ?: '—' }}
                            {% if mapping.provenanceUrl %}<a href="{{ mapping.provenanceUrl }}" class="ms-2" rel="noopener" target="_blank"><i class="bi bi-box-arrow-up-right" aria-hidden="true"></i></a>{% endif %}
                        </dd>

                        <dt class="col-sm-4">{{ 'admin.mapping_quality.field.methodology'|trans({}, 'admin') }}</dt>
                        <dd class="col-sm-8">
                            <code class="small">{{ mapping.methodologyType ?: '—' }}</code>
                            {% if mapping.methodologyDescription %}<p class="text-muted small mb-0 mt-1">{{ mapping.methodologyDescription|nl2br }}</p>{% endif %}
                        </dd>

                        <dt class="col-sm-4">{{ 'admin.mapping_quality.field.rationale'|trans({}, 'admin') }}</dt>
                        <dd class="col-sm-8">{% if mapping.mappingRationale %}{{ mapping.mappingRationale|nl2br }}{% else %}—{% endif %}</dd>

                        {% if mapping.gapWarning %}
                            <dt class="col-sm-4">{{ 'admin.mapping_quality.field.gap_warning'|trans({}, 'admin') }}</dt>
                            <dd class="col-sm-8">
                                <div class="alert alert-warning mb-0 small">
                                    <i class="bi bi-exclamation-triangle" aria-hidden="true"></i> {{ mapping.gapWarning|nl2br }}
                                </div>
                            </dd>
                        {% endif %}

                        {% if mapping.auditEvidenceHint %}
                            <dt class="col-sm-4">{{ 'admin.mapping_quality.field.audit_evidence'|trans({}, 'admin') }}</dt>
                            <dd class="col-sm-8"><div class="alert alert-info mb-0 small"><i class="bi bi-clipboard-check" aria-hidden="true"></i> {{ mapping.auditEvidenceHint|nl2br }}</div></dd>
                        {% endif %}

                        <dt class="col-sm-4">{{ 'admin.mapping_quality.field.version'|trans({}, 'admin') }}</dt>
                        <dd class="col-sm-8">v{{ mapping.version }} (gültig ab {{ mapping.validFrom|date('Y-m-d') }}{% if mapping.validUntil %} bis {{ mapping.validUntil|date('Y-m-d') }}{% endif %})</dd>

                        <dt class="col-sm-4">{{ 'admin.mapping_quality.field.source_id'|trans({}, 'admin') }}</dt>
                        <dd class="col-sm-8"><code class="small">{{ mapping.source }}</code></dd>
                    </dl>
                {% endblock %}
            {% endembed %}
        </div>

        <div class="col-md-4">
            {% set scoreClass = mapping.qualityScore >= 80 ? 'success' : (mapping.qualityScore >= 60 ? 'warning' : 'danger') %}
            {% embed '_components/_card.html.twig' with { class: 'border-' ~ scoreClass } %}
                {% block card_header %}
                    <div class="card-header">
                        <h3 class="h6 mb-0">{{ 'admin.mapping_quality.mqs_score'|trans({}, 'admin') }}</h3>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="text-center mb-3">
                        <h1 class="display-4 mb-0 text-{{ scoreClass }}">{{ mapping.qualityScore ?? '–' }}</h1>
                        <small class="text-muted">{{ 'admin.mapping_quality.mqs_max'|trans({}, 'admin') }}</small>
                    </div>
                    {% if mapping.mqsBreakdown %}
                        <table class="table table-sm mb-0">
                            <tbody>
                                <tr><td class="small">Provenance</td><td class="text-end small">{{ mapping.mqsBreakdown.provenance }} / 25</td></tr>
                                <tr><td class="small">Methodology</td><td class="text-end small">{{ mapping.mqsBreakdown.methodology }} / 20</td></tr>
                                <tr><td class="small">Confidence</td><td class="text-end small">{{ mapping.mqsBreakdown.confidence }} / 15</td></tr>
                                <tr><td class="small">Coverage</td><td class="text-end small">{{ mapping.mqsBreakdown.coverage }} / 15</td></tr>
                                <tr><td class="small">Bidirectional</td><td class="text-end small">{{ mapping.mqsBreakdown.bidirectional }} / 15</td></tr>
                                <tr><td class="small">Lifecycle</td><td class="text-end small">{{ mapping.mqsBreakdown.lifecycle }} / 10</td></tr>
                            </tbody>
                        </table>
                    {% endif %}
                {% endblock %}
            {% endembed %}

            {# Lifecycle-Transitions #}
            {% if allowedTransitions|length > 0 %}
                {% embed '_components/_card.html.twig' with { class: 'mt-3' } %}
                    {% block card_header %}
                        <div class="card-header">
                            <h3 class="h6 mb-0">{{ 'admin.mapping_quality.lifecycle_actions'|trans({}, 'admin') }}</h3>
                        </div>
                    {% endblock %}
                    {% block card_body %}
                        <p class="small text-muted">{{ 'admin.mapping_quality.transition_hint'|trans({}, 'admin') }}</p>
                        {% for state in allowedTransitions %}
                            <form method="post" action="{{ path('admin_mapping_quality_transition', {id: mapping.id}) }}" class="mb-2"
                                  data-controller="ui-actions"
                                  data-action="submit->ui-actions#confirm"
                                  data-ui-actions-message-param="{{ 'admin.mapping_quality.transition_confirm'|trans({'%state%': state}, 'admin') }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('mapping_lifecycle_' ~ mapping.id) }}">
                                <input type="hidden" name="to" value="{{ state }}">
                                {% if state in ['approved', 'published', 'deprecated'] %}
                                    <input type="text" name="reason" class="form-control form-control-sm mb-1" placeholder="{{ 'admin.mapping_quality.transition_reason_placeholder'|trans({}, 'admin') }}">
                                {% endif %}
                                {% set btnClass = state == 'published' ? 'success' : (state == 'deprecated' ? 'danger' : (state == 'approved' ? 'primary' : 'secondary')) %}
                                <button type="submit" class="btn btn-sm btn-{{ btnClass }} w-100">
                                    <i class="bi bi-arrow-right" aria-hidden="true"></i> {{ state }}
                                </button>
                            </form>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
