{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'admin' %}

{% block title %}{{ 'admin.policy_style.title'|trans }} — {{ tenant.name }}{% endblock %}

{% block admin_content %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% include '_components/_breadcrumb.html.twig' with {
    breadcrumbs: [
        { label: 'admin.dashboard.title'|trans({}, 'admin'), url: path('admin_hub_index') },
        { label: 'admin.policy_style.title'|trans }
    ]
} %}

{{ _fa_page_header.render({
    badge: { icon: 'palette2', label: tenant.name },
    title: 'admin.policy_style.title'|trans,
    subtitle: 'admin.policy_style.subtitle'|trans
}) }}

<main class="fa-aurora-surface">

{% set _flash_variant_map = { 'success': 'success', 'error': 'danger', 'danger': 'danger', 'warning': 'warning', 'info': 'info', 'notice': 'info' } %}
{% for label, msgs in app.flashes %}
    {% for msg in msgs %}
        {{ _fa_alert.render({ variant: _flash_variant_map[label]|default('info'), body: msg|trans, class: 'mb-3' }) }}
    {% endfor %}
{% endfor %}

<div class="row g-4"
     data-controller="policy-style-preview"
     data-policy-style-preview-preview-url-value="{{ path('app_admin_policy_style_preview') }}"
     data-policy-style-preview-csrf-value="{{ csrf_token('admin_policy_style_preview') }}">

    {# ---------- Form column (left) ---------- #}
    <div class="col-xl-7">
        <section class="fa-section">
            <header class="fa-section__header">
                <h2 class="fa-section__title">{{ 'admin.policy_style.section.form'|trans }}</h2>
                <p class="fa-section__subtitle text-muted small mb-0">
                    {{ 'admin.policy_style.section.form_subtitle'|trans }}
                </p>
            </header>
            <div class="fa-section__body">
                {{ form_start(form, {
                    attr: form.vars.attr|merge({
                        'data-action': 'change->policy-style-preview#refresh input->policy-style-preview#refresh'
                    })
                }) }}

                <h3 class="h6 text-muted mb-3">{{ 'admin.policy_style.group.cover'|trans }}</h3>
                <div class="row g-3">
                    <div class="col-md-6">{{ form_row(form.policyDocCoverPattern) }}</div>
                    <div class="col-md-6">{{ form_row(form.policyDocCoverLogoSize) }}</div>
                </div>

                <hr class="my-4">
                <h3 class="h6 text-muted mb-3">{{ 'admin.policy_style.group.typography'|trans }}</h3>
                <div class="row g-3">
                    <div class="col-md-6">{{ form_row(form.policyDocFontFamily) }}</div>
                    <div class="col-md-6">{{ form_row(form.policyDocPageMargin) }}</div>
                </div>

                <hr class="my-4">
                <h3 class="h6 text-muted mb-3">{{ 'admin.policy_style.group.watermark'|trans }}</h3>
                <div class="row g-3 align-items-end">
                    <div class="col-md-4">{{ form_row(form.policyDocWatermarkEnabled) }}</div>
                    <div class="col-md-8">
                        <label for="{{ form.policyDocWatermarkOpacity.vars.id }}" class="form-label">
                            {{ 'admin.policy_style.field.watermark_opacity'|trans }}
                            (<span data-policy-style-preview-target="opacityLabel">{{ (form.policyDocWatermarkOpacity.vars.value * 100)|round }}%</span>)
                        </label>
                        <input type="range"
                               class="form-range"
                               min="0" max="100" step="1"
                               value="{{ (form.policyDocWatermarkOpacity.vars.value * 100)|round }}"
                               data-policy-style-preview-target="opacitySlider"
                               data-action="input->policy-style-preview#syncOpacity"
                               aria-label="{{ 'admin.policy_style.field.watermark_opacity'|trans }}">
                        {{ form_widget(form.policyDocWatermarkOpacity, {attr: {hidden: true, class: 'visually-hidden'}}) }}
                        <p class="form-text">{{ 'admin.policy_style.help.watermark_opacity'|trans }}</p>
                    </div>
                </div>

                <hr class="my-4">
                <h3 class="h6 text-muted mb-3">{{ 'admin.policy_style.group.layout'|trans }}</h3>
                <div class="row g-3">
                    <div class="col-md-6">{{ form_row(form.policyDocSignatureLines) }}</div>
                    <div class="col-md-6 d-flex flex-column gap-2">
                        {{ form_row(form.policyDocShowToc) }}
                        {{ form_row(form.policyDocShowHistory) }}
                        {{ form_row(form.policyDocShowAnnexARefs) }}
                    </div>
                </div>

                <hr class="my-4">
                <h3 class="h6 text-muted mb-3">{{ 'admin.policy_style.group.footer'|trans }}</h3>
                <div class="row g-3">
                    <div class="col-12">{{ form_row(form.policyDocFooterText) }}</div>
                </div>

                {% if form.policyDocCustomCss is defined %}
                    <hr class="my-4">
                    <h3 class="h6 text-muted mb-3">
                        {{ 'admin.policy_style.group.advanced'|trans }}
                        <span class="badge bg-warning-subtle text-warning ms-2">ROLE_ADMIN</span>
                    </h3>
                    {{ form_row(form.policyDocCustomCss) }}
                {% endif %}

                <div class="d-flex flex-wrap gap-2 mt-4">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                        <i class="bi bi-check2 me-1"></i>{{ 'admin.policy_style.save'|trans }}
                    </button>
                    <a href="{{ path('admin_hub_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                        {{ 'admin.cancel'|trans }}
                    </a>
                </div>
                {{ form_end(form) }}

                {# Reset-Form: separate submit, dedicated CSRF token. #}
                <form method="post"
                      action="{{ path('app_admin_policy_style_reset') }}"
                      class="mt-3"
                      onsubmit="return confirm('{{ 'admin.policy_style.reset_confirm'|trans|e('js') }}');">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_policy_style_reset') }}">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost btn-sm text-warning">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>
                        {{ 'admin.policy_style.reset'|trans }}
                    </button>
                </form>
            </div>
        </section>
    </div>

    {# ---------- Live preview column (right) ---------- #}
    <div class="col-xl-5">
        <section class="fa-section position-sticky" style="top: 1.5rem;">
            <header class="fa-section__header">
                <h2 class="fa-section__title">{{ 'admin.policy_style.section.preview'|trans }}</h2>
                <p class="fa-section__subtitle text-muted small mb-0">
                    {{ 'admin.policy_style.section.preview_subtitle'|trans }}
                </p>
            </header>
            <div class="fa-section__body">
                <div class="policy-style-preview-frame"
                     data-policy-style-preview-target="frame"
                     aria-live="polite">
                    {% include 'admin/policy_style/_preview.html.twig' with {
                        tenant: tenant,
                        style_config: style_config,
                        sample: sample
                    } %}
                </div>
            </div>
        </section>
    </div>
</div>
</main>
{% endblock %}
