{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'admin' %}

{% block title %}{{ 'admin.tenant_settings.title'|trans }} — {{ tenant.name }}{% endblock %}

{% block admin_content %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% include '_components/_breadcrumb.html.twig' with {
    breadcrumbs: [
        { label: 'admin.dashboard.title'|trans({}, 'admin'), url: path('admin_dashboard') },
        { label: 'admin.tenant_management.title'|trans({}, 'admin'), url: path('admin_tenant_management_index') },
        { label: 'admin.tenant_settings.title'|trans }
    ]
} %}

{{ _fa_page_header.render({
    badge: { icon: 'gear', label: tenant.name },
    title: 'admin.tenant_settings.title'|trans,
    subtitle: 'admin.tenant_settings.subtitle'|trans
}) }}

<main class="fa-aurora-surface">

{# V3 W2-L3 — flash banners via Aurora alert macro (variant-mapped). #}
{% set _flash_variant_map = { 'success': 'success', 'error': 'danger', 'danger': 'danger', 'warning': 'warning', 'info': 'info', 'notice': 'info' } %}
{% for label, msgs in app.flashes %}
    {% for msg in msgs %}
        {{ _fa_alert.render({ variant: _flash_variant_map[label]|default('info'), body: msg|trans, class: 'mb-3' }) }}
    {% endfor %}
{% endfor %}

<div class="row">
    <div class="col-lg-7 mb-4">
        <section class="fa-section">
            <header class="fa-section__header">
                <h2 class="fa-section__title">{{ 'admin.tenant_settings.section_tenant'|trans }}</h2>
            </header>
            <div class="fa-section__body">
                {{ form_start(form) }}
                <div class="row g-3">
                    <div class="col-md-6">{{ form_row(form.locale) }}</div>
                    <div class="col-md-6">{{ form_row(form.timezone) }}</div>
                    <div class="col-md-6">{{ form_row(form.financialYearStartMonth) }}</div>
                    <div class="col-md-6">{{ form_row(form.tlpDefault) }}</div>
                    <div class="col-md-6">{{ form_row(form.dpoContactName) }}</div>
                    <div class="col-md-6">{{ form_row(form.dpoContactEmail) }}</div>
                </div>

                <hr class="my-4">
                <h3 class="h6 text-muted mb-3">{{ 'admin.tenant_settings.section_operational'|trans }}</h3>
                <div class="row g-3">
                    <div class="col-md-6">{{ form_row(form.riskMethodology) }}</div>
                    <div class="col-md-6">{{ form_row(form.riskMatrixSize) }}</div>
                    <div class="col-md-6">{{ form_row(form.wizardMaturityTarget) }}</div>
                </div>

                <hr class="my-4">
                <h3 class="h6 text-muted mb-3">{{ 'admin.tenant_settings.section_api'|trans }}</h3>
                <div class="row g-3">
                    <div class="col-md-6">{{ form_row(form.apiRateLimitPerMinute) }}</div>
                </div>

                <hr class="my-4">
                <h3 class="h6 text-muted mb-3">{{ 'admin.tenant_settings.section_json'|trans }}</h3>
                <p class="text-muted small">{{ 'admin.tenant_settings.json_help'|trans }}</p>
                <div class="row g-3">
                    <div class="col-12">{{ form_row(form.supervisoryAuthorities) }}</div>
                    <div class="col-12">{{ form_row(form.dataRetentionPolicies) }}</div>
                    <div class="col-12">{{ form_row(form.notificationPreferences) }}</div>
                    <div class="col-12">{{ form_row(form.csirtEndpoints) }}</div>
                    <div class="col-12">{{ form_row(form.crisisTeamOnCall) }}</div>
                </div>

                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                        <i class="fa-icon fa-icon--ui-check me-1"></i>{{ 'admin.tenant_settings.save'|trans }}
                    </button>
                    <a href="{{ path('admin_tenant_management_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                        {{ 'admin.cancel'|trans }}
                    </a>
                </div>
                {{ form_end(form) }}
            </div>
        </section>
    </div>

    <div class="col-lg-5 mb-4">
        <section class="fa-section">
            <header class="fa-section__header">
                <h2 class="fa-section__title">{{ 'admin.tenant_settings.section_global'|trans }}</h2>
            </header>
            <div class="fa-section__body">
                <p class="text-muted small">{{ 'admin.tenant_settings.global_help'|trans }}</p>
                {% embed '_components/_fa_table.html.twig' with { compact: true, hover: false } %}
                    {% block table_body %}
                        {% trans_default_domain 'admin' %}
                        <tr class="fa-table__row">
                            <th scope="row" class="fa-table__cell">{{ 'admin.tenant_settings.mfa_roles'|trans }}</th>
                            <td class="fa-table__cell"><code>{{ globals.mfa_required_roles }}</code></td>
                        </tr>
                        <tr class="fa-table__row">
                            <th scope="row" class="fa-table__cell">{{ 'admin.tenant_settings.password_min_length'|trans }}</th>
                            <td class="fa-table__cell">{{ globals.password_min_length }} {{ 'admin.tenant_settings.chars'|trans }}</td>
                        </tr>
                        <tr class="fa-table__row">
                            <th scope="row" class="fa-table__cell">{{ 'admin.tenant_settings.password_complexity'|trans }}</th>
                            <td class="fa-table__cell">
                                {% if globals.password_require_complexity %}
                                    <span class="fa-status-pill fa-status-pill--success">{{ 'admin.tenant_settings.enforced'|trans }}</span>
                                {% else %}
                                    <span class="fa-status-pill fa-status-pill--warning">{{ 'admin.tenant_settings.disabled'|trans }}</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr class="fa-table__row">
                            <th scope="row" class="fa-table__cell">{{ 'admin.tenant_settings.password_rotation'|trans }}</th>
                            <td class="fa-table__cell">
                                {% if globals.password_rotation_days == 0 %}
                                    <span class="text-muted">{{ 'admin.tenant_settings.no_rotation'|trans }}</span>
                                {% else %}
                                    {{ globals.password_rotation_days }} {{ 'admin.tenant_settings.days'|trans }}
                                {% endif %}
                            </td>
                        </tr>
                        <tr class="fa-table__row">
                            <th scope="row" class="fa-table__cell">{{ 'admin.tenant_settings.session_timeout'|trans }}</th>
                            <td class="fa-table__cell">{{ globals.session_timeout_minutes }} {{ 'admin.tenant_settings.minutes'|trans }}</td>
                        </tr>
                        <tr class="fa-table__row">
                            <th scope="row" class="fa-table__cell">{{ 'admin.tenant_settings.backup_schedule'|trans }}</th>
                            <td class="fa-table__cell"><code>{{ globals.backup_schedule }}</code></td>
                        </tr>
                        <tr class="fa-table__row">
                            <th scope="row" class="fa-table__cell">{{ 'admin.tenant_settings.backup_retention'|trans }}</th>
                            <td class="fa-table__cell">{{ globals.backup_retention_days }} {{ 'admin.tenant_settings.days'|trans }}</td>
                        </tr>
                        <tr class="fa-table__row">
                            <th scope="row" class="fa-table__cell">{{ 'admin.tenant_settings.environment_label'|trans }}</th>
                            <td class="fa-table__cell"><code>{{ globals.environment_label }}</code></td>
                        </tr>
                        <tr class="fa-table__row">
                            <th scope="row" class="fa-table__cell">{{ 'admin.tenant_settings.telemetry'|trans }}</th>
                            <td class="fa-table__cell">
                                {% if globals.telemetry_opt_in %}
                                    <span class="fa-status-pill fa-status-pill--primary">opt-in</span>
                                {% else %}
                                    <span class="fa-status-pill fa-status-pill--neutral">off</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% endblock %}
                {% endembed %}
                <a href="{{ path('app_system_settings_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost btn-sm">
                    <i class="fa-icon fa-icon--ui-settings me-1"></i>{{ 'admin.tenant_settings.edit_globals'|trans }}
                </a>
            </div>
        </section>
    </div>
</div>
</main>
{% endblock %}
