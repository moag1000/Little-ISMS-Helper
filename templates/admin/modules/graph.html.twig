{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'admin.modules.dependency_graph'|trans({}, 'admin') }} - {{ 'admin.panel.title'|trans({}, 'admin') }}{% endblock %}

{% block admin_title %}{{ 'admin.modules.dependency_graph'|trans({}, 'admin') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('admin_modules_index') }}">{{ 'admin.nav.module_management'|trans({}, 'admin') }}</a></li>
    <li class="breadcrumb-item active" aria-current="page">{{ 'admin.modules.dependency_graph'|trans({}, 'admin') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'diagram-3', label: 'Modules' },
        title: 'Modul-Abhängigkeiten',
        subtitle: 'Visualisierung der Modul-Abhängigkeiten',
        actions: [
            { label: 'common.back_to_overview'|trans({}, 'messages'), variant: 'ghost', icon: 'arrow-left', href: path('admin_modules_index') }
        ]
    }) }}

    <div class="row g-4">
        <div class="col-lg-8">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">Abhängigkeits-Graph</h2>
                </div>
                <div class="fa-section__body">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th scope="col">Modul</th>
                                    <th scope="col">Status</th>
                                    <th scope="col">Typ</th>
                                    <th scope="col">Benötigt</th>
                                    <th scope="col">Benötigt von</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for key, graph in dependency_graph %}
                                <tr class="{{ key in active_modules ? 'table-success' : '' }}">
                                    <td>
                                        <strong>{{ graph.name }}</strong>
                                    </td>
                                    <td>
                                        {% if key in active_modules %}
                                            <span class="badge bg-success">Aktiv</span>
                                        {% else %}
                                            <span class="badge bg-secondary">Inaktiv</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if graph.required %}
                                            <span class="badge bg-warning text-dark">Erforderlich</span>
                                        {% else %}
                                            <span class="badge bg-info">Optional</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if graph.dependencies|length > 0 %}
                                            {% for dep in graph.dependencies %}
                                                <span class="badge bg-warning text-dark me-1">{{ dependency_graph[dep].name }}</span>
                                            {% endfor %}
                                        {% else %}
                                            <span class="text-muted">-</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if graph.dependents|length > 0 %}
                                            {% for dep in graph.dependents %}
                                                <span class="badge bg-info me-1">{{ dependency_graph[dep].name }}</span>
                                            {% endfor %}
                                        {% else %}
                                            <span class="text-muted">-</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </div>

        <div class="col-lg-4">
            <section class="fa-section mb-3">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">Legende</h2>
                </div>
                <div class="fa-section__body">
                    <dl class="mb-0">
                        <dt><span class="badge bg-success">Aktiv</span></dt>
                        <dd>Modul ist derzeit aktiviert</dd>

                        <dt><span class="badge bg-secondary">Inaktiv</span></dt>
                        <dd>Modul ist derzeit deaktiviert</dd>

                        <dt><span class="badge bg-warning text-dark">Erforderlich</span></dt>
                        <dd>Modul ist Pflicht und kann nicht deaktiviert werden</dd>

                        <dt><span class="badge bg-info">Optional</span></dt>
                        <dd>Modul kann aktiviert/deaktiviert werden</dd>

                        <dt>Benötigt</dt>
                        <dd>Module, die vorher aktiviert sein müssen</dd>

                        <dt>Benötigt von</dt>
                        <dd>Module, die dieses Modul benötigen</dd>
                    </dl>
                </div>
            </section>

            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="fa-icon fa-icon--ui-lightbulb" aria-hidden="true"></i>
                        Hinweise
                    </h2>
                </div>
                <div class="fa-section__body">
                    <ul class="mb-0 small">
                        <li>{{ 'admin.modules.hint.auto_dependencies'|trans({}, 'admin') }}</li>
                        <li>{{ 'admin.modules.hint.activate_required'|trans({}, 'admin') }}</li>
                        <li>{{ 'admin.modules.hint.deactivate_dependency'|trans({}, 'admin') }}</li>
                        <li>{{ 'admin.modules.hint.required_always_active'|trans({}, 'admin') }}</li>
                    </ul>
                </div>
            </section>
        </div>
    </div>
{% endblock admin_content %}
