{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_kpi_card.html.twig' as _fa_kpi_card %}

{% block title %}{{ 'admin.modules.title'|trans({}, 'admin') }} - {{ 'admin.panel.title'|trans({}, 'admin') }}{% endblock %}

{% block admin_title %}{{ 'admin.modules.title'|trans({}, 'admin') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item active" aria-current="page">{{ 'admin.modules.title'|trans({}, 'admin') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'puzzle', label: 'Modules' },
        title: 'admin.modules.title'|trans({}, 'admin'),
        actions: [
            { label: 'admin.modules.dependency_graph'|trans({}, 'admin'), variant: 'ghost', icon: 'diagram-3', href: path('admin_modules_graph') }
        ]
    }) }}

    {# Statistics #}
    <div class="row g-3 mb-4">
        <div class="col-md-3">{{ _fa_kpi_card.render({ value: statistics.total_modules, label: 'admin.modules.stats.total'|trans({}, 'admin') }) }}</div>
        <div class="col-md-3">{{ _fa_kpi_card.render({ value: statistics.active_modules, label: 'admin.modules.stats.active'|trans({}, 'admin') }) }}</div>
        <div class="col-md-3">{{ _fa_kpi_card.render({ value: statistics.inactive_modules, label: 'admin.modules.stats.inactive'|trans({}, 'admin') }) }}</div>
        <div class="col-md-3">{{ _fa_kpi_card.render({ value: statistics.required_modules, label: 'admin.modules.stats.required'|trans({}, 'admin') }) }}</div>
    </div>

    {# Active Modules #}
    <section class="fa-section mb-4">
        <div class="fa-section__header">
            <h2 class="fa-section__title">
                <i class="fa-icon fa-icon--status-ok text-success" aria-hidden="true"></i>
                {{ 'admin.modules.active_modules'|trans({}, 'admin') }} ({{ active_modules|length }})
            </h2>
        </div>
        <div class="fa-section__body">
            {% if active_modules|length > 0 %}
                <div class="row g-3">
                    {% for key, module in all_modules %}
                        {% if key in active_modules %}
                            <div class="col-md-6 col-lg-4">
                                <div class="fa-rag-card fa-rag-card--green h-100">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <h3 class="h6 mb-0">
                                            <i class="bi bi-{{ module.icon }} text-{{ module.required ? 'warning' : 'success' }}" aria-hidden="true"></i>
                                            {{ module.name }}
                                        </h3>
                                        <span class="fa-status-pill fa-status-pill--success">{{ 'admin.modules.status.active'|trans({}, 'admin') }}</span>
                                    </div>
                                    <p class="text-muted small">{{ module.description }}</p>

                                    {% if dependency_graph[key].dependencies|length > 0 %}
                                        <div class="mb-2">
                                            <small class="text-warning">
                                                <i class="fa-icon fa-icon--ui-link" aria-hidden="true"></i>
                                                <strong>{{ 'admin.modules.dependencies'|trans({}, 'admin') }}:</strong>
                                            </small><br>
                                            {% for dep in dependency_graph[key].dependencies %}
                                                <span class="fa-status-pill fa-status-pill--warning me-1 mb-1">{{ all_modules[dep].name }}</span>
                                            {% endfor %}
                                        </div>
                                    {% endif %}

                                    {% if dependency_graph[key].dependents|length > 0 %}
                                        <div class="mb-2">
                                            <small class="text-info">
                                                <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                                                <strong>{{ 'admin.modules.required_by'|trans({}, 'admin') }}:</strong>
                                            </small><br>
                                            {% for dep in dependency_graph[key].dependents %}
                                                <span class="fa-status-pill fa-status-pill--primary me-1 mb-1">{{ all_modules[dep].name }}</span>
                                            {% endfor %}
                                        </div>
                                    {% endif %}

                                    <div class="d-grid gap-2 mt-3">
                                        <a href="{{ path('admin_modules_details', {moduleKey: key}) }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                            <i class="fa-icon fa-icon--ui-info" aria-hidden="true"></i> {{ 'admin.modules.details'|trans({}, 'admin') }}
                                        </a>
                                        {% if not module.required %}
                                            <form method="post" action="{{ path('admin_modules_deactivate', {moduleKey: key}) }}"
                                                  data-controller="ui-actions"
                                                  data-action="submit->ui-actions#confirm"
                                                  data-ui-actions-message-param="{{ 'admin.modules.confirm_deactivate'|trans({'%name%': module.name}, 'admin') }}">
                                                <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger fa-cyber-btn--sm w-100">
                                                    <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i> {{ 'admin.modules.deactivate'|trans({}, 'admin') }}
                                                </button>
                                            </form>
                                        {% else %}
                                            <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm" disabled>
                                                <i class="fa-icon fa-icon--ui-lock" aria-hidden="true"></i> {{ 'admin.modules.required'|trans({}, 'admin') }}
                                            </button>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            {% else %}
                <p class="text-muted text-center py-4">{{ 'admin.modules.no_active'|trans({}, 'admin') }}</p>
            {% endif %}
        </div>
    </section>

    {# Inactive Modules #}
    {% set inactive_modules = [] %}
    {% for key, module in all_modules %}
        {% if key not in active_modules %}
            {% set inactive_modules = inactive_modules|merge([{key: key, module: module}]) %}
        {% endif %}
    {% endfor %}

    {% if inactive_modules|length > 0 %}
        <section class="fa-section">
            <div class="fa-section__header">
                <h2 class="fa-section__title">
                    <i class="fa-icon fa-icon--status-critical text-secondary" aria-hidden="true"></i>
                    {{ 'admin.modules.inactive_modules'|trans({}, 'admin') }} ({{ inactive_modules|length }})
                </h2>
            </div>
            <div class="fa-section__body">
                <div class="row g-3">
                    {% for item in inactive_modules %}
                        {% set key = item.key %}
                        {% set module = item.module %}
                        <div class="col-md-6 col-lg-4">
                            <div class="fa-rag-card h-100" style="border-left-color: var(--border);">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <h3 class="h6 mb-0 text-secondary">
                                        <i class="bi bi-{{ module.icon }}" aria-hidden="true"></i>
                                        {{ module.name }}
                                    </h3>
                                    <span class="fa-status-pill fa-status-pill--neutral">{{ 'admin.modules.status.inactive'|trans({}, 'admin') }}</span>
                                </div>
                                <p class="text-muted small">{{ module.description }}</p>

                                {% if dependency_graph[key].dependencies|length > 0 %}
                                    <div class="mb-2">
                                        <small class="text-warning">
                                            <i class="fa-icon fa-icon--ui-link" aria-hidden="true"></i>
                                            <strong>{{ 'admin.modules.dependencies'|trans({}, 'admin') }}:</strong>
                                        </small><br>
                                        {% for dep in dependency_graph[key].dependencies %}
                                            <span class="fa-status-pill fa-status-pill--warning me-1 mb-1">{{ all_modules[dep].name }}</span>
                                        {% endfor %}
                                    </div>
                                {% endif %}

                                <div class="d-grid gap-2 mt-3">
                                    <a href="{{ path('admin_modules_details', {moduleKey: key}) }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                        <i class="fa-icon fa-icon--ui-info" aria-hidden="true"></i> {{ 'admin.modules.details'|trans({}, 'admin') }}
                                    </a>
                                    <form method="post" action="{{ path('admin_modules_activate', {moduleKey: key}) }}">
                                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--success fa-cyber-btn--sm w-100">
                                            <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i> {{ 'admin.modules.activate'|trans({}, 'admin') }}
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}
{% endblock admin_content %}
