{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ module.name }} - {{ 'admin.modules.details'|trans({}, 'admin') }}{% endblock %}

{% block admin_title %}{{ module.name }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('admin_modules_index') }}">{{ 'admin.nav.module_management'|trans({}, 'admin') }}</a></li>
    <li class="breadcrumb-item active" aria-current="page">{{ module.name }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: module.icon, label: 'Module' },
        title: module.name,
        subtitle: module.description,
        actions: [
            { label: 'common.back_to_overview'|trans({}, 'messages'), variant: 'ghost', icon: 'arrow-left', href: path('admin_modules_index') }
        ]
    }) }}

    <div class="row">
        <div class="col-lg-8">
            {# Module Info #}
            <section class="fa-section mb-4">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="fa-icon fa-icon--ui-info" aria-hidden="true"></i>
                        Modul-Informationen
                    </h2>
                    <div class="fa-section__tools">
                        {% if is_active %}
                            <span class="fa-status-pill fa-status-pill--success fs-6">Aktiv</span>
                        {% else %}
                            <span class="fa-status-pill fa-status-pill--neutral fs-6">Inaktiv</span>
                        {% endif %}
                    </div>
                </div>
                <div class="fa-section__body">
                    <dl class="row mb-0">
                        <dt class="col-sm-3">Beschreibung</dt>
                        <dd class="col-sm-9">{{ module.description }}</dd>

                        <dt class="col-sm-3">Status</dt>
                        <dd class="col-sm-9">
                            {% if module.required %}
                                <span class="fa-status-pill fa-status-pill--warning me-1">Erforderlich</span>
                            {% else %}
                                <span class="fa-status-pill fa-status-pill--primary me-1">Optional</span>
                            {% endif %}
                            {% if is_active %}
                                <span class="fa-status-pill fa-status-pill--success">Aktiv</span>
                            {% else %}
                                <span class="fa-status-pill fa-status-pill--neutral">Inaktiv</span>
                            {% endif %}
                        </dd>

                        <dt class="col-sm-3">Entities</dt>
                        <dd class="col-sm-9">
                            {% for entity in module.entities %}
                                <span class="fa-status-pill fa-status-pill--neutral me-1">{{ entity }}</span>
                            {% endfor %}
                        </dd>

                        <dt class="col-sm-3">Routen</dt>
                        <dd class="col-sm-9">
                            {% for route in module.routes %}
                                <code class="me-2">{{ route }}</code>
                            {% endfor %}
                        </dd>
                    </dl>
                </div>
            </section>

            {# Dependencies #}
            {% if graph.dependencies|length > 0 or graph.dependents|length > 0 %}
                <section class="fa-section mb-4">
                    <div class="fa-section__header">
                        <h2 class="fa-section__title">
                            <i class="fa-icon fa-icon--nav-process" aria-hidden="true"></i>
                            Abhängigkeiten
                        </h2>
                    </div>
                    <div class="fa-section__body">
                        {% if graph.dependencies|length > 0 %}
                            <h3 class="h6 mb-2">
                                <i class="fa-icon fa-icon--ui-link text-warning" aria-hidden="true"></i>
                                Benötigt folgende Module:
                            </h3>
                            <div class="mb-4">
                                {% for dep in graph.dependencies %}
                                    <span class="fa-status-pill fa-status-pill--warning fs-6 me-2 mb-2">{{ dep }}</span>
                                {% endfor %}
                            </div>
                        {% endif %}

                        {% if graph.dependents|length > 0 %}
                            <h3 class="h6 mb-2">
                                <i class="fa-icon fa-icon--util-arrow-right text-info" aria-hidden="true"></i>
                                Wird benötigt von:
                            </h3>
                            <div>
                                {% for dep in graph.dependents %}
                                    <span class="fa-status-pill fa-status-pill--primary fs-6 me-2 mb-2">{{ dep }}</span>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                </section>
            {% endif %}

            {# Sample Data #}
            {% if sample_data|length > 0 and is_active %}
                <section class="fa-section mb-4">
                    <div class="fa-section__header">
                        <h2 class="fa-section__title">
                            <i class="bi bi-file-earmark-code" aria-hidden="true"></i>
                            Verfügbare Beispiel-Daten
                        </h2>
                    </div>
                    <div class="fa-section__body">
                        <form method="post" action="{{ path('admin_modules_import_data', {moduleKey: module_key}) }}">
                            {% for key, data in sample_data %}
                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="checkbox" name="samples[{{ key }}]" value="1" id="sample_{{ key }}">
                                    <label class="form-check-label" for="sample_{{ key }}">
                                        <strong>{{ data.name }}</strong>
                                        <br>
                                        <small class="text-muted">{{ data.description }}</small>
                                    </label>
                                </div>
                            {% endfor %}
                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary mt-3">
                                <i class="fa-icon fa-icon--nav-download" aria-hidden="true"></i>
                                Ausgewählte Daten importieren
                            </button>
                        </form>
                    </div>
                </section>
            {% endif %}
        </div>

        <div class="col-lg-4">
            {# Actions #}
            <section class="fa-section mb-4">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="bi bi-gears" aria-hidden="true"></i>
                        Aktionen
                    </h2>
                </div>
                <div class="fa-section__body">
                    <div class="d-grid gap-2">
                        {% if is_active %}
                            {% if not module.required %}
                                <form method="post" action="{{ path('admin_modules_deactivate', {moduleKey: module_key}) }}"
                                      data-controller="ui-actions"
                                      data-action="submit->ui-actions#confirm"
                                      data-ui-actions-message-param="Modul {{ module.name }} wirklich deaktivieren?">
                                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger w-100">
                                        <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i>
                                        Modul deaktivieren
                                    </button>
                                </form>
                            {% else %}
                                <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost" disabled>
                                    <i class="fa-icon fa-icon--ui-lock" aria-hidden="true"></i>
                                    Modul ist erforderlich
                                </button>
                            {% endif %}

                            <a href="{{ path('admin_modules_export', {moduleKey: module_key}) }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                                <i class="fa-icon fa-icon--import" aria-hidden="true"></i>
                                Daten exportieren
                            </a>
                        {% else %}
                            <form method="post" action="{{ path('admin_modules_activate', {moduleKey: module_key}) }}">
                                <button type="submit" class="fa-cyber-btn fa-cyber-btn--success w-100">
                                    <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i>
                                    Modul aktivieren
                                </button>
                            </form>
                        {% endif %}

                        <a href="{{ path('admin_modules_graph') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                            <i class="fa-icon fa-icon--nav-process" aria-hidden="true"></i>
                            Dependency-Graph
                        </a>
                    </div>
                </div>
            </section>

            {# Quick Info #}
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="fa-icon fa-icon--ui-lightbulb" aria-hidden="true"></i>
                        Hinweise
                    </h2>
                </div>
                <div class="fa-section__body">
                    <ul class="mb-0 small">
                        {% if module.required %}
                            <li>Dieses Modul ist erforderlich und kann nicht deaktiviert werden</li>
                        {% endif %}
                        {% if graph.dependents|length > 0 %}
                            <li>Andere Module hängen von diesem Modul ab</li>
                        {% endif %}
                        <li>Beim Deaktivieren werden keine Daten gelöscht</li>
                        <li>Sie können das Modul jederzeit wieder aktivieren</li>
                    </ul>
                </div>
            </section>
        </div>
    </div>
{% endblock admin_content %}
