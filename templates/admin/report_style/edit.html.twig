{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'admin' %}
{% import '_components/_status_pill.html.twig' as pill %}

{% block title %}{{ 'admin.report_style.title'|trans }} — {{ tenant.name }}{% endblock %}

{% block admin_content %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% include '_components/_breadcrumb.html.twig' with {
    breadcrumbs: [
        { label: 'admin.dashboard.title'|trans({}, 'admin'), url: path('admin_hub_index') },
        { label: 'admin.report_style.title'|trans }
    ]
} %}

{{ _fa_page_header.render({
    badge: { icon: 'file-earmark-bar-graph', label: tenant.name },
    title: 'admin.report_style.title'|trans,
    subtitle: 'admin.report_style.subtitle'|trans
}) }}

<main class="fa-aurora-surface">

{% set _flash_variant_map = { 'success': 'success', 'error': 'danger', 'danger': 'danger', 'warning': 'warning', 'info': 'info', 'notice': 'info' } %}
{% for label, msgs in app.flashes %}
    {% for msg in msgs %}
        {{ _fa_alert.render({ variant: _flash_variant_map[label]|default('info'), body: msg|trans, class: 'mb-3' }) }}
    {% endfor %}
{% endfor %}

<div class="row g-4"
     data-controller="report-style-preview"
     data-report-style-preview-preview-url-value="{{ path('app_admin_report_style_preview') }}"
     data-report-style-preview-csrf-value="{{ csrf_token('admin_report_style_preview') }}">

    {# ---------- Form column (left) ---------- #}
    <div class="col-xl-7">
        <section class="fa-section">
            <header class="fa-section__header">
                <h2 class="fa-section__title">{{ 'admin.report_style.section.form'|trans }}</h2>
                <p class="fa-section__subtitle text-muted small mb-0">
                    {{ 'admin.report_style.section.form_subtitle'|trans }}
                </p>
            </header>
            <div class="fa-section__body">
                {{ form_start(form, {
                    attr: form.vars.attr|merge({
                        'data-action': 'change->report-style-preview#refresh input->report-style-preview#refresh'
                    })
                }) }}

                <h3 class="h6 text-muted mb-3">{{ 'admin.report_style.group.cover'|trans }}</h3>
                <div class="row g-3">
                    <div class="col-md-6">{{ form_row(form.reportDocCoverPattern) }}</div>
                    <div class="col-md-6">{{ form_row(form.reportDocDefaultAudience) }}</div>
                </div>

                <hr class="my-4">
                <h3 class="h6 text-muted mb-3">{{ 'admin.report_style.group.typography'|trans }}</h3>
                <div class="row g-3">
                    <div class="col-md-6">{{ form_row(form.reportDocFontFamily) }}</div>
                    <div class="col-md-6">{{ form_row(form.reportDocPageOrientation) }}</div>
                </div>

                <hr class="my-4">
                <h3 class="h6 text-muted mb-3">{{ 'admin.report_style.group.charts'|trans }}</h3>
                <div class="row g-3">
                    <div class="col-md-6">{{ form_row(form.reportDocChartColorScheme) }}</div>
                    <div class="col-md-6">
                        {# Color-scheme swatches (4 mini previews) #}
                        <label class="form-label">{{ 'admin.report_style.swatches.label'|trans }}</label>
                        <div class="d-flex flex-column gap-2 small">
                            {% for scheme, swatch in {
                                'aurora': ['#22d3ee','#a855f7','#10b981','#f59e0b','#ef4444'],
                                'audit': ['#1e293b','#334155','#64748b','#94a3b8','#cbd5e1'],
                                'print-friendly': ['#000000','#404040','#808080','#a0a0a0','#d0d0d0'],
                                'colorblind-safe': ['#0072B2','#E69F00','#009E73','#CC79A7','#F0E442']
                            } %}
                                <div class="d-flex align-items-center gap-2">
                                    <span class="text-muted" style="min-width:6rem;">
                                        {{ ('admin.report_style.chart.' ~ scheme|replace({'-':'_'}))|trans }}
                                    </span>
                                    <span class="d-inline-flex" aria-hidden="true">
                                        {% for hex in swatch %}
                                            <span style="display:inline-block;width:14px;height:14px;border:1px solid var(--border);background:{{ hex }};"></span>
                                        {% endfor %}
                                    </span>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                <hr class="my-4">
                <h3 class="h6 text-muted mb-3">{{ 'admin.report_style.group.watermark'|trans }}</h3>
                <div class="row g-3 align-items-end">
                    <div class="col-md-4">{{ form_row(form.reportDocWatermarkEnabled) }}</div>
                    <div class="col-md-8">
                        <label for="{{ form.reportDocWatermarkOpacity.vars.id }}" class="form-label">
                            {{ 'admin.report_style.field.watermark_opacity'|trans }}
                            (<span data-report-style-preview-target="opacityLabel">{{ ((form.reportDocWatermarkOpacity.vars.value ?? 0.0)|number_format(2, '.', '') * 100)|round }}%</span>)
                        </label>
                        <input type="range"
                               class="form-range"
                               min="0" max="100" step="1"
                               value="{{ ((form.reportDocWatermarkOpacity.vars.value ?? 0.0)|number_format(2, '.', '') * 100)|round }}"
                               data-report-style-preview-target="opacitySlider"
                               data-action="input->report-style-preview#syncOpacity"
                               aria-label="{{ 'admin.report_style.field.watermark_opacity'|trans }}">
                        {{ form_widget(form.reportDocWatermarkOpacity, {attr: {hidden: true, class: 'visually-hidden'}}) }}
                        <p class="form-text">{{ 'admin.report_style.help.watermark_opacity'|trans }}</p>
                    </div>
                </div>

                <hr class="my-4">
                <h3 class="h6 text-muted mb-3">{{ 'admin.report_style.group.slots'|trans }}</h3>
                <div class="d-flex flex-column gap-2">
                    {{ form_row(form.reportDocShowExecSummary) }}
                    {{ form_row(form.reportDocShowAppendix) }}
                    {{ form_row(form.reportDocShowDistributionList) }}
                </div>

                <hr class="my-4">
                <h3 class="h6 text-muted mb-3">{{ 'admin.report_style.group.footer'|trans }}</h3>
                <div class="row g-3">
                    <div class="col-12">{{ form_row(form.reportDocFooterDisclaimer) }}</div>
                </div>

                {% if form.reportDocCustomCss is defined %}
                    <hr class="my-4">
                    <h3 class="h6 text-muted mb-3">
                        {{ 'admin.report_style.group.advanced'|trans }}
                        {{ pill.render('ROLE_ADMIN', 'warning', {size: 'sm', class: 'ms-2'}) }}
                    </h3>
                    {{ form_row(form.reportDocCustomCss) }}
                {% endif %}

                <div class="d-flex flex-wrap gap-2 mt-4">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                        <i class="bi bi-check2 me-1"></i>{{ 'admin.report_style.save'|trans }}
                    </button>
                    <a href="{{ path('admin_hub_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                        {{ 'admin.cancel'|trans }}
                    </a>
                </div>
                {{ form_end(form) }}

                {# Reset-Form: separate submit, dedicated CSRF token. #}
                <form method="post"
                      action="{{ path('app_admin_report_style_reset') }}"
                      class="mt-3"
                      onsubmit="return confirm('{{ 'admin.report_style.reset_confirm'|trans|e('js') }}');">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_report_style_reset') }}">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost btn-sm text-warning">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>
                        {{ 'admin.report_style.reset'|trans }}
                    </button>
                </form>
            </div>
        </section>
    </div>

    {# ---------- Live preview column (right) ---------- #}
    <div class="col-xl-5">
        <section class="fa-section position-sticky" style="top: 1.5rem;">
            <header class="fa-section__header">
                <h2 class="fa-section__title">{{ 'admin.report_style.section.preview'|trans }}</h2>
                <p class="fa-section__subtitle text-muted small mb-0">
                    {{ 'admin.report_style.section.preview_subtitle'|trans }}
                </p>
            </header>
            <div class="fa-section__body">
                <div class="report-style-preview-frame"
                     data-report-style-preview-target="frame"
                     aria-live="polite">
                    {% include 'admin/report_style/_preview.html.twig' with {
                        tenant: tenant,
                        style_config: style_config,
                        sample: sample
                    } %}
                </div>
            </div>
        </section>
    </div>
</div>
</main>
{% endblock %}
