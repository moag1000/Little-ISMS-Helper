{#
 # Report-Doc Live-Preview fragment.
 #
 # Receives the same `style_config` array shape that
 # `_fa_report_doc.html.twig` (sister-agent W7-parallel) consumes.
 # We render a built-in "preview-light" 5-slot layout (cover /
 # exec-summary / data / appendix / footer) so the configurator
 # stays usable while the canonical macro is in flight. Once the
 # macro lands, this can be replaced with a `_fa_report_doc.render`
 # call without changing the configurator.
 #
 # Locals:
 #   - tenant       : App\Entity\Tenant
 #   - style_config : array<string, mixed> — reportDocStyleConfig snapshot
 #   - sample       : array — sample report data (sections, kpis, distribution)
 #}
{% trans_default_domain 'admin' %}

{% set _font = style_config.font_family|default('Inter') %}
{% set _cover = style_config.cover_pattern|default('branded') %}
{% set _audience = style_config.default_audience|default('internal') %}
{% set _orientation = style_config.page_orientation|default('auto') %}
{% set _chart_scheme = style_config.chart_color_scheme|default('aurora') %}
{% set _watermark_on = style_config.watermark_enabled|default(true) %}
{% set _watermark_op = style_config.watermark_opacity|default(0.08) %}
{% set _show_exec = style_config.show_exec_summary|default(true) %}
{% set _show_appendix = style_config.show_appendix|default(true) %}
{% set _show_distribution = style_config.show_distribution_list|default(true) %}
{% set _disclaimer = style_config.footer_disclaimer|default('') %}
{% set _primary = style_config.primary_color|default('#0d6efd') %}
{% set _secondary = style_config.secondary_color|default('#6c757d') %}
{% set _custom_css = style_config.custom_css|default('') %}

{# Audience-driven layout flags drive watermark text + cover label. #}
{% set _audience_label = {
    'vorstand': 'admin.report_style.audience.vorstand',
    'auditor': 'admin.report_style.audience.auditor',
    'aufsicht': 'admin.report_style.audience.aufsicht',
    'internal': 'admin.report_style.audience.internal'
}[_audience]|default('admin.report_style.audience.internal') %}

{% set _chart_palette = {
    'aurora': ['#22d3ee','#a855f7','#10b981','#f59e0b','#ef4444'],
    'audit': ['#1e293b','#334155','#64748b','#94a3b8','#cbd5e1'],
    'print-friendly': ['#000000','#404040','#808080','#a0a0a0','#d0d0d0'],
    'colorblind-safe': ['#0072B2','#E69F00','#009E73','#CC79A7','#F0E442']
}[_chart_scheme]|default(['#22d3ee','#a855f7','#10b981','#f59e0b','#ef4444']) %}

<div class="report-doc-preview report-doc-preview--cover-{{ _cover }} report-doc-preview--audience-{{ _audience }} report-doc-preview--orientation-{{ _orientation }}"
     data-report-style-preview-target="frameInner"
     style="--rd-font: '{{ _font }}', system-ui, sans-serif;
            --rd-primary: {{ _primary }};
            --rd-secondary: {{ _secondary }};
            --rd-watermark-opacity: {{ _watermark_op }};
            --rd-chart-1: {{ _chart_palette[0] }};
            --rd-chart-2: {{ _chart_palette[1] }};
            --rd-chart-3: {{ _chart_palette[2] }};
            --rd-chart-4: {{ _chart_palette[3] }};
            --rd-chart-5: {{ _chart_palette[4] }};">

    {# --- Slot 1: Cover --- #}
    <article class="report-doc-preview__page report-doc-preview__page--cover">
        {% if _watermark_on %}
            <div class="report-doc-preview__watermark" aria-hidden="true">
                {{ sample.classification|default('TLP:AMBER') }}
            </div>
        {% endif %}

        <header class="report-doc-preview__cover-header">
            <div class="report-doc-preview__logo" aria-hidden="true">
                <i class="bi bi-file-earmark-bar-graph"></i>
            </div>
            <div>
                <p class="report-doc-preview__tenant">{{ sample.tenant_name|default(tenant.name) }}</p>
                <p class="report-doc-preview__doccode text-muted">{{ sample.report_code|default('RPT-XXX-001') }}</p>
            </div>
        </header>

        <div class="report-doc-preview__cover-body">
            <p class="report-doc-preview__eyebrow">{{ _audience_label|trans }}</p>
            <h1 class="report-doc-preview__title">{{ sample.report_title|default('ISMS-Management-Review') }}</h1>
            <dl class="report-doc-preview__meta">
                <dt>{{ 'admin.report_style.preview.period'|trans }}</dt>
                <dd>{{ sample.report_period|default('—') }}</dd>
                <dt>{{ 'admin.report_style.preview.classification'|trans }}</dt>
                <dd>{{ sample.classification|default('TLP:AMBER') }}</dd>
                <dt>{{ 'admin.report_style.preview.audience'|trans }}</dt>
                <dd>{{ _audience_label|trans }}</dd>
            </dl>
        </div>
    </article>

    {# --- Slot 2: Exec-Summary --- #}
    {% if _show_exec %}
        <article class="report-doc-preview__page report-doc-preview__page--exec">
            <h2 class="report-doc-preview__h2">{{ 'admin.report_style.preview.exec_summary'|trans }}</h2>
            <p class="report-doc-preview__body-text">{{ sample.exec_summary }}</p>

            <div class="report-doc-preview__kpi-row">
                {% for kpi in sample.kpis %}
                    <div class="report-doc-preview__kpi">
                        <span class="report-doc-preview__kpi-value">{{ kpi.value }}</span>
                        <span class="report-doc-preview__kpi-label text-muted">{{ kpi.label }}</span>
                    </div>
                {% endfor %}
            </div>
        </article>
    {% endif %}

    {# --- Slot 3: Data --- #}
    <article class="report-doc-preview__page report-doc-preview__page--data">
        <h2 class="report-doc-preview__h2">{{ 'admin.report_style.preview.data_section'|trans }}</h2>
        {% for s in sample.sections %}
            <section class="report-doc-preview__section">
                <h3 class="report-doc-preview__h3">{{ s.number }} {{ s.title }}</h3>
                <p class="report-doc-preview__body-text">{{ s.preview }}</p>
            </section>
        {% endfor %}

        {# Mini bar-chart preview using the active color scheme #}
        <div class="report-doc-preview__chart-mock" aria-hidden="true">
            {% for i in 1..5 %}
                <span class="report-doc-preview__bar" style="--bar-bg: var(--rd-chart-{{ i }}); --bar-h: {{ 30 + (i * 12) }}%;"></span>
            {% endfor %}
        </div>
    </article>

    {# --- Slot 4: Appendix (optional) --- #}
    {% if _show_appendix %}
        <article class="report-doc-preview__page report-doc-preview__page--appendix">
            <h2 class="report-doc-preview__h2">{{ 'admin.report_style.preview.appendix'|trans }}</h2>
            <ol class="report-doc-preview__appendix-list">
                {% for a in sample.appendix %}
                    <li><strong>{{ a.code }}</strong> — {{ a.title }}</li>
                {% endfor %}
            </ol>

            {% if _show_distribution %}
                <h3 class="report-doc-preview__h3">{{ 'admin.report_style.preview.distribution_list'|trans }}</h3>
                <table class="report-doc-preview__distribution-table">
                    <thead>
                        <tr>
                            <th>{{ 'admin.report_style.preview.col_recipient'|trans }}</th>
                            <th>{{ 'admin.report_style.preview.col_role'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for d in sample.distribution %}
                            <tr><td>{{ d.name }}</td><td>{{ d.role }}</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </article>
    {% endif %}

    {# --- Slot 5: Footer --- #}
    <footer class="report-doc-preview__footer text-muted">
        {% if _disclaimer %}
            {{ _disclaimer }}
        {% else %}
            {{ 'admin.report_style.preview.default_footer'|trans({ '%tenant%': sample.tenant_name|default(tenant.name) }) }}
        {% endif %}
    </footer>
</div>

{# Custom-CSS preview (inert; only applied to real export to avoid
   layout-breaking the configurator). #}
{% if _custom_css %}
    <details class="mt-3">
        <summary class="text-muted small">{{ 'admin.report_style.preview.custom_css_inert'|trans }}</summary>
        <pre class="border rounded p-2 small bg-body-tertiary"><code>{{ _custom_css }}</code></pre>
    </details>
{% endif %}

<style>
.report-doc-preview {
    font-family: var(--rd-font);
    background: var(--surface, #fff);
    border: 1px solid var(--border, #dee2e6);
    border-radius: 6px;
    overflow: hidden;
    position: relative;
    transform: scale(0.92);
    transform-origin: top center;
}
.report-doc-preview--orientation-landscape { aspect-ratio: 1.41 / 1; }
.report-doc-preview__page {
    padding: 18mm 16mm;
    border-bottom: 1px dashed var(--border, #dee2e6);
    position: relative;
    min-height: 220px;
}
.report-doc-preview__page:last-of-type { border-bottom: 0; }
.report-doc-preview__watermark {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    font-weight: 800;
    letter-spacing: 0.5rem;
    color: var(--rd-primary);
    opacity: var(--rd-watermark-opacity);
    pointer-events: none;
    transform: rotate(-30deg);
    user-select: none;
}
.report-doc-preview__cover-header {
    display: flex; align-items: center; gap: 1rem;
    margin-bottom: 2rem;
}
.report-doc-preview__logo {
    width: 56px; height: 56px; border-radius: 8px;
    background: var(--rd-primary); color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.6rem; flex: 0 0 auto;
}
.report-doc-preview__tenant { font-weight: 700; margin: 0; font-size: 1.1rem; }
.report-doc-preview__doccode { margin: 0; font-size: 0.85rem; }
.report-doc-preview__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.75rem;
    color: var(--rd-secondary);
    margin: 0 0 0.5rem 0;
}
.report-doc-preview__title {
    font-size: 1.65rem;
    color: var(--rd-primary);
    margin: 0 0 1rem 0;
    line-height: 1.15;
}
.report-doc-preview__meta {
    display: grid; grid-template-columns: max-content 1fr;
    gap: 0.25rem 1rem; font-size: 0.85rem; margin: 0;
}
.report-doc-preview__meta dt { color: var(--rd-secondary); }
.report-doc-preview__meta dd { margin: 0; font-weight: 600; }
.report-doc-preview__h2 {
    color: var(--rd-primary);
    font-size: 1.05rem;
    margin: 0 0 0.75rem 0;
    border-bottom: 2px solid var(--rd-primary);
    padding-bottom: 0.25rem;
}
.report-doc-preview__h3 {
    color: var(--rd-secondary);
    font-size: 0.95rem;
    margin: 0.75rem 0 0.4rem 0;
}
.report-doc-preview__body-text { font-size: 0.85rem; line-height: 1.55; margin: 0 0 0.5rem 0; }
.report-doc-preview__section { margin-bottom: 0.75rem; }
.report-doc-preview__kpi-row {
    display: flex; gap: 1rem; margin-top: 1rem;
    padding-top: 0.75rem; border-top: 1px dashed var(--border);
}
.report-doc-preview__kpi {
    display: flex; flex-direction: column; flex: 1 1 0;
    align-items: center; text-align: center;
}
.report-doc-preview__kpi-value {
    font-size: 1.4rem; font-weight: 700; color: var(--rd-primary);
}
.report-doc-preview__kpi-label { font-size: 0.7rem; }
.report-doc-preview__chart-mock {
    margin-top: 0.75rem;
    height: 80px;
    display: flex; align-items: flex-end; gap: 8px;
    padding: 6px 0;
    border-top: 1px dashed var(--border);
}
.report-doc-preview__bar {
    flex: 1 1 0;
    background: var(--bar-bg);
    height: var(--bar-h);
    border-radius: 2px 2px 0 0;
}
.report-doc-preview__appendix-list {
    margin: 0 0 0.75rem 1rem; padding: 0;
    font-size: 0.85rem;
}
.report-doc-preview__appendix-list li { margin-bottom: 0.2rem; }
.report-doc-preview__distribution-table {
    width: 100%; border-collapse: collapse; font-size: 0.8rem;
}
.report-doc-preview__distribution-table th,
.report-doc-preview__distribution-table td {
    border: 1px solid var(--border, #dee2e6);
    padding: 0.35rem 0.5rem; text-align: left;
}
.report-doc-preview__distribution-table th {
    background: var(--surface-2, #f8f9fa);
    color: var(--rd-secondary);
    font-weight: 600;
}
.report-doc-preview__footer {
    padding: 0.75rem 16mm;
    font-size: 0.7rem;
    background: var(--surface-2, #f8f9fa);
    border-top: 1px solid var(--border, #dee2e6);
}

/* Cover-pattern variants */
.report-doc-preview--cover-minimal .report-doc-preview__title {
    color: var(--rd-secondary); border: 0;
}
.report-doc-preview--cover-minimal .report-doc-preview__h2 { border-color: var(--rd-secondary); }
.report-doc-preview--cover-board-formal .report-doc-preview__title {
    font-family: 'Merriweather', serif;
    text-align: center;
    letter-spacing: 0.02em;
}
.report-doc-preview--cover-board-formal .report-doc-preview__cover-header {
    justify-content: center; text-align: center; flex-direction: column;
}
.report-doc-preview--cover-auditor-formal .report-doc-preview__title {
    font-family: 'Merriweather', serif;
}
.report-doc-preview--cover-auditor-formal .report-doc-preview__h2 {
    text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.95rem;
}

/* Audience-driven cover labels (eyebrow color) */
.report-doc-preview--audience-vorstand .report-doc-preview__eyebrow { color: var(--rd-primary); font-weight: 700; }
.report-doc-preview--audience-auditor .report-doc-preview__eyebrow { color: #1e293b; }
.report-doc-preview--audience-aufsicht .report-doc-preview__eyebrow { color: #b91c1c; }
</style>
