{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block admin_title %}{{ 'audit_log.retention.title'|trans({}, 'audit_log') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item active" aria-current="page">{{ 'audit_log.retention.title'|trans({}, 'audit_log') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'archive', label: 'Audit Log' },
        title: 'audit_log.retention.title'|trans({}, 'audit_log'),
        subtitle: 'audit_log.retention.subtitle'|trans({}, 'audit_log'),
    }) }}

    <div class="row">
        <div class="col-lg-8">
            <section class="fa-section mb-4">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="fa-icon fa-icon--nav-sliders" aria-hidden="true"></i>
                        {{ 'audit_log.retention.setting_title'|trans({}, 'audit_log') }}
                    </h2>
                </div>
                <div class="fa-section__body">
                    <form method="post" action="{{ path('app_admin_audit_retention') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('audit_retention') }}">

                        <div class="mb-3">
                            <label for="retention_days" class="form-label fw-semibold">
                                {{ 'audit_log.retention.field.days'|trans({}, 'audit_log') }}
                            </label>
                            <input type="number"
                                   class="form-control fa-cyber-input__field"
                                   id="retention_days"
                                   name="retention_days"
                                   value="{{ retention_days }}"
                                   min="{{ min_days }}"
                                   max="{{ max_days }}"
                                   step="1"
                                   required
                                   aria-describedby="retention_help">
                            <div id="retention_help" class="form-text">
                                {{ 'audit_log.retention.field.help'|trans({'%min%': min_days, '%max%': max_days, '%default%': default_days}, 'audit_log') }}
                            </div>
                        </div>

                        {{ _fa_alert.render({ variant: 'warning', class: 'small mb-3', body: 'audit_log.retention.warning'|trans({}, 'audit_log') }) }}

                        <div class="d-flex gap-2">
                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                                <i class="fa-icon fa-icon--ui-save" aria-hidden="true"></i>
                                {{ 'common.save'|trans({}, 'messages') }}
                            </button>
                        </div>
                    </form>
                </div>
            </section>

            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="fa-icon fa-icon--ui-info" aria-hidden="true"></i>
                        {{ 'audit_log.retention.compliance_title'|trans({}, 'audit_log') }}
                    </h2>
                </div>
                <div class="fa-section__body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">DSGVO Art. 5.1(e)</dt>
                        <dd class="col-sm-8">{{ 'audit_log.retention.compliance.gdpr'|trans({}, 'audit_log') }}</dd>

                        <dt class="col-sm-4">NIS2 Art. 21.2</dt>
                        <dd class="col-sm-8">{{ 'audit_log.retention.compliance.nis2'|trans({}, 'audit_log') }}</dd>

                        <dt class="col-sm-4">ISO 27001 Clause 9.1</dt>
                        <dd class="col-sm-8">{{ 'audit_log.retention.compliance.iso'|trans({}, 'audit_log') }}</dd>
                    </dl>
                </div>
            </section>
        </div>
    </div>
{% endblock %}
