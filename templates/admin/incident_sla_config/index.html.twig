{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'incident_sla.title'|trans({}, 'incident_sla') }}{% endblock %}

{% block admin_content %}
<div class="container-fluid">
    {{ _fa_page_header.render({
        badge: { icon: 'stopwatch', label: 'SLA' },
        title: 'incident_sla.title'|trans({}, 'incident_sla'),
        subtitle: 'incident_sla.subtitle'|trans({}, 'incident_sla'),
    }) }}

    <div class="row">
        <div class="col-lg-10">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="fa-icon fa-icon--nav-list-ordered" aria-hidden="true"></i>
                        {{ 'incident_sla.section.list'|trans({}, 'incident_sla') }}
                    </h2>
                </div>
                <div class="fa-section__body">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th scope="col">{{ 'incident_sla.field.severity'|trans({}, 'incident_sla') }}</th>
                                    <th scope="col">{{ 'incident_sla.field.response_hours'|trans({}, 'incident_sla') }}</th>
                                    <th scope="col">{{ 'incident_sla.field.escalation_hours'|trans({}, 'incident_sla') }}</th>
                                    <th scope="col">{{ 'incident_sla.field.resolution_hours'|trans({}, 'incident_sla') }}</th>
                                    <th scope="col">{{ 'incident_sla.updated_at'|trans({}, 'incident_sla') }}</th>
                                    <th scope="col" class="text-end">{{ 'common.actions'|trans({}, 'messages') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for config in configs %}
                                    {% set variant = (config.severity == 'breach' or config.severity == 'critical') ? 'danger' : (config.severity == 'high' ? 'warning' : (config.severity == 'medium' ? 'info' : 'secondary')) %}
                                    <tr>
                                        <td>
                                            {% set _svpill = variant in ['info'] ? 'primary' : (variant in ['secondary','light','dark'] ? 'neutral' : variant) %}
                                            <span class="badge bg-{{ variant }} fa-status-pill fa-status-pill--{{ _svpill }}">
                                                {{ ('incident_sla.severity.' ~ config.severity)|trans({}, 'incident_sla') }}
                                            </span>
                                        </td>
                                        <td><strong>{{ config.responseHours }}h</strong></td>
                                        <td>{{ config.escalationHours ? config.escalationHours ~ 'h' : '—' }}</td>
                                        <td>{{ config.resolutionHours ? config.resolutionHours ~ 'h' : '—' }}</td>
                                        <td class="small text-muted">
                                            {{ config.updatedAt ? config.updatedAt|date('d.m.Y H:i') : '—' }}
                                        </td>
                                        <td class="text-end">
                                            <a href="{{ path('app_admin_incident_sla_config_edit', {id: config.id}) }}"
                                               class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
                                               aria-label="{{ 'common.edit'|trans({}, 'messages') }}">
                                                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                                            </a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {{ _fa_alert.render({ variant: 'info', icon: 'bi-info-circle', class: 'small mb-0 mt-3', body: 'incident_sla.hint.regulatory'|trans({}, 'incident_sla') }) }}
                </div>
            </section>
        </div>
    </div>
</div>
{% endblock %}
