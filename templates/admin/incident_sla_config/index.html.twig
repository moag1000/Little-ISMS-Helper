{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_status_pill.html.twig' as pill %}

{% block title %}{{ 'incident_sla.title'|trans({}, 'incident_sla') }}{% endblock %}

{% block admin_content %}
<div class="container-fluid">
    {{ _fa_page_header.render({
        badge: { icon: 'ui-hourglass', label: 'SLA' },
        title: 'incident_sla.title'|trans({}, 'incident_sla'),
        subtitle: 'incident_sla.subtitle'|trans({}, 'incident_sla'),
    }) }}

    <div class="row">
        <div class="col-lg-10">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="fa-icon fa-icon--nav-list-ordered" aria-hidden="true"></i>
                        {{ 'incident_sla.section.list'|trans({}, 'incident_sla') }}
                    </h2>
                </div>
                <div class="fa-section__body">
                    {# V3 W3-UX: migrated to fa-table Aurora pattern #}
                    {% embed '_components/_fa_table.html.twig' with { hover: true, sortable: true } %}
                        {% block table_head %}
                            <tr>
                                <th class="fa-table__th fa-table__th--sortable" data-sort-key="severity" tabindex="0" role="columnheader" aria-sort="none" data-action="click->fa-table-sort#sort keydown.enter->fa-table-sort#sort keydown.space->fa-table-sort#sort">{{ 'incident_sla.field.severity'|trans({}, 'incident_sla') }}</th>
                                <th class="fa-table__th fa-table__th--sortable fa-table__th--num" data-sort-key="response" tabindex="0" role="columnheader" aria-sort="none" data-action="click->fa-table-sort#sort keydown.enter->fa-table-sort#sort keydown.space->fa-table-sort#sort">{{ 'incident_sla.field.response_hours'|trans({}, 'incident_sla') }}</th>
                                <th class="fa-table__th fa-table__th--num">{{ 'incident_sla.field.escalation_hours'|trans({}, 'incident_sla') }}</th>
                                <th class="fa-table__th fa-table__th--num">{{ 'incident_sla.field.resolution_hours'|trans({}, 'incident_sla') }}</th>
                                <th class="fa-table__th">{{ 'incident_sla.updated_at'|trans({}, 'incident_sla') }}</th>
                                <th class="fa-table__th fa-table__th--actions">{{ 'common.actions'|trans({}, 'messages') }}</th>
                            </tr>
                        {% endblock %}
                        {% block table_body %}
                            {% import '_components/_status_pill.html.twig' as pill %}
                            {% for config in configs %}
                                {% set variant = (config.severity == 'breach' or config.severity == 'critical') ? 'danger' : (config.severity == 'high' ? 'warning' : (config.severity == 'medium' ? 'info' : 'secondary')) %}
                                <tr class="fa-table__row">
                                    <td class="fa-table__cell" data-sort-value="{{ config.severity }}">
                                        {% set _svtone = variant in ['info'] ? 'primary' : (variant in ['secondary','light','dark'] ? 'neutral' : variant) %}
                                        {{ pill.render(('incident_sla.severity.' ~ config.severity)|trans({}, 'incident_sla'), _svtone, {size: 'sm'}) }}
                                    </td>
                                    <td class="fa-table__cell fa-table__cell--num" data-sort-value="{{ config.responseHours }}"><strong>{{ config.responseHours }}h</strong></td>
                                    <td class="fa-table__cell fa-table__cell--num">{{ config.escalationHours ? config.escalationHours ~ 'h' : '—' }}</td>
                                    <td class="fa-table__cell fa-table__cell--num">{{ config.resolutionHours ? config.resolutionHours ~ 'h' : '—' }}</td>
                                    <td class="fa-table__cell fa-table__cell--muted">
                                        {{ config.updatedAt ? config.updatedAt|date('d.m.Y H:i') : '—' }}
                                    </td>
                                    <td class="fa-table__cell fa-table__cell--actions">
                                        <a href="{{ path('app_admin_incident_sla_config_edit', {id: config.id}) }}"
                                           class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
                                           aria-label="{{ 'common.edit'|trans({}, 'messages') }}">
                                            <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endblock %}
                    {% endembed %}
                    {{ _fa_alert.render({ variant: 'info', icon: 'status-info', class: 'small mb-0 mt-3', body: 'incident_sla.hint.regulatory'|trans({}, 'incident_sla') }) }}
                </div>
            </section>
        </div>
    </div>
</div>
{% endblock %}
