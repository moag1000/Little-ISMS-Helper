{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'incident_sla' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block admin_title %}{{ 'incident_sla.edit.title'|trans({'%severity%': ('incident_sla.severity.' ~ config.severity)|trans({}, 'incident_sla')}, 'incident_sla') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_incident_sla_config') }}">{{ 'incident_sla.back_to_list'|trans({}, 'incident_sla') }}</a></li>
    <li class="breadcrumb-item active" aria-current="page">{{ 'incident_sla.edit.title'|trans({'%severity%': ('incident_sla.severity.' ~ config.severity)|trans({}, 'incident_sla')}, 'incident_sla') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'stopwatch', label: 'SLA' },
        title: 'incident_sla.edit.title'|trans({'%severity%': ('incident_sla.severity.' ~ config.severity)|trans({}, 'incident_sla')}, 'incident_sla'),
        subtitle: 'incident_sla.section.edit'|trans({}, 'incident_sla'),
        actions: [
            { label: 'incident_sla.back_to_list'|trans({}, 'incident_sla'), variant: 'ghost', icon: 'arrow-left', href: path('app_admin_incident_sla_config') }
        ]
    }) }}

    <div class="row">
        <div class="col-lg-8">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="fa-icon fa-icon--nav-sliders" aria-hidden="true"></i>
                        {{ 'incident_sla.section.edit'|trans({}, 'incident_sla') }}
                    </h2>
                </div>
                <div class="fa-section__body">
                    {{ form_start(form) }}
                        <div class="mb-3">{{ form_row(form.responseHours, { attr: { class: 'form-control' } }) }}</div>
                        <div class="mb-3">{{ form_row(form.escalationHours, { attr: { class: 'form-control' } }) }}</div>
                        <div class="mb-3">{{ form_row(form.resolutionHours, { attr: { class: 'form-control' } }) }}</div>
                        <div class="mb-3">{{ form_row(form.note, { attr: { class: 'form-control' } }) }}</div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                                <i class="fa-icon fa-icon--ui-save" aria-hidden="true"></i>
                                {{ 'common.save'|trans({}, 'messages') }}
                            </button>
                            <a href="{{ path('app_admin_incident_sla_config') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                                {{ 'common.cancel'|trans({}, 'messages') }}
                            </a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </section>
        </div>
    </div>
{% endblock %}
