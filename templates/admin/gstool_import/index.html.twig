{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'gstool_import' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_status_pill.html.twig' as pill %}

{% block title %}{{ 'gstool_import.title'|trans({}, 'gstool_import') }}{% endblock %}

{% block admin_title %}{{ 'gstool_import.title'|trans({}, 'gstool_import') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item active" aria-current="page">{{ 'gstool_import.title'|trans({}, 'gstool_import') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'ui-upload', label: 'Import' },
        title: 'gstool_import.title'|trans({}, 'gstool_import'),
        subtitle: 'gstool_import.intro'|trans({}, 'gstool_import'),
    }) }}

    <section class="fa-section mb-4">
        <div class="fa-section__header">
            <h2 class="fa-section__title">
                <i class="fa-icon fa-icon--nav-upload" aria-hidden="true"></i>
                {{ 'gstool_import.upload.card_title'|trans({}, 'gstool_import') }}
            </h2>
        </div>
        <div class="fa-section__body">
            <p class="text-muted">{{ 'gstool_import.intro'|trans({}, 'gstool_import') }}</p>

            {{ form_start(form) }}
                {{ form_row(form.file) }}
                {{ form_row(form.dryRun) }}
                {{ form_row(form.submit) }}
            {{ form_end(form) }}

            <div class="mt-4">
                <h3 class="h6">{{ 'gstool_import.schema.title'|trans({}, 'gstool_import') }}</h3>
                <p class="small text-muted">{{ 'gstool_import.schema.description'|trans({}, 'gstool_import') }}</p>
                <pre class="small bg-body-secondary p-3 rounded"><code>&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;gstool-export version="1.0"&gt;
  &lt;zielobjekte&gt;
    &lt;zielobjekt id="ZO-001" type="IT-System"&gt;
      &lt;name&gt;Webserver-Prod&lt;/name&gt;
      &lt;kurzbeschreibung&gt;...&lt;/kurzbeschreibung&gt;
      &lt;verantwortlich&gt;IT&lt;/verantwortlich&gt;
      &lt;standort&gt;RZ-Nord&lt;/standort&gt;
      &lt;schutzbedarf&gt;
        &lt;vertraulichkeit&gt;hoch&lt;/vertraulichkeit&gt;
        &lt;integritaet&gt;sehr hoch&lt;/integritaet&gt;
        &lt;verfuegbarkeit&gt;hoch&lt;/verfuegbarkeit&gt;
      &lt;/schutzbedarf&gt;
    &lt;/zielobjekt&gt;
  &lt;/zielobjekte&gt;
  &lt;modellierung&gt;
    &lt;abhaengigkeit von="ZO-001" zu="ZO-002"/&gt;
  &lt;/modellierung&gt;
&lt;/gstool-export&gt;</code></pre>
            </div>
        </div>
    </section>

    {% if result is not null %}
        <section class="fa-section">
            <div class="fa-section__header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h2 class="fa-section__title">
                    {% if isDryRun %}
                        <i class="fa-icon fa-icon--status-pending text-warning" aria-hidden="true"></i>
                        {{ 'gstool_import.result.preview_title'|trans({}, 'gstool_import') }}
                    {% else %}
                        <i class="fa-icon fa-icon--status-ok text-success" aria-hidden="true"></i>
                        {{ 'gstool_import.result.commit_title'|trans({}, 'gstool_import') }}
                        {% if result.session_id is defined and result.session_id %}
                            <small class="text-muted">#{{ result.session_id }}</small>
                        {% endif %}
                    {% endif %}
                </h2>
                <span class="fa-status-pill fa-status-pill--neutral">
                    {{ 'gstool_import.result.summary'|trans({
                        '%new%': result.summary.new,
                        '%update%': result.summary.update,
                        '%error%': result.summary.error,
                    }, 'gstool_import') }}
                </span>
            </div>
            <div class="fa-section__body p-0">
                {% if result.header_error is not null %}
                    <div class="p-3">
                        <div class="fa-alert fa-alert--danger mb-0">{{ result.header_error }}</div>
                    </div>
                {% else %}
                    <ul class="nav nav-tabs px-3 pt-3" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="tab-assets" data-bs-toggle="tab" data-bs-target="#pane-assets" type="button" role="tab">
                                {{ 'gstool_import.tab.assets'|trans({}, 'gstool_import') }}
                                <span class="fa-status-pill fa-status-pill--neutral ms-1">{{ result.rows|length }}</span>
                            </button>
                        </li>
                        {% if result.bausteine_rows is defined and result.bausteine_rows|length > 0 %}
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="tab-bausteine" data-bs-toggle="tab" data-bs-target="#pane-bausteine" type="button" role="tab">
                                {{ 'gstool_import.tab.bausteine'|trans({}, 'gstool_import') }}
                                <span class="fa-status-pill fa-status-pill--neutral ms-1">{{ result.bausteine_rows|length }}</span>
                            </button>
                        </li>
                        {% endif %}
                        {% if result.massnahmen_rows is defined and result.massnahmen_rows|length > 0 %}
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="tab-massnahmen" data-bs-toggle="tab" data-bs-target="#pane-massnahmen" type="button" role="tab">
                                {{ 'gstool_import.tab.massnahmen'|trans({}, 'gstool_import') }}
                                <span class="fa-status-pill fa-status-pill--neutral ms-1">{{ result.massnahmen_rows|length }}</span>
                            </button>
                        </li>
                        {% endif %}
                        {% if result.risiken_rows is defined and result.risiken_rows|length > 0 %}
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="tab-risiken" data-bs-toggle="tab" data-bs-target="#pane-risiken" type="button" role="tab">
                                {{ 'gstool_import.tab.risiken'|trans({}, 'gstool_import') }}
                                <span class="fa-status-pill fa-status-pill--neutral ms-1">{{ result.risiken_rows|length }}</span>
                            </button>
                        </li>
                        {% endif %}
                    </ul>
                    <div class="tab-content">

                    <div class="tab-pane fade show active" id="pane-assets" role="tabpanel">
                    {% embed '_components/_fa_table.html.twig' with { compact: true } %}
                        {% block table_head %}
                            <tr>
                                <th scope="col" class="fa-table__th">{{ 'gstool_import.result.line'|trans({}, 'gstool_import') }}</th>
                                <th scope="col" class="fa-table__th">{{ 'gstool_import.result.action'|trans({}, 'gstool_import') }}</th>
                                <th scope="col" class="fa-table__th">{{ 'gstool_import.result.gstool_id'|trans({}, 'gstool_import') }}</th>
                                <th scope="col" class="fa-table__th">{{ 'gstool_import.result.name'|trans({}, 'gstool_import') }}</th>
                                <th scope="col" class="fa-table__th">{{ 'gstool_import.result.asset_type'|trans({}, 'gstool_import') }}</th>
                                <th scope="col" class="fa-table__th fa-table__th--num">C</th>
                                <th scope="col" class="fa-table__th fa-table__th--num">I</th>
                                <th scope="col" class="fa-table__th fa-table__th--num">A</th>
                                <th scope="col" class="fa-table__th">{{ 'gstool_import.result.error'|trans({}, 'gstool_import') }}</th>
                            </tr>
                        {% endblock %}
                        {% block table_body %}
                            {% for row in result.rows %}
                                <tr class="fa-table__row">
                                    <td class="fa-table__cell text-muted small">{{ row.line ?? '' }}</td>
                                    <td class="fa-table__cell">
                                        {% if row.action == 'new' %}
                                            <span class="fa-status-pill fa-status-pill--success">{{ 'gstool_import.action.new'|trans({}, 'gstool_import') }}</span>
                                        {% elseif row.action == 'update' %}
                                            <span class="fa-status-pill fa-status-pill--primary">{{ 'gstool_import.action.update'|trans({}, 'gstool_import') }}</span>
                                        {% elseif row.action == 'error' %}
                                            <span class="fa-status-pill fa-status-pill--danger">{{ 'gstool_import.action.error'|trans({}, 'gstool_import') }}</span>
                                        {% else %}
                                            <span class="fa-status-pill fa-status-pill--neutral">{{ row.action }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="fa-table__cell"><code>{{ row.id ?? '' }}</code></td>
                                    <td class="fa-table__cell">{{ row.name ?? '' }}</td>
                                    <td class="fa-table__cell"><code class="small">{{ row.assetType ?? '' }}</code></td>
                                    <td class="fa-table__cell fa-table__cell--num">{{ row.confidentiality ?? '–' }}</td>
                                    <td class="fa-table__cell fa-table__cell--num">{{ row.integrity ?? '–' }}</td>
                                    <td class="fa-table__cell fa-table__cell--num">{{ row.availability ?? '–' }}</td>
                                    <td class="fa-table__cell text-danger small">{{ row.error ?? '' }}</td>
                                </tr>
                            {% endfor %}
                        {% endblock %}
                    {% endembed %}
                    </div>

                    {% if result.bausteine_rows is defined and result.bausteine_rows|length > 0 %}
                    <div class="tab-pane fade" id="pane-bausteine" role="tabpanel">
                    <div class="fa-alert fa-alert--info mx-3 mt-3 mb-0 small">
                        {{ 'gstool_import.bausteine.note'|trans({}, 'gstool_import') }}
                    </div>
                    {% embed '_components/_fa_table.html.twig' with { compact: true } %}
                        {% block table_head %}
                            <tr>
                                <th scope="col" class="fa-table__th">{{ 'gstool_import.bausteine.legacy_id'|trans({}, 'gstool_import') }}</th>
                                <th scope="col" class="fa-table__th">{{ 'gstool_import.bausteine.title_old'|trans({}, 'gstool_import') }}</th>
                                <th scope="col" class="fa-table__th">{{ 'gstool_import.bausteine.kompendium_2023'|trans({}, 'gstool_import') }}</th>
                                <th scope="col" class="fa-table__th">{{ 'gstool_import.bausteine.title_new'|trans({}, 'gstool_import') }}</th>
                                <th scope="col" class="fa-table__th">{{ 'gstool_import.bausteine.zielobjekt'|trans({}, 'gstool_import') }}</th>
                                <th scope="col" class="fa-table__th">{{ 'gstool_import.bausteine.status'|trans({}, 'gstool_import') }}</th>
                            </tr>
                        {% endblock %}
                        {% block table_body %}
                            {% import '_components/_status_pill.html.twig' as pill %}
                            {% for r in result.bausteine_rows %}
                                <tr class="fa-table__row">
                                    <td class="fa-table__cell"><code>{{ r.legacy_id }}</code></td>
                                    <td class="fa-table__cell small">{{ r.title_old ?? '–' }}</td>
                                    <td class="fa-table__cell">
                                        {% if r.kompendium_2023_id %}
                                            <code class="text-success">{{ r.kompendium_2023_id }}</code>
                                        {% else %}
                                            <span class="text-danger small">{{ 'gstool_import.bausteine.unmapped'|trans({}, 'gstool_import') }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="fa-table__cell small">{{ r.title_new ?? '–' }}</td>
                                    <td class="fa-table__cell"><code class="small">{{ r.zielobjekt ?? '–' }}</code></td>
                                    <td class="fa-table__cell">
                                        {% set s = r.status %}
                                        {{ pill.render(s, s == 'direct' ? 'success' : (s == 'split' ? 'warning' : (s == 'merged' ? 'primary' : (s == 'removed' ? 'danger' : (s == 'bcm' ? 'primary' : 'neutral')))), {size: 'sm'}) }}
                                        {% if r.note %}<div class="small text-muted">{{ r.note }}</div>{% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endblock %}
                    {% endembed %}
                    </div>
                    {% endif %}

                    {% if result.massnahmen_rows is defined and result.massnahmen_rows|length > 0 %}
                    <div class="tab-pane fade" id="pane-massnahmen" role="tabpanel">
                    {% embed '_components/_fa_table.html.twig' with { compact: true } %}
                        {% block table_head %}
                            <tr>
                                <th scope="col" class="fa-table__th">{{ 'gstool_import.massnahmen.legacy_id'|trans({}, 'gstool_import') }}</th>
                                <th scope="col" class="fa-table__th">{{ 'gstool_import.massnahmen.titel'|trans({}, 'gstool_import') }}</th>
                                <th scope="col" class="fa-table__th">{{ 'gstool_import.massnahmen.baustein'|trans({}, 'gstool_import') }}</th>
                                <th scope="col" class="fa-table__th">{{ 'gstool_import.massnahmen.umsetzungsstatus'|trans({}, 'gstool_import') }}</th>
                                <th scope="col" class="fa-table__th">{{ 'gstool_import.massnahmen.implementation_status'|trans({}, 'gstool_import') }}</th>
                            </tr>
                        {% endblock %}
                        {% block table_body %}
                            {% for r in result.massnahmen_rows %}
                                <tr class="fa-table__row">
                                    <td class="fa-table__cell"><code>{{ r.legacy_id }}</code></td>
                                    <td class="fa-table__cell small">{{ r.titel ?? '–' }}</td>
                                    <td class="fa-table__cell">
                                        <code>{{ r.baustein_legacy ?? '–' }}</code>
                                        {% if r.baustein_kompendium_2023 %}
                                            <span class="text-muted">→</span> <code class="text-success">{{ r.baustein_kompendium_2023 }}</code>
                                        {% endif %}
                                    </td>
                                    <td class="fa-table__cell"><code class="small">{{ r.umsetzungsstatus_raw ?? '–' }}</code></td>
                                    <td class="fa-table__cell">
                                        {% set s = r.implementation_status %}
                                        {% if s == 'implemented' %}
                                            <span class="fa-status-pill fa-status-pill--success">{{ s }}</span>
                                        {% elseif s == 'partially_implemented' %}
                                            <span class="fa-status-pill fa-status-pill--warning">{{ s }}</span>
                                        {% elseif s == 'not_implemented' %}
                                            <span class="fa-status-pill fa-status-pill--danger">{{ s }}</span>
                                        {% elseif s == 'not_applicable' %}
                                            <span class="fa-status-pill fa-status-pill--neutral">{{ s }}</span>
                                        {% else %}
                                            <span class="text-muted small">unmapped</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endblock %}
                    {% endembed %}
                    </div>
                    {% endif %}

                    {% if result.risiken_rows is defined and result.risiken_rows|length > 0 %}
                    <div class="tab-pane fade" id="pane-risiken" role="tabpanel">
                    {% embed '_components/_fa_table.html.twig' with { compact: true } %}
                        {% block table_head %}
                            <tr>
                                <th scope="col" class="fa-table__th">{{ 'gstool_import.risiken.legacy_id'|trans({}, 'gstool_import') }}</th>
                                <th scope="col" class="fa-table__th">{{ 'gstool_import.risiken.titel'|trans({}, 'gstool_import') }}</th>
                                <th scope="col" class="fa-table__th">{{ 'gstool_import.risiken.haeufigkeit'|trans({}, 'gstool_import') }}</th>
                                <th scope="col" class="fa-table__th fa-table__th--num">L</th>
                                <th scope="col" class="fa-table__th">{{ 'gstool_import.risiken.schaden'|trans({}, 'gstool_import') }}</th>
                                <th scope="col" class="fa-table__th fa-table__th--num">I</th>
                                <th scope="col" class="fa-table__th fa-table__th--num">{{ 'gstool_import.risiken.score'|trans({}, 'gstool_import') }}</th>
                                <th scope="col" class="fa-table__th">{{ 'gstool_import.risiken.behandlung'|trans({}, 'gstool_import') }}</th>
                            </tr>
                        {% endblock %}
                        {% block table_body %}
                            {% import '_components/_status_pill.html.twig' as pill %}
                            {% for r in result.risiken_rows %}
                                <tr class="fa-table__row">
                                    <td class="fa-table__cell"><code>{{ r.legacy_id }}</code></td>
                                    <td class="fa-table__cell small">{{ r.titel ?? '–' }}</td>
                                    <td class="fa-table__cell small">{{ r.eintrittshaeufigkeit_raw ?? '–' }}</td>
                                    <td class="fa-table__cell fa-table__cell--num"><strong>{{ r.inherent_likelihood ?? '–' }}</strong></td>
                                    <td class="fa-table__cell small">{{ r.schadenshoehe_raw ?? '–' }}</td>
                                    <td class="fa-table__cell fa-table__cell--num"><strong>{{ r.inherent_impact ?? '–' }}</strong></td>
                                    <td class="fa-table__cell fa-table__cell--num">
                                        {% if r.inherent_risk_score %}
                                            {{ pill.render(r.inherent_risk_score, r.inherent_risk_score >= 13 ? 'danger' : (r.inherent_risk_score >= 7 ? 'warning' : 'success'), {size: 'sm'}) }}
                                        {% else %}–{% endif %}
                                    </td>
                                    <td class="fa-table__cell">
                                        {% if r.treatment_strategy %}
                                            <span class="fa-status-pill fa-status-pill--primary">{{ r.treatment_strategy }}</span>
                                        {% else %}<span class="text-muted small">–</span>{% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endblock %}
                    {% endembed %}
                    </div>
                    {% endif %}

                    </div>{# /.tab-content #}
                {% endif %}
            </div>
        </section>
    {% endif %}
{% endblock %}
