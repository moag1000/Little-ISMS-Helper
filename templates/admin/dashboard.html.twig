{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}

{% block admin_title %}{{ 'admin.dashboard.title'|trans({}, 'admin') }}{% endblock %}
{% block admin_subtitle %}
    <p class="text-muted">{{ 'admin.dashboard.subtitle'|trans({}, 'admin') }}</p>
{% endblock %}

{% block admin_content %}
    {# Hub-Promo-Banner — Sprint 1 des Admin-Panel-Refactors. Hub bleibt
       opt-in via /admin/hub bis Mega-Menu-Switch in Sprint 4. #}
    <div class="fa-alert fa-alert--info mb-4" role="status">
        <i class="fa-icon fa-icon--ui-stars fa-alert__icon" aria-hidden="true"></i>
        <div class="fa-alert__body">
            <div class="fa-alert__title">{{ 'admin.hub.title'|trans({}, 'admin') }}</div>
            <p class="mb-2 small">{{ 'admin.hub.subtitle'|trans({'%count%': 36}, 'admin') }}</p>
            <a href="{{ path('admin_hub_index') }}" class="fa-cyber-btn fa-cyber-btn--info fa-cyber-btn--sm">
                <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                {{ 'admin.hub.title'|trans({}, 'admin') }}
            </a>
        </div>
    </div>

    {# System Alerts #}
    {% if alerts is not empty %}
        <div class="row mb-4">
            <div class="col-12">
                <h2 class="h5 mb-3">
                    <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i>
                    {{ 'admin.dashboard.alerts.title'|trans({}, 'admin') }}
                </h2>
                {% for alert in alerts %}
                    <div class="fa-alert fa-alert--{{ alert.type }}" role="alert">
                        <i class="bi {{ alert.icon }}" aria-hidden="true"></i>
                        <strong>{{ alert.message|trans({}, 'admin') }}</strong>
                        {% if alert.count is defined %}
                            - {{ alert.count }}
                            {{ (alert.count == 1 ? 'admin.dashboard.alerts.item' : 'admin.dashboard.alerts.items')|trans({}, 'admin') }}
                        {% endif %}
                        {% if alert.action %}
                            <a href="{{ alert.action }}" class="fa-alert__link ms-2">{{ 'admin.dashboard.alerts.view'|trans({}, 'admin') }} →</a>
                        {% endif %}
                        {% if alert.fix_route is defined and alert.fix_route %}
                            <form method="post" action="{{ path(alert.fix_route) }}" class="d-inline ms-2">
                                <input type="hidden" name="_token" value="{{ csrf_token(alert.fix_csrf_name) }}">
                                <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--sm">
                                    <i class="bi bi-wrench-adjustable" aria-hidden="true"></i>
                                    {{ alert.fix_label|trans({}, 'admin') }}
                                </button>
                            </form>
                        {% endif %}
                        <button type="button" class="fa-alert__close" data-bs-dismiss="alert" aria-label="{{ 'common.close'|trans({}, 'messages') }}">
                            <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i>
                        </button>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {# Quick Stats Cards #}
    {% set _fw_variant = stats.compliance.frameworks_loaded >= stats.compliance.frameworks_catalog ? 'success' : (stats.compliance.frameworks_loaded > 0 ? 'warning' : 'danger') %}
    {% set _review_variant = stats.compliance.unreviewed_seed_mappings == 0 ? 'success' : (stats.compliance.unreviewed_seed_mappings < 10 ? 'warning' : 'danger') %}
    <div class="row g-3 mb-4">
        <div class="col-md-6 col-lg-3">
            {{ _fa_feature_card.render({
                variant: 'primary',
                icon: 'people-fill',
                label: 'admin.dashboard.stats.users'|trans({}, 'admin'),
                value: stats.users.total,
                hint: stats.users.active ~ ' ' ~ ('admin.dashboard.stats.active'|trans({}, 'admin')) ~ (stats.users.inactive > 0 ? ' · ' ~ stats.users.inactive ~ ' ' ~ ('admin.dashboard.stats.inactive'|trans({}, 'admin')) : ''),
                href: path('user_management_index')
            }) }}
        </div>
        <div class="col-md-6 col-lg-3">
            {{ _fa_feature_card.render({
                variant: 'success',
                icon: 'calendar-check-fill',
                label: 'admin.dashboard.stats.active_sessions'|trans({}, 'admin'),
                value: stats.sessions.active_24h,
                hint: 'admin.dashboard.stats.last_24h'|trans({}, 'admin')
            }) }}
        </div>
        <div class="col-md-6 col-lg-3">
            {{ _fa_feature_card.render({
                variant: _fw_variant,
                icon: 'shield-check',
                label: 'admin.dashboard.stats.frameworks'|trans({}, 'admin'),
                value: stats.compliance.frameworks_loaded ~ ' / ' ~ stats.compliance.frameworks_catalog,
                hint: 'admin.dashboard.stats.mappings_count'|trans({'%count%': stats.compliance.mappings_total}, 'admin'),
                href: path('admin_compliance_index')
            }) }}
        </div>
        <div class="col-md-6 col-lg-3">
            {{ _fa_feature_card.render({
                variant: _review_variant,
                icon: 'person-check-fill',
                label: 'admin.dashboard.stats.unreviewed_mappings'|trans({}, 'admin'),
                value: stats.compliance.unreviewed_seed_mappings,
                hint: stats.workflows.open > 0
                    ? ('admin.dashboard.stats.workflows_open'|trans({'%count%': stats.workflows.open}, 'admin'))
                    : ('admin.dashboard.stats.workflows_none'|trans({}, 'admin')),
                href: stats.compliance.unreviewed_seed_mappings > 0 ? path('app_compliance_mapping_seed_review') : null
            }) }}
        </div>
    </div>

    <div class="row g-4">
        {# Module Statistics #}
        <div class="col-lg-8">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="bi bi-bar-chart-fill text-primary" aria-hidden="true"></i>
                        {{ 'admin.dashboard.modules.title'|trans({}, 'admin') }}
                    </h2>
                </div>
                <div class="fa-section__body">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th scope="col">{{ 'admin.dashboard.modules.module'|trans({}, 'admin') }}</th>
                                    {% if currentTenant %}
                                        <th scope="col" class="text-end">{{ 'corporate.view.own_only'|trans({}, 'tenant') }}</th>
                                        <th scope="col" class="text-end">{{ 'corporate.view.including_inherited'|trans({}, 'tenant') }}</th>
                                        <th scope="col" class="text-end">{{ 'corporate.view.including_subsidiaries'|trans({}, 'tenant') }}</th>
                                    {% else %}
                                        <th scope="col" class="text-end">{{ 'admin.dashboard.modules.records'|trans({}, 'admin') }}</th>
                                    {% endif %}
                                    <th scope="col" class="text-end">{{ 'admin.dashboard.modules.action'|trans({}, 'admin') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><i class="fa-icon fa-icon--nav-cpu text-primary" aria-hidden="true"></i> {{ 'admin.dashboard.modules.assets'|trans({}, 'admin') }}</td>
                                    {% if currentTenant %}
                                        <td class="text-end"><span class="badge bg-primary">{{ stats.modules.assets.own }}</span></td>
                                        <td class="text-end"><span class="badge bg-primary">{{ stats.modules.assets.own + stats.modules.assets.inherited }}</span></td>
                                        <td class="text-end"><span class="badge bg-primary">{{ stats.modules.assets.total }}</span></td>
                                    {% else %}
                                        <td class="text-end"><span class="badge bg-primary">{{ stats.modules.assets.total }}</span></td>
                                    {% endif %}
                                    <td class="text-end">
                                        <a href="{{ path('app_asset_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">{{ 'common.view'|trans({}, 'messages') }}</a>
                                    </td>
                                </tr>
                                <tr>
                                    <td><i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> {{ 'admin.dashboard.modules.risks'|trans({}, 'admin') }}</td>
                                    {% if currentTenant %}
                                        <td class="text-end"><span class="badge bg-danger">{{ stats.modules.risks.own }}</span></td>
                                        <td class="text-end"><span class="badge bg-danger">{{ stats.modules.risks.own + stats.modules.risks.inherited }}</span></td>
                                        <td class="text-end"><span class="badge bg-danger">{{ stats.modules.risks.total }}</span></td>
                                    {% else %}
                                        <td class="text-end"><span class="badge bg-danger">{{ stats.modules.risks.total }}</span></td>
                                    {% endif %}
                                    <td class="text-end">
                                        <a href="{{ path('app_risk_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">{{ 'common.view'|trans({}, 'messages') }}</a>
                                    </td>
                                </tr>
                                <tr>
                                    <td><i class="fa-icon fa-icon--compliance-shield" aria-hidden="true"></i> {{ 'admin.dashboard.modules.controls'|trans({}, 'admin') }}</td>
                                    {% if currentTenant %}
                                        <td class="text-end"><span class="badge bg-success">{{ stats.modules.controls.own }}</span></td>
                                        <td class="text-end"><span class="badge bg-success">{{ stats.modules.controls.own + stats.modules.controls.inherited }}</span></td>
                                        <td class="text-end"><span class="badge bg-success">{{ stats.modules.controls.total }}</span></td>
                                    {% else %}
                                        <td class="text-end"><span class="badge bg-success">{{ stats.modules.controls.total }}</span></td>
                                    {% endif %}
                                    <td class="text-end">
                                        <a href="{{ path('app_soa_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">{{ 'common.view'|trans({}, 'messages') }}</a>
                                    </td>
                                </tr>
                                <tr>
                                    <td><i class="fa-icon fa-icon--vulnerability fa-icon--warning" aria-hidden="true"></i> {{ 'admin.dashboard.modules.incidents'|trans({}, 'admin') }}</td>
                                    {% if currentTenant %}
                                        <td class="text-end"><span class="badge bg-warning text-dark">{{ stats.modules.incidents.own }}</span></td>
                                        <td class="text-end"><span class="badge bg-warning text-dark">{{ stats.modules.incidents.own + stats.modules.incidents.inherited }}</span></td>
                                        <td class="text-end"><span class="badge bg-warning text-dark">{{ stats.modules.incidents.total }}</span></td>
                                    {% else %}
                                        <td class="text-end"><span class="badge bg-warning text-dark">{{ stats.modules.incidents.total }}</span></td>
                                    {% endif %}
                                    <td class="text-end">
                                        <a href="{{ path('app_incident_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">{{ 'common.view'|trans({}, 'messages') }}</a>
                                    </td>
                                </tr>
                                <tr>
                                    <td><i class="fa-icon fa-icon--audit-internal" aria-hidden="true"></i> {{ 'admin.dashboard.modules.audits'|trans({}, 'admin') }}</td>
                                    {% if currentTenant %}
                                        <td class="text-end"><span class="badge bg-info">{{ stats.modules.audits.own }}</span></td>
                                        <td class="text-end"><span class="badge bg-info">{{ stats.modules.audits.own + stats.modules.audits.inherited }}</span></td>
                                        <td class="text-end"><span class="badge bg-info">{{ stats.modules.audits.total }}</span></td>
                                    {% else %}
                                        <td class="text-end"><span class="badge bg-info">{{ stats.modules.audits.total }}</span></td>
                                    {% endif %}
                                    <td class="text-end">
                                        <a href="{{ path('app_audit_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">{{ 'common.view'|trans({}, 'messages') }}</a>
                                    </td>
                                </tr>
                                <tr>
                                    <td><i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i> {{ 'admin.dashboard.modules.compliance'|trans({}, 'admin') }}</td>
                                    {% if currentTenant %}
                                        <td class="text-end"><span class="badge bg-secondary">{{ stats.modules.compliance_requirements.own }}</span></td>
                                        <td class="text-end"><span class="badge bg-secondary">{{ stats.modules.compliance_requirements.own + stats.modules.compliance_requirements.inherited }}</span></td>
                                        <td class="text-end"><span class="badge bg-secondary">{{ stats.modules.compliance_requirements.total }}</span></td>
                                    {% else %}
                                        <td class="text-end"><span class="badge bg-secondary">{{ stats.modules.compliance_requirements.total }}</span></td>
                                    {% endif %}
                                    <td class="text-end">
                                        <a href="{{ path('app_compliance_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">{{ 'common.view'|trans({}, 'messages') }}</a>
                                    </td>
                                </tr>
                                <tr>
                                    <td><i class="fa-icon fa-icon--training" aria-hidden="true"></i> {{ 'admin.dashboard.modules.trainings'|trans({}, 'admin') }}</td>
                                    {% if currentTenant %}
                                        <td class="text-end"><span class="badge bg-dark">{{ stats.modules.trainings.own }}</span></td>
                                        <td class="text-end"><span class="badge bg-dark">{{ stats.modules.trainings.own + stats.modules.trainings.inherited }}</span></td>
                                        <td class="text-end"><span class="badge bg-dark">{{ stats.modules.trainings.total }}</span></td>
                                    {% else %}
                                        <td class="text-end"><span class="badge bg-dark">{{ stats.modules.trainings.total }}</span></td>
                                    {% endif %}
                                    <td class="text-end">
                                        <a href="{{ path('app_training_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">{{ 'common.view'|trans({}, 'messages') }}</a>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </div>

        {# Recent Activity & Quick Actions #}
        <div class="col-lg-4">
            {# Quick Actions (Sprint 11) — kontextabhängig: nur zeigen was gerade
             # relevant ist, plus immer-sinnvolle Power-User-Shortcuts. #}
            <section class="fa-section mb-4">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="bi bi-lightning-fill text-warning" aria-hidden="true"></i>
                        {{ 'admin.dashboard.quick_actions.title'|trans({}, 'admin') }}
                    </h2>
                </div>
                <div class="fa-section__body">
                    <div class="d-grid gap-2">
                        {# Kontext-Actions — nur bei Bedarf sichtbar #}
                        {% if stats.compliance.unreviewed_seed_mappings > 0 %}
                            <a href="{{ path('app_compliance_mapping_seed_review') }}" class="fa-cyber-btn fa-cyber-btn--warning">
                                <i class="fa-icon fa-icon--user" aria-hidden="true"></i>
                                {{ 'admin.dashboard.quick_actions.review_seeds'|trans({'%count%': stats.compliance.unreviewed_seed_mappings}, 'admin') }}
                            </a>
                        {% endif %}
                        {% if stats.compliance.frameworks_missing > 0 %}
                            <a href="{{ path('admin_compliance_index') }}" class="fa-cyber-btn fa-cyber-btn--warning">
                                <i class="fa-icon fa-icon--import" aria-hidden="true"></i>
                                {{ 'admin.dashboard.quick_actions.load_frameworks'|trans({'%count%': stats.compliance.frameworks_missing}, 'admin') }}
                            </a>
                        {% endif %}
                        {% if stats.users.inactive > 0 %}
                            <a href="{{ path('user_management_index') }}" class="fa-cyber-btn fa-cyber-btn--warning">
                                <i class="fa-icon fa-icon--ui-person" aria-hidden="true"></i>
                                {{ 'admin.dashboard.quick_actions.review_inactive_users'|trans({'%count%': stats.users.inactive}, 'admin') }}
                            </a>
                        {% endif %}

                        {# Standard-Shortcuts — immer sichtbar #}
                        <a href="{{ path('user_management_new') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                            <i class="fa-icon fa-icon--ui-person" aria-hidden="true"></i> {{ 'admin.dashboard.quick_actions.add_user'|trans({}, 'admin') }}
                        </a>
                        <a href="{{ path('tenant_management_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                            <i class="fa-icon fa-icon--nav-building" aria-hidden="true"></i> {{ 'admin.dashboard.quick_actions.manage_tenants'|trans({}, 'admin') }}
                        </a>
                        <a href="{{ path('admin_compliance_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                            <i class="fa-icon fa-icon--compliance-shield" aria-hidden="true"></i> {{ 'admin.dashboard.quick_actions.manage_compliance'|trans({}, 'admin') }}
                        </a>
                        <a href="{{ path('app_audit_log_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                            <i class="fa-icon fa-icon--nav-journal" aria-hidden="true"></i> {{ 'admin.dashboard.quick_actions.view_logs'|trans({}, 'admin') }}
                        </a>
                        <a href="{{ path('app_admin_audit_retention') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                            <i class="fa-icon fa-icon--status-archived" aria-hidden="true"></i> {{ 'audit_log.retention.title'|trans({}, 'audit_log') }}
                        </a>
                        <a href="{{ path('app_admin_risk_approval_config') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                            <i class="fa-icon fa-icon--nav-sliders" aria-hidden="true"></i> {{ 'risk_approval_config.title'|trans({}, 'risk_approval_config') }}
                        </a>
                        <a href="{{ path('app_admin_tenant_email_branding') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                            <i class="bi bi-envelope-paper" aria-hidden="true"></i> {{ 'tenant.email.title'|trans({}, 'tenant') }}
                        </a>
                        <a href="{{ path('app_admin_incident_sla_config') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                            <i class="bi bi-stopwatch" aria-hidden="true"></i> {{ 'incident_sla.title'|trans({}, 'incident_sla') }}
                        </a>
                        <a href="{{ path('app_admin_quick_fix_settings') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                            <i class="fa-icon fa-icon--nav-tools" aria-hidden="true"></i> {{ 'quick_fix.settings.title'|trans({}, 'quick_fix') }}
                        </a>
                    </div>
                </div>
            </section>

            {# Recent Activity #}
            <section class="fa-section">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="bi bi-clock-history text-info" aria-hidden="true"></i>
                        {{ 'admin.dashboard.activity.title'|trans({}, 'admin') }}
                    </h2>
                </div>
                <div class="fa-section__body">
                    {% if recentActivity is empty %}
                        <div class="p-3 text-center text-muted">
                            <i class="fa-icon fa-icon--ui-inbox fs-3" aria-hidden="true"></i>
                            <p class="mb-0 mt-2">{{ 'admin.dashboard.activity.empty'|trans({}, 'admin') }}</p>
                        </div>
                    {% else %}
                        <div class="list-group list-group-flush">
                            {% for log in recentActivity %}
                                <div class="list-group-item">
                                    <div class="d-flex w-100 justify-content-between align-items-start">
                                        <div>
                                            <div class="mb-1 small fw-semibold">{{ log.action|trans }}</div>
                                            <p class="mb-1 small text-muted">
                                                {{ log.entityType }} #{{ log.entityId }}
                                                {% if log.username %}
                                                    <span class="badge bg-light text-dark border">{{ log.username }}</span>
                                                {% endif %}
                                            </p>
                                        </div>
                                        <small class="text-muted text-nowrap ms-2">
                                            {{ log.createdAt|date('d.m H:i') }}
                                        </small>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
                <div class="fa-section__footer">
                    <a href="{{ path('app_audit_log_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm w-100">
                        {{ 'admin.dashboard.activity.view_all'|trans({}, 'admin') }} <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                    </a>
                </div>
            </section>
        </div>
    </div>
{% endblock %}
