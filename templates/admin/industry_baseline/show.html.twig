{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'framework_baseline' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}

{% block title %}{{ 'framework_baseline.title'|trans }} — {{ framework }}{% endblock %}

{% block admin_title %}{{ ('framework_baseline.framework.' ~ framework)|trans({}, 'framework_baseline')|default(framework) }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('admin_industry_baselines_index') }}">{{ 'framework_baseline.title'|trans }}</a></li>
    <li class="breadcrumb-item active" aria-current="page">{{ framework }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'collection', label: framework },
        title: ('framework_baseline.framework.' ~ framework)|trans({}, 'framework_baseline')|default(framework),
        subtitle: 'framework_baseline.show.subtitle'|trans,
    }) }}

    {% if tenant is null %}
        <div class="fa-alert fa-alert--warning small">
            <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i>
            {{ 'framework_baseline.tenant_required'|trans }}
        </div>
    {% endif %}

    {% if baselines|length == 0 %}
        {{ _fa_empty_state.render({
            mood: 'thinking',
            title: 'framework_baseline.empty_for_framework'|trans,
        }) }}
    {% else %}
        <section class="fa-section">
            <div class="fa-section__body">
                <div class="row g-3">
                    {% for baseline in baselines %}
                        <div class="col-md-6 col-lg-6">
                            <div class="card h-100">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <code class="small text-muted">{{ baseline.id }}</code>
                                        <span class="fa-status-pill fa-status-pill--primary">{{ baseline.industry }}</span>
                                    </div>
                                    <h2 class="h5 mb-2">{{ baseline.name }}</h2>
                                    <p class="small text-muted mb-3" style="white-space: pre-line;">{{ baseline.description }}</p>
                                    <p class="small text-muted mb-3">
                                        <i class="fa-icon fa-icon--nav-document" aria-hidden="true"></i>
                                        <code>{{ baseline.file }}</code>
                                    </p>

                                    {% if is_granted('ROLE_MANAGER') and tenant is not null %}
                                        <form method="post" action="{{ path('admin_industry_baselines_apply', {framework: framework}) }}" class="d-flex gap-2 flex-wrap">
                                            <input type="hidden" name="_token" value="{{ csrf_token('industry_baseline_apply') }}">
                                            <input type="hidden" name="baseline_id" value="{{ baseline.id }}">
                                            <button type="submit" name="dry_run" value="1" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost">
                                                <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
                                                {{ 'framework_baseline.action.preview'|trans }}
                                            </button>
                                            <button type="submit"
                                                    class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--primary"
                                                    data-confirm="{{ 'framework_baseline.confirm.apply'|trans({'%name%': baseline.name, '%tenant%': tenant.name}, 'framework_baseline') }}">
                                                <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i>
                                                {{ 'framework_baseline.action.apply'|trans }}
                                            </button>
                                        </form>
                                    {% else %}
                                        <p class="small text-muted fst-italic mb-0">
                                            {% if tenant is null %}
                                                {{ 'framework_baseline.tenant_required'|trans }}
                                            {% else %}
                                                {{ 'framework_baseline.requires_manager'|trans }}
                                            {% endif %}
                                        </p>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}
{% endblock %}
