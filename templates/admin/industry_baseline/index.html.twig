{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'framework_baseline' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}

{% block title %}{{ 'framework_baseline.title'|trans }}{% endblock %}

{% block admin_title %}{{ 'framework_baseline.title'|trans }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item active" aria-current="page">{{ 'framework_baseline.title'|trans }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'collection', label: 'Baselines' },
        title: 'framework_baseline.title'|trans,
        subtitle: 'framework_baseline.subtitle'|trans,
    }) }}

    {% if tenant is null %}
        <div class="fa-alert fa-alert--warning small">
            <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i>
            {{ 'framework_baseline.tenant_required'|trans }}
        </div>
    {% endif %}

    {% if frameworks|length == 0 %}
        {{ _fa_empty_state.render({
            mood: 'thinking',
            title: 'framework_baseline.no_frameworks'|trans,
        }) }}
    {% else %}
        <section class="fa-section">
            <div class="fa-section__body">
                <div class="row g-3">
                    {% for f in frameworks %}
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100">
                                <div class="card-body d-flex flex-column">
                                    <code class="small text-muted mb-2">{{ f.code }}</code>
                                    <h2 class="h5">{{ ('framework_baseline.framework.' ~ f.code)|trans({}, 'framework_baseline')|default(f.code) }}</h2>
                                    <p class="small text-muted flex-grow-1">
                                        {{ 'framework_baseline.baselines_count'|trans({'%count%': f.count}, 'framework_baseline') }}
                                    </p>
                                    <a href="{{ path('admin_industry_baselines_show', {framework: f.code}) }}"
                                       class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--primary mt-2">
                                        <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i> {{ 'framework_baseline.action.view'|trans }}
                                    </a>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}

    <div class="fa-alert fa-alert--info mt-4 small">
        <i class="fa-icon fa-icon--status-info" aria-hidden="true"></i>
        {{ 'framework_baseline.help'|trans|raw }}
    </div>
{% endblock %}
