{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'admin' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}

{% block title %}{{ 'admin.data_repair.section.duplicates'|trans({}, 'admin') }} — {{ 'admin.data_repair.title'|trans({}, 'admin') }}{% endblock %}

{% block admin_title %}
    <i class="fa-icon fa-icon--ui-copy" aria-hidden="true"></i> {{ 'admin.data_repair.section.duplicates'|trans({}, 'admin') }}
{% endblock %}

{% block admin_content %}
<div class="container-fluid">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.admin'|trans({}, 'nav'), url: path('admin_dashboard') },
            { label: 'admin.data_repair.title'|trans({}, 'admin'), url: path('admin_data_repair_index') },
            { label: 'admin.data_repair.section.duplicates'|trans({}, 'admin') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'ui-copy', label: 'admin.data_repair.section.badge'|trans({}, 'admin') },
        title: 'admin.data_repair.section.duplicates'|trans({}, 'admin'),
        subtitle: 'admin.data_repair.section.duplicates_description'|trans({}, 'admin'),
    }) }}

    {% for message in app.flashes('success') %}{{ _fa_alert.render({ variant: 'success', dismissible: true, body: message }) }}{% endfor %}
    {% for message in app.flashes('error') %}{{ _fa_alert.render({ variant: 'danger', dismissible: true, body: message }) }}{% endfor %}
    {% for message in app.flashes('warning') %}{{ _fa_alert.render({ variant: 'warning', dismissible: true, body: message }) }}{% endfor %}
    {% for message in app.flashes('info') %}{{ _fa_alert.render({ variant: 'info', dismissible: true, body: message }) }}{% endfor %}

    {# Cache state + refresh-now CTA #}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: cache is null ? 'warning' : 'info', class: 'mb-4' } } %}
        {% block alert_body %}
        <div class="d-flex align-items-start gap-3 flex-wrap">
            <div class="flex-grow-1">
                <div class="fa-alert__title">{{ 'admin.data_repair.section.cache_status'|trans({}, 'admin') }}</div>
                {% if cache is not null %}
                    <p class="small text-muted mb-0">
                        {{ 'admin.data_repair.section.last_scan'|trans({
                            '%when%': cache.completed_at|date('Y-m-d H:i'),
                            '%duration%': (cache.duration_ms / 1000)|round(1),
                        }, 'admin') }}
                        — {{ 'admin.data_repair.section.duplicates_summary'|trans({
                            '%groups%': cache.payload.total_groups|default(0),
                            '%types%': cache.payload.groups_by_type|default({})|length,
                        }, 'admin') }}
                    </p>
                {% else %}
                    <p class="small text-muted mb-0">
                        {{ 'admin.data_repair.section.never_scanned_full'|trans({}, 'admin') }}
                    </p>
                {% endif %}
            </div>
            <form method="post" action="{{ path('admin_data_repair_duplicates_refresh') }}" class="d-inline-block">
                <input type="hidden" name="_token" value="{{ csrf_token('refresh_section_duplicates') }}">
                <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                    <i class="fa-icon fa-icon--arrow-repeat" aria-hidden="true"></i>
                    {{ 'admin.data_repair.section.refresh_now'|trans({}, 'admin') }}
                </button>
            </form>
        </div>
        {% endblock %}
    {% endembed %}

    {% set hasDuplicates = (duplicates.audits|default([])|length > 0)
        or (duplicates.assets|default([])|length > 0)
        or (duplicates.risks|default([])|length > 0)
        or (duplicates.incidents|default([])|length > 0)
        or (duplicates.documents|default([])|length > 0) %}

    {% if not hasDuplicates %}
        {{ _fa_alert.render({ variant: 'success', body: 'admin.data_repair.duplicates.all_ok'|trans({}, 'admin') }) }}
    {% else %}
        {{ _fa_alert.render({
            variant: 'warning',
            body: '<strong>' ~ 'common.warning'|trans({}, 'messages') ~ ':</strong> ' ~ 'admin.data_repair.duplicates.description'|trans({}, 'admin'),
        }) }}

        {# Summary pills #}
        <div class="d-flex flex-wrap gap-2 mb-4">
            {% for typeKey in ['audits', 'assets', 'risks', 'incidents', 'documents'] %}
                {% set groups = duplicates[typeKey]|default([]) %}
                {% if groups|length > 0 %}
                    <span class="fa-status-pill fa-status-pill--warning">
                        {{ typeKey|replace({'_': ' '})|title }}: {{ groups|length }} {{ 'admin.data_repair.duplicates.group_count'|trans({}, 'admin') }}
                    </span>
                {% endif %}
            {% endfor %}
        </div>

        {# Per-type merge forms (SUPER_ADMIN only — destructive) #}
        <div class="row g-3">
            {% for typeKey in ['audits', 'assets', 'risks', 'incidents', 'documents'] %}
                {% set groups = duplicates[typeKey]|default([]) %}
                {% if groups|length > 0 %}
                    <div class="col-md-6 col-lg-4">
                        <section class="fa-section h-100 border-warning">
                            <div class="fa-section__header">
                                <h3 class="mb-0 fs-6 fw-semibold">
                                    <i class="fa-icon fa-icon--ui-copy" aria-hidden="true"></i>
                                    {{ typeKey|replace({'_': ' '})|title }}
                                </h3>
                            </div>
                            <div class="fa-section__body">
                                {% set totalDupItems = 0 %}
                                {% for grp in groups %}
                                    {% set cnt = grp.count is defined ? grp.count : (grp|length) %}
                                    {% set totalDupItems = totalDupItems + cnt %}
                                {% endfor %}
                                <p class="small text-muted mb-2">
                                    {{ 'admin.data_repair.duplicates.group_info'|trans({'%groups%': groups|length, '%items%': totalDupItems}, 'admin') }}
                                </p>
                                <p class="small mb-3">{{ 'admin.data_repair.duplicates.merge_hint'|trans({}, 'admin') }}</p>
                                <form method="post"
                                      action="{{ path('admin_data_repair_fix_duplicates', {entityType: typeKey}) }}"
                                      data-controller="ui-actions"
                                      data-action="submit->ui-actions#confirm"
                                      data-ui-actions-message-param="{{ 'admin.data_repair.duplicates.confirm_merge'|trans({'%type%': typeKey, '%count%': groups|length}, 'admin') }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('fix_duplicates_' ~ typeKey) }}">
                                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--warning fa-cyber-btn--full">
                                        <i class="fa-icon fa-icon--nav-tools" aria-hidden="true"></i>
                                        {{ 'admin.data_repair.duplicates.merge_button'|trans({'%count%': groups|length}, 'admin') }}
                                    </button>
                                </form>
                            </div>
                        </section>
                    </div>
                {% endif %}
            {% endfor %}
        </div>

        {# Details #}
        <details class="mt-4">
            <summary class="fw-semibold cursor-pointer">{{ 'admin.data_repair.duplicates.show_details'|trans({}, 'admin') }}</summary>
            <div class="mt-3">
            {% for typeKey in ['audits', 'assets', 'risks', 'incidents', 'documents'] %}
                {% set groups = duplicates[typeKey]|default([]) %}
                {% if groups|length > 0 %}
                    <h4 class="mt-3 mb-2 fs-6 text-uppercase text-muted">{{ typeKey|replace({'_': ' '})|title }}</h4>
                    {% for grp in groups %}
                        {% set entities = grp.entities is defined ? grp.entities : grp %}
                        {% set groupLabel = grp.value is defined ? grp.value : (entities|first).title|default((entities|first).name|default('#' ~ (entities|first).id|default(''))) %}
                        <section class="fa-section mb-2 border-warning">
                            <div class="fa-section__header">
                                <span class="fw-semibold small">{{ groupLabel }}</span>
                                <span class="fa-status-pill fa-status-pill--warning">{{ (entities|length) ~ ' ' ~ 'admin.data_repair.duplicates.items'|trans({}, 'admin') }}</span>
                            </div>
                            <div class="fa-section__body">
                                <ul class="list-unstyled mb-0 small">
                                {% for entity in entities %}
                                    <li class="mb-1">
                                        <span class="fa-status-pill fa-status-pill--neutral">{{ 'ID: ' ~ entity.id }}</span>
                                        {% if entity.title is defined %}{{ entity.title }}{% elseif entity.name is defined %}{{ entity.name }}{% elseif entity.auditNumber is defined %}{{ entity.auditNumber }}{% elseif entity.originalFilename is defined %}{{ entity.originalFilename }}{% endif %}
                                        {% if entity.tenant is defined and entity.tenant %}<small class="text-muted">({{ entity.tenant.name }})</small>{% endif %}
                                    </li>
                                {% endfor %}
                                </ul>
                            </div>
                        </section>
                    {% endfor %}
                {% endif %}
            {% endfor %}
            </div>
        </details>
    {% endif %}

    <div class="mt-4">
        <a href="{{ path('admin_data_repair_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
            <i class="fa-icon fa-icon--util-arrow-left" aria-hidden="true"></i>
            {{ 'admin.data_repair.section.back_to_index'|trans({}, 'admin') }}
        </a>
    </div>
</div>
{% endblock %}
