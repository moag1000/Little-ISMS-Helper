                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--{{ totalDataQualityIssues > 0 ? 'status-warning' : 'ui-check-circle' }}" aria-hidden="true"></i>
                    {{ 'admin.data_repair.data_quality.title'|trans({}, 'admin') }}
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% import '_components/_fa_alert.html.twig' as _fa_alert %}
            {% if totalDataQualityIssues == 0 %}
                {{ _fa_alert.render({ variant: 'success', class: 'mb-0', body: 'admin.data_repair.data_quality.all_ok'|trans({}, 'admin') }) }}
            {% else %}
                {{ _fa_alert.render({ variant: 'warning', body: '<strong>' ~ 'common.warning'|trans({}, 'messages') ~ ':</strong> ' ~ 'admin.data_repair.data_quality.issues_found'|trans({'%count%': totalDataQualityIssues}, 'admin') }) }}

                {# Summary grid #}
                <div class="row row-cols-2 row-cols-md-4 g-3 mb-4">
                    {% set dqCheckKeys = [
                        'workflows_stuck',
                        'risks_zero_values',
                        'incidents_no_rca',
                        'treatments_unreviewed'
                    ] %}
                    {% for checkKey in dqCheckKeys %}
                        {% set items = dataQualityIssues[checkKey] is defined ? dataQualityIssues[checkKey] : [] %}
                        <div class="col">
                            {% embed '_components/_card.html.twig' with { class: 'text-center h-100 ' ~ (items|length > 0 ? 'bg-warning bg-opacity-10' : 'bg-success bg-opacity-10') } %}
                                {% block card_body %}
                                    <h3 class="text-{{ items|length > 0 ? 'warning' : 'success' }} mb-1">{{ items|length }}</h3>
                                    <p class="mb-0 small">{{ ('admin.data_repair.data_quality.' ~ checkKey)|trans({}, 'admin') }}</p>
                                {% endblock %}
                            {% endembed %}
                        </div>
                    {% endfor %}
                </div>

                {# Check 1: Stuck workflows #}
                {% if dataQualityIssues.workflows_stuck is defined and dataQualityIssues.workflows_stuck|length > 0 %}
                <div class="mb-4">
                    <h3 class="fs-5">{{ 'admin.data_repair.data_quality.workflows_stuck'|trans({}, 'admin') }}</h3>
                    <p class="text-muted small">{{ 'admin.data_repair.data_quality.workflows_stuck_hint'|trans({}, 'admin') }}</p>
                    {% embed '_components/_table.html.twig' with { 'class': 'table-sm table-striped', 'responsive': true, 'noMargin': true } %}
                        {% block table_head %}
                            <tr>
                                <th scope="col">ID</th>
                                <th scope="col">{{ 'admin.data_repair.data_quality.col_workflow'|trans({}, 'admin') }}</th>
                                <th scope="col">{{ 'admin.data_repair.data_quality.col_entity'|trans({}, 'admin') }}</th>
                                <th scope="col">{{ 'admin.data_repair.data_quality.col_started'|trans({}, 'admin') }}</th>
                                <th scope="col">{{ 'common.status'|trans({}, 'messages') }}</th>
                            </tr>
                        {% endblock %}
                        {% block table_body %}
                            {% for instance in dataQualityIssues.workflows_stuck %}
                            <tr class="table-warning">
                                <td>{{ instance.id }}</td>
                                <td>{{ instance.workflow ? instance.workflow.name : '-' }}{% if instance.tenant %}<br><small class="text-muted">{{ instance.tenant.name }}</small>{% endif %}</td>
                                <td><small class="text-muted">{{ instance.entityType }}</small> #{{ instance.entityId }}</td>
                                <td>{{ instance.startedAt ? instance.startedAt|date('Y-m-d') : '-' }}</td>
                                <td>{% include '_components/_badge.html.twig' with { variant: 'warning', content: instance.status } only %}</td>
                            </tr>
                            {% endfor %}
                        {% endblock %}
                    {% endembed %}
                </div>
                {% endif %}

                {# Check 2: Risks with zero probability/impact #}
                {% if dataQualityIssues.risks_zero_values is defined and dataQualityIssues.risks_zero_values|length > 0 %}
                <div class="mb-4">
                    <h3 class="fs-5">{{ 'admin.data_repair.data_quality.risks_zero_values'|trans({}, 'admin') }}</h3>
                    <p class="text-muted small">{{ 'admin.data_repair.data_quality.risks_zero_values_hint'|trans({}, 'admin') }}</p>
                    {% embed '_components/_table.html.twig' with { 'class': 'table-sm table-striped', 'responsive': true, 'noMargin': true } %}
                        {% block table_head %}
                            <tr>
                                <th scope="col">ID</th>
                                <th scope="col">{{ 'risk.label.title'|trans({}, 'risk') }}</th>
                                <th scope="col">{{ 'risk.field.status'|trans({}, 'risk') }}</th>
                                <th scope="col">{{ 'risk.field.probability'|trans({}, 'risk') }}</th>
                                <th scope="col">{{ 'common.actions'|trans({}, 'messages') }}</th>
                            </tr>
                        {% endblock %}
                        {% block table_body %}
                            {% for risk in dataQualityIssues.risks_zero_values %}
                            <tr class="table-warning">
                                <td>{{ risk.id }}</td>
                                <td>{{ risk.title }}{% if risk.tenant %}<br><small class="text-muted">{{ risk.tenant.name }}</small>{% endif %}</td>
                                <td>{% include '_components/_badge.html.twig' with { variant: 'secondary', content: risk.status.value } only %}</td>
                                <td>{{ risk.probability ?? '-' }}</td>
                                <td>
                                    <a href="{{ path('app_risk_show', {id: risk.id, _locale: app.request.locale}) }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                        <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                                        {{ 'common.view'|trans({}, 'messages') }}
                                    </a>
                                </td>
                            </tr>
                            {% endfor %}
                        {% endblock %}
                    {% endembed %}
                </div>
                {% endif %}

                {# Check 3: Incidents closed without root cause #}
                {% if dataQualityIssues.incidents_no_rca is defined and dataQualityIssues.incidents_no_rca|length > 0 %}
                <div class="mb-4">
                    <h3 class="fs-5">{{ 'admin.data_repair.data_quality.incidents_no_rca'|trans({}, 'admin') }}</h3>
                    <p class="text-muted small">{{ 'admin.data_repair.data_quality.incidents_no_rca_hint'|trans({}, 'admin') }}</p>
                    {% embed '_components/_table.html.twig' with { 'class': 'table-sm table-striped', 'responsive': true, 'noMargin': true } %}
                        {% block table_head %}
                            <tr>
                                <th scope="col">ID</th>
                                <th scope="col">{{ 'incidents.field.title'|trans({}, 'incidents') }}</th>
                                <th scope="col">{{ 'incidents.field.status'|trans({}, 'incidents') }}</th>
                                <th scope="col">{{ 'common.actions'|trans({}, 'messages') }}</th>
                            </tr>
                        {% endblock %}
                        {% block table_body %}
                            {% for incident in dataQualityIssues.incidents_no_rca %}
                            <tr class="table-warning">
                                <td>{{ incident.id }}</td>
                                <td>{{ incident.title }}{% if incident.tenant %}<br><small class="text-muted">{{ incident.tenant.name }}</small>{% endif %}</td>
                                <td>{% include '_components/_badge.html.twig' with { variant: 'secondary', content: incident.status } only %}</td>
                                <td>
                                    <a href="{{ path('app_incident_show', {id: incident.id, _locale: app.request.locale}) }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                        <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                                        {{ 'common.view'|trans({}, 'messages') }}
                                    </a>
                                </td>
                            </tr>
                            {% endfor %}
                        {% endblock %}
                    {% endembed %}
                </div>
                {% endif %}

                {# Check 4: Treatment plans completed without effectiveness review date #}
                {% if dataQualityIssues.treatments_unreviewed is defined and dataQualityIssues.treatments_unreviewed|length > 0 %}
                <div class="mb-4">
                    <h3 class="fs-5">{{ 'admin.data_repair.data_quality.treatments_unreviewed'|trans({}, 'admin') }}</h3>
                    <p class="text-muted small">{{ 'admin.data_repair.data_quality.treatments_unreviewed_hint'|trans({}, 'admin') }}</p>
                    {% embed '_components/_table.html.twig' with { 'class': 'table-sm table-striped', 'responsive': true, 'noMargin': true } %}
                        {% block table_head %}
                            <tr>
                                <th scope="col">ID</th>
                                <th scope="col">{{ 'admin.data_repair.data_quality.col_treatment'|trans({}, 'admin') }}</th>
                                <th scope="col">{{ 'admin.data_repair.data_quality.col_risk'|trans({}, 'admin') }}</th>
                                <th scope="col">{{ 'common.status'|trans({}, 'messages') }}</th>
                            </tr>
                        {% endblock %}
                        {% block table_body %}
                            {% for plan in dataQualityIssues.treatments_unreviewed %}
                            <tr class="table-warning">
                                <td>{{ plan.id }}</td>
                                <td>{{ plan.title }}{% if plan.tenant %}<br><small class="text-muted">{{ plan.tenant.name }}</small>{% endif %}</td>
                                <td>{{ plan.risk ? plan.risk.title : '-' }}</td>
                                <td>{% include '_components/_badge.html.twig' with { variant: 'success', content: plan.status } only %}</td>
                            </tr>
                            {% endfor %}
                        {% endblock %}
                    {% endembed %}
                </div>
                {% endif %}

            {% endif %}
        {% endblock %}
    {% endembed %}

</div>
{% endblock %}
