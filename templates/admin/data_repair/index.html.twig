                    {% embed '_components/_table.html.twig' with { 'class': 'table-sm table-striped', 'responsive': true, 'noMargin': true } %}
                        {% block table_head %}
                            <tr>
                                <th scope="col">ID</th>
                                <th scope="col">{{ 'risk.label.title'|trans({}, 'risk') }}</th>
                                <th scope="col">{{ 'risk.field.inherent_risk'|trans({}, 'risk') }}</th>
                                <th scope="col">{{ 'risk.field.residual_risk'|trans({}, 'risk') }}</th>
                                <th scope="col">{{ 'common.actions'|trans({}, 'messages') }}</th>
