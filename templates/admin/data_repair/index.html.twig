{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'admin'%}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% block title %}{{ 'admin.data_repair.title'|trans({}, 'admin') }} - {{ 'admin.panel.title'|trans({}, 'admin') }}{% endblock %}

{% block admin_title %}
    <i class="fa-icon fa-icon--nav-tools" aria-hidden="true"></i> {{ 'admin.data_repair.title'|trans({}, 'admin') }}
{% endblock %}

{% block admin_content %}
<div class="container-fluid">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.admin'|trans({}, 'nav'), url: path('admin_dashboard') },
            { label: 'admin.data_repair.title'|trans({}, 'admin') }
        ]
    } %}

    <div class="mb-4">
        <p class="text-muted mb-0">{{ 'admin.data_repair.description'|trans({}, 'admin') }}</p>
    </div>

    {# Sprint 10 / S10-2: Junior-Sorge „Titel klingt gefährlich" —
     # explizite Warn-Leiste mit Reversibilitäts-Information. #}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'danger', class: 'border-start border-5 border-danger shadow-sm' } } %}
        {% block alert_body %}
        <div class="fa-alert__title">{{ 'admin.data_repair.safety.title'|trans({}, 'admin') }}</div>
        <p class="mb-2">
            <strong>{{ 'admin.data_repair.safety.lead'|trans({}, 'admin') }}</strong>
        </p>
        <ul class="mb-3 small">
            <li>{{ 'admin.data_repair.safety.point_audit_log'|trans({}, 'admin') }}</li>
            <li>{{ 'admin.data_repair.safety.point_backup'|trans({}, 'admin') }}</li>
            <li>{{ 'admin.data_repair.safety.point_confirm'|trans({}, 'admin') }}</li>
        </ul>
        <div class="d-flex gap-2 align-items-center">
            <a href="{{ path('data_backup_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                <i class="fa-icon fa-icon--nav-hdd" aria-hidden="true"></i>
                {{ 'admin.data_repair.safety.action_backup'|trans({}, 'admin') }}
            </a>
            <a href="{{ path('app_audit_log_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                <i class="fa-icon fa-icon--nav-journal" aria-hidden="true"></i>
                {{ 'admin.data_repair.safety.action_audit_log'|trans({}, 'admin') }}
            </a>
            <span class="small text-muted ms-auto">
                {{ 'admin.data_repair.safety.role_hint'|trans({}, 'admin') }}
            </span>
        </div>
        {% endblock %}
    {% endembed %}

    {% for message in app.flashes('success') %}
        {{ _fa_alert.render({ variant: 'success', dismissible: true, body: message }) }}
    {% endfor %}

    {% for message in app.flashes('error') %}
        {{ _fa_alert.render({ variant: 'danger', dismissible: true, body: message }) }}
    {% endfor %}

    {# Schema-Maintenance — 3-Card-Grid (Migrations | Drift | Aktionen).
     # Buttons werden IMMER gerendert; bei nichts-zu-tun disabled + Status-Pill
     # zeigt grün/gelb/rot den aktuellen Zustand. So sieht der Admin auch im
     # Sync-Fall, dass die Funktion existiert und erreichbar ist. #}
    <div class="row g-3 mb-4">
        {# Migrations Card #}
        <div class="col-md-4">
            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header">
                        <h4 class="mb-0">
                            <i class="fa-icon fa-icon--nav-database-add" aria-hidden="true"></i>
                            {{ 'admin.data_repair.schema.migrations'|trans({}, 'admin') }}
                        </h4>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <p class="mb-2">
                        {% if migration_status.pending > 0 %}
                            <span class="fa-status-pill fa-status-pill--warning">
                                {{ migration_status.pending }} {{ 'admin.data_repair.schema.pending'|trans({}, 'admin') }}
                            </span>
                        {% else %}
                            <span class="fa-status-pill fa-status-pill--success">
                                {{ 'admin.data_repair.schema.up_to_date'|trans({}, 'admin') }}
                            </span>
                        {% endif %}
                    </p>
                    {% if migration_status.pending > 0 %}
                        <ul class="small mb-3">
                            {% for name in migration_status.names|slice(0, 5) %}
                                <li><code>{{ name }}</code></li>
                            {% endfor %}
                            {% if migration_status.names|length > 5 %}
                                <li>… {{ migration_status.names|length - 5 }} {{ 'admin.data_repair.schema.more'|trans({}, 'admin') }}</li>
                            {% endif %}
                        </ul>
                    {% endif %}
                    <form method="post" action="{{ path('admin_data_repair_migrations_execute') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('migrations_execute') }}">
                        <button type="submit"
                                class="fa-cyber-btn fa-cyber-btn--{{ migration_status.pending > 0 ? 'warning' : 'ghost' }} fa-cyber-btn--full"
                                {% if migration_status.pending == 0 %}disabled{% endif %}>
                            <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                            {{ 'admin.data_repair.schema.run_migrations'|trans({}, 'admin') }}
                        </button>
                    </form>
                {% endblock %}
            {% endembed %}
        </div>

        {# Schema Drift Card #}
        <div class="col-md-4">
            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header">
                        <h4 class="mb-0">
                            <i class="fa-icon fa-icon--ui-refresh" aria-hidden="true"></i>
                            {{ 'admin.data_repair.schema.drift'|trans({}, 'admin') }}
                        </h4>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <p class="mb-2">
                        {% if schema_drift.count > 0 %}
                            <span class="fa-status-pill fa-status-pill--danger">
                                {{ schema_drift.count }} {{ 'admin.data_repair.schema.statements'|trans({}, 'admin') }}
                            </span>
                            {% if schema_drift.destructive|length > 0 %}
                                <span class="fa-status-pill fa-status-pill--warning">
                                    {{ schema_drift.destructive|length }} {{ 'admin.data_repair.schema.destructive'|trans({}, 'admin') }}
                                </span>
                            {% endif %}
                        {% else %}
                            <span class="fa-status-pill fa-status-pill--success">
                                {{ 'admin.data_repair.schema.in_sync'|trans({}, 'admin') }}
                            </span>
                        {% endif %}
                    </p>
                    {% if schema_drift.count > 0 %}
                        <details class="mb-2 small">
                            <summary>{{ 'admin.data_repair.schema.show_sql'|trans({}, 'admin') }}</summary>
                            <pre class="mt-2 p-2 bg-body-secondary rounded" style="max-height: 200px; overflow: auto;"><code>{{ schema_drift.statements|join(";\n") }}</code></pre>
                        </details>
                    {% endif %}
                    <form method="post" action="{{ path('admin_data_repair_schema_reconcile') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('schema_reconcile') }}">
                        <button type="submit"
                                class="fa-cyber-btn fa-cyber-btn--{{ schema_drift.count > 0 ? 'danger' : 'ghost' }} fa-cyber-btn--full"
                                {% if schema_drift.count == 0 %}disabled{% endif %}>
                            <i class="fa-icon fa-icon--ui-refresh" aria-hidden="true"></i>
                            {{ 'admin.data_repair.schema.run_reconcile'|trans({}, 'admin') }}
                        </button>
                    </form>
                {% endblock %}
            {% endembed %}
        </div>

        {# Refresh Status Card #}
        <div class="col-md-4">
            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header">
                        <h4 class="mb-0">
                            <i class="fa-icon fa-icon--util-spinner" aria-hidden="true"></i>
                            {{ 'admin.data_repair.schema.actions'|trans({}, 'admin') }}
                        </h4>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <p class="small text-muted mb-2">
                        {{ 'admin.data_repair.schema.actions_desc'|trans({}, 'admin') }}
                    </p>
                    <a href="{{ path('admin_data_repair_index') }}"
                       class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--full mb-2">
                        <i class="fa-icon fa-icon--ui-refresh" aria-hidden="true"></i>
                        {{ 'admin.data_repair.schema.refresh'|trans({}, 'admin') }}
                    </a>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    {# Data Health Summary #}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4 border-' ~ (summary.health_score >= 90 ? 'success' : (summary.health_score >= 70 ? 'warning' : 'danger')) } %}
        {% block card_header %}
            <div class="card-header">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--nav-heart-pulse" aria-hidden="true"></i> Data Health Score: {{ summary.health_score }}%
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% import '_components/_fa_alert.html.twig' as _fa_alert %}
            <div class="row g-3">
                <div class="col-md-4">
                    {% embed '_components/_card.html.twig' with { 'class': 'text-center ' ~ (summary.orphaned_count > 0 ? 'bg-warning' : 'bg-success') ~ ' bg-opacity-10' } %}
                        {% block card_body %}
                            <h3 class="text-{% if summary.orphaned_count > 0 %}warning{% else %}success{% endif %}">{{ summary.orphaned_count }}</h3>
                            <p class="mb-0"><i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> Orphaned Entities</p>
                        {% endblock %}
                    {% endembed %}
                </div>
                <div class="col-md-4">
                    {% embed '_components/_card.html.twig' with { 'class': 'text-center ' ~ (summary.broken_references_count > 0 ? 'bg-danger' : 'bg-success') ~ ' bg-opacity-10' } %}
                        {% block card_body %}
                            <h3 class="text-{% if summary.broken_references_count > 0 %}danger{% else %}success{% endif %}">{{ summary.broken_references_count }}</h3>
                            <p class="mb-0"><i class="fa-icon fa-icon--ui-link" aria-hidden="true"></i> Broken References</p>
                        {% endblock %}
                    {% endembed %}
                </div>
                <div class="col-md-4">
                    {% embed '_components/_card.html.twig' with { 'class': 'text-center ' ~ (summary.duplicates_count > 0 ? 'bg-warning' : 'bg-success') ~ ' bg-opacity-10' } %}
                        {% block card_body %}
                            <h3 class="text-{% if summary.duplicates_count > 0 %}warning{% else %}success{% endif %}">{{ summary.duplicates_count }}</h3>
                            <p class="mb-0"><i class="fa-icon fa-icon--ui-copy" aria-hidden="true"></i> Duplicates</p>
                        {% endblock %}
                    {% endembed %}
                </div>
            </div>

            {% if summary.total_issues > 0 %}
                {{ _fa_alert.render({ variant: 'info', class: 'mt-3 mb-0', body: '<strong>' ~ 'common.info'|trans({}, 'messages') ~ ':</strong> Found ' ~ summary.total_issues ~ ' total issues. Use the repair tools below to fix them.' }) }}
            {% else %}
                {{ _fa_alert.render({ variant: 'success', class: 'mt-3 mb-0', body: '<strong>All systems healthy!</strong> No data integrity issues detected.' }) }}
            {% endif %}
        {% endblock %}
    {% endembed %}

    {# Quick Fix Tools #}
    {% if summary.orphaned_count > 0 or summary.broken_references_count > 0 %}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
        {% block card_header %}
            <div class="card-header">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--nav-tools" aria-hidden="true"></i> Quick Fix Tools
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            <div class="row g-3">
                {% if summary.orphaned_count > 0 %}
                <div class="col-md-6"
                     data-controller="data-repair"
                     data-data-repair-base-url-value="{{ path('admin_data_repair_fix_all_orphans', {tenantId: 0}) }}"
                     data-data-repair-expected-total-value="{{ summary.orphaned_count }}"
                     data-data-repair-confirm-text-value="Assign ALL orphaned entities to this tenant?">
                    <h3>Fix All Orphaned Entities</h3>
                    <p class="text-muted">Assign all {{ summary.orphaned_count }} orphaned entities to a tenant</p>
                    <form method="post" data-data-repair-target="form">
                        <input type="hidden" name="_token" value="{{ csrf_token('fix_all_orphans') }}">
                        <div class="input-group">
                            <select name="tenant_id" class="form-select" required data-data-repair-target="tenantSelect">
                                <option value="">Select Tenant...</option>
                                {% for tenant in tenants %}
                                    <option value="{{ tenant.id }}">{{ tenant.name }}</option>
                                {% endfor %}
                            </select>
                            <button type="button" class="fa-cyber-btn fa-cyber-btn--warning" data-action="data-repair#fixAllOrphans">
                                <i class="bi bi-lightning" aria-hidden="true"></i> Fix All Orphans
                            </button>
                        </div>
                    </form>
                </div>
                {% endif %}

                {% if summary.broken_references_count > 0 %}
                <div class="col-md-6">
                    <h3>Fix Tenant Mismatches</h3>
                    <p class="text-muted">Automatically align {{ summary.broken_references_count }} tenant assignments</p>
                    <form method="post" action="{{ path('admin_data_repair_fix_tenant_mismatches') }}"
                          data-controller="ui-actions"
                          data-action="submit->ui-actions#confirm"
                          data-ui-actions-message-param="Fix all tenant mismatches automatically?">
                        <input type="hidden" name="_token" value="{{ csrf_token('fix_tenant_mismatches') }}">
                        <div class="mb-2">
                            <label for="fix_tenant_mismatches_reason" class="form-label small fw-semibold">
                                {{ 'admin.data_repair.reason_label'|trans({}, 'admin') }} <span class="text-danger" aria-hidden="true">*</span>
                            </label>
                            <textarea
                                id="fix_tenant_mismatches_reason"
                                name="reason"
                                class="form-control"
                                rows="2"
                                minlength="20"
                                required
                                aria-required="true"
                                aria-describedby="fix_tenant_mismatches_reason_help"></textarea>
                            <div id="fix_tenant_mismatches_reason_help" class="form-text">
                                {{ 'admin.data_repair.reason_help'|trans({}, 'admin') }}
                            </div>
                        </div>
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger w-100">
                            <i class="bi bi-lightning" aria-hidden="true"></i> Fix Tenant Mismatches
                        </button>
                    </form>
                </div>
                {% endif %}
            </div>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {# ────────────────────────────────────────────────────────────────────────
       Duplicate Fix Tools
       Shown only when at least one duplicate group exists across any entity type.
    ──────────────────────────────────────────────────────────────────────── #}
    {% set hasDuplicates = (duplicates.audits is defined and duplicates.audits|length > 0)
        or (duplicates.assets is defined and duplicates.assets|length > 0)
        or (duplicates.risks is defined and duplicates.risks|length > 0)
        or (duplicates.incidents is defined and duplicates.incidents|length > 0)
        or (duplicates.documents is defined and duplicates.documents|length > 0) %}
    {% if hasDuplicates %}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4 border-warning' } %}
        {% block card_header %}
            <div class="card-header bg-warning-subtle text-warning">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--ui-copy" aria-hidden="true"></i>
                    {{ 'admin.data_repair.duplicates.title'|trans({}, 'admin') }}
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% import '_components/_fa_alert.html.twig' as _fa_alert %}
            {{ _fa_alert.render({ variant: 'warning', body: '<strong>' ~ 'common.warning'|trans({}, 'messages') ~ ':</strong> ' ~ 'admin.data_repair.duplicates.description'|trans({}, 'admin') }) }}

            {# Summary pills per entity type #}
            <div class="d-flex flex-wrap gap-2 mb-4">
                {% for typeKey in ['audits', 'assets', 'risks', 'incidents', 'documents'] %}
                    {% set groups = duplicates[typeKey] is defined ? duplicates[typeKey] : [] %}
                    {% if groups|length > 0 %}
                        <span class="fa-status-pill fa-status-pill--warning">
                            {{ typeKey|replace({'_': ' '})|title }}: {{ groups|length }} {{ 'admin.data_repair.duplicates.group_count'|trans({}, 'admin') }}
                        </span>
                    {% endif %}
                {% endfor %}
            </div>

            {# Per-type merge forms (SUPER_ADMIN only — destructive) #}
            <div class="row g-3">
                {% for typeKey in ['audits', 'assets', 'risks', 'incidents', 'documents'] %}
                    {% set groups = duplicates[typeKey] is defined ? duplicates[typeKey] : [] %}
                    {% if groups|length > 0 %}
                    <div class="col-md-6 col-lg-4">
                        {% embed '_components/_card.html.twig' with { class: 'h-100 border-warning' } %}
                            {% block card_header %}
                                <div class="card-header">
                                    <h3 class="mb-0 fs-6 fw-semibold">
                                        <i class="fa-icon fa-icon--ui-copy" aria-hidden="true"></i>
                                        {{ typeKey|replace({'_': ' '})|title }}
                                    </h3>
                                </div>
                            {% endblock %}
                            {% block card_body %}
                                {% set totalDupItems = 0 %}
                                {% for grp in groups %}
                                    {% set cnt = grp.count is defined ? grp.count : (grp|length) %}
                                    {% set totalDupItems = totalDupItems + cnt %}
                                {% endfor %}
                                <p class="small text-muted mb-2">
                                    {{ 'admin.data_repair.duplicates.group_info'|trans({'%groups%': groups|length, '%items%': totalDupItems}, 'admin') }}
                                </p>
                                <p class="small mb-3">{{ 'admin.data_repair.duplicates.merge_hint'|trans({}, 'admin') }}</p>
                                <form method="post"
                                      action="{{ path('admin_data_repair_fix_duplicates', {entityType: typeKey}) }}"
                                      data-controller="ui-actions"
                                      data-action="submit->ui-actions#confirm"
                                      data-ui-actions-message-param="{{ 'admin.data_repair.duplicates.confirm_merge'|trans({'%type%': typeKey, '%count%': groups|length}, 'admin') }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('fix_duplicates_' ~ typeKey) }}">
                                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--warning fa-cyber-btn--full">
                                        <i class="fa-icon fa-icon--nav-tools" aria-hidden="true"></i>
                                        {{ 'admin.data_repair.duplicates.merge_button'|trans({'%count%': groups|length}, 'admin') }}
                                    </button>
                                </form>
                            {% endblock %}
                        {% endembed %}
                    </div>
                    {% endif %}
                {% endfor %}
            </div>

            {# Detailed duplicate groups — collapsed by default for readability #}
            <details class="mt-4">
                <summary class="fw-semibold cursor-pointer">{{ 'admin.data_repair.duplicates.show_details'|trans({}, 'admin') }}</summary>
                <div class="mt-3">
                {% for typeKey in ['audits', 'assets', 'risks', 'incidents', 'documents'] %}
                    {% set groups = duplicates[typeKey] is defined ? duplicates[typeKey] : [] %}
                    {% if groups|length > 0 %}
                    <h4 class="mt-3 mb-2 fs-6 text-uppercase text-muted">{{ typeKey|replace({'_': ' '})|title }}</h4>
                    {% for grp in groups %}
                        {% set entities = grp.entities is defined ? grp.entities : grp %}
                        {% set groupLabel = grp.value is defined ? grp.value : (entities|first).title|default((entities|first).name|default('#' ~ (entities|first).id|default(''))) %}
                        {% embed '_components/_card.html.twig' with { class: 'mb-2 border-warning' } %}
                            {% block card_header %}
                                <div class="card-header py-2">
                                    <span class="fw-semibold small">{{ groupLabel }}</span>
                                    {% include '_components/_badge.html.twig' with { variant: 'warning', content: (entities|length) ~ ' ' ~ 'admin.data_repair.duplicates.items'|trans({}, 'admin') } only %}
                                </div>
                            {% endblock %}
                            {% block card_body %}
                                <ul class="list-unstyled mb-0 small">
                                {% for entity in entities %}
                                    <li class="mb-1">
                                        {% include '_components/_badge.html.twig' with { variant: 'secondary', content: 'ID: ' ~ entity.id } only %}
                                        {% if entity.title is defined %}{{ entity.title }}{% elseif entity.name is defined %}{{ entity.name }}{% elseif entity.auditNumber is defined %}{{ entity.auditNumber }}{% elseif entity.originalFilename is defined %}{{ entity.originalFilename }}{% endif %}
                                        {% if entity.tenant is defined and entity.tenant %}<small class="text-muted">({{ entity.tenant.name }})</small>{% endif %}
                                    </li>
                                {% endfor %}
                                </ul>
                            {% endblock %}
                        {% endembed %}
                    {% endfor %}
                    {% endif %}
                {% endfor %}
                </div>
            </details>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {# Orphaned Entities Section #}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
        {% block card_header %}
            <div class="card-header bg-warning-subtle text-warning">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> {{ 'admin.data_repair.orphaned_entities'|trans({}, 'admin') }}
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% import '_components/_fa_alert.html.twig' as _fa_alert %}
            {% set totalOrphans = 0 %}
            {% for entities in orphanedEntities %}{% set totalOrphans = totalOrphans + entities|length %}{% endfor %}
            {% if totalOrphans == 0 %}
                {{ _fa_alert.render({ variant: 'success', class: 'mb-0', body: 'admin.data_repair.no_orphans'|trans({}, 'admin') }) }}
            {% else %}
                {{ _fa_alert.render({ variant: 'warning', body: '<strong>' ~ 'common.warning'|trans({}, 'messages') ~ ':</strong> ' ~ 'admin.data_repair.orphans_found'|trans({}, 'admin') ~ ' — ' ~ 'admin.data_repair.total_orphans'|trans({'%count%': totalOrphans}, 'admin') }) }}

                {# Dynamischer Orphan-Count-Grid — pro detektiertem Entity-Typ eine Karte.
                   Zeigt auch seltene/seit Refactor neu erkannte Typen (Controls, Workflows, …). #}
                <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3 mb-3">
                    {% for key, entities in orphanedEntities %}
                        {% if entities|length > 0 %}
                            <div class="col">
                                {% embed '_components/_card.html.twig' with { class: 'text-center h-100' } %}
                                    {% block card_body %}
                                        <h3 class="text-danger mb-1">{{ entities|length }}</h3>
                                        <p class="mb-0 small text-uppercase">{{ key|replace({'_': ' '}) }}</p>
                                    {% endblock %}
                                {% endembed %}
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>

                {# Bulk Assignment Form — Entity-Type-Dropdown dynamisch aus allen
                   detektierten Orphan-Typen. #}
                <form method="post" action="{{ path('admin_data_repair_assign_orphans') }}" class="mb-4">
                    <input type="hidden" name="_token" value="{{ csrf_token('assign_orphans') }}">
                    <div class="row align-items-end">
                        <div class="col-md-4">
                            <label for="tenant_id" class="form-label">{{ 'admin.data_repair.assign_to_tenant'|trans({}, 'admin') }}</label>
                            <select name="tenant_id" id="tenant_id" class="form-select" required>
                                <option value="">{{ 'admin.data_repair.select_tenant'|trans({}, 'admin') }}</option>
                                {% for tenant in tenants %}
                                    <option value="{{ tenant.id }}">{{ tenant.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label for="entity_type" class="form-label">{{ 'admin.data_repair.entity_type'|trans({}, 'admin') }}</label>
                            <select name="entity_type" id="entity_type" class="form-select" required>
                                <option value="all">{{ 'admin.data_repair.all_orphans'|trans({}, 'admin') }} ({{ totalOrphans }})</option>
                                {% for key, entities in orphanedEntities %}
                                    {% if entities|length > 0 %}
