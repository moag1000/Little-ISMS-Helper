                                    </a>
                                </td>
                            </tr>
                            {% endfor %}
                        {% endblock %}
                    {% endembed %}
                </div>
                {% endif %}

                {# Check 4: Past review date #}
                {% if riskHealthIssues.risks_past_review_date is defined and riskHealthIssues.risks_past_review_date|length > 0 %}
