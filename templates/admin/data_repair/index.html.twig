                                <th scope="col">ID</th>
                                <th scope="col">{{ 'common.name'|trans({}, 'messages') }}</th>
                                <th scope="col">{{ 'common.date'|trans({}, 'messages') }}</th>
                                <th scope="col">{{ 'common.actions'|trans({}, 'messages') }}</th>
                            </tr>
                        {% endblock %}
                        {% block table_body %}
                            {% for breach in complianceHealthIssues.breaches_overdue_72h %}
                            <tr class="table-danger">
                                <td>{{ breach.id }}</td>
                                <td>{{ breach.title ?? breach.referenceNumber ?? ('#' ~ breach.id) }}{% if breach.tenant %}<br><small class="text-muted">{{ breach.tenant.name }}</small>{% endif %}</td>
                                <td>
