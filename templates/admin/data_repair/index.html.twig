    {# ────────────────────────────────────────────────────────────────────────
       Data Quality (Tier 3) — Operational gaps beyond structural integrity.
       Four checks: stuck workflows, risks without values, incidents without
       RCA, and completed treatment plans missing effectiveness review.
    ──────────────────────────────────────────────────────────────────────── #}
    {% set totalDataQualityIssues = 0 %}
    {% for issueGroup in dataQualityIssues %}{% set totalDataQualityIssues = totalDataQualityIssues + issueGroup|length %}{% endfor %}
