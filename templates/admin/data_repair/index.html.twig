                            <tr>
                                <th scope="col">ID</th>
                                <th scope="col">{{ 'common.name'|trans({}, 'messages') }}</th>
                                <th scope="col">Status</th>
                                <th scope="col">{{ 'common.actions'|trans({}, 'messages') }}</th>
                            </tr>
                        {% endblock %}
                        {% block table_body %}
                            {% for dsr in complianceHealthIssues.dsr_overdue_30d %}
