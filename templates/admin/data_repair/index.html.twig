                                        <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                                        {{ 'common.view'|trans({}, 'messages') }}
                                    </a>
                                </td>
                            </tr>
                            {% endfor %}
                        {% endblock %}
                    {% endembed %}
                    </div>
                </details>
