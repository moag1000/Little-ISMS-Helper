{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'admin'%}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% block title %}{{ 'admin.data_repair.title'|trans({}, 'admin') }} - {{ 'admin.panel.title'|trans({}, 'admin') }}{% endblock %}

{% block admin_title %}
    <i class="fa-icon fa-icon--nav-tools" aria-hidden="true"></i> {{ 'admin.data_repair.title'|trans({}, 'admin') }}
{% endblock %}

{% block admin_content %}
<div class="container-fluid">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.admin'|trans({}, 'nav'), url: path('admin_dashboard') },
            { label: 'admin.data_repair.title'|trans({}, 'admin') }
        ]
    } %}

    <div class="mb-4">
        <p class="text-muted mb-0">{{ 'admin.data_repair.description'|trans({}, 'admin') }}</p>
    </div>

    {# Sprint 10 / S10-2: Junior-Sorge „Titel klingt gefährlich" —
     # explizite Warn-Leiste mit Reversibilitäts-Information. #}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'danger', class: 'border-start border-5 border-danger shadow-sm' } } %}
        {% block alert_body %}
        <div class="fa-alert__title">{{ 'admin.data_repair.safety.title'|trans({}, 'admin') }}</div>
        <p class="mb-2">
            <strong>{{ 'admin.data_repair.safety.lead'|trans({}, 'admin') }}</strong>
        </p>
        <ul class="mb-3 small">
            <li>{{ 'admin.data_repair.safety.point_audit_log'|trans({}, 'admin') }}</li>
            <li>{{ 'admin.data_repair.safety.point_backup'|trans({}, 'admin') }}</li>
            <li>{{ 'admin.data_repair.safety.point_confirm'|trans({}, 'admin') }}</li>
        </ul>
        <div class="d-flex gap-2 align-items-center">
            <a href="{{ path('data_backup_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                <i class="fa-icon fa-icon--nav-hdd" aria-hidden="true"></i>
                {{ 'admin.data_repair.safety.action_backup'|trans({}, 'admin') }}
            </a>
            <a href="{{ path('app_audit_log_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                <i class="fa-icon fa-icon--nav-journal" aria-hidden="true"></i>
                {{ 'admin.data_repair.safety.action_audit_log'|trans({}, 'admin') }}
            </a>
            <span class="small text-muted ms-auto">
                {{ 'admin.data_repair.safety.role_hint'|trans({}, 'admin') }}
            </span>
        </div>
        {% endblock %}
    {% endembed %}

    {% for message in app.flashes('success') %}
        {{ _fa_alert.render({ variant: 'success', dismissible: true, body: message }) }}
    {% endfor %}

    {% for message in app.flashes('error') %}
        {{ _fa_alert.render({ variant: 'danger', dismissible: true, body: message }) }}
    {% endfor %}

    {# Data Health Summary #}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4 border-' ~ (summary.health_score >= 90 ? 'success' : (summary.health_score >= 70 ? 'warning' : 'danger')) } %}
        {% block card_header %}
            <div class="card-header">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--nav-heart-pulse" aria-hidden="true"></i> Data Health Score: {{ summary.health_score }}%
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% import '_components/_fa_alert.html.twig' as _fa_alert %}
            <div class="row g-3">
                <div class="col-md-4">
                    {% embed '_components/_card.html.twig' with { 'class': 'text-center ' ~ (summary.orphaned_count > 0 ? 'bg-warning' : 'bg-success') ~ ' bg-opacity-10' } %}
                        {% block card_body %}
                            <h3 class="text-{% if summary.orphaned_count > 0 %}warning{% else %}success{% endif %}">{{ summary.orphaned_count }}</h3>
                            <p class="mb-0"><i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> Orphaned Entities</p>
                        {% endblock %}
                    {% endembed %}
                </div>
                <div class="col-md-4">
                    {% embed '_components/_card.html.twig' with { 'class': 'text-center ' ~ (summary.broken_references_count > 0 ? 'bg-danger' : 'bg-success') ~ ' bg-opacity-10' } %}
                        {% block card_body %}
                            <h3 class="text-{% if summary.broken_references_count > 0 %}danger{% else %}success{% endif %}">{{ summary.broken_references_count }}</h3>
                            <p class="mb-0"><i class="fa-icon fa-icon--ui-link" aria-hidden="true"></i> Broken References</p>
                        {% endblock %}
                    {% endembed %}
                </div>
                <div class="col-md-4">
                    {% embed '_components/_card.html.twig' with { 'class': 'text-center ' ~ (summary.duplicates_count > 0 ? 'bg-warning' : 'bg-success') ~ ' bg-opacity-10' } %}
                        {% block card_body %}
                            <h3 class="text-{% if summary.duplicates_count > 0 %}warning{% else %}success{% endif %}">{{ summary.duplicates_count }}</h3>
                            <p class="mb-0"><i class="fa-icon fa-icon--ui-copy" aria-hidden="true"></i> Duplicates</p>
                        {% endblock %}
                    {% endembed %}
                </div>
            </div>

            {% if summary.total_issues > 0 %}
                {{ _fa_alert.render({ variant: 'info', class: 'mt-3 mb-0', body: '<strong>' ~ 'common.info'|trans({}, 'messages') ~ ':</strong> Found ' ~ summary.total_issues ~ ' total issues. Use the repair tools below to fix them.' }) }}
            {% else %}
                {{ _fa_alert.render({ variant: 'success', class: 'mt-3 mb-0', body: '<strong>All systems healthy!</strong> No data integrity issues detected.' }) }}
            {% endif %}
        {% endblock %}
    {% endembed %}

    {# Quick Fix Tools #}
    {% if summary.orphaned_count > 0 or summary.broken_references_count > 0 %}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
        {% block card_header %}
            <div class="card-header">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--nav-tools" aria-hidden="true"></i> Quick Fix Tools
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            <div class="row g-3">
                {% if summary.orphaned_count > 0 %}
                <div class="col-md-6"
                     data-controller="data-repair"
                     data-data-repair-base-url-value="{{ path('admin_data_repair_fix_all_orphans', {tenantId: 0}) }}"
                     data-data-repair-expected-total-value="{{ summary.orphaned_count }}"
                     data-data-repair-confirm-text-value="Assign ALL orphaned entities to this tenant?">
                    <h3>Fix All Orphaned Entities</h3>
                    <p class="text-muted">Assign all {{ summary.orphaned_count }} orphaned entities to a tenant</p>
                    <form method="post" data-data-repair-target="form">
                        <input type="hidden" name="_token" value="{{ csrf_token('fix_all_orphans') }}">
                        <div class="input-group">
                            <select name="tenant_id" class="form-select" required data-data-repair-target="tenantSelect">
                                <option value="">Select Tenant...</option>
                                {% for tenant in tenants %}
                                    <option value="{{ tenant.id }}">{{ tenant.name }}</option>
                                {% endfor %}
                            </select>
                            <button type="button" class="fa-cyber-btn fa-cyber-btn--warning" data-action="data-repair#fixAllOrphans">
                                <i class="bi bi-lightning" aria-hidden="true"></i> Fix All Orphans
                            </button>
                        </div>
                    </form>
                </div>
                {% endif %}

                {% if summary.broken_references_count > 0 %}
                <div class="col-md-6">
                    <h3>Fix Tenant Mismatches</h3>
                    <p class="text-muted">Automatically align {{ summary.broken_references_count }} tenant assignments</p>
                    <form method="post" action="{{ path('admin_data_repair_fix_tenant_mismatches') }}"
                          data-controller="ui-actions"
                          data-action="submit->ui-actions#confirm"
                          data-ui-actions-message-param="Fix all tenant mismatches automatically?">
                        <input type="hidden" name="_token" value="{{ csrf_token('fix_tenant_mismatches') }}">
                        <div class="mb-2">
                            <label for="fix_tenant_mismatches_reason" class="form-label small fw-semibold">
                                {{ 'admin.data_repair.reason_label'|trans({}, 'admin') }} <span class="text-danger" aria-hidden="true">*</span>
                            </label>
                            <textarea
                                id="fix_tenant_mismatches_reason"
                                name="reason"
                                class="form-control"
                                rows="2"
                                minlength="20"
                                required
                                aria-required="true"
                                aria-describedby="fix_tenant_mismatches_reason_help"></textarea>
                            <div id="fix_tenant_mismatches_reason_help" class="form-text">
                                {{ 'admin.data_repair.reason_help'|trans({}, 'admin') }}
                            </div>
                        </div>
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger w-100">
                            <i class="bi bi-lightning" aria-hidden="true"></i> Fix Tenant Mismatches
                        </button>
                    </form>
                </div>
                {% endif %}
            </div>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {# Orphaned Entities Section #}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
        {% block card_header %}
            <div class="card-header bg-warning-subtle text-warning">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> {{ 'admin.data_repair.orphaned_entities'|trans({}, 'admin') }}
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% import '_components/_fa_alert.html.twig' as _fa_alert %}
            {% set totalOrphans = 0 %}
            {% for entities in orphanedEntities %}{% set totalOrphans = totalOrphans + entities|length %}{% endfor %}
            {% if totalOrphans == 0 %}
                {{ _fa_alert.render({ variant: 'success', class: 'mb-0', body: 'admin.data_repair.no_orphans'|trans({}, 'admin') }) }}
            {% else %}
                {{ _fa_alert.render({ variant: 'warning', body: '<strong>' ~ 'common.warning'|trans({}, 'messages') ~ ':</strong> ' ~ 'admin.data_repair.orphans_found'|trans({}, 'admin') ~ ' — ' ~ 'admin.data_repair.total_orphans'|trans({'%count%': totalOrphans}, 'admin') }) }}

                {# Dynamischer Orphan-Count-Grid — pro detektiertem Entity-Typ eine Karte.
                   Zeigt auch seltene/seit Refactor neu erkannte Typen (Controls, Workflows, …). #}
                <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3 mb-3">
                    {% for key, entities in orphanedEntities %}
                        {% if entities|length > 0 %}
                            <div class="col">
                                {% embed '_components/_card.html.twig' with { class: 'text-center h-100' } %}
                                    {% block card_body %}
                                        <h3 class="text-danger mb-1">{{ entities|length }}</h3>
                                        <p class="mb-0 small text-uppercase">{{ key|replace({'_': ' '}) }}</p>
                                    {% endblock %}
                                {% endembed %}
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>

                {# Bulk Assignment Form — Entity-Type-Dropdown dynamisch aus allen
                   detektierten Orphan-Typen. #}
                <form method="post" action="{{ path('admin_data_repair_assign_orphans') }}" class="mb-4">
                    <input type="hidden" name="_token" value="{{ csrf_token('assign_orphans') }}">
                    <div class="row align-items-end">
                        <div class="col-md-4">
                            <label for="tenant_id" class="form-label">{{ 'admin.data_repair.assign_to_tenant'|trans({}, 'admin') }}</label>
                            <select name="tenant_id" id="tenant_id" class="form-select" required>
                                <option value="">{{ 'admin.data_repair.select_tenant'|trans({}, 'admin') }}</option>
                                {% for tenant in tenants %}
                                    <option value="{{ tenant.id }}">{{ tenant.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label for="entity_type" class="form-label">{{ 'admin.data_repair.entity_type'|trans({}, 'admin') }}</label>
                            <select name="entity_type" id="entity_type" class="form-select" required>
                                <option value="all">{{ 'admin.data_repair.all_orphans'|trans({}, 'admin') }} ({{ totalOrphans }})</option>
                                {% for key, entities in orphanedEntities %}
                                    {% if entities|length > 0 %}
                                        <option value="{{ key }}">{{ key|replace({'_': ' '})|title }} ({{ entities|length }})</option>
                                    {% endif %}
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-4">
                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--warning w-100">
                                <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i> {{ 'admin.data_repair.assign_orphans'|trans({}, 'admin') }}
                            </button>
                        </div>
                    </div>
                </form>

                {# Detailed Lists #}
                {% if orphanedAssets|length > 0 %}
                <div class="mb-4">
                    <h3>{{ 'admin.data_repair.orphaned_assets_list'|trans({}, 'admin') }}</h3>
                    {% embed '_components/_table.html.twig' with {
                        'class': 'table-sm table-striped',
                        'responsive': true,
                        'noMargin': true
                    } %}
                        {% block table_head %}
                            <tr>
                                <th scope="col">ID</th>
                                <th scope="col">{{ 'common.name'|trans({}, 'messages') }}</th>
                                <th scope="col">{{ 'asset.label.type'|trans({}, 'asset') }}</th>
                                <th scope="col">{{ 'common.actions'|trans({}, 'messages') }}</th>
                            </tr>
                        {% endblock %}
                        {% block table_body %}
                            {% for asset in orphanedAssets %}
                            <tr>
                                <td>{{ asset.id }}</td>
                                <td>{{ asset.name }}</td>
                                <td>{{ asset.assetType }}</td>
                                <td>
                                    <form method="post" action="{{ path('admin_data_repair_reassign_entity', {type: 'asset', id: asset.id}) }}" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('reassign_entity_' ~ asset.id) }}">
                                        <div class="input-group input-group-sm">
                                            <select name="tenant_id" class="form-select form-select-sm" required>
                                                {% for tenant in tenants %}
                                                    <option value="{{ tenant.id }}">{{ tenant.name }}</option>
                                                {% endfor %}
                                            </select>
                                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm" aria-label="{{ 'common.apply'|trans({}, 'messages') }}">
                                                <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i>
                                            </button>
                                        </div>
                                    </form>
                                </td>
                            </tr>
                            {% endfor %}
                        {% endblock %}
                    {% endembed %}
                </div>
                {% endif %}

                {% if orphanedRisks|length > 0 %}
                <div class="mb-4">
                    <h3>{{ 'admin.data_repair.orphaned_risks_list'|trans({}, 'admin') }}</h3>
                    {% embed '_components/_table.html.twig' with {
                        'class': 'table-sm table-striped',
                        'responsive': true,
                        'noMargin': true
                    } %}
                        {% block table_head %}
                            <tr>
                                <th scope="col">ID</th>
                                <th scope="col">{{ 'risk.label.title'|trans({}, 'risk') }}</th>
                                <th scope="col">{{ 'risk.label.inherent_risk'|trans({}, 'risk') }}</th>
                                <th scope="col">{{ 'common.actions'|trans({}, 'messages') }}</th>
                            </tr>
                        {% endblock %}
                        {% block table_body %}
                            {% for risk in orphanedRisks %}
                            <tr>
                                <td>{{ risk.id }}</td>
                                <td>{{ risk.title }}</td>
                                <td>{{ risk.inherentRiskLevel }}</td>
                                <td>
                                    <form method="post" action="{{ path('admin_data_repair_reassign_entity', {type: 'risk', id: risk.id}) }}" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('reassign_entity_' ~ risk.id) }}">
                                        <div class="input-group input-group-sm">
                                            <select name="tenant_id" class="form-select form-select-sm" required>
                                                {% for tenant in tenants %}
                                                    <option value="{{ tenant.id }}">{{ tenant.name }}</option>
                                                {% endfor %}
                                            </select>
                                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm" aria-label="{{ 'common.apply'|trans({}, 'messages') }}">
                                                <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i>
                                            </button>
                                        </div>
                                    </form>
                                </td>
                            </tr>
                            {% endfor %}
                        {% endblock %}
                    {% endembed %}
                </div>
                {% endif %}

                {% if orphanedIncidents|length > 0 %}
                <div class="mb-4">
                    <h3>{{ 'admin.data_repair.orphaned_incidents_list'|trans({}, 'admin') }}</h3>
                    {% embed '_components/_table.html.twig' with {
                        'class': 'table-sm table-striped',
                        'responsive': true,
                        'noMargin': true
                    } %}
                        {% block table_head %}
                            <tr>
                                <th scope="col">ID</th>
                                <th scope="col">{{ 'incident.label.title'|trans({}, 'incident') }}</th>
                                <th scope="col">{{ 'incident.label.severity'|trans({}, 'incident') }}</th>
                                <th scope="col">{{ 'common.actions'|trans({}, 'messages') }}</th>
                            </tr>
                        {% endblock %}
                        {% block table_body %}
                            {% for incident in orphanedIncidents %}
                            <tr>
                                <td>{{ incident.id }}</td>
                                <td>{{ incident.title }}</td>
                                <td>{{ incident.severity }}</td>
                                <td>
                                    <form method="post" action="{{ path('admin_data_repair_reassign_entity', {type: 'incident', id: incident.id}) }}" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('reassign_entity_' ~ incident.id) }}">
                                        <div class="input-group input-group-sm">
                                            <select name="tenant_id" class="form-select form-select-sm" required>
                                                {% for tenant in tenants %}
                                                    <option value="{{ tenant.id }}">{{ tenant.name }}</option>
                                                {% endfor %}
                                            </select>
                                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm" aria-label="{{ 'common.apply'|trans({}, 'messages') }}">
                                                <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i>
                                            </button>
                                        </div>
                                    </form>
                                </td>
                            </tr>
                            {% endfor %}
                        {% endblock %}
                    {% endembed %}
                </div>
                {% endif %}
            {% endif %}
        {% endblock %}
    {% endembed %}

    {# Tenant Statistics #}
    {% embed '_components/_card.html.twig' %}
        {% block card_header %}
            <div class="card-header">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--nav-building" aria-hidden="true"></i> {{ 'admin.data_repair.tenant_statistics'|trans({}, 'admin') }}
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% embed '_components/_table.html.twig' with {
                'class': 'table-striped',
                'responsive': true,
                'noMargin': true
            } %}
                {% block table_head %}
                    <tr>
                        <th scope="col">{{ 'tenant.name'|trans({}, 'tenant') }}</th>
                        <th scope="col" class="text-center">{{ 'nav.assets'|trans({}, 'nav') }}</th>
                        <th scope="col" class="text-center">{{ 'nav.risks'|trans({}, 'nav') }}</th>
                        <th scope="col" class="text-center">{{ 'nav.incidents'|trans({}, 'nav') }}</th>
                        <th scope="col" class="text-center">Audits</th>
                        <th scope="col" class="text-center">Documents</th>
                        <th scope="col" class="text-center">BC Plans</th>
                        <th scope="col" class="text-center">{{ 'common.all'|trans({}, 'messages') }}</th>
                    </tr>
                {% endblock %}
                {% block table_body %}
                    {% for stat in tenantStats %}
                    <tr>
                        <td>
                            <strong>{{ stat.tenant.name }}</strong>
                            {% if stat.tenant.description %}
                                <br><small class="text-muted">{{ stat.tenant.description }}</small>
                            {% endif %}
                        </td>
                        <td class="text-center">{{ stat.assets }}</td>
                        <td class="text-center">{{ stat.risks }}</td>
                        <td class="text-center">{{ stat.incidents }}</td>
                        <td class="text-center">{{ stat.audits|default(0) }}</td>
                        <td class="text-center">{{ stat.documents|default(0) }}</td>
                        <td class="text-center">{{ stat.bc_plans|default(0) }}</td>
                        <td class="text-center"><strong>{{ stat.assets + stat.risks + stat.incidents + (stat.audits|default(0)) + (stat.documents|default(0)) + (stat.bc_plans|default(0)) }}</strong></td>
                    </tr>
                    {% endfor %}
                {% endblock %}
            {% endembed %}
        {% endblock %}
    {% endembed %}

    {# fixAllOrphans is now handled by data-repair Stimulus controller #}

    {# Asset Assignment Repair for Risks #}
    {% set risksWithoutAsset = allRisks|filter(r => r.asset is null) %}
    {% if risksWithoutAsset|length > 0 %}
    {% embed '_components/_card.html.twig' with { 'class': 'mt-4' } %}
        {% block card_header %}
            <div class="card-header bg-warning-subtle text-warning">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> {{ 'admin.data_repair.risk_asset_assignment'|trans({}, 'admin') }}
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% import '_components/_fa_alert.html.twig' as _fa_alert %}
            {{ _fa_alert.render({ variant: 'warning', body: '<strong>' ~ 'common.warning'|trans({}, 'messages') ~ ':</strong> ' ~ 'admin.data_repair.risk_asset_assignment_desc'|trans({}, 'admin') }) }}
            {% embed '_components/_table.html.twig' with {
                'class': 'table-sm table-striped',
                'responsive': true,
                'noMargin': true
            } %}
                {% block table_head %}
                    <tr>
                        <th scope="col">ID</th>
                        <th scope="col">{{ 'risk.label.title'|trans({}, 'risk') }}</th>
                        <th scope="col">{{ 'admin.data_repair.current_asset'|trans({}, 'admin') }}</th>
                        <th scope="col">{{ 'admin.data_repair.assign_to_asset'|trans({}, 'admin') }}</th>
                    </tr>
                {% endblock %}
                {% block table_body %}
                    {% for risk in risksWithoutAsset %}
                    <tr class="table-warning">
                        <td>{{ risk.id }}</td>
                        <td>
                            {{ risk.title }}
                            {% if risk.tenant %}
                                <br><small class="text-muted">{{ risk.tenant.name }}</small>
                            {% endif %}
                        </td>
                        <td>
                            {% if risk.asset %}
                                {% include '_components/_badge.html.twig' with { variant: 'success', content: risk.asset.name } %}
                            {% else %}
                                {% include '_components/_badge.html.twig' with { variant: 'danger', content: 'admin.data_repair.no_asset'|trans({}, 'admin') } %}
                            {% endif %}
                        </td>
                        <td>
                            <form method="post" action="{{ path('admin_data_repair_assign_asset', {type: 'risk', id: risk.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('assign_asset_' ~ risk.id) }}">
                                <div class="input-group input-group-sm">
                                    <select name="asset_id" class="form-select form-select-sm" required>
                                        <option value="">{{ 'admin.data_repair.select_asset'|trans({}, 'admin') }}</option>
                                        {% for asset in allAssets %}
                                            <option value="{{ asset.id }}"{% if risk.asset and risk.asset.id == asset.id %} selected{% endif %}>
                                                {{ asset.name }} ({{ asset.tenant ? asset.tenant.name : 'Kein Tenant' }})
                                            </option>
                                        {% endfor %}
                                    </select>
                                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm" aria-label="{{ 'common.view_details'|trans({}, 'messages') }}">
                                        <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                                    </button>
                                </div>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                {% endblock %}
            {% endembed %}
        {% endblock %}
    {% endembed %}
    {% endif %}

    {# Asset Assignment Repair for Incidents #}
    {% set incidentsWithoutAsset = allIncidents|filter(i => i.affectedAssets|length == 0) %}
    {% if incidentsWithoutAsset|length > 0 %}
    {% embed '_components/_card.html.twig' with { 'class': 'mt-4' } %}
        {% block card_header %}
            <div class="card-header bg-warning-subtle text-warning">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> {{ 'admin.data_repair.incident_asset_assignment'|trans({}, 'admin') }}
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% import '_components/_fa_alert.html.twig' as _fa_alert %}
            {{ _fa_alert.render({ variant: 'warning', body: '<strong>' ~ 'common.warning'|trans({}, 'messages') ~ ':</strong> ' ~ 'admin.data_repair.incident_asset_assignment_desc'|trans({}, 'admin') }) }}
            {% embed '_components/_table.html.twig' with {
                'class': 'table-sm table-striped',
                'responsive': true,
                'noMargin': true
            } %}
                {% block table_head %}
                    <tr>
                        <th scope="col">ID</th>
                        <th scope="col">{{ 'incident.label.title'|trans({}, 'incident') }}</th>
                        <th scope="col">{{ 'admin.data_repair.current_asset'|trans({}, 'admin') }}</th>
                        <th scope="col">{{ 'admin.data_repair.assign_to_asset'|trans({}, 'admin') }}</th>
                    </tr>
                {% endblock %}
                {% block table_body %}
                    {% for incident in incidentsWithoutAsset %}
                    <tr class="table-warning">
                        <td>{{ incident.id }}</td>
                        <td>
                            {{ incident.title }}
                            {% if incident.tenant %}
                                <br><small class="text-muted">{{ incident.tenant.name }}</small>
                            {% endif %}
                        </td>
                        <td>
                            {% if incident.affectedAssets|length > 0 %}
                                {% for asset in incident.affectedAssets %}
                                    {% include '_components/_badge.html.twig' with { variant: 'success', content: asset.name } %}
                                {% endfor %}
                            {% else %}
                                {% include '_components/_badge.html.twig' with { variant: 'danger', content: 'admin.data_repair.no_asset'|trans({}, 'admin') } %}
                            {% endif %}
                        </td>
                        <td>
                            <form method="post" action="{{ path('admin_data_repair_assign_asset', {type: 'incident', id: incident.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('assign_asset_' ~ incident.id) }}">
                                <div class="input-group input-group-sm">
                                    <select name="asset_id" class="form-select form-select-sm" required>
                                        <option value="">{{ 'admin.data_repair.select_asset'|trans({}, 'admin') }}</option>
                                        {% for asset in allAssets %}
                                            <option value="{{ asset.id }}">
                                                {{ asset.name }} ({{ asset.tenant ? asset.tenant.name : 'Kein Tenant' }})
                                            </option>
                                        {% endfor %}
                                    </select>
                                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm" aria-label="{{ 'common.view_details'|trans({}, 'messages') }}">
                                        <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                                    </button>
                                </div>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                {% endblock %}
            {% endembed %}
        {% endblock %}
    {% endembed %}
    {% endif %}

    {# Controls Without Risks #}
    {% if controlsWithoutRisks|length > 0 %}
    {% embed '_components/_card.html.twig' with { 'class': 'mt-4' } %}
        {% block card_header %}
            <div class="card-header bg-warning-subtle text-warning">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> {{ 'admin.data_repair.controls_without_risks'|trans({}, 'admin') }}
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% import '_components/_fa_alert.html.twig' as _fa_alert %}
            {{ _fa_alert.render({ variant: 'warning', body: '<strong>' ~ 'common.warning'|trans({}, 'messages') ~ ':</strong> ' ~ 'admin.data_repair.controls_without_risks_desc'|trans({}, 'admin') }) }}
            <p class="text-muted">{{ 'admin.data_repair.controls_count'|trans({'%count%': controlsWithoutRisks|length}, 'admin') }}</p>
            {% embed '_components/_table.html.twig' with {
                'class': 'table-sm table-striped',
                'responsive': true,
                'noMargin': true
            } %}
                {% block table_head %}
                    <tr>
                        <th scope="col">{{ 'control.field.control_id'|trans({}, 'control') }}</th>
                        <th scope="col">{{ 'control.field.name'|trans({}, 'control') }}</th>
                        <th scope="col">{{ 'control.field.category'|trans({}, 'control') }}</th>
                        <th scope="col">{{ 'control.field.implementation_status'|trans({}, 'control') }}</th>
                        <th scope="col">{{ 'admin.data_repair.assign_risk'|trans({}, 'admin') }}</th>
                    </tr>
                {% endblock %}
                {% block table_body %}
                    {% for control in controlsWithoutRisks %}
                    <tr class="table-warning">
                        <td>{% include '_components/_badge.html.twig' with { variant: 'primary', content: control.controlId } %}</td>
                        <td>{{ control.name }}</td>
                        <td>{{ control.category }}</td>
                        <td>
                            {% include '_components/_badge.html.twig' with { variant: control.implementationStatus == 'implemented' ? 'success' : (control.implementationStatus == 'in_progress' ? 'warning' : (control.implementationStatus == 'not_started' ? 'secondary' : 'dark')), content: ('control.status.' ~ control.implementationStatus)|trans({}, 'control') } %}
                        </td>
                        <td>
                            <form method="post" action="{{ path('admin_data_repair_assign_risk', {id: control.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('assign_risk_' ~ control.id) }}">
                                <div class="input-group input-group-sm">
                                    <select name="risk_id" class="form-select form-select-sm" required>
                                        <option value="">{{ 'admin.data_repair.select_risk'|trans({}, 'admin') }}</option>
                                        {% for risk in allRisks %}
                                            <option value="{{ risk.id }}">
                                                {{ risk.title }} ({{ risk.tenant ? risk.tenant.name : 'Kein Tenant' }})
                                            </option>
                                        {% endfor %}
                                    </select>
                                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm" aria-label="{{ 'common.view'|trans({}, 'messages') }}">
                                        <i class="fa-icon fa-icon--ui-link" aria-hidden="true"></i>
                                    </button>
                                </div>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                {% endblock %}
            {% endembed %}
        {% endblock %}
    {% endembed %}
    {% endif %}

    {# Controls Without Assets #}
    {% if controlsWithoutAssets|length > 0 %}
    {% embed '_components/_card.html.twig' with { 'class': 'mt-4' } %}
        {% block card_header %}
            <div class="card-header">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--compliance-shield" aria-hidden="true"></i> {{ 'admin.data_repair.controls_without_assets'|trans({}, 'admin') }}
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% import '_components/_fa_alert.html.twig' as _fa_alert %}
            {{ _fa_alert.render({ variant: 'info', body: '<strong>' ~ 'common.info'|trans({}, 'messages') ~ ':</strong> ' ~ 'admin.data_repair.controls_without_assets_desc'|trans({}, 'admin') }) }}
            <p class="text-muted">{{ 'admin.data_repair.controls_count'|trans({'%count%': controlsWithoutAssets|length}, 'admin') }}</p>
            {% embed '_components/_table.html.twig' with {
                'class': 'table-sm table-striped',
                'responsive': true,
                'noMargin': true
            } %}
                {% block table_head %}
                    <tr>
                        <th scope="col">{{ 'control.field.control_id'|trans({}, 'control') }}</th>
                        <th scope="col">{{ 'control.field.name'|trans({}, 'control') }}</th>
                        <th scope="col">{{ 'control.field.category'|trans({}, 'control') }}</th>
                        <th scope="col">{{ 'control.field.implementation_status'|trans({}, 'control') }}</th>
                        <th scope="col">{{ 'admin.data_repair.assign_asset'|trans({}, 'admin') }}</th>
                    </tr>
                {% endblock %}
                {% block table_body %}
                    {% for control in controlsWithoutAssets %}
                    <tr>
                        <td>{% include '_components/_badge.html.twig' with { variant: 'primary', content: control.controlId } %}</td>
                        <td>{{ control.name }}</td>
                        <td>{{ control.category }}</td>
                        <td>
                            {% include '_components/_badge.html.twig' with { variant: control.implementationStatus == 'implemented' ? 'success' : (control.implementationStatus == 'in_progress' ? 'warning' : (control.implementationStatus == 'not_started' ? 'secondary' : 'dark')), content: ('control.status.' ~ control.implementationStatus)|trans({}, 'control') } %}
                        </td>
                        <td>
                            <form method="post" action="{{ path('admin_data_repair_assign_asset_to_control', {id: control.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('assign_asset_to_control_' ~ control.id) }}">
                                <div class="input-group input-group-sm">
                                    <select name="asset_id" class="form-select form-select-sm" required>
                                        <option value="">{{ 'admin.data_repair.select_asset'|trans({}, 'admin') }}</option>
                                        {% for asset in allAssets %}
                                            <option value="{{ asset.id }}">
                                                {{ asset.name }} ({{ asset.tenant ? asset.tenant.name : 'Kein Tenant' }})
                                            </option>
                                        {% endfor %}
                                    </select>
                                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm" aria-label="{{ 'common.view'|trans({}, 'messages') }}">
                                        <i class="fa-icon fa-icon--ui-link" aria-hidden="true"></i>
                                    </button>
                                </div>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                {% endblock %}
            {% endembed %}
        {% endblock %}
    {% endembed %}
    {% endif %}

    {# Duplicate Entities #}
    {% if duplicates.audits is defined and duplicates.audits|length > 0 %}
    {% embed '_components/_card.html.twig' with { 'class': 'mt-4' } %}
        {% block card_header %}
            <div class="card-header bg-warning-subtle text-warning">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--ui-copy" aria-hidden="true"></i> Duplicate Audit Numbers
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% import '_components/_fa_alert.html.twig' as _fa_alert %}
            {{ _fa_alert.render({ variant: 'warning', body: '<strong>' ~ 'common.warning'|trans({}, 'messages') ~ ':</strong> Found ' ~ duplicates.audits|length ~ ' audit number(s) used multiple times within the same tenant.' }) }}
            {% for dup in duplicates.audits %}
                {% embed '_components/_card.html.twig' with { class: 'mb-3 border-warning' } %}
                    {% block card_header %}
                        <div class="card-header">
                            <strong>Audit Number:</strong> {{ dup.value }}
                            {% include '_components/_badge.html.twig' with { variant: 'warning', content: dup.count ~ ' duplicates' } %}
                        </div>
                    {% endblock %}
                    {% block card_body %}
                        <ul class="list-unstyled mb-0">
                        {% for audit in dup.entities %}
                            <li class="mb-2">
                                {% include '_components/_badge.html.twig' with { variant: 'secondary', content: 'ID: ' ~ audit.id } %}
                                {{ audit.title }}
                                <small class="text-muted">({{ audit.tenant.name }})</small>
                                {% if audit.plannedDate %}
                                    - <small>{{ audit.plannedDate|date('d.m.Y') }}</small>
                                {% endif %}
                            </li>
                        {% endfor %}
                        </ul>
                    {% endblock %}
                {% endembed %}
            {% endfor %}
        {% endblock %}
    {% endembed %}
    {% endif %}

    {% if duplicates.assets is defined and duplicates.assets|length > 0 %}
    {% embed '_components/_card.html.twig' with { 'class': 'mt-4' } %}
        {% block card_header %}
            <div class="card-header bg-warning-subtle text-warning">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--ui-copy" aria-hidden="true"></i> Duplicate Asset Names
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% import '_components/_fa_alert.html.twig' as _fa_alert %}
            {{ _fa_alert.render({ variant: 'warning', body: '<strong>' ~ 'common.warning'|trans({}, 'messages') ~ ':</strong> Found ' ~ duplicates.assets|length ~ ' asset name(s) used multiple times within the same tenant.' }) }}
            {% for dup in duplicates.assets %}
                {% embed '_components/_card.html.twig' with { class: 'mb-3 border-warning' } %}
                    {% block card_header %}
                        <div class="card-header">
                            <strong>Asset Name:</strong> {{ dup.value }}
                            {% include '_components/_badge.html.twig' with { variant: 'warning', content: dup.count ~ ' duplicates' } %}
                        </div>
                    {% endblock %}
                    {% block card_body %}
                        <ul class="list-unstyled mb-0">
                        {% for asset in dup.entities %}
                            <li class="mb-2">
                                {% include '_components/_badge.html.twig' with { variant: 'secondary', content: 'ID: ' ~ asset.id } %}
                                {{ asset.name }}
                                <small class="text-muted">({{ asset.tenant.name }}, Type: {{ asset.assetType }})</small>
                            </li>
                        {% endfor %}
                        </ul>
                    {% endblock %}
                {% endembed %}
            {% endfor %}
        {% endblock %}
    {% endembed %}
    {% endif %}

    {# Inconsistent Data #}
    {% if inconsistentData.audits_completed_without_date is defined and inconsistentData.audits_completed_without_date|length > 0 %}
    {% embed '_components/_card.html.twig' with { 'class': 'mt-4' } %}
        {% block card_header %}
            <div class="card-header">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--ui-calendar" aria-hidden="true"></i> Completed Audits Without Completion Date
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% import '_components/_fa_alert.html.twig' as _fa_alert %}
            {{ _fa_alert.render({ variant: 'info', body: 'Found ' ~ inconsistentData.audits_completed_without_date|length ~ ' audit(s) marked as completed but missing actual completion date.' }) }}
            <ul>
            {% for audit in inconsistentData.audits_completed_without_date %}
                <li>
                    {% include '_components/_badge.html.twig' with { variant: 'secondary', content: audit.auditNumber } %}
                    {{ audit.title }}
                    {% include '_components/_badge.html.twig' with { variant: audit.status == 'completed' ? 'success' : 'primary', content: audit.status } %}
                </li>
            {% endfor %}
            </ul>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {% if inconsistentData.risks_residual_higher_than_inherent is defined and inconsistentData.risks_residual_higher_than_inherent|length > 0 %}
    {% embed '_components/_card.html.twig' with { 'class': 'mt-4' } %}
        {% block card_header %}
            <div class="card-header">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> Risks with Residual > Inherent
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% import '_components/_fa_alert.html.twig' as _fa_alert %}
            {{ _fa_alert.render({ variant: 'info', body: 'Found ' ~ inconsistentData.risks_residual_higher_than_inherent|length ~ ' risk(s) where residual risk is higher than inherent risk (should never happen).' }) }}
            <ul>
            {% for risk in inconsistentData.risks_residual_higher_than_inherent %}
                <li>
                    {{ risk.title }}
                    {% include '_components/_badge.html.twig' with { variant: 'danger', content: 'Inherent: ' ~ risk.inherentRiskLevel } %}
                    →
                    {% include '_components/_badge.html.twig' with { variant: 'warning', content: 'Residual: ' ~ risk.residualRiskLevel } %}
                </li>
            {% endfor %}
            </ul>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {# Broken References #}
    {% if brokenReferences|length > 0 %}
    {% embed '_components/_card.html.twig' with { 'class': 'mt-4' } %}
        {% block card_header %}
            <div class="card-header">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i> {{ 'admin.data_repair.broken_references'|trans({}, 'admin') }}
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% import '_components/_fa_alert.html.twig' as _fa_alert %}
            {{ _fa_alert.render({ variant: 'danger', body: '<strong>' ~ 'common.error'|trans({}, 'messages') ~ ':</strong> ' ~ 'admin.data_repair.broken_references_desc'|trans({}, 'admin') }) }}
            {% embed '_components/_table.html.twig' with {
                'class': 'table-sm table-striped',
                'responsive': true,
                'noMargin': true
            } %}
                {% block table_head %}
                    <tr>
                        <th scope="col">{{ 'admin.data_repair.entity_type'|trans({}, 'admin') }}</th>
                        <th scope="col">ID</th>
                        <th scope="col">{{ 'common.name'|trans({}, 'messages') }}</th>
                        <th scope="col">{{ 'admin.data_repair.issue'|trans({}, 'admin') }}</th>
                    </tr>
                {% endblock %}
                {% block table_body %}
                    {% for ref in brokenReferences %}
                    <tr class="table-danger">
                        <td>{% include '_components/_badge.html.twig' with { variant: 'secondary', content: ref.entity_type } %}</td>
                        <td>{{ ref.entity_id }}</td>
                        <td>{{ ref.entity_name }}</td>
                        <td>{{ ref.issue }}</td>
                    </tr>
                    {% endfor %}
                {% endblock %}
            {% endembed %}
        {% endblock %}
    {% endembed %}
    {% endif %}
</div>
{% endblock %}
