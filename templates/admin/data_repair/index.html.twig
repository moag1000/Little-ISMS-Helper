{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'admin' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}

{% block title %}{{ 'admin.data_repair.title'|trans({}, 'admin') }} - {{ 'admin.panel.title'|trans({}, 'admin') }}{% endblock %}

{% block admin_title %}
    <i class="fa-icon fa-icon--nav-tools" aria-hidden="true"></i> {{ 'admin.data_repair.title'|trans({}, 'admin') }}
{% endblock %}

{#
 # The async-rendering refactor splits this page into a fast-rendering
 # cache-driven hub and four per-section sub-pages (orphans / duplicates /
 # broken-references / health). Every tile below reads scalar counts from
 # var/data_integrity/<section>.json. The "Refresh now" CTAs on each
 # sub-page dispatch a section-scoped scan job via JobDispatcher.
 #
 # Counts are stale-tolerant by design: when an admin clicks a repair
 # action the underlying route still reads live data — the cache only
 # drives the navigation UI and timestamp banners.
 #}

{% set hourAgo = "now"|date('U') - 3600 %}
{% set fullCache = integrityResultCache %}
{% set fullCacheStale = fullCache is null or fullCache.completed_at < hourAgo %}

{% block admin_content %}
<div class="container-fluid">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.admin'|trans({}, 'nav'), url: path('admin_dashboard') },
            { label: 'admin.data_repair.title'|trans({}, 'admin') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'nav-wrench', label: 'Data Repair' },
        title: 'admin.data_repair.title'|trans({}, 'admin'),
        subtitle: 'admin.data_repair.description'|trans({}, 'admin'),
    }) }}

    {# Safety banner — every action here mutates live data. #}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'danger', class: 'border-start border-5 border-danger shadow-sm' } } %}
        {% block alert_body %}
        <div class="fa-alert__title">{{ 'admin.data_repair.safety.title'|trans({}, 'admin') }}</div>
        <p class="mb-2">
            <strong>{{ 'admin.data_repair.safety.lead'|trans({}, 'admin') }}</strong>
        </p>
        <ul class="mb-3 small">
            <li>{{ 'admin.data_repair.safety.point_audit_log'|trans({}, 'admin') }}</li>
            <li>{{ 'admin.data_repair.safety.point_backup'|trans({}, 'admin') }}</li>
            <li>{{ 'admin.data_repair.safety.point_confirm'|trans({}, 'admin') }}</li>
        </ul>
        <div class="d-flex gap-2 align-items-center">
            <a href="{{ path('data_backup_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                <i class="fa-icon fa-icon--nav-hdd" aria-hidden="true"></i>
                {{ 'admin.data_repair.safety.action_backup'|trans({}, 'admin') }}
            </a>
            <a href="{{ path('app_audit_log_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                <i class="fa-icon fa-icon--nav-journal" aria-hidden="true"></i>
                {{ 'admin.data_repair.safety.action_audit_log'|trans({}, 'admin') }}
            </a>
            <span class="small text-muted ms-auto">
                {{ 'admin.data_repair.safety.role_hint'|trans({}, 'admin') }}
            </span>
        </div>
        {% endblock %}
    {% endembed %}

    {% for message in app.flashes('success') %}
        {{ _fa_alert.render({ variant: 'success', dismissible: true, body: message }) }}
    {% endfor %}

    {% for message in app.flashes('error') %}
        {{ _fa_alert.render({ variant: 'danger', dismissible: true, body: message }) }}
    {% endfor %}

    {% for message in app.flashes('warning') %}
        {{ _fa_alert.render({ variant: 'warning', dismissible: true, body: message }) }}
    {% endfor %}

    {% for message in app.flashes('info') %}
        {{ _fa_alert.render({ variant: 'info', dismissible: true, body: message }) }}
    {% endfor %}

    {# Full integrity-scan banner — cache state + run-now CTA. #}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: fullCacheStale ? 'warning' : 'info', class: 'mb-4' } } %}
        {% block alert_body %}
        <div class="d-flex align-items-start gap-3 flex-wrap">
            <div class="flex-grow-1">
                <div class="fa-alert__title">{{ 'admin.data_repair.integrity_check.title'|trans({}, 'admin') }}</div>
                <p class="mb-2">{{ 'admin.data_repair.integrity_check.description'|trans({}, 'admin') }}</p>
                {% if fullCache is not null %}
                    <p class="small text-muted mb-0">
                        <i class="fa-icon fa-icon--status-info" aria-hidden="true"></i>
                        {{ 'admin.data_repair.integrity_check.last_run'|trans({
                            '%when%': fullCache.completed_at|date('Y-m-d H:i'),
                            '%duration%': (fullCache.duration_ms / 1000)|round(1),
                        }, 'admin') }}
                        {% set _c = fullCache.counts %}
                        — {{ 'admin.data_repair.integrity_check.last_counts'|trans({
                            '%orphans%': _c.orphans_total|default(0),
                            '%duplicates%': _c.duplicates_groups|default(0),
                            '%broken%': _c.broken_references|default(0),
                            '%health%': _c.health_score|default(0),
                        }, 'admin') }}
                    </p>
                {% else %}
                    <p class="small text-muted mb-0">
                        <i class="fa-icon fa-icon--status-info" aria-hidden="true"></i>
                        {{ 'admin.data_repair.integrity_check.never_run'|trans({}, 'admin') }}
                    </p>
                {% endif %}
            </div>
            <form method="post" action="{{ path('admin_data_repair_run_integrity_check') }}" class="d-inline-block">
                <input type="hidden" name="_token" value="{{ csrf_token('run_integrity_check') }}">
                <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                    <i class="fa-icon fa-icon--arrow-repeat" aria-hidden="true"></i>
                    {{ 'admin.data_repair.integrity_check.run_now'|trans({}, 'admin') }}
                </button>
            </form>
        </div>
        {% endblock %}
    {% endembed %}

    {# Schema-Maintenance — 3-Card-Grid (Migrations | Drift | Aktionen). #}
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h4 class="mb-0">
                        <i class="fa-icon fa-icon--nav-database-add" aria-hidden="true"></i>
                        {{ 'admin.data_repair.schema.migrations'|trans({}, 'admin') }}
                    </h4>
                </div>
                <div class="fa-section__body">
                    <p class="mb-2">
                        {% if migration_status.pending > 0 %}
                            <span class="fa-status-pill fa-status-pill--warning">
                                {{ migration_status.pending }} {{ 'admin.data_repair.schema.pending'|trans({}, 'admin') }}
                            </span>
                        {% else %}
                            <span class="fa-status-pill fa-status-pill--success">
                                {{ 'admin.data_repair.schema.up_to_date'|trans({}, 'admin') }}
                            </span>
                        {% endif %}
                    </p>
                    {% if migration_status.pending > 0 %}
                        <ul class="small mb-3">
                            {% for name in migration_status.names|slice(0, 5) %}
                                <li><code>{{ name }}</code></li>
                            {% endfor %}
                            {% if migration_status.names|length > 5 %}
                                <li>… {{ migration_status.names|length - 5 }} {{ 'admin.data_repair.schema.more'|trans({}, 'admin') }}</li>
                            {% endif %}
                        </ul>
                    {% endif %}
                    <form method="post" action="{{ path('admin_data_repair_migrations_execute') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('migrations_execute') }}">
                        <button type="submit"
                                class="fa-cyber-btn fa-cyber-btn--{{ migration_status.pending > 0 ? 'warning' : 'ghost' }} fa-cyber-btn--full"
                                {% if migration_status.pending == 0 %}disabled{% endif %}>
                            <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                            {{ 'admin.data_repair.schema.run_migrations'|trans({}, 'admin') }}
                        </button>
                    </form>
                </div>
            </section>
        </div>

        <div class="col-md-4">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h4 class="mb-0">
                        <i class="fa-icon fa-icon--ui-refresh" aria-hidden="true"></i>
                        {{ 'admin.data_repair.schema.drift'|trans({}, 'admin') }}
                    </h4>
                </div>
                <div class="fa-section__body">
                    <p class="mb-2">
                        {% if schema_drift.count > 0 %}
                            <span class="fa-status-pill fa-status-pill--danger">
                                {{ schema_drift.count }} {{ 'admin.data_repair.schema.statements'|trans({}, 'admin') }}
                            </span>
                            {% if schema_drift.destructive|length > 0 %}
                                <span class="fa-status-pill fa-status-pill--warning">
                                    {{ schema_drift.destructive|length }} {{ 'admin.data_repair.schema.destructive'|trans({}, 'admin') }}
                                </span>
                            {% endif %}
                        {% else %}
                            <span class="fa-status-pill fa-status-pill--success">
                                {{ 'admin.data_repair.schema.in_sync'|trans({}, 'admin') }}
                            </span>
                        {% endif %}
                    </p>
                    {% if schema_drift.count > 0 %}
                        <details class="mb-2 small">
                            <summary>{{ 'admin.data_repair.schema.show_sql'|trans({}, 'admin') }}</summary>
                            <pre class="mt-2 p-2 bg-body-secondary rounded" style="max-height: 200px; overflow: auto;"><code>{{ schema_drift.statements|join(";\n") }}</code></pre>
                        </details>
                    {% endif %}
                    <form method="post" action="{{ path('admin_data_repair_schema_reconcile') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('schema_reconcile') }}">
                        <button type="submit"
                                class="fa-cyber-btn fa-cyber-btn--{{ schema_drift.count > 0 ? 'danger' : 'ghost' }} fa-cyber-btn--full"
                                {% if schema_drift.count == 0 %}disabled{% endif %}>
                            <i class="fa-icon fa-icon--ui-refresh" aria-hidden="true"></i>
                            {{ 'admin.data_repair.schema.run_reconcile'|trans({}, 'admin') }}
                        </button>
                    </form>
                </div>
            </section>
        </div>

        <div class="col-md-4">
            <section class="fa-section">
                <div class="fa-section__header">
                    <h4 class="mb-0">
                        <i class="fa-icon fa-icon--nav-people" aria-hidden="true"></i>
                        {{ 'admin.data_repair.tenant_card.title'|trans({}, 'admin') }}
                    </h4>
                </div>
                <div class="fa-section__body">
                    <p class="mb-2">
                        <span class="fa-status-pill fa-status-pill--neutral">
                            {{ 'admin.data_repair.tenant_card.tenant_count'|trans({'%count%': tenantCount}, 'admin') }}
                        </span>
                    </p>
                    <p class="small text-muted mb-0">
                        {{ 'admin.data_repair.tenant_card.description'|trans({}, 'admin') }}
                    </p>
                </div>
            </section>
        </div>
    </div>

    {# ====================================================================
       Per-section KPI tiles — each links to its sub-page where repair
       actions + previewed rows are rendered. Counts come from the
       per-section cache; "never scanned" tiles render neutral grey.
    ==================================================================== #}
    <h2 class="mt-4 mb-3">
        <i class="fa-icon fa-icon--nav-heart-pulse" aria-hidden="true"></i>
        {{ 'admin.data_repair.sections_title'|trans({}, 'admin') }}
    </h2>

    <div class="row g-3 mb-4">
        {# Orphans tile #}
        {% set orphCache = sectionCaches.orphans %}
        {% set orphTotal = orphCache is not null ? (orphCache.payload.total|default(0)) : null %}
        {% set orphVariant = orphCache is null ? 'primary' : (orphTotal > 0 ? 'warning' : 'success') %}
        <div class="col-md-6 col-lg-3">
            {{ _fa_feature_card.render({
                variant: orphVariant,
                icon: 'status-warning',
                label: 'admin.data_repair.section.orphans'|trans({}, 'admin'),
                value: orphCache is null ? '—' : orphTotal,
                hint: orphCache is null
                    ? 'admin.data_repair.section.never_scanned'|trans({}, 'admin')
                    : 'admin.data_repair.section.scanned_ago'|trans({'%when%': orphCache.completed_at|date('Y-m-d H:i')}, 'admin'),
                href: path('admin_data_repair_orphans'),
            }) }}
        </div>

        {# Duplicates tile #}
        {% set dupCache = sectionCaches.duplicates %}
        {% set dupTotal = dupCache is not null ? (dupCache.payload.total_groups|default(0)) : null %}
        {% set dupVariant = dupCache is null ? 'primary' : (dupTotal > 0 ? 'warning' : 'success') %}
        <div class="col-md-6 col-lg-3">
            {{ _fa_feature_card.render({
                variant: dupVariant,
                icon: 'ui-copy',
                label: 'admin.data_repair.section.duplicates'|trans({}, 'admin'),
                value: dupCache is null ? '—' : dupTotal,
                hint: dupCache is null
                    ? 'admin.data_repair.section.never_scanned'|trans({}, 'admin')
                    : 'admin.data_repair.section.scanned_ago'|trans({'%when%': dupCache.completed_at|date('Y-m-d H:i')}, 'admin'),
                href: path('admin_data_repair_duplicates_index'),
            }) }}
        </div>

        {# Broken refs tile #}
        {% set brCache = sectionCaches.broken_references %}
        {% set brTotal = brCache is not null
            ? (brCache.payload.broken_total|default(0)) + (brCache.payload.cascade_total|default(0)) + (brCache.payload.uploads_total|default(0))
            : null %}
        {% set brVariant = brCache is null ? 'primary' : (brTotal > 0 ? 'danger' : 'success') %}
        <div class="col-md-6 col-lg-3">
            {{ _fa_feature_card.render({
                variant: brVariant,
                icon: 'ui-link',
                label: 'admin.data_repair.section.broken_references'|trans({}, 'admin'),
                value: brCache is null ? '—' : brTotal,
                hint: brCache is null
                    ? 'admin.data_repair.section.never_scanned'|trans({}, 'admin')
                    : 'admin.data_repair.section.scanned_ago'|trans({'%when%': brCache.completed_at|date('Y-m-d H:i')}, 'admin'),
                href: path('admin_data_repair_broken_refs_index'),
            }) }}
        </div>

        {# Health tile #}
        {% set healthCache = sectionCaches.health %}
        {% set healthTotal = healthCache is not null ? (healthCache.payload.total|default(0)) : null %}
        {% set healthVariant = healthCache is null ? 'primary' : (healthTotal > 0 ? 'warning' : 'success') %}
        <div class="col-md-6 col-lg-3">
            {{ _fa_feature_card.render({
                variant: healthVariant,
                icon: 'nav-heart-pulse',
                label: 'admin.data_repair.section.health'|trans({}, 'admin'),
                value: healthCache is null ? '—' : healthTotal,
                hint: healthCache is null
                    ? 'admin.data_repair.section.never_scanned'|trans({}, 'admin')
                    : 'admin.data_repair.section.scanned_ago'|trans({'%when%': healthCache.completed_at|date('Y-m-d H:i')}, 'admin'),
                href: path('admin_data_repair_health_index'),
            }) }}
        </div>
    </div>

    {# ====================================================================
       Inventory previews — render cached scan results inline so the admin
       can SEE what's cleanable without clicking through to the sub-pages.
       Each section card reads from SectionScanResultCache (fast file read,
       no DB roundtrip on this page) and shows the first ~10 items + a
       "View all" link when more remain. Cache-empty cards render an
       Aurora empty-state with a "Scan now" CTA pointing to the section.
    ==================================================================== #}
    <h2 class="mt-5 mb-3">
        <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
        {{ 'admin.data_repair.inventory.title'|trans({}, 'admin') }}
    </h2>

    {# Orphans inventory card #}
    <section class="fa-section mb-4 {{ orphCache is null ? 'border-primary' : (orphTotal > 0 ? 'border-warning' : 'border-success') }}">
        <div class="fa-section__header">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                <h3 class="mb-0 fs-5">
                    <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i>
                    {{ 'admin.data_repair.section.orphans'|trans({}, 'admin') }}
                    {% if orphCache is not null %}
                        <span class="fa-status-pill fa-status-pill--{{ orphTotal > 0 ? 'warning' : 'success' }} ms-2">
                            {{ orphTotal }}
                        </span>
                    {% endif %}
                </h3>
                <div class="d-flex gap-2 align-items-center small text-muted">
                    {% if orphCache is not null %}
                        <span>
                            <i class="fa-icon fa-icon--status-info" aria-hidden="true"></i>
                            {{ 'admin.data_repair.section.scanned_ago'|trans({'%when%': orphCache.completed_at|date('Y-m-d H:i')}, 'admin') }}
                        </span>
                    {% endif %}
                    <form method="post" action="{{ path('admin_data_repair_orphans_refresh') }}" class="d-inline-block m-0">
                        <input type="hidden" name="_token" value="{{ csrf_token('refresh_section_orphans') }}">
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                            <i class="fa-icon fa-icon--arrow-repeat" aria-hidden="true"></i>
                            {{ 'admin.data_repair.section.refresh_now'|trans({}, 'admin') }}
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <div class="fa-section__body">
            {% if orphCache is null %}
                {{ _fa_alert.render({
                    variant: 'info',
                    body: 'admin.data_repair.inventory.never_scanned'|trans({}, 'admin'),
                }) }}
            {% elseif orphTotal == 0 %}
                {{ _fa_alert.render({
                    variant: 'success',
                    body: 'admin.data_repair.no_orphans'|trans({}, 'admin'),
                }) }}
            {% else %}
                {% set orphPreview = orphCache.payload.preview_by_type|default({}) %}
                {% set orphCounts = orphCache.payload.counts_by_type|default({}) %}
                <p class="small text-muted mb-3">
                    {{ 'admin.data_repair.section.orphans_summary'|trans({
                        '%total%': orphTotal,
                        '%types%': orphCounts|length,
                    }, 'admin') }}
                </p>
                <div class="fa-table-wrap">
                    <table class="fa-table fa-table--compact fa-table--hover">
                        <thead class="fa-table__head"><tr>
                            <th scope="col" class="fa-table__th">{{ 'admin.data_repair.inventory.col_type'|trans({}, 'admin') }}</th>
                            <th scope="col" class="fa-table__th">ID</th>
                            <th scope="col" class="fa-table__th">{{ 'common.name'|trans({}, 'messages') }}</th>
                        </tr></thead>
                        <tbody class="fa-table__body">
                            {% set rowsShown = 0 %}
                            {% set maxRows = 15 %}
                            {% for typeKey, rows in orphPreview %}
                                {% for row in rows %}
                                    {% if rowsShown < maxRows %}
                                        <tr class="fa-table__row">
                                            <td class="fa-table__cell">
                                                <span class="fa-status-pill fa-status-pill--neutral">{{ typeKey|replace({'_': ' '})|title }}</span>
                                            </td>
                                            <td class="fa-table__cell">{{ row.id ?? '—' }}</td>
                                            <td class="fa-table__cell">{{ row.label ?? '—' }}</td>
                                        </tr>
                                        {% set rowsShown = rowsShown + 1 %}
                                    {% endif %}
                                {% endfor %}
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% if orphTotal > rowsShown %}
                    <p class="small text-muted mt-2 mb-0">
                        {{ 'admin.data_repair.inventory.more_items'|trans({'%count%': orphTotal - rowsShown}, 'admin') }}
                    </p>
                {% endif %}
                <div class="mt-3">
                    <a href="{{ path('admin_data_repair_orphans') }}" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--sm">
                        <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                        {{ 'admin.data_repair.inventory.show_all'|trans({}, 'admin') }}
                    </a>
                </div>
            {% endif %}
        </div>
    </section>

    {# Duplicates inventory card #}
    <section class="fa-section mb-4 {{ dupCache is null ? 'border-primary' : (dupTotal > 0 ? 'border-warning' : 'border-success') }}">
        <div class="fa-section__header">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                <h3 class="mb-0 fs-5">
                    <i class="fa-icon fa-icon--ui-copy" aria-hidden="true"></i>
                    {{ 'admin.data_repair.section.duplicates'|trans({}, 'admin') }}
                    {% if dupCache is not null %}
                        <span class="fa-status-pill fa-status-pill--{{ dupTotal > 0 ? 'warning' : 'success' }} ms-2">
                            {{ dupTotal }}
                        </span>
                    {% endif %}
                </h3>
                <div class="d-flex gap-2 align-items-center small text-muted">
                    {% if dupCache is not null %}
                        <span>
                            <i class="fa-icon fa-icon--status-info" aria-hidden="true"></i>
                            {{ 'admin.data_repair.section.scanned_ago'|trans({'%when%': dupCache.completed_at|date('Y-m-d H:i')}, 'admin') }}
                        </span>
                    {% endif %}
                    <form method="post" action="{{ path('admin_data_repair_duplicates_refresh') }}" class="d-inline-block m-0">
                        <input type="hidden" name="_token" value="{{ csrf_token('refresh_section_duplicates') }}">
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                            <i class="fa-icon fa-icon--arrow-repeat" aria-hidden="true"></i>
                            {{ 'admin.data_repair.section.refresh_now'|trans({}, 'admin') }}
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <div class="fa-section__body">
            {% if dupCache is null %}
                {{ _fa_alert.render({
                    variant: 'info',
                    body: 'admin.data_repair.inventory.never_scanned'|trans({}, 'admin'),
                }) }}
            {% elseif dupTotal == 0 %}
                {{ _fa_alert.render({
                    variant: 'success',
                    body: 'admin.data_repair.duplicates.all_ok'|trans({}, 'admin'),
                }) }}
            {% else %}
                {% set dupPreview = dupCache.payload.preview_by_type|default({}) %}
                {% set dupGroups = dupCache.payload.groups_by_type|default({}) %}
                <p class="small text-muted mb-3">
                    {{ 'admin.data_repair.section.duplicates_summary'|trans({
                        '%groups%': dupTotal,
                        '%types%': dupGroups|length,
                    }, 'admin') }}
                </p>
                <div class="fa-table-wrap">
                    <table class="fa-table fa-table--compact fa-table--hover">
                        <thead class="fa-table__head"><tr>
                            <th scope="col" class="fa-table__th">{{ 'admin.data_repair.inventory.col_type'|trans({}, 'admin') }}</th>
                            <th scope="col" class="fa-table__th">{{ 'admin.data_repair.inventory.col_group'|trans({}, 'admin') }}</th>
                            <th scope="col" class="fa-table__th">{{ 'admin.data_repair.inventory.col_count'|trans({}, 'admin') }}</th>
                        </tr></thead>
                        <tbody class="fa-table__body">
                            {% set rowsShown = 0 %}
                            {% set maxRows = 15 %}
                            {% for typeKey, groups in dupPreview %}
                                {% for grp in groups %}
                                    {% if rowsShown < maxRows %}
                                        <tr class="fa-table__row">
                                            <td class="fa-table__cell">
                                                <span class="fa-status-pill fa-status-pill--neutral">{{ typeKey|replace({'_': ' '})|title }}</span>
                                            </td>
                                            <td class="fa-table__cell">{{ grp.label ?? '—' }}</td>
                                            <td class="fa-table__cell">
                                                <span class="fa-status-pill fa-status-pill--warning">{{ grp.count ?? 0 }}</span>
                                            </td>
                                        </tr>
                                        {% set rowsShown = rowsShown + 1 %}
                                    {% endif %}
                                {% endfor %}
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% if dupTotal > rowsShown %}
                    <p class="small text-muted mt-2 mb-0">
                        {{ 'admin.data_repair.inventory.more_groups'|trans({'%count%': dupTotal - rowsShown}, 'admin') }}
                    </p>
                {% endif %}
                <div class="mt-3">
                    <a href="{{ path('admin_data_repair_duplicates_index') }}" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--sm">
                        <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                        {{ 'admin.data_repair.inventory.show_all'|trans({}, 'admin') }}
                    </a>
                </div>
            {% endif %}
        </div>
    </section>

    {# Broken-references inventory card #}
    <section class="fa-section mb-4 {{ brCache is null ? 'border-primary' : (brTotal > 0 ? 'border-danger' : 'border-success') }}">
        <div class="fa-section__header">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                <h3 class="mb-0 fs-5">
                    <i class="fa-icon fa-icon--ui-link" aria-hidden="true"></i>
                    {{ 'admin.data_repair.section.broken_references'|trans({}, 'admin') }}
                    {% if brCache is not null %}
                        <span class="fa-status-pill fa-status-pill--{{ brTotal > 0 ? 'danger' : 'success' }} ms-2">
                            {{ brTotal }}
                        </span>
                    {% endif %}
                </h3>
                <div class="d-flex gap-2 align-items-center small text-muted">
                    {% if brCache is not null %}
                        <span>
                            <i class="fa-icon fa-icon--status-info" aria-hidden="true"></i>
                            {{ 'admin.data_repair.section.scanned_ago'|trans({'%when%': brCache.completed_at|date('Y-m-d H:i')}, 'admin') }}
                        </span>
                    {% endif %}
                    <form method="post" action="{{ path('admin_data_repair_broken_refs_refresh') }}" class="d-inline-block m-0">
                        <input type="hidden" name="_token" value="{{ csrf_token('refresh_section_broken_refs') }}">
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                            <i class="fa-icon fa-icon--arrow-repeat" aria-hidden="true"></i>
                            {{ 'admin.data_repair.section.refresh_now'|trans({}, 'admin') }}
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <div class="fa-section__body">
            {% if brCache is null %}
                {{ _fa_alert.render({
                    variant: 'info',
                    body: 'admin.data_repair.inventory.never_scanned'|trans({}, 'admin'),
                }) }}
            {% elseif brTotal == 0 %}
                {{ _fa_alert.render({
                    variant: 'success',
                    body: 'admin.data_repair.section.no_broken_refs'|trans({}, 'admin'),
                }) }}
            {% else %}
                {% set brokenTotal = brCache.payload.broken_total|default(0) %}
                {% set cascadeTotal = brCache.payload.cascade_total|default(0) %}
                {% set uploadsTotal = brCache.payload.uploads_total|default(0) %}
                <p class="small text-muted mb-3">
                    {{ 'admin.data_repair.section.broken_refs_summary'|trans({
                        '%broken%': brokenTotal,
                        '%cascade%': cascadeTotal,
                        '%uploads%': uploadsTotal,
                    }, 'admin') }}
                </p>

                {% set brokenByBucket = brCache.payload.broken_by_bucket|default({}) %}
                {% set cascadeByBucket = brCache.payload.cascade_by_bucket|default({}) %}
                <div class="row g-3">
                    {% if brokenByBucket|length > 0 %}
                        <div class="col-md-6">
                            <h4 class="fs-6 mb-2">{{ 'admin.data_repair.inventory.broken_refs_header'|trans({}, 'admin') }}</h4>
                            <ul class="list-unstyled small mb-0">
                                {% for bucket, count in brokenByBucket %}
                                    <li class="mb-1">
                                        <span class="fa-status-pill fa-status-pill--danger">{{ count }}</span>
                                        {{ bucket|replace({'_': ' '})|title }}
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}
                    {% if cascadeByBucket|length > 0 %}
                        <div class="col-md-6">
                            <h4 class="fs-6 mb-2">{{ 'admin.data_repair.inventory.cascade_orphans_header'|trans({}, 'admin') }}</h4>
                            <ul class="list-unstyled small mb-0">
                                {% for bucket, count in cascadeByBucket %}
                                    <li class="mb-1">
                                        <span class="fa-status-pill fa-status-pill--warning">{{ count }}</span>
                                        {{ bucket|replace({'_': ' '})|title }}
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}
                </div>
                {% if uploadsTotal > 0 %}
                    <p class="small text-muted mt-3 mb-0">
                        <i class="fa-icon fa-icon--nav-hdd" aria-hidden="true"></i>
                        {{ 'admin.data_repair.inventory.orphaned_uploads_summary'|trans({'%count%': uploadsTotal}, 'admin') }}
                    </p>
                {% endif %}
                <div class="mt-3">
                    <a href="{{ path('admin_data_repair_broken_refs_index') }}" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--sm">
                        <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                        {{ 'admin.data_repair.inventory.show_all'|trans({}, 'admin') }}
                    </a>
                </div>
            {% endif %}
        </div>
    </section>

    {# Health-issues inventory card #}
    <section class="fa-section mb-4 {{ healthCache is null ? 'border-primary' : (healthTotal > 0 ? 'border-warning' : 'border-success') }}">
        <div class="fa-section__header">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                <h3 class="mb-0 fs-5">
                    <i class="fa-icon fa-icon--nav-heart-pulse" aria-hidden="true"></i>
                    {{ 'admin.data_repair.section.health'|trans({}, 'admin') }}
                    {% if healthCache is not null %}
                        <span class="fa-status-pill fa-status-pill--{{ healthTotal > 0 ? 'warning' : 'success' }} ms-2">
                            {{ healthTotal }}
                        </span>
                    {% endif %}
                </h3>
                <div class="d-flex gap-2 align-items-center small text-muted">
                    {% if healthCache is not null %}
                        <span>
                            <i class="fa-icon fa-icon--status-info" aria-hidden="true"></i>
                            {{ 'admin.data_repair.section.scanned_ago'|trans({'%when%': healthCache.completed_at|date('Y-m-d H:i')}, 'admin') }}
                        </span>
                    {% endif %}
                    <form method="post" action="{{ path('admin_data_repair_health_refresh') }}" class="d-inline-block m-0">
                        <input type="hidden" name="_token" value="{{ csrf_token('refresh_section_health') }}">
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                            <i class="fa-icon fa-icon--arrow-repeat" aria-hidden="true"></i>
                            {{ 'admin.data_repair.section.refresh_now'|trans({}, 'admin') }}
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <div class="fa-section__body">
            {% if healthCache is null %}
                {{ _fa_alert.render({
                    variant: 'info',
                    body: 'admin.data_repair.inventory.never_scanned'|trans({}, 'admin'),
                }) }}
            {% elseif healthTotal == 0 %}
                {{ _fa_alert.render({
                    variant: 'success',
                    body: 'admin.data_repair.section.health_all_ok'|trans({}, 'admin'),
                }) }}
            {% else %}
                {% set healthBuckets = healthCache.payload.buckets|default({}) %}
                <div class="row g-3">
                    {% for bucketKey, bucket in healthBuckets %}
                        {% if (bucket.total|default(0)) > 0 %}
                            <div class="col-md-6 col-lg-3">
                                <div class="fa-section h-100 border-warning">
                                    <div class="fa-section__header">
                                        <h4 class="mb-0 fs-6">
                                            {{ bucketKey|replace({'_': ' '})|title }}
                                            <span class="fa-status-pill fa-status-pill--warning ms-1">{{ bucket.total }}</span>
                                        </h4>
                                    </div>
                                    <div class="fa-section__body">
                                        {% set byCheck = bucket.by_check|default({}) %}
                                        <ul class="list-unstyled small mb-0">
                                            {% for checkKey, count in byCheck %}
                                                <li class="mb-1">
                                                    <span class="fa-status-pill fa-status-pill--neutral">{{ count }}</span>
                                                    {{ checkKey|replace({'_': ' '})|title }}
                                                </li>
                                            {% endfor %}
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
                <div class="mt-3">
                    <a href="{{ path('admin_data_repair_health_index') }}" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--sm">
                        <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                        {{ 'admin.data_repair.inventory.show_all'|trans({}, 'admin') }}
                    </a>
                </div>
            {% endif %}
        </div>
    </section>

    {{ _fa_alert.render({
        variant: 'info',
        class: 'mt-3',
        body: '<strong>' ~ 'common.note'|trans({}, 'messages') ~ ':</strong> ' ~ 'admin.data_repair.section.tip'|trans({}, 'admin'),
    }) }}
</div>
{% endblock %}
