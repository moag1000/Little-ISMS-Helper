{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block admin_title %}{{ 'admin.tour_content.title'|trans({}, 'admin') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item active" aria-current="page">{{ 'admin.tour_content.title'|trans({}, 'admin') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'compass', label: 'Tour Content' },
        title: 'admin.tour_content.title'|trans({}, 'admin'),
        subtitle: 'admin.tour_content.description'|trans({}, 'admin'),
    }) }}

    {% if scope_tenant %}
        {% set _scopeBody %}
            {{ 'admin.tour_content.scope_tenant_hint'|trans({'%tenant%': scope_tenant.name}, 'admin') }}
            {% if can_set_global %}
                <br>
                <span class="small">{{ 'admin.tour_content.global_hint'|trans({}, 'admin') }}</span>
            {% endif %}
        {% endset %}
        {{ _fa_alert.render({ variant: 'info', class: 'small', body: _scopeBody }) }}
    {% endif %}

    <div class="row g-3">
        {% for tour in tours %}
            {% set count = override_counts[tour.id]|default(0) %}
            <div class="col-md-6 col-lg-4">
                <a href="{{ path('admin_tour_content_edit', {tourId: tour.id}) }}"
                   class="text-decoration-none">
                    <section class="fa-section h-100{{ count > 0 ? ' border-primary' : '' }}">
                        <div class="fa-section__body">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h3 class="h6 mb-1">
                                        <i class="fa-icon fa-icon--nav-stars" aria-hidden="true"></i>
                                        {{ ('guided_tour.' ~ tour.id ~ '.meta.label')|trans({}, 'guided_tour') }}
                                    </h3>
                                    <div class="small text-muted">
                                        {{ tour.step_count }} {{ 'admin.tour_content.steps'|trans({}, 'admin') }}
                                        · {{ tour.duration_min }} min
                                    </div>
                                </div>
                                {% if count > 0 %}
                                    <span class="badge text-bg-primary">{{ count }}</span>
                                {% endif %}
                            </div>
                            <p class="small text-body mt-2 mb-0">
                                {{ ('guided_tour.' ~ tour.id ~ '.meta.description')|trans({}, 'guided_tour') }}
                            </p>
                        </div>
                    </section>
                </a>
            </div>
        {% endfor %}
    </div>
{% endblock %}
