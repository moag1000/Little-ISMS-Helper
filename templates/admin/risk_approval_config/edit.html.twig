{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block admin_title %}{{ 'risk_approval_config.title'|trans({}, 'risk_approval_config') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item active" aria-current="page">{{ 'risk_approval_config.title'|trans({}, 'risk_approval_config') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'check2-circle', label: 'Risk Approval' },
        title: 'risk_approval_config.title'|trans({}, 'risk_approval_config'),
        subtitle: 'risk_approval_config.subtitle'|trans({}, 'risk_approval_config'),
    }) }}

    <div class="row">
        <div class="col-lg-8">
            <section class="fa-section mb-4">
                <div class="fa-section__header">
                    <h2 class="fa-section__title">
                        <i class="fa-icon fa-icon--ui-settings" aria-hidden="true"></i>
                        {{ 'risk_approval_config.section.thresholds'|trans({}, 'risk_approval_config') }}
                    </h2>
                </div>
                <div class="fa-section__body">
                    {{ form_start(form) }}
                        {{ form_row(form.thresholdAutomatic) }}
                        {{ form_row(form.thresholdManager) }}
                        {{ form_row(form.thresholdExecutive) }}
                        {{ form_row(form.note) }}
                        {{ _fa_alert.render({ variant: 'info', class: 'small mb-3', body: 'risk_approval_config.hint.order'|trans({}, 'risk_approval_config') }) }}
                        <div class="d-flex gap-2">
                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                                <i class="fa-icon fa-icon--ui-save" aria-hidden="true"></i>
                                {{ 'common.save'|trans({}, 'messages') }}
                            </button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </section>

            {% if config.updatedAt %}
                <section class="fa-section">
                    <div class="fa-section__header">
                        <h2 class="fa-section__title">
                            <i class="fa-icon fa-icon--nav-calendar-check" aria-hidden="true"></i>
                            {{ 'risk_approval_config.section.last_change'|trans({}, 'risk_approval_config') }}
                        </h2>
                    </div>
                    <div class="fa-section__body">
                        <dl class="row mb-0">
                            <dt class="col-sm-3">{{ 'risk_approval_config.updated_at'|trans({}, 'risk_approval_config') }}</dt>
                            <dd class="col-sm-9">{{ config.updatedAt|date('d.m.Y H:i') }}</dd>
                            {% if config.updatedBy %}
                                <dt class="col-sm-3">{{ 'risk_approval_config.updated_by'|trans({}, 'risk_approval_config') }}</dt>
                                <dd class="col-sm-9">{{ config.updatedBy.email }}</dd>
                            {% endif %}
                            {% if config.note %}
                                <dt class="col-sm-3">{{ 'risk_approval_config.field.note'|trans({}, 'risk_approval_config') }}</dt>
                                <dd class="col-sm-9">{{ config.note }}</dd>
                            {% endif %}
                        </dl>
                    </div>
                </section>
            {% endif %}
        </div>
    </div>
{% endblock %}
