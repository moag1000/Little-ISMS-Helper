{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'kpi_threshold.page.title'|trans({}, 'admin') }}{% endblock %}

{% block admin_content %}
<div class="container-fluid">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'admin.title'|trans({}, 'admin'), url: path('admin_dashboard') },
            { label: 'admin.nav.kpi_thresholds'|trans({}, 'admin') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'speedometer2', label: 'KPI' },
        title: 'kpi_threshold.page.title'|trans({}, 'admin'),
        subtitle: 'kpi_threshold.page.subtitle'|trans({}, 'admin'),
        actions: [
            { label: 'kpi_threshold.action.new'|trans({}, 'admin'), variant: 'primary', icon: 'plus-lg', href: path('admin_kpi_threshold_new') }
        ]
    }) }}

    <section class="fa-section">
        <div class="fa-section__body p-0">
            {% if configs is empty %}
                {{ _fa_alert.render({ variant: 'info', icon: 'bi-info-circle', class: 'm-3', body: 'kpi_threshold.message.no_configs'|trans({}, 'admin') }) }}
            {% else %}
                {# V3 W3-UX: migrated to fa-table Aurora pattern #}
                {% embed '_components/_fa_table.html.twig' with { hover: true, sortable: true } %}
                    {% block table_head %}
                        <tr>
                            <th class="fa-table__th fa-table__th--sortable" data-sort-key="kpi_key" tabindex="0" role="columnheader" aria-sort="none" data-action="click->fa-table-sort#sort keydown.enter->fa-table-sort#sort keydown.space->fa-table-sort#sort">{{ 'kpi_threshold.field.kpi_key'|trans({}, 'admin') }}</th>
                            <th class="fa-table__th">{{ 'kpi_threshold.field.good_threshold'|trans({}, 'admin') }}</th>
                            <th class="fa-table__th">{{ 'kpi_threshold.field.warning_threshold'|trans({}, 'admin') }}</th>
                            <th class="fa-table__th fa-table__th--sortable" data-sort-key="updated" tabindex="0" role="columnheader" aria-sort="none" data-action="click->fa-table-sort#sort keydown.enter->fa-table-sort#sort keydown.space->fa-table-sort#sort">{{ 'kpi_threshold.field.updated_at'|trans({}, 'admin') }}</th>
                            <th class="fa-table__th fa-table__th--actions">{{ 'common.actions'|trans({}, 'messages') }}</th>
                        </tr>
                    {% endblock %}
                    {% block table_body %}
                        {% for c in configs %}
                            <tr class="fa-table__row">
                                <td class="fa-table__cell" data-sort-value="{{ c.kpiKey }}">
                                    <code>{{ c.kpiKey }}</code>
                                    <div class="text-muted small">{{ ('kpi_threshold.key.' ~ c.kpiKey)|trans({}, 'admin') }}</div>
                                </td>
                                <td class="fa-table__cell"><span class="fa-status-pill fa-status-pill--success">≥ {{ c.goodThreshold }}</span></td>
                                <td class="fa-table__cell"><span class="fa-status-pill fa-status-pill--warning">≥ {{ c.warningThreshold }}</span></td>
                                <td class="fa-table__cell" data-sort-value="{{ c.updatedAt ? c.updatedAt|date('Y-m-d H:i') : c.createdAt|date('Y-m-d H:i') }}">{{ c.updatedAt ? c.updatedAt|date('Y-m-d H:i') : c.createdAt|date('Y-m-d H:i') }}</td>
                                <td class="fa-table__cell fa-table__cell--actions">
                                    <a href="{{ path('admin_kpi_threshold_edit', {id: c.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                        <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                                    </a>
                                    <form method="post" action="{{ path('admin_kpi_threshold_delete', {id: c.id}) }}" class="d-inline"
                                          data-controller="ui-actions"
                                          data-action="submit->ui-actions#confirm"
                                          data-ui-actions-message-param="{{ 'kpi_threshold.confirm.delete'|trans({}, 'admin') }}"
                                          data-ui-actions-tone-param="danger">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_kth_' ~ c.id) }}">
                                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger fa-cyber-btn--sm">
                                            <i class="fa-icon fa-icon--ui-trash" aria-hidden="true"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            {% endif %}
        </div>
    </section>
</div>
{% endblock %}
