{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'kpi_threshold.page.title'|trans({}, 'admin') }}{% endblock %}

{% block admin_content %}
<div class="container-fluid">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'admin.title'|trans({}, 'admin'), url: path('admin_dashboard') },
            { label: 'admin.nav.kpi_thresholds'|trans({}, 'admin') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'speedometer2', label: 'KPI' },
        title: 'kpi_threshold.page.title'|trans({}, 'admin'),
        subtitle: 'kpi_threshold.page.subtitle'|trans({}, 'admin'),
        actions: [
            { label: 'kpi_threshold.action.new'|trans({}, 'admin'), variant: 'primary', icon: 'plus-lg', href: path('admin_kpi_threshold_new') }
        ]
    }) }}

    <section class="fa-section">
        <div class="fa-section__body p-0">
            {% if configs is empty %}
                {{ _fa_alert.render({ variant: 'info', icon: 'bi-info-circle', class: 'm-3', body: 'kpi_threshold.message.no_configs'|trans({}, 'admin') }) }}
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                        <tr>
                            <th scope="col">{{ 'kpi_threshold.field.kpi_key'|trans({}, 'admin') }}</th>
                            <th scope="col">{{ 'kpi_threshold.field.good_threshold'|trans({}, 'admin') }}</th>
                            <th scope="col">{{ 'kpi_threshold.field.warning_threshold'|trans({}, 'admin') }}</th>
                            <th scope="col">{{ 'kpi_threshold.field.updated_at'|trans({}, 'admin') }}</th>
                            <th scope="col" class="text-end">{{ 'common.actions'|trans({}, 'messages') }}</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for c in configs %}
                            <tr>
                                <td>
                                    <code>{{ c.kpiKey }}</code>
                                    <div class="text-muted small">{{ ('kpi_threshold.key.' ~ c.kpiKey)|trans({}, 'admin') }}</div>
                                </td>
                                <td><span class="badge bg-success fa-status-pill fa-status-pill--success">≥ {{ c.goodThreshold }}</span></td>
                                <td><span class="badge bg-warning-subtle text-warning fa-status-pill fa-status-pill--warning">≥ {{ c.warningThreshold }}</span></td>
                                <td>{{ c.updatedAt ? c.updatedAt|date('Y-m-d H:i') : c.createdAt|date('Y-m-d H:i') }}</td>
                                <td class="text-end">
                                    <a href="{{ path('admin_kpi_threshold_edit', {id: c.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                        <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                                    </a>
                                    <form method="post" action="{{ path('admin_kpi_threshold_delete', {id: c.id}) }}" class="d-inline"
                                          data-controller="ui-actions"
                                          data-action="submit->ui-actions#confirm"
                                          data-ui-actions-message-param="{{ 'kpi_threshold.confirm.delete'|trans({}, 'admin') }}"
                                          data-ui-actions-tone-param="danger">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_kth_' ~ c.id) }}">
                                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger fa-cyber-btn--sm">
                                            <i class="fa-icon fa-icon--ui-trash" aria-hidden="true"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </section>
</div>
{% endblock %}
