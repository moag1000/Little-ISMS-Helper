{{ form_start(form) }}
    <div class="row g-3">
        <div class="col-12">{{ form_row(form.kpiKey) }}</div>
        <div class="col-md-6">{{ form_row(form.goodThreshold) }}</div>
        <div class="col-md-6">{{ form_row(form.warningThreshold) }}</div>
    </div>
    <div class="alert alert-info mt-3 small">
        <i class="bi bi-info-circle" aria-hidden="true"></i>
        {{ 'kpi_threshold.hint.thresholds'|trans({}, 'admin') }}
    </div>
    <div class="mt-4">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-save" aria-hidden="true"></i> {{ 'common.save'|trans({}, 'messages') }}
        </button>
        <a href="{{ path('admin_kpi_threshold_index') }}" class="btn btn-outline-secondary">
            {{ 'common.cancel'|trans({}, 'messages') }}
        </a>
    </div>
{{ form_end(form) }}
