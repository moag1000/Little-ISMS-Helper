{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'admin' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block admin_title %}{{ 'kpi_threshold.page.new'|trans({}, 'admin') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('admin_kpi_threshold_index') }}">{{ 'admin.nav.kpi_thresholds'|trans({}, 'admin') }}</a></li>
    <li class="breadcrumb-item active">{{ 'kpi_threshold.page.new'|trans({}, 'admin') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'nav-dashboard', label: 'KPI' },
        title: 'kpi_threshold.page.new'|trans({}, 'admin'),
        subtitle: 'kpi_threshold.page.subtitle'|trans({}, 'admin'),
    }) }}

    <section class="fa-section">
        <div class="fa-section__header">
            <h2 class="fa-section__title">{{ 'kpi_threshold.page.new'|trans({}, 'admin') }}</h2>
        </div>
        <div class="fa-section__body">
            {% include 'admin/kpi_threshold/_form.html.twig' with {form: form} %}
        </div>
    </section>
{% endblock %}
