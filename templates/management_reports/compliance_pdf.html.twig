{% trans_default_domain 'management_reports' %}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{{ 'management_reports.compliance.title'|trans({}, 'management_reports') }}</title>
    <style>
        body { font-family: 'DejaVu Sans', sans-serif; font-size: 9pt; margin: 0; padding: 15px; }
        .header {
            text-align: center;
            margin-bottom: 20px;
            border-bottom: 3px solid #0ea5e9;
            padding-bottom: 10px;
        }
        .header h1 { color: var(--bg); margin: 0; font-size: 18pt; }
        .header .date { color: #888; font-size: 9pt; margin-top: 3px; }

        .compliance-score {
            text-align: center;
            margin: 20px 0;
            padding: 20px;
            border: 3px solid #cbd5e1;
            border-radius: 10px;
        }
        .compliance-score .number { font-size: 48pt; font-weight: bold; }
        .compliance-score .label { font-size: 12pt; color: #666; }

        .section { margin: 15px 0; page-break-inside: avoid; }
        .section h2 { background: #0ea5e9; color: white; padding: 6px; font-size: 10pt; margin: 0 0 8px 0; }

        table { width: 100%; border-collapse: collapse; margin: 8px 0; }
        th { background: var(--bg); color: var(--primary); padding: 5px; text-align: left; font-size: 8pt; }
        td { padding: 5px; border-bottom: 1px solid #ddd; font-size: 8pt; }
        tr:nth-child(even) { background: var(--bg); }

        .badge { display: inline-block; padding: 2px 5px; border-radius: 3px; font-size: 7pt; font-weight: bold; }
        .badge-success { background: #dcfce7; color: #166534; }
        .badge-warning { background: #fef3c7; color: #92400e; }
        .badge-info { background: #e0f2fe; color: #0369a1; }

        .progress-bar { background: #e5e7eb; height: 15px; border-radius: 8px; overflow: hidden; margin: 5px 0; }
        .progress-fill { height: 100%; border-radius: 8px; }
        .progress-fill.success { background: #16a34a; }
        .progress-fill.warning { background: #d97706; }
        .progress-fill.danger { background: var(--danger); }

        .footer { position: fixed; bottom: 10px; left: 15px; right: 15px; text-align: center; font-size: 7pt; color: #888; border-top: 1px solid #ddd; padding-top: 5px; }
    </style>
</head>
<body>
    <div class="header">
        <h1>{{ 'management_reports.compliance.title'|trans({}, 'management_reports') }}</h1>
        <div class="date">{{ 'management_reports.generated_at'|trans({}, 'management_reports') }}: {{ generated_at|date('d.m.Y H:i') }} | Version: {{ version }}</div>
    </div>

    {# Overall Compliance Score #}
    <div class="compliance-score">
        <div class="number" style="color: {% if report.overall_compliance >= 80 %}#16a34a{% elseif report.overall_compliance >= 60 %}#d97706{% else %}var(--danger){% endif %};">
            {{ report.overall_compliance }}%
        </div>
        <div class="label">{{ 'management_reports.compliance.overall'|trans({}, 'management_reports') }}</div>
        <div class="progress-bar" style="width: 80%; margin: 10px auto;">
            <div class="progress-fill {% if report.overall_compliance >= 80 %}success{% elseif report.overall_compliance >= 60 %}warning{% else %}danger{% endif %}" style="width: {{ report.overall_compliance }}%"></div>
        </div>
    </div>

    {# Control Status #}
    <div class="section">
        <h2>{{ 'management_reports.compliance.control_status'|trans({}, 'management_reports') }}</h2>
        <table>
            <tr>
                <th scope="col">{{ 'management_reports.compliance.header.metric'|trans({}, 'management_reports') }}</th>
                <th scope="col">{{ 'management_reports.compliance.header.count'|trans({}, 'management_reports') }}</th>
                <th scope="col">{{ 'management_reports.compliance.header.percentage'|trans({}, 'management_reports') }}</th>
            </tr>
            <tr>
                <td>{{ 'management_reports.compliance.total'|trans({}, 'management_reports') }}</td>
                <td>{{ report.controls.total }}</td>
                <td>100%</td>
            </tr>
            <tr>
                <td>{{ 'management_reports.compliance.applicable'|trans({}, 'management_reports') }}</td>
                <td>{{ report.controls.applicable }}</td>
                <td>{{ report.controls.total > 0 ? ((report.controls.applicable / report.controls.total) * 100)|round(1) : 0 }}%</td>
            </tr>
            <tr>
                <td>{{ 'management_reports.compliance.implemented'|trans({}, 'management_reports') }}</td>
                <td><span class="badge badge-success">{{ report.controls.implemented }}</span></td>
                <td>{{ report.controls.total > 0 ? ((report.controls.implemented / report.controls.total) * 100)|round(1) : 0 }}%</td>
            </tr>
            <tr>
                <td>{{ 'management_reports.compliance.not_applicable'|trans({}, 'management_reports') }}</td>
                <td><span class="badge badge-info">{{ report.controls.not_applicable }}</span></td>
                <td>{{ report.controls.total > 0 ? ((report.controls.not_applicable / report.controls.total) * 100)|round(1) : 0 }}%</td>
            </tr>
        </table>
    </div>

    {# Frameworks #}
    <div class="section">
        <h2>{{ 'management_reports.compliance.frameworks'|trans({}, 'management_reports') }}</h2>
        <table>
            <tr>
                <th scope="col">{{ 'management_reports.compliance.framework_name'|trans({}, 'management_reports') }}</th>
                <th scope="col">{{ 'management_reports.compliance.framework_code'|trans({}, 'management_reports') }}</th>
                <th scope="col">{{ 'management_reports.compliance.framework_status'|trans({}, 'management_reports') }}</th>
            </tr>
            {% for framework in report.frameworks %}
            <tr>
                <td>{{ framework.name }}</td>
                <td><code>{{ framework.code }}</code></td>
                <td>
                    {% if framework.active %}
                    <span class="badge badge-success">{{ 'management_reports.compliance.active'|trans({}, 'management_reports') }}</span>
                    {% else %}
                    <span class="badge badge-warning">{{ 'management_reports.compliance.inactive'|trans({}, 'management_reports') }}</span>
                    {% endif %}
                </td>
            </tr>
            {% endfor %}
        </table>
        <p style="font-size: 8pt; color: #666; margin-top: 5px;">
            {{ 'management_reports.compliance.active_frameworks'|trans({}, 'management_reports') }}: {{ report.active_frameworks }} / {{ report.frameworks|length }}
        </p>
    </div>

    {# Compliance Status Assessment #}
    <div class="section">
        <h2>{{ 'management_reports.compliance.assessment_title'|trans({}, 'management_reports') }}</h2>
        {% if report.overall_compliance >= 80 %}
        <div style="background: #dcfce7; padding: 10px; border-radius: 5px; border: 1px solid #86efac;">
            <strong style="color: #166534;">{{ 'management_reports.compliance.good_standing'|trans({}, 'management_reports') }}</strong>
            <p style="margin: 5px 0 0; font-size: 8pt; color: #166534;">
                {{ 'management_reports.compliance.good_standing_text'|trans({}, 'management_reports') }}
            </p>
        </div>
        {% elseif report.overall_compliance >= 60 %}
        <div style="background: #fef3c7; padding: 10px; border-radius: 5px; border: 1px solid #fcd34d;">
            <strong style="color: #92400e;">{{ 'management_reports.compliance.improvement_needed'|trans({}, 'management_reports') }}</strong>
            <p style="margin: 5px 0 0; font-size: 8pt; color: #92400e;">
                {{ 'management_reports.compliance.improvement_text_detail'|trans({}, 'management_reports') }}
            </p>
        </div>
        {% else %}
        <div style="background: #fecaca; padding: 10px; border-radius: 5px; border: 1px solid var(--danger);">
            <strong style="color: #991b1b;">{{ 'management_reports.compliance.immediate_action'|trans({}, 'management_reports') }}</strong>
            <p style="margin: 5px 0 0; font-size: 8pt; color: #991b1b;">
                {{ 'management_reports.compliance.immediate_action_text'|trans({}, 'management_reports') }}
            </p>
        </div>
        {% endif %}
    </div>

    {# Recommendations #}
    <div class="section">
        <h2>{{ 'management_reports.compliance.recommendations_title'|trans({}, 'management_reports') }}</h2>
        <table>
            <tr>
                <th scope="col">{{ 'management_reports.compliance.header.priority'|trans({}, 'management_reports') }}</th>
                <th scope="col">{{ 'management_reports.compliance.header.action'|trans({}, 'management_reports') }}</th>
            </tr>
            <tr>
                <td><span class="badge badge-success">{{ 'management_reports.compliance.priority.high'|trans({}, 'management_reports') }}</span></td>
                <td>{{ 'management_reports.compliance.tip_1'|trans({}, 'management_reports') }}</td>
            </tr>
            <tr>
                <td><span class="badge badge-warning">{{ 'management_reports.compliance.priority.medium'|trans({}, 'management_reports') }}</span></td>
                <td>{{ 'management_reports.compliance.tip_2'|trans({}, 'management_reports') }}</td>
            </tr>
            <tr>
                <td><span class="badge badge-info">{{ 'management_reports.compliance.priority.low'|trans({}, 'management_reports') }}</span></td>
                <td>{{ 'management_reports.compliance.tip_3'|trans({}, 'management_reports') }}</td>
            </tr>
        </table>
    </div>

    <div class="footer">
        {{ 'management_reports.compliance.footer'|trans({}, 'management_reports') }}
    </div>
</body>
</html>
