{% trans_default_domain 'management_reports' %}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{{ 'management_reports.executive.title'|trans({}, 'management_reports') }}</title>
    <style>
        body { font-family: 'DejaVu Sans', sans-serif; font-size: 10pt; margin: 0; padding: 20px; }
        .header {
            text-align: center;
            margin-bottom: 25px;
            border-bottom: 3px solid transparent;
            border-image: linear-gradient(90deg, var(--primary) 0%, var(--accent) 50%, var(--accent) 100%) 1;
            padding-bottom: 10px;
        }
        .header h1 { color: var(--bg); margin: 0; font-size: 20pt; text-transform: uppercase; letter-spacing: 0.5pt; }
        .header .subtitle { color: #666; font-size: 10pt; margin-top: 3px; }
        .header .date { color: #888; font-size: 9pt; margin-top: 3px; }

        .stats-grid { display: table; width: 100%; margin: 15px 0; }
        .stat-box {
            display: table-cell;
            width: 25%;
            padding: 10px;
            border: 1px solid #cbd5e1;
            text-align: center;
            background: linear-gradient(135deg, var(--bg) 0%, var(--surface-2) 100%);
        }
        .stat-box .number { font-size: 24pt; font-weight: bold; color: var(--primary); }
        .stat-box .number.danger { color: var(--danger); }
        .stat-box .number.success { color: #16a34a; }
        .stat-box .number.warning { color: #d97706; }
        .stat-box .label { font-size: 8pt; color: var(--bg); text-transform: uppercase; font-weight: bold; letter-spacing: 0.3pt; }

        .section { margin: 20px 0; page-break-inside: avoid; }
        .section h2 {
            background: linear-gradient(90deg, var(--bg) 0%, var(--surface) 100%);
            color: var(--primary);
            padding: 8px;
            font-size: 11pt;
            margin: 0 0 10px 0;
            text-transform: uppercase;
            letter-spacing: 0.3pt;
        }

        table { width: 100%; border-collapse: collapse; margin: 10px 0; }
        th {
            background: var(--bg);
            color: var(--primary);
            padding: 6px;
            text-align: left;
            font-size: 9pt;
            text-transform: uppercase;
        }
        td { padding: 6px; border-bottom: 1px solid #ddd; font-size: 9pt; }
        tr:nth-child(even) { background: var(--bg); }

        .progress-bar { background: #e5e7eb; height: 12px; border-radius: 6px; overflow: hidden; margin: 3px 0; }
        .progress-fill { height: 100%; border-radius: 6px; }
        .progress-fill.danger { background: var(--danger); }
        .progress-fill.warning { background: #d97706; }
        .progress-fill.info { background: #0ea5e9; }
        .progress-fill.success { background: #16a34a; }

        .badge { display: inline-block; padding: 2px 6px; border-radius: 3px; font-size: 8pt; font-weight: bold; }
        .badge-danger { background: #fecaca; color: #991b1b; }
        .badge-warning { background: #fef3c7; color: #92400e; }
        .badge-info { background: #e0f2fe; color: #0369a1; }
        .badge-success { background: #dcfce7; color: #166534; }

        .footer { position: fixed; bottom: 15px; left: 20px; right: 20px; text-align: center; font-size: 8pt; color: #888; border-top: 1px solid #ddd; padding-top: 8px; }
        .page-break { page-break-after: always; }
    </style>
</head>
<body>
    <div class="header">
        <h1>{{ 'management_reports.executive.title'|trans({}, 'management_reports') }}</h1>
        <div class="subtitle">{{ 'management_reports.executive.subtitle'|trans({}, 'management_reports') }}</div>
        <div class="date">{{ 'management_reports.generated_at'|trans({}, 'management_reports') }}: {{ generated_at|date('d.m.Y H:i') }} | Version: {{ version }}</div>
    </div>

    {# Key Metrics #}
    <div class="stats-grid">
        <div class="stat-box">
            <div class="number">{{ summary.summary.total_assets }}</div>
            <div class="label">{{ 'management_reports.executive.assets'|trans({}, 'management_reports') }}</div>
        </div>
        <div class="stat-box">
            <div class="number">{{ summary.summary.total_risks }}</div>
            <div class="label">{{ 'management_reports.executive.risks'|trans({}, 'management_reports') }}</div>
        </div>
        <div class="stat-box">
            <div class="number success">{{ summary.summary.compliance_percentage }}%</div>
            <div class="label">{{ 'management_reports.executive.compliance'|trans({}, 'management_reports') }}</div>
        </div>
        <div class="stat-box">
            <div class="number">{{ summary.summary.total_controls }}</div>
            <div class="label">{{ 'management_reports.executive.controls'|trans({}, 'management_reports') }}</div>
        </div>
    </div>

    {# Risk Distribution #}
    <div class="section">
        <h2>{{ 'management_reports.executive.risk_distribution'|trans({}, 'management_reports') }}</h2>
        <table>
            <tr>
                <th scope="col">{{ 'management_reports.executive.header.level'|trans({}, 'management_reports') }}</th>
                <th scope="col">{{ 'management_reports.executive.header.count'|trans({}, 'management_reports') }}</th>
                <th scope="col">{{ 'management_reports.executive.header.distribution'|trans({}, 'management_reports') }}</th>
            </tr>
            <tr>
                <td><span class="badge badge-danger">{{ 'management_reports.risk_level.critical'|trans({}, 'management_reports') }} (≥20)</span></td>
                <td>{{ summary.risk_distribution.critical }}</td>
                <td>
                    <div class="progress-bar">
                        <div class="progress-fill danger" style="width: {{ summary.summary.total_risks > 0 ? (summary.risk_distribution.critical / summary.summary.total_risks * 100) : 0 }}%"></div>
                    </div>
                </td>
            </tr>
            <tr>
                <td><span class="badge badge-warning">{{ 'management_reports.risk_level.high'|trans({}, 'management_reports') }} (12-19)</span></td>
                <td>{{ summary.risk_distribution.high }}</td>
                <td>
                    <div class="progress-bar">
                        <div class="progress-fill warning" style="width: {{ summary.summary.total_risks > 0 ? (summary.risk_distribution.high / summary.summary.total_risks * 100) : 0 }}%"></div>
                    </div>
                </td>
            </tr>
            <tr>
                <td><span class="badge badge-info">{{ 'management_reports.risk_level.medium'|trans({}, 'management_reports') }} (6-11)</span></td>
                <td>{{ summary.risk_distribution.medium }}</td>
                <td>
                    <div class="progress-bar">
                        <div class="progress-fill info" style="width: {{ summary.summary.total_risks > 0 ? (summary.risk_distribution.medium / summary.summary.total_risks * 100) : 0 }}%"></div>
                    </div>
                </td>
            </tr>
            <tr>
                <td><span class="badge badge-success">{{ 'management_reports.risk_level.low'|trans({}, 'management_reports') }} (&lt;6)</span></td>
                <td>{{ summary.risk_distribution.low }}</td>
                <td>
                    <div class="progress-bar">
                        <div class="progress-fill success" style="width: {{ summary.summary.total_risks > 0 ? (summary.risk_distribution.low / summary.summary.total_risks * 100) : 0 }}%"></div>
                    </div>
                </td>
            </tr>
        </table>
    </div>

    {# Control Implementation Status #}
    <div class="section">
        <h2>{{ 'management_reports.executive.control_status'|trans({}, 'management_reports') }}</h2>
        <table>
            <tr>
                <th scope="col">{{ 'management_reports.executive.header.status'|trans({}, 'management_reports') }}</th>
                <th scope="col">{{ 'management_reports.executive.header.count'|trans({}, 'management_reports') }}</th>
                <th scope="col">{{ 'management_reports.executive.header.progress'|trans({}, 'management_reports') }}</th>
            </tr>
            <tr>
                <td><span class="badge badge-success">{{ 'management_reports.control_status.implemented'|trans({}, 'management_reports') }}</span></td>
                <td>{{ summary.control_status.implemented }}</td>
                <td>
                    <div class="progress-bar">
                        <div class="progress-fill success" style="width: {{ summary.summary.total_controls > 0 ? (summary.control_status.implemented / summary.summary.total_controls * 100) : 0 }}%"></div>
                    </div>
                </td>
            </tr>
            <tr>
                <td><span class="badge badge-warning">{{ 'management_reports.control_status.in_progress'|trans({}, 'management_reports') }}</span></td>
                <td>{{ summary.control_status.in_progress }}</td>
                <td>
                    <div class="progress-bar">
                        <div class="progress-fill warning" style="width: {{ summary.summary.total_controls > 0 ? (summary.control_status.in_progress / summary.summary.total_controls * 100) : 0 }}%"></div>
                    </div>
                </td>
            </tr>
            <tr>
                <td><span class="badge badge-info">{{ 'management_reports.control_status.not_started'|trans({}, 'management_reports') }}</span></td>
                <td>{{ summary.control_status.not_started }}</td>
                <td>
                    <div class="progress-bar">
                        <div class="progress-fill info" style="width: {{ summary.summary.total_controls > 0 ? (summary.control_status.not_started / summary.summary.total_controls * 100) : 0 }}%"></div>
                    </div>
                </td>
            </tr>
        </table>
    </div>

    {# Operational Metrics #}
    <div class="section">
        <h2>{{ 'management_reports.executive.operational_metrics'|trans({}, 'management_reports') }}</h2>
        <table>
            <tr>
                <th scope="col">{{ 'management_reports.executive.header.metric'|trans({}, 'management_reports') }}</th>
                <th scope="col">{{ 'management_reports.executive.header.value'|trans({}, 'management_reports') }}</th>
                <th scope="col">{{ 'management_reports.executive.header.status'|trans({}, 'management_reports') }}</th>
            </tr>
            <tr>
                <td>{{ 'management_reports.executive.open_incidents_12m'|trans({}, 'management_reports') }}</td>
                <td>{{ summary.incident_summary.open }}</td>
                <td>{% if summary.incident_summary.open > 5 %}<span class="badge badge-warning">{{ 'management_reports.executive.status.attention'|trans({}, 'management_reports') }}</span>{% else %}<span class="badge badge-success">{{ 'management_reports.executive.status.normal'|trans({}, 'management_reports') }}</span>{% endif %}</td>
            </tr>
            <tr>
                <td>{{ 'management_reports.executive.total_incidents_12m'|trans({}, 'management_reports') }}</td>
                <td>{{ summary.incident_summary.total_12_months }}</td>
                <td><span class="badge badge-info">{{ 'management_reports.executive.status.tracked'|trans({}, 'management_reports') }}</span></td>
            </tr>
            <tr>
                <td>{{ 'management_reports.executive.audits_completed'|trans({}, 'management_reports') }}</td>
                <td>{{ summary.audit_summary.completed_this_year }}</td>
                <td>{% if summary.audit_summary.completed_this_year >= 1 %}<span class="badge badge-success">{{ 'management_reports.audit.compliant'|trans({}, 'management_reports') }}</span>{% else %}<span class="badge badge-warning">{{ 'management_reports.audit.pending'|trans({}, 'management_reports') }}</span>{% endif %}</td>
            </tr>
            <tr>
                <td>{{ 'management_reports.executive.total_trainings'|trans({}, 'management_reports') }}</td>
                <td>{{ summary.training_summary.total_trainings }}</td>
                <td><span class="badge badge-success">{{ 'management_reports.executive.status.active'|trans({}, 'management_reports') }}</span></td>
            </tr>
        </table>
    </div>

    {# Trend Data #}
    {% if risk_trends|length > 0 %}
    <div class="section">
        <h2>{{ 'management_reports.executive.risk_trends'|trans({}, 'management_reports') }}</h2>
        <table>
            <tr>
                <th scope="col">{{ 'management_reports.trend.month'|trans({}, 'management_reports') }}</th>
                <th scope="col">{{ 'management_reports.trend.total_risks'|trans({}, 'management_reports') }}</th>
                <th scope="col">{{ 'management_reports.trend.high_critical'|trans({}, 'management_reports') }}</th>
                <th scope="col">{{ 'management_reports.trend.new_risks'|trans({}, 'management_reports') }}</th>
            </tr>
            {% for trend in risk_trends %}
            <tr>
                <td>{{ trend.month_name }}</td>
                <td><strong>{{ trend.total }}</strong></td>
                <td>{% if trend.high_critical > 0 %}<span class="badge badge-danger">{{ trend.high_critical }}</span>{% else %}<span class="badge badge-success">0</span>{% endif %}</td>
                <td>{{ trend.new_risks }}</td>
            </tr>
            {% endfor %}
        </table>
    </div>
    {% endif %}

    <div class="footer">
        {{ 'management_reports.executive.footer'|trans({}, 'management_reports') }}
    </div>
</body>
</html>
