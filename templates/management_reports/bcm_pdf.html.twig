{# ─────────────────────────────────────────────────────────────────────────
   BCM Report PDF — fa-report-doc 5-slot macro
   Audience: internal (ISB / BCM Officer)
   Status:   final (ISO 22301 evidence)
   ─────────────────────────────────────────────────────────────────────── #}
<!DOCTYPE html>
<html lang="{{ app.request.locale|default('de') }}">
<head>
    <meta charset="UTF-8">
    <title>{{ 'management_reports.bcm.title'|trans({}, 'management_reports') }}</title>
    <style>
        :root {
            --surface:#ffffff;--surface-2:#f6f6fa;--border:#dfe3f0;--border-strong:#b9bfd6;
            --fg-1:#0e0a1f;--fg-2:#4c4a73;--fg-3:#6d6b92;
            --primary:#0284c7;--primary-strong:#0369a1;--primary-tint:rgba(2,132,199,.10);
            --accent-tint:rgba(124,58,237,.10);--accent-strong:#6d28d9;
            --success:#059669;--success-strong:#047857;--success-tint:rgba(5,150,105,.10);
            --warning:#d97706;--warning-strong:#b45309;
            --danger:#dc2626;--danger-strong:#b91c1c;
        }
        @page{size:A4 portrait;margin:14mm 12mm 18mm 12mm;}
        body{background:#fff;font-family:'DejaVu Sans',sans-serif;margin:0;padding:0;}
        .report-doc{background:var(--surface);color:var(--fg-1);font-size:9pt;line-height:1.45;max-width:none;margin:0;border:0;border-radius:0;}
        .report-doc__cover{padding:16pt 14pt 12pt;border-bottom:1px solid var(--border);}
        .report-doc__cover-top{display:table;width:100%;}
        .report-doc__brand{display:table-cell;vertical-align:middle;}
        .report-doc__chips{display:table-cell;text-align:right;vertical-align:middle;}
        .report-doc__logo{display:inline-block;width:28pt;height:28pt;border-radius:5pt;background:var(--primary);color:#fff;text-align:center;line-height:28pt;font-weight:700;font-size:16pt;vertical-align:middle;margin-right:6pt;}
        .report-doc__brand-name{font-weight:700;font-size:10pt;color:var(--fg-1);display:inline-block;vertical-align:middle;}
        .report-doc__brand-meta{font-size:7pt;color:var(--fg-3);}
        .report-doc__chip{display:inline-block;padding:2pt 6pt;border-radius:8pt;background:var(--surface-2);color:var(--fg-2);font-size:6pt;font-weight:700;text-transform:uppercase;letter-spacing:.06em;border:1px solid var(--border);margin-left:3pt;}
        .report-doc__chip--status-final{background:var(--success-tint);color:var(--success-strong);border-color:transparent;}
        .report-doc__chip--audience-internal{background:var(--accent-tint);color:var(--accent-strong);border-color:transparent;}
        .report-doc__cover-center{padding:14pt 0 10pt;}
        .report-doc__kicker{font-size:7pt;color:var(--primary);font-weight:700;letter-spacing:.12em;text-transform:uppercase;margin:0 0 4pt;}
        .report-doc__title{font-size:18pt;font-weight:800;color:var(--fg-1);margin:0 0 6pt;line-height:1.1;}
        .report-doc__sub{font-size:9pt;color:var(--fg-2);margin:0;}
        .report-doc__cover-grid{border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:8pt 0;margin:0;}
        .report-doc__cover-grid>div{display:inline-block;width:31%;margin:0 1% 4pt 0;vertical-align:top;}
        .report-doc__cover-label{font-size:6pt;color:var(--fg-3);text-transform:uppercase;letter-spacing:.08em;font-weight:700;margin:0 0 2pt;}
        .report-doc__cover-value{font-size:8pt;color:var(--fg-1);font-weight:600;margin:0;}
        .report-doc__exec-summary{padding:10pt 14pt;background:var(--surface-2);border-bottom:1px solid var(--border);}
        .report-doc__exec-heading{font-size:11pt;font-weight:800;margin:0 0 8pt;padding-bottom:4pt;border-bottom:2px solid var(--fg-1);}
        .report-doc__kpi-grid{display:table;width:100%;border-spacing:4pt;}
        .report-doc__kpi-tile{display:table-cell;padding:7pt 8pt;border:1px solid var(--border);border-radius:4pt;vertical-align:top;background:var(--surface);}
        .report-doc__kpi-tile--success{border-left:2pt solid var(--success);}
        .report-doc__kpi-tile--warning{border-left:2pt solid var(--warning);}
        .report-doc__kpi-tile--danger{border-left:2pt solid var(--danger);}
        .report-doc__kpi-tile--neutral{border-left:2pt solid var(--primary);}
        .report-doc__kpi-label{font-size:6pt;color:var(--fg-3);text-transform:uppercase;letter-spacing:.06em;font-weight:700;margin-bottom:2pt;}
        .report-doc__kpi-value{font-size:14pt;font-weight:800;color:var(--fg-1);}
        .report-doc__tldr{background:var(--surface);border:1px solid var(--border);border-left:3pt solid var(--primary);padding:7pt 10pt;margin:0 0 10pt;}
        .report-doc__tldr-label{font-size:6pt;color:var(--primary-strong);font-weight:700;text-transform:uppercase;letter-spacing:.1em;margin:0 0 5pt;}
        .report-doc__tldr-list{list-style:none;margin:0;padding:0;}
        .report-doc__tldr-item{font-size:8pt;color:var(--fg-1);padding:2pt 0;}
        .report-doc__tldr-item--ok{border-left:2pt solid var(--success);padding-left:6pt;}
        .report-doc__tldr-item--warn{border-left:2pt solid var(--warning);padding-left:6pt;}
        .report-doc__tldr-item--danger{border-left:2pt solid var(--danger);padding-left:6pt;}
        .report-doc__tldr-dot{display:none;}
        .report-doc__data-section{padding:10pt 14pt;border-bottom:1px solid var(--border);page-break-inside:avoid;}
        .report-doc__section-heading{font-size:11pt;font-weight:700;color:var(--fg-1);margin:0 0 6pt;padding-bottom:3pt;border-bottom:2px solid var(--fg-1);}
        .report-doc__section-body{font-size:8pt;color:var(--fg-1);margin:6pt 0;}
        .report-doc__table{width:100%;border-collapse:collapse;font-size:7.5pt;}
        .report-doc__table th{background:var(--surface-2);color:var(--fg-2);padding:4pt 5pt;border:.5pt solid var(--border-strong);font-weight:700;text-transform:uppercase;letter-spacing:.06em;font-size:6pt;text-align:left;}
        .report-doc__table td{padding:4pt 5pt;border:.5pt solid var(--border);color:var(--fg-1);vertical-align:top;}
        .report-doc__table tbody tr:nth-child(even) td{background:var(--surface-2);}
        .report-doc__table-wrap{margin:8pt 0;}
        .report-doc__appendix{padding:10pt 14pt;background:var(--surface-2);border-bottom:1px solid var(--border);}
        .report-doc__appendix-heading{font-size:11pt;font-weight:700;margin:0 0 8pt;padding-bottom:3pt;border-bottom:2px solid var(--fg-1);}
        .report-doc__appendix-subheading{font-size:8pt;font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin:7pt 0 3pt;}
        .report-doc__appendix-body{font-size:8pt;color:var(--fg-2);}
        .report-doc__appendix-sources{padding-left:12pt;font-size:7.5pt;color:var(--fg-2);}
        .report-doc__footer-disclaimer{padding:10pt 14pt;background:var(--surface);border-top:1px solid var(--border-strong);}
        .report-doc__distribution-label{font-size:6pt;color:var(--fg-3);text-transform:uppercase;letter-spacing:.08em;font-weight:700;margin:0 0 3pt;}
        .report-doc__distribution-list{list-style:none;padding:0;margin:0 0 6pt;font-size:8pt;color:var(--fg-2);}
        .report-doc__distribution-list li{display:inline-block;border-left:2pt solid var(--border);padding:0 7pt;}
        .report-doc__disclaimer-text{font-size:7pt;color:var(--fg-3);padding:6pt;background:var(--surface-2);border:1px solid var(--border);border-radius:3pt;margin:0 0 6pt;}
        .report-doc__footer-meta{font-size:6pt;color:var(--fg-3);}
        .report-doc__footer-brand{font-weight:700;color:var(--fg-2);}
        .badge{display:inline-block;padding:1pt 4pt;border-radius:3pt;font-size:6.5pt;font-weight:700;}
        .badge-success{background:var(--success-tint);color:var(--success-strong);}
        .badge-warning{background:rgba(217,119,6,.12);color:var(--warning-strong);}
        .badge-danger{background:rgba(220,38,38,.12);color:var(--danger-strong);}
        .badge-info{background:var(--primary-tint);color:var(--primary-strong);}
    </style>
</head>
<body>
{% import '_components/_fa_report_doc.html.twig' as _fa_report_doc %}

{% set _exercises_compliant = report.exercises.last_12_months >= 2 %}
{% set _exercises_status = _exercises_compliant ? 'badge-success' : (report.exercises.last_12_months >= 1 ? 'badge-warning' : 'badge-danger') %}
{% set _exercises_label = _exercises_compliant
    ? ('management_reports.bcm.iso22301_compliant'|trans({}, 'management_reports'))
    : (report.exercises.last_12_months >= 1
        ? ('management_reports.bcm.minimum_met'|trans({}, 'management_reports'))
        : ('management_reports.bcm.non_compliant'|trans({}, 'management_reports'))) %}

{% set _exercise_rows = [
    [ 'management_reports.bcm.total_exercises'|trans({}, 'management_reports'), report.exercises.total, '-' ],
    [ 'management_reports.bcm.exercises_12m'|trans({}, 'management_reports'),
      report.exercises.last_12_months,
      '<span class="badge ' ~ _exercises_status ~ '">' ~ _exercises_label ~ '</span>' ],
] %}

{% set _process_rows = [
    [ 'management_reports.bcm.total_processes'|trans({}, 'management_reports'), report.business_processes.total ],
    [ 'management_reports.bcm.critical_processes'|trans({}, 'management_reports'),
      '<span class="badge badge-danger">' ~ report.business_processes.critical ~ '</span>' ],
] %}

{% set _bia_rows = [
    [ '<span class="badge badge-danger">' ~ ('management_reports.criticality.critical'|trans({}, 'management_reports')) ~ '</span>', bia.by_criticality.critical ],
    [ '<span class="badge badge-warning">' ~ ('management_reports.criticality.high'|trans({}, 'management_reports')) ~ '</span>',    bia.by_criticality.high ],
    [ '<span class="badge badge-info">' ~ ('management_reports.criticality.medium'|trans({}, 'management_reports')) ~ '</span>',    bia.by_criticality.medium ],
    [ '<span class="badge badge-success">' ~ ('management_reports.criticality.low'|trans({}, 'management_reports')) ~ '</span>',   bia.by_criticality.low ],
] %}

{{ _fa_report_doc.render({
    report: {
        title:        'management_reports.bcm.full_title'|trans({}, 'management_reports'),
        kicker:       'ISO 22301 · Business Continuity',
        status:       'final',
        audience:     'internal',
        generated_at: generated_at|date('d.m.Y H:i'),
        prepared_by:  version,
    },
    brand_name: 'Little ISMS Helper',
    key_findings: [
        { label: ('management_reports.bcm.total_plans'|trans({}, 'management_reports')) ~ ': ' ~ report.bc_plans.total, tone: 'ok' },
        { label: ('management_reports.bcm.active_plans'|trans({}, 'management_reports')) ~ ': ' ~ report.bc_plans.active, tone: 'ok' },
        { label: ('management_reports.bcm.exercises_12m'|trans({}, 'management_reports')) ~ ': ' ~ report.exercises.last_12_months,
          tone: _exercises_compliant ? 'ok' : (report.exercises.last_12_months >= 1 ? 'warn' : 'danger') },
        { label: ('management_reports.bcm.critical_processes'|trans({}, 'management_reports')) ~ ': ' ~ report.business_processes.critical,
          tone: report.business_processes.critical > 0 ? 'warn' : 'ok' },
    ],
    kpis: [
        { label: 'management_reports.bcm.total_plans'|trans({}, 'management_reports'),    value: report.bc_plans.total,   tone: 'neutral' },
        { label: 'management_reports.bcm.active_plans'|trans({}, 'management_reports'),   value: report.bc_plans.active,  tone: report.bc_plans.active > 0 ? 'success' : 'warning' },
        { label: 'management_reports.bcm.exercises_12m'|trans({}, 'management_reports'),  value: report.exercises.last_12_months, tone: _exercises_compliant ? 'success' : 'danger' },
        { label: 'management_reports.bcm.critical_processes'|trans({}, 'management_reports'), value: report.business_processes.critical, tone: report.business_processes.critical > 0 ? 'warning' : 'success' },
    ],
    sections: [
        {
            heading: 'management_reports.bcm.exercises'|trans({}, 'management_reports'),
            table: {
                headers: [
                    'management_reports.bcm.header.metric'|trans({}, 'management_reports'),
                    'management_reports.bcm.header.value'|trans({}, 'management_reports'),
                    'management_reports.bcm.header.status'|trans({}, 'management_reports'),
                ],
                rows: _exercise_rows,
            },
        },
        {
            heading: 'management_reports.bcm.business_processes'|trans({}, 'management_reports'),
            table: {
                headers: [
                    'management_reports.bcm.header.metric'|trans({}, 'management_reports'),
                    'management_reports.bcm.header.value'|trans({}, 'management_reports'),
                ],
                rows: _process_rows,
            },
        },
        {
            heading: 'management_reports.bcm.bia_summary'|trans({}, 'management_reports'),
            table: {
                headers: [
                    'management_reports.bcm.header.criticality'|trans({}, 'management_reports'),
                    'management_reports.bcm.header.count'|trans({}, 'management_reports'),
                ],
                rows: _bia_rows,
            },
        },
    ],
    appendix: {
        methodology: '<p>BCM data sourced from BcPlanRepository, BcExerciseRepository, BusinessProcessRepository, and BIA records. ISO 22301 compliance threshold: ≥2 exercises per 12 months.</p>',
        sources: [
            { label: 'BcPlanRepository', detail: 'findByTenant() — all BC plans' },
            { label: 'BcExerciseRepository', detail: 'findByTenant() — exercises last 12 months' },
            { label: 'BusinessProcessRepository', detail: 'findByTenant() — with criticality' },
        ],
        glossary: [
            { term: 'RTO',        definition: 'Recovery Time Objective — maximum tolerable downtime' },
            { term: 'RPO',        definition: 'Recovery Point Objective — maximum tolerable data loss' },
            { term: 'BIA',        definition: 'Business Impact Analysis — assessment of process criticality' },
            { term: 'ISO 22301',  definition: 'International standard for Business Continuity Management Systems' },
        ],
    },
    distribution: [
        { role: 'BCM Officer', name: '—' },
        { role: 'CISO',        name: '—' },
    ],
}) }}
</body>
</html>
