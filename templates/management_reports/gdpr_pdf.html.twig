{% trans_default_domain 'management_reports' %}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{{ 'management_reports.gdpr.title'|trans({}, 'management_reports') }}</title>
    <style>
        body { font-family: 'DejaVu Sans', sans-serif; font-size: 9pt; margin: 0; padding: 15px; }
        .header {
            text-align: center;
            margin-bottom: 20px;
            border-bottom: 3px solid #1f2937;
            padding-bottom: 10px;
        }
        .header h1 { color: var(--bg); margin: 0; font-size: 18pt; }
        .header .subtitle { color: #666; font-size: 10pt; margin-top: 3px; }
        .header .date { color: #888; font-size: 9pt; margin-top: 3px; }

        .stats-grid { display: table; width: 100%; margin: 15px 0; }
        .stat-box {
            display: table-cell;
            width: 25%;
            padding: 10px;
            border: 1px solid #cbd5e1;
            text-align: center;
        }
        .stat-box .number { font-size: 24pt; font-weight: bold; }
        .stat-box .label { font-size: 7pt; color: #666; text-transform: uppercase; }

        .section { margin: 15px 0; page-break-inside: avoid; }
        .section h2 { background: #1f2937; color: white; padding: 6px; font-size: 10pt; margin: 0 0 8px 0; }

        table { width: 100%; border-collapse: collapse; margin: 8px 0; }
        th { background: var(--bg); color: var(--primary); padding: 5px; text-align: left; font-size: 8pt; }
        td { padding: 5px; border-bottom: 1px solid #ddd; font-size: 8pt; }
        tr:nth-child(even) { background: var(--bg); }

        .badge { display: inline-block; padding: 2px 5px; border-radius: 3px; font-size: 7pt; font-weight: bold; }
        .badge-danger { background: #fecaca; color: #991b1b; }
        .badge-warning { background: #fef3c7; color: #92400e; }
        .badge-success { background: #dcfce7; color: #166534; }
        .badge-info { background: #e0f2fe; color: #0369a1; }

        .alert { padding: 8px; margin: 10px 0; border-radius: 4px; font-size: 8pt; }
        .alert-danger { background: #fecaca; color: #991b1b; border: 1px solid var(--danger); }
        .alert-info { background: #e0f2fe; color: #0369a1; border: 1px solid #7dd3fc; }

        .progress-bar { background: #e5e7eb; height: 12px; border-radius: 6px; overflow: hidden; }
        .progress-fill { height: 100%; border-radius: 6px; }

        .footer { position: fixed; bottom: 10px; left: 15px; right: 15px; text-align: center; font-size: 7pt; color: #888; border-top: 1px solid #ddd; padding-top: 5px; }
    </style>
</head>
<body>
    <div class="header">
        <h1>{{ 'management_reports.gdpr.title'|trans({}, 'management_reports') }}</h1>
        <div class="subtitle">{{ 'management_reports.gdpr.subtitle'|trans({}, 'management_reports') }}</div>
        <div class="date">{{ 'management_reports.generated_at'|trans({}, 'management_reports') }}: {{ generated_at|date('d.m.Y H:i') }} | Version: {{ version }}</div>
    </div>

    {# Summary Statistics #}
    <div class="stats-grid">
        <div class="stat-box">
            <div class="number" style="color: #1f2937;">{{ report.total_breaches }}</div>
            <div class="label">{{ 'management_reports.gdpr.total_breaches'|trans({}, 'management_reports') }}</div>
        </div>
        <div class="stat-box">
            <div class="number" style="color: #0ea5e9;">{{ report.this_year }}</div>
            <div class="label">{{ 'management_reports.gdpr.this_year'|trans({}, 'management_reports') }}</div>
        </div>
        <div class="stat-box">
            <div class="number" style="color: #16a34a;">{{ report.notification_status.notified }}</div>
            <div class="label">{{ 'management_reports.gdpr.notified'|trans({}, 'management_reports') }}</div>
        </div>
        <div class="stat-box">
            <div class="number" style="color: #d97706;">{{ report.notification_status.pending }}</div>
            <div class="label">{{ 'management_reports.gdpr.pending_notification'|trans({}, 'management_reports') }}</div>
        </div>
    </div>

    {# Pending Notification Alert #}
    {% if report.notification_status.pending > 0 %}
    <div class="alert alert-danger">
        <strong>{{ 'management_reports.gdpr.urgent_attention'|trans({}, 'management_reports') }}:</strong> {{ 'management_reports.gdpr.pending_notification_warning'|trans({'%count%': report.notification_status.pending}, 'management_reports') }}
        {{ 'management_reports.gdpr.art33_72h_note'|trans({}, 'management_reports') }}
    </div>
    {% endif %}

    {# Severity Breakdown #}
    <div class="section">
        <h2>{{ 'management_reports.gdpr.by_severity'|trans({}, 'management_reports') }}</h2>
        <table>
            <tr>
                <th scope="col">{{ 'management_reports.gdpr.header.severity'|trans({}, 'management_reports') }}</th>
                <th scope="col">{{ 'management_reports.gdpr.header.count'|trans({}, 'management_reports') }}</th>
                <th scope="col">{{ 'management_reports.gdpr.header.distribution'|trans({}, 'management_reports') }}</th>
            </tr>
            <tr>
                <td><span class="badge badge-danger">{{ 'management_reports.severity.critical'|trans({}, 'management_reports') }}</span></td>
                <td>{{ report.by_severity.critical }}</td>
                <td>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: {{ report.total_breaches > 0 ? (report.by_severity.critical / report.total_breaches * 100) : 0 }}%; background: var(--danger);"></div>
                    </div>
                </td>
            </tr>
            <tr>
                <td><span class="badge badge-warning">{{ 'management_reports.severity.high'|trans({}, 'management_reports') }}</span></td>
                <td>{{ report.by_severity.high }}</td>
                <td>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: {{ report.total_breaches > 0 ? (report.by_severity.high / report.total_breaches * 100) : 0 }}%; background: #d97706;"></div>
                    </div>
                </td>
            </tr>
            <tr>
                <td><span class="badge badge-info">{{ 'management_reports.severity.medium'|trans({}, 'management_reports') }}</span></td>
                <td>{{ report.by_severity.medium }}</td>
                <td>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: {{ report.total_breaches > 0 ? (report.by_severity.medium / report.total_breaches * 100) : 0 }}%; background: #0ea5e9;"></div>
                    </div>
                </td>
            </tr>
            <tr>
                <td><span class="badge badge-success">{{ 'management_reports.severity.low'|trans({}, 'management_reports') }}</span></td>
                <td>{{ report.by_severity.low }}</td>
                <td>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: {{ report.total_breaches > 0 ? (report.by_severity.low / report.total_breaches * 100) : 0 }}%; background: #16a34a;"></div>
                    </div>
                </td>
            </tr>
        </table>
    </div>

    {# GDPR Requirements #}
    <div class="section">
        <h2>{{ 'management_reports.gdpr.requirements'|trans({}, 'management_reports') }}</h2>
        <div class="alert alert-info">
            <strong>{{ 'management_reports.gdpr.article_33_34'|trans({}, 'management_reports') }}</strong>
        </div>
        <table>
            <tr>
                <th scope="col">{{ 'management_reports.gdpr.header.requirement'|trans({}, 'management_reports') }}</th>
                <th scope="col">{{ 'management_reports.gdpr.header.description'|trans({}, 'management_reports') }}</th>
            </tr>
            <tr>
                <td>{{ 'management_reports.gdpr.72h_notification'|trans({}, 'management_reports') }}</td>
                <td>{{ 'management_reports.gdpr.72h_description'|trans({}, 'management_reports') }}</td>
            </tr>
            <tr>
                <td>{{ 'management_reports.gdpr.data_subject_notification'|trans({}, 'management_reports') }}</td>
                <td>{{ 'management_reports.gdpr.data_subject_description'|trans({}, 'management_reports') }}</td>
            </tr>
            <tr>
                <td>{{ 'management_reports.gdpr.documentation'|trans({}, 'management_reports') }}</td>
                <td>{{ 'management_reports.gdpr.documentation_description'|trans({}, 'management_reports') }}</td>
            </tr>
            <tr>
                <td>{{ 'management_reports.gdpr.risk_assessment'|trans({}, 'management_reports') }}</td>
                <td>{{ 'management_reports.gdpr.risk_assessment_description'|trans({}, 'management_reports') }}</td>
            </tr>
        </table>
    </div>

    {# Breach List #}
    {% if report.breaches|length > 0 %}
    <div class="section">
        <h2>{{ 'management_reports.gdpr.breach_list'|trans({}, 'management_reports') }}</h2>
        <table>
            <tr>
                <th scope="col">{{ 'management_reports.gdpr.header.id'|trans({}, 'management_reports') }}</th>
                <th scope="col">{{ 'management_reports.gdpr.header.title'|trans({}, 'management_reports') }}</th>
                <th scope="col">{{ 'management_reports.gdpr.header.severity'|trans({}, 'management_reports') }}</th>
                <th scope="col">{{ 'management_reports.gdpr.header.discovered'|trans({}, 'management_reports') }}</th>
                <th scope="col">{{ 'management_reports.gdpr.header.notification_required'|trans({}, 'management_reports') }}</th>
                <th scope="col">{{ 'management_reports.gdpr.header.notified'|trans({}, 'management_reports') }}</th>
            </tr>
            {% for breach in report.breaches %}
            <tr>
                <td>{{ breach.id }}</td>
                <td>{{ breach.title|slice(0, 30) }}{% if breach.title|length > 30 %}...{% endif %}</td>
                <td>
                    {% set severity = breach.severity|default('medium') %}
                    {% if severity == 'critical' %}
                    <span class="badge badge-danger">{{ severity }}</span>
                    {% elseif severity == 'high' %}
                    <span class="badge badge-warning">{{ severity }}</span>
                    {% elseif severity == 'medium' %}
                    <span class="badge badge-info">{{ severity }}</span>
                    {% else %}
                    <span class="badge badge-success">{{ severity }}</span>
                    {% endif %}
                </td>
                <td>{{ breach.discoveredAt ? breach.discoveredAt|date('Y-m-d') : '-' }}</td>
                <td>{{ breach.notificationRequired ? 'management_reports.gdpr.yes'|trans({}, 'management_reports') : 'management_reports.gdpr.no'|trans({}, 'management_reports') }}</td>
                <td>
                    {% if breach.notificationDate %}
                    {{ breach.notificationDate|date('Y-m-d') }}
                    {% elseif breach.notificationRequired %}
                    <span class="badge badge-warning">{{ 'management_reports.gdpr.pending'|trans({}, 'management_reports') }}</span>
                    {% else %}
                    -
                    {% endif %}
                </td>
            </tr>
            {% endfor %}
        </table>
    </div>
    {% else %}
    <div class="section">
        <h2>{{ 'management_reports.gdpr.breach_list'|trans({}, 'management_reports') }}</h2>
        <div class="alert" style="background: #dcfce7; color: #166534; border: 1px solid #86efac;">
            <strong>{{ 'management_reports.gdpr.no_breaches_title'|trans({}, 'management_reports') }}.</strong> {{ 'management_reports.gdpr.no_breaches_text'|trans({}, 'management_reports') }}
        </div>
    </div>
    {% endif %}

    <div class="footer">
        {{ 'management_reports.gdpr.footer'|trans({}, 'management_reports') }}
    </div>
</body>
</html>
