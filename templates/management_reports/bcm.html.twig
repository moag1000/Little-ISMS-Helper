{% extends 'base.html.twig' %}
{% trans_default_domain 'management_reports' %}

{% block title %}{{ 'management_reports.bcm.title'|trans({}, 'management_reports') }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% block body %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.reports'|trans({}, 'nav'), path: 'app_reports_index' },
            { label: 'management_reports.title'|trans({}, 'management_reports'), path: 'app_management_reports' },
            { label: 'management_reports.bcm.title'|trans({}, 'management_reports') }
        ]
    } %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 mb-0">
            <i class="fa-icon fa-icon--compliance-shield fa-icon--success" aria-hidden="true"></i> {{ 'management_reports.bcm.title'|trans({}, 'management_reports') }}
        </h1>
        <div>
            <div class="btn-group">
                <a href="{{ path('app_management_reports_bcm_pdf') }}" class="fa-cyber-btn fa-cyber-btn--danger">
                    <i class="fa-icon fa-icon--nav-file-pdf" aria-hidden="true"></i> {{ 'management_reports.action.download_pdf'|trans({}, 'management_reports') }}
                </a>
                <a href="{{ path('app_management_reports_bcm_excel') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                    <i class="fa-icon fa-icon--nav-file-check" aria-hidden="true"></i> {{ 'management_reports.action.download_excel'|trans({}, 'management_reports') }}
                </a>
            </div>
            {% include '_components/_fa_pdf_locale_switch.html.twig' with {route: 'app_management_reports_bcm_pdf'} only %}
        </div>
    </div>

    {# BC Plans Summary #}
    <div class="row mb-4">
        <div class="col-md-3">
            {{ _fa_feature_card.render({
                icon: 'nav-file-earmark-text',
                label: 'management_reports.bcm.total_plans'|trans({}, 'management_reports'),
                value: report.bc_plans.total,
                variant: 'primary'
            }) }}
        </div>
        <div class="col-md-3">
            {{ _fa_feature_card.render({
                icon: 'status-ok',
                label: 'management_reports.bcm.active_plans'|trans({}, 'management_reports'),
                value: report.bc_plans.active,
                variant: 'success'
            }) }}
        </div>
        <div class="col-md-3">
            {{ _fa_feature_card.render({
                icon: 'ui-hourglass',
                label: 'management_reports.bcm.draft_plans'|trans({}, 'management_reports'),
                value: report.bc_plans.draft,
                variant: 'warning'
            }) }}
        </div>
        <div class="col-md-3">
            {{ _fa_feature_card.render({
                icon: 'ui-search',
                label: 'management_reports.bcm.review_plans'|trans({}, 'management_reports'),
                value: report.bc_plans.review,
                variant: 'primary'
            }) }}
        </div>
    </div>

    <div class="row">
        {# BC Exercises #}
        <div class="col-md-6 mb-4">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100 shadow-sm' } %}
                {% block card_header %}
                    <div class="card-header">
                        <h3 class="h5 mb-0">
                            <i class="fa-icon fa-icon--ui-calendar-event" aria-hidden="true"></i>
                            {{ 'management_reports.bcm.exercises'|trans({}, 'management_reports') }}
                        </h3>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="row text-center mb-3">
                        <div class="col-6">
                            <h4 class="text-primary">{{ report.exercises.total }}</h4>
                            <small class="text-muted">{{ 'management_reports.bcm.total_exercises'|trans({}, 'management_reports') }}</small>
                        </div>
                        <div class="col-6">
                            <h4 class="text-success">{{ report.exercises.last_12_months }}</h4>
                            <small class="text-muted">{{ 'management_reports.bcm.exercises_12m'|trans({}, 'management_reports') }}</small>
                        </div>
                    </div>
                    {% if report.exercises.last_12_months >= 2 %}
                    <div class="fa-alert fa-alert--success mb-0" role="alert">
                        <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
                        {{ 'management_reports.bcm.exercises_compliant'|trans({}, 'management_reports') }}
                    </div>
                    {% else %}
                    <div class="fa-alert fa-alert--warning mb-0" role="alert">
                        <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i>
                        {{ 'management_reports.bcm.exercises_warning'|trans({}, 'management_reports') }}
                    </div>
                    {% endif %}
                {% endblock %}
            {% endembed %}
        </div>

        {# Business Processes #}
        <div class="col-md-6 mb-4">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100 shadow-sm' } %}
                {% block card_header %}
                    <div class="card-header">
                        <h3 class="h5 mb-0">
                            <i class="fa-icon fa-icon--nav-process" aria-hidden="true"></i>
                            {{ 'management_reports.bcm.business_processes'|trans({}, 'management_reports') }}
                        </h3>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="row text-center">
                        <div class="col-6">
                            <h4 class="text-primary">{{ report.business_processes.total }}</h4>
                            <small class="text-muted">{{ 'management_reports.bcm.total_processes'|trans({}, 'management_reports') }}</small>
                        </div>
                        <div class="col-6">
                            <h4 class="text-danger">{{ report.business_processes.critical }}</h4>
                            <small class="text-muted">{{ 'management_reports.bcm.critical_processes'|trans({}, 'management_reports') }}</small>
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    {# BIA Summary #}
    {% embed '_components/_card.html.twig' with { 'class': 'shadow-sm mb-4' } %}
        {% block card_header %}
            <div class="card-header">
                <h3 class="h5 mb-0">
                    <i class="fa-icon fa-icon--ui-copy" aria-hidden="true"></i>
                    {{ 'management_reports.bcm.bia_summary'|trans({}, 'management_reports') }}
                </h3>
            </div>
        {% endblock %}
        {% block card_body %}
    {% import '_components/_fa_progress.html.twig' as _fa_progress %}
            <div class="row mb-4">
                <div class="col-md-3 text-center">
                    <div class="border rounded p-3 h-100">
                        <h4 class="text-danger">{{ bia.by_criticality.critical }}</h4>
                        <small class="text-muted">{{ 'management_reports.criticality.critical'|trans({}, 'management_reports') }}</small>
                    </div>
                </div>
                <div class="col-md-3 text-center">
                    <div class="border rounded p-3 h-100">
                        <h4 class="text-warning">{{ bia.by_criticality.high }}</h4>
                        <small class="text-muted">{{ 'management_reports.criticality.high'|trans({}, 'management_reports') }}</small>
                    </div>
                </div>
                <div class="col-md-3 text-center">
                    <div class="border rounded p-3 h-100">
                        <h4 class="text-info">{{ bia.by_criticality.medium }}</h4>
                        <small class="text-muted">{{ 'management_reports.criticality.medium'|trans({}, 'management_reports') }}</small>
                    </div>
                </div>
                <div class="col-md-3 text-center">
                    <div class="border rounded p-3 h-100">
                        <h4 class="text-success">{{ bia.by_criticality.low }}</h4>
                        <small class="text-muted">{{ 'management_reports.criticality.low'|trans({}, 'management_reports') }}</small>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    {% embed '_components/_card.html.twig' %}
                        {% block card_body %}
                            {% import '_components/_fa_progress.html.twig' as _fa_progress %}
                            <h5>{{ 'management_reports.bcm.rto_rpo_coverage'|trans({}, 'management_reports') }}</h5>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span>{{ 'management_reports.bcm.processes_with_rto'|trans({}, 'management_reports') }}</span>
                                {% include '_components/_badge.html.twig' with { variant: 'primary', content: bia.rto_defined ~ ' / ' ~ bia.total_processes } %}
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span>{{ 'management_reports.bcm.processes_with_rpo'|trans({}, 'management_reports') }}</span>
                                {% include '_components/_badge.html.twig' with { variant: 'primary', content: bia.rpo_defined ~ ' / ' ~ bia.total_processes } %}
                            </div>
                            {{ _fa_progress.render({ value: bia.coverage, tone: 'success', showText: true, class: 'mt-3' }) }}
                        {% endblock %}
                    {% endembed %}
                </div>
                <div class="col-md-6">
                    {% if bia.coverage < 80 %}
                    <div class="fa-alert fa-alert--warning h-100 d-flex align-items-center" role="alert">
                        <div>
                            <h5><i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> {{ 'management_reports.bcm.bia_warning_title'|trans({}, 'management_reports') }}</h5>
                            <p class="mb-0">{{ 'management_reports.bcm.bia_warning_text'|trans({}, 'management_reports') }}</p>
                        </div>
                    </div>
                    {% else %}
                    <div class="fa-alert fa-alert--success h-100 d-flex align-items-center" role="alert">
                        <div>
                            <h5><i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i> {{ 'management_reports.bcm.bia_success_title'|trans({}, 'management_reports') }}</h5>
                            <p class="mb-0">{{ 'management_reports.bcm.bia_success_text'|trans({}, 'management_reports') }}</p>
                        </div>
                    </div>
                    {% endif %}
                </div>
            </div>
        {% endblock %}
    {% endembed %}

    {# BC Plans Table #}
    {% if report.bc_plans.plans|length > 0 %}
    {% embed '_components/_card.html.twig' with { 'class': 'shadow-sm mb-4' } %}
        {% block card_header %}
            <div class="card-header">
                <h3 class="h5 mb-0">
                    <i class="fa-icon fa-icon--nav-list-check" aria-hidden="true"></i>
                    {{ 'management_reports.bcm.plans_overview'|trans({}, 'management_reports') }}
                </h3>
            </div>
        {% endblock %}
        {% block card_body %}
            {% embed '_components/_fa_table.html.twig' with { compact: true } %}
                {% block table_head %}
                    <tr>
                        <th scope="col" class="fa-table__th">{{ 'management_reports.bcm.header.name'|trans({}, 'management_reports') }}</th>
                        <th scope="col" class="fa-table__th">{{ 'management_reports.bcm.header.status'|trans({}, 'management_reports') }}</th>
                        <th scope="col" class="fa-table__th">{{ 'management_reports.bcm.header.last_review'|trans({}, 'management_reports') }}</th>
                        <th scope="col" class="fa-table__th">{{ 'management_reports.bcm.header.next_review'|trans({}, 'management_reports') }}</th>
                    </tr>
                {% endblock %}
                {% block table_body %}
                    {% for plan in report.bc_plans.plans %}
                    <tr class="fa-table__row">
                        <td class="fa-table__cell">
                            <a href="{{ path('app_bc_plan_show', {id: plan.id}) }}">{{ plan.name }}</a>
                        </td>
                        <td class="fa-table__cell">
                            {% set statusVariant = (plan.status == 'active' or plan.status == 'approved') ? 'success' : (plan.status == 'draft' ? 'warning' : (plan.status == 'review' ? 'info' : 'secondary')) %}
                            {% include '_components/_badge.html.twig' with { variant: statusVariant, content: plan.status } %}
                        </td>
                        <td class="fa-table__cell">{{ plan.lastReviewDate ? plan.lastReviewDate|date('Y-m-d') : '-' }}</td>
                        <td class="fa-table__cell">{{ plan.nextReviewDate ? plan.nextReviewDate|date('Y-m-d') : '-' }}</td>
                    </tr>
                    {% endfor %}
                {% endblock %}
            {% endembed %}
        {% endblock %}
    {% endembed %}
    {% endif %}

    {# Report Generated Info #}
    <div class="text-muted small text-end">
        <i class="fa-icon fa-icon--ui-clock" aria-hidden="true"></i>
        {{ 'management_reports.generated_at'|trans({}, 'management_reports') }}: {{ report.generated_at|date('Y-m-d H:i') }}
    </div>
</div>
{% endblock %}
