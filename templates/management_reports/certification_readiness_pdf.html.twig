<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>ISO 27001 Certification Readiness Assessment</title>
    <style>
        @page { margin: 15mm 12mm; size: A4 portrait; }
        body { font-family: 'DejaVu Sans', sans-serif; font-size: 9pt; margin: 0; padding: 0; color: #1e293b; }

        .header {
            text-align: center;
            margin-bottom: 20px;
            border-bottom: 3px solid transparent;
            border-image: linear-gradient(90deg, #06b6d4 0%, #ec4899 50%, #8b5cf6 100%) 1;
            padding-bottom: 10px;
        }
        .header h1 { color: #0f172a; margin: 0; font-size: 16pt; text-transform: uppercase; letter-spacing: 0.5pt; }
        .header .subtitle { color: #666; font-size: 10pt; margin-top: 3px; }
        .header .date { color: #888; font-size: 9pt; margin-top: 3px; }

        .section { margin: 15px 0; page-break-inside: avoid; }
        .section h2 {
            background: linear-gradient(90deg, #0f172a 0%, #1e293b 100%);
            color: #06b6d4;
            padding: 6px 8px;
            font-size: 10pt;
            margin: 0 0 8px 0;
            text-transform: uppercase;
            letter-spacing: 0.3pt;
        }

        /* Score cards */
        .score-grid { display: table; width: 100%; margin-bottom: 15px; }
        .score-box {
            display: table-cell;
            width: 33.33%;
            padding: 10px 8px;
            border: 1px solid #e2e8f0;
            text-align: center;
            background: #f8fafc;
        }
        .score-box .number { font-size: 22pt; font-weight: bold; margin: 0; }
        .score-box .number.success { color: #16a34a; }
        .score-box .number.warning { color: #d97706; }
        .score-box .number.danger { color: #dc2626; }
        .score-box .label { font-size: 7.5pt; color: #475569; text-transform: uppercase; font-weight: bold; letter-spacing: 0.3pt; }

        .recommendation {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 4px;
            font-size: 10pt;
            font-weight: bold;
            color: #fff;
            margin-top: 4px;
        }
        .recommendation.ready { background: #16a34a; }
        .recommendation.conditional { background: #d97706; }
        .recommendation.not-ready { background: #dc2626; }

        /* Tables */
        table { width: 100%; border-collapse: collapse; margin: 5px 0; }
        th {
            background: #0f172a;
            color: #06b6d4;
            padding: 5px 6px;
            text-align: left;
            font-size: 8pt;
            text-transform: uppercase;
        }
        td { padding: 4px 6px; font-size: 8.5pt; border-bottom: 1px solid #e2e8f0; }
        tr:nth-child(even) td { background: #f8fafc; }

        /* Progress bar */
        .progress-bar-container { background: #e5e7eb; height: 12px; border-radius: 6px; overflow: hidden; display: inline-block; width: 80px; vertical-align: middle; }
        .progress-fill { height: 100%; border-radius: 6px; }
        .progress-fill.success { background: #16a34a; }
        .progress-fill.warning { background: #d97706; }
        .progress-fill.danger { background: #dc2626; }

        /* Badges */
        .badge { display: inline-block; padding: 2px 6px; border-radius: 3px; font-size: 7pt; font-weight: bold; color: #fff; }
        .badge-success { background: #16a34a; }
        .badge-warning { background: #d97706; color: #1e293b; }
        .badge-danger { background: #dc2626; }

        /* Gap list */
        .gap-item { padding: 3px 0; font-size: 8.5pt; border-bottom: 1px solid #f1f5f9; }
        .gap-critical { color: #dc2626; }
        .gap-recommended { color: #475569; }

        /* Two-column */
        .two-col { display: table; width: 100%; }
        .col-left { display: table-cell; width: 50%; padding-right: 6px; vertical-align: top; }
        .col-right { display: table-cell; width: 50%; padding-left: 6px; vertical-align: top; }

        .footer {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            text-align: center;
            font-size: 7pt;
            color: #94a3b8;
            border-top: 1px solid #e2e8f0;
            padding-top: 4px;
        }
    </style>
</head>
<body>
    {# Header #}
    <div class="header">
        <h1>ISO 27001 Certification Readiness Assessment</h1>
        <div class="subtitle">Little ISMS Helper</div>
        <div class="date">{{ generated_at|date('d.m.Y H:i') }}</div>
    </div>

    {# Readiness Score #}
    <div class="score-grid">
        <div class="score-box">
            <div class="number {% if overall_score >= 85 %}success{% elseif overall_score >= 70 %}warning{% else %}danger{% endif %}">{{ overall_score }}%</div>
            <div class="label">Overall Readiness</div>
            <div>
                <span class="recommendation {% if recommendation == 'READY' %}ready{% elseif recommendation == 'CONDITIONAL' %}conditional{% else %}not-ready{% endif %}">
                    {% if recommendation == 'READY' %}READY
                    {% elseif recommendation == 'CONDITIONAL' %}CONDITIONAL
                    {% else %}NOT READY{% endif %}
                </span>
            </div>
        </div>
        <div class="score-box">
            <div class="number {% if clause_score >= 80 %}success{% elseif clause_score >= 60 %}warning{% else %}danger{% endif %}">{{ clause_score }}%</div>
            <div class="label">Clause Compliance (4-10)</div>
        </div>
        <div class="score-box">
            <div class="number {% if control_percentage >= 80 %}success{% elseif control_percentage >= 60 %}warning{% else %}danger{% endif %}">{{ control_percentage }}%</div>
            <div class="label">Annex A Controls</div>
            <div style="font-size: 7.5pt; color: #64748b;">{{ control_stats.implemented }} / {{ control_stats.total }} implemented</div>
        </div>
    </div>

    {# Section 1: Clause Compliance #}
    <div class="section">
        <h2>Section 1: Clause Compliance (4-10)</h2>
        {% if clause_compliance is not empty %}
        <table>
            <thead>
                <tr>
                    <th scope="col">Clause</th>
                    <th scope="col">Score</th>
                    <th scope="col">Status</th>
                    <th scope="col">Gaps</th>
                </tr>
            </thead>
            <tbody>
                {% for key, clause in clause_compliance %}
                <tr>
                    <td><strong>{{ clause.name|trans({}, 'compliance') }}</strong></td>
                    <td>
                        <span class="progress-bar-container">
                            <span class="progress-fill {% if clause.score >= 80 %}success{% elseif clause.score >= 40 %}warning{% else %}danger{% endif %}" style="width: {{ clause.score }}%"></span>
                        </span>
                        {{ clause.score }}%
                    </td>
                    <td>
                        {% if clause.status == 'complete' %}
                            <span class="badge badge-success">Complete</span>
                        {% elseif clause.status == 'partial' %}
                            <span class="badge badge-warning">Partial</span>
                        {% else %}
                            <span class="badge badge-danger">Not Started</span>
                        {% endif %}
                    </td>
                    <td>{{ clause.gaps|length }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% else %}
        <p style="color: #94a3b8;">ISO 27001 wizard not available. Enable the controls module to run the assessment.</p>
        {% endif %}
    </div>

    {# Section 2: Annex A Control Coverage #}
    <div class="section">
        <h2>Section 2: Annex A Control Coverage</h2>
        <table>
            <thead>
                <tr>
                    <th scope="col">Metric</th>
                    <th scope="col">Count</th>
                </tr>
            </thead>
            <tbody>
                <tr><td>Total Applicable Controls</td><td><strong>{{ control_stats.total }}</strong></td></tr>
                <tr><td>Implemented</td><td style="color: #16a34a;"><strong>{{ control_stats.implemented }}</strong></td></tr>
                <tr><td>In Progress</td><td style="color: #d97706;"><strong>{{ control_stats.in_progress }}</strong></td></tr>
                <tr><td>Not Started</td><td style="color: #dc2626;"><strong>{{ control_stats.not_started }}</strong></td></tr>
                <tr><td>Not Applicable</td><td>{{ control_stats.not_applicable }}</td></tr>
                <tr><td>Implementation Rate</td><td><strong>{{ control_percentage }}%</strong></td></tr>
            </tbody>
        </table>

        {% if controls_not_started|length > 0 %}
        <div style="margin-top: 8px;">
            <strong style="font-size: 8.5pt; color: #dc2626;">Controls Not Started ({{ controls_not_started|length }}):</strong>
            <div style="font-size: 7.5pt; color: #475569; margin-top: 3px;">
                {% for control in controls_not_started[:15] %}
                    {{ control.id }}{% if not loop.last %}, {% endif %}
                {% endfor %}
                {% if controls_not_started|length > 15 %}
                    ... and {{ controls_not_started|length - 15 }} more
                {% endif %}
            </div>
        </div>
        {% endif %}

        {% if controls_in_progress|length > 0 %}
        <div style="margin-top: 6px;">
            <strong style="font-size: 8.5pt; color: #d97706;">Controls In Progress ({{ controls_in_progress|length }}):</strong>
            <div style="font-size: 7.5pt; color: #475569; margin-top: 3px;">
                {% for control in controls_in_progress[:15] %}
                    {{ control.id }}{% if not loop.last %}, {% endif %}
                {% endfor %}
                {% if controls_in_progress|length > 15 %}
                    ... and {{ controls_in_progress|length - 15 }} more
                {% endif %}
            </div>
        </div>
        {% endif %}
    </div>

    {# Section 4: Gap List #}
    {% if critical_gaps|length > 0 or recommended_improvements|length > 0 %}
    <div class="section">
        <h2>Section 3: Gap List (Priority)</h2>

        {% if critical_gaps|length > 0 %}
        <div style="margin-bottom: 8px;">
            <strong style="font-size: 9pt; color: #dc2626;">Critical Gaps (Must Fix Before Audit):</strong>
            {% for gap in critical_gaps %}
            <div class="gap-item gap-critical">
                &#10007; {{ gap.name|default(gap.check|default('Unknown')) }}
                {% if gap.description|default('') %} - {{ gap.description }}{% endif %}
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {% if recommended_improvements|length > 0 %}
        <div>
            <strong style="font-size: 9pt; color: #475569;">Recommended Improvements:</strong>
            {% for improvement in recommended_improvements[:10] %}
            <div class="gap-item gap-recommended">
                &#8594; {{ improvement.name|default(improvement.check|default('Unknown')) }}
                {% if improvement.description|default('') %} - {{ improvement.description }}{% endif %}
            </div>
            {% endfor %}
            {% if recommended_improvements|length > 10 %}
            <div class="gap-item gap-recommended" style="font-style: italic;">
                ... and {{ recommended_improvements|length - 10 }} more improvements identified.
            </div>
            {% endif %}
        </div>
        {% endif %}
    </div>
    {% endif %}

    {# Footer #}
    <div class="footer">
        Generated: {{ generated_at|date('d.m.Y H:i') }} |
        Version: {{ version }} |
        CONFIDENTIAL | Little ISMS Helper
    </div>
</body>
</html>
