{% extends 'base.html.twig' %}
{% trans_default_domain 'management_reports' %}

{% block title %}{{ 'management_reports.gdpr.title'|trans({}, 'management_reports') }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% block body %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.reports'|trans({}, 'nav'), path: 'app_reports_index' },
            { label: 'management_reports.title'|trans({}, 'management_reports'), path: 'app_management_reports' },
            { label: 'management_reports.gdpr.title'|trans({}, 'management_reports') }
        ]
    } %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 mb-0">
            <i class="fa-icon fa-icon--control" aria-hidden="true"></i> {{ 'management_reports.gdpr.title'|trans({}, 'management_reports') }}
        </h1>
        <div class="btn-group">
            <a href="{{ path('app_management_reports_gdpr_pdf') }}" class="fa-cyber-btn fa-cyber-btn--danger">
                <i class="fa-icon fa-icon--nav-file-pdf" aria-hidden="true"></i> {{ 'management_reports.action.download_pdf'|trans({}, 'management_reports') }}
            </a>
            <a href="{{ path('app_management_reports_gdpr_excel') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                <i class="bi bi-file-excel" aria-hidden="true"></i> {{ 'management_reports.action.download_excel'|trans({}, 'management_reports') }}
            </a>
        </div>
    </div>

    {# Data Breach Summary #}
    <div class="row mb-4">
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' with { 'class': 'text-center h-100' } %}
                {% block card_body %}
                    <i class="fa-icon fa-icon--breach fs-1" aria-hidden="true"></i>
                    <h3 class="display-5">{{ report.total_breaches }}</h3>
                    <small>{{ 'management_reports.gdpr.total_breaches'|trans({}, 'management_reports') }}</small>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-3">
            {{ _fa_feature_card.render({
                icon: 'calendar',
                label: 'management_reports.gdpr.this_year'|trans({}, 'management_reports'),
                value: report.this_year,
                variant: 'primary'
            }) }}
        </div>
        <div class="col-md-3">
            {{ _fa_feature_card.render({
                icon: 'check-circle',
                label: 'management_reports.gdpr.notified'|trans({}, 'management_reports'),
                value: report.notification_status.notified,
                variant: 'success'
            }) }}
        </div>
        <div class="col-md-3">
            {{ _fa_feature_card.render({
                icon: 'hourglass-split',
                label: 'management_reports.gdpr.pending_notification'|trans({}, 'management_reports'),
                value: report.notification_status.pending,
                variant: 'warning'
            }) }}
        </div>
    </div>

    <div class="row">
        {# Severity Breakdown #}
        <div class="col-md-6 mb-4">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100 shadow-sm' } %}
                {% block card_header %}
                    <div class="card-header">
                        <h3 class="h5 mb-0">
                            <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i>
                            {{ 'management_reports.gdpr.by_severity'|trans({}, 'management_reports') }}
                        </h3>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            {% include '_components/_badge.html.twig' with { variant: 'danger', content: 'management_reports.severity.critical'|trans({}, 'management_reports') } %}
                            <span>{{ report.by_severity.critical }}</span>
                        </div>
                        <div class="progress progress-h-20">
                            <div class="progress-bar bg-danger" style="width: {{ report.total_breaches > 0 ? (report.by_severity.critical / report.total_breaches * 100) : 0 }}%"></div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            {% include '_components/_badge.html.twig' with { variant: 'warning', content: 'management_reports.severity.high'|trans({}, 'management_reports') } %}
                            <span>{{ report.by_severity.high }}</span>
                        </div>
                        <div class="progress progress-h-20">
                            <div class="progress-bar bg-warning" style="width: {{ report.total_breaches > 0 ? (report.by_severity.high / report.total_breaches * 100) : 0 }}%"></div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            {% include '_components/_badge.html.twig' with { variant: 'info', content: 'management_reports.severity.medium'|trans({}, 'management_reports') } %}
                            <span>{{ report.by_severity.medium }}</span>
                        </div>
                        <div class="progress progress-h-20">
                            <div class="progress-bar bg-info" style="width: {{ report.total_breaches > 0 ? (report.by_severity.medium / report.total_breaches * 100) : 0 }}%"></div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            {% include '_components/_badge.html.twig' with { variant: 'success', content: 'management_reports.severity.low'|trans({}, 'management_reports') } %}
                            <span>{{ report.by_severity.low }}</span>
                        </div>
                        <div class="progress progress-h-20">
                            <div class="progress-bar bg-success" style="width: {{ report.total_breaches > 0 ? (report.by_severity.low / report.total_breaches * 100) : 0 }}%"></div>
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>

        {# GDPR Requirements #}
        <div class="col-md-6 mb-4">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100 shadow-sm' } %}
                {% block card_header %}
                    <div class="card-header">
                        <h3 class="h5 mb-0">
                            <i class="fa-icon fa-icon--ui-info" aria-hidden="true"></i>
                            {{ 'management_reports.gdpr.requirements'|trans({}, 'management_reports') }}
                        </h3>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="fa-alert fa-alert--info mb-3" role="alert">
                        <strong>{{ 'management_reports.gdpr.article_33_34'|trans({}, 'management_reports') }}</strong>
                    </div>
                    <ul class="list-group">
                        <li class="list-group-item">
                            <strong>{{ 'management_reports.gdpr.72h_notification'|trans({}, 'management_reports') }}</strong>
                            <p class="mb-0 small text-muted">{{ 'management_reports.gdpr.72h_description'|trans({}, 'management_reports') }}</p>
                        </li>
                        <li class="list-group-item">
                            <strong>{{ 'management_reports.gdpr.data_subject_notification'|trans({}, 'management_reports') }}</strong>
                            <p class="mb-0 small text-muted">{{ 'management_reports.gdpr.data_subject_description'|trans({}, 'management_reports') }}</p>
                        </li>
                        <li class="list-group-item">
                            <strong>{{ 'management_reports.gdpr.documentation'|trans({}, 'management_reports') }}</strong>
                            <p class="mb-0 small text-muted">{{ 'management_reports.gdpr.documentation_description'|trans({}, 'management_reports') }}</p>
                        </li>
                    </ul>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    {# Pending Notifications Alert #}
    {% if report.notification_status.pending > 0 %}
    <div class="fa-alert fa-alert--danger mb-4" role="alert">
        <h5><i class="bi bi-exclamation-octagon" aria-hidden="true"></i> {{ 'management_reports.gdpr.urgent_attention'|trans({}, 'management_reports') }}</h5>
        <p>{{ 'management_reports.gdpr.pending_notification_warning'|trans({'%count%': report.notification_status.pending}, 'management_reports') }}</p>
        <a href="{{ path('app_data_breach_index') }}" class="fa-cyber-btn fa-cyber-btn--danger">
            <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i> {{ 'management_reports.gdpr.view_breaches'|trans({}, 'management_reports') }}
        </a>
    </div>
    {% endif %}

    {# Breaches Table #}
    {% if report.breaches|length > 0 %}
    {% embed '_components/_card.html.twig' with { 'class': 'shadow-sm mb-4' } %}
        {% block card_header %}
            <div class="card-header">
                <h3 class="h5 mb-0">
                    <i class="fa-icon fa-icon--ui-list" aria-hidden="true"></i>
                    {{ 'management_reports.gdpr.breach_list'|trans({}, 'management_reports') }}
                </h3>
            </div>
        {% endblock %}
        {% block card_body %}
            <div class="table-responsive">
                <table class="table table-sm table-hover">
                    <thead>
                        <tr>
                            <th scope="col">{{ 'management_reports.gdpr.header.id'|trans({}, 'management_reports') }}</th>
                            <th scope="col">{{ 'management_reports.gdpr.header.title'|trans({}, 'management_reports') }}</th>
                            <th scope="col">{{ 'management_reports.gdpr.header.severity'|trans({}, 'management_reports') }}</th>
                            <th scope="col">{{ 'management_reports.gdpr.header.discovered'|trans({}, 'management_reports') }}</th>
                            <th scope="col">{{ 'management_reports.gdpr.header.notification_required'|trans({}, 'management_reports') }}</th>
                            <th scope="col">{{ 'management_reports.gdpr.header.notified'|trans({}, 'management_reports') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for breach in report.breaches %}
                        <tr>
                            <td>{{ breach.id }}</td>
                            <td>
                                <a href="{{ path('app_data_breach_show', {id: breach.id}) }}">
                                    {{ breach.title }}
                                </a>
                            </td>
                            <td>
                                {% set severity = breach.severity|default('medium') %}
                                {% include '_components/_badge.html.twig' with { variant: severity == 'critical' ? 'danger' : (severity == 'high' ? 'warning' : (severity == 'medium' ? 'info' : 'success')), content: severity } %}
                            </td>
                            <td>{{ breach.discoveredAt ? breach.discoveredAt|date('Y-m-d') : '-' }}</td>
                            <td>
                                {% include '_components/_badge.html.twig' with { variant: breach.notificationRequired ? 'danger' : 'secondary', content: breach.notificationRequired ? 'common.yes'|trans({}, 'messages') : 'common.no'|trans({}, 'messages') } %}
                            </td>
                            <td>
                                {% if breach.notificationDate %}
                                <span class="text-success">{{ breach.notificationDate|date('Y-m-d') }}</span>
                                {% elseif breach.notificationRequired %}
                                {% include '_components/_badge.html.twig' with { variant: 'warning', content: 'management_reports.gdpr.pending'|trans({}, 'management_reports') } %}
                                {% else %}
                                <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endblock %}
    {% endembed %}
    {% else %}
    <div class="fa-alert fa-alert--success mb-4" role="alert">
        <h5><i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i> {{ 'management_reports.gdpr.no_breaches_title'|trans({}, 'management_reports') }}</h5>
        <p class="mb-0">{{ 'management_reports.gdpr.no_breaches_text'|trans({}, 'management_reports') }}</p>
    </div>
    {% endif %}

    {# Quick Links #}
    {% embed '_components/_card.html.twig' with { 'class': 'shadow-sm mb-4' } %}
        {% block card_body %}
            <div class="row">
                <div class="col-md-4">
                    <a href="{{ path('app_data_breach_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost w-100">
                        <i class="fa-icon fa-icon--breach" aria-hidden="true"></i> {{ 'management_reports.gdpr.view_breaches'|trans({}, 'management_reports') }}
                    </a>
                </div>
                <div class="col-md-4">
                    <a href="{{ path('app_processing_activity_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost w-100">
                        <i class="fa-icon fa-icon--asset-database" aria-hidden="true"></i> {{ 'management_reports.gdpr.view_ropa'|trans({}, 'management_reports') }}
                    </a>
                </div>
                <div class="col-md-4">
                    <a href="{{ path('app_dpia_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost w-100">
                        <i class="fa-icon fa-icon--ui-copy-data" aria-hidden="true"></i> {{ 'management_reports.gdpr.view_dpia'|trans({}, 'management_reports') }}
                    </a>
                </div>
            </div>
        {% endblock %}
    {% endembed %}

    {# Report Generated Info #}
    <div class="text-muted small text-end">
        <i class="fa-icon fa-icon--ui-clock" aria-hidden="true"></i>
        {{ 'management_reports.generated_at'|trans({}, 'management_reports') }}: {{ report.generated_at|date('Y-m-d H:i') }}
    </div>
</div>
{% endblock %}
