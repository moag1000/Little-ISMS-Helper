{% extends 'base.html.twig' %}
{% trans_default_domain 'management_reports' %}

{% block title %}{{ 'management_reports.title'|trans({}, 'management_reports') }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% block body %}
{% import '_macros/cards.html.twig' as cards %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

<main class="fa-aurora-surface">
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.reports'|trans({}, 'nav'), path: 'app_reports_index' },
            { label: 'management_reports.title'|trans({}, 'management_reports') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'graph-up-arrow', label: 'nav.reports'|trans({}, 'nav') },
        title: 'management_reports.title'|trans({}, 'management_reports'),
        subtitle: 'management_reports.subtitle'|trans({}, 'management_reports')
    }) }}

    {# Quick Stats Row #}
    <div class="row mb-4">
        <div class="col-md-3">
            {{ _fa_feature_card.render({
                icon: 'server',
                label: 'management_reports.stats.assets'|trans({}, 'management_reports'),
                value: summary.summary.total_assets,
                variant: 'primary'
            }) }}
        </div>
        <div class="col-md-3">
            {{ _fa_feature_card.render({
                icon: 'exclamation-triangle',
                label: 'management_reports.stats.high_risks'|trans({}, 'management_reports'),
                value: summary.risk_distribution.critical + summary.risk_distribution.high,
                variant: 'danger'
            }) }}
        </div>
        <div class="col-md-3">
            {{ _fa_feature_card.render({
                icon: 'shield-check',
                label: 'management_reports.stats.compliance'|trans({}, 'management_reports'),
                value: summary.summary.compliance_percentage,
                unit: '%',
                variant: 'success'
            }) }}
        </div>
        <div class="col-md-3">
            {{ _fa_feature_card.render({
                icon: 'bell',
                label: 'management_reports.stats.open_incidents'|trans({}, 'management_reports'),
                value: summary.incident_summary.open,
                variant: 'warning'
            }) }}
        </div>
    </div>

    {# Report Categories #}
    <h2 class="h4 mb-3">
        <i class="fa-icon fa-icon--nav-collection" aria-hidden="true"></i> {{ 'management_reports.categories.title'|trans({}, 'management_reports') }}
    </h2>

    <div class="row">
        {% for category in categories %}
        <div class="col-md-6 col-lg-4 mb-4">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100 shadow-sm border-' ~ category.color } %}
                {% block card_header %}
                    <div class="card-header">
                        <h3 class="h5 mb-0">
                            <i class="bi bi-{{ category.icon }}" aria-hidden="true"></i>
                            {{ ('management_reports.category.' ~ category.key ~ '.title')|trans({}, 'management_reports') }}
                        </h3>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <p class="text-muted small mb-3">{{ ('management_reports.category.' ~ category.key ~ '.description')|trans({}, 'management_reports') }}</p>
                    <ul class="list-unstyled small mb-0">
                        {% for report in category.reports %}
                        <li class="mb-2">
                            <i class="fa-icon fa-icon--policy text-{{ category.color }}" aria-hidden="true"></i>
                            {{ ('management_reports.report.' ~ report.key)|trans({}, 'management_reports') }}
                        </li>
                        {% endfor %}
                    </ul>
                {% endblock %}
                {% block card_footer %}
                    <div class="card-footer bg-body-secondary">
                        {% set route_name = 'app_management_reports_' ~ category.key %}
                        <a href="{{ path(route_name) }}" class="fa-cyber-btn fa-cyber-btn--sm {{ category.color in ['danger','warning'] ? 'fa-cyber-btn--' ~ category.color : 'fa-cyber-btn--ghost' }}">
                            <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i> {{ 'management_reports.action.view_reports'|trans({}, 'management_reports') }}
                        </a>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        {% endfor %}
    </div>

    {# Quick Access Section #}
    <div class="row mt-4">
        <div class="col-12">
            {% embed '_components/_card.html.twig' with { 'class': 'shadow-sm' } %}
                {% block card_header %}
                    <div class="card-header bg-body-secondary">
                        <h3 class="h5 mb-0">
                            <i class="bi bi-lightning" aria-hidden="true"></i> {{ 'management_reports.quick_access.title'|trans({}, 'management_reports') }}
                        </h3>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="row">
                        <div class="col-md-6">
                            <h4 class="h6">{{ 'management_reports.quick_access.pdf_exports'|trans({}, 'management_reports') }}</h4>
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                <a href="{{ path('app_reports_board_one_pager_pdf') }}" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--sm">
                                    <i class="fa-icon fa-icon--nav-file-pdf" aria-hidden="true"></i> Board One-Pager
                                </a>
                                <a href="{{ path('app_management_reports_executive_pdf') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                    <i class="fa-icon fa-icon--nav-file-pdf" aria-hidden="true"></i> Executive Summary
                                </a>
                                <a href="{{ path('app_management_reports_risk_pdf') }}" class="fa-cyber-btn fa-cyber-btn--danger fa-cyber-btn--sm">
                                    <i class="fa-icon fa-icon--nav-file-pdf" aria-hidden="true"></i> Risk Report
                                </a>
                                <a href="{{ path('app_management_reports_bcm_pdf') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                    <i class="fa-icon fa-icon--nav-file-pdf" aria-hidden="true"></i> BCM Report
                                </a>
                                <a href="{{ path('app_management_reports_compliance_pdf') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                    <i class="fa-icon fa-icon--nav-file-pdf" aria-hidden="true"></i> Compliance Status
                                </a>
                                <a href="{{ path('app_management_reports_review_output_pdf') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                    <i class="fa-icon fa-icon--nav-file-pdf" aria-hidden="true"></i> {{ 'management_reports.review_output.title'|trans({}, 'management_reports') }}
                                </a>
                                <a href="{{ path('app_management_reports_quarterly_trend') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                    <i class="fa-icon fa-icon--nav-bar-chart" aria-hidden="true"></i> {{ 'management_reports.quarterly_trend.view_report'|trans({}, 'management_reports') }}
                                </a>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <h4 class="h6">{{ 'management_reports.quick_access.excel_exports'|trans({}, 'management_reports') }}</h4>
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                <a href="{{ path('app_management_reports_risk_excel') }}" class="fa-cyber-btn fa-cyber-btn--danger fa-cyber-btn--sm">
                                    <i class="bi bi-file-excel" aria-hidden="true"></i> Risk Register
                                </a>
                                <a href="{{ path('app_management_reports_assets_excel') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                    <i class="bi bi-file-excel" aria-hidden="true"></i> Asset Inventory
                                </a>
                                <a href="{{ path('app_management_reports_bcm_excel') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                    <i class="bi bi-file-excel" aria-hidden="true"></i> BCM Report
                                </a>
                                <a href="{{ path('app_management_reports_compliance_excel') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                    <i class="bi bi-file-excel" aria-hidden="true"></i> Compliance Status
                                </a>
                                <a href="{{ path('app_management_reports_audit_excel') }}" class="fa-cyber-btn fa-cyber-btn--warning fa-cyber-btn--sm">
                                    <i class="bi bi-file-excel" aria-hidden="true"></i> Audit Report
                                </a>
                                <a href="{{ path('app_management_reports_gdpr_excel') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                    <i class="bi bi-file-excel" aria-hidden="true"></i> GDPR / Data Breach
                                </a>
                            </div>
                            <h4 class="h6">{{ 'cert_readiness.title'|trans({}, 'management_reports') }}</h4>
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                <a href="{{ path('app_management_reports_cert_readiness') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                    <i class="fa-icon fa-icon--nav-patch-check" aria-hidden="true"></i> {{ 'cert_readiness.view_assessment'|trans({}, 'management_reports') }}
                                </a>
                                <a href="{{ path('app_management_reports_cert_readiness_pdf') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                    <i class="fa-icon fa-icon--nav-file-pdf" aria-hidden="true"></i> {{ 'cert_readiness.download_pdf'|trans({}, 'management_reports') }}
                                </a>
                            </div>
                            <h4 class="h6">{{ 'management_reports.quick_access.evidence_package'|trans({}, 'management_reports') }}</h4>
                            <div class="d-flex flex-wrap gap-2">
                                <a href="{{ path('app_management_reports_evidence_package') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                    <i class="bi bi-file-zip" aria-hidden="true"></i> {{ 'management_reports.action.download_evidence_package'|trans({}, 'management_reports') }}
                                </a>
                            </div>
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>
</div>
</main>
{% endblock %}
