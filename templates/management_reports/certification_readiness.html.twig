{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% trans_default_domain 'management_reports' %}

{% block title %}{{ 'cert_readiness.title'|trans({}, 'management_reports') }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% block body %}
{% import '_macros/cards.html.twig' as cards %}

<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.reports'|trans({}, 'nav'), path: 'app_reports_index' },
            { label: 'management_reports.title'|trans({}, 'management_reports'), path: 'app_management_reports' },
            { label: 'cert_readiness.title'|trans({}, 'management_reports') }
        ]
    } only %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 mb-0">
            <i class="bi bi-patch-check" aria-hidden="true"></i> {{ 'cert_readiness.title'|trans({}, 'management_reports') }}
        </h1>
        <a href="{{ path('app_management_reports_cert_readiness_pdf') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
            <i class="bi bi-file-pdf" aria-hidden="true"></i> {{ 'management_reports.action.download_pdf'|trans({}, 'management_reports') }}
        </a>
    </div>

    {# Readiness Score Overview #}
    <div class="row mb-4">
        <div class="col-md-4">
            {% embed '_components/_card.html.twig' with {
                'class': 'h-100 text-center ' ~ (recommendation == 'READY' ? 'border-success' : (recommendation == 'CONDITIONAL' ? 'border-warning' : 'border-danger'))
            } %}
                {% block card_body %}
                    <h3 class="display-4 fw-bold {% if recommendation == 'READY' %}text-success{% elseif recommendation == 'CONDITIONAL' %}text-warning{% else %}text-danger{% endif %}">
                        {{ overall_score }}%
                    </h3>
                    <p class="text-muted mb-2">{{ 'cert_readiness.overall_score'|trans({}, 'management_reports') }}</p>
                    <span class="badge fs-6 {% if recommendation == 'READY' %}bg-success{% elseif recommendation == 'CONDITIONAL' %}bg-warning-subtle text-warning{% else %}bg-danger{% endif %}">
                        {{ ('cert_readiness.recommendation.' ~ recommendation|lower)|trans({}, 'management_reports') }}
                    </span>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-4">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100' } %}
                {% block card_body %}
                    <h5>{{ 'cert_readiness.clause_compliance_score'|trans({}, 'management_reports') }}</h5>
                    <div class="progress progress-h-24 mb-2">
                        <div class="progress-bar {% if clause_score >= 80 %}bg-success{% elseif clause_score >= 60 %}bg-warning{% else %}bg-danger{% endif %}"
                             role="progressbar" style="width: {{ clause_score }}%"
                             aria-valuenow="{{ clause_score }}" aria-valuemin="0" aria-valuemax="100">
                            {{ clause_score }}%
                        </div>
                    </div>
                    <small class="text-muted">{{ 'cert_readiness.clauses_4_10'|trans({}, 'management_reports') }}</small>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-4">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100' } %}
                {% block card_body %}
                    <h5>{{ 'cert_readiness.annex_a_coverage'|trans({}, 'management_reports') }}</h5>
                    <div class="progress progress-h-24 mb-2">
                        <div class="progress-bar {% if control_percentage >= 80 %}bg-success{% elseif control_percentage >= 60 %}bg-warning{% else %}bg-danger{% endif %}"
                             role="progressbar" style="width: {{ control_percentage }}%"
                             aria-valuenow="{{ control_percentage }}" aria-valuemin="0" aria-valuemax="100">
                            {{ control_percentage }}%
                        </div>
                    </div>
                    <small class="text-muted">
                        {{ control_stats.implemented }} / {{ control_stats.total }} {{ 'cert_readiness.controls_implemented'|trans({}, 'management_reports') }}
                    </small>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    {# Section 1: Clause Compliance #}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4 shadow-sm' } %}
        {% block card_header %}
            <div class="card-header">
                <h3 class="h5 mb-0">
                    <i class="bi bi-list-check" aria-hidden="true"></i> {{ 'cert_readiness.section.clause_compliance'|trans({}, 'management_reports') }}
                </h3>
            </div>
        {% endblock %}
        {% block card_body %}
            {% if clause_compliance is not empty %}
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th scope="col">{{ 'cert_readiness.table.clause'|trans({}, 'management_reports') }}</th>
                            <th scope="col">{{ 'cert_readiness.table.score'|trans({}, 'management_reports') }}</th>
                            <th scope="col">{{ 'cert_readiness.table.status'|trans({}, 'management_reports') }}</th>
                            <th scope="col">{{ 'cert_readiness.table.gaps'|trans({}, 'management_reports') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for key, clause in clause_compliance %}
                        <tr>
                            <td>
                                <strong>{{ clause.name|trans({}, 'compliance') }}</strong>
                            </td>
                            <td>
                                <div class="progress" style="height: 20px; min-width: 100px;">
                                    <div class="progress-bar {% if clause.score >= 80 %}bg-success{% elseif clause.score >= 40 %}bg-warning{% else %}bg-danger{% endif %}"
                                         role="progressbar" style="width: {{ clause.score }}%"
                                         aria-valuenow="{{ clause.score }}" aria-valuemin="0" aria-valuemax="100">
                                        {{ clause.score }}%
                                    </div>
                                </div>
                            </td>
                            <td>
                                {% if clause.status == 'complete' %}
                                    <span class="fa-status-pill fa-status-pill--success">{{ 'cert_readiness.status.complete'|trans({}, 'management_reports') }}</span>
                                {% elseif clause.status == 'partial' %}
                                    <span class="fa-status-pill fa-status-pill--warning">{{ 'cert_readiness.status.partial'|trans({}, 'management_reports') }}</span>
                                {% else %}
                                    <span class="fa-status-pill fa-status-pill--danger">{{ 'cert_readiness.status.not_started'|trans({}, 'management_reports') }}</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if clause.gaps|length > 0 %}
                                    <span class="text-danger">{{ clause.gaps|length }} {{ 'cert_readiness.gaps_found'|trans({}, 'management_reports') }}</span>
                                {% else %}
                                    <span class="text-success"><i class="bi bi-check-circle" aria-hidden="true"></i></span>
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% else %}
            {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning', icon: 'bi-info-circle', class: 'mb-0' } } %}
                {% block alert_body %}{{ 'cert_readiness.no_iso_wizard'|trans({}, 'management_reports') }}{% endblock %}
            {% endembed %}
            {% endif %}
        {% endblock %}
    {% endembed %}

    {# Section 2: Annex A Control Coverage #}
    <div class="row mb-4">
        <div class="col-md-6">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100 shadow-sm' } %}
                {% block card_header %}
                    <div class="card-header">
                        <h3 class="h5 mb-0">
                            <i class="bi bi-shield-exclamation" aria-hidden="true"></i> {{ 'cert_readiness.section.controls_not_started'|trans({}, 'management_reports') }}
                            <span class="fa-status-pill fa-status-pill--neutral ms-2">{{ controls_not_started|length }}</span>
                        </h3>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {% if controls_not_started|length > 0 %}
                    <div class="list-group list-group-flush" style="max-height: 300px; overflow-y: auto;">
                        {% for control in controls_not_started %}
                        <div class="list-group-item list-group-item-action py-2">
                            <strong>{{ control.id }}</strong> - {{ control.title }}
                        </div>
                        {% endfor %}
                    </div>
                    {% else %}
                    <p class="text-success mb-0"><i class="bi bi-check-circle" aria-hidden="true"></i> {{ 'cert_readiness.all_controls_started'|trans({}, 'management_reports') }}</p>
                    {% endif %}
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-6">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100 shadow-sm' } %}
                {% block card_header %}
                    <div class="card-header">
                        <h3 class="h5 mb-0">
                            <i class="bi bi-clock-history" aria-hidden="true"></i> {{ 'cert_readiness.section.controls_in_progress'|trans({}, 'management_reports') }}
                            <span class="fa-status-pill fa-status-pill--neutral ms-2">{{ controls_in_progress|length }}</span>
                        </h3>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {% if controls_in_progress|length > 0 %}
                    <div class="list-group list-group-flush" style="max-height: 300px; overflow-y: auto;">
                        {% for control in controls_in_progress %}
                        <div class="list-group-item list-group-item-action py-2">
                            <strong>{{ control.id }}</strong> - {{ control.title }}
                        </div>
                        {% endfor %}
                    </div>
                    {% else %}
                    <p class="text-success mb-0"><i class="bi bi-check-circle" aria-hidden="true"></i> {{ 'cert_readiness.no_controls_in_progress'|trans({}, 'management_reports') }}</p>
                    {% endif %}
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    {# Section 4: Gap List #}
    {% if critical_gaps|length > 0 %}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4 shadow-sm border-danger' } %}
        {% block card_header %}
            <div class="card-header">
                <h3 class="h5 mb-0">
                    <i class="bi bi-exclamation-octagon" aria-hidden="true"></i> {{ 'cert_readiness.section.critical_gaps'|trans({}, 'management_reports') }}
                </h3>
            </div>
        {% endblock %}
        {% block card_body %}
            <ul class="list-group list-group-flush">
                {% for gap in critical_gaps %}
                <li class="list-group-item">
                    <i class="bi bi-x-circle text-danger" aria-hidden="true"></i>
                    <strong>{{ gap.name|default(gap.check|default('')) }}</strong>
                    {% if gap.description|default('') %}
                        <br><small class="text-muted">{{ gap.description }}</small>
                    {% endif %}
                </li>
                {% endfor %}
            </ul>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {% if recommended_improvements|length > 0 %}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4 shadow-sm' } %}
        {% block card_header %}
            <div class="card-header bg-body-secondary">
                <h3 class="h5 mb-0">
                    <i class="bi bi-lightbulb" aria-hidden="true"></i> {{ 'cert_readiness.section.recommended_improvements'|trans({}, 'management_reports') }}
                </h3>
            </div>
        {% endblock %}
        {% block card_body %}
            <ul class="list-group list-group-flush">
                {% for improvement in recommended_improvements[:20] %}
                <li class="list-group-item">
                    <i class="bi bi-arrow-right text-info" aria-hidden="true"></i>
                    {{ improvement.name|default(improvement.check|default('')) }}
                    {% if improvement.description|default('') %}
                        <br><small class="text-muted">{{ improvement.description }}</small>
                    {% endif %}
                </li>
                {% endfor %}
            </ul>
        {% endblock %}
    {% endembed %}
    {% endif %}
</div>
{% endblock %}
