{#
  Reusable Card Macros for Little-ISMS-Helper — Aurora v4 tokens

  WP-1a: Migrated from Bootstrap .card/.card-header/.card-body/.card-footer
  to FairyAurora fa-section / fa-feature-card / status-pill.
  shadow-sm and bg-* on headers removed (Aurora shadow tokens + CLAUDE.md §9 anti-pattern).

  Import in your templates with:
  {% import '_macros/cards.html.twig' as cards %}
#}

{% import '_components/_status_pill.html.twig' as pill %}

{#
  Health Status Card
  Used for: System health monitoring, service status displays

  Parameters:
  - title: Card title/heading
  - icon: Bootstrap icon class (without 'bi-' prefix)
  - status: Status value (e.g., 'healthy', 'warning', 'error')
  - border_color: Aurora tone for left-accent / border (e.g., 'success', 'danger')
  - content: HTML content for card body (use {% set %} block)
  - actions: Optional HTML for action buttons (use {% set %} block)
#}
{% macro status_card(title, icon, status, border_color, content, actions) %}
    <section class="fa-section fa-section--bordered fa-section--{{ border_color|default('neutral') }} h-100">
        <div class="fa-section__header">
            <h3 class="fa-section__title">
                <i class="bi bi-{{ icon }}" aria-hidden="true"></i> {{ title }}
            </h3>
        </div>
        <div class="fa-section__body">
            {{ content|raw }}
            {% if actions %}
                <div class="mt-3">
                    {{ actions|raw }}
                </div>
            {% endif %}
        </div>
    </section>
{% endmacro %}

{#
  Stat Card
  Used for: Dashboard KPI statistics, metric displays

  Parameters:
  - icon: Aurora icon class (full class with 'fa-icon fa-icon--…' or 'bi bi-…')
  - bg_color: Unused — Aurora variant is derived from the icon colour context.
              Pass variant as the colour name without 'bg-' prefix.
  - title: Card label text
  - value: Main value/number to display
  - change_icon: Bootstrap/Aurora icon for change indicator (optional)
  - change_text: Text for change indicator
  - change_type: 'positive', 'negative', or empty (used as Aurora hint tone)
#}
{% macro stat_card(icon, bg_color, title, value, change_icon, change_text, change_type) %}
    {% set variant = bg_color|default('')|replace({'bg-': ''}) %}
    {% set hintClass = change_type == 'positive' ? 'text-success' : (change_type == 'negative' ? 'text-danger' : 'text-muted') %}
    <article class="fa-feature-card fa-feature-card--{{ variant }}">
        {% if icon %}
            <div class="fa-feature-card__icon-chip" aria-hidden="true">
                <i class="{{ icon }}"></i>
            </div>
        {% endif %}
        <p class="fa-feature-card__label">{{ title }}</p>
        <div class="fa-feature-card__value-row">
            <span class="fa-feature-card__value">{{ value }}</span>
        </div>
        {% if change_text %}
            <p class="fa-feature-card__hint {{ hintClass }}">
                {% if change_icon %}
                    <i class="{{ change_icon }}" aria-hidden="true"></i>
                {% endif %}
                {{ change_text }}
            </p>
        {% endif %}
    </article>
{% endmacro %}

{#
  KPI Card
  @deprecated Use _fa_feature_card.html.twig directly instead.
  This macro remains for backward-compat only.

  Parameters:
  - title: Card title text
  - value: Main value to display
  - subtitle: Optional subtitle/description text
  - progress_value: Optional progress bar percentage (0-100)
  - progress_color: Optional Aurora tone for progress bar and text
  - border_class: Unused (Aurora handles borders via tokens)
#}
{% macro kpi_card(title, value, subtitle, progress_value, progress_color, border_class) %}
    <article class="fa-feature-card fa-feature-card--{{ progress_color|default('primary') }}">
        <p class="fa-feature-card__label">{{ title }}</p>
        <div class="fa-feature-card__value-row">
            <span class="fa-feature-card__value">{{ value }}</span>
        </div>
        {% if subtitle %}
            <p class="fa-feature-card__hint">{{ subtitle }}</p>
        {% endif %}
        {% if progress_value is not null %}
            <div class="progress progress-h-6 mt-2">
                <div class="progress-bar bg-{{ progress_color|default('primary') }}"
                     role="progressbar"
                     style="width: {{ progress_value }}%"
                     aria-valuenow="{{ progress_value }}"
                     aria-valuemin="0"
                     aria-valuemax="100"></div>
            </div>
        {% endif %}
    </article>
{% endmacro %}

{#
  Widget Card
  Used for: Dashboard widgets, chart containers, activity feeds

  Parameters:
  - widget_id: Unique widget identifier for dashboard customizer
  - title: Widget title text
  - icon: Bootstrap/Aurora icon class (full class)
  - actions: Optional HTML for header action buttons
  - content: HTML content for widget body
  - border_class: Optional Aurora border colour name (e.g., 'warning') — applied as text-<color> on title
  - header_bg_class: Unused — Aurora manages header backgrounds via tokens (CLAUDE.md §9)
  - badge_text: Optional badge text for header
  - badge_class: Optional badge colour variant (e.g., 'warning')
#}
{% macro widget_card(widget_id, title, icon, actions, content, border_class, header_bg_class, badge_text, badge_class) %}
    {% set titleColorClass = border_class ? 'text-' ~ border_class|replace({'border-': ''}) : '' %}
    <div class="widget-card mb-4{{ border_class ? ' border-' ~ border_class|replace({'border-': ''}) : '' }}"
         data-widget-id="{{ widget_id }}"
         data-dashboard-customizer-target="widget">
        <div class="widget-header">
            <h3 class="widget-title{{ titleColorClass ? ' ' ~ titleColorClass : '' }}">
                <i class="{{ icon }}" aria-hidden="true"></i>
                {{ title }}
            </h3>
            {% if badge_text %}
                {% include '_components/_badge.html.twig' with {
                    variant: badge_class|default('bg-secondary')|replace({'bg-': ''}),
                    content: badge_text
                } %}
            {% endif %}
            {% if actions %}
                <div class="widget-actions">
                    {{ actions|raw }}
                </div>
            {% endif %}
        </div>
        {{ content|raw }}
    </div>
{% endmacro %}

{#
  Report Card
  Used for: Report download cards with description and action buttons

  Parameters:
  - title: Report title
  - icon: Bootstrap icon class (without 'bi-' prefix)
  - header_bg: Unused — Aurora manages section backgrounds via tokens (CLAUDE.md §9)
  - header_text: Unused — text colour set via Aurora tokens
  - description: Report description text
  - features: Array or list of feature items
  - pdf_url: URL for PDF download
  - excel_url: URL for Excel download
#}
{% macro report_card(title, icon, header_bg, header_text, description, features, pdf_url, excel_url) %}
    <section class="fa-section h-100">
        <div class="fa-section__header">
            <h3 class="fa-section__title">
                <i class="bi bi-{{ icon }}" aria-hidden="true"></i> {{ title }}
            </h3>
        </div>
        <div class="fa-section__body">
            <p class="text-muted">{{ description }}</p>
            {% if features %}
                <ul class="small mb-3">
                    {% for feature in features %}
                        <li>{{ feature }}</li>
                    {% endfor %}
                </ul>
            {% endif %}
        </div>
        <div class="fa-section__footer">
            <div class="d-grid gap-2">
                {% if pdf_url %}
                    <a href="{{ pdf_url }}" class="fa-cyber-btn fa-cyber-btn--danger fa-cyber-btn--sm" data-turbo="false">
                        <i class="fa-icon fa-icon--nav-file-pdf" aria-hidden="true"></i> {{ 'reports.action.download_pdf'|trans({}, 'reports') }}
                    </a>
                {% endif %}
                {% if excel_url %}
                    <a href="{{ excel_url }}" class="fa-cyber-btn fa-cyber-btn--success fa-cyber-btn--sm" data-turbo="false">
                        <i class="fa-icon fa-icon--nav-file-check" aria-hidden="true"></i> {{ 'reports.action.download_excel'|trans({}, 'reports') }}
                    </a>
                {% endif %}
            </div>
        </div>
    </section>
{% endmacro %}

{#
  Simple Card
  Used for: Generic content cards, info boxes

  Parameters:
  - title: Card title/heading
  - icon: Optional Bootstrap icon class (without 'bi-' prefix)
  - content: HTML content for card body
  - footer: Optional HTML for card footer
  - header_class: Unused — Aurora manages section backgrounds via tokens (CLAUDE.md §9)
  - border_class: Unused — Aurora handles borders via tokens
  - actions: Optional HTML for header action buttons (rendered as fa-section__tools)
#}
{% macro simple_card(title, icon, content, footer, header_class, border_class, actions) %}
    <section class="fa-section">
        <div class="fa-section__header">
            <h3 class="fa-section__title">
                {% if icon %}
                    <i class="bi bi-{{ icon }}" aria-hidden="true"></i>
                {% endif %}
                {{ title }}
            </h3>
            {% if actions %}
                <div class="fa-section__tools">
                    {{ actions|raw }}
                </div>
            {% endif %}
        </div>
        <div class="fa-section__body">
            {{ content|raw }}
        </div>
        {% if footer %}
            <div class="fa-section__footer">
                {{ footer|raw }}
            </div>
        {% endif %}
    </section>
{% endmacro %}

