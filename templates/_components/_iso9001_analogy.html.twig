{#
  ISO-9001-Brücke: kurzer Inline-Hinweis für QMB/Neulinge.
  Varianten halten Analogie passend zum Kontext (Mapping, Seeds, Quality, …).

  Params:
    variant: 'mapping' | 'seeds' | 'quality' | 'reuse' | 'default'
#}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% set variant = variant|default('default') %}
{% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', class: 'small mb-3' } } %}
    {% block alert_body %}
    <div class="d-flex align-items-start gap-2">
        <i class="fa-icon fa-icon--ui-lightbulb text-warning" aria-hidden="true"></i>
        <div class="flex-grow-1">
            <strong>{{ 'compliance.iso9001_bridge.prefix'|trans({}, 'compliance') }}</strong>
            {{ ('compliance.iso9001_bridge.variant.' ~ variant)|trans({}, 'compliance') }}
            <a href="{{ path('app_help_iso9001_bridge') }}" class="fa-alert__link">
                {{ 'compliance.iso9001_bridge.more'|trans({}, 'compliance') }}
            </a>
        </div>
    </div>
    {% endblock %}
{% endembed %}
