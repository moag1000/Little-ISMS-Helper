{#
 # FairyAurora v4.0 — fa-empty-state macro (active variant)
 #
 # Coexists with the existing _empty_state.html.twig (include-pattern, passive).
 # This macro renders the "active" variant: Aurora-pattern surface background,
 # centered Alva SVG via _alva.html.twig, title, text, and CTA buttons.
 #
 # Usage:
 #   {% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
 #   {{ _fa_empty_state.render({
 #       mood:    'curious',
 #       title:   'Noch keine Dokumente',
 #       text:    'Laden Sie das erste Dokument hoch…',
 #       actions: [
 #           { label: 'Hochladen',      variant: 'primary', icon: 'upload',  href: '#' },
 #           { label: 'Vorlage wählen', variant: 'ghost',                    href: '#' }
 #       ]
 #   }) }}
 #
 # Parameters:
 #   mood    - Alva mood (idle|happy|thinking|focused|working|scanning|warning|celebrating|sleeping)
 #             default: 'thinking' (plan §21: "noch nichts angelegt")
 #   title   - heading text (required)
 #   text    - descriptive paragraph (optional)
 #   actions - array of { label, variant, icon?, href } (optional)
 #   alvaSize - Alva SVG size in px (default 96)
 #   class   - extra CSS classes on wrapper (optional)
 #   norm_ref      - ISO reference line (string, optional) — small muted text below description
 #   prerequisite  - warning text (string, optional) — alert above CTA buttons
 #   help_link     - URL for glossary link (string, optional) — ghost CTA button with ? icon
 #}

{% macro render(props = {}) %}
    {% set mood = props.mood|default('thinking') %}
    {% set actions = props.actions|default([]) %}

    <div class="fa-empty-state fa-empty-state--active{{ props.class is defined ? ' ' ~ props.class : '' }}"
         role="status">

        {# Alva character centered — Twig 3.x doesn't propagate file-top
           {% import %} into macros reliably, so we use {% include %}
           against _alva.html.twig's file-level body instead. #}
        <div class="fa-empty-state__alva">
            {% include '_components/_alva.html.twig' with {
                mood: mood,
                size: props.alvaSize|default(96),
                decorative: true
            } only %}
        </div>

        {# Title #}
        {% if props.title is defined and props.title %}
            <h3 class="fa-empty-state__title">{{ props.title }}</h3>
        {% endif %}

        {# Descriptive text #}
        {% if props.text is defined and props.text %}
            <p class="fa-empty-state__desc">{{ props.text }}</p>
        {% endif %}

        {# Norm reference #}
        {% if props.norm_ref is defined and props.norm_ref %}
            <p class="fa-empty-state__norm-ref text-muted small mb-2">
                <i class="bi bi-book" aria-hidden="true"></i> {{ props.norm_ref }}
            </p>
        {% endif %}

        {# Prerequisite warning #}
        {% if props.prerequisite is defined and props.prerequisite %}
            <div class="fa-empty-state__prereq alert alert-warning d-inline-flex align-items-center gap-2 mt-2 mb-3 py-2 px-3 small">
                <i class="bi bi-lock-fill" aria-hidden="true"></i>
                {{ props.prerequisite }}
            </div>
        {% endif %}

        {# CTA buttons #}
        {% if actions|length > 0 or (props.help_link is defined and props.help_link) %}
            <div class="fa-empty-state__actions">
                {% for action in actions %}
                    {% set variant = action.variant|default('primary') %}
                    <a href="{{ action.href|default('#') }}"
                       class="fa-cyber-btn fa-cyber-btn--{{ variant }}">
                        {% if action.icon is defined and action.icon %}
                            <i class="bi bi-{{ action.icon }}" aria-hidden="true"></i>
                        {% endif %}
                        <span class="fa-cyber-btn__label">{{ action.label }}</span>
                    </a>
                {% endfor %}
                {% if props.help_link is defined and props.help_link %}
                    <a href="{{ props.help_link }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                        <i class="bi bi-question-circle" aria-hidden="true"></i>
                        <span class="fa-cyber-btn__label">{{ 'common.learn_more'|trans({}, 'messages') }}</span>
                    </a>
                {% endif %}
            </div>
        {% endif %}
    </div>
{% endmacro %}
