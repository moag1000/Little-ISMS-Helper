{# Dashboard Customization Settings Modal #}

<div class="modal fade" id="dashboardSettingsModal" tabindex="-1" data-dashboard-customizer-target="settingsModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fa-icon fa-icon--nav-sliders" aria-hidden="true"></i> Dashboard anpassen
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'action.close'|trans({}, 'messages') }}"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-4">
                    Wählen Sie aus, welche Widgets auf Ihrem Dashboard angezeigt werden sollen.
                </p>

                <div class="widget-toggles">
                    <h6 class="mb-3">Statistik-Karten</h6>
                    <div class="form-check form-switch mb-3"
                         data-widget-toggle="stats-cards"
                         data-action="click->dashboard-customizer#toggleWidget">
                        <input class="form-check-input" type="checkbox" checked>
                        <label class="form-check-label">
                            <i class="fa-icon fa-icon--nav-bar-chart me-2 text-primary" aria-hidden="true"></i>
                            Statistik-Übersicht (Assets, Risks, Controls, Incidents)
                        </label>
                    </div>

                    <h6 class="mb-3 mt-4">Charts</h6>
                    <div class="form-check form-switch mb-3"
                         data-widget-toggle="risk-chart"
                         data-action="click->dashboard-customizer#toggleWidget">
                        <input class="form-check-input" type="checkbox" checked>
                        <label class="form-check-label">
                            <i class="fa-icon fa-icon--nav-pie-chart me-2 text-warning" aria-hidden="true"></i>
                            Risikoverteilung
                        </label>
                    </div>

                    <div class="form-check form-switch mb-3"
                         data-widget-toggle="asset-chart"
                         data-action="click->dashboard-customizer#toggleWidget">
                        <input class="form-check-input" type="checkbox" checked>
                        <label class="form-check-label">
                            <i class="fa-icon fa-icon--nav-bar-chart me-2 text-info" aria-hidden="true"></i>
                            Assets nach Kategorie
                        </label>
                    </div>

                    <h6 class="mb-3 mt-4">Widgets</h6>
                    <div class="form-check form-switch mb-3"
                         data-widget-toggle="activity-feed"
                         data-action="click->dashboard-customizer#toggleWidget">
                        <input class="form-check-input" type="checkbox" checked>
                        <label class="form-check-label">
                            <i class="fa-icon fa-icon--nav-activity me-2 text-success" aria-hidden="true"></i>
                            Letzte Aktivitäten
                        </label>
                    </div>

                    <div class="form-check form-switch mb-3"
                         data-widget-toggle="quick-actions"
                         data-action="click->dashboard-customizer#toggleWidget">
                        <input class="form-check-input" type="checkbox" checked>
                        <label class="form-check-label">
                            <i class="bi bi-lightning-fill me-2 text-warning" aria-hidden="true"></i>
                            Schnellzugriff
                        </label>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="fa-cyber-btn fa-cyber-btn--danger me-auto"
                        data-action="click->dashboard-customizer#resetToDefaults">
                    <i class="fa-icon fa-icon--ui-refresh" aria-hidden="true"></i> {{ 'common.reset'|trans({}, 'messages') }}
                </button>
                <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost" data-bs-dismiss="modal">
                    {{ 'common.close'|trans({}, 'messages') }}
                </button>
            </div>
        </div>
    </div>
</div>

<style>
.widget-toggles .form-check-label {
    cursor: pointer;
    display: flex;
    align-items: center;
    font-weight: 500;
}

.widget-toggles .form-check-input {
    cursor: pointer;
}

.widget-toggles h6 {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
}
</style>
