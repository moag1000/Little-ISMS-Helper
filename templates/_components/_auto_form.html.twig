{#
    Automatic Form Field Renderer

    This component automatically renders all form fields using the _form_field component.
    It intelligently groups fields by section and handles all field types.

    ──────────────────────────────────────────────────────────────────────────────
    BASIC USAGE (flat layout — default, backward-compatible)
    ──────────────────────────────────────────────────────────────────────────────

        {% include '_components/_auto_form.html.twig' with {
            'form': form,
            'sections': {
                'details': {
                    'label': 'supplier.section.details'|trans({}, 'suppliers'),
                    'fields': ['name', 'criticality', 'status', 'description', 'serviceProvided']
                },
                'contact': {
                    'label': 'supplier.section.contact_info'|trans({}, 'suppliers'),
                    'fields': ['contactPerson', 'email', 'phone', 'address']
                }
            },
            'col_widths': {
                'name': 4,
                'criticality': 4,
                'status': 4,
                'description': 12
            },
            'tooltips': {
                'probability': 'risk.tooltip.probability',
                'impact': 'risk.tooltip.impact'
            }
        } %}

    ──────────────────────────────────────────────────────────────────────────────
    OUTLINE-RAIL LAYOUT (opt-in, Phase-2)
    ──────────────────────────────────────────────────────────────────────────────

    Delegates to `_fa_form_layout` macro with an outline-rail sidebar + section
    cards. Recommended for large forms (15+ fields, 4–10 sections).
    Phase-3 will migrate existing FormTypes — DO NOT migrate in Phase-2.

        {% include '_components/_auto_form.html.twig' with {
            'form':     form,
            'layout':   'outline-rail',   {# 'flat' (default) | 'outline-rail' #}
            'eyebrow':  'GDPR Art. 35',   {# optional badge above title #}
            'title':    'DPIA',           {# used as form heading #}
            'subtitle': 'HR-Server 04',   {# optional sub-heading #}
            'sections': {
                'overview': {
                    'label': 'Overview',
                    'fields': ['name', 'description', 'status']
                },
                'details': {
                    'label': 'Details',
                    'fields': ['riskLevel', 'affectedData', 'measures']
                }
            },
            'actions': {
                'close':  { 'label': 'Cancel',        'variant': 'ghost' },
                'submit': { 'label': 'Save and close', 'variant': 'primary' }
            }
        } %}

    When `layout == 'outline-rail'`, section progress (done/current/pending)
    is computed automatically from `form[field].vars.value` emptiness.

    ──────────────────────────────────────────────────────────────────────────────
    ALL PARAMETERS
    ──────────────────────────────────────────────────────────────────────────────

    Common (both layouts):
    - form               (FormView, required)
    - sections           (map, optional) — section_key → {label, fields[]}
                          Auto-populated from SectionMapInterface if omitted.
    - col_widths         (map, optional) — field_name → Bootstrap col (1–12)
    - help_texts         (map, optional) — field_name → pre-translated help text
    - tooltips           (map, optional) — field_name → translation key
    - exclude            (array, optional) — field names to skip entirely
    - translation_domain (string, optional) — override tooltip translation domain
    - strict_whitelist   (bool, default false) — H-03: suppress catch-all bucket
    - automatic_fields   (array, optional) — fields marked as auto-populated

    Flat-only:
    - skip_other         (bool, default false) — suppress the catch-all section
    - other_section_label (string, optional) — label for catch-all section

    Outline-rail-only:
    - layout             ('flat'|'outline-rail', default 'flat')
    - eyebrow            (string, optional) — small-caps badge above title
    - title              (string, optional) — form heading (default 'Form')
    - subtitle           (string, optional) — sub-heading
    - actions            (map, optional) — {close, next, submit} action defs

    Note: Labels are taken from field.vars.label which is already translated
          by the FormType. Help texts must be provided pre-translated.
          Tooltips are translation keys that will be resolved at render time.

    H-03 Privilege-Escalation Hardening:
    The catch-all "Other fields" bucket renders every form-child not explicitly
    listed in `sections`. Sensitive fields like `permissions`, `roles`, `tenant`,
    `isActive` can leak through if a caller forgets to declare them. Use
    `strict_whitelist: true` to suppress the catch-all entirely. High-risk forms
    (admin/user/role/tenant) MUST set strict_whitelist: true.
#}

{# ─── Shared parameter initialisation ────────────────────────────────────── #}
{% set layout          = layout|default('flat') %}
{% set exclude_fields  = exclude|default([]) %}
{% set help_texts      = help_texts|default({}) %}
{% set tooltips        = tooltips|default({}) %}
{% set automatic_fields = automatic_fields|default([]) %}
{% set default_col_width = 12 %}
{% set passed_translation_domain = translation_domain|default(null) %}
{% set other_section_label = other_section_label|default('common.section.other'|trans({}, 'messages')) %}
{% set skip_other      = skip_other|default(false) %}

{# ─── H-03 Privilege-Escalation Hardening ───────────────────────────────── #}
{% set strict_whitelist = strict_whitelist|default(false) %}
{% if strict_whitelist %}
    {% set skip_other = true %}
{% endif %}

{# ─── S4 Foundation P-2 SectionPolicy ───────────────────────────────────── #}
{% set sections = sections|default(null) %}
{% if sections is null %}
    {% set _form_section_map = form_section_map(form) %}
    {% if _form_section_map is not null %}
        {% set sections = {} %}
        {% for section_key, field_list in _form_section_map %}
            {% set sections = sections|merge({
                (section_key): {
                    'label': ('form.section.' ~ section_key)|trans({}, 'messages'),
                    'fields': field_list,
                }
            }) %}
        {% endfor %}
    {% else %}
        {% set sections = {} %}
    {% endif %}
{% endif %}

{# Collect all field names listed in sections — for catch-all detection #}
{% set listed_fields = [] %}
{% for section in sections %}
    {% set listed_fields = listed_fields|merge(section.fields) %}
{% endfor %}

{# ════════════════════════════════════════════════════════════════════════════
   OUTLINE-RAIL LAYOUT
   Delegates entirely to _fa_form_layout macro with section bodies rendered
   via the _auto_form_section_body partial.
   ════════════════════════════════════════════════════════════════════════════ #}
{% if layout == 'outline-rail' %}
    {% import '_components/_fa_form_layout.html.twig' as _fa_form %}

    {# Build sections array for the macro, computing fill-progress per section #}
    {% set fa_form_sections = [] %}
    {% for section_key, section_def in sections %}
        {% set section_field_count = section_def.fields|length %}
        {% set section_filled = 0 %}
        {% for field_name in section_def.fields %}
            {% if form[field_name] is defined and form[field_name].vars.value is not empty %}
                {% set section_filled = section_filled + 1 %}
            {% endif %}
        {% endfor %}

        {# Derive status from fill ratio #}
        {% if section_filled == section_field_count and section_field_count > 0 %}
            {% set section_status = 'done' %}
        {% elseif section_filled > 0 %}
            {% set section_status = 'current' %}
        {% else %}
            {% set section_status = 'pending' %}
        {% endif %}

        {# Render section body via the shared partial #}
        {% set section_body %}
            {% include '_components/_auto_form_section_body.html.twig' with {
                'form':               form,
                'section_fields':     section_def.fields,
                'col_widths':         col_widths|default({}),
                'help_texts':         help_texts,
                'tooltips':           tooltips,
                'exclude_fields':     exclude_fields,
                'automatic_fields':   automatic_fields,
                'translation_domain': passed_translation_domain
            } %}
        {% endset %}

        {% set fa_form_sections = fa_form_sections|merge([{
            'id':     'sec-' ~ section_key,
            'title':  section_def.label,
            'status': section_status,
            'fields': section_field_count,
            'filled': section_filled,
            'body':   section_body
        }]) %}
    {% endfor %}

    {# Count done sections for progress bar #}
    {% set _done_count = 0 %}
    {% for sec in fa_form_sections %}
        {% if sec.status == 'done' %}
            {% set _done_count = _done_count + 1 %}
        {% endif %}
    {% endfor %}

    {# Build default actions if none provided #}
    {% set _default_actions = {
        'submit': { 'label': 'common.save'|trans({}, 'messages'), 'variant': 'primary' }
    } %}
    {% if actions is defined and actions %}
        {# Translate string labels in passed actions (close/next/submit) #}
        {% set _resolved_actions = {} %}
        {% for action_key, action_def in actions %}
            {% set _resolved_actions = _resolved_actions|merge({
                (action_key): action_def
            }) %}
        {% endfor %}
        {% set _actions = _resolved_actions %}
    {% else %}
        {% set _actions = _default_actions %}
    {% endif %}

    {{ _fa_form.render({
        'eyebrow':   eyebrow|default(null),
        'title':     title|default('Form'),
        'subtitle':  subtitle|default(null),
        'progress':  {
            'done':  _done_count,
            'total': fa_form_sections|length
        },
        'sections':  fa_form_sections,
        'actions':   _actions
    }) }}

{# ════════════════════════════════════════════════════════════════════════════
   FLAT LAYOUT (default) — original behaviour, zero regression risk
   ════════════════════════════════════════════════════════════════════════════ #}
{% else %}

    {% for section_key, section in sections %}
        <fieldset class="mb-4">
            <legend class="h5 mb-3">{{ section.label|raw }}</legend>

            {% include '_components/_auto_form_section_body.html.twig' with {
                'form':               form,
                'section_fields':     section.fields,
                'col_widths':         col_widths|default({}),
                'help_texts':         help_texts,
                'tooltips':           tooltips,
                'exclude_fields':     exclude_fields,
                'automatic_fields':   automatic_fields,
                'translation_domain': passed_translation_domain
            } %}
        </fieldset>
    {% endfor %}

    {# ─── Catch-all: render any form-field NOT listed in sections ─────────────
       Symfony's form_end() auto-renders unrendered fields via form_rest, which
       would land them AFTER the submit-button. Render them here under a final
       "Weitere Felder" fieldset so the form stays single-block.

       Skip via {skip_other: true} param if caller intentionally manages all
       fields (e.g. has its own form_widget calls outside this component).

       S4 P-2 SectionPolicy note: if the FormType implements SectionMapInterface,
       any field that ends up here is a leak — it means the section-map is out
       of sync with the builder. In dev-env we render a visible warning. CI-gate
       `scripts/quality/check_form_sections.py` enforces parity.
    #}
    {% set _has_section_map = form_section_map(form) is not null %}
    {% if not skip_other %}
        {% set other_fields = [] %}
        {% for child in form %}
            {% set child_name = child.vars.name %}
            {% if child_name not in listed_fields and child_name not in exclude_fields and child.vars.block_prefixes[1]|default('') != 'hidden' %}
                {% set other_fields = other_fields|merge([child_name]) %}
            {% endif %}
        {% endfor %}

        {% if other_fields|length > 0 %}
            <fieldset class="mb-4">
                <legend class="h5 mb-3">{{ other_section_label }}</legend>
                {% if _has_section_map and app.environment == 'dev' %}
                    <div class="alert alert-warning small mb-3" role="alert">
                        <strong>{{ 'form.section.warning.unmapped_title'|trans({}, 'messages') }}</strong>
                        {{ 'form.section.warning.unmapped_body'|trans({ '%fields%': other_fields|join(', ') }, 'messages') }}
                    </div>
                {% endif %}

                {% include '_components/_auto_form_section_body.html.twig' with {
                    'form':               form,
                    'section_fields':     other_fields,
                    'col_widths':         col_widths|default({}),
                    'help_texts':         help_texts,
                    'tooltips':           tooltips,
                    'exclude_fields':     exclude_fields,
                    'automatic_fields':   automatic_fields,
                    'translation_domain': passed_translation_domain
                } %}
            </fieldset>
        {% endif %}
    {% endif %}

    {# ─── H-03 dev-only visibility ───────────────────────────────────────────
       Show which fields are suppressed by strict_whitelist (privilege-escalation
       safeguard) OR rendered via the catch-all (potential leak risk). Dev only.
       Hidden in prod for performance + UX. #}
    {% if app.environment == 'dev' %}
        {% set _unmapped_fields = [] %}
        {% for child in form %}
            {% set child_name = child.vars.name %}
            {% set child_type = child.vars.block_prefixes[1]|default('') %}
            {% if child_name not in listed_fields
                and child_name not in exclude_fields
                and child_type != 'hidden'
                and child_name != '_token' %}
                {% set _unmapped_fields = _unmapped_fields|merge([child_name]) %}
            {% endif %}
        {% endfor %}
        {% if _unmapped_fields|length > 0 and strict_whitelist %}
            <div class="alert alert-info small mb-3" role="alert">
                <strong>[dev] H-03 strict whitelist:</strong>
                {{ _unmapped_fields|length }} field(s) suppressed
                (privilege-escalation safeguard):
                <code>{{ _unmapped_fields|join(', ') }}</code>.
                Add to a <code>sections</code> entry to render them.
            </div>
        {% elseif _unmapped_fields|length > 0 and not skip_other %}
            <div class="alert alert-warning small mb-3" role="alert">
                <strong>[dev] @todo H-03 section-policy:</strong>
                {{ _unmapped_fields|length }} field(s) rendered via catch-all
                (no section-policy whitelist):
                <code>{{ _unmapped_fields|join(', ') }}</code>.
                Privilege-escalation risk if any are sensitive (roles, permissions,
                tenant, isActive). Add to <code>sections</code> or pass
                <code>strict_whitelist: true</code>.
            </div>
        {% endif %}
    {% endif %}

{% endif %}{# end layout == 'flat' #}
