{#
    Automatic Form Field Renderer

    This component automatically renders all form fields using the _form_field component.
    It intelligently groups fields by section and handles all field types.

    Usage:
        {% include '_components/_auto_form.html.twig' with {
            'form': form,
            'sections': {
                'details': {
                    'label': 'supplier.section.details'|trans({}, 'suppliers'),
                    'fields': ['name', 'criticality', 'status', 'description', 'serviceProvided']
                },
                'contact': {
                    'label': 'supplier.section.contact_info'|trans({}, 'suppliers'),
                    'fields': ['contactPerson', 'email', 'phone', 'address']
                }
            },
            'col_widths': {
                'name': 4,
                'criticality': 4,
                'status': 4,
                'description': 12
            },
            'tooltips': {
                'probability': 'risk.tooltip.probability',
                'impact': 'risk.tooltip.impact'
            }
        } %}

    Parameters:
    - form: The Symfony form object
    - sections: Array of sections with labels and field names
    - col_widths: (Optional) Custom column widths for specific fields (default: 12 for full width)
    - help_texts: (Optional) Array of help texts for specific fields (field_name => translated help text)
    - tooltips: (Optional) Array of tooltip keys for specific fields (field_name => translation key)
    - exclude: (Optional) Array of field names to exclude from rendering

    Note: Labels are taken from field.vars.label which is already translated by the FormType.
          Help texts must be provided pre-translated via the help_texts parameter.
          Tooltips are translation keys that will be translated and shown as hover tooltips.
#}

{% set exclude_fields = exclude|default([]) %}
{% set help_texts = help_texts|default({}) %}
{% set tooltips = tooltips|default({}) %}
{% set automatic_fields = automatic_fields|default([]) %}
{% set default_col_width = 12 %}
{% set passed_translation_domain = translation_domain|default(null) %}
{% set other_section_label = other_section_label|default('common.section.other'|trans({}, 'messages')) %}
{% set skip_other = skip_other|default(false) %}

{# ─── H-03 Privilege-Escalation Hardening (Security) ────────────────────────
   The catch-all "Other fields" bucket renders EVERY form-child that is not
   explicitly listed in `sections`. Sensitive fields like `permissions`,
   `roles`, `tenant`, `isActive` can leak through if a caller forgets to
   add them to a section — attackers could then inject these via dev-tools.

   Callers MAY opt-in to strict whitelist mode via:
     {% include '_components/_auto_form.html.twig' with {
         strict_whitelist: true,   # H-03 — suppress catch-all entirely
         sections: { ... }
     } %}

   strict_whitelist implies skip_other: true. High-risk forms (admin/user/
   role/tenant) MUST set strict_whitelist: true. The dev-environment
   surfaces a warning when the catch-all is active and there are unmapped
   fields, so devs can incrementally adopt sections (see @todo H-03 markers).
#}
{% set strict_whitelist = strict_whitelist|default(false) %}
{% if strict_whitelist %}
    {% set skip_other = true %}
{% endif %}

{# ─── S4 Foundation P-2 SectionPolicy ───────────────────────────────────────
   If caller did not pass a `sections` dict explicitly, check if the FormType
   implements SectionMapInterface (form_section_map() returns non-null) and
   build the sections dict from `getSectionMap()`. Section labels resolve to
   the `form.section.<key>` translation key in `messages` domain.

   This makes regulatorily-critical fields (BCPlan RTO/RPO, BCExercise
   actualRtoAchieved/successCriteria, etc.) appear in well-defined sections
   instead of leaking into the catch-all "Sonstiges" bucket.
#}
{% set sections = sections|default(null) %}
{% if sections is null %}
    {% set _form_section_map = form_section_map(form) %}
    {% if _form_section_map is not null %}
        {% set sections = {} %}
        {% for section_key, field_list in _form_section_map %}
            {% set sections = sections|merge({
                (section_key): {
                    'label': ('form.section.' ~ section_key)|trans({}, 'messages'),
                    'fields': field_list,
                }
            }) %}
        {% endfor %}
    {% else %}
        {% set sections = {} %}
    {% endif %}
{% endif %}

{# Collect all field names listed in sections — for catch-all detection #}
{% set listed_fields = [] %}
{% for section in sections %}
    {% set listed_fields = listed_fields|merge(section.fields) %}
{% endfor %}

{% for section_key, section in sections %}
    <fieldset class="mb-4">
        <legend class="h5 mb-3">{{ section.label|raw }}</legend>

        {% set current_row_fields = [] %}
        {% set current_row_width = 0 %}

        {% for field_name in section.fields %}
            {% if field_name not in exclude_fields and form[field_name] is defined %}
                {% set field = form[field_name] %}
                {% set field_type = field.vars.block_prefixes[1]|default('text') %}
                {% set col_width = col_widths[field_name]|default(default_col_width) %}

                {# Handle checkbox fields separately #}
                {% if field_type == 'checkbox' %}
                    {# Flush current row if any #}
                    {% if current_row_fields|length > 0 %}
                        <div class="row">
                            {% for row_field in current_row_fields %}
                                {{ row_field|raw }}
                            {% endfor %}
                        </div>
                        {% set current_row_fields = [] %}
                        {% set current_row_width = 0 %}
                    {% endif %}

                    {# Render checkbox #}
                    <div class="row">
                        <div class="col-12">
                            <div class="form-check mb-3">
                                {{ form_widget(field, {'attr': {'class': 'form-check-input'}}) }}
                                {{ form_label(field, null, {'label_attr': {'class': 'form-check-label'}}) }}
                                {{ form_errors(field) }}
                            </div>
                        </div>
                    </div>
                {% else %}
                    {# Regular field - add to current row or start new row #}
                    {% if current_row_width + col_width > 12 %}
                        {# Start new row #}
                        <div class="row">
                            {% for row_field in current_row_fields %}
                                {{ row_field|raw }}
                            {% endfor %}
                        </div>
                        {% set current_row_fields = [] %}
                        {% set current_row_width = 0 %}
                    {% endif %}

                    {# Capture field HTML #}
                    {% set field_html %}
                        <div class="col-md-{{ col_width }}">
                            {% set help_key = help_texts[field_name]|default(null) %}
                            {% set tooltip_key = tooltips[field_name]|default(null) %}
                            {# Use passed translation_domain for tooltips, fallback to field's domain #}
                            {% set trans_domain = passed_translation_domain ? passed_translation_domain : field.vars.translation_domain|default('messages') %}
                            {% include '_components/_form_field.html.twig' with {
                                'field': field,
                                'label_key': field.vars.label,
                                'help_key': help_key,
                                'tooltip_key': tooltip_key,
                                'translation_domain': trans_domain,
                                'required': field.vars.required,
                                'automatic': field_name in automatic_fields
                            } %}
                        </div>
                    {% endset %}

                    {% set current_row_fields = current_row_fields|merge([field_html]) %}
                    {% set current_row_width = current_row_width + col_width %}
                {% endif %}
            {% endif %}
        {% endfor %}

        {# Flush remaining row #}
        {% if current_row_fields|length > 0 %}
            <div class="row">
                {% for row_field in current_row_fields %}
                    {{ row_field|raw }}
                {% endfor %}
            </div>
        {% endif %}
    </fieldset>
{% endfor %}

{# ─── Catch-all: render any form-field NOT listed in sections ──────────────
   Symfony's form_end() auto-renders unrendered fields via form_rest, which
   would land them AFTER the submit-button. Render them here under a final
   "Weitere Felder" fieldset so the form stays single-block.

   Skip via {skip_other: true} param if caller intentionally manages all
   fields (e.g. has its own form_widget calls outside this component).

   S4 P-2 SectionPolicy note: if the FormType implements SectionMapInterface,
   any field that ends up here is a leak — it means the section-map is out
   of sync with the builder. In dev-env we render a visible warning. CI-gate
   `scripts/quality/check_form_sections.py` enforces parity.
#}
{% set _has_section_map = form_section_map(form) is not null %}
{% if not skip_other %}
    {% set other_fields = [] %}
    {% for child in form %}
        {% set child_name = child.vars.name %}
        {% if child_name not in listed_fields and child_name not in exclude_fields and child.vars.block_prefixes[1]|default('') != 'hidden' %}
            {% set other_fields = other_fields|merge([child_name]) %}
        {% endif %}
    {% endfor %}

    {% if other_fields|length > 0 %}
        <fieldset class="mb-4">
            <legend class="h5 mb-3">{{ other_section_label }}</legend>
            {% if _has_section_map and app.environment == 'dev' %}
                <div class="alert alert-warning small mb-3" role="alert">
                    <strong>{{ 'form.section.warning.unmapped_title'|trans({}, 'messages') }}</strong>
                    {{ 'form.section.warning.unmapped_body'|trans({ '%fields%': other_fields|join(', ') }, 'messages') }}
                </div>
            {% endif %}
            {% set current_row_fields = [] %}
            {% set current_row_width = 0 %}
            {% for field_name in other_fields %}
                {% set field = form[field_name] %}
                {% set field_type = field.vars.block_prefixes[1]|default('text') %}
                {% set col_width = col_widths[field_name]|default(default_col_width) %}

                {% if field_type == 'checkbox' %}
                    {% if current_row_fields|length > 0 %}
                        <div class="row">
                            {% for row_field in current_row_fields %}{{ row_field|raw }}{% endfor %}
                        </div>
                        {% set current_row_fields = [] %}
                        {% set current_row_width = 0 %}
                    {% endif %}
                    <div class="row">
                        <div class="col-12">
                            <div class="form-check mb-3">
                                {{ form_widget(field, {'attr': {'class': 'form-check-input'}}) }}
                                {{ form_label(field, null, {'label_attr': {'class': 'form-check-label'}}) }}
                                {{ form_errors(field) }}
                            </div>
                        </div>
                    </div>
                {% else %}
                    {% if current_row_width + col_width > 12 %}
                        <div class="row">
                            {% for row_field in current_row_fields %}{{ row_field|raw }}{% endfor %}
                        </div>
                        {% set current_row_fields = [] %}
                        {% set current_row_width = 0 %}
                    {% endif %}
                    {% set field_html %}
                        <div class="col-md-{{ col_width }}">
                            {% set help_key = help_texts[field_name]|default(null) %}
                            {% set tooltip_key = tooltips[field_name]|default(null) %}
                            {% set trans_domain = passed_translation_domain ? passed_translation_domain : field.vars.translation_domain|default('messages') %}
                            {% include '_components/_form_field.html.twig' with {
                                'field': field,
                                'label_key': field.vars.label,
                                'help_key': help_key,
                                'tooltip_key': tooltip_key,
                                'translation_domain': trans_domain,
                                'required': field.vars.required,
                                'automatic': field_name in automatic_fields
                            } %}
                        </div>
                    {% endset %}
                    {% set current_row_fields = current_row_fields|merge([field_html]) %}
                    {% set current_row_width = current_row_width + col_width %}
                {% endif %}
            {% endfor %}
            {% if current_row_fields|length > 0 %}
                <div class="row">
                    {% for row_field in current_row_fields %}{{ row_field|raw }}{% endfor %}
                </div>
            {% endif %}
        </fieldset>
    {% endif %}
{% endif %}

{# ─── H-03 dev-only visibility ─────────────────────────────────────────────
   Show which fields are suppressed by strict_whitelist (privilege-escalation
   safeguard) OR rendered via the catch-all (potential leak risk). Dev only.
   Hidden in prod for performance + UX. #}
{% if app.environment == 'dev' %}
    {% set _unmapped_fields = [] %}
    {% for child in form %}
        {% set child_name = child.vars.name %}
        {% set child_type = child.vars.block_prefixes[1]|default('') %}
        {% if child_name not in listed_fields
            and child_name not in exclude_fields
            and child_type != 'hidden'
            and child_name != '_token' %}
            {% set _unmapped_fields = _unmapped_fields|merge([child_name]) %}
        {% endif %}
    {% endfor %}
    {% if _unmapped_fields|length > 0 and strict_whitelist %}
        <div class="alert alert-info small mb-3" role="alert">
            <strong>[dev] H-03 strict whitelist:</strong>
            {{ _unmapped_fields|length }} field(s) suppressed
            (privilege-escalation safeguard):
            <code>{{ _unmapped_fields|join(', ') }}</code>.
            Add to a <code>sections</code> entry to render them.
        </div>
    {% elseif _unmapped_fields|length > 0 and not skip_other %}
        <div class="alert alert-warning small mb-3" role="alert">
            <strong>[dev] @todo H-03 section-policy:</strong>
            {{ _unmapped_fields|length }} field(s) rendered via catch-all
            (no section-policy whitelist):
            <code>{{ _unmapped_fields|join(', ') }}</code>.
            Privilege-escalation risk if any are sensitive (roles, permissions,
            tenant, isActive). Add to <code>sections</code> or pass
            <code>strict_whitelist: true</code>.
        </div>
    {% endif %}
{% endif %}
