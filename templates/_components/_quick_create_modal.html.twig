{#
 # S14 Cluster A — Quick-Create Modal Partial (legacy, single-include shim)
 #
 # @deprecated 2026-05-25 Use the split partials directly:
 #   - `_quick_create_modal_trigger.html.twig` — render INSIDE the <form>
 #     (typically via the `extras_before_actions` slot of `_auto_form`)
 #   - `_quick_create_modal_dialog.html.twig`  — render OUTSIDE the <form>
 #     (nested <form> in HTML is invalid + breaks the controller)
 #
 # This shim keeps the original single-include API working for legacy
 # callers that render their entire form/modal block outside a parent
 # <form>, but emits the modal markup adjacent to the trigger — which
 # produces invalid HTML when included inside a <form>.
 #
 # New code MUST use the split partials.
 #
 # Required params:
 #   entityType       string  — slug for /api/quick-create/{entityType}
 #                              (allowed: 'asset', 'crisis-team', 'business-process')
 #   targetSelectId   string  — id of the parent <select> that should receive
 #                              the new option
 #   modalId          string  — unique DOM id for the fa-modal shell
 #
 # Optional params:
 #   triggerLabel     string  — label on the trigger button
 #   title            string  — modal title
 #   icon             string  — Aurora icon name (default 'plus-circle')
 #   placeholder      string  — input placeholder
 #}

{%- set entityType     = entityType|default('asset') -%}
{%- set targetSelectId = targetSelectId|default('') -%}
{%- set modalId        = modalId|default('quickCreate-' ~ random()) -%}
{%- set triggerLabel   = triggerLabel|default('quick_create.cta'|trans({}, 'quick_create')) -%}
{%- set title          = title|default('quick_create.modal.title'|trans({}, 'quick_create')) -%}
{%- set subtitle       = subtitle|default('quick_create.modal.subtitle'|trans({}, 'quick_create')) -%}
{%- set placeholder    = placeholder|default('quick_create.placeholder.name'|trans({}, 'quick_create')) -%}
{%- set icon           = icon|default('plus-circle') -%}

{% include '_components/_quick_create_modal_trigger.html.twig' with {
    entityType:     entityType,
    targetSelectId: targetSelectId,
    modalId:        modalId,
    triggerLabel:   triggerLabel,
} only %}

{% include '_components/_quick_create_modal_dialog.html.twig' with {
    entityType:     entityType,
    targetSelectId: targetSelectId,
    modalId:        modalId,
    title:          title,
    subtitle:       subtitle,
    icon:           icon,
    placeholder:    placeholder,
} only %}
