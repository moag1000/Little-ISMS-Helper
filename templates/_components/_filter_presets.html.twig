{# Smart Filter Presets Component
   Usage: {% include '_components/_filter_presets.html.twig' with {
       entity: 'risk',
       presets: [...]
   } %}
   
   Features:
   - One-click filtering
   - Visual indicators
   - Customizable presets
#}

{% set defaultPresets = {
    'risk': [
        { id: 'high', label: 'Hohe Risiken', icon: 'status-warning', color: 'danger', filter: 'level:high' },
        { id: 'unmitigated', label: 'Unbehandelt', icon: 'nav-shield-alert', color: 'warning', filter: 'status:identified' },
        { id: 'overdue', label: 'Überfällige Reviews', icon: 'nav-clock-history', color: 'danger', filter: 'overdue:true' },
        { id: 'critical', label: 'Kritisch', icon: 'status-critical', color: 'danger', filter: 'level:critical' }
    ],
    'asset': [
        { id: 'critical', label: 'Kritische Assets', icon: 'ui-star', color: 'danger', filter: 'criticality:high' },
        { id: 'unprotected', label: 'Ungeschützt', icon: 'nav-shield-alert', color: 'warning', filter: 'protected:false' },
        { id: 'high_risk', label: 'Hohes Risiko', icon: 'status-warning', color: 'danger', filter: 'risk:high' },
        { id: 'recent', label: 'Neu hinzugefügt', icon: 'plus', color: 'success', filter: 'recent:7d' }
    ],
    'incident': [
        { id: 'open', label: 'Offen', icon: 'status-critical', color: 'danger', filter: 'status:open' },
        { id: 'critical', label: 'Kritisch', icon: 'status-critical', color: 'danger', filter: 'severity:critical' },
        { id: 'recent', label: 'Letzte 7 Tage', icon: 'clock', color: 'warning', filter: 'recent:7d' },
        { id: 'unresolved', label: 'Ungelöst', icon: 'ui-hourglass', color: 'warning', filter: 'resolved:false' }
    ],
    'training': [
        { id: 'upcoming', label: 'Anstehend', icon: 'ui-calendar-event', color: 'primary', filter: 'upcoming:true' },
        { id: 'overdue', label: 'Überfällig', icon: 'status-warning', color: 'danger', filter: 'overdue:true' },
        { id: 'completed', label: 'Abgeschlossen', icon: 'status-ok', color: 'success', filter: 'status:completed' },
        { id: 'mandatory', label: 'Pflicht', icon: 'ui-star', color: 'warning', filter: 'mandatory:true' }
    ]
} %}

{% set activePresets = presets|default(defaultPresets[entity]|default([])) %}

{% if activePresets|length > 0 %}
<div class="filter-presets">
    <div class="filter-presets-header">
        <i class="fa-icon fa-icon--ui-funnel" aria-hidden="true"></i>
        <span>Schnellfilter:</span>
    </div>
    <div class="filter-presets-items">
        {% for preset in activePresets %}
        <button type="button"
                class="filter-preset-btn"
                data-filter="{{ preset.filter }}"
                data-preset-id="{{ preset.id }}"
                title="{{ preset.label }}">
            <i class="{{ preset.icon }} text-{{ preset.color }}"></i>
            <span>{{ preset.label }}</span>
        </button>
        {% endfor %}
        <button type="button"
                class="filter-preset-btn filter-preset-clear"
                data-action="click->filter#clear"
                title="{{ 'common.reset_all_filters'|trans({}, 'messages') }}">
            <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i>
            <span>{{ 'common.reset'|trans({}, 'messages') }}</span>
        </button>
    </div>
</div>
{% endif %}
