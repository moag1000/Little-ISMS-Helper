{#
 # @deprecated since 2026-05-07 — use canonical .bulk-action-bar pattern from
 # docs/design_system/sections/feedback-systems.html §175-255 instead.
 #
 # Migration guide:
 #   OLD: {% import '_components/_fa_bulk_action_bar.html.twig' as _fa_bulk_bar %}
 #        {{ _fa_bulk_bar.render({ actions: [...] }) }}
 #   NEW: {% include '_components/_bulk_action_bar.html.twig' with {
 #            actions: ['export', 'delete', 'approve', 'tag', 'assign']
 #        } %}
 #
 # This file is kept as a BC-bridge: callers using the legacy fa-bulk-action-bar
 # macro receive the canonical markup so visual + behavioral parity is preserved.
 # The legacy `.fa-bulk-action-bar*` CSS classes are no longer authoritative —
 # canonical CSS lives in `assets/styles/bulk-actions.css`. New code MUST use the
 # canonical macro `_bulk_action_bar.html.twig`.
 #
 # Targets emitted (Stimulus-compatible):
 #   data-fa-bulk-select-target="actionBar"   (legacy fa-bulk-select)
 #   data-bulk-actions-target="actionBar"     (canonical bulk-actions)
 #   data-fa-bulk-select-target="count"
 #   data-bulk-actions-target="count"
 #
 # A11y:
 #   - role="region", aria-live="polite", aria-atomic="true"
 #   - close-button has aria-label
 #}

{% macro render(props = {}) %}
    {% set actions       = props.actions|default([]) %}
    {% set label         = props.label|default('bulk_actions.selected'|trans({}, 'messages')) %}
    {% set deselectLabel = props.deselectLabel|default('bulk_actions.deselect'|trans({}, 'messages')) %}
    {% set initialHidden = props.initiallyHidden is defined ? props.initiallyHidden : true %}

    {# Canonical .bulk-action-bar (BC-bridge for legacy fa-bulk-action-bar callers) #}
    <div class="bulk-action-bar"
         data-fa-bulk-select-target="actionBar"
         data-bulk-actions-target="actionBar"
         {% if initialHidden %}hidden{% endif %}
         role="region"
         aria-live="polite"
         aria-atomic="true"
         aria-label="{{ 'bulk_actions.toolbar'|trans({}, 'messages') }}">

        <div class="bulk-selection-info">
            <span class="bulk-selection-count"
                  data-fa-bulk-select-target="count"
                  data-bulk-actions-target="count">0</span>
            <span class="bulk-selection-label">{{ label }}</span>
        </div>

        {% if actions|length > 0 %}
            <div class="bulk-action-divider" aria-hidden="true"></div>
            <div class="bulk-actions">
                {% for action in actions %}
                    {% set variant = action.variant|default('ghost') %}
                    {% set btnClass = 'bulk-action-btn' %}
                    {% if variant == 'success' %}
                        {% set btnClass = btnClass ~ ' bulk-action-btn-success' %}
                    {% elseif variant == 'danger' %}
                        {% set btnClass = btnClass ~ ' bulk-action-btn-danger' %}
                    {% endif %}
                    <button type="button"
                            class="{{ btnClass }}"
                            {% if action.dataAction is defined %}data-action="{{ action.dataAction }}"{% endif %}
                            {% if action.ariaLabel is defined %}aria-label="{{ action.ariaLabel }}"{% endif %}>
                        {% if action.icon is defined %}<i class="bi {{ action.icon }}" aria-hidden="true"></i> {% endif %}
                        {{ action.label }}
                    </button>
                {% endfor %}
            </div>
        {% endif %}

        <button type="button"
                class="bulk-action-close"
                aria-label="{{ deselectLabel }}"
                title="{{ deselectLabel }}"
                data-action="click->fa-bulk-select#deselectAll click->bulk-actions#deselectAll">
            <i class="bi bi-x" aria-hidden="true"></i>
        </button>
    </div>
{% endmacro %}
