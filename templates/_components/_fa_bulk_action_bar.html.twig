{#
 # Bulk-Action-Bar macro — Aurora v4 BC-bridge
 #
 # DEPRECATED 2026-05-11 — Use the plain include instead:
 #   {% include '_components/_bulk_action_bar.html.twig' with { actions: [...] } %}
 #
 # This macro is kept for unknown callers that import it. It now emits the
 # canonical BEM markup (.fa-bulk-bar* class set) regardless of the `variant`
 # prop, so even legacy callers automatically get the new look.
 #
 # Props:
 #   variant         'neutral' | 'brand'   default: 'neutral'
 #                   'brand' → .fa-bulk-bar.fa-bulk-bar--brand (gradient)
 #                   'neutral' → .fa-bulk-bar surface default
 #   actions         Array of action objects: { label, icon?, variant?, dataAction?, ariaLabel? }
 #   label           Translation-ready string for "N ausgewählt" label
 #   deselectLabel   Aria/title label for the close button
 #   initiallyHidden Boolean — whether to add hidden attr (default: true)
 #
 # Stimulus targets emitted (both aliases):
 #   data-fa-bulk-select-target="actionBar"
 #   data-bulk-actions-target="actionBar"
 #   data-fa-bulk-select-target="count"
 #   data-bulk-actions-target="count"
 #}

{% macro render(props = {}) %}
    {% set barVariant    = props.variant|default('neutral') %}
    {% set actions       = props.actions|default([]) %}
    {% set label         = props.label|default('bulk_actions.selected'|trans({}, 'messages')) %}
    {% set deselectLabel = props.deselectLabel|default('bulk_actions.deselect'|trans({}, 'messages')) %}
    {% set initialHidden = props.initiallyHidden is defined ? props.initiallyHidden : true %}

    {% set barClass = barVariant == 'brand' ? 'fa-bulk-bar fa-bulk-bar--brand' : 'fa-bulk-bar' %}

    <div class="{{ barClass }}"
         data-fa-bulk-select-target="actionBar"
         data-bulk-actions-target="actionBar"
         {% if initialHidden %}hidden{% endif %}
         role="region"
         aria-live="polite"
         aria-atomic="true"
         aria-label="{{ 'bulk_actions.toolbar'|trans({}, 'messages') }}">

        <div class="fa-bulk-bar__count">
            <span class="fa-bulk-bar__count-num"
                  data-fa-bulk-select-target="count"
                  data-bulk-actions-target="count">0</span>
            <span class="fa-bulk-bar__count-label">{{ label }}</span>
        </div>

        {% if actions|length > 0 %}
            <div class="fa-bulk-bar__divider" aria-hidden="true"></div>
            <div class="fa-bulk-bar__actions">
                {% for action in actions %}
                    {% set btnVariant = action.variant|default('ghost') %}
                    {% set btnClass = 'fa-bulk-btn' %}
                    {% if btnVariant == 'success' %}
                        {% set btnClass = btnClass ~ ' fa-bulk-btn--success' %}
                    {% elseif btnVariant == 'danger' %}
                        {% set btnClass = btnClass ~ ' fa-bulk-btn--danger' %}
                    {% elseif btnVariant == 'primary' %}
                        {% set btnClass = btnClass ~ ' fa-bulk-btn--primary' %}
                    {% endif %}
                    <button type="button"
                            class="{{ btnClass }}"
                            {% if action.dataAction is defined %}data-action="{{ action.dataAction }}"{% endif %}
                            {% if action.ariaLabel is defined %}aria-label="{{ action.ariaLabel }}"{% endif %}>
                        {# Auto-strip legacy bi- prefix so DB/YAML values keep working. #}
                        {% if action.icon is defined %}<i class="fa-icon fa-icon--{{ (action.icon starts with 'bi-') ? action.icon[3:] : action.icon }}" aria-hidden="true"></i>{% endif %}
                        {{ action.label }}
                    </button>
                {% endfor %}
            </div>
        {% endif %}

        <div class="fa-bulk-bar__divider" aria-hidden="true"></div>
        <button type="button"
                class="fa-bulk-bar__close"
                aria-label="{{ deselectLabel }}"
                title="{{ deselectLabel }}"
                data-action="click->fa-bulk-select#deselectAll click->bulk-actions#deselectAll">
            <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i>
        </button>
    </div>
{% endmacro %}
