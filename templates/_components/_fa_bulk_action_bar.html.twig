{#
 # Bulk-Action-Bar macro — Aurora v4
 #
 # Renders a floating bulk-action bar. Two variants:
 #
 #   'brand'   (default) — canonical gradient bar (.bulk-action-bar, used by the
 #             Stimulus bulk-actions controller). Backward-compatible with all
 #             existing callers. Keeps `.bulk-action-bar` class so Stimulus
 #             controller selectors remain unchanged.
 #
 #   'neutral' — neutral surface bar (.fa-bulk-bar) per the Aurora v4 DS
 #             (docs/design_system/previews/bulk-action-bar.html). Uses the new
 #             fa-bulk-bar / fa-bulk-btn class set. Choose for general-purpose
 #             lists where the gradient bar would be too prominent.
 #
 # Props:
 #   variant         'brand' | 'neutral'   default: 'brand'
 #   actions         Array of action objects: { label, icon?, variant?, dataAction?, ariaLabel? }
 #   label           Translation-ready string for "N ausgewählt" label
 #   deselectLabel   Aria/title label for the close button
 #   initiallyHidden Boolean — whether to add hidden attr (default: true)
 #   brandVariant    'brand' (gradient) | '' — for neutral bars, add .fa-bulk-bar--brand
 #                   to get the gradient effect on the fa-bulk-bar class set (optional)
 #
 # Targets emitted (Stimulus-compatible):
 #   data-fa-bulk-select-target="actionBar"   (legacy fa-bulk-select controller)
 #   data-bulk-actions-target="actionBar"     (canonical bulk-actions controller)
 #   data-fa-bulk-select-target="count"
 #   data-bulk-actions-target="count"
 #
 # A11y:
 #   - role="region", aria-live="polite", aria-atomic="true"
 #   - close-button has aria-label
 #}

{% macro render(props = {}) %}
    {% set barVariant   = props.variant|default('brand') %}
    {% set actions      = props.actions|default([]) %}
    {% set label        = props.label|default('bulk_actions.selected'|trans({}, 'messages')) %}
    {% set deselectLabel = props.deselectLabel|default('bulk_actions.deselect'|trans({}, 'messages')) %}
    {% set initialHidden = props.initiallyHidden is defined ? props.initiallyHidden : true %}

    {% if barVariant == 'neutral' %}
        {# ── Neutral-surface variant (.fa-bulk-bar class set) ── #}
        {% set barExtraClass = props.brandVariant is defined and props.brandVariant == 'brand' ? ' fa-bulk-bar--brand' : '' %}
        <div class="fa-bulk-bar{{ barExtraClass }}"
             data-fa-bulk-select-target="actionBar"
             data-bulk-actions-target="actionBar"
             {% if initialHidden %}hidden{% endif %}
             role="region"
             aria-live="polite"
             aria-atomic="true"
             aria-label="{{ 'bulk_actions.toolbar'|trans({}, 'messages') }}">

            <div class="fa-bulk-bar__count">
                <span class="fa-bulk-bar__count-num"
                      data-fa-bulk-select-target="count"
                      data-bulk-actions-target="count">0</span>
                <span class="fa-bulk-bar__count-label">{{ label }}</span>
            </div>

            {% if actions|length > 0 %}
                <div class="fa-bulk-bar__divider" aria-hidden="true"></div>
                <div class="fa-bulk-bar__actions">
                    {% for action in actions %}
                        {% set btnVariant = action.variant|default('ghost') %}
                        {% set btnClass = 'fa-bulk-btn' %}
                        {% if btnVariant == 'success' %}
                            {% set btnClass = btnClass ~ ' fa-bulk-btn--success' %}
                        {% elseif btnVariant == 'danger' %}
                            {% set btnClass = btnClass ~ ' fa-bulk-btn--danger' %}
                        {% elseif btnVariant == 'primary' %}
                            {% set btnClass = btnClass ~ ' fa-bulk-btn--primary' %}
                        {% endif %}
                        <button type="button"
                                class="{{ btnClass }}"
                                {% if action.dataAction is defined %}data-action="{{ action.dataAction }}"{% endif %}
                                {% if action.ariaLabel is defined %}aria-label="{{ action.ariaLabel }}"{% endif %}>
                            {% if action.icon is defined %}<i class="bi {{ action.icon }}" aria-hidden="true"></i>{% endif %}
                            {{ action.label }}
                        </button>
                    {% endfor %}
                </div>
            {% endif %}

            <div class="fa-bulk-bar__divider" aria-hidden="true"></div>
            <button type="button"
                    class="fa-bulk-bar__close"
                    aria-label="{{ deselectLabel }}"
                    title="{{ deselectLabel }}"
                    data-action="click->fa-bulk-select#deselectAll click->bulk-actions#deselectAll">
                <i class="bi bi-x-lg" aria-hidden="true"></i>
            </button>
        </div>

    {% else %}
        {# ── Brand/gradient variant (.bulk-action-bar — canonical, default) ── #}
        {# Stimulus controller selectors unchanged: data-bulk-actions-target="actionBar" #}
        <div class="bulk-action-bar"
             data-fa-bulk-select-target="actionBar"
             data-bulk-actions-target="actionBar"
             {% if initialHidden %}hidden{% endif %}
             role="region"
             aria-live="polite"
             aria-atomic="true"
             aria-label="{{ 'bulk_actions.toolbar'|trans({}, 'messages') }}">

            <div class="bulk-selection-info">
                <span class="bulk-selection-count"
                      data-fa-bulk-select-target="count"
                      data-bulk-actions-target="count">0</span>
                <span class="bulk-selection-label">{{ label }}</span>
            </div>

            {% if actions|length > 0 %}
                <div class="bulk-action-divider" aria-hidden="true"></div>
                <div class="bulk-actions">
                    {% for action in actions %}
                        {% set btnVariant = action.variant|default('ghost') %}
                        {% set btnClass = 'bulk-action-btn' %}
                        {% if btnVariant == 'success' %}
                            {% set btnClass = btnClass ~ ' bulk-action-btn-success' %}
                        {% elseif btnVariant == 'danger' %}
                            {% set btnClass = btnClass ~ ' bulk-action-btn-danger' %}
                        {% endif %}
                        <button type="button"
                                class="{{ btnClass }}"
                                {% if action.dataAction is defined %}data-action="{{ action.dataAction }}"{% endif %}
                                {% if action.ariaLabel is defined %}aria-label="{{ action.ariaLabel }}"{% endif %}>
                            {% if action.icon is defined %}<i class="bi {{ action.icon }}" aria-hidden="true"></i> {% endif %}
                            {{ action.label }}
                        </button>
                    {% endfor %}
                </div>
            {% endif %}

            <button type="button"
                    class="bulk-action-close"
                    aria-label="{{ deselectLabel }}"
                    title="{{ deselectLabel }}"
                    data-action="click->fa-bulk-select#deselectAll click->bulk-actions#deselectAll">
                <i class="bi bi-x" aria-hidden="true"></i>
            </button>
        </div>
    {% endif %}
{% endmacro %}
