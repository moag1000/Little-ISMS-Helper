{#
    Reusable Bulk Delete Confirmation Dialog — Aurora fa-modal shell (2026-05-21)

    WCAG 2.1 AA compliant. Wraps existing dynamic-content + inline-script
    inside the canonical .fa-modal shell. JS reuses fa-modal:request-open /
    fa-modal#close dispatch instead of new bootstrap.Modal().

    Usage:
        {% include '_components/_bulk_delete_modal.html.twig' with {
            'entity_name': 'Assets',
            'entity_name_plural': 'Assets',
            'delete_route': 'app_asset_bulk_delete',
            'dependencies_info': 'Risks and Controls may be affected'
        } %}
#}

{% set entity_lower = entity_name|lower %}
{% set modal_id = 'bulkDelete' ~ entity_name ~ 'Modal' %}

<div class="fa-modal fa-modal--confirm fa-modal--danger"
     id="{{ modal_id }}"
     data-controller="fa-modal"
     data-fa-modal-mode-value="confirm"
     data-fa-modal-tone-value="danger"
     role="alertdialog"
     aria-modal="true"
     aria-labelledby="{{ modal_id }}Label"
     aria-hidden="true">

    <div class="fa-modal__backdrop"
         data-fa-modal-target="backdrop"
         data-action="click->fa-modal#backdropClick"
         aria-hidden="true"></div>

    <div class="fa-modal__container" data-fa-modal-target="dialog">

        <header class="fa-modal__header">
            <span class="fa-modal__icon" aria-hidden="true">
                <i class="fa-icon fa-icon--status-warning"></i>
            </span>
            <div class="fa-modal__heading">
                <h2 class="fa-modal__title" id="{{ modal_id }}Label">
                    {{ 'bulk_delete.confirm.title'|trans({}, 'bulk_delete') }}
                </h2>
            </div>
            <button type="button"
                    class="fa-modal__close"
                    aria-label="{{ 'action.close'|trans({}, 'messages') }}"
                    data-action="fa-modal#cancel">
                <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i>
            </button>
        </header>

        <div class="fa-modal__body">
            <div class="fa-alert fa-alert--danger" role="alert">
                <p class="mb-2">
                    <strong>{{ 'bulk_delete.warning'|trans({}, 'bulk_delete') }}:</strong>
                    <span id="{{ modal_id }}SelectedCount">0</span>
                    {{ entity_name_plural|default(entity_name) }}
                    {{ 'bulk_delete.will_be_deleted'|trans({}, 'bulk_delete') }}
                </p>

                {% if dependencies_info is defined and dependencies_info %}
                    <p class="mb-0 small">
                        <i class="fa-icon fa-icon--ui-info" aria-hidden="true"></i>
                        {{ dependencies_info }}
                    </p>
                {% endif %}
            </div>

            <div class="mb-3">
                <h6>{{ 'bulk_delete.selected_items'|trans({}, 'bulk_delete') }}:</h6>
                <div id="{{ modal_id }}ItemsList"
                     class="border rounded p-2 bg-body-secondary"
                     style="max-height: 200px; overflow-y: auto;"
                     role="region"
                     aria-label="{{ 'bulk_delete.selected_items'|trans({}, 'bulk_delete') }}">
                </div>
            </div>

            <div class="form-check">
                <input class="form-check-input"
                       type="checkbox"
                       id="{{ modal_id }}Confirm"
                       aria-required="true"
                       aria-describedby="{{ modal_id }}ConfirmHelp">
                <label class="form-check-label" for="{{ modal_id }}Confirm">
                    {{ 'bulk_delete.understand'|trans({}, 'bulk_delete') }}
                </label>
                <div id="{{ modal_id }}ConfirmHelp" class="form-text">
                    {{ 'bulk_delete.confirm_help'|trans({}, 'bulk_delete') }}
                </div>
            </div>
        </div>

        <footer class="fa-modal__footer">
            <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost" data-action="fa-modal#cancel">
                <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i>
                {{ 'action.cancel'|trans({}, 'messages') }}
            </button>
            <button type="button"
                    class="fa-cyber-btn fa-cyber-btn--danger"
                    id="{{ modal_id }}ConfirmButton"
                    disabled
                    data-delete-route="{{ delete_route }}"
                    aria-describedby="{{ modal_id }}ConfirmHelp">
                <i class="fa-icon fa-icon--ui-trash" aria-hidden="true"></i>
                {{ 'action.delete_selected'|trans({}, 'messages') }}
            </button>
        </footer>
    </div>
</div>

{# Inline behavior: opens via window.showBulkDeleteModal(ids, items). #}
<script>
(function() {
    const modalId = '{{ modal_id }}';
    const modal = document.getElementById(modalId);
    const confirmCheckbox = document.getElementById(modalId + 'Confirm');
    const confirmButton = document.getElementById(modalId + 'ConfirmButton');
    const selectedCountSpan = document.getElementById(modalId + 'SelectedCount');
    const itemsList = document.getElementById(modalId + 'ItemsList');

    let selectedIds = [];

    confirmCheckbox?.addEventListener('change', function() {
        if (confirmButton) {
            confirmButton.disabled = !this.checked;
        }
    });

    confirmButton?.addEventListener('click', async function() {
        if (selectedIds.length === 0) return;

        const deleteRoute = this.dataset.deleteRoute;
        const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content;

        try {
            const response = await fetch(deleteRoute, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-Token': csrfToken,
                },
                body: JSON.stringify({ ids: selectedIds }),
            });

            if (response.ok) {
                const app = window.Stimulus;
                if (app && modal) {
                    const ctl = app.getControllerForElementAndIdentifier(modal, 'fa-modal');
                    ctl?.close();
                }
                showSuccessMessage(selectedIds.length + ' {{ entity_name_plural|default(entity_name)|lower }} deleted successfully');
                setTimeout(() => window.location.reload(), 1000);
            } else {
                const error = await response.text();
                showErrorMessage('Error deleting items: ' + error);
            }
        } catch (error) {
            showErrorMessage('Error: ' + error.message);
        }
    });

    window.showBulkDeleteModal = function(ids, items) {
        selectedIds = ids;

        if (selectedCountSpan) selectedCountSpan.textContent = ids.length;

        if (itemsList) {
            itemsList.innerHTML = '<ul class="mb-0">' +
                items.map(item => `<li>${escapeHtml(item)}</li>`).join('') +
                '</ul>';
        }

        if (confirmCheckbox) confirmCheckbox.checked = false;
        if (confirmButton) confirmButton.disabled = true;

        document.dispatchEvent(new CustomEvent('fa-modal:request-open', {
            bubbles: true,
            detail: { id: modalId },
        }));

        modal?.addEventListener('fa-modal:opened', function onOpened() {
            confirmCheckbox?.focus();
        }, { once: true });
    };

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function showSuccessMessage(message) { showFlashMessage(message, 'success'); }
    function showErrorMessage(message)   { showFlashMessage(message, 'danger'); }

    function showFlashMessage(message, type) {
        const alertDiv = document.createElement('div');
        alertDiv.className = `fa-alert fa-alert--${type}`;
        alertDiv.setAttribute('role', 'alert');
        alertDiv.innerHTML = `
            ${message}
            <button type="button" class="fa-alert__dismiss" aria-label="{{ 'common.close'|trans({}, 'messages') }}">×</button>
        `;
        const container = document.querySelector('.container-fluid') || document.body;
        container.insertBefore(alertDiv, container.firstChild);
        setTimeout(() => alertDiv.remove(), 5000);
    }
})();
</script>
