{#
 # FairyAurora v4 — Norm-Bridge Macro (Audit-S5 P-12)
 #
 # Renders an unobtrusive cross-norm hint underneath a form-field label so a
 # user coming from ISO 9001 / ISO 14001 / other QM-systems can instantly
 # recognise a familiar term (e.g. "Interested Party → Stakeholder").
 #
 # Visibility:
 #   - Default ('subtle'): only rendered when the current user opted-in via
 #     User.previousQmsBackground == 'iso_9001'.
 #   - 'always_visible': rendered for every user (use for high-impact bridges
 #     such as Risk-Threat → ISO 9001 8.5.6).
 #
 # The macro deliberately renders nothing when no user is available (CLI,
 # anonymous routes) so it is safe to drop into any template.
 #
 # Usage:
 #   {% import '_components/_fa_norm_bridge.html.twig' as _fa_norm_bridge %}
 #   {{ _fa_norm_bridge.render({
 #       from_norm: 'ISO 27001',
 #       to_norm:   'ISO 9001 4.2',
 #       bridge_text: ('interested_parties.iso_9001_bridge.party'|trans({}, 'interested_parties')),
 #       prominence: 'subtle',
 #   }) }}
 #
 # Props:
 #   from_norm    string  — Source norm label, e.g. 'ISO 27001'
 #   to_norm      string  — Target norm label, e.g. 'ISO 9001 4.2'
 #   bridge_text  string  — Pre-translated bridge text (caller handles trans)
 #   prominence   string  — 'subtle' (default) | 'always_visible'
 #}
{% macro render(props) %}
    {%- set _prominence = props.prominence|default('subtle') -%}
    {%- set _userBg = app.user is not null and app.user.previousQmsBackground is defined
                        ? app.user.previousQmsBackground : null -%}
    {%- set _show = _prominence == 'always_visible' or _userBg in ['iso_9001', 'iso_14001', 'other'] -%}
    {%- if _show -%}
        <small class="fa-norm-bridge fa-norm-bridge--{{ _prominence }}"
               role="note"
               aria-label="{{ props.from_norm }} → {{ props.to_norm }}">
            <i class="fa-icon fa-icon--ui-link fa-norm-bridge__icon" aria-hidden="true"></i>
            <strong class="fa-norm-bridge__norms">{{ props.from_norm }} → {{ props.to_norm }}:</strong>
            <span class="fa-norm-bridge__text">{{ props.bridge_text }}</span>
        </small>
    {%- endif -%}
{% endmacro %}
