{#
  FairyAurora v3→v4 Bridge — delegates to _fa_empty_state macro.

  Usage (unchanged — backward-compatible):
  {% include '_components/_empty_state.html.twig' with {
      mood: 'thinking',
      title: 'Noch keine Assets vorhanden',
      description: 'Legen Sie Ihr erstes Asset an, um zu beginnen.',
      action: { label: 'Asset erstellen', url: path('app_asset_new'), icon: 'bi-plus-circle' }
  } %}

  New code should use _fa_empty_state.html.twig directly (macro pattern).
#}

{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}

{% set _actions = [] %}
{% if action is defined and is_granted('ROLE_USER') %}
    {% set _icon = action.icon|default('bi-plus-circle') %}
    {# Strip 'bi-' prefix — v4 macro adds it back #}
    {% if _icon starts with 'bi-' %}
        {% set _icon = _icon[3:] %}
    {% endif %}
    {% set _actions = _actions|merge([{ label: action.label, variant: 'primary', icon: _icon, href: action.url }]) %}
    {% if secondary is defined %}
        {% set _sec_icon = secondary.icon|default(null) %}
        {% if _sec_icon and _sec_icon starts with 'bi-' %}
            {% set _sec_icon = _sec_icon[3:] %}
        {% endif %}
        {% set _actions = _actions|merge([{ label: secondary.label, variant: 'ghost', icon: _sec_icon, href: secondary.url }]) %}
    {% endif %}
{% endif %}

{{ _fa_empty_state.render({
    mood: mood|default('thinking'),
    title: title|default(''),
    text: description|default(null),
    actions: _actions,
    alvaSize: alvaSize|default(80)
}) }}
