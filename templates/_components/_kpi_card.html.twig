{#
  ⚠️ DEPRECATED (Aurora v4.0) — use `fa-feature-card` instead.

  Replacement pattern:
    {% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}
    {{ _fa_feature_card.render({
        label: 'Offene Risiken',
        value: 12,
        icon: 'shield-exclamation',       {# no 'bi-' prefix #}
        variant: 'primary',
        hint: '+3 seit letzter Woche',
        href: '/risk'
    }) }}

  Field mapping (legacy → fa-feature-card):
    icon        → icon (drop 'bi-' prefix)
    trend       → hint (prepend ↑/↓ Unicode for direction)
    detail      → hint
    link        → href
    info/secondary variants → primary
  See `/dev/design-system` for live preview + full macro API.

  This legacy include still works for backward compat but emits a deprecation
  warning in dev env. Scheduled removal: Aurora v5.

  FairyAurora KPI Card — Aurora-Pattern mit Mono-Label + Big-Sans-Value + Delta-Chip + Sparkline

  Usage (Minimal):
  {% include '_components/_kpi_card.html.twig' with {
      label: 'Offene Risiken',
      value: 12
  } %}

  Usage (Voll):
  {% include '_components/_kpi_card.html.twig' with {
      icon: 'bi-shield-exclamation',
      label: 'Offene Risiken',
      value: 12,
      unit: '',
      trend: '+3',
      delta: { value: '+3', direction: 'up', tone: 'danger' },
      hint: 'seit letzter Woche',
      sparkline: [8, 9, 11, 10, 12, 12, 12],
      variant: 'primary',
      emphasis: true,
      link: '/risk'
  } %}

  Parameter:
    label      - Mono-uppercase Label (required)
    value      - Big value (required)
    unit       - Optionale Einheit neben dem Value
    icon       - bi-* icon class (optional)
    trend      - Legacy-Text "+12%" / "-3" (fallback, wenn delta nicht gesetzt)
    delta      - { value: '+3', direction: 'up'|'down', tone: 'success'|'danger'|'neutral' }
    hint       - Sub-Text unter Delta (z.B. "seit letzter Woche")
    sparkline  - array of numbers → SVG-Sparkline
    variant    - primary|accent|success|warning|danger (default: primary) — Delta-Farbe + Accent-Strip
    emphasis   - boolean → Top-Gradient-Line + primary-glow-shadow
    link       - Optional URL → macht Card klickbar mit Arrow-Icon
    detail     - Legacy-Detail-Text (rendered wenn gesetzt)
#}

{% import '_components/_sparkline.html.twig' as spark %}

{% set variant = variant|default('primary') %}
{% set icon = icon|default(null) %}
{% set trend = trend|default(null) %}
{% set delta = delta|default(null) %}
{% set hint = hint|default(null) %}
{% set unit = unit|default('') %}
{% set link = link|default(null) %}
{% set detail = detail|default(null) %}
{% set emphasis = emphasis|default(false) %}
{% set sparkline = sparkline|default(null) %}

{# Auto-derive delta from legacy trend string if delta not explicitly given #}
{% if trend and not delta %}
    {% set direction = trend starts with '-' ? 'down' : 'up' %}
    {% set tone = direction == 'up' ? 'success' : 'danger' %}
    {% set delta = { value: trend, direction: direction, tone: tone } %}
{% endif %}

<div class="fa-kpi-card kpi-card kpi-card-{{ variant }} fa-kpi-card--{{ variant }} {% if emphasis %}fa-kpi-card--emphasis{% endif %} {% if link %}fa-kpi-card--linked{% endif %}">
    {% if emphasis %}<span class="fa-kpi-card__topline" aria-hidden="true"></span>{% endif %}

    {% if icon %}
        <div class="fa-kpi-card__icon kpi-card-icon" aria-hidden="true">
            <i class="bi {{ icon }}"></i>
        </div>
    {% endif %}

    <div class="fa-kpi-card__body kpi-card-content">
        <div class="fa-kpi-card__label kpi-card-label">{{ label }}</div>

        <div class="fa-kpi-card__value kpi-card-value">
            <span class="fa-kpi-card__number">{{ value }}</span>
            {% if unit %}<span class="fa-kpi-card__unit kpi-card-unit">{{ unit }}</span>{% endif %}
        </div>

        {% if delta %}
            <div class="fa-kpi-card__delta kpi-card-trend trend-{{ delta.direction }}">
                <i class="bi bi-arrow-{{ delta.direction }}" aria-hidden="true"></i>
                <span class="fa-kpi-card__delta-value">{{ delta.value }}</span>
                {% if hint %}<span class="fa-kpi-card__hint">· {{ hint }}</span>{% endif %}
            </div>
        {% elseif hint %}
            <div class="fa-kpi-card__hint-only">{{ hint }}</div>
        {% endif %}

        {% if detail %}
            <div class="kpi-card-detail fa-kpi-card__detail">{{ detail }}</div>
        {% endif %}

        {% if sparkline %}
            <div class="fa-kpi-card__sparkline">
                {{ spark.render(sparkline, { tone: variant, width: 140, height: 32 }) }}
            </div>
        {% endif %}
    </div>

    {% if link %}
        <a href="{{ link }}" class="fa-kpi-card__link kpi-card-link" data-turbo-action="advance"
           aria-label="{{ 'common.view_details'|trans({}, 'messages') }}">
            <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
        </a>
    {% endif %}
</div>

{% if app.environment == 'dev' %}
<script>
    if (typeof console !== 'undefined' && console.warn) {
        console.warn('[Aurora v4 Deprecation] _components/_kpi_card.html.twig — migrate to _components/_fa_feature_card.html.twig. See /dev/design-system for API.');
    }
</script>
{% endif %}
