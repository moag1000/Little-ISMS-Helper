{#
  System-Template Selector Modal — Aurora fa-modal--settings shell (2026-05-21)

  Usage:
    {% include '_components/_system_template_selector.html.twig' with {
        templates: system_templates(constant('App\\Entity\\Asset::ASSET_CLASS')),
        entity_class: 'App\\Entity\\Asset',
        redirect_to: 'app_asset_index',
        modal_id: 'systemTemplateModal'
    } %}

  Open via trigger: `data-controller="fa-modal-dispatcher" data-action="click->fa-modal-dispatcher#open" data-fa-modal-id="<modal_id>"`

  Required vars:
    - templates       : list<SystemTemplate>  (from system_templates() Twig fn)
    - entity_class    : string  FQCN, used for ARIA + display
    - redirect_to     : string  Route name to return to after apply
    - modal_id        : string  HTML id of the modal (default: systemTemplateModal)
#}
{% set modal_id = modal_id|default('systemTemplateModal') %}
{% set redirect_to = redirect_to|default('app_dashboard') %}

<div class="fa-modal fa-modal--settings"
     id="{{ modal_id }}"
     data-controller="fa-modal"
     data-fa-modal-mode-value="settings"
     role="dialog"
     aria-modal="true"
     aria-labelledby="{{ modal_id }}Label"
     aria-hidden="true">

    <div class="fa-modal__backdrop"
         data-fa-modal-target="backdrop"
         data-action="click->fa-modal#backdropClick"
         aria-hidden="true"></div>

    <div class="fa-modal__container" data-fa-modal-target="dialog">
        <header class="fa-modal__header">
            <span class="fa-modal__icon" aria-hidden="true">
                <i class="fa-icon fa-icon--nav-collection"></i>
            </span>
            <div class="fa-modal__heading">
                <h2 class="fa-modal__title" id="{{ modal_id }}Label">
                    {{ 'system_templates.modal.title'|trans({}, 'system_templates') }}
                </h2>
            </div>
            <button type="button"
                    class="fa-modal__close"
                    data-action="fa-modal#cancel"
                    aria-label="{{ 'common.close'|trans({}, 'messages') }}">
                <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i>
            </button>
        </header>

        <div class="fa-modal__body">
            <p class="text-body-secondary">
                {{ 'system_templates.modal.intro'|trans({}, 'system_templates') }}
            </p>
            {% if templates is empty %}
                <div class="alert alert-info mb-0" role="alert">
                    {{ 'system_templates.modal.empty'|trans({}, 'system_templates') }}
                </div>
            {% else %}
                <ul class="list-group">
                    {% for tpl in templates %}
                        <li class="list-group-item">
                            <form method="post"
                                  action="{{ path('app_system_template_apply') }}"
                                  class="d-flex justify-content-between align-items-start gap-3">
                                <input type="hidden" name="_token"
                                       value="{{ csrf_token('system_template_apply') }}">
                                <input type="hidden" name="template_key" value="{{ tpl.key }}">
                                <input type="hidden" name="redirect_to" value="{{ redirect_to }}">
                                <div class="flex-grow-1">
                                    <div class="fw-semibold">{{ tpl.name }}</div>
                                    <div class="small text-body-secondary">{{ tpl.description }}</div>
                                    {% if tpl.items is not null %}
                                        <span class="badge bg-secondary mt-1">
                                            {{ 'system_templates.modal.bulk_records'|trans({'%count%': tpl.items|length}, 'system_templates') }}
                                        </span>
                                    {% endif %}
                                    {% if tpl.module %}
                                        <span class="badge bg-light text-dark border mt-1">
                                            {{ tpl.module }}
                                        </span>
                                    {% endif %}
                                </div>
                                <button type="submit" class="btn btn-primary btn-sm align-self-center">
                                    <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i>
                                    {{ 'system_templates.modal.apply'|trans({}, 'system_templates') }}
                                </button>
                            </form>
                        </li>
                    {% endfor %}
                </ul>
            {% endif %}
        </div>

        <footer class="fa-modal__footer">
            <button type="button"
                    class="btn btn-outline-secondary"
                    data-action="fa-modal#cancel">
                {{ 'common.close'|trans({}, 'messages') }}
            </button>
        </footer>
    </div>
</div>
