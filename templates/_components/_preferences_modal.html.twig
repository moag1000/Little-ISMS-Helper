{#
 FairyAurora v4.0 — Preferences-Modal (canonical fa-modal--settings shell, 2026-05-21)

 Usage: {% include '_components/_preferences_modal.html.twig' %}
 Open via: trigger with data-action="preferences#open" OR dispatch
          new CustomEvent('fa-modal:request-open', { detail: { id: 'preferencesModal' } })

 Features:
 - View density, animations toggle, keyboard shortcuts, language
 - Export/import of preferences
 - i18n via preferences domain (DE + EN)
 - Preserves legacy `.preferences-modal` class for modal_manager_controller BC
#}

<div class="fa-modal fa-modal--settings preferences-modal"
     id="preferencesModal"
     data-controller="fa-modal preferences"
     data-preferences-target="modal"
     data-fa-modal-target="dialog"
     data-fa-modal-mode-value="settings"
     role="dialog"
     aria-modal="true"
     aria-labelledby="preferencesModalTitle"
     aria-hidden="true">

    <div class="fa-modal__backdrop"
         data-fa-modal-target="backdrop"
         data-action="click->fa-modal#backdropClick"
         aria-hidden="true"></div>

    <div class="fa-modal__container">

        <header class="fa-modal__header">
            <span class="fa-modal__icon" aria-hidden="true">
                <i class="fa-icon fa-icon--ui-settings"></i>
            </span>
            <div class="fa-modal__heading">
                <h2 class="fa-modal__title" id="preferencesModalTitle">
                    {{ 'preferences.title'|trans({}, 'preferences')|default('Einstellungen') }}
                </h2>
            </div>
            <button type="button"
                    class="fa-modal__close"
                    data-action="fa-modal#cancel"
                    aria-label="{{ 'common.close'|trans({}, 'messages') }}">
                <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i>
            </button>
        </header>

        <div class="fa-modal__body">

            {# View-Density #}
            <section class="fa-prefs-section preference-section">
                <h3 class="fa-prefs-section__title preference-section-title">
                    <i class="fa-icon fa-icon--nav-grid" aria-hidden="true"></i>
                    {{ 'preferences.density.title'|trans({}, 'preferences')|default('Ansichtsdichte') }}
                </h3>
                <div class="fa-cyber-input fa-cyber-input--select">
                    <div class="fa-cyber-input__frame">
                        <span class="fa-cyber-input__tick fa-cyber-input__tick--tl"></span>
                        <span class="fa-cyber-input__tick fa-cyber-input__tick--tr"></span>
                        <span class="fa-cyber-input__tick fa-cyber-input__tick--bl"></span>
                        <span class="fa-cyber-input__tick fa-cyber-input__tick--br"></span>
                        <select class="fa-cyber-input__field form-select"
                                data-preferences-target="viewDensity"
                                data-action="change->preferences#setViewDensity">
                            <option value="compact">{{ 'preferences.density.compact'|trans({}, 'preferences')|default('Kompakt') }}</option>
                            <option value="comfortable" selected>{{ 'preferences.density.comfortable'|trans({}, 'preferences')|default('Komfortabel') }}</option>
                        </select>
                        <span class="fa-cyber-input__chevron" aria-hidden="true">▾</span>
                    </div>
                    <div class="fa-cyber-input__hint">{{ 'preferences.density.hint'|trans({}, 'preferences')|default('Bestimmt, wie viel Abstand zwischen Elementen ist') }}</div>
                </div>
            </section>

            {# Animations #}
            <section class="fa-prefs-section preference-section">
                <h3 class="fa-prefs-section__title preference-section-title">
                    <i class="fa-icon fa-icon--nav-stars" aria-hidden="true"></i>
                    {{ 'preferences.animations.title'|trans({}, 'preferences')|default('Animationen') }}
                </h3>
                <label class="fa-prefs-toggle">
                    <input type="checkbox"
                           class="fa-prefs-toggle__input form-check-input"
                           data-preferences-target="animations"
                           data-action="change->preferences#toggleAnimations"
                           checked>
                    <span class="fa-prefs-toggle__slider" aria-hidden="true"></span>
                    <span class="fa-prefs-toggle__label">{{ 'preferences.animations.enable'|trans({}, 'preferences')|default('Animationen aktivieren') }}</span>
                </label>
                <div class="fa-cyber-input__hint">{{ 'preferences.animations.hint'|trans({}, 'preferences')|default('Deaktivieren für bessere Performance') }}</div>
            </section>

            {# Keyboard-Shortcuts #}
            <section class="fa-prefs-section preference-section">
                <h3 class="fa-prefs-section__title preference-section-title">
                    <i class="fa-icon fa-icon--nav-tools" aria-hidden="true"></i>
                    {{ 'preferences.shortcuts.title'|trans({}, 'preferences')|default('Tastaturkürzel') }}
                </h3>
                <label class="fa-prefs-toggle">
                    <input type="checkbox"
                           class="fa-prefs-toggle__input form-check-input"
                           data-preferences-target="keyboardShortcuts"
                           data-action="change->preferences#toggleKeyboardShortcuts"
                           checked>
                    <span class="fa-prefs-toggle__slider" aria-hidden="true"></span>
                    <span class="fa-prefs-toggle__label">{{ 'preferences.shortcuts.enable'|trans({}, 'preferences')|default('Tastaturkürzel aktivieren') }}</span>
                </label>
                <div class="fa-cyber-input__hint">{{ 'preferences.shortcuts.hint'|trans({}, 'preferences')|default('Cmd+K für Suche, Space für Vorschau, etc.') }}</div>
            </section>

            {# Language #}
            <section class="fa-prefs-section preference-section">
                <h3 class="fa-prefs-section__title preference-section-title">
                    <i class="fa-icon fa-icon--ui-globe" aria-hidden="true"></i>
                    {{ 'preferences.language.title'|trans({}, 'preferences')|default('Sprache') }}
                </h3>
                <div class="fa-cyber-input fa-cyber-input--select">
                    <div class="fa-cyber-input__frame">
                        <span class="fa-cyber-input__tick fa-cyber-input__tick--tl"></span>
                        <span class="fa-cyber-input__tick fa-cyber-input__tick--tr"></span>
                        <span class="fa-cyber-input__tick fa-cyber-input__tick--bl"></span>
                        <span class="fa-cyber-input__tick fa-cyber-input__tick--br"></span>
                        <select class="fa-cyber-input__field form-select"
                                data-preferences-target="language"
                                data-action="change->preferences#setLanguage">
                            <option value="de" {% if app.request.locale == 'de' %}selected{% endif %}>Deutsch</option>
                            <option value="en" {% if app.request.locale == 'en' %}selected{% endif %}>English</option>
                        </select>
                        <span class="fa-cyber-input__chevron" aria-hidden="true">▾</span>
                    </div>
                </div>
            </section>

            {# Export / Import #}
            <section class="fa-prefs-section preference-section">
                <h3 class="fa-prefs-section__title preference-section-title">
                    <i class="fa-icon fa-icon--util-arrow-down" aria-hidden="true"></i>
                    {{ 'preferences.backup.title'|trans({}, 'preferences')|default('Einstellungen sichern') }}
                </h3>
                <div class="fa-prefs-actions">
                    {% import '_components/_cyber_button.html.twig' as btn %}
                    {{ btn.render('preferences.backup.export'|trans({}, 'preferences')|default('Exportieren'), {
                        variant: 'secondary',
                        size: 'sm',
                        icon: 'download',
                        attrs: { 'data-action': 'click->preferences#exportPreferences' }
                    }) }}
                    <label class="fa-cyber-btn fa-cyber-btn--secondary fa-cyber-btn--sm">
                        <i class="fa-icon fa-icon--nav-upload" aria-hidden="true"></i>
                        <span class="fa-cyber-btn__label">{{ 'preferences.backup.import'|trans({}, 'preferences')|default('Importieren') }}</span>
                        <input type="file"
                               accept=".json"
                               style="display:none;"
                               data-action="change->preferences#importPreferences">
                    </label>
                </div>
            </section>
        </div>

        <footer class="fa-modal__footer">
            {% import '_components/_cyber_button.html.twig' as btn %}
            {{ btn.render('common.reset'|trans({}, 'messages')|default('Zurücksetzen'), {
                variant: 'danger',
                size: 'sm',
                icon: 'ui-undo',
                attrs: { 'data-action': 'click->preferences#resetToDefaults' }
            }) }}
            {{ btn.render('common.close'|trans({}, 'messages')|default('Schließen'), {
                variant: 'primary',
                size: 'sm',
                attrs: { 'data-action': 'fa-modal#cancel' }
            }) }}
        </footer>
    </div>
</div>
