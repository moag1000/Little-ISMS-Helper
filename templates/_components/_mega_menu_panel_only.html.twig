{#
 # Wave 5 — Flyout Panels (Mega-Menu Secondary Content)
 # Rendered at body-level to escape z-index stacking context.
 # Each panel is a <div class="flyout"> keyed by data-category.
 # The Stimulus mega-menu controller adds/removes .is-open on the matching panel.
 #
 # Runtime Safety Audit (2026-05-27):
 # - Routes: 95 path() calls verified — all exist in router (php bin/console debug:router).
 # - Translation keys: all |trans({}, 'nav') calls cross-checked against nav.de.yaml + nav.en.yaml.
 # - Stimulus controllers: mega_menu_controller.js (data-controller="mega-menu",
 #   data-action="mega-menu#toggle"), guided_tour_controller.js, keyboard_shortcuts_controller.js.
 # - Module gates: 18 is_module_active() calls (incl. resource_planning) — all keys exist in config/modules.yaml.
 # - Role gates: ROLE_ADMIN, ROLE_AUDITOR, ROLE_MANAGER, ROLE_GROUP_CISO,
 #   PERSONA_CISO, PERSONA_RISK, PERSONA_DPO, PERSONA_COMPLIANCE, ADMIN_OWN_TENANT.
 # - Holding-structure gates: Portfolio panel + Konzern-Reports require
 #   app.user.tenant.isPartOfCorporateStructure() == true.
 #
 # Wave 5 — flyout pattern:
 #   .flyout          — hidden panel (opacity:0, pointer-events:none)
 #   .flyout.is-open  — visible panel (added by mega_menu_controller.js)
 #   .fly-section     — card grouping within flyout
 #   .fly-item        — individual navigation link within a section
 #   data-density="standard|expert" — hidden at lower density levels
 #}
{% set current_route = app.request.attributes.get('_route') %}
{% set _locale = app.request.locale %}

{# ─────────────── Dashboard ─────────────── #}
<div class="flyout" id="flyout-dashboard" data-mega-menu-target="panel" data-category="dashboard"
     role="menu" aria-label="{{ 'nav.mega.category.dashboard'|trans({}, 'nav') }}">
    <button class="flyout__close" aria-label="{{ 'nav.mega.close'|trans({}, 'nav') }}" data-action="click->mega-menu#closePanel">✕</button>
    <header class="flyout__head">
        <div class="flyout__eye"><i class="fa-icon fa-icon--nav-dashboard" aria-hidden="true"></i> Dashboard</div>
        <h2 class="flyout__title">{{ 'nav.mega.flyout.dashboard.title'|trans({}, 'nav') }}</h2>
    </header>
    <div class="flyout__sections">

        <div class="fly-section">
            <header class="fly-section__head">
                <h3 class="fly-section__title">{{ 'nav.mega.section.overview'|trans({}, 'nav') }}</h3>
            </header>
            <a href="{{ path('app_home') }}" class="fly-item {% if current_route starts with 'app_home' %}is-active{% endif %}" data-turbo-action="advance" role="menuitem">
                <span class="fly-item__icon"><i class="fa-icon fa-icon--nav-home" aria-hidden="true"></i></span>
                <span class="fly-item__body">
                    <span class="fly-item__title">{{ 'nav.home'|trans({}, 'nav') }}</span>
                    <span class="fly-item__sub">{{ 'nav.mega.desc.home'|trans({}, 'nav') }}</span>
                </span>
            </a>
            <a href="{{ path('app_dashboard') }}" class="fly-item {% if current_route starts with 'app_dashboard' %}is-active{% endif %}" data-turbo-action="advance" role="menuitem">
                <span class="fly-item__icon"><i class="fa-icon fa-icon--nav-dashboard" aria-hidden="true"></i></span>
                <span class="fly-item__body">
                    <span class="fly-item__title">{{ 'nav.dashboard'|trans({}, 'nav') }}</span>
                    <span class="fly-item__sub">{{ 'nav.mega.desc.dashboard'|trans({}, 'nav') }}</span>
                </span>
            </a>
            {% if is_granted('ROLE_MANAGER') %}
            <a href="{{ path('app_analytics_dashboard') }}" class="fly-item {% if current_route starts with 'app_analytics_' %}is-active{% endif %}" data-turbo-action="advance" role="menuitem" data-density="standard">
                <span class="fly-item__icon"><i class="fa-icon fa-icon--nav-bar-chart" aria-hidden="true"></i></span>
                <span class="fly-item__body">
                    <span class="fly-item__title">{{ 'nav.analytics'|trans({}, 'nav') }}</span>
                    <span class="fly-item__sub">{{ 'nav.mega.desc.analytics'|trans({}, 'nav') }}</span>
                </span>
            </a>
            {% endif %}
        </div>

        <div class="fly-section">
            <header class="fly-section__head">
                <h3 class="fly-section__title">{{ 'nav.mega.section.reports'|trans({}, 'nav') }}</h3>
                <span class="fly-section__norm">Cl. 9.3</span>
            </header>
            {% if is_granted('ROLE_AUDITOR') %}
            <a href="{{ path('app_management_reports') }}" class="fly-item {% if current_route starts with 'app_management_reports' %}is-active{% endif %}" data-turbo-action="advance" role="menuitem">
                <span class="fly-item__icon"><i class="fa-icon fa-icon--nav-reports" aria-hidden="true"></i></span>
                <span class="fly-item__body">
