{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{#
  First Steps Checklist Component
  Shows an onboarding checklist for new ISMS installations.
  Dismissable via session preference (POST to dismiss route).

  S5 / Junior-Finding #4: 5-Schritt-Pfad "Mein erstes ISMS" —
  Kontext → Asset → Risiko → Control → Dokument. Die Reihenfolge
  spiegelt, wie ein QMB-mit-9001-Hintergrund laut Persona-Walkthrough
  intuitiv vorgeht: erst Kontext/Scope, dann Inventar, dann Risiken,
  dann Maßnahmen, am Ende Nachweise.

  Required variables:
  - context_defined (bool): Whether ISMSContext has org_name + isms_scope
  - asset_count (int): Number of assets created
  - risk_count (int): Number of risks assessed
  - applicable_control_count (int): Number of controls marked applicable
  - document_count (int): Number of documents attached
  - show_first_steps (bool): Whether to show the checklist
#}

{% if show_first_steps|default(false) %}
{% set steps = [
    { key: 'context', label: 'first_steps.define_context'|trans({}, 'dashboard'),
      description: 'first_steps.define_context_desc'|trans({}, 'dashboard'),
      url: path('app_context_index'), icon: 'bi-diagram-2',
      done: context_defined|default(false), norm: 'ISO 27001 Klausel 4' },
    { key: 'assets', label: 'first_steps.create_asset'|trans({}, 'dashboard'),
      description: 'first_steps.create_asset_desc'|trans({}, 'dashboard'),
      url: path('app_asset_new'), icon: 'bi-hdd-network',
      done: asset_count|default(0) > 0, norm: 'ISO 27001 A.5.9' },
    { key: 'risks', label: 'first_steps.assess_risk'|trans({}, 'dashboard'),
      description: 'first_steps.assess_risk_desc'|trans({}, 'dashboard'),
      url: path('app_risk_new'), icon: 'bi-exclamation-triangle',
      done: risk_count|default(0) > 0, norm: 'ISO 27001 6.1.2' },
    { key: 'control', label: 'first_steps.apply_control'|trans({}, 'dashboard'),
      description: 'first_steps.apply_control_desc'|trans({}, 'dashboard'),
      url: path('app_soa_index'), icon: 'bi-list-check',
      done: applicable_control_count|default(0) > 0, norm: 'ISO 27001 6.1.3 d / Annex A' },
    { key: 'document', label: 'first_steps.attach_document'|trans({}, 'dashboard'),
      description: 'first_steps.attach_document_desc'|trans({}, 'dashboard'),
      url: path('app_document_new'), icon: 'bi-file-earmark-text',
      done: document_count|default(0) > 0, norm: 'ISO 27001 7.5' },
] %}

{% set done_count = 0 %}
{% for step in steps %}
    {% if step.done %}
        {% set done_count = done_count + 1 %}
    {% endif %}
{% endfor %}
{% set total_count = steps|length %}
{% set progress_pct = total_count > 0 ? ((done_count / total_count) * 100)|round : 0 %}

<div class="card fa-section border-primary mb-4 shadow-sm"
     data-widget-id="first-steps"
     data-dashboard-customizer-target="widget">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="bi bi-rocket-takeoff me-2" aria-hidden="true"></i>
            {{ 'first_steps.title'|trans({}, 'dashboard') }}
        </h5>
        <div class="d-flex align-items-center gap-2">
            <span class="badge bg-body-secondary text-primary fa-status-pill fa-status-pill--neutral">
                {{ done_count }}/{{ total_count }} {{ 'first_steps.completed'|trans({}, 'dashboard') }}
            </span>
            <form method="post" action="{{ path('app_dashboard_dismiss_first_steps') }}" class="d-inline">
                <input type="hidden" name="_token" value="{{ csrf_token('dismiss_first_steps') }}">
                <button type="submit" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost border-0" title="{{ 'first_steps.dismiss'|trans({}, 'dashboard') }}" aria-label="{{ 'first_steps.dismiss'|trans({}, 'dashboard') }}">
                    <i class="bi bi-x-lg" aria-hidden="true"></i>
                </button>
            </form>
        </div>
    </div>
    <div class="card-body">
        {# Progress bar #}
        <div class="mb-3">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <small class="text-muted">{{ 'first_steps.progress_label'|trans({}, 'dashboard') }}</small>
                <small class="fw-bold">{{ progress_pct }}%</small>
            </div>
            <div class="progress progress-h-8">
                <div class="progress-bar {% if progress_pct >= 80 %}bg-success{% elseif progress_pct >= 40 %}bg-primary{% else %}bg-info{% endif %}"
                     role="progressbar"
                     style="width: {{ progress_pct }}%"
                     aria-valuenow="{{ progress_pct }}"
                     aria-valuemin="0"
                     aria-valuemax="100"></div>
            </div>
        </div>

        {# Checklist items #}
        <ul class="list-unstyled mb-0">
            {% for step in steps %}
            <li class="d-flex align-items-start py-2 {% if not loop.last %}border-bottom{% endif %}">
                <div class="flex-shrink-0 me-3 mt-1">
                    {% if step.done %}
                        <i class="bi bi-check-circle-fill text-success fs-5" aria-hidden="true"></i>
                    {% else %}
                        <i class="bi bi-circle text-muted fs-5" aria-hidden="true"></i>
                    {% endif %}
                </div>
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <a href="{{ step.url }}" class="text-decoration-none fw-semibold {% if step.done %}text-muted text-decoration-line-through{% endif %}">
                                <i class="bi {{ step.icon }} me-1" aria-hidden="true"></i>
                                {{ step.label }}
                            </a>
                            <div class="small text-muted mt-1">{{ step.description }}</div>
                        </div>
                        <div class="text-end ms-2">
                            <span class="badge bg-body-secondary text-secondary border fa-status-pill fa-status-pill--neutral" style="font-size: 0.7rem;">{{ step.norm }}</span>
                        </div>
                    </div>
                </div>
            </li>
            {% endfor %}
        </ul>

        {# Hint for ISO 9001 users #}
        {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', icon: 'bi-info-circle', class: 'mt-3 mb-0 py-2 small' } } %}
            {% block alert_body %}{{ 'first_steps.iso9001_hint'|trans({}, 'dashboard') }}{% endblock %}
        {% endembed %}
    </div>
</div>
{% endif %}
