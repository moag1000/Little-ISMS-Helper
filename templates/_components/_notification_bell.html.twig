{# Notification Bell Button (Header Version)
   Usage: {% include '_components/_notification_bell.html.twig' %}

   This is the button that appears in the header.
   The panel is defined in _notification_center.html.twig
#}

{# FairyAurora v3.0 — Controller-Scope liegt auf <body> (base.html.twig),
   damit Bell-Button und Panel den gleichen Stimulus-Scope teilen. #}
<div class="notification-bell">
    <button type="button"
            class="notification-bell-btn-header"
            data-action="click->notifications#toggle"
            title="{{ 'notifications.title'|trans({}, 'messages') }}"
            aria-label="{{ 'notifications.title'|trans({}, 'messages') }}">
        <i class="fa-icon fa-icon--ui-bell" aria-hidden="true"></i>
        <span class="notification-badge d-none"
              data-notifications-target="badge">0</span>
    </button>
</div>
