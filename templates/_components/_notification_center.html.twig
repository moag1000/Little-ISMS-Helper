{# Notification Center Panel
   Usage: {% include '_components/_notification_center.html.twig' %}

   This contains only the notification panel.
   The button is in _notification_bell.html.twig (in header)
#}

{# FairyAurora v3.0 — data-controller + values liegen auf <body>.
   Hier nur noch die Panel-Struktur als einfacher Wrapper. #}
<div class="notification-center-panel">
    {# Notification Panel #}
    <div class="notification-panel d-none"
         role="dialog"
         aria-modal="true"
         aria-labelledby="notification-panel-title"
         data-notifications-target="panel"
         data-action="click->notifications#handleBackdropClick">
        
        <div class="notification-panel-container">
            {# Panel Header #}
            <div class="notification-panel-header">
                <h5 class="notification-panel-title" id="notification-panel-title">
                    <i class="bi bi-bell" aria-hidden="true"></i>
                    {{ 'notifications.title'|trans({}, 'notifications') }}
                </h5>
                <div class="notification-panel-actions">
                    <button type="button"
                            class="btn btn-sm btn-link"
                            data-action="click->notifications#markAllAsRead"
                            title="{{ 'notifications.action.mark_all_read'|trans({}, 'notifications') }}">
                        <i class="bi bi-check2-all" aria-hidden="true"></i>
                    </button>
                    <button type="button"
                            class="btn btn-sm btn-link"
                            data-action="click->notifications#clearAll"
                            title="{{ 'notifications.action.clear_all'|trans({}, 'notifications') }}">
                        <i class="bi bi-trash" aria-hidden="true"></i>
                    </button>
                    <button type="button"
                            class="btn-close btn-sm"
                            data-action="click->notifications#close"
                            aria-label="{{ 'action.close'|trans({}, 'messages') }}"></button>
                </div>
            </div>

            {# Notification List #}
            <div class="notification-list" data-notifications-target="list">
                {# Notifications will be rendered here by JavaScript #}
                <div class="notification-empty">
                    <i class="bi bi-bell-slash text-muted fa-icon-lg" aria-hidden="true"></i>
                    <p class="mt-3 mb-0">{{ 'notifications.empty.title'|trans({}, 'notifications') }}</p>
                    <p class="text-muted small">{{ 'notifications.empty.description'|trans({}, 'notifications') }}</p>
                </div>
            </div>
        </div>
    </div>
</div>
