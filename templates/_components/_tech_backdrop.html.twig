{#
 # FairyAurora TechBackdrop — SVG-Background mit Grid + Dots + Circuit-Traces + Nodes
 #
 # Wird in setup-layout Left-Panel als absolut-positionierter Overlay genutzt.
 # Radial-Fade-Mask rechts-unten zeigt Tech-Feeling dezent ohne visuelles Rauschen.
 #
 # Usage:
 #   {% import '_components/_tech_backdrop.html.twig' as tech %}
 #   {{ tech.render(0.9) }}   {# intensity 0..1 #}
 #}

{% macro render(intensity = 1) %}
    {% set uid = 'tb' ~ random(999999) %}
    <svg class="fa-tech-backdrop"
         style="opacity:{{ intensity }};"
         width="100%" height="100%"
         viewBox="0 0 600 800"
         preserveAspectRatio="xMidYMid slice"
         aria-hidden="true">
        <defs>
            <pattern id="g-{{ uid }}" width="24" height="24" patternUnits="userSpaceOnUse">
                <path d="M 24 0 L 0 0 0 24" fill="none" stroke="var(--fg)" stroke-width="0.4" opacity="0.06"/>
            </pattern>
            <pattern id="d-{{ uid }}" width="48" height="48" patternUnits="userSpaceOnUse">
                <circle cx="24" cy="24" r="0.9" fill="var(--primary)" opacity="0.22"/>
            </pattern>
            <radialGradient id="f-{{ uid }}" cx="40%" cy="45%" r="60%">
                <stop offset="0%"   stop-color="#000" stop-opacity="0"/>
                <stop offset="65%"  stop-color="#000" stop-opacity="0"/>
                <stop offset="100%" stop-color="#000" stop-opacity="0.55"/>
            </radialGradient>
            <mask id="m-{{ uid }}">
                <rect width="100%" height="100%" fill="white"/>
                <rect width="100%" height="100%" fill="url(#f-{{ uid }})"/>
            </mask>
        </defs>
        <g mask="url(#m-{{ uid }})">
            <rect width="100%" height="100%" fill="url(#g-{{ uid }})"/>
            <rect width="100%" height="100%" fill="url(#d-{{ uid }})"/>
            <g stroke="var(--primary)" stroke-width="0.55" fill="none" opacity="0.22">
                <path d="M 0 160 L 140 160 L 170 190 L 290 190" stroke-linecap="round"/>
                <path d="M 600 280 L 460 280 L 430 310 L 340 310" stroke-linecap="round"/>
                <path d="M 60 560 L 180 560 L 210 530 L 330 530" stroke-linecap="round"/>
                <path d="M 520 620 L 400 620" stroke-linecap="round"/>
            </g>
            <g fill="var(--accent)" opacity="0.5">
                <circle cx="140" cy="160" r="1.8"/>
                <circle cx="290" cy="190" r="1.8"/>
                <circle cx="460" cy="280" r="1.8"/>
                <circle cx="340" cy="310" r="1.8"/>
                <circle cx="180" cy="560" r="1.8"/>
                <circle cx="330" cy="530" r="1.8"/>
                <circle cx="400" cy="620" r="1.8"/>
            </g>
        </g>
    </svg>
{% endmacro %}
