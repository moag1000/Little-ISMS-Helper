{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{#
  Bulk Delete Confirmation Modal — Aurora fa-modal shell (2026-05-21)
  Accessible confirmation dialog for bulk delete operations.

  Targets used by bulk-delete-confirmation Stimulus controller:
    - modal, message, count, entityLabel, dependencies, dependencyList,
      loading, error, errorMessage, confirmButton, cancelButton
  Open via JS:
    this.dispatch('fa-modal:request-open', { detail: { id: 'bulkDeleteModal' } });
#}

<div class="fa-modal fa-modal--confirm fa-modal--danger"
     id="bulkDeleteModal"
     data-controller="fa-modal bulk-delete-confirmation"
     data-bulk-delete-confirmation-target="modal"
     data-fa-modal-mode-value="confirm"
     data-fa-modal-tone-value="danger"
     role="alertdialog"
     aria-modal="true"
     aria-labelledby="bulkDeleteModalTitle"
     aria-describedby="bulkDeleteModalDescription"
     aria-hidden="true">

    <div class="fa-modal__backdrop"
         data-fa-modal-target="backdrop"
         data-action="click->fa-modal#backdropClick"
         aria-hidden="true"></div>

    <div class="fa-modal__container" data-fa-modal-target="dialog">

        <header class="fa-modal__header">
            <span class="fa-modal__icon" aria-hidden="true">
                <i class="fa-icon fa-icon--status-warning"></i>
            </span>
            <div class="fa-modal__heading">
                <h2 class="fa-modal__title" id="bulkDeleteModalTitle">
                    {{ 'bulk_delete.confirm.title'|trans({}, 'bulk_delete') }}
                </h2>
            </div>
            <button type="button"
                    class="fa-modal__close"
                    aria-label="{{ 'action.close'|trans({}, 'messages') }}"
                    data-action="fa-modal#cancel click->bulk-delete-confirmation#cancel">
                <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i>
            </button>
        </header>

        <div class="fa-modal__body">
            {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning', icon: 'status-critical', class: 'd-flex align-items-start gap-3' } } %}
                {% block alert_body %}<div class="flex-grow-1"> <p id="bulkDeleteModalDescription" class="mb-2 fw-semibold" data-bulk-delete-confirmation-target="message"> </p> <p class="mb-0 small text-muted"> {{ 'bulk_delete.confirm.warning'|trans({}, 'bulk_delete') }} </p> </div>{% endblock %}
            {% endembed %}

            <div class="mb-3">
                <h6 class="fw-semibold mb-2">
                    {{ 'bulk_delete.selection.title'|trans({}, 'bulk_delete') }}
                </h6>
                <div class="d-flex align-items-center gap-2 p-2 bg-body-secondary rounded">
                    <i class="fa-icon fa-icon--ui-check text-primary" aria-hidden="true"></i>
                    <span>
                        <strong data-bulk-delete-confirmation-target="count">0</strong>
                        <span data-bulk-delete-confirmation-target="entityLabel">{{ 'common.entries'|trans({}, 'messages') }}</span>
                    </span>
                </div>
            </div>

            <div data-bulk-delete-confirmation-target="dependencies" class="d-none">
                <h6 class="fw-semibold mb-2">
                    {{ 'bulk_delete.dependencies.title'|trans({}, 'bulk_delete') }}
                </h6>
                <div class="fa-alert fa-alert--info" role="alert">
                    <div class="fa-alert__body">
                    <ul class="mb-0 ps-3"
                        data-bulk-delete-confirmation-target="dependencyList"
                        aria-label="{{ 'bulk_delete.dependencies.list'|trans({}, 'bulk_delete') }}">
                    </ul>
                    </div>
                </div>
            </div>

            <div data-bulk-delete-confirmation-target="loading" class="text-center py-3 d-none">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">{{ 'common.loading'|trans({}, 'messages') }}</span>
                </div>
                <p class="mt-2 text-muted small">
                    {{ 'bulk_delete.loading'|trans({}, 'bulk_delete') }}
                </p>
            </div>

            <div data-bulk-delete-confirmation-target="error" class="fa-alert fa-alert--danger d-none" role="alert">
                <i class="fa-icon fa-icon--status-critical fa-alert__icon" aria-hidden="true"></i>
                <div class="fa-alert__body">
                    <span data-bulk-delete-confirmation-target="errorMessage"></span>
                </div>
            </div>
        </div>

        <footer class="fa-modal__footer">
            <button type="button"
                    class="fa-cyber-btn fa-cyber-btn--ghost"
                    data-action="click->bulk-delete-confirmation#cancel"
                    data-bulk-delete-confirmation-target="cancelButton">
                <i class="fa-icon fa-icon--ui-close me-1" aria-hidden="true"></i>
                {{ 'action.cancel'|trans({}, 'messages') }}
            </button>
            <button type="button"
                    class="fa-cyber-btn fa-cyber-btn--danger"
                    data-action="click->bulk-delete-confirmation#confirm"
                    data-bulk-delete-confirmation-target="confirmButton"
                    autofocus>
                <i class="fa-icon fa-icon--ui-trash me-1" aria-hidden="true"></i>
                {{ 'action.delete'|trans({}, 'messages') }}
            </button>
        </footer>
    </div>
</div>
