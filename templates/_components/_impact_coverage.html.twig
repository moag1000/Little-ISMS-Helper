{#
 # V3 B6 / EF-4: Inverse-Coverage Impact-Analyse Block
 #
 # Renders a section that shows "If this entity changes, which frameworks
 # are affected at which requirements?". Reusable for Control/Asset/Risk
 # show templates. Pass `impact_coverage` from controller (output of
 # InverseCoverageService::forControl/forAsset/forRisk).
 #
 # Usage:
 #   {% include '_components/_impact_coverage.html.twig' with {
 #       impact: impact_coverage,
 #       entity_label: 'asset' | 'control' | 'risk'
 #   } %}
 #
 # Parameters:
 #   impact         - array{total: int, frameworks: array<string, {framework, requirements}>}
 #   entity_label   - i18n-key suffix for messages (asset|control|risk)
 #}

{% import '_components/_status_pill.html.twig' as pill %}

{% if impact is defined and impact.total > 0 %}
    <section class="fa-section mb-4" data-test="impact-coverage">
        <div class="fa-section__header">
            <h2 class="fa-section__title">
                <i class="fa-icon fa-icon--nav-workflow" aria-hidden="true"></i>
                {{ ('coverage.impact.title.' ~ entity_label)|trans({}, 'compliance') }}
                {{ pill.render(impact.total, 'primary', {class: 'ms-2'}) }}
            </h2>
            <div class="fa-section__tools">
                <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
                        data-controller="fa-modal-dispatcher" data-action="click->fa-modal-dispatcher#open" data-fa-modal-id="impactCoverageModal-{{ entity_label }}">
                    <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
                    {{ 'coverage.impact.view_modal'|trans({}, 'compliance') }}
                </button>
            </div>
        </div>
        <div class="fa-section__body">
            <p class="text-muted small mb-2">{{ ('coverage.impact.help.' ~ entity_label)|trans({}, 'compliance') }}</p>
            <div class="d-flex flex-wrap gap-2">
                {% for code, group in impact.frameworks %}
                    {{ pill.render(group.framework.code ~ ': ' ~ group.requirements|length, 'neutral') }}
                {% endfor %}
            </div>
        </div>
    </section>

    {# Modal with detailed list #}
    <div class="fa-modal fa-modal--confirm fa-modal--neutral" id="impactCoverageModal-{{ entity_label }}"
     data-controller="fa-modal" data-fa-modal-mode-value="confirm" data-fa-modal-tone-value="neutral"
     role="dialog" aria-modal="true" aria-labelledby="impactCoverageModal-{{ entity_label }}Label" aria-hidden="true">
    <div class="fa-modal__backdrop" data-fa-modal-target="backdrop" data-action="click->fa-modal#backdropClick" aria-hidden="true"></div>
    <div class="fa-modal__container" data-fa-modal-target="dialog"><header class="fa-modal__header"><span class="fa-modal__icon" aria-hidden="true"><i class="fa-icon fa-icon--ui-info"></i></span><div class="fa-modal__heading"><h2  id="impactCoverageModal-{{ entity_label }}Label" class="fa-modal__title">
                        {{ ('coverage.impact.title.' ~ entity_label)|trans({}, 'compliance') }}
                    </h2></div><button type="button" class="fa-modal__close" data-action="fa-modal#cancel" aria-label="{{ 'action.close'|trans({}, 'messages') }}"><i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i></button></header>
                <div class="fa-modal__body">
                    <p class="text-muted small">{{ ('coverage.impact.help.' ~ entity_label)|trans({}, 'compliance') }}</p>
                    {% for code, group in impact.frameworks %}
                        <div class="mb-3">
                            <h3 class="h6 mb-2">
                                {{ pill.render(group.framework.code, 'primary') }}
                                {{ group.framework.name }}
                                <span class="text-muted small">({{ group.requirements|length }})</span>
                            </h3>
                            <ul class="list-unstyled ms-3">
                                {% for req in group.requirements %}
                                    <li class="mb-1">
                                        <a href="{{ path('app_compliance_requirement_show', {id: req.id}) }}"
                                           class="text-decoration-none">
                                            <code class="text-info">{{ req.requirementId }}</code>
                                            <span class="text-body">{{ req.title }}</span>
                                        </a>
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endfor %}
                </div>
                <footer class="fa-modal__footer">
                    <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost" data-action="fa-modal#cancel">{{ 'common.close'|trans({}, 'messages') }}</button></div>
</div>
    </div>
{% endif %}
