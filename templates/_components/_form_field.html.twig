{# Form Field Component - Aurora v4 cyber-input via global form_theme

   Delegates rendering to {{ form_row(field) }}, which routes through the
   global form-theme `form/fa_cyber_input.html.twig` and produces the proper
   Aurora frame (header + corner-ticks + glow). Tooltip icons render as
   sidecar UI to keep the cyber-input frame clean.

   Backward-compat: legacy params `label_key`, `help_key`, `tooltip_key`,
   `translation_domain`, `required`, `automatic` are still accepted; their
   semantics are preserved via attr-merging on the underlying form-row.

   Junior-ISB-Audit-2026-05-22 S14 #17 (BP-Tooltips Drawer Pattern):
   When a `drawer_key` is provided, the verbose help-text is moved into an
   Aurora `fa-drawer` (side-sheet) opened via a "Mehr Info..." button. The
   inline help-text stays as a 30-sec summary. Drawer markup must be mounted
   once per page via `_components/_fa_help_drawer.html.twig` inside the same
   `data-controller="help-drawer"` scope.
#}

{% set field_id = field.vars.id %}
{% set has_errors = field.vars.errors|length > 0 %}
{% set is_required = required|default(field.vars.required) %}

{% set trans_domain = translation_domain|default('messages') %}
{% set help_text = help_key is defined ? (help_key|trans({}, trans_domain)) : (help|default(null)) %}
{% set explicit_tooltip = tooltip_key is defined ? (tooltip_key|trans({}, trans_domain)) : (tooltip|default(null)) %}
{% set drawer_body = drawer_key is defined and drawer_key ? (drawer_key|trans({}, trans_domain)) : null %}
{% set is_automatic = automatic|default(false) %}
{% set tooltip_text = explicit_tooltip ? explicit_tooltip : help_text %}
{% if is_automatic and not explicit_tooltip %}
    {% set tooltip_text = 'form.automatic_value'|trans({}, 'messages') %}
{% endif %}

{# When a drawer is available, the verbose content lives there — suppress the
   sidecar Bootstrap tooltip-icon to avoid duplicating the info in two places.
#}
{% if drawer_body %}
    {% set tooltip_text = null %}
{% endif %}

{# Inject is-automatic class + aria-required + caller-supplied help into the
   field's render-vars. The form-theme already handles base styling; we just
   enrich the attrs and forward help-text into field.vars.help so the theme's
   hint-line picks it up. #}
{% set merged_attr = field.vars.attr|merge({
    'class': (field.vars.attr.class|default('') ~ (is_automatic ? ' fairy-field-automatic' : ''))|trim,
    'aria-required': is_required ? 'true' : 'false'
}) %}
{% set field_vars = {attr: merged_attr} %}
{% if help_text and not (field.vars.help|default(null)) %}
    {% set field_vars = field_vars|merge({help: help_text}) %}
{% endif %}

{% if tooltip_text or is_automatic %}
    {# Field with sidecar tooltip icon (Aurora cyber-frame + tooltip outside) #}
    <div class="fa-cyber-input-row d-flex align-items-start gap-2">
        <div class="flex-grow-1">
            {{ form_row(field, field_vars) }}
        </div>
        <i class="fa-icon {{ is_automatic ? 'fa-icon--ui-magic fairy-icon-sparkle' : 'fa-icon--status-info text-primary' }} mt-2"
           data-bs-toggle="tooltip"
           data-bs-placement="right"
           data-bs-html="true"
           data-bs-title="{{ tooltip_text }}"
           role="button"
           tabindex="0"
           aria-label="{{ is_automatic ? 'form.automatic_value'|trans({}, 'messages') : 'common.help'|trans({}, 'messages') }}"
           style="cursor: help; font-size: 1.1em;"></i>
    </div>
{% else %}
    {{ form_row(field, field_vars) }}
{% endif %}

{#
    Junior-ISB-Audit-2026-05-22 S14 #17: BP-Tooltips Drawer Pattern.
    Render the "Mehr Info..." trigger below the field when a drawer_key is
    provided. The verbose help-content is passed via data-attrs and rendered
    by the shared help_drawer Stimulus controller into the single page-level
    fa-drawer instance.
#}
{% if drawer_body %}
    {% set field_label_text = field.vars.label is iterable
        ? (field.vars.label.label|default(field.vars.name)|trans({}, trans_domain))
        : (field.vars.label ? (field.vars.label|trans({}, trans_domain)) : field.vars.name) %}
    <button type="button"
            class="btn btn-link btn-sm p-0 mt-1 fairy-help-drawer-trigger"
            data-action="click->help-drawer#open"
            data-help-drawer-title-param="{{ field_label_text }}"
            data-help-drawer-body-param="{{ drawer_body }}"
            aria-label="{{ 'common.more_info_aria'|trans({'%field%': field_label_text}, 'messages') }}">
        <i class="fa-icon fa-icon--status-info me-1" aria-hidden="true"></i>{{ 'common.more_info'|trans({}, 'messages') }}
    </button>
{% endif %}
