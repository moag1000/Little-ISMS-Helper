{% extends 'base.html.twig' %}
{% trans_default_domain 'soa' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}

{% block title %}{{ 'soa.no_tenant.title'|trans({}, 'soa') }} — Little ISMS Helper{% endblock %}

{% block body %}
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.soa'|trans({}, 'nav') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'shield-check', label: 'nav.soa'|trans({}, 'nav') },
        title: 'soa.no_tenant.title'|trans({}, 'soa'),
        subtitle: 'soa.no_tenant.subtitle'|trans({}, 'soa')
    }) }}

    <main class="fa-aurora-surface mt-4">
        {{ _fa_empty_state.render({
            mood: 'warning',
            title: 'soa.no_tenant.title'|trans({}, 'soa'),
            text: isAdmin
                ? 'soa.no_tenant.body_admin'|trans({}, 'soa')
                : 'soa.no_tenant.body_user'|trans({}, 'soa'),
            actions: isAdmin
                ? [
                    {
                        label: 'soa.no_tenant.cta_user_management'|trans({}, 'soa'),
                        href: path('user_management_index'),
                        variant: 'primary'
                    },
                    {
                        label: 'soa.no_tenant.cta_data_repair'|trans({}, 'soa'),
                        href: path('admin_data_repair_index'),
                        variant: 'secondary'
                    }
                ]
                : [
                    {
                        label: 'soa.no_tenant.cta_logout'|trans({}, 'soa'),
                        href: path('app_logout'),
                        variant: 'secondary'
                    }
                ]
        }) }}
    </main>
{% endblock %}
