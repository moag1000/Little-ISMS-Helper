{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% trans_default_domain 'soa' %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}

{% block title %}{{ category }} {{ 'soa.label.controls'|trans({}, 'soa') }} - Statement of Applicability - Little ISMS Helper{% endblock %}

{% block body %}
<div class="page-header">
    <div>
        <h1>{{ category }} {{ 'soa.label.controls'|trans({}, 'soa') }}</h1>
        <p class="text-muted">ISO/IEC 27001:2022 Annex A - {{ category }} Kontrollen</p>
    </div>
    <div class="button-group">
        <a href="{{ path('app_soa_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
            <i class="fa-icon fa-icon--util-arrow-left" aria-hidden="true"></i> {{ 'soa.action.back_to_overview'|trans({}, 'soa') }}
        </a>
    </div>
</div>

{# Statistics Cards #}
<div class="kpi-grid kpi-grid-responsive">
    <div class="col-auto">
        {{ _fa_feature_card.render({ label: 'soa.kpi.total_controls'|trans({}, 'soa'), value: controls|length, variant: 'primary' }) }}
    </div>
    <div class="col-auto">
        {{ _fa_feature_card.render({ label: 'soa.kpi.applicable_controls'|trans({}, 'soa'), value: controls|filter(c => c.applicable)|length, variant: 'success' }) }}
    </div>
    <div class="col-auto">
        {% set implemented = controls|filter(c => c.applicable and c.implementationStatus == 'implemented')|length %}
        {% set applicable = controls|filter(c => c.applicable)|length %}
        {{ _fa_feature_card.render({ label: 'soa.kpi.implemented_controls'|trans({}, 'soa'), value: implemented, hint: 'soa.kpi.of'|trans({}, 'soa') ~ ' ' ~ applicable, variant: 'info' }) }}
    </div>
    <div class="col-auto">
        {% set applicable = controls|filter(c => c.applicable)|length %}
        {% set implemented = controls|filter(c => c.applicable and c.implementationStatus == 'implemented')|length %}
        {% set percentage = applicable > 0 ? (implemented / applicable * 100)|round : 0 %}
        {{ _fa_feature_card.render({ label: 'soa.kpi.compliance_rate'|trans({}, 'soa'), value: percentage ~ '%', variant: 'warning' }) }}
    </div>
</div>

{% if auto_seeded is defined and auto_seeded > 0 %}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'success', icon: 'bi-check-circle-fill' } } %}
        {% block alert_body %}{{ 'soa.message.auto_seeded'|trans({'%count%': auto_seeded}, 'soa') }}{% endblock %}
    {% endembed %}
{% endif %}

{# Controls Table #}
<h2>{{ 'soa.label.controls'|trans({}, 'soa') }}</h2>

{% if controls|length == 0 and total_for_tenant is defined and total_for_tenant == 0 %}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning' } } %}
        {% block alert_body %}
            <h4 class="fa-alert__title">{{ 'soa.empty.no_controls_for_tenant.title'|trans({}, 'soa') }}</h4>
            <p class="mb-2">
                {% if iso_27001_active is defined and iso_27001_active %}
                    {{ 'soa.empty.no_controls_for_tenant.iso_active'|trans({}, 'soa') }}
                {% else %}
                    {{ 'soa.empty.no_controls_for_tenant.iso_inactive'|trans({}, 'soa') }}
                {% endif %}
            </p>
            {% if is_granted('ROLE_ADMIN') %}
                <form method="post" action="{{ path('app_soa_bootstrap_annex_a') }}" class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('bootstrap_annex_a') }}">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--sm">
                        <i class="fa-icon fa-icon--nav-download me-1" aria-hidden="true"></i>
                        {{ 'soa.empty.load_button'|trans({}, 'soa') }}
                    </button>
                </form>
            {% else %}
                <p class="small text-muted mb-0">
                    {{ 'soa.empty.contact_admin'|trans({}, 'soa') }}
                </p>
            {% endif %}
        {% endblock %}
    {% endembed %}
{% elseif controls|length == 0 %}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', icon: 'bi-info-circle' } } %}
        {% block alert_body %}{{ 'soa.empty.no_controls_in_category'|trans({'%category%': category, '%total%': total_for_tenant}, 'soa') }}{% endblock %}
    {% endembed %}
{% endif %}

{% embed '_components/_table.html.twig' with {'class': 'table-container', 'noMargin': true} %}
    {% block table_head %}
        <tr>
            <th scope="col">{{ 'soa.table.control_id'|trans({}, 'soa') }}</th>
            <th scope="col">{{ 'soa.table.name'|trans({}, 'soa') }}</th>
            <th scope="col" class="text-center">{{ 'soa.table.applicable'|trans({}, 'soa') }}</th>
            <th scope="col">{{ 'soa.table.implementation_status'|trans({}, 'soa') }}</th>
            <th scope="col" class="text-center">{{ 'soa.table.progress'|trans({}, 'soa') }}</th>
            <th scope="col">{{ 'soa.field.responsible_person'|trans({}, 'soa') }}</th>
            <th scope="col" class="text-center">{{ 'soa.table.actions'|trans({}, 'soa') }}</th>
        </tr>
    {% endblock %}
    {% block table_body %}
        {% for control in controls %}
        <tr>
            <td>{% include '_components/_iso_reference_label.html.twig' with { control: control, show_name: false, code_class: 'fw-bold' } only %}</td>
            <td>
                {{ control.name }}
                <br>
                <small class="text-muted">{{ control.description|slice(0, 100) }}{% if control.description|length > 100 %}...{% endif %}</small>
            </td>
            <td class="text-center">
                {% if control.applicable %}
                    {% include '_components/_badge.html.twig' with { variant: 'success', icon: 'bi-check', content: 'soa.value.yes'|trans({}, 'soa') } %}
                {% else %}
                    {% include '_components/_badge.html.twig' with { variant: 'neutral', icon: 'bi-x', content: 'soa.value.no'|trans({}, 'soa') } %}
                {% endif %}
            </td>
            <td>
                {% if control.applicable %}
                    {% if control.implementationStatus == 'implemented' %}
                        {% include '_components/_badge.html.twig' with { variant: 'success', icon: 'bi-check-circle', content: 'soa.status.implemented'|trans({}, 'soa') } %}
                    {% elseif control.implementationStatus == 'in_progress' %}
                        {% include '_components/_badge.html.twig' with { variant: 'warning', content: 'soa.in_progress_badge_emoji'|trans({}, 'soa') } %}
                    {% elseif control.implementationStatus == 'not_started' %}
                        {% include '_components/_badge.html.twig' with { variant: 'danger', icon: 'bi-pause-circle', content: 'soa.status.not_started'|trans({}, 'soa') } %}
                    {% else %}
                        {% include '_components/_badge.html.twig' with { variant: 'neutral', content: 'soa.value.na'|trans({}, 'soa') } %}
                    {% endif %}
                {% else %}
                    {% include '_components/_badge.html.twig' with { variant: 'neutral', content: 'soa.status.not_applicable'|trans({}, 'soa') } %}
                {% endif %}
            </td>
            <td>
                {% if control.applicable %}
                    <div class="progress progress-compact">
                        <div class="progress-bar" style="width: {{ control.implementationPercentage }}%; font-size: 0.75rem;">
                            {{ control.implementationPercentage }}%
                        </div>
                    </div>
                {% else %}
                    <span class="text-center-block-light">-</span>
                {% endif %}
            </td>
            <td>
                {% if control.responsiblePerson %}
                    {{ control.responsiblePerson }}
                {% else %}
                    <span class="text-muted">{{ 'soa.field.unassigned'|trans({}, 'soa') }}</span>
                {% endif %}
            </td>
            <td class="text-center">
                <a href="{{ path('app_soa_show', {id: control.id}) }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost me-1" title="{{ 'soa.action.view_details'|trans({}, 'soa') }}">
                    <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i> {{ 'soa.action.view_details'|trans({}, 'soa') }}
                </a>
                <a href="{{ path('app_soa_edit', {id: control.id}) }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost" title="{{ 'soa.action.edit'|trans({}, 'soa') }}">
                    <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i> {{ 'soa.action.edit'|trans({}, 'soa') }}
                </a>
            </td>
        </tr>
        {% else %}
        <tr>
            <td colspan="7" class="text-center-p-xl-muted">
                {{ 'soa.message.no_controls_filtered'|trans({}, 'soa') }}
            </td>
        </tr>
        {% endfor %}
    {% endblock %}
{% endembed %}
{% endblock %}
