{% extends 'base.html.twig' %}
{% trans_default_domain 'control' %}

{% block title %}{{ 'soa.action.edit'|trans({}, 'soa') }} - {{ control.controlId }} - Little ISMS Helper{% endblock %}

{% block body %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.soa'|trans({}, 'nav'), url: path('app_soa_index') },
            { label: control.controlId, url: path('app_soa_show', {id: control.id}) },
            { label: 'common.edit'|trans({}, 'messages') }
        ]
    } %}
</div>

{{ _fa_page_header.render({
    title: ('soa.action.edit'|trans({}, 'soa')) ~ ': ' ~ (control.controlId),
    badge: { icon: 'ui-edit', label: '' },
    actions: [
        { label: 'common.back_to_list'|trans({}, 'messages'), href: path('app_soa_index'), variant: 'ghost', icon: 'util-arrow-left' }
    ]
}) }}

{# F13 — control.name / control.description are instance free-text, NOT
   translation keys: output them raw (no |trans filter). #}
{% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', class: 'mb-4' } } %}
    {% block alert_body %}
        <div class="fa-alert__title">{{ control.name }}</div>
        <p class="mt-sm-text-light">{{ control.description }}</p>
        <div class="mt-2">
            {% include '_components/_badge.html.twig' with { variant: 'info', content: control.category|trans({}, 'control') } %}
        </div>
    {% endblock %}
{% endembed %}

{# F8 — read-only warning when linked evidence has been superseded (ISO 27001 §7.5). #}
{% if control.isEvidenceOutdated %}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning', class: 'mb-4' } } %}
        {% block alert_body %}
            <div class="fa-alert__title">{{ 'control.evidence.outdated_title'|trans({}, 'control') }}</div>
            <p class="mb-0">{{ 'control.evidence.outdated_body'|trans({}, 'control') }}</p>
        {% endblock %}
    {% endembed %}
{% endif %}

{{ form_start(form) }}

{# ── Overview ─────────────────────────────────────────────────────── #}
<fieldset class="mb-4">
    <legend class="h5 mb-3">{{ 'form.section.overview'|trans({}, 'messages') }}</legend>
    <div class="row">
        <div class="col-md-6">
            {% include '_components/_form_field.html.twig' with {
                'field': form.controlId,
                'label_key': form.controlId.vars.label,
                'translation_domain': 'control',
                'required': form.controlId.vars.required
            } %}
        </div>
        <div class="col-md-6">
            {% include '_components/_form_field.html.twig' with {
                'field': form.category,
                'label_key': form.category.vars.label,
                'translation_domain': 'control',
                'required': form.category.vars.required
            } %}
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            {% include '_components/_form_field.html.twig' with {
                'field': form.name,
                'label_key': form.name.vars.label,
                'translation_domain': 'control',
                'required': form.name.vars.required
            } %}
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            {% include '_components/_form_field.html.twig' with {
                'field': form.description,
                'label_key': form.description.vars.label,
                'translation_domain': 'control',
                'required': form.description.vars.required
            } %}
        </div>
    </div>
</fieldset>

{# ── Applicability ────────────────────────────────────────────────── #}
<fieldset class="mb-4">
    <legend class="h5 mb-3">{{ 'form.section.applicability'|trans({}, 'messages') }}</legend>
    <div class="row">
        <div class="col-md-12">
            <div class="form-check mb-3">
                {{ form_widget(form.applicable, {'attr': {'class': 'form-check-input'}}) }}
                {{ form_label(form.applicable, null, {'label_attr': {'class': 'form-check-label'}}) }}
                {{ form_errors(form.applicable) }}
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            {% include '_components/_form_field.html.twig' with {
                'field': form.justification,
                'label_key': form.justification.vars.label,
                'translation_domain': 'control',
                'required': form.justification.vars.required
            } %}
        </div>
    </div>
</fieldset>

{# ── Implementation (F3: collapses when applicable=false) ──────────── #}
<fieldset class="mb-4" data-controller="control-status"
          data-applicability-toggle-target="collapse"
          data-control-status-verified-tooltip="{{ 'control.status_hint.verified_full'|trans({}, 'control') }}"
          data-control-status-implemented-confirm="{{ 'control.status_hint.implemented_confirm'|trans({}, 'control') }}">
    <legend class="h5 mb-3">{{ 'form.section.implementation'|trans({}, 'messages') }}</legend>
    <div class="row">
        <div class="col-md-12">
            {% include '_components/_form_field.html.twig' with {
                'field': form.implementationStatus,
                'label_key': form.implementationStatus.vars.label,
                'translation_domain': 'control',
                'required': form.implementationStatus.vars.required
            } %}
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <div class="mb-3" data-controller="progress-slider">
                {{ form_label(form.implementationPercentage) }}
                <div class="flex-center-gap-md">
                    {{ form_widget(form.implementationPercentage, {
                        'attr': {
                            'type': 'range',
                            'class': 'flex-1',
                            'min': '0',
                            'max': '100',
                            'data-control-status-target': 'percentage',
                            'data-progress-slider-target': 'slider',
                            'data-action': 'input->progress-slider#update',
                            'aria-label': form.implementationPercentage.vars.label|trans({}, 'control')
                        }
                    }) }}
                    <span data-progress-slider-target="display" class="fa-status-pill fa-status-pill--primary badge-fs-1-p-sm-md">
                        {{ form.vars.data.implementationPercentage }}%
                    </span>
                </div>
                <div class="progress mt-2">
                    <div data-progress-slider-target="bar" class="progress-bar" style="width: {{ form.vars.data.implementationPercentage }}%">
                        {{ form.vars.data.implementationPercentage }}%
                    </div>
                </div>
                {{ form_help(form.implementationPercentage) }}
                {{ form_errors(form.implementationPercentage) }}
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-md-6">
            {% include '_components/_form_field.html.twig' with {
                'field': form.targetDate,
                'label_key': form.targetDate.vars.label,
                'translation_domain': 'control',
                'required': form.targetDate.vars.required
            } %}
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            {% include '_components/_form_field.html.twig' with {
                'field': form.implementationNotes,
                'label_key': form.implementationNotes.vars.label,
                'translation_domain': 'control',
                'required': form.implementationNotes.vars.required
            } %}
        </div>
    </div>
</fieldset>

{# ── Classification ───────────────────────────────────────────────── #}
<fieldset class="mb-4">
    <legend class="h5 mb-3">{{ 'form.section.classification'|trans({}, 'messages') }}</legend>
    <div class="row">
        <div class="col-md-4">
            {% include '_components/_form_field.html.twig' with {
                'field': form.controlType,
                'label_key': form.controlType.vars.label,
                'translation_domain': 'control',
                'required': form.controlType.vars.required
            } %}
        </div>
        <div class="col-md-4">
            {% include '_components/_form_field.html.twig' with {
                'field': form.automationLevel,
                'label_key': form.automationLevel.vars.label,
                'translation_domain': 'control',
                'required': form.automationLevel.vars.required
            } %}
        </div>
        <div class="col-md-4">
            {% include '_components/_form_field.html.twig' with {
                'field': form.controlMaturity,
                'label_key': form.controlMaturity.vars.label,
                'translation_domain': 'control',
                'required': form.controlMaturity.vars.required
            } %}
        </div>
    </div>
</fieldset>

{# ── Effectiveness (F3: collapses when applicable=false) ───────────── #}
<fieldset class="mb-4" data-applicability-toggle-target="collapse">
    <legend class="h5 mb-3">{{ 'form.section.effectiveness'|trans({}, 'messages') }}</legend>
    <div class="row">
        <div class="col-md-4">
            {% include '_components/_form_field.html.twig' with {
                'field': form.effectiveness,
                'label_key': form.effectiveness.vars.label,
                'translation_domain': 'control',
                'required': form.effectiveness.vars.required
            } %}
        </div>
        <div class="col-md-4">
            {% include '_components/_form_field.html.twig' with {
                'field': form.lastEffectivenessTest,
                'label_key': form.lastEffectivenessTest.vars.label,
                'translation_domain': 'control',
                'required': form.lastEffectivenessTest.vars.required
            } %}
        </div>
        <div class="col-md-4">
            {% include '_components/_form_field.html.twig' with {
                'field': form.nextEffectivenessTest,
                'label_key': form.nextEffectivenessTest.vars.label,
                'translation_domain': 'control',
                'required': form.nextEffectivenessTest.vars.required
            } %}
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            {% include '_components/_form_field.html.twig' with {
                'field': form.evidenceDocuments,
                'label_key': form.evidenceDocuments.vars.label,
                'translation_domain': 'control',
                'required': form.evidenceDocuments.vars.required
            } %}
        </div>
    </div>
</fieldset>

{# ── Responsibility ───────────────────────────────────────────────── #}
<fieldset class="mb-4">
    <legend class="h5 mb-3">{{ 'form.section.responsibility'|trans({}, 'messages') }}</legend>
    {# F6 — User-or-Ref requirement marker. #}
    <p class="text-muted small mb-3">
        <i class="fa-icon fa-icon--ui-info-circle"></i>
        {{ 'control.help.owner_required_marker'|trans({}, 'control') }}
    </p>
    <div class="row">
        <div class="col-md-6">
            {{ form_row(form.responsiblePersonUser) }}
        </div>
        <div class="col-md-6">
            {{ form_row(form.responsiblePersonRef) }}
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            {{ form_row(form.responsibleDeputyPersons) }}
        </div>
    </div>
    {# F6 — legacy free-text owner hidden behind a collapsed disclosure. #}
    <details class="mt-2">
        <summary class="text-muted small">{{ 'control.disclosure.legacy_owner'|trans({}, 'control') }}</summary>
        <div class="mt-2">
            {% include '_components/_form_field.html.twig' with {
                'field': form.responsiblePerson,
                'label_key': form.responsiblePerson.vars.label,
                'translation_domain': 'control',
                'required': form.responsiblePerson.vars.required
            } %}
        </div>
    </details>
</fieldset>

{# ── Review ───────────────────────────────────────────────────────── #}
<fieldset class="mb-4">
    <legend class="h5 mb-3">{{ 'form.section.review'|trans({}, 'messages') }}</legend>
    <div class="row">
        <div class="col-md-6">
            {% include '_components/_form_field.html.twig' with {
                'field': form.lastReviewDate,
                'label_key': form.lastReviewDate.vars.label,
                'translation_domain': 'control',
                'required': form.lastReviewDate.vars.required
            } %}
        </div>
        <div class="col-md-6">
            {% include '_components/_form_field.html.twig' with {
                'field': form.nextReviewDate,
                'label_key': form.nextReviewDate.vars.label,
                'translation_domain': 'control',
                'required': form.nextReviewDate.vars.required
            } %}
        </div>
    </div>
</fieldset>

{# ── Framework references ─────────────────────────────────────────── #}
<fieldset class="mb-4">
    <legend class="h5 mb-3">{{ 'form.section.references'|trans({}, 'messages') }}</legend>
    {{ form_row(form.frameworkReferences) }}
</fieldset>

{# ── Relations ────────────────────────────────────────────────────── #}
<fieldset class="mb-4">
    <legend class="h5 mb-3">{{ 'form.section.relations'|trans({}, 'messages') }}</legend>
    <div class="row">
        <div class="col-md-12">
            {{ form_row(form.risks) }}
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            {% include '_components/_form_field.html.twig' with {
                'field': form.protectedAssets,
                'label_key': form.protectedAssets.vars.label,
                'translation_domain': 'control',
                'required': form.protectedAssets.vars.required
            } %}
        </div>
    </div>
</fieldset>

{# ── Cloud (module-gated: fields only present when 'cloud_security' active) ── #}
{% if form.cloudControlReference is defined %}
    <fieldset class="mb-4">
        <legend class="h5 mb-3">{{ 'form.section.cloud'|trans({}, 'messages') }}</legend>
        <div class="row">
            <div class="col-md-4">
                {% include '_components/_form_field.html.twig' with {
                    'field': form.cloudControlReference,
                    'label_key': form.cloudControlReference.vars.label,
                    'translation_domain': 'control',
                    'required': form.cloudControlReference.vars.required
                } %}
            </div>
            <div class="col-md-4">
                {% include '_components/_form_field.html.twig' with {
                    'field': form.cloudPrivacyReference,
                    'label_key': form.cloudPrivacyReference.vars.label,
                    'translation_domain': 'control',
                    'required': form.cloudPrivacyReference.vars.required
                } %}
            </div>
            <div class="col-md-4">
                {% include '_components/_form_field.html.twig' with {
                    'field': form.pimsReference,
                    'label_key': form.pimsReference.vars.label,
                    'translation_domain': 'control',
                    'required': form.pimsReference.vars.required
                } %}
            </div>
        </div>
        <div class="row">
            <div class="col-md-6">
                {% include '_components/_form_field.html.twig' with {
                    'field': form.customerOrProviderResponsibility,
                    'label_key': form.customerOrProviderResponsibility.vars.label,
                    'translation_domain': 'control',
                    'required': form.customerOrProviderResponsibility.vars.required
                } %}
            </div>
        </div>
    </fieldset>
{% endif %}

<div class="d-flex gap-2 mt-4">
    <button type="submit" class="fa-cyber-btn fa-cyber-btn--success">
        {{ 'common.save_changes'|trans({}, 'messages') }}
    </button>
    <a href="{{ path('app_soa_show', {id: control.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost">
        {{ 'common.cancel'|trans({}, 'messages') }}
    </a>
</div>

{# Render any field not explicitly placed above (safety net — must stay empty
   per SectionPolicy; surfaces accidental orphans in dev instead of dropping). #}
{{ form_rest(form) }}

{{ form_end(form) }}

{% endblock %}
