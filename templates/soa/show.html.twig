{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% trans_default_domain 'soa' %}

{% block title %}{{ control.controlId }} - {{ control.name }} - Little ISMS Helper{% endblock %}

{% block body %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.soa'|trans({}, 'nav'), url: path('app_soa_index') },
            { label: control.controlId ~ ': ' ~ control.name }
        ]
    } %}
</div>

<div class="page-header">
    <div>
        <h1>{{ control.controlId }}: {{ control.name }}</h1>
        <div class="mt-2">
            {% include '_components/_badge.html.twig' with { variant: 'info', content: ('soa.category.' ~ control.category)|trans({}, 'soa') } %}
            {% set mrisLocale = app.request.locale|default('de') %}
            {% if control.mythosResilience == 'standfest' %}
                <span data-bs-toggle="tooltip" title="{{ mris_help('mris.help.standfest', 'tooltip', mrisLocale) }}">
                    {% include '_components/_badge.html.twig' with { variant: 'success', content: 'soa.mris.standfest'|trans({}, 'soa') } %}
                </span>
            {% elseif control.mythosResilience == 'degradiert' %}
                <span data-bs-toggle="tooltip" title="{{ mris_help('mris.help.partially_degraded', 'tooltip', mrisLocale) }}">
                    {% include '_components/_badge.html.twig' with { variant: 'warning', content: 'soa.mris.degradiert'|trans({}, 'soa') } %}
                </span>
            {% elseif control.mythosResilience == 'reibung' %}
                <span data-bs-toggle="tooltip" title="{{ mris_help('mris.help.pure_friction', 'tooltip', mrisLocale) }}">
                    {% include '_components/_badge.html.twig' with { variant: 'danger', content: 'soa.mris.reibung'|trans({}, 'soa') } %}
                </span>
            {% elseif control.mythosResilience == 'nicht_betroffen' %}
                <span data-bs-toggle="tooltip" title="{{ mris_help('mris.help.not_affected', 'tooltip', mrisLocale) }}">
                    {% include '_components/_badge.html.twig' with { variant: 'secondary', content: 'soa.mris.nicht_betroffen'|trans({}, 'soa') } %}
                </span>
            {% endif %}
        </div>
    </div>
    <div class="button-group">
        <a href="{{ path('app_soa_edit', {id: control.id}) }}" class="btn btn-primary">
            <i class="bi bi-pencil" aria-hidden="true"></i> {{ 'soa.action.edit'|trans({}, 'soa') }}
        </a>
        {%- set categoryLabel = ('soa.category.' ~ control.category)|trans({}, 'soa') -%}
        <a href="{{ path('app_soa_by_category', {category: control.category}) }}" class="btn btn-secondary">
            ← {{ 'soa.action.back_to_category'|trans({'%category%': categoryLabel}, 'soa') }}
        </a>
    </div>
</div>

{# MRIS-Warning für "Reine Reibung"-Controls (gem. Peddi 2026, MRIS v1.5 Anhang A) #}
{% if control.mythosResilience == 'reibung' %}
<div data-tour="mris-reibung-warning">
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'danger', class: 'mb-4' } } %}
        {% block alert_body %}
            <strong>{{ 'soa.mris.reibung_warning_title'|trans({}, 'soa') }}</strong><br>
            {{ 'soa.mris.reibung_warning_body'|trans({}, 'soa') }}
            {% if control.mythosFlankingMhcs is not empty %}
                <br>
                <strong>{{ 'soa.mris.flanking_mhcs'|trans({}, 'soa') }}:</strong>
                {% for mhc in control.mythosFlankingMhcs %}
                    <code>{{ mhc }}</code>{% if not loop.last %}, {% endif %}
                {% endfor %}
            {% endif %}
            <br>
            <small class="text-muted">{{ 'soa.mris.source'|trans({}, 'soa') }}</small>
        {% endblock %}
    {% endembed %}
</div>
{% elseif control.mythosResilience == 'degradiert' and control.mythosFlankingMhcs is not empty %}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning', icon: 'bi-info-circle-fill', class: 'mb-4' } } %}
        {% block alert_body %}
            <strong>{{ 'soa.mris.degradiert_hint_title'|trans({}, 'soa') }}</strong><br>
            {{ 'soa.mris.degradiert_hint_body'|trans({}, 'soa') }}
            <strong>{{ 'soa.mris.flanking_mhcs'|trans({}, 'soa') }}:</strong>
            {% for mhc in control.mythosFlankingMhcs %}
                <code>{{ mhc }}</code>{% if not loop.last %}, {% endif %}
            {% endfor %}
            <br>
            <small class="text-muted">{{ 'soa.mris.source'|trans({}, 'soa') }}</small>
        {% endblock %}
    {% endembed %}
{% endif %}

{# Control Description #}
{% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
    {% block card_body %}
        <h2>{{ 'soa.section.description'|trans({}, 'soa') }}</h2>
        <p class="text-light-mt-sm-lh">
            {{ control.description }}
        </p>
    {% endblock %}
{% endembed %}

{# Applicability Status #}
{% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
    {% block card_body %}
        <h2>{{ 'soa.section.applicability_status'|trans({}, 'soa') }}</h2>
        <div class="stats-grid mt-2 grid-responsive-200">
            <div class="stat-item">
                <strong class="fs-4">
                    {% if control.applicable %}
                        {% include '_components/_badge.html.twig' with { variant: 'success', size: 'lg', content: '✓ ' ~ 'soa.value.yes'|trans({}, 'soa') } %}
                        <span class="visually-hidden">{{ 'soa.table.applicable'|trans({}, 'soa') }}</span>
                    {% else %}
                        {% include '_components/_badge.html.twig' with { variant: 'secondary', size: 'lg', class: 'badge-neutral-lg', content: '✗ ' ~ 'soa.status.not_applicable'|trans({}, 'soa') } %}
                    {% endif %}
                </strong>
                <span>{{ 'soa.field.applicable'|trans({}, 'soa') }}</span>
            </div>

            {% if control.applicable %}
            <div class="stat-item">
                <strong class="fs-4">
                    {% if control.implementationStatus == 'implemented' %}
                        {% include '_components/_badge.html.twig' with { variant: 'success', size: 'lg', icon: 'bi-check-circle', content: 'soa.status.implemented'|trans({}, 'soa') } %}
                    {% elseif control.implementationStatus == 'in_progress' %}
                        {% include '_components/_badge.html.twig' with { variant: 'warning', size: 'lg', icon: 'bi-arrow-clockwise', content: 'soa.status.in_progress'|trans({}, 'soa') } %}
                    {% elseif control.implementationStatus == 'not_started' %}
                        {% include '_components/_badge.html.twig' with { variant: 'danger', size: 'lg', icon: 'bi-pause-circle', content: 'soa.status.not_started'|trans({}, 'soa') } %}
                    {% else %}
                        {% include '_components/_badge.html.twig' with { variant: 'secondary', size: 'lg', class: 'badge-neutral-lg', content: 'soa.value.na'|trans({}, 'soa') } %}
                    {% endif %}
                </strong>
                <span>{{ 'soa.table.implementation_status'|trans({}, 'soa') }}</span>
            </div>

            <div class="stat-item">
                <strong class="fs-4">{{ control.implementationPercentage }}%</strong>
                <span>{{ 'soa.field.implementation_percentage'|trans({}, 'soa') }}</span>
            </div>
            {% endif %}
        </div>

        {% if control.applicable %}
        <div class="progress mt-3 progress-lg">
            <div class="progress-bar" style="width: {{ control.implementationPercentage }}%; font-size: 1rem;">
                {{ control.implementationPercentage }}%
            </div>
        </div>
        {% endif %}
    {% endblock %}
{% endembed %}

{# Justification #}
{% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
    {% block card_body %}
        <h2>{{ 'soa.section.justification'|trans({}, 'soa') }}</h2>
        {% if control.justification %}
            <div class="info-box mt-2 bg-body-secondary">
                <p class="ws-pre-wrap-lh">{{ control.justification }}</p>
            </div>
        {% else %}
            <p class="text-muted mt-sm">
                {{ 'soa.message.no_justification'|trans({}, 'soa') }}
            </p>
        {% endif %}
    {% endblock %}
{% endembed %}

{% if control.applicable %}
{# Implementation Details #}
{% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
    {% block card_body %}
        <h2>{{ 'soa.section.implementation_details'|trans({}, 'soa') }}</h2>

        <div class="form-group mt-3">
            <h2 class="fs-1 mb-sm">{{ 'soa.section.implementation_notes'|trans({}, 'soa') }}</h2>
            {% if control.implementationNotes %}
                <div class="info-box bg-body-secondary">
                    <p class="ws-pre-wrap-lh">{{ control.implementationNotes }}</p>
                </div>
            {% else %}
                <p class="text-muted">
                    {{ 'soa.message.no_implementation_notes'|trans({}, 'soa') }}
                </p>
            {% endif %}
        </div>

        <div class="stats-grid mt-3 grid-responsive-250">
            <div class="stat-item">
                <strong>
                    {% if control.responsiblePerson %}
                        {{ control.responsiblePerson }}
                    {% else %}
                        <span class="text-muted">{{ 'soa.field.unassigned'|trans({}, 'soa') }}</span>
                    {% endif %}
                </strong>
                <span>{{ 'soa.field.responsible_person'|trans({}, 'soa') }}</span>
            </div>

            <div class="stat-item">
                <strong>
                    {% if control.targetDate %}
                        {{ control.targetDate|date('d.m.Y') }}
                    {% else %}
                        <span class="text-muted">{{ 'soa.field.not_set'|trans({}, 'soa') }}</span>
                    {% endif %}
                </strong>
                <span>{{ 'soa.field.target_date'|trans({}, 'soa') }}</span>
            </div>
        </div>
    {% endblock %}
{% endembed %}
{% endif %}

{# Data Reuse: Protected Assets #}
{% if control.protectedAssets is defined and control.protectedAssets|length > 0 %}
{% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
    {% block card_body %}
        <h2><i class="fa-icon fa-icon--compliance-shield" aria-hidden="true"></i> {{ 'soa.section.data_reuse_protected_assets'|trans({'%count%': control.protectedAssets|length}, 'soa') }}</h2>
        {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', icon: 'bi-exclamation-triangle', class: 'mt-2' } } %}
            {% block alert_body %}<strong>{{ 'soa.label.control_coverage'|trans({}, 'soa') }}</strong> {{ 'soa.message.control_coverage'|trans({'%count%': control.protectedAssets|length, '%value%': control.protectedAssetValue}, 'soa') }} {% if control.highRiskAssetCount > 0 %} <br><strong><i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> {{ control.highRiskAssetCount }}</strong> {{ 'soa.message.high_risk_assets'|trans({}, 'soa') }} {% endif %}{% endblock %}
        {% endembed %}
        <div class="data-reuse-list">
            {% for asset in control.protectedAssets %}
                <div class="data-reuse-item">
                    <strong>{{ asset.name }}</strong>
                    {% include '_components/_badge.html.twig' with { variant: 'info', content: asset.assetType } %}
                    <small>{{ 'soa.field.cia'|trans({}, 'soa') }}: {{ asset.confidentialityValue }}/{{ asset.integrityValue }}/{{ asset.availabilityValue }}</small>
                </div>
            {% endfor %}
        </div>
    {% endblock %}
{% endembed %}
{% endif %}

{# Data Reuse: Related Risks #}
{% if control.risks is defined and control.risks|length > 0 %}
{% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
    {% block card_body %}
        <h2><i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> {{ 'soa.section.data_reuse_related_risks'|trans({'%count%': control.risks|length}, 'soa') }}</h2>
        <p class="text-light">{{ 'soa.message.related_risks_info'|trans({}, 'soa') }}</p>
        <div class="data-reuse-list">
            {% for risk in control.risks %}
                <div class="data-reuse-item">
                    <strong>{{ risk.title }}</strong>
                    <span class="{{ badge_score(risk.inherentRiskLevel, 16, 9) }}">
                        {{ 'soa.field.risk_level'|trans({}, 'soa') }}: {{ risk.inherentRiskLevel }}
                    </span>
                    <small>{{ 'soa.field.status'|trans({}, 'soa') }}: {{ risk.status|upper }}</small>
                </div>
            {% endfor %}
        </div>
    {% endblock %}
{% endembed %}
{% endif %}

{# Data Reuse: Related Incidents #}
{% if control.incidents is defined and control.incidents|length > 0 %}
{% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
    {% block card_body %}
        <h2><i class="bi bi-list-check" aria-hidden="true"></i> {{ 'soa.section.data_reuse_related_incidents'|trans({'%count%': control.incidents|length}, 'soa') }}</h2>
        {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning', icon: 'bi-exclamation-triangle' } } %}
            {% block alert_body %}<strong><i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> {{ control.incidents|length }} {{ 'soa.label.incidents'|trans({}, 'soa') }}</strong> {{ 'soa.message.related_incidents_count'|trans({}, 'soa') }} {% if control.isReviewNeeded %} <br><strong>{{ 'soa.label.review_required'|trans({}, 'soa') }}</strong> {{ 'soa.message.review_required'|trans({}, 'soa') }} {% endif %}{% endblock %}
        {% endembed %}
        <div class="data-reuse-list">
            {% for incident in control.incidents %}
                <div class="data-reuse-item">
                    <strong>{{ incident.title }}</strong>
                    <span class="{{ badge_severity(incident.severity) }}">
                        {{ incident.severity|upper }}
                    </span>
                    <small>{{ incident.detectedAt|date('Y-m-d') }}</small>
                </div>
            {% endfor %}
        </div>
    {% endblock %}
{% endembed %}
{% endif %}

{# Data Reuse: Training Coverage #}
{% if control.trainings is defined and control.trainings|length > 0 %}
{% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
    {% block card_body %}
        {% import '_components/_fa_alert.html.twig' as _fa_alert %}
        <h2>Training Coverage ({{ control.trainings|length }})</h2>
        {{ _fa_alert.render({ variant: control.hasTrainingCoverage ? 'success' : 'warning', body: '<strong>Status: ' ~ control.trainingStatus|upper ~ '</strong>' ~ (not control.hasTrainingCoverage ? '<br>Keine abgeschlossenen Trainings für dieses Control.' : '') }) }}
        <div class="data-reuse-list">
            {% for training in control.trainings %}
                <div class="data-reuse-item">
                    <strong>{{ training.title }}</strong>
                    <span class="{{ badge_status(training.status) }}">{{ training.status|upper }}</span>
                    {% if training.completionDate %}
                        <small>Abgeschlossen: {{ training.completionDate|date('Y-m-d') }}</small>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    {% endblock %}
{% endembed %}
{% endif %}

{# Control Effectiveness Score #}
{% if control.applicable and control.implementationPercentage == 100 %}
{% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
    {% block card_body %}
        <h2>Control Effectiveness</h2>
        <div class="stats-grid grid-responsive-200">
            <div class="stat-item">
                <strong style="font-size: 2rem; color: {{ control.effectivenessScore >= 80 ? 'var(--color-success)' : (control.effectivenessScore >= 50 ? 'var(--color-warning)' : 'var(--color-danger)') }}">
                    {{ control.effectivenessScore|number_format(1) }}%
                </strong>
                <span>Effectiveness Score</span>
            </div>
        </div>
        <p class="text-light-mt-sm">
            Basierend auf Incident-Analyse nach Control-Implementierung.
        </p>
    {% endblock %}
{% endembed %}
{% endif %}

{# Metadata #}
{% embed '_components/_card.html.twig' %}
    {% block card_body %}
        <h2>{{ 'soa.section.metadata'|trans({}, 'soa') }}</h2>
        <div class="stats-grid mt-2 grid-responsive-250">
            <div class="stat-item">
                <strong>{{ control.createdAt|date('d.m.Y H:i') }}</strong>
                <span>{{ 'soa.field.created_at'|trans({}, 'soa') }}</span>
            </div>

            <div class="stat-item">
                <strong>{{ control.updatedAt|date('d.m.Y H:i') }}</strong>
                <span>{{ 'soa.field.updated_at'|trans({}, 'soa') }}</span>
            </div>

            {% if control.lastReviewDate %}
            <div class="stat-item">
                <strong>{{ control.lastReviewDate|date('d.m.Y') }}</strong>
                <span>{{ 'soa.field.last_review'|trans({}, 'soa') }}</span>
            </div>
            {% endif %}

            {% if control.nextReviewDate %}
            <div class="stat-item">
                <strong>{{ control.nextReviewDate|date('d.m.Y') }}</strong>
                <span>{{ 'soa.field.next_review'|trans({}, 'soa') }}</span>
            </div>
            {% endif %}
        </div>
    {% endblock %}
{% endembed %}

{# A2 Auto-Mapping-Vorschläge #}
{% if mapping_suggestions is defined and mapping_suggestions|length > 0 %}
    {% embed '_components/_card.html.twig' with { class: 'mt-4 border-info' } %}
        {% block card_header %}
            <div class="card-header d-flex justify-content-between align-items-center">
                <h2 class="h6 mb-0">
                    <i class="bi bi-magic" aria-hidden="true"></i>
                    {{ 'control.mapping_suggestions.title'|trans({
                        '%count%': mapping_suggestions_total,
                        '%frameworks%': mapping_suggestions|length
                    }, 'control') }}
                </h2>
                <span class="badge text-bg-info">{{ mapping_suggestions_total }}</span>
            </div>
        {% endblock %}
        {% block card_body %}
            <p class="small text-muted">{{ 'control.mapping_suggestions.description'|trans({}, 'control') }}</p>

            {% for code, rows in mapping_suggestions %}
                <div class="mb-3">
                    <h3 class="h6">
                        <span class="badge bg-body-secondary border fa-status-pill fa-status-pill--neutral">{{ code }}</span>
                        {{ rows[0].framework.name }}
                    </h3>
                    <ul class="list-unstyled mb-0">
                        {% for row in rows %}
                            {% set conf_pct = (row.confidence * 100)|round %}
                            {% set conf_variant = conf_pct >= 50 ? 'success' : (conf_pct >= 30 ? 'warning' : 'secondary') %}
                            {% set conf_label = conf_pct >= 50
                                ? 'control.mapping_suggestions.confidence.high'|trans({}, 'control')
                                : (conf_pct >= 30
                                    ? 'control.mapping_suggestions.confidence.medium'|trans({}, 'control')
                                    : 'control.mapping_suggestions.confidence.low'|trans({}, 'control'))
                            %}
                            <li class="d-flex justify-content-between align-items-start border-bottom py-2">
                                <div class="flex-grow-1">
                                    <div>
                                        <code>{{ row.requirement.requirementId }}</code>
                                        <span class="ms-1">{{ row.requirement.title }}</span>
                                    </div>
                                    {% if row.requirement.category %}
                                        <div class="small text-muted">{{ row.requirement.category }}</div>
                                    {% endif %}
                                </div>
                                <div class="ms-2 d-flex align-items-center gap-2">
                                    <span class="badge text-bg-{{ conf_variant }}"
                                          title="{{ 'control.mapping_suggestions.confidence.tooltip'|trans({'%pct%': conf_pct}, 'control') }}"
                                          data-bs-toggle="tooltip">
                                        {{ conf_label }}
                                    </span>
                                    <form method="post"
                                          action="{{ path('app_soa_accept_suggestion', { id: control.id, requirementId: row.requirement.id }) }}"
                                          class="d-inline">
                                        <input type="hidden" name="_token"
                                               value="{{ csrf_token('accept_suggestion_' ~ control.id ~ '_' ~ row.requirement.id) }}">
                                        <input type="hidden" name="confidence" value="{{ row.confidence }}">
                                        <button type="submit" class="btn btn-sm btn-outline-success">
                                            <i class="bi bi-plus-circle" aria-hidden="true"></i>
                                            {{ 'control.mapping_suggestions.accept'|trans({}, 'control') }}
                                        </button>
                                    </form>
                                </div>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            {% endfor %}

            <div class="small text-muted mt-2">
                <i class="bi bi-info-circle" aria-hidden="true"></i>
                {{ 'control.mapping_suggestions.footer_hint'|trans({}, 'control') }}
            </div>
        {% endblock %}
    {% endembed %}
{% endif %}

{# Action Buttons #}
<div class="d-flex gap-2 mt-4">
    <a href="{{ path('app_soa_edit', {id: control.id}) }}" class="btn btn-success">
        <i class="bi bi-pencil" aria-hidden="true"></i> {{ 'soa.action.edit'|trans({}, 'soa') }}
    </a>
    <a href="{{ path('app_soa_index') }}" class="btn btn-secondary">
        <i class="bi bi-list" aria-hidden="true"></i> {{ 'common.back_to_list'|trans({}, 'messages') }}
    </a>
</div>

<style>
/* Data Reuse Sections */
.data-reuse-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 1rem;
}
.data-reuse-item {
    padding: 0.75rem;
    background: var(--surface-2);
    border-left: 3px solid var(--primary);
    border-radius: 4px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
}
/* .alert / .alert-* — styled centrally in fairy-aurora-components.css */
/* .badge-risk-* / .badge-severity-* removed: dead code. BadgeExtension
   functions render "badge bg-<color>" classes — Aurora's .badge.bg-*
   rules style them. */
</style>
{% endblock %}
