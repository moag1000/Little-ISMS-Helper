{% extends 'base.html.twig' %}
{% trans_default_domain 'soa' %}
{% import '_macros/inheritance_badge.html.twig' as inheritance %}
{% import '_macros/cards.html.twig' as cards %}

{% block title %}{{ 'soa.page.title'|trans({}, 'soa') }} - Little ISMS Helper{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {# Sticky header styles now in app.css - Dark mode compatible #}
{% endblock %}

{% block body %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% include '_components/_breadcrumb.html.twig' with {
    breadcrumbs: [
        { label: 'nav.soa'|trans({}, 'nav') }
    ]
} %}

{{ _fa_page_header.render({
    badge: { icon: 'shield-check', label: 'nav.soa'|trans({}, 'nav') },
    title: 'soa.page.title'|trans({}, 'soa'),
    subtitle: 'soa.page.subtitle'|trans({}, 'soa'),
    actions: [
        { label: 'soa.action.export_html'|trans({}, 'soa'), variant: 'ghost', icon: 'file-earmark-text', href: path('app_soa_export') },
        { label: 'soa.action.export_pdf'|trans({}, 'soa'), variant: 'secondary', icon: 'file-earmark-pdf', href: path('app_soa_export_pdf') },
        { label: 'soa.action.preview_pdf'|trans({}, 'soa'), variant: 'ghost', icon: 'eye', href: path('app_soa_preview_pdf') }
    ]
}) }}
{# TODO: export/preview actions above use Turbo navigation; add data-turbo="false" via custom markup if full-page download is required #}
<p class="text-muted small mb-0 mt-n2"><a href="{{ path('app_help_glossary') }}#glossary-soa" class="text-muted" title="{{ 'common.glossary_link'|trans({}, 'messages') }}" data-bs-toggle="tooltip"><i class="bi bi-question-circle" aria-hidden="true" style="font-size: 0.75rem;"></i> {{ 'common.glossary_link'|trans({}, 'messages') }}</a></p>

<main class="fa-aurora-surface">

{# View Filter #}
{% if currentTenant %}
{% embed '_components/_card.html.twig' with {
    'class': 'mb-3'
} %}
    {% block card_body %}
        <form method="get" action="{{ path('app_soa_index') }}" class="d-flex align-items-center gap-2">
            <label for="view-filter" class="mb-0 fw-bold">
                <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i> {{ 'common.view'|trans({}, 'messages') }}:
            </label>
            <select class="form-select form-select-sm w-auto" id="view-filter" name="view" data-controller="ui-actions" data-action="change->ui-actions#autoSubmit">
                <option value="own" {{ inheritanceInfo.currentView == 'own' ? 'selected' : '' }}>
                    {{ 'corporate.view.own_only'|trans({}, 'messages') }}
                </option>
                {% if inheritanceInfo.hasParent %}
                <option value="inherited" {{ inheritanceInfo.currentView == 'inherited' ? 'selected' : '' }}>
                    {{ 'corporate.view.including_inherited'|trans({}, 'messages') }}
                </option>
                {% endif %}
                {% if inheritanceInfo.hasSubsidiaries %}
                <option value="subsidiaries" {{ inheritanceInfo.currentView == 'subsidiaries' ? 'selected' : '' }}>
                    {{ 'corporate.view.including_subsidiaries'|trans({}, 'messages') }}
                </option>
                {% endif %}
            </select>
            <noscript>
                <button type="submit" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost">{{ 'common.apply'|trans({}, 'messages') }}</button>
            </noscript>
        </form>
    {% endblock %}
{% endembed %}
{% endif %}

{# KPI Cards #}
<div class="kpi-grid">
    <div class="col-auto">
        {% if currentTenant %}
            {% set subtitle = 'corporate.stats.breakdown'|trans({'%own%': detailedStats.own, '%inherited%': detailedStats.inherited, '%subsidiaries%': detailedStats.subsidiaries}, 'messages') %}
            {{ cards.kpi_card(('soa.kpi.total_controls'|trans({}, 'soa')), detailedStats.total, subtitle, null, 'primary', null) }}
        {% else %}
            {{ cards.kpi_card(('soa.kpi.total_controls'|trans({}, 'soa')), detailedStats.total, null, null, 'primary', null) }}
        {% endif %}
    </div>
    <div class="col-auto">
        {{ cards.kpi_card(('soa.kpi.applicable_controls'|trans({}, 'soa')), controls|filter(c => c.applicable)|length, null, null, 'success', null) }}
    </div>
    <div class="col-auto">
        {% set implemented = controls|filter(c => c.applicable and c.implementationStatus == 'implemented')|length %}
        {% set applicable = controls|filter(c => c.applicable)|length %}
        {{ cards.kpi_card(('soa.kpi.implemented_controls'|trans({}, 'soa')), implemented, ('soa.kpi.of'|trans({}, 'soa')) ~ ' ' ~ applicable, null, 'info', null) }}
    </div>
    <div class="col-auto">
        {% set applicable = controls|filter(c => c.applicable)|length %}
        {% set implemented = controls|filter(c => c.applicable and c.implementationStatus == 'implemented')|length %}
        {% set percentage = applicable > 0 ? (implemented / applicable * 100)|round : 0 %}
        {{ cards.kpi_card(('soa.kpi.compliance_rate'|trans({}, 'soa')), percentage ~ '%', null, percentage, 'warning', null) }}
    </div>
</div>

{# Category Overview #}
<h2>{{ 'soa.section.by_category'|trans({}, 'soa') }}</h2>

<div class="module-grid">
    {% set categories = {
        'Organizational': '🏢',
        'People': '👥',
        'Physical': '🏠',
        'Technological': '💻'
    } %}

    {% for category, icon in categories %}
        {% set cat_controls = controls|filter(c => c.category == category) %}
        {% set applicable_controls = cat_controls|filter(c => c.applicable) %}
        {% set implemented_controls = applicable_controls|filter(c => c.implementationStatus == 'implemented') %}

        {% embed '_components/_card.html.twig' %}
            {% block card_body %}
                <div class="fs-2-mb-sm">{{ icon }}</div>
                <h2>{{ ('soa.category.' ~ category)|trans({}, 'soa') }} {{ 'soa.label.controls'|trans({}, 'soa') }}</h2>
                <div class="stats-grid mt-2">
                    <div class="stat-item">
                        <strong>{{ cat_controls|length }}</strong>
                        <span>{{ 'soa.kpi.total_controls'|trans({}, 'soa') }}</span>
                    </div>
                    <div class="stat-item">
                        <strong>{{ applicable_controls|length }}</strong>
                        <span>{{ 'soa.kpi.applicable_controls'|trans({}, 'soa') }}</span>
                    </div>
                    <div class="stat-item">
                        <strong>{{ implemented_controls|length }}</strong>
                        <span>{{ 'soa.kpi.implemented_controls'|trans({}, 'soa') }}</span>
                    </div>
                </div>

                {% set impl_percentage = applicable_controls|length > 0 ? (implemented_controls|length / applicable_controls|length * 100)|round : 0 %}
                <div class="progress mt-2">
                    <div class="progress-bar" style="width: {{ impl_percentage }}%">
                        {{ impl_percentage }}%
                    </div>
                </div>

                <div class="mt-2">
                    <a href="{{ path('app_soa_by_category', {category: category}) }}" class="btn btn-sm">{{ 'soa.action.view_details'|trans({}, 'soa') }}</a>
                </div>
            {% endblock %}
        {% endembed %}
    {% endfor %}
</div>

{# Filter and Table #}
<h2>{{ 'soa.section.all_controls'|trans({}, 'soa') }}</h2>

{# WS-5 Bulk tag actions bar (polymorphic) #}
{% if is_granted('TAG_APPLY') %}
    {% include '_components/_bulk_action_bar.html.twig' with {
        entity_class:   'App\\Entity\\Control',
        action_urls: {
            tag_add: path('admin_tag_bulk_apply', {entityClass: 'Control'}),
        },
        available_tags: available_tags(),
    } only %}
{% endif %}

{# C3 Bulk-Edit Applicability (Sprint 3) — power-user tool for CM #}
{% if is_granted('ROLE_MANAGER') %}
    <details class="card fa-section mb-3">
        <summary class="card-header" style="cursor: pointer;">
            <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i>
            <strong>{{ 'control.bulk.title'|trans({}, 'control') }}</strong>
            <small class="text-muted ms-2">{{ 'control.bulk.hint'|trans({}, 'control') }}</small>
        </summary>
        <div class="card-body">
            <form method="post" action="{{ path('app_soa_bulk_applicability') }}" class="row g-2 align-items-end">
                <input type="hidden" name="_token" value="{{ csrf_token('soa_bulk_applicability') }}">
                <div class="col-md-4">
                    <label for="bulk-control-ids" class="form-label small">{{ 'control.bulk.ids'|trans({}, 'control') }}</label>
                    <input type="text" id="bulk-control-ids" name="control_ids_raw" class="form-control form-control-sm"
                           placeholder="12, 34, 56">
                </div>
                <div class="col-md-2">
                    <label for="bulk-applicable" class="form-label small">{{ 'control.bulk.status'|trans({}, 'control') }}</label>
                    <select id="bulk-applicable" name="applicable" class="form-select form-select-sm">
                        <option value="0">{{ 'control.bulk.non_applicable'|trans({}, 'control') }}</option>
                        <option value="1">{{ 'control.bulk.applicable'|trans({}, 'control') }}</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label for="bulk-reason" class="form-label small">{{ 'control.bulk.reason'|trans({}, 'control') }}</label>
                    <input type="text" id="bulk-reason" name="reason" class="form-control form-control-sm"
                           placeholder="{{ 'control.bulk.reason_placeholder'|trans({}, 'control') }}">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--sm w-100"
                            onclick="this.form.querySelectorAll('[name=control_ids_raw]')[0].value.split(/[,\s]+/).filter(Boolean).forEach(id => { var h = document.createElement('input'); h.type='hidden'; h.name='control_ids[]'; h.value=id; this.form.appendChild(h); });">
                        <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i>
                        {{ 'control.bulk.submit'|trans({}, 'control') }}
                    </button>
                </div>
            </form>
            <div class="small text-muted mt-2">
                <i class="fa-icon fa-icon--ui-info" aria-hidden="true"></i>
                {{ 'control.bulk.footer_hint'|trans({}, 'control') }}
            </div>
        </div>
    </details>
{% endif %}

{# Search-first Filter: URL-persisted state (UXC-11 / UXC-12) #}
{% embed '_components/_search_filter_form.html.twig' with {
    action: path('app_soa_index'),
    filter_keys: ['category', 'status', 'mris', 'view', 'tag'],
    search_placeholder: 'soa.filter.search_placeholder'|trans({}, 'soa'),
    form_id: 'soa-filter-form'
} %}
    {% block filters %}
        {% if app.request.query.get('view') %}
            <input type="hidden" name="view" value="{{ app.request.query.get('view') }}">
        {% endif %}
        <div class="col-md-4">
            <label for="category-filter" class="form-label">{{ 'soa.filter.category'|trans({}, 'soa') }}</label>
            <select id="category-filter" name="category" class="form-select">
                <option value="">{{ 'soa.filter.all_categories'|trans({}, 'soa') }}</option>
                <option value="Organizational" {{ app.request.query.get('category') == 'Organizational' ? 'selected' : '' }}>{{ 'soa.category.Organizational'|trans({}, 'soa') }}</option>
                <option value="People" {{ app.request.query.get('category') == 'People' ? 'selected' : '' }}>{{ 'soa.category.People'|trans({}, 'soa') }}</option>
                <option value="Physical" {{ app.request.query.get('category') == 'Physical' ? 'selected' : '' }}>{{ 'soa.category.Physical'|trans({}, 'soa') }}</option>
                <option value="Technological" {{ app.request.query.get('category') == 'Technological' ? 'selected' : '' }}>{{ 'soa.category.Technological'|trans({}, 'soa') }}</option>
            </select>
        </div>
        <div class="col-md-4">
            <label for="status-filter" class="form-label">{{ 'soa.filter.status'|trans({}, 'soa') }}</label>
            <select id="status-filter" name="status" class="form-select">
                <option value="">{{ 'soa.filter.all_status'|trans({}, 'soa') }}</option>
                <option value="implemented" {{ app.request.query.get('status') == 'implemented' ? 'selected' : '' }}>{{ 'soa.status.implemented'|trans({}, 'soa') }}</option>
                <option value="in_progress" {{ app.request.query.get('status') == 'in_progress' ? 'selected' : '' }}>{{ 'soa.status.in_progress'|trans({}, 'soa') }}</option>
                <option value="not_started" {{ app.request.query.get('status') == 'not_started' ? 'selected' : '' }}>{{ 'soa.status.not_started'|trans({}, 'soa') }}</option>
                <option value="not_applicable" {{ app.request.query.get('status') == 'not_applicable' ? 'selected' : '' }}>{{ 'soa.status.not_applicable'|trans({}, 'soa') }}</option>
            </select>
        </div>
        <div class="col-md-4">
            <label for="mris-filter" class="form-label">{{ 'soa.filter.mris'|trans({}, 'soa') }}
                <small class="text-muted" title="MRIS v1.5 nach Peddi (CC BY 4.0)">ⓘ</small>
            </label>
            <select id="mris-filter" name="mris" class="form-select">
                <option value="">{{ 'soa.filter.mris_all'|trans({}, 'soa') }}</option>
                <option value="standfest" {{ mrisFilter == 'standfest' ? 'selected' : '' }}>{{ 'soa.mris.standfest'|trans({}, 'soa') }} ({{ mrisStats.standfest|default(0) }})</option>
                <option value="degradiert" {{ mrisFilter == 'degradiert' ? 'selected' : '' }}>{{ 'soa.mris.degradiert'|trans({}, 'soa') }} ({{ mrisStats.degradiert|default(0) }})</option>
                <option value="reibung" {{ mrisFilter == 'reibung' ? 'selected' : '' }}>{{ 'soa.mris.reibung'|trans({}, 'soa') }} ({{ mrisStats.reibung|default(0) }})</option>
                <option value="nicht_betroffen" {{ mrisFilter == 'nicht_betroffen' ? 'selected' : '' }}>{{ 'soa.mris.nicht_betroffen'|trans({}, 'soa') }} ({{ mrisStats.nicht_betroffen|default(0) }})</option>
            </select>
        </div>
    {% endblock %}
{% endembed %}

{% embed '_components/_table.html.twig' with {
    'stickyHeader': true,
    'theadClass': 'table-light',
    'wrapperClass': 'table-container'
} %}
    {% import '_macros/inheritance_badge.html.twig' as inheritance %}
    {% block table_head %}
        <tr>
            <th scope="col" style="min-width: 100px;">{{ 'soa.table.control_id'|trans({}, 'soa') }}</th>
            <th scope="col" style="min-width: 250px;">{{ 'soa.table.name'|trans({}, 'soa') }}</th>
            <th scope="col" style="min-width: 120px;">{{ 'soa.table.category'|trans({}, 'soa') }}</th>
            <th scope="col" class="text-center" style="min-width: 130px;" title="{{ 'soa.table.mris_help'|trans({}, 'soa') }}" data-tour="mris-soa-column">{{ 'soa.table.mris'|trans({}, 'soa') }}</th>
            <th scope="col" class="text-center" style="min-width: 100px;">{{ 'soa.table.applicable'|trans({}, 'soa') }}</th>
            <th scope="col" style="min-width: 150px;">{{ 'soa.table.implementation_status'|trans({}, 'soa') }}</th>
            <th scope="col" class="text-center" style="min-width: 120px;">{{ 'soa.table.progress'|trans({}, 'soa') }}</th>
            <th scope="col" class="text-center" style="min-width: 180px;">{{ 'soa.table.actions'|trans({}, 'soa') }}</th>
        </tr>
    {% endblock %}
    {% block table_body %}
        {% import '_macros/inheritance_badge.html.twig' as inheritance %}
        {% for control in controls %}
        <tr data-filter-target="filterableRow" data-category="{{ control.category }}" data-status="{{ control.implementationStatus }}">
            <td>{% include '_components/_iso_reference_label.html.twig' with { control: control, show_name: false, code_class: 'fw-bold' } only %}</td>
            <td>
                {{ control.name }}
                {{ inheritance.small_badge(control, currentTenant) }}
            </td>
            <td>
                {% include '_components/_badge.html.twig' with { variant: 'info', content: ('soa.category.' ~ control.category)|trans({}, 'soa') } %}
            </td>
            <td class="text-center">
                {% set mrisLocale = app.request.locale|default('de') %}
                {% if control.mythosResilience == 'standfest' %}
                    <span data-bs-toggle="tooltip" title="{{ mris_help('mris.help.standfest', 'tooltip', mrisLocale) }}">
                        {% include '_components/_badge.html.twig' with { variant: 'success', content: 'soa.mris.standfest'|trans({}, 'soa') } %}
                    </span>
                {% elseif control.mythosResilience == 'degradiert' %}
                    <span data-bs-toggle="tooltip" title="{{ mris_help('mris.help.partially_degraded', 'tooltip', mrisLocale) }}">
                        {% include '_components/_badge.html.twig' with { variant: 'warning', content: 'soa.mris.degradiert'|trans({}, 'soa') } %}
                    </span>
                {% elseif control.mythosResilience == 'reibung' %}
                    <span data-bs-toggle="tooltip" title="{{ mris_help('mris.help.pure_friction', 'tooltip', mrisLocale) }}">
                        {% include '_components/_badge.html.twig' with { variant: 'danger', content: 'soa.mris.reibung'|trans({}, 'soa') } %}
                    </span>
                {% elseif control.mythosResilience == 'nicht_betroffen' %}
                    <span data-bs-toggle="tooltip" title="{{ mris_help('mris.help.not_affected', 'tooltip', mrisLocale) }}">
                        {% include '_components/_badge.html.twig' with { variant: 'secondary', class: 'badge-neutral', content: 'soa.mris.nicht_betroffen'|trans({}, 'soa') } %}
                    </span>
                {% else %}
                    <span class="text-muted small">—</span>
                {% endif %}
                {% if control.mythosFlankingMhcs is not empty %}
                    <div class="small text-muted mt-1" data-bs-toggle="tooltip" title="{{ mris_help('mris.help.flanking_mhcs', 'tooltip', mrisLocale) }}">{{ control.mythosFlankingMhcs|join(', ') }}</div>
                {% endif %}
            </td>
            <td class="text-center">
                {% if control.applicable %}
                    {% include '_components/_badge.html.twig' with { variant: 'success', content: '✓ ' ~ 'soa.value.yes'|trans({}, 'soa') } %}
                {% else %}
                    {% include '_components/_badge.html.twig' with { variant: 'secondary', class: 'badge-neutral', content: '✗ ' ~ 'soa.value.no'|trans({}, 'soa') } %}
                {% endif %}
            </td>
            <td>
                {% if control.applicable %}
                    {% if control.implementationStatus == 'implemented' %}
                        {% include '_components/_badge.html.twig' with { variant: 'success', icon: 'bi-check-circle', content: 'soa.status.implemented'|trans({}, 'soa') } %}
                    {% elseif control.implementationStatus == 'in_progress' %}
                        {% include '_components/_badge.html.twig' with { variant: 'warning', icon: 'bi-arrow-clockwise', content: 'soa.status.in_progress'|trans({}, 'soa') } %}
                    {% elseif control.implementationStatus == 'not_started' %}
                        {% include '_components/_badge.html.twig' with { variant: 'danger', icon: 'bi-pause-circle', content: 'soa.status.not_started'|trans({}, 'soa') } %}
                    {% else %}
                        {% include '_components/_badge.html.twig' with { variant: 'secondary', class: 'badge-neutral', content: 'soa.value.na'|trans({}, 'soa') } %}
                    {% endif %}
                {% else %}
                    {% include '_components/_badge.html.twig' with { variant: 'secondary', class: 'badge-neutral', content: 'soa.status.not_applicable'|trans({}, 'soa') } %}
                {% endif %}
            </td>
            <td>
                {% if control.applicable %}
                    <div class="progress progress-compact">
                        <div class="progress-bar" style="width: {{ control.implementationPercentage }}%; font-size: 0.75rem;">
                            {{ control.implementationPercentage }}%
                        </div>
                    </div>
                {% else %}
                    <span class="text-center-block-light">-</span>
                {% endif %}
            </td>
            <td class="text-center">
                <div class="btn-group btn-group-sm" role="group" aria-label="{{ 'common.actions'|trans({}, 'messages') }}">
                    <a href="{{ path('app_soa_show', {id: control.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost" title="{{ 'common.view'|trans({}, 'messages') }}" aria-label="{{ 'common.view'|trans({}, 'messages') }}">👁 {{ 'common.view'|trans({}, 'messages') }}</a>
                    <a href="{{ path('app_soa_edit', {id: control.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost" title="{{ 'common.edit'|trans({}, 'messages') }}" aria-label="{{ 'common.edit'|trans({}, 'messages') }}"><i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i> {{ 'common.edit'|trans({}, 'messages') }}</a>
                </div>
            </td>
        </tr>
        {% endfor %}
    {% endblock %}
{% endembed %}

{% if controls|length == 0 %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
{{ _fa_empty_state.render({
    mood: 'curious',
    title: 'soa.message.no_controls_filtered'|trans({}, 'soa')
}) }}
{% endif %}
</main>
{% endblock %}
