{% extends 'pdf/_base_document.html.twig' %}
{% trans_default_domain 'soa' %}

{# Document Metadata #}
{% block document_id %}DOC-ISMS-SOA-001{% endblock %}
{% block document_title %}{{ 'page.title'|trans({}, 'messages') }}{% endblock %}
{% block document_type %}{{ 'report.document_type'|trans({}, 'reports') }}{% endblock %}
{% block document_version %}{{ version }}{% endblock %}
{% block document_status %}{{ status|default(('status.approved'|trans({}, 'messages'))) }}{% endblock %}
{% block document_status_class %}{{ status|default('approved')|lower }}{% endblock %}
{% block document_classification %}{{ 'label.classification_confidential'|trans({}, 'messages') }}{% endblock %}
{% block classification_class %}confidential{% endblock %}

{# Header/Footer #}
{% block header_center %}{{ 'report.header_center'|trans({}, 'reports') }}{% endblock %}
{% block header_right %}{{ 'label.classification_confidential_upper'|trans({}, 'messages') }}{% endblock %}
{% block footer_version %}{{ version }}{% endblock %}

{# Show Approval Section #}
{% set show_approval = true %}
{% block reviewer_name %}{{ app.user.fullName|default(('report.default_reviewer'|trans({}, 'reports'))) }}{% endblock %}
{% block review_date %}{{ generatedAt|date('d.m.Y') }}{% endblock %}
{% block approver_name %}{{ approver|default(('report.default_approver'|trans({}, 'messages'))) }}{% endblock %}
{% block approval_date %}{{ approval_date|default(generatedAt|date('d.m.Y')) }}{% endblock %}

{# Show Version History - Beispieldaten! Echte Versionsdaten vom Controller übergeben! #}
{% set show_version_history = true %}
{% block version_history %}
{# Beispiel-Versionsverlauf - durch echte Daten vom Controller ersetzen:
   {% for versionEntry in versionHistory %}
   <tr>
       <td>{{ versionEntry.version }}</td>
       <td>{{ versionEntry.date|date('d.m.Y') }}</td>
       <td>{{ versionEntry.author }}</td>
       <td>{{ versionEntry.changes }}</td>
   </tr>
   {% endfor %}
#}
<tr>
    <td>1.0</td>
    <td>{{ generatedAt|date_modify('-6 months')|date('d.m.Y') }}</td>
    <td>ISMS Team</td>
    <td>Initiale Version nach ISO 27001:2022</td>
</tr>
<tr>
    <td>1.5</td>
    <td>{{ generatedAt|date_modify('-3 months')|date('d.m.Y') }}</td>
    <td>{{ app.user.fullName }}</td>
    <td>Aktualisierung Controls A.8 und A.11</td>
</tr>
<tr>
    <td>2.0</td>
    <td>{{ generatedAt|date('d.m.Y') }}</td>
    <td>{{ app.user.fullName }}</td>
    <td>Vollständige Überprüfung aller Controls, Status-Update</td>
</tr>
{% endblock %}

{# Custom Styles for SoA — Aurora token CSS (no raw hex) #}
{% block custom_styles %}
.stats-grid       { display: table; width: 100%; margin-bottom: 20pt; border-collapse: collapse; border: 2px solid var(--border); }
.stats-row        { display: table-row; }
.stats-cell       { display: table-cell; padding: 10pt; text-align: center; border: 1px solid var(--border); width: 25%; background: var(--surface-2); }
.stats-label      { font-size: 8pt; color: var(--fg-2); text-transform: uppercase; font-weight: bold; margin-bottom: 5pt; letter-spacing: 0.5pt; }
.stats-value      { font-size: 18pt; color: var(--primary); font-weight: bold; }

.control-table    { width: 100%; border-collapse: collapse; margin-bottom: 14pt; font-size: 8pt; border: 1px solid var(--border); }
.control-table th { background: var(--fg); color: var(--surface); padding: 5pt; text-align: left; font-weight: bold; border: 1px solid var(--border); text-transform: uppercase; letter-spacing: 0.3pt; }
.control-table td { padding: 4pt; border: 1px solid var(--border); vertical-align: top; }
.control-table tr:nth-child(even) { background: var(--surface-2); }
.control-id       { font-weight: bold; color: var(--primary); white-space: nowrap; }

.badge {
    display: inline-block;
    padding: 2pt 5pt;
    border-radius: 3pt;
    font-size: 7pt;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 0.3pt;
}
.badge-implemented     { background: var(--success-tint); color: var(--success); }
.badge-partial         { background: var(--warning-tint); color: var(--warning); }
.badge-not-implemented { background: var(--danger-tint);  color: var(--danger);  }
.badge-planned         { background: #dbeafe; color: var(--info-text); }
.badge-applicable      { background: var(--success-tint); color: var(--success); }
.badge-not-applicable  { background: var(--surface-2); color: var(--fg-2); border: 1px solid var(--border); }

.category-header {
    background: var(--info-tint);
    padding: 7pt 10pt;
    margin-top: 12pt;
    margin-bottom: 7pt;
    border-left: 4px solid var(--primary);
    font-weight: bold;
    font-size: 9.5pt;
    color: var(--info-text);
    text-transform: uppercase;
    letter-spacing: 0.4pt;
}

.percentage { font-weight: bold; color: var(--primary); }
{% endblock %}

{# Main Document Content #}
{% block document_content %}

{# Executive Summary #}
<h1>{{ 'soa.title'|trans({}, 'soa')}}</h1>
<p class="text-center text-muted mb-medium">
    {{ 'report.pdf.subtitle'|trans }}
</p>

<div class="mb-large">
    <h2>{{ 'report.pdf.section_summary'|trans }}</h2>
    <p>
        {{ 'report.pdf.intro_line1'|trans({'%tenant%': '<strong>' ~ tenant_name|default('report.pdf.default_tenant'|trans) ~ '</strong>'})|raw }}
    </p>
    <p>
        {{ 'report.pdf.intro_line2'|trans }}
    </p>
</div>

{# Statistics Overview #}
<h2>{{ 'section.implementation_overview'|trans }}</h2>
<div class="stats-grid">
    <div class="stats-row">
        <div class="stats-cell">
            <div class="stats-label">{{ 'kpi.total_controls'|trans }}</div>
            <div class="stats-value">{{ stats.total }}</div>
        </div>
        <div class="stats-cell">
            <div class="stats-label">{{ 'kpi.applicable_controls'|trans }}</div>
            <div class="stats-value">{{ stats.total }}</div>
        </div>
        <div class="stats-cell">
            <div class="stats-label">{{ 'status.implemented'|trans }}</div>
            <div class="stats-value">{{ stats.implemented }}</div>
        </div>
        <div class="stats-cell">
            <div class="stats-label">{{ 'kpi.compliance_rate'|trans }}</div>
            <div class="stats-value">
                <span class="percentage">{% if stats.total > 0 %}{{ ((stats.implemented / stats.total) * 100)|round }}%{% else %}0%{% endif %}</span>
            </div>
        </div>
    </div>
</div>

<div class="mb-large">
    <p><strong>{{ 'report.pdf.implementation_status_heading'|trans }}</strong></p>
    <ul>
        <li>{{ 'report.pdf.stat_fully_implemented'|trans({'%count%': stats.implemented}) }}</li>
        <li>{{ 'report.pdf.stat_in_progress'|trans({'%count%': stats.in_progress}) }}</li>
        <li>{{ 'report.pdf.stat_not_started'|trans({'%count%': stats.not_started}) }}</li>
        <li>{{ 'report.pdf.stat_not_applicable'|trans({'%count%': stats.not_applicable}) }}</li>
    </ul>
</div>

{# Controls by Category #}
<div class="page-break"></div>
<h2>{{ 'section.controls_by_category'|trans }}</h2>

{% for categoryName, categoryControls in controlsByCategory %}
<div class="category-header">{{ categoryName }}</div>

<table class="control-table">
    <thead>
        <tr>
            <th scope="col" style="width: 8%;">{{ 'table.control_id'|trans }}</th>
            <th scope="col" style="width: 22%;">{{ 'table.name'|trans }}</th>
            <th scope="col" style="width: 30%;">{{ 'section.description'|trans }}</th>
            <th scope="col" style="width: 12%;" class="text-center">{{ 'table.mris'|trans }}<br><span style="font-weight:normal;font-size:10px;">(Peddi 2026)</span></th>
            <th scope="col" style="width: 8%;" class="text-center">{{ 'table.applicable'|trans }}</th>
            <th scope="col" style="width: 10%;" class="text-center">{{ 'field.status'|trans }}</th>
            <th scope="col" style="width: 10%;" class="text-center">{{ 'table.progress'|trans }}</th>
        </tr>
    </thead>
    <tbody>
        {% for control in categoryControls %}
        <tr>
            <td class="control-id">{{ control.controlId }}</td>
            <td><strong>{{ control.name }}</strong></td>
            <td class="text-muted">{{ control.description|slice(0, 200) }}{% if control.description|length > 200 %}...{% endif %}</td>
            <td class="text-center">
                {% if control.mythosResilience == 'standfest' %}<span class="badge" style="background:#d1e7dd;color:#0f5132;">{{ 'mris.standfest'|trans }}</span>
                {% elseif control.mythosResilience == 'degradiert' %}<span class="badge" style="background:#fff3cd;color:#664d03;">{{ 'report.pdf.mris_degradiert_short'|trans }}</span>
                {% elseif control.mythosResilience == 'reibung' %}<span class="badge" style="background:#f8d7da;color:#842029;">{{ 'mris.reibung'|trans }}</span>
                {% elseif control.mythosResilience == 'nicht_betroffen' %}<span class="badge" style="background:#e2e3e5;color:#41464b;">{{ 'mris.nicht_betroffen'|trans }}</span>
                {% else %}<span class="text-muted" style="font-size:10px;">—</span>
                {% endif %}
                {% if control.mythosFlankingMhcs is not empty %}
                    <div style="font-size:9px;color:#666;margin-top:2px;">{{ control.mythosFlankingMhcs|join(', ') }}</div>
                {% endif %}
            </td>
            <td class="text-center">
                {% if control.applicable %}
                    <span class="badge badge-applicable">✓ {{ 'value.yes'|trans }}</span>
                {% else %}
                    <span class="badge badge-not-applicable">✗ {{ 'value.no'|trans }}</span>
                {% endif %}
            </td>
            <td class="text-center">
                {% if control.applicable %}
                    {% if control.implementationStatus == 'implemented' %}
                        <span class="badge badge-implemented">{{ 'status.implemented'|trans }}</span>
                    {% elseif control.implementationStatus == 'partial' %}
                        <span class="badge badge-partial">{{ 'status.partial'|trans }}</span>
                    {% elseif control.implementationStatus == 'planned' %}
                        <span class="badge badge-planned">{{ 'status.planned'|trans }}</span>
                    {% else %}
                        <span class="badge badge-not-implemented">{{ 'report.pdf.status_open'|trans }}</span>
                    {% endif %}
                {% else %}
                    <span class="badge badge-not-applicable">{{ 'value.na'|trans }}</span>
                {% endif %}
            </td>
            <td class="text-center">
                {% if control.applicable %}
                    <strong>{{ control.implementationPercentage }}%</strong>
                {% else %}
                    —
                {% endif %}
            </td>
        </tr>
        {% if not control.applicable and control.justification %}
        <tr>
            <td colspan="6" style="background-color: #fef3c7; padding: 5pt;">
                <strong>{{ 'report.pdf.justification_prefix'|trans }}</strong> {{ control.justification }}
            </td>
        </tr>
        {% endif %}
        {% endfor %}
    </tbody>
</table>
{% endfor %}

{# Detailed Justifications #}
<div class="page-break"></div>
<h2>{{ 'report.pdf.section_detailed_justifications'|trans }}</h2>

<h3>{{ 'report.pdf.section_non_applicable'|trans }}</h3>
{% set hasNonApplicable = false %}
{% for control in controls %}
    {% if not control.applicable %}
        {% set hasNonApplicable = true %}
        <div class="no-break mb-medium">
            <p><strong>{{ control.controlId }} - {{ control.name }}</strong></p>
            <p class="text-muted" style="margin-left: 15pt;">
                <em>{{ 'field.justification'|trans }}:</em> {{ control.justification|default('empty.no_justification'|trans) }}
            </p>
        </div>
    {% endif %}
{% endfor %}
{% if not hasNonApplicable %}
<p class="text-muted">{{ 'report.pdf.all_controls_applicable'|trans }}</p>
{% endif %}

<h3>{{ 'report.pdf.section_planned'|trans }}</h3>
{% set hasPlanned = false %}
{% for control in controls %}
    {% if control.applicable and control.implementationStatus == 'planned' %}
        {% set hasPlanned = true %}
        <div class="no-break mb-medium">
            <p><strong>{{ control.controlId }} - {{ control.name }}</strong></p>
            <p class="text-muted" style="margin-left: 15pt;">
                <em>{{ 'field.target_date'|trans }}:</em> {{ control.targetDate|default('TBD')|date('d.m.Y') }}<br>
                <em>{{ 'label.responsible'|trans }}</em> {{ control.responsiblePerson|default('field.unassigned'|trans) }}
            </p>
        </div>
    {% endif %}
{% endfor %}
{% if not hasPlanned %}
<p class="text-muted">{{ 'report.pdf.no_planned_implementations'|trans }}</p>
{% endif %}

{% endblock %}

{# References Section #}
{% set show_references = true %}
{% block references_content %}
<table>
    <thead>
        <tr>
            <th scope="col" style="width: 20%;">{{ 'report.pdf.ref_col_document'|trans }}</th>
            <th scope="col" style="width: 15%;">{{ 'report.pdf.ref_col_type'|trans }}</th>
            <th scope="col">{{ 'section.description'|trans }}</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>ISO/IEC 27001:2022</td>
            <td>Standard</td>
            <td>{{ 'soa.iso27001_full_title'|trans({}, 'soa')}}</td>
        </tr>
        <tr>
            <td>ISO/IEC 27002:2022</td>
            <td>Standard</td>
            <td>Information security controls</td>
        </tr>
        <tr>
            <td>ISMS-POL-001</td>
            <td>Policy</td>
            <td>{{ 'report.pdf.ref_isms_policy'|trans }}</td>
        </tr>
        <tr>
            <td>ISMS-RISK-001</td>
            <td>Risk Assessment</td>
            <td>{{ 'report.pdf.ref_risk_assessment'|trans }}</td>
        </tr>
    </tbody>
</table>
{% endblock %}
