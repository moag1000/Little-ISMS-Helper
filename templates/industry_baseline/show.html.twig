{% extends 'base.html.twig' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ baseline.name }} · {{ 'industry_baseline.title'|trans({}, 'industry_baseline') }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'industry_baseline.title'|trans({}, 'industry_baseline'), path: 'app_industry_baseline_index' },
            { label: baseline.name }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'nav-collection', label: ('industry_baseline.industry.' ~ baseline.industry)|trans({}, 'industry_baseline') },
        title: baseline.name,
        subtitle: 'v' ~ baseline.version ~ ' · ' ~ baseline.source
    }) }}

    {# Apply / Status forms (POST + complex layout) kept below header (cannot be expressed via _fa_page_header GET-only actions) #}
    <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
        <div></div>
        <div class="d-flex flex-column align-items-end gap-2">
            {% if applied_record %}
                <span class="fa-status-pill fa-status-pill--success">
                    <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
                    {{ 'industry_baseline.status.applied_at'|trans({'%date%': applied_record.appliedAt|date('Y-m-d H:i')}, 'industry_baseline') }}
                </span>
            {% elseif inherited_record %}
                <span class="fa-status-pill fa-status-pill--primary" title="{{ 'industry_baseline.status.inherited_from'|trans({'%tenant%': inherited_record.tenant.name}, 'industry_baseline') }}">
                    <i class="fa-icon fa-icon--nav-process" aria-hidden="true"></i>
                    {{ 'industry_baseline.status.inherited'|trans({'%tenant%': inherited_record.tenant.name}, 'industry_baseline') }}
                </span>
                <form method="post" action="{{ path('app_industry_baseline_apply', {code: baseline.code}) }}"
                      data-controller="ui-actions"
                      data-action="submit->ui-actions#confirm"
                      data-ui-actions-message-param="{{ 'industry_baseline.confirm_apply_over_inherited'|trans({}, 'industry_baseline') }}"
                      data-ui-actions-tone-param="danger">
                    <input type="hidden" name="_token" value="{{ csrf_token('apply_baseline_' ~ baseline.code) }}">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                        <i class="fa-icon fa-icon--nav-magic" aria-hidden="true"></i>
                        {{ 'industry_baseline.action.apply_locally'|trans({}, 'industry_baseline') }}
                    </button>
                </form>
            {% else %}
                <form method="post" action="{{ path('app_industry_baseline_apply', {code: baseline.code}) }}"
                      data-controller="ui-actions"
                      data-action="submit->ui-actions#confirm"
                      data-ui-actions-message-param="{{ 'industry_baseline.confirm_apply'|trans({}, 'industry_baseline') }}"
                      data-ui-actions-tone-param="danger">
                    <input type="hidden" name="_token" value="{{ csrf_token('apply_baseline_' ~ baseline.code) }}">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                        <i class="fa-icon fa-icon--nav-magic" aria-hidden="true"></i>
                        {{ 'industry_baseline.action.apply'|trans({}, 'industry_baseline') }}
                    </button>
                </form>
            {% endif %}

            {% if app.user and app.user.tenant and app.user.tenant.allSubsidiaries|length > 0 %}
                <form method="post" action="{{ path('app_industry_baseline_apply_recursive', {code: baseline.code}) }}"
                      data-controller="ui-actions"
                      data-action="submit->ui-actions#confirm"
                      data-ui-actions-message-param="{{ 'industry_baseline.confirm_apply_recursive'|trans({'%count%': app.user.tenant.allSubsidiaries|length + 1}, 'industry_baseline') }}"
                      data-ui-actions-tone-param="danger">
                    <input type="hidden" name="_token" value="{{ csrf_token('apply_baseline_recursive_' ~ baseline.code) }}">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                        <i class="fa-icon fa-icon--nav-process" aria-hidden="true"></i>
                        {{ 'industry_baseline.action.apply_recursive'|trans({'%count%': app.user.tenant.allSubsidiaries|length + 1}, 'industry_baseline') }}
                    </button>
                </form>
            {% endif %}
        </div>
    </div>

    <div class="row">
        <div class="col-md-7">
            {% embed '_components/_card.html.twig' with { class: 'shadow-sm mb-4' } %}
                {% block card_header %}
                    <div class="card-header">
                        <h2 class="h5 mb-0">{{ 'industry_baseline.field.description'|trans({}, 'industry_baseline') }}</h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <p>{{ baseline.description|nl2br }}</p>
                {% endblock %}
            {% endembed %}

            {# Preset Risks #}
            {% if baseline.presetRisks|length > 0 %}
                {% embed '_components/_card.html.twig' with { class: 'shadow-sm mb-4', noPadding: true } %}
                    {% block card_header %}
                        <div class="card-header">
                            <h2 class="h5 mb-0">
                                <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i>
                                {{ 'industry_baseline.field.preset_risks'|trans({}, 'industry_baseline') }}
                                <span class="fa-status-pill fa-status-pill--neutral ms-1">{{ baseline.presetRisks|length }}</span>
                            </h2>
                        </div>
                    {% endblock %}
                    {% block card_body %}
                        {% embed '_components/_fa_table.html.twig' with { compact: true } %}
                            {% block table_head %}
                                <tr>
                                    <th scope="col" class="fa-table__th">{{ 'industry_baseline.risk.title'|trans({}, 'industry_baseline') }}</th>
                                    <th scope="col" class="fa-table__th">{{ 'industry_baseline.risk.category'|trans({}, 'industry_baseline') }}</th>
                                    <th scope="col" class="fa-table__th">{{ 'industry_baseline.risk.inherent'|trans({}, 'industry_baseline') }}</th>
                                    <th scope="col" class="fa-table__th">{{ 'industry_baseline.risk.treatment'|trans({}, 'industry_baseline') }}</th>
                                </tr>
                            {% endblock %}
                            {% block table_body %}
                                {% for risk in baseline.presetRisks %}
                                    {% set inherent = (risk.inherent_likelihood|default(3)) * (risk.inherent_impact|default(3)) %}
                                    <tr class="fa-table__row">
                                        <td class="fa-table__cell">
                                            <strong>{{ risk.title }}</strong>
                                            <div class="small text-muted">{{ risk.description|default('')|u.truncate(120, '…') }}</div>
                                        </td>
                                        <td class="fa-table__cell"><code>{{ risk.category|default('–') }}</code></td>
                                        <td class="fa-table__cell">
                                            {% set _v = inherent >= 15 ? 'danger' : (inherent >= 8 ? 'warning' : 'success') %}
                                            <span class="fa-status-pill fa-status-pill--{{ _v }}">
                                                {{ inherent }}
                                            </span>
                                        </td>
                                        <td class="fa-table__cell"><code>{{ risk.treatment_strategy|default('mitigate') }}</code></td>
                                    </tr>
                                {% endfor %}
                            {% endblock %}
                        {% endembed %}
                    {% endblock %}
                {% endembed %}
            {% endif %}

            {# Preset Assets #}
            {% if baseline.presetAssets|length > 0 %}
                {% embed '_components/_card.html.twig' with { class: 'shadow-sm mb-4', noPadding: true } %}
                    {% block card_header %}
                        <div class="card-header">
                            <h2 class="h5 mb-0">
                                <i class="fa-icon text-primary fa-icon--nav-boxes" aria-hidden="true"></i>
                                {{ 'industry_baseline.field.preset_assets'|trans({}, 'industry_baseline') }}
                                <span class="fa-status-pill fa-status-pill--neutral ms-1">{{ baseline.presetAssets|length }}</span>
                            </h2>
                        </div>
                    {% endblock %}
                    {% block card_body %}
                        {% embed '_components/_fa_table.html.twig' with { compact: true } %}
                            {% block table_head %}
                                <tr>
                                    <th scope="col" class="fa-table__th">{{ 'industry_baseline.asset.name'|trans({}, 'industry_baseline') }}</th>
                                    <th scope="col" class="fa-table__th">{{ 'industry_baseline.asset.type'|trans({}, 'industry_baseline') }}</th>
                                    <th scope="col" class="fa-table__th fa-table__th--num">C</th>
                                    <th scope="col" class="fa-table__th fa-table__th--num">I</th>
                                    <th scope="col" class="fa-table__th fa-table__th--num">A</th>
                                </tr>
                            {% endblock %}
                            {% block table_body %}
                                {% for asset in baseline.presetAssets %}
                                    <tr class="fa-table__row">
                                        <td class="fa-table__cell">
                                            <strong>{{ asset.name }}</strong>
                                            <div class="small text-muted">{{ asset.description|default('') }}</div>
                                        </td>
                                        <td class="fa-table__cell"><code>{{ asset.asset_type|default('–') }}</code></td>
                                        <td class="fa-table__cell fa-table__cell--num">{{ asset.confidentiality|default(3) }}</td>
                                        <td class="fa-table__cell fa-table__cell--num">{{ asset.integrity|default(3) }}</td>
                                        <td class="fa-table__cell fa-table__cell--num">{{ asset.availability|default(3) }}</td>
                                    </tr>
                                {% endfor %}
                            {% endblock %}
                        {% endembed %}
                    {% endblock %}
                {% endembed %}
            {% endif %}

            {# Preset Controls #}
            {% if baseline.presetApplicableControls|length > 0 %}
                {% embed '_components/_card.html.twig' with { class: 'shadow-sm mb-4' } %}
                    {% block card_header %}
                        <div class="card-header">
                            <h2 class="h5 mb-0">
                                <i class="fa-icon fa-icon--nav-list-check text-success" aria-hidden="true"></i>
                                {{ 'industry_baseline.field.preset_controls'|trans({}, 'industry_baseline') }}
                                <span class="fa-status-pill fa-status-pill--neutral ms-1">{{ baseline.presetApplicableControls|length }}</span>
                            </h2>
                        </div>
                    {% endblock %}
                    {% block card_body %}
                        <div class="d-flex flex-wrap gap-1">
                            {% for control in baseline.presetApplicableControls %}
                                <code class="fa-status-pill fa-status-pill--neutral border">{{ control }}</code>
                            {% endfor %}
                        </div>
                    {% endblock %}
                {% endembed %}
            {% endif %}
        </div>

        <div class="col-md-5">
            {% embed '_components/_card.html.twig' with { class: 'shadow-sm mb-4 border-success' } %}
                {% block card_body %}
                    <div class="text-center">
                        <div class="small text-uppercase text-muted mb-1">
                            <i class="fa-icon fa-icon--threat text-success" aria-hidden="true"></i>
                            {{ 'industry_baseline.field.fte_saved'|trans({}, 'industry_baseline') }}
                        </div>
                        <div class="display-4 fw-bold text-success mb-1">
                            {{ baseline.fteDaysSavedEstimate|number_format(1, '.', ',') }}
                            <small class="fs-5 text-muted">{{ 'industry_baseline.fte_suffix'|trans({}, 'industry_baseline') }}</small>
                        </div>
                        <div class="text-muted small">{{ 'industry_baseline.fte_subtitle'|trans({}, 'industry_baseline') }}</div>
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/_card.html.twig' with { class: 'shadow-sm mb-4' } %}
                {% block card_header %}
                    <div class="card-header">
                        <h2 class="h5 mb-0">{{ 'industry_baseline.field.frameworks'|trans({}, 'industry_baseline') }}</h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <dl class="mb-0">
                        <dt>{{ 'industry_baseline.field.required_frameworks'|trans({}, 'industry_baseline') }}</dt>
                        <dd>
                            {% for code in baseline.requiredFrameworks %}
                                <span class="fa-status-pill fa-status-pill--primary me-1">{{ code }}</span>
                            {% endfor %}
                        </dd>
                        {% if baseline.recommendedFrameworks|length > 0 %}
                            <dt class="mt-2">{{ 'industry_baseline.field.recommended_frameworks'|trans({}, 'industry_baseline') }}</dt>
                            <dd>
                                {% for code in baseline.recommendedFrameworks %}
                                    <span class="border fa-status-pill fa-status-pill--neutral me-1">{{ code }}</span>
                                {% endfor %}
                            </dd>
                        {% endif %}
                    </dl>
                {% endblock %}
            {% endembed %}

            {% if applied_record %}
                {% embed '_components/_card.html.twig' with { class: 'shadow-sm mb-4' } %}
                    {% block card_header %}
                        <div class="card-header">
                            <h2 class="h5 mb-0">{{ 'industry_baseline.applied_record.title'|trans({}, 'industry_baseline') }}</h2>
                        </div>
                    {% endblock %}
                    {% block card_body %}
                        <dl class="small mb-0">
                            <dt>{{ 'industry_baseline.applied_record.applied_at'|trans({}, 'industry_baseline') }}</dt>
                            <dd>{{ applied_record.appliedAt|date('Y-m-d H:i') }}</dd>
                            <dt>{{ 'industry_baseline.applied_record.applied_by'|trans({}, 'industry_baseline') }}</dt>
                            <dd>{{ applied_record.appliedBy.email|default('—') }}</dd>
                            <dt>{{ 'industry_baseline.applied_record.summary'|trans({}, 'industry_baseline') }}</dt>
                            <dd>
                                <pre class="small bg-body-tertiary p-2 mb-0">{{ applied_record.createdSummary|json_encode(constant('JSON_PRETTY_PRINT') b-or constant('JSON_UNESCAPED_UNICODE')) }}</pre>
                            </dd>
                        </dl>
                    {% endblock %}
                {% endembed %}
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
