{% trans_default_domain 'certification_bundle' %}
{% extends 'pdf/_base_document.html.twig' %}

{% block document_type %}{{ 'certification_bundle.pdf.overview.title'|trans({}, 'certification_bundle') }}{% endblock %}
{% block document_id %}DOC-CERT-OVW{% endblock %}
{% block document_title %}{{ 'certification_bundle.pdf.overview.title'|trans({}, 'certification_bundle') }}{% endblock %}
{% block document_version %}{{ version }}{% endblock %}
{% block document_status_class %}approved{% endblock %}
{% block document_status %}GENERATED{% endblock %}
{% block classification_class %}confidential{% endblock %}
{% block document_classification %}{{ 'certification_bundle.pdf.confidential'|trans({}, 'certification_bundle') }}{% endblock %}
{% block organization_name %}{{ tenant_name }}{% endblock %}
{% block header_left %}{{ tenant_name }}{% endblock %}
{% block header_center %}{{ 'certification_bundle.pdf.overview.title'|trans({}, 'certification_bundle') }}{% endblock %}
{% block header_right %}{{ 'certification_bundle.pdf.confidential'|trans({}, 'certification_bundle') }}{% endblock %}
{% block footer_left %}DOC-CERT-OVW | Version {{ version }}{% endblock %}
{% block footer_center %}{{ tenant_name }}{% endblock %}
{% block footer_version %}{{ version }}{% endblock %}
{% block created_date %}{{ generated_at|date('d.m.Y') }}{% endblock %}
{% block modified_date %}{{ generated_at|date('d.m.Y H:i') }}{% endblock %}

{% block document_content %}
<h1>{{ 'certification_bundle.pdf.overview.title'|trans({}, 'certification_bundle') }}</h1>
<p class="text-muted">{{ 'certification_bundle.pdf.generated'|trans({}, 'certification_bundle') }}: {{ generated_at|date('d.m.Y H:i') }} | {{ 'certification_bundle.pdf.organization'|trans({}, 'certification_bundle') }}: {{ tenant_name }}</p>

<h2>{{ 'certification_bundle.pdf.overview.section_1'|trans({}, 'certification_bundle') }}</h2>
<table>
    <thead>
        <tr>
            <th scope="col">{{ 'certification_bundle.pdf.overview.col.metric'|trans({}, 'certification_bundle') }}</th>
            <th scope="col">{{ 'certification_bundle.pdf.overview.col.count'|trans({}, 'certification_bundle') }}</th>
            <th scope="col">{{ 'certification_bundle.pdf.overview.col.percentage'|trans({}, 'certification_bundle') }}</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>{{ 'certification_bundle.pdf.overview.controls.total'|trans({}, 'certification_bundle') }}</td>
            <td>{{ control_stats.total }}</td>
            <td>100%</td>
        </tr>
        <tr>
            <td><strong>{{ 'certification_bundle.pdf.overview.controls.implemented'|trans({}, 'certification_bundle') }}</strong></td>
            <td><strong>{{ control_stats.implemented }}</strong></td>
            <td><strong>{{ control_percentage }}%</strong></td>
        </tr>
        <tr>
            <td>{{ 'certification_bundle.pdf.overview.controls.in_progress'|trans({}, 'certification_bundle') }}</td>
            <td>{{ control_stats.in_progress }}</td>
            <td>{{ control_stats.total > 0 ? ((control_stats.in_progress / control_stats.total) * 100)|round(1) : 0 }}%</td>
        </tr>
        <tr>
            <td>{{ 'certification_bundle.pdf.overview.controls.not_started'|trans({}, 'certification_bundle') }}</td>
            <td>{{ control_stats.not_started }}</td>
            <td>{{ control_stats.total > 0 ? ((control_stats.not_started / control_stats.total) * 100)|round(1) : 0 }}%</td>
        </tr>
        <tr>
            <td>{{ 'certification_bundle.pdf.overview.controls.not_applicable'|trans({}, 'certification_bundle') }}</td>
            <td>{{ control_stats.not_applicable }}</td>
            <td>{{ control_stats.total > 0 ? ((control_stats.not_applicable / control_stats.total) * 100)|round(1) : 0 }}%</td>
        </tr>
    </tbody>
</table>

<h2>{{ 'certification_bundle.pdf.overview.section_2'|trans({}, 'certification_bundle') }}</h2>
<table>
    <thead>
        <tr>
            <th scope="col">{{ 'certification_bundle.pdf.overview.col.risk_level'|trans({}, 'certification_bundle') }}</th>
            <th scope="col">{{ 'certification_bundle.pdf.overview.col.count'|trans({}, 'certification_bundle') }}</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td><span style="color: var(--danger);">{{ 'certification_bundle.pdf.overview.risk.critical'|trans({}, 'certification_bundle') }}</span></td>
            <td>{{ risks_by_level.critical }}</td>
        </tr>
        <tr>
            <td><span style="color: var(--warning);">{{ 'certification_bundle.pdf.overview.risk.high'|trans({}, 'certification_bundle') }}</span></td>
            <td>{{ risks_by_level.high }}</td>
        </tr>
        <tr>
            <td><span style="color: var(--warning);">{{ 'certification_bundle.pdf.overview.risk.medium'|trans({}, 'certification_bundle') }}</span></td>
            <td>{{ risks_by_level.medium }}</td>
        </tr>
        <tr>
            <td><span style="color: var(--success);">{{ 'certification_bundle.pdf.overview.risk.low'|trans({}, 'certification_bundle') }}</span></td>
            <td>{{ risks_by_level.low }}</td>
        </tr>
        <tr>
            <td><strong>{{ 'certification_bundle.pdf.overview.risk.total'|trans({}, 'certification_bundle') }}</strong></td>
            <td><strong>{{ risks|length }}</strong></td>
        </tr>
    </tbody>
</table>

<h2>{{ 'certification_bundle.pdf.overview.section_3'|trans({}, 'certification_bundle') }}</h2>
<p>{{ 'certification_bundle.pdf.overview.total_assets_registered'|trans({}, 'certification_bundle') }}: <strong>{{ assets|length }}</strong></p>

<h2>{{ 'certification_bundle.pdf.overview.section_4'|trans({}, 'certification_bundle') }}</h2>
<p>{{ 'certification_bundle.pdf.overview.total_documents'|trans({}, 'certification_bundle') }}: <strong>{{ documents|length }}</strong></p>

<h2>{{ 'certification_bundle.pdf.overview.section_5'|trans({}, 'certification_bundle') }}</h2>
<p>{{ 'certification_bundle.pdf.overview.active_treatment_plans'|trans({}, 'certification_bundle') }}: <strong>{{ treatment_plans|length }}</strong></p>

{% if treatment_plans|length > 0 %}
<table>
    <thead>
        <tr>
            <th scope="col">{{ 'certification_bundle.pdf.overview.col.title'|trans({}, 'certification_bundle') }}</th>
            <th scope="col">{{ 'certification_bundle.pdf.overview.col.priority'|trans({}, 'certification_bundle') }}</th>
            <th scope="col">{{ 'certification_bundle.pdf.overview.col.status'|trans({}, 'certification_bundle') }}</th>
            <th scope="col">{{ 'certification_bundle.pdf.overview.col.completion'|trans({}, 'certification_bundle') }}</th>
            <th scope="col">{{ 'certification_bundle.pdf.overview.col.target_date'|trans({}, 'certification_bundle') }}</th>
        </tr>
    </thead>
    <tbody>
        {% for plan in treatment_plans %}
        <tr>
            <td>{{ plan.title }}</td>
            <td>
                <span class="status-badge {% if plan.priority == 'critical' %}status-review{% elseif plan.priority == 'high' %}status-draft{% else %}status-approved{% endif %}">
                    {{ plan.priority|upper }}
                </span>
            </td>
            <td>{{ plan.status|replace({'_': ' '})|capitalize }}</td>
            <td>{{ plan.completionPercentage }}%</td>
            <td>{{ plan.targetCompletionDate ? plan.targetCompletionDate|date('d.m.Y') : '-' }}</td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% endif %}

<h2>{{ 'certification_bundle.pdf.overview.section_6'|trans({}, 'certification_bundle') }}</h2>
<table>
    <thead>
        <tr>
            <th scope="col">{{ 'certification_bundle.pdf.overview.col.document'|trans({}, 'certification_bundle') }}</th>
            <th scope="col">{{ 'certification_bundle.pdf.overview.col.description'|trans({}, 'certification_bundle') }}</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>00_ISMS_OVERVIEW.pdf</td>
            <td>{{ 'certification_bundle.pdf.overview.bundle.overview_desc'|trans({}, 'certification_bundle') }}</td>
        </tr>
        <tr>
            <td>01_STATEMENT_OF_APPLICABILITY.pdf</td>
            <td>{{ 'certification_bundle.pdf.overview.bundle.soa_desc'|trans({}, 'certification_bundle') }}</td>
        </tr>
        <tr>
            <td>02_RISK_TREATMENT_PLAN.pdf</td>
            <td>{{ 'certification_bundle.pdf.overview.bundle.rtp_desc'|trans({}, 'certification_bundle') }}</td>
        </tr>
        <tr>
            <td>03_ASSET_REGISTER.pdf</td>
            <td>{{ 'certification_bundle.pdf.overview.bundle.asset_desc'|trans({}, 'certification_bundle') }}</td>
        </tr>
        <tr>
            <td>04_EVIDENCE/</td>
            <td>{{ 'certification_bundle.pdf.overview.bundle.evidence_desc'|trans({}, 'certification_bundle') }}</td>
        </tr>
        <tr>
            <td>05_GAP_ANALYSIS.csv</td>
            <td>{{ 'certification_bundle.pdf.overview.bundle.gap_desc'|trans({}, 'certification_bundle') }}</td>
        </tr>
        <tr>
            <td>METADATA.json</td>
            <td>{{ 'certification_bundle.pdf.overview.bundle.metadata_desc'|trans({}, 'certification_bundle') }}</td>
        </tr>
    </tbody>
</table>
{% endblock %}
