{% trans_default_domain 'certification_bundle' %}
{% extends 'pdf/_base_document.html.twig' %}

{% block document_type %}{{ 'certification_bundle.pdf.risk_treatment_plan.title'|trans({}, 'certification_bundle') }}{% endblock %}
{% block document_id %}DOC-CERT-RTP{% endblock %}
{% block document_title %}{{ 'certification_bundle.pdf.risk_treatment_plan.title'|trans({}, 'certification_bundle') }}{% endblock %}
{% block document_version %}{{ version }}{% endblock %}
{% block document_status_class %}approved{% endblock %}
{% block document_status %}GENERATED{% endblock %}
{% block classification_class %}confidential{% endblock %}
{% block document_classification %}{{ 'certification_bundle.pdf.confidential'|trans({}, 'certification_bundle') }}{% endblock %}
{% block organization_name %}{{ tenant_name }}{% endblock %}
{% block header_left %}{{ tenant_name }}{% endblock %}
{% block header_center %}{{ 'certification_bundle.pdf.risk_treatment_plan.title'|trans({}, 'certification_bundle') }}{% endblock %}
{% block header_right %}{{ 'certification_bundle.pdf.confidential'|trans({}, 'certification_bundle') }}{% endblock %}
{% block footer_left %}DOC-CERT-RTP | Version {{ version }}{% endblock %}
{% block footer_center %}{{ tenant_name }}{% endblock %}
{% block footer_version %}{{ version }}{% endblock %}
{% block created_date %}{{ generated_at|date('d.m.Y') }}{% endblock %}
{% block modified_date %}{{ generated_at|date('d.m.Y H:i') }}{% endblock %}

{% block custom_styles %}
    .risk-critical { color: var(--danger); font-weight: bold; }
    .risk-high { color: var(--warning); font-weight: bold; }
    .risk-medium { color: var(--warning); }
    .risk-low { color: var(--success); }
{% endblock %}

{% block document_content %}
<h1>{{ 'certification_bundle.pdf.risk_treatment_plan.title'|trans({}, 'certification_bundle') }}</h1>
<p class="text-muted">{{ 'certification_bundle.pdf.generated'|trans({}, 'certification_bundle') }}: {{ generated_at|date('d.m.Y H:i') }} | {{ 'certification_bundle.pdf.organization'|trans({}, 'certification_bundle') }}: {{ tenant_name }}</p>
<p>{{ 'certification_bundle.pdf.risk_treatment_plan.total_risks'|trans({}, 'certification_bundle') }}: <strong>{{ risks|length }}</strong> | {{ 'certification_bundle.pdf.risk_treatment_plan.active_plans'|trans({}, 'certification_bundle') }}: <strong>{{ treatment_plans|length }}</strong></p>

<h2>{{ 'certification_bundle.pdf.risk_treatment_plan.section_register'|trans({}, 'certification_bundle') }}</h2>

{% if risks|length == 0 %}
    <p class="text-muted">{{ 'certification_bundle.pdf.risk_treatment_plan.no_risks'|trans({}, 'certification_bundle') }}</p>
{% else %}
<table>
    <thead>
        <tr>
            <th scope="col" style="width: 5%;">{{ 'certification_bundle.pdf.risk_treatment_plan.col.id'|trans({}, 'certification_bundle') }}</th>
            <th scope="col" style="width: 18%;">{{ 'certification_bundle.pdf.risk_treatment_plan.col.title'|trans({}, 'certification_bundle') }}</th>
            <th scope="col" style="width: 10%;">{{ 'certification_bundle.pdf.risk_treatment_plan.col.treatment'|trans({}, 'certification_bundle') }}</th>
            <th scope="col" style="width: 8%;">{{ 'certification_bundle.pdf.risk_treatment_plan.col.inherent'|trans({}, 'certification_bundle') }}</th>
            <th scope="col" style="width: 8%;">{{ 'certification_bundle.pdf.risk_treatment_plan.col.residual'|trans({}, 'certification_bundle') }}</th>
            <th scope="col" style="width: 8%;">{{ 'certification_bundle.pdf.risk_treatment_plan.col.status'|trans({}, 'certification_bundle') }}</th>
            <th scope="col" style="width: 13%;">{{ 'certification_bundle.pdf.risk_treatment_plan.col.owner'|trans({}, 'certification_bundle') }}</th>
            <th scope="col" style="width: 10%;">{{ 'certification_bundle.pdf.risk_treatment_plan.col.review_date'|trans({}, 'certification_bundle') }}</th>
        </tr>
    </thead>
    <tbody>
        {% for risk in risks %}
        {% set score = risk.riskScore %}
        {% set residual = risk.residualRiskLevel %}
        {% set level = score >= 20 ? 'critical' : (score >= 12 ? 'high' : (score >= 6 ? 'medium' : 'low')) %}
        {% set residualLevel = residual >= 20 ? 'critical' : (residual >= 12 ? 'high' : (residual >= 6 ? 'medium' : 'low')) %}
        <tr>
            <td>{{ risk.id }}</td>
            <td>{{ risk.title }}</td>
            <td>{{ risk.treatmentStrategy ? risk.treatmentStrategy.value : '-' }}</td>
            <td class="risk-{{ level }}">{{ score }}</td>
            <td class="risk-{{ residualLevel }}">{{ residual }}</td>
            <td>{{ risk.status ? risk.status.value : '-' }}</td>
            <td>{{ risk.riskOwnerName ?? '-' }}</td>
            <td>{{ risk.reviewDate ? risk.reviewDate|date('d.m.Y') : '-' }}</td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% endif %}

{% if treatment_plans|length > 0 %}
<div class="page-break"></div>
<h2>{{ 'certification_bundle.pdf.risk_treatment_plan.section_plans'|trans({}, 'certification_bundle') }}</h2>
<table>
    <thead>
        <tr>
            <th scope="col" style="width: 20%;">{{ 'certification_bundle.pdf.risk_treatment_plan.col.title'|trans({}, 'certification_bundle') }}</th>
            <th scope="col" style="width: 15%;">{{ 'certification_bundle.pdf.risk_treatment_plan.col.related_risk'|trans({}, 'certification_bundle') }}</th>
            <th scope="col" style="width: 10%;">{{ 'certification_bundle.pdf.risk_treatment_plan.col.priority'|trans({}, 'certification_bundle') }}</th>
            <th scope="col" style="width: 10%;">{{ 'certification_bundle.pdf.risk_treatment_plan.col.status'|trans({}, 'certification_bundle') }}</th>
            <th scope="col" style="width: 8%;">{{ 'certification_bundle.pdf.risk_treatment_plan.col.progress'|trans({}, 'certification_bundle') }}</th>
            <th scope="col" style="width: 12%;">{{ 'certification_bundle.pdf.risk_treatment_plan.col.responsible'|trans({}, 'certification_bundle') }}</th>
            <th scope="col" style="width: 12%;">{{ 'certification_bundle.pdf.risk_treatment_plan.col.target_date'|trans({}, 'certification_bundle') }}</th>
            <th scope="col" style="width: 8%;">{{ 'certification_bundle.pdf.risk_treatment_plan.col.budget'|trans({}, 'certification_bundle') }}</th>
        </tr>
    </thead>
    <tbody>
        {% for plan in treatment_plans %}
        <tr>
            <td>{{ plan.title }}</td>
            <td>{{ plan.risk ? plan.risk.title : '-' }}</td>
            <td>
                <span class="{% if plan.priority == 'critical' %}risk-critical{% elseif plan.priority == 'high' %}risk-high{% else %}risk-medium{% endif %}">
                    {{ plan.priority|upper }}
                </span>
            </td>
            <td>{{ plan.status|replace({'_': ' '})|capitalize }}</td>
            <td>{{ plan.completionPercentage }}%</td>
            <td>{{ plan.responsiblePersonName ?? '-' }}</td>
            <td>{{ plan.targetCompletionDate ? plan.targetCompletionDate|date('d.m.Y') : '-' }}</td>
            <td>{{ plan.budget ?? '-' }}</td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% endif %}
{% endblock %}
