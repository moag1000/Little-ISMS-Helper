{# ───────────────────────────────────────────────────────────────────
   Risk Management Report — Auditor-orientiertes Risikoregister
   Migriert auf das fa-report-doc 5-slot Template (Cover · Exec ·
   Data · Appendix · Footer).

   Audience: auditor → table-first Layout (dichte Tabelle, kompakte KPIs)
   Status:   final   → kein Watermark, freigegeben zur Verteilung
   ─────────────────────────────────────────────────────────────────── #}
<!DOCTYPE html>
<html lang="{{ app.request.locale|default('de') }}">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
    <title>Risk Management Report</title>
    <style>
        :root {
            --surface: #ffffff;
            --surface-2: #f6f6fa;
            --surface-3: #eef0f9;
            --border: #dfe3f0;
            --border-strong: #b9bfd6;
            --fg-1: #0e0a1f;
            --fg-2: #4c4a73;
            --fg-3: #6d6b92;
            --primary: #0284c7;
            --primary-strong: #0369a1;
            --primary-tint: rgba(2, 132, 199, 0.10);
            --primary-glow: rgba(2, 132, 199, 0.20);
            --accent-tint: rgba(124, 58, 237, 0.10);
            --accent-strong: #6d28d9;
            --success: #059669;
            --success-strong: #047857;
            --success-tint: rgba(5, 150, 105, 0.10);
            --success-glow: rgba(5, 150, 105, 0.20);
            --warning: #d97706;
            --warning-strong: #b45309;
            --warning-glow: rgba(217, 119, 6, 0.20);
            --danger: #dc2626;
            --danger-strong: #b91c1c;
            --danger-glow: rgba(220, 38, 38, 0.20);
            --r-md: 8px;
        }
        @page { size: A4 portrait; margin: 16mm 14mm 20mm 14mm; }
        body { background: #fff; font-family: 'DejaVu Sans', sans-serif; margin: 0; padding: 0; }

        {# Inline subset of report-doc.css critical rules so dompdf renders
           without external assets. Full stylesheet at assets/styles/report-doc.css. #}
        .report-doc { background: var(--surface); color: var(--fg-1); font-size: 9pt; line-height: 1.45; max-width: none; margin: 0; border: 0; border-radius: 0; }
        .report-doc__cover { padding: 16pt 14pt 12pt; border-bottom: 1px solid var(--border); }
        .report-doc__cover-top { display: table; width: 100%; }
        .report-doc__brand { display: table-cell; vertical-align: middle; }
        .report-doc__chips { display: table-cell; text-align: right; vertical-align: middle; }
        .report-doc__logo { display: inline-block; width: 28pt; height: 28pt; border-radius: 5pt; background: var(--primary); color: #fff; text-align: center; line-height: 28pt; font-weight: 700; font-size: 16pt; vertical-align: middle; margin-right: 6pt; }
        .report-doc__brand-name { font-weight: 700; font-size: 10pt; color: var(--fg-1); display: inline-block; vertical-align: middle; }
        .report-doc__brand-meta { font-size: 7pt; color: var(--fg-3); }
        .report-doc__chip { display: inline-block; padding: 2pt 6pt; border-radius: 8pt; background: var(--surface-2); color: var(--fg-2); font-size: 6pt; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; border: 1px solid var(--border); margin-left: 3pt; }
        .report-doc__chip--status-final { background: var(--success-tint); color: var(--success-strong); border-color: transparent; }
        .report-doc__chip--audience-auditor { background: var(--accent-tint); color: var(--accent-strong); border-color: transparent; }
        .report-doc__chip--classification { background: var(--fg-1); color: #fff; border-color: transparent; }
        .report-doc__cover-center { padding: 14pt 0 10pt; }
        .report-doc__kicker { font-size: 7pt; color: var(--primary); font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; margin: 0 0 4pt; }
        .report-doc__title { font-size: 18pt; font-weight: 800; color: var(--fg-1); margin: 0 0 6pt; line-height: 1.1; }
        .report-doc__sub { font-size: 9pt; color: var(--fg-2); margin: 0; }
        .report-doc__cover-grid { border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 8pt 0; margin: 0; }
        .report-doc__cover-grid > div { display: inline-block; width: 31%; margin: 0 1% 4pt 0; vertical-align: top; }
        .report-doc__cover-label { font-size: 6pt; color: var(--fg-3); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 700; margin: 0 0 2pt; }
        .report-doc__cover-value { font-size: 8pt; color: var(--fg-1); font-weight: 600; margin: 0; }
        .report-doc__exec-summary { padding: 10pt 14pt; background: var(--surface); border-bottom: 1px solid var(--border); }
        .report-doc__exec-heading { font-size: 11pt; font-weight: 800; margin: 0 0 8pt; padding-bottom: 4pt; border-bottom: 2px solid var(--fg-1); }
        .report-doc__tldr { background: var(--surface-2); border: 1px solid var(--border); border-left: 3pt solid var(--primary); padding: 7pt 10pt; margin: 0 0 10pt; }
        .report-doc__tldr-label { font-size: 6pt; color: var(--primary-strong); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 5pt; }
        .report-doc__tldr-list { list-style: none; margin: 0; padding: 0; }
        .report-doc__tldr-item { font-size: 8pt; color: var(--fg-1); padding: 2pt 0; }
        .report-doc__tldr-item--ok { border-left: 2pt solid var(--success); padding-left: 6pt; }
        .report-doc__tldr-item--warn { border-left: 2pt solid var(--warning); padding-left: 6pt; }
        .report-doc__tldr-item--danger { border-left: 2pt solid var(--danger); padding-left: 6pt; }
        .report-doc__tldr-dot { display: none; }
        .report-doc__kpi-grid { display: table; width: 100%; border-spacing: 4pt; }
        .report-doc__kpi-tile { display: table-cell; padding: 7pt 8pt; border: 1px solid var(--border); border-radius: 4pt; vertical-align: top; background: var(--surface); }
        .report-doc__kpi-tile--success { border-left: 2pt solid var(--success); }
        .report-doc__kpi-tile--warning { border-left: 2pt solid var(--warning); }
        .report-doc__kpi-tile--danger  { border-left: 2pt solid var(--danger); }
        .report-doc__kpi-tile--neutral { border-left: 2pt solid var(--primary); }
        .report-doc__kpi-label { font-size: 6pt; color: var(--fg-3); text-transform: uppercase; letter-spacing: 0.06em; font-weight: 700; margin-bottom: 2pt; }
        .report-doc__kpi-value { font-size: 14pt; font-weight: 800; color: var(--fg-1); }
        .report-doc__kpi-trend { font-size: 7pt; }
        .report-doc__data-section { padding: 10pt 14pt; border-bottom: 1px solid var(--border); page-break-inside: auto; }
        .report-doc__data-section + .report-doc__data-section { page-break-before: always; }
        .report-doc__section-heading { font-size: 11pt; font-weight: 700; color: var(--fg-1); margin: 0 0 6pt; padding-bottom: 3pt; border-bottom: 2px solid var(--fg-1); }
        .report-doc__section-intro { font-size: 8pt; color: var(--fg-2); margin: 0 0 8pt; }
        .report-doc__table { width: 100%; border-collapse: collapse; font-size: 7.5pt; }
        .report-doc__table th { background: var(--surface-2); color: var(--fg-2); padding: 4pt 5pt; border: 0.5pt solid var(--border-strong); font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; font-size: 6pt; text-align: left; }
        .report-doc__table td { padding: 4pt 5pt; border: 0.5pt solid var(--border); color: var(--fg-1); vertical-align: top; }
        .report-doc__table tbody tr:nth-child(even) td { background: var(--surface-2); }
        .report-doc__appendix { padding: 10pt 14pt; background: var(--surface); border-top: 3pt solid var(--primary); border-bottom: 1px solid var(--border); }
        .report-doc__appendix-heading { font-size: 11pt; font-weight: 700; margin: 0 0 8pt; padding-bottom: 3pt; border-bottom: 2px solid var(--fg-1); }
        .report-doc__appendix-subheading { font-size: 8pt; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; margin: 7pt 0 3pt; }
        .report-doc__appendix-body { font-size: 8pt; color: var(--fg-2); }
        .report-doc__appendix-sources { padding-left: 12pt; font-size: 7.5pt; color: var(--fg-2); }
        .report-doc__footer-disclaimer { padding: 10pt 14pt; background: var(--surface); border-top: 1px solid var(--border-strong); }
        .report-doc__distribution-label { font-size: 6pt; color: var(--fg-3); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 700; margin: 0 0 3pt; }
        .report-doc__distribution-list { list-style: none; padding: 0; margin: 0 0 6pt; font-size: 8pt; color: var(--fg-2); }
        .report-doc__distribution-list li { display: inline-block; border-left: 2pt solid var(--border); padding: 0 7pt; }
        .report-doc__disclaimer-text { font-size: 7pt; color: var(--fg-3); padding: 6pt; background: var(--surface-2); border: 1px solid var(--border); border-radius: 3pt; margin: 0 0 6pt; }
        .report-doc__footer-meta { font-size: 6pt; color: var(--fg-3); }
        .report-doc__footer-brand { font-weight: 700; color: var(--fg-2); }
        .report-doc__footer-classification { color: var(--danger-strong); font-weight: 700; text-transform: uppercase; }
    </style>
</head>
<body>
{% import '_components/_fa_report_doc.html.twig' as _fa_report_doc %}

{% set _critical_high_pct = total_risks > 0 ? (((critical_risks + high_risks) / total_risks * 100)|round(1)) : 0 %}

{% set _findings = [
    { label: 'Total Risks: ' ~ total_risks, tone: 'ok' },
    { label: 'Critical: '   ~ critical_risks, tone: critical_risks > 0 ? 'danger' : 'ok' },
    { label: 'High: '       ~ high_risks,     tone: high_risks > 5 ? 'warn' : 'ok' },
    { label: 'Critical+High share: ' ~ _critical_high_pct ~ '%',
      tone: _critical_high_pct >= 30 ? 'danger' : (_critical_high_pct >= 15 ? 'warn' : 'ok') },
] %}

{% set _kpis = [
    { label: 'Total',    value: total_risks,    tone: 'neutral' },
    { label: 'Critical', value: critical_risks, tone: critical_risks > 0 ? 'danger' : 'success' },
    { label: 'High',     value: high_risks,     tone: high_risks > 5 ? 'warning' : 'success' },
    { label: 'Medium',   value: medium_risks,   tone: 'neutral' },
    { label: 'Low',      value: low_risks,      tone: 'success' },
] %}

{# Critical & High table #}
{% set _critical_and_high = risks|filter(r => r.riskScore >= 12) %}
{% set _ch_rows = [] %}
{% for risk in _critical_and_high %}
    {% set _level_label = risk.riskScore >= 20 ? 'Critical' : 'High' %}
    {% set _level_chip  = risk.riskScore >= 20 ? 'confidential' : 'draft' %}
    {% set _ch_rows = _ch_rows|merge([[
        risk.id,
        risk.title,
        risk.asset ? risk.asset.name : '-',
        risk.riskScore,
        '<span class="report-doc__chip report-doc__chip--status-' ~ _level_chip ~ '">' ~ _level_label ~ '</span>',
        risk.treatmentStrategy ? risk.treatmentStrategy.value|capitalize : '<span style="color:var(--fg-3);">Not defined</span>',
        risk.riskOwnerName ?? '-',
    ]]) %}
{% endfor %}

{# All risks #}
{% set _all_rows = [] %}
{% for risk in risks %}
    {% set _level_label = risk.riskScore >= 20 ? 'Critical' : (risk.riskScore >= 12 ? 'High' : (risk.riskScore >= 6 ? 'Medium' : 'Low')) %}
    {% set _level_chip  = risk.riskScore >= 20 ? 'confidential' : (risk.riskScore >= 12 ? 'draft' : 'final') %}
    {% set _all_rows = _all_rows|merge([[
        risk.id,
        risk.title,
        risk.asset ? risk.asset.name : '-',
        risk.probability ?? '-',
        risk.impact ?? '-',
        risk.riskScore,
        '<span class="report-doc__chip report-doc__chip--status-' ~ _level_chip ~ '">' ~ _level_label ~ '</span>',
        risk.treatmentStrategy ? risk.treatmentStrategy.value|capitalize : '-',
        risk.status ? risk.status.value|capitalize : '-',
        risk.riskOwnerName ?? '-',
    ]]) %}
{% endfor %}

{# Distribution by level #}
{% set _dist_rows = [
    [ 'Critical (≥20)', critical_risks, total_risks > 0 ? ((critical_risks / total_risks * 100)|round(1)) ~ '%' : '0%' ],
    [ 'High (12-19)',   high_risks,     total_risks > 0 ? ((high_risks / total_risks * 100)|round(1))   ~ '%' : '0%' ],
    [ 'Medium (6-11)',  medium_risks,   total_risks > 0 ? ((medium_risks / total_risks * 100)|round(1)) ~ '%' : '0%' ],
    [ 'Low (<6)',       low_risks,      total_risks > 0 ? ((low_risks / total_risks * 100)|round(1))    ~ '%' : '0%' ],
] %}

{% set _sections = [
    {
        heading: 'Critical & High Risks (Top Priority)',
        intro: _critical_and_high|length > 0 ? (_critical_and_high|length ~ ' risks require immediate attention and treatment.') : 'No critical or high-priority risks identified.',
        table: _critical_and_high|length > 0 ? {
            headers: [ 'ID', 'Title', 'Asset', 'Score', 'Level', 'Treatment', 'Owner' ],
            rows:    _ch_rows,
        } : null,
    },
    {
        heading: 'All Risks (Detailed View)',
        table: {
            headers: [ 'ID', 'Title', 'Asset', 'L', 'I', 'Score', 'Level', 'Treatment', 'Status', 'Owner' ],
            rows:    _all_rows,
        },
    },
    {
        heading: 'pdf.risk_report.distribution_by_level'|trans({}, 'messages'),
        table: {
            headers: [ 'Risk Level', 'Count', 'Percentage' ],
            rows:    _dist_rows,
        },
    },
] %}

{{ _fa_report_doc.render({
    report: {
        title:        'Risk Management Report',
        subtitle:     'Risk Overview and Analysis' ~ (filter_info ? ' — Applied filters: ' ~ filter_info : ''),
        kicker:       'ISMS · Risk Register',
        status:       'final',
        audience:     'auditor',
        generated_at: pdf_generation_date|date('d.m.Y H:i'),
        standard:     'ISO 27005',
    },
    brand_name:   'Little ISMS Helper',
    key_findings: _findings,
    kpis:         _kpis,
    sections:     _sections,
    appendix: {
        methodology: '<p>Risk score = Probability × Impact (1-25). ISO 27001 thresholds: Critical ≥20, High 12-19, Medium 6-11, Low &lt;6.</p>',
        sources: [
            { label: 'RiskRepository', detail: 'findByTenant() — filtered by ' ~ (filter_info|default('no filters')) },
        ],
        glossary: [
            { term: 'L',     definition: 'Likelihood / Probability (1-5)' },
            { term: 'I',     definition: 'Impact / Severity (1-5)' },
            { term: 'Score', definition: 'L × I (1-25), determines risk-level bucket' },
            { term: 'Treatment', definition: 'mitigate / accept / transfer / avoid (ISO 27005 §9.5)' },
        ],
    },
    distribution: [
        { role: 'CISO',          name: '—' },
        { role: 'Risk Officer',  name: '—' },
        { role: 'External Auditor', name: '—' },
    ],
}) }}
</body>
</html>
