{% extends 'base.html.twig' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block title %}{{ 'prototype_protection.page.index_title'|trans({}, 'prototype_protection') }}{% endblock %}

{% set status_variant = {
    'draft':     'secondary',
    'in_review': 'info',
    'approved':  'success',
    'rejected':  'danger',
    'expired':   'warning',
} %}

{% set result_variant = {
    'not_applicable': 'secondary',
    'not_met':        'danger',
    'partial':        'warning',
    'met':            'success',
    'exceeded':       'success',
} %}

{% block body %}
<div class="container-fluid">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.compliance'|trans({}, 'nav') },
            { label: 'prototype_protection.page.index_title'|trans({}, 'prototype_protection') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'shield-lock', label: 'nav.compliance'|trans({}, 'nav') },
        title: 'prototype_protection.page.index_title'|trans({}, 'prototype_protection'),
        subtitle: 'prototype_protection.page.index_description'|trans({}, 'prototype_protection'),
        actions: [
            { label: 'prototype_protection.action.new'|trans({}, 'prototype_protection'), variant: 'primary', icon: 'plus-circle', href: path('app_prototype_protection_new') }
        ]
    }) }}

    <main class="fa-aurora-surface">

    {% if expiring|length > 0 %}
        {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning' } } %}
            {% block alert_body %}
                <div class="fa-alert__title">{{ 'prototype_protection.expiring.heading'|trans({'%count%': expiring|length}, 'prototype_protection') }}</div>
                <ul class="mb-0 small">
                    {% for a in expiring %}
                        <li>
                            <a href="{{ path('app_prototype_protection_show', {id: a.id}) }}" class="fa-alert__link">{{ a.title }}</a>
                            — {{ 'prototype_protection.field.next_assessment_due'|trans({}, 'prototype_protection') }}:
                            {{ a.nextAssessmentDue|date('d.m.Y') }}
                        </li>
                    {% endfor %}
                </ul>
            {% endblock %}
        {% endembed %}
    {% endif %}

    {% embed '_components/_card.html.twig' %}
        {% block card_body %}
            {% if assessments|length == 0 %}
                {% include '_components/_empty_state.html.twig' with {
                    icon: 'bi-shield-lock',
                    title: 'prototype_protection.empty.title'|trans({}, 'prototype_protection'),
                    message: 'prototype_protection.empty.message'|trans({}, 'prototype_protection')
                } %}
            {% else %}
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th scope="col">{{ 'prototype_protection.field.title'|trans({}, 'prototype_protection') }}</th>
                                <th scope="col">{{ 'prototype_protection.field.status'|trans({}, 'prototype_protection') }}</th>
                                <th scope="col">{{ 'prototype_protection.field.tisax_level'|trans({}, 'prototype_protection') }}</th>
                                <th scope="col">{{ 'prototype_protection.field.assessment_date'|trans({}, 'prototype_protection') }}</th>
                                <th scope="col">{{ 'prototype_protection.field.overall_result'|trans({}, 'prototype_protection') }}</th>
                                <th scope="col">{{ 'prototype_protection.field.next_assessment_due'|trans({}, 'prototype_protection') }}</th>
                                <th scope="col"></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for a in assessments %}
                                <tr>
                                    <td>
                                        <a href="{{ path('app_prototype_protection_show', {id: a.id}) }}">{{ a.title }}</a>
                                        {% if a.supplier %}
                                            <div class="small text-muted">{{ a.supplier.name }}</div>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% include '_components/_badge.html.twig' with {
                                            variant: status_variant[a.status] ?? 'secondary',
                                            content: ('prototype_protection.status.' ~ a.status)|trans({}, 'prototype_protection')
                                        } %}
                                    </td>
                                    <td>{{ a.tisaxLevel ?? '—' }}</td>
                                    <td>{{ a.assessmentDate ? a.assessmentDate|date('d.m.Y') : '—' }}</td>
                                    <td>
                                        {% if a.overallResult %}
                                            {% include '_components/_badge.html.twig' with {
                                                variant: result_variant[a.overallResult] ?? 'secondary',
                                                content: ('prototype_protection.result.' ~ a.overallResult)|trans({}, 'prototype_protection')
                                            } %}
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if a.nextAssessmentDue %}
                                            {{ a.nextAssessmentDue|date('d.m.Y') }}
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-end">
                                        <a href="{{ path('app_prototype_protection_edit', {id: a.id}) }}"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil" aria-hidden="true"></i>
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        {% endblock %}
    {% endembed %}
    </main>
</div>
{% endblock %}
