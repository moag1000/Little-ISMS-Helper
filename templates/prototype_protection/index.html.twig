{% extends 'base.html.twig' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block title %}{{ 'prototype_protection.page.index_title'|trans({}, 'prototype_protection') }}{% endblock %}

{% set status_variant = {
    'draft':     'secondary',
    'in_review': 'info',
    'approved':  'success',
    'rejected':  'danger',
    'expired':   'warning',
} %}

{% set result_variant = {
    'not_applicable': 'secondary',
    'not_met':        'danger',
    'partial':        'warning',
    'met':            'success',
    'exceeded':       'success',
} %}

{% block body %}
<div class="container-fluid">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.compliance'|trans({}, 'nav'), url: path('app_compliance_index') },
            { label: 'prototype_protection.page.index_title'|trans({}, 'prototype_protection') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'nav-shield-lock', label: 'nav.compliance'|trans({}, 'nav') },
        title: 'prototype_protection.page.index_title'|trans({}, 'prototype_protection'),
        subtitle: 'prototype_protection.page.index_description'|trans({}, 'prototype_protection'),
        actions: [
            { label: 'prototype_protection.action.new'|trans({}, 'prototype_protection'), variant: 'primary', icon: 'plus', href: path('app_prototype_protection_new'), attrs: { 'data-turbo-frame': 'fa-form-modal' } }
        ]
    }) }}

    <main class="fa-aurora-surface">

    {% if expiring|length > 0 %}
        {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning' } } %}
            {% block alert_body %}
                <div class="fa-alert__title">{{ 'prototype_protection.expiring.heading'|trans({'%count%': expiring|length}, 'prototype_protection') }}</div>
                <ul class="mb-0 small">
                    {% for a in expiring %}
                        <li>
                            <a href="{{ path('app_prototype_protection_show', {id: a.id}) }}" class="fa-alert__link">{{ a.title }}</a>
                            — {{ 'prototype_protection.field.next_assessment_due'|trans({}, 'prototype_protection') }}:
                            {{ a.nextAssessmentDue|date('d.m.Y') }}
                        </li>
                    {% endfor %}
                </ul>
            {% endblock %}
        {% endembed %}
    {% endif %}

    {% embed '_components/_card.html.twig' %}
        {% block card_body %}
            {% if assessments|length == 0 %}
                {% include '_components/_empty_state.html.twig' with {
                    icon: 'nav-shield-lock',
                    title: 'prototype_protection.empty.title'|trans({}, 'prototype_protection'),
                    message: 'prototype_protection.empty.message'|trans({}, 'prototype_protection')
                } %}
            {% else %}
                {% embed '_components/_fa_table.html.twig' with { compact: true } %}
                    {% block table_head %}
                        <tr>
                            <th scope="col" class="fa-table__th">{{ 'prototype_protection.field.title'|trans({}, 'prototype_protection') }}</th>
                            <th scope="col" class="fa-table__th">{{ 'prototype_protection.field.status'|trans({}, 'prototype_protection') }}</th>
                            <th scope="col" class="fa-table__th">{{ 'prototype_protection.field.tisax_level'|trans({}, 'prototype_protection') }}</th>
                            <th scope="col" class="fa-table__th">{{ 'prototype_protection.field.assessment_date'|trans({}, 'prototype_protection') }}</th>
                            <th scope="col" class="fa-table__th">{{ 'prototype_protection.field.overall_result'|trans({}, 'prototype_protection') }}</th>
                            <th scope="col" class="fa-table__th">{{ 'prototype_protection.field.next_assessment_due'|trans({}, 'prototype_protection') }}</th>
                            <th class="fa-table__th fa-table__th--actions"></th>
                        </tr>
                    {% endblock %}
                    {% block table_body_attrs %}id="prototype-protection-rows"{% endblock %}
                    {% block table_body %}
                        {% for a in assessments %}
                            {% include 'prototype_protection/_row.html.twig' with { a: a } %}
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            {% endif %}
        {% endblock %}
    {% endembed %}
    </main>
</div>
{% endblock %}
