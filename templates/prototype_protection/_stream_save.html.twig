{# Turbo Stream after a successful in-modal PrototypeProtectionAssessment save. #}
{% if is_new %}
    <turbo-stream action="append" target="prototype-protection-rows">
        <template>{% include 'prototype_protection/_row.html.twig' with { a: assessment } %}</template>
    </turbo-stream>
{% else %}
    <turbo-stream action="replace" target="prototype-protection-row-{{ assessment.id }}">
        <template>{% include 'prototype_protection/_row.html.twig' with { a: assessment } %}</template>
    </turbo-stream>
{% endif %}
