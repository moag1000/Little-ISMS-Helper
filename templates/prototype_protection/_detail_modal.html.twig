{# PrototypeProtectionAssessment read-only detail — rendered inside the
   fa-form-modal Turbo Frame. Uses drawer chrome for a clean condensed layout.
   "Vollansicht" link bypasses Turbo for the full show page. #}
{% trans_default_domain 'prototype_protection' %}
{% set status_variant = {
    'draft':     'secondary',
    'in_review': 'info',
    'approved':  'success',
    'rejected':  'danger',
    'expired':   'warning',
} %}
{% set result_variant = {
    'not_applicable': 'secondary',
    'not_met':        'danger',
    'partial':        'warning',
    'met':            'success',
    'exceeded':       'success',
} %}
<turbo-frame id="fa-form-modal">
    <div class="fa-drawer__header">
        <div class="fa-drawer__header-text">
            <div class="fa-drawer__eyebrow">TISAX VDA ISA 6.0 · Kap. 8 Prototypenschutz</div>
            <div class="fa-drawer__title">{{ assessment.title }}</div>
        </div>
        <button type="button" class="fa-drawer__close" data-action="fa-form-modal#close"
                aria-label="{{ 'common.close'|trans({}, 'messages') }}">
            <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i>
        </button>
    </div>
    <div class="fa-drawer__body">
        <div class="fa-drawer__section">
            {% include '_components/_badge.html.twig' with {
                variant: status_variant[assessment.status] ?? 'secondary',
                content: ('prototype_protection.status.' ~ assessment.status)|trans({}, 'prototype_protection')
            } %}
            {% if assessment.overallResult %}
                {% include '_components/_badge.html.twig' with {
                    variant: result_variant[assessment.overallResult] ?? 'secondary',
                    content: ('prototype_protection.result.' ~ assessment.overallResult)|trans({}, 'prototype_protection')
                } %}
            {% endif %}
        </div>

        {% if assessment.tisaxLevel %}
            <div class="fa-drawer__kv">
                <span class="label">{{ 'prototype_protection.field.tisax_level'|trans({}, 'prototype_protection') }}</span>
                <span>{{ assessment.tisaxLevel }}</span>
            </div>
        {% endif %}

        {% if assessment.assessmentDate %}
            <div class="fa-drawer__kv">
                <span class="label">{{ 'prototype_protection.field.assessment_date'|trans({}, 'prototype_protection') }}</span>
                <span>{{ assessment.assessmentDate|date('d.m.Y') }}</span>
            </div>
        {% endif %}

        {% if assessment.nextAssessmentDue %}
            <div class="fa-drawer__kv">
                <span class="label">{{ 'prototype_protection.field.next_assessment_due'|trans({}, 'prototype_protection') }}</span>
                <span>{{ assessment.nextAssessmentDue|date('d.m.Y') }}</span>
            </div>
        {% endif %}

        {% if assessment.supplier %}
            <div class="fa-drawer__kv">
                <span class="label">{{ 'prototype_protection.field.supplier'|trans({}, 'prototype_protection') }}</span>
                <span>{{ assessment.supplier.name }}</span>
            </div>
        {% endif %}

        {% if assessment.location %}
            <div class="fa-drawer__kv">
                <span class="label">{{ 'prototype_protection.field.location'|trans({}, 'prototype_protection') }}</span>
                <span>{{ assessment.location.name }}</span>
            </div>
        {% endif %}

        {% if assessment.assessor or assessment.assessorPerson %}
            <div class="fa-drawer__kv">
                <span class="label">{{ 'prototype_protection.field.assessor'|trans({}, 'prototype_protection') }}</span>
                <span>
                    {% if assessment.assessor %}
                        {{ assessment.assessor.fullName|default(assessment.assessor.email) }}
                    {% elseif assessment.assessorPerson %}
                        {{ assessment.assessorPerson.fullName }}
                    {% endif %}
                </span>
            </div>
        {% endif %}

        {% if assessment.overallResult %}
            <div class="fa-drawer__kv">
                <span class="label">{{ 'prototype_protection.field.overall_result'|trans({}, 'prototype_protection') }}</span>
                <span>{% include '_components/_badge.html.twig' with {
                    variant: result_variant[assessment.overallResult] ?? 'secondary',
                    content: ('prototype_protection.result.' ~ assessment.overallResult)|trans({}, 'prototype_protection')
                } %}</span>
            </div>
        {% endif %}

        <div class="fa-drawer__section">
            <a href="{{ path('app_prototype_protection_show', {id: assessment.id}) }}" data-turbo="false" class="fa-row-link">
                {{ 'common.open_full_view'|trans({}, 'messages') }} →
            </a>
        </div>
    </div>
    <div class="fa-drawer__footer" style="display:flex;gap:10px;justify-content:flex-end">
        <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--md" data-action="fa-form-modal#close">
            <span class="fa-cyber-btn__label">{{ 'common.close'|trans({}, 'messages') }}</span>
        </button>
        {% if is_granted('ROLE_MANAGER') %}
            <a href="{{ path('app_prototype_protection_edit', {id: assessment.id}) }}" data-turbo-frame="fa-form-modal"
               class="fa-cyber-btn fa-cyber-btn--md">
                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                <span class="fa-cyber-btn__label">{{ 'common.edit'|trans({}, 'messages') }}</span>
            </a>
        {% else %}
            <span class="fa-cyber-btn fa-cyber-btn--md" aria-disabled="true"
                  style="opacity:.5;pointer-events:none">
                <i class="fa-icon fa-icon--ui-lock" aria-hidden="true"></i>
                <span class="fa-cyber-btn__label">{{ 'common.edit'|trans({}, 'messages') }}</span>
            </span>
        {% endif %}
    </div>
</turbo-frame>
