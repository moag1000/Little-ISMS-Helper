        {# 10. AURORA TOKENS REFERENCE                                     #}
        {# ═══════════════════════════════════════════════════════════════ #}
        <section class="fa-section mb-5" id="sec-tokens">
            <div class="fa-section__header">
                <h2 class="fa-section__title">Aurora Design Tokens</h2>
            </div>
            <div class="fa-section__body">

                <p class="mb-3" style="color:var(--fg-2); font-size:.875rem;">
                    All colors must be referenced via CSS custom properties — never hardcode hex values.
                    Source of truth: <code>assets/styles/fairy-aurora.css</code>
                </p>

                <div class="table-responsive">
                    <table class="table" style="color:var(--fg);">
                        <thead>
                            <tr style="border-bottom:1px solid var(--border);">
                                <th style="color:var(--fg-2); font-weight:500; width:40px;"></th>
                                <th style="color:var(--fg-2); font-weight:500;">Token</th>
                                <th style="color:var(--fg-2); font-weight:500;">Usage</th>
                                <th style="color:var(--fg-2); font-weight:500;">CSS Usage</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% set tokens = [
                                { token: '--primary',         usage: 'Primary brand colour — interactive elements, key accents' },
                                { token: '--primary-strong',  usage: 'Darker primary for hover states and borders' },
                                { token: '--primary-tint',    usage: 'Very light primary tint for backgrounds, highlights' },
                                { token: '--accent',          usage: 'Secondary accent (Alva wand glow, sparkles)' },
                                { token: '--accent-tint',     usage: 'Light accent tint — subtle callout backgrounds' },
                                { token: '--success',         usage: 'Positive states — SLA met, controls active, OK' },
                                { token: '--warning',         usage: 'Caution states — pending items, medium risks' },
                                { token: '--danger',          usage: 'Error / critical states — incidents, high risks' },
                                { token: '--surface',         usage: 'Page-level background surface' },
                                { token: '--surface-2',       usage: 'Card / panel surface (slightly raised)' },
                                { token: '--fg',              usage: 'Primary text foreground' },
                                { token: '--fg-2',            usage: 'Secondary / muted text' },
                                { token: '--fg-3',            usage: 'Tertiary / placeholder text' },
                                { token: '--border',          usage: 'Default border colour' },
                                { token: '--border-strong',   usage: 'Stronger border for emphasis or dividers' }
                            ] %}
                            {% for t in tokens %}
                                <tr style="border-bottom:1px solid var(--border);">
                                    <td>
                                        <span style="display:inline-block; width:40px; height:40px; border-radius:6px; background:var({{ t.token }}); border:1px solid var(--border);" title="{{ t.token }}"></span>
                                    </td>
                                    <td><code style="color:var(--primary);">var({{ t.token }})</code></td>
                                    <td style="color:var(--fg-2); font-size:.875rem;">{{ t.usage }}</td>
                                    <td><code style="color:var(--fg-3); font-size:.8rem;">color: var({{ t.token }})</code></td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                <details>
                    <summary style="cursor:pointer; color:var(--primary); margin-bottom:.5rem;">Code kopieren</summary>
                    <pre style="background:var(--surface-2); border:1px solid var(--border); border-radius:6px; padding:1rem; overflow-x:auto;"><code>{% verbatim %}{# CORRECT — always use CSS custom properties #}
<span style="color: var(--primary);">Primary text</span>
<div style="background: var(--surface-2); border: 1px solid var(--border);">Card</div>

{# WRONG — never use hardcoded hex #}
{# <span style="color: #0284c7;">Primary text</span>  ← stylelint will catch this #}

{# Token categories: #}
{# Brand:    --primary, --primary-strong, --primary-tint, --accent, --accent-tint #}
{# Semantic: --success, --warning, --danger #}
{# Surface:  --surface, --surface-2 #}
{# Text:     --fg, --fg-2, --fg-3 #}
{# Border:   --border, --border-strong #}{% endverbatim %}</code></pre>
                </details>
            </div>
        </section>

