                        ~ '<label style="display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--surface-2);border:1px solid var(--border);border-radius:var(--r-md);cursor:pointer;"><input type="checkbox" checked> <span><strong style="display:block;margin-bottom:2px;">DPIA-Status</strong><span style="font-size:11.5px;color:var(--fg-3);">GDPR Art. 35 Datenschutz-Folgenabschätzungen</span></span></label>'
                        ~ '</div>',
                    primaryLabel: 'Speichern',
                    primaryIcon: 'ui-check',
                }) }}

                <details class="mt-3">
                    <summary style="cursor:pointer; color:var(--primary); font-weight:600; padding:.5rem 0;">Code kopieren</summary>
                    <pre style="background:var(--surface-2); border:1px solid var(--border); border-radius:6px; padding:1rem; overflow-x:auto; font-size:12px; margin-top:.75rem;"><code>{% verbatim %}{% import '_components/_fa_modal.html.twig' as _fa_modal %}

{{ _fa_modal.settings({
    id:            'dashboard-customize',
    icon:          'sliders',
    title:         'Dashboard anpassen',
    subtitle:      'Sichtbarkeit der Widgets',
    body:          include('dashboard/_widget_toggles.html.twig'),
    primaryLabel:  'Speichern',
    formAction:    path('dashboard_settings_save'),
    formCsrfToken: csrf_token('dashboard_settings'),
}) }}{% endverbatim %}</code></pre>
                </details>
            </div>
        </section>

    </div>{# /container-xl #}
</main>
{% endblock %}
