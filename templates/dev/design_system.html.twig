{# Living Styleguide — live macro demos PLUS the canonical spec sections
   shipped under docs/design_system/sections/*.html (loaded by
   DevDesignSystemController::loadSpecSections()). Single source of truth
   per AURORA_v4_FULL_MIGRATION_PLAN.md § 11.3 Living-Doc-Page. #}
{% extends 'base.html.twig' %}

{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_section.html.twig' as _fa_section %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
{% import '_components/_fa_hero.html.twig' as _fa_hero %}
{% import '_components/_fa_filter_chip.html.twig' as _fa_filter_chip %}
{% import '_components/_fa_entity_card.html.twig' as _fa_entity_card %}
{% import '_components/_fa_entity_badge.html.twig' as _fa_entity_badge %}
{% import '_components/_alva.html.twig' as alva %}
{% import '_components/_fa_form_layout.html.twig' as _fa_form %}
{% import '_components/_fa_modal_wizard.html.twig' as _fa_modal_wizard %}
{% import '_components/_fa_modal.html.twig' as _fa_modal %}
{% import '_components/_fa_tabs.html.twig' as _fa_tabs %}

{% block title %}Aurora v4 Living Styleguide{% endblock %}

{% block body %}
<meta name="turbo-cache-control" content="no-cache">

<main class="fa-aurora-surface fa-aurora-surface--dots" style="min-height:100vh; padding-bottom: 4rem;">
    <div class="container-xl py-4">

        {# ── Top navigation ────────────────────────────────────────────── #}
        <nav class="d-flex flex-wrap gap-2 mb-4 p-3" style="background:var(--surface-2); border-radius:var(--radius-lg,8px); border:1px solid var(--border);">
            <span style="color:var(--fg-2); font-size:.75rem; align-self:center; margin-right:.5rem;">Jump to:</span>
            <a href="#sec-spec-sections" class="fa-filter-chip">Living Spec</a>
            <a href="#sec-surface"      class="fa-filter-chip">Aurora Surfaces</a>
            <a href="#sec-page-header"  class="fa-filter-chip">fa-page-header</a>
            <a href="#sec-section"      class="fa-filter-chip">fa-section</a>
            <a href="#sec-feature-card" class="fa-filter-chip">fa-feature-card</a>
            <a href="#sec-empty-state"  class="fa-filter-chip">fa-empty-state</a>
            <a href="#sec-hero"         class="fa-filter-chip">fa-hero</a>
            <a href="#sec-filter-chip"  class="fa-filter-chip">fa-filter-chip</a>
            <a href="#sec-entity-card"  class="fa-filter-chip">fa-entity-card</a>
            <a href="#sec-entity-badge" class="fa-filter-chip">fa-entity-badge</a>
            <a href="#sec-alva"         class="fa-filter-chip">Alva moods</a>
            <a href="#sec-cyber-btn"    class="fa-filter-chip">fa-cyber-btn</a>
            <a href="#sec-tokens"       class="fa-filter-chip">Aurora tokens</a>
            <a href="#sec-bulk-bar"     class="fa-filter-chip">fa-bulk-bar</a>
            <a href="#sec-kbd"          class="fa-filter-chip">fa-kbd / fa-cheatsheet</a>
            <a href="#sec-pager"        class="fa-filter-chip">fa-pager</a>
            <a href="#sec-fa-menu"      class="fa-filter-chip">fa-menu</a>
            <a href="#fa-form-layout"       class="fa-filter-chip">fa-form-layout</a>
            <a href="#fa-modal-wizard"     class="fa-filter-chip">fa-modal--wizard</a>
            <a href="#fa-tabs"             class="fa-filter-chip">fa-tabs</a>
            <a href="#fa-modal-confirm"    class="fa-filter-chip">fa-modal--confirm</a>
            <a href="#fa-modal-settings"   class="fa-filter-chip">fa-modal--settings</a>
        </nav>

        {# ── Page header ───────────────────────────────────────────────── #}
        {{ _fa_page_header.render({
            badge:    { icon: 'nav-palette', label: 'Dev only' },
            title:    'Aurora v4 Living Styleguide',
            subtitle: 'Every FairyAurora component with live preview and copy-paste Twig snippet.',
            actions: [
                { label: 'Source',   variant: 'ghost',   icon: 'ui-external-link',    href: '#' },
                { label: 'Phase 5',  variant: 'primary',  icon: 'ui-stars',     href: '#' }
            ]
        }) }}

        {# ═══════════════════════════════════════════════════════════════ #}
        {# 0. LIVING SPEC SECTIONS                                          #}
        {#    Canonical HTML fragments from docs/design_system/sections/.   #}
        {#    Each section is collapsed by default — live demos below       #}
        {#    remain the primary navigation, spec is reference material.    #}
        {# ═══════════════════════════════════════════════════════════════ #}
        {% if spec_sections|default([])|length > 0 %}
        <section class="fa-section mb-5" id="sec-spec-sections">
            <div class="fa-section__header">
                <h2 class="fa-section__title">
                    <i class="fa-icon fa-icon--nav-book me-2" aria-hidden="true"></i>
                    Living Spec Sections
                </h2>
                <p class="fa-section__subtitle" style="margin:.25rem 0 0; color:var(--fg-2); font-size:.8rem;">
                    Canonical Aurora v4 reference material — collapsed by default.
                    Source: <code>docs/design_system/sections/*.html</code>.
                </p>
            </div>
            <div class="fa-section__body">
                <div class="d-flex flex-wrap gap-2 mb-3">
                    {% for sec in spec_sections %}
                        <a href="#spec-{{ sec.key }}" class="fa-filter-chip">{{ sec.title }}</a>
                    {% endfor %}
                </div>
                {% for sec in spec_sections %}
                    <details id="spec-{{ sec.key }}" class="mb-2" style="background:var(--surface-2); border:1px solid var(--border); border-radius:var(--radius-md,6px); padding:.75rem 1rem;">
                        <summary style="cursor:pointer; color:var(--primary); font-weight:600;">
                            {{ sec.title }}
                            <span style="color:var(--fg-3); font-weight:400; font-size:.8rem; margin-left:.5rem;">
                                ({{ sec.key }}.html)
                            </span>
                        </summary>
                        <div class="spec-section-body mt-3">
                            {{ sec.html|raw }}
                        </div>
                    </details>
                {% endfor %}
            </div>
        </section>
        {% endif %}

        {# ═══════════════════════════════════════════════════════════════ #}
        {# 1. AURORA SURFACE VARIANTS                                      #}
        {# ═══════════════════════════════════════════════════════════════ #}
        <section class="fa-section mb-5" id="sec-surface">
            <div class="fa-section__header">
                <h2 class="fa-section__title">Aurora Surface Variants</h2>
            </div>
            <div class="fa-section__body">

                <div class="row g-3 mb-3">
                    <div class="col-sm-6 col-lg-3">
                        <div class="fa-aurora-surface d-flex align-items-center justify-content-center fw-semibold"
                             style="height:200px; border-radius:var(--radius-lg,8px); border:1px solid var(--border); color:var(--fg);">
                            .fa-aurora-surface
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <div class="fa-aurora-surface--subtle d-flex align-items-center justify-content-center fw-semibold"
                             style="height:200px; border-radius:var(--radius-lg,8px); border:1px solid var(--border); color:var(--fg);">
                            .fa-aurora-surface--subtle
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <div class="fa-aurora-surface--hero d-flex align-items-center justify-content-center fw-semibold"
                             style="height:200px; border-radius:var(--radius-lg,8px); border:1px solid var(--border); color:var(--fg);">
                            .fa-aurora-surface--hero
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <div class="fa-aurora-surface--dots d-flex align-items-center justify-content-center fw-semibold"
                             style="height:200px; border-radius:var(--radius-lg,8px); border:1px solid var(--border); color:var(--fg);">
                            .fa-aurora-surface--dots
                        </div>
                    </div>
                </div>

                <details>
                    <summary style="cursor:pointer; color:var(--primary); margin-bottom:.5rem;">Code kopieren</summary>
                    <pre style="background:var(--surface-2); border:1px solid var(--border); border-radius:6px; padding:1rem; overflow-x:auto;"><code>{% verbatim %}<div class="fa-aurora-surface">…default aurora…</div>
<div class="fa-aurora-surface--subtle">…subtle variant…</div>
<div class="fa-aurora-surface--hero">…hero variant…</div>
<div class="fa-aurora-surface--dots">…dots variant…</div>{% endverbatim %}</code></pre>
                </details>
            </div>
        </section>

        {# ═══════════════════════════════════════════════════════════════ #}
        {# 2. FA-PAGE-HEADER                                               #}
        {# ═══════════════════════════════════════════════════════════════ #}
        <section class="fa-section mb-5" id="sec-page-header">
            <div class="fa-section__header">
                <h2 class="fa-section__title">fa-page-header</h2>
            </div>
            <div class="fa-section__body">

                <div class="mb-3" style="background:var(--surface-2); border:1px solid var(--border); border-radius:var(--radius-lg,8px); padding:1.5rem;">
                    {{ _fa_page_header.render({
                        badge:    { icon: 'nav-shield-lock', label: 'ISMS' },
                        title:    'Risikoübersicht',
                        subtitle: 'Alle offenen Risiken der aktuellen Periode.',
                        actions: [
                            { label: 'Filter',    variant: 'ghost',   icon: 'ui-funnel',  href: '#' },
                            { label: 'Neu',       variant: 'primary', icon: 'plus',    href: '#' }
                        ]
                    }) }}
                </div>

                <details>
                    <summary style="cursor:pointer; color:var(--primary); margin-bottom:.5rem;">Code kopieren</summary>
                    <pre style="background:var(--surface-2); border:1px solid var(--border); border-radius:6px; padding:1rem; overflow-x:auto;"><code>{% verbatim %}{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{{ _fa_page_header.render({
    badge:    { icon: 'nav-shield-lock', label: 'ISMS' },
    title:    'Risikoübersicht',
    subtitle: 'Alle offenen Risiken der aktuellen Periode.',
    actions: [
        { label: 'Filter', variant: 'ghost',   icon: 'ui-funnel', href: path('risk_index') },
        { label: 'Neu',    variant: 'primary',  icon: 'plus',   href: path('risk_new') }
    ]
}) }}{% endverbatim %}</code></pre>
                </details>
            </div>
        </section>

        {# ═══════════════════════════════════════════════════════════════ #}
        {# 3. FA-SECTION                                                   #}
        {# ═══════════════════════════════════════════════════════════════ #}
        <section class="fa-section mb-5" id="sec-section">
            <div class="fa-section__header">
                <h2 class="fa-section__title">fa-section</h2>
            </div>
            <div class="fa-section__body">

                <div class="mb-3">
                    {{ _fa_section.render({
                        title:  'Neueste Aktivität',
                        tools:  '<button class="fa-filter-chip fa-filter-chip--active" type="button">Heute</button>
                                 <button class="fa-filter-chip" type="button">Woche</button>
                                 <button class="fa-filter-chip" type="button">Monat</button>',
                        body:   '<p style="color:var(--fg-2);">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Quisque vehicula mauris in erat accumsan, vel varius odio lacinia. Suspendisse potenti.</p>',
                        footer: '<a href="#" class="fa-link">Alle anzeigen &rarr;</a>'
                    }) }}
                </div>

                <details>
                    <summary style="cursor:pointer; color:var(--primary); margin-bottom:.5rem;">Code kopieren</summary>
                    <pre style="background:var(--surface-2); border:1px solid var(--border); border-radius:6px; padding:1rem; overflow-x:auto;"><code>{% verbatim %}{% import '_components/_fa_section.html.twig' as _fa_section %}

{{ _fa_section.render({
    title:  'Neueste Aktivität',
    tools:  '<button class="fa-filter-chip fa-filter-chip--active" type="button">Heute</button>
             <button class="fa-filter-chip" type="button">Woche</button>',
    body:   '<p>Lorem ipsum dolor sit amet…</p>',
    footer: '<a href="#" class="fa-link">Alle anzeigen →</a>'
}) }}{% endverbatim %}</code></pre>
                </details>
            </div>
        </section>

        {# ═══════════════════════════════════════════════════════════════ #}
        {# 4. FA-FEATURE-CARD                                              #}
        {# ═══════════════════════════════════════════════════════════════ #}
        <section class="fa-section mb-5" id="sec-feature-card">
            <div class="fa-section__header">
                <h2 class="fa-section__title">fa-feature-card</h2>
            </div>
            <div class="fa-section__body">

                <div class="row g-3 mb-3">
                    <div class="col-sm-6 col-lg-3">
                        {{ _fa_feature_card.render({
                            label:   'SLA erfüllt',
                            value:   '98.4',
                            unit:    '%',
                            variant: 'success',
                            icon:    'check-circle-fill',
                            hint:    '+2.1% seit letzter Woche'
                        }) }}
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        {{ _fa_feature_card.render({
                            label:   'Offene Risiken',
                            value:   '12',
                            unit:    '',
                            variant: 'warning',
                            icon:    'exclamation-triangle-fill',
                            hint:    '3 neu diese Woche'
                        }) }}
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        {{ _fa_feature_card.render({
                            label:   'Kritische Vorfälle',
                            value:   '2',
                            unit:    '',
                            variant: 'danger',
                            icon:    'shield-exclamation',
                            hint:    'Eskalation erforderlich'
                        }) }}
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        {{ _fa_feature_card.render({
                            label:   'Controls aktiv',
                            value:   '87',
                            unit:    '/ 93',
                            variant: 'primary',
                            icon:    'toggles-on',
                            hint:    '6 ausstehend'
                        }) }}
                    </div>
                </div>

                <details>
                    <summary style="cursor:pointer; color:var(--primary); margin-bottom:.5rem;">Code kopieren</summary>
                    <pre style="background:var(--surface-2); border:1px solid var(--border); border-radius:6px; padding:1rem; overflow-x:auto;"><code>{% verbatim %}{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}

{{ _fa_feature_card.render({
    label:   'SLA erfüllt',
    value:   '98.4',
    unit:    '%',
    variant: 'success',    {# success | warning | danger | primary #}
    icon:    'check-circle-fill',
    hint:    '+2.1% seit letzter Woche'
}) }}

{# Clickable tile — add href #}
{{ _fa_feature_card.render({
    label:   'Offene Risiken',
    value:   '12',
    variant: 'warning',
    icon:    'exclamation-triangle-fill',
    href:    path('risk_index')
}) }}{% endverbatim %}</code></pre>
                </details>
            </div>
        </section>

        {# ═══════════════════════════════════════════════════════════════ #}
        {# 5. FA-EMPTY-STATE                                               #}
        {# ═══════════════════════════════════════════════════════════════ #}
        <section class="fa-section mb-5" id="sec-empty-state">
            <div class="fa-section__header">
                <h2 class="fa-section__title">fa-empty-state</h2>
            </div>
            <div class="fa-section__body">

                <div class="mb-3">
                    {{ _fa_empty_state.render({
                        mood:    'curious',
                        title:   'Noch keine Dokumente vorhanden',
                        text:    'Laden Sie das erste Dokument hoch oder wählen Sie eine Vorlage, um loszulegen.',
                        actions: [
                            { label: 'Dokument hochladen', variant: 'primary', icon: 'ui-upload',        href: '#' },
                            { label: 'Vorlage wählen',     variant: 'ghost',   icon: 'nav-file-earmark-text',  href: '#' }
                        ]
                    }) }}
                </div>

                <details>
                    <summary style="cursor:pointer; color:var(--primary); margin-bottom:.5rem;">Code kopieren</summary>
                    <pre style="background:var(--surface-2); border:1px solid var(--border); border-radius:6px; padding:1rem; overflow-x:auto;"><code>{% verbatim %}{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}

{{ _fa_empty_state.render({
    mood:    'curious',   {# idle|happy|thinking|focused|working|scanning|warning|celebrating|sleeping #}
    title:   'Noch keine Dokumente vorhanden',
    text:    'Laden Sie das erste Dokument hoch oder wählen Sie eine Vorlage.',
    actions: [
        { label: 'Hochladen',     variant: 'primary', icon: 'ui-upload',       href: path('document_new') },
        { label: 'Vorlage wählen', variant: 'ghost',  icon: 'nav-file-earmark-text', href: '#' }
    ]
}) }}{% endverbatim %}</code></pre>
                </details>
            </div>
        </section>

        {# ═══════════════════════════════════════════════════════════════ #}
        {# 6. FA-HERO                                                      #}
        {# ═══════════════════════════════════════════════════════════════ #}
        <section class="fa-section mb-5" id="sec-hero">
            <div class="fa-section__header">
                <h2 class="fa-section__title">fa-hero</h2>
            </div>
            <div class="fa-section__body">

                <div class="mb-3">
                    {{ _fa_hero.render({
                        mood:     'happy',
                        title:    'Willkommen zurück, Max',
                        subtitle: 'Heute warten 3 Aufgaben in der Inbox auf Sie. Ihr ISMS-Status ist aktuell.',
                        actions:  [
                            { label: "Los geht's", variant: 'primary', icon: 'ui-arrow-right', href: '#' }
                        ]
                    }) }}
                </div>

                <details>
                    <summary style="cursor:pointer; color:var(--primary); margin-bottom:.5rem;">Code kopieren</summary>
                    <pre style="background:var(--surface-2); border:1px solid var(--border); border-radius:6px; padding:1rem; overflow-x:auto;"><code>{% verbatim %}{% import '_components/_fa_hero.html.twig' as _fa_hero %}

{{ _fa_hero.render({
    mood:     'happy',    {# idle|happy|thinking|focused|working|scanning|warning|celebrating|sleeping #}
    title:    'Willkommen zurück, {{ app.user.displayName }}',
    subtitle: 'Heute warten 3 Aufgaben in der Inbox auf Sie.',
    actions:  [
        { label: "Los geht's", variant: 'primary', icon: 'ui-arrow-right', href: path('dashboard') }
    ]
}) }}{% endverbatim %}</code></pre>
                </details>
            </div>
        </section>

        {# ═══════════════════════════════════════════════════════════════ #}
        {# 7. FA-FILTER-CHIP                                               #}
        {# ═══════════════════════════════════════════════════════════════ #}
        <section class="fa-section mb-5" id="sec-filter-chip">
            <div class="fa-section__header">
                <h2 class="fa-section__title">fa-filter-chip</h2>
            </div>
            <div class="fa-section__body">

                {# Single chips #}
                <p class="mb-2" style="color:var(--fg-2); font-size:.875rem;">Single chips:</p>
                <div class="d-flex flex-wrap gap-2 mb-4">
                    {{ _fa_filter_chip.render('Alle',  { active: false }) }}
                    {{ _fa_filter_chip.render('Heute', { active: true  }) }}
                    {{ _fa_filter_chip.render('Mit Icon', { active: false, icon: 'ui-funnel' }) }}
                </div>

                {# Group #}
                <p class="mb-2" style="color:var(--fg-2); font-size:.875rem;">Chip group (activeIndex=1):</p>
                <div class="mb-4">
                    {{ _fa_filter_chip.group(['Heute', 'Woche', 'Monat', 'Quartal'], 1) }}
                </div>

                {# Group with hrefs #}
                <p class="mb-2" style="color:var(--fg-2); font-size:.875rem;">{{ 'dev.design_system.filter_chip.group_with_hrefs'|trans({}, 'dev') }}</p>
                <div class="mb-3">
                    {{ _fa_filter_chip.group([
                        { label: 'Offen',       href: '?status=open'   },
                        { label: 'In Bearbeitung', href: '?status=wip' },
                        { label: 'Geschlossen', href: '?status=closed' }
                    ], 0) }}
                </div>

                <details>
                    <summary style="cursor:pointer; color:var(--primary); margin-bottom:.5rem;">Code kopieren</summary>
                    <pre style="background:var(--surface-2); border:1px solid var(--border); border-radius:6px; padding:1rem; overflow-x:auto;"><code>{% verbatim %}{% import '_components/_fa_filter_chip.html.twig' as _fa_filter_chip %}

{# Single chip — as <button> #}
{{ _fa_filter_chip.render('Heute', { active: true }) }}

{# Single chip — as <a> with icon #}
{{ _fa_filter_chip.render('Filter', { active: false, icon: 'ui-funnel', href: '?filter=1' }) }}

{# Group — string labels, second chip active #}
{{ _fa_filter_chip.group(['Heute', 'Woche', 'Monat'], 1) }}

{# Group — objects with hrefs #}
{{ _fa_filter_chip.group([
    { label: 'Offen',       href: '?status=open'   },
    { label: 'In Bearbeitung', href: '?status=wip' },
    { label: 'Geschlossen', href: '?status=closed' }
], 0) }}{% endverbatim %}</code></pre>
                </details>
            </div>
        </section>

        {# ═══════════════════════════════════════════════════════════════ #}
        {# 7b. fa-entity-card — Listen-Item-Card mit Entity-Icon          #}
        {# ═══════════════════════════════════════════════════════════════ #}
        <section class="fa-section mb-5" id="sec-entity-card">
            <div class="fa-section__header">
                <h2 class="fa-section__title">fa-entity-card</h2>
            </div>
            <div class="fa-section__body">
                <p class="text-muted mb-3">Listen-Item-Card für Findings, Risks, Controls, Incidents, Audits, NCs. 7 Entity-Type-Variants mit Akzent-Leiste + Icon-Färbung. Compact-Variante für dichte Listen.</p>

                <div class="d-flex flex-column gap-2 mb-3">
                    {{ _fa_entity_card.render({
                        type:    'finding',
                        icon:    'finding',
                        title:   'F-2026-014 Lückenhafte Logging-Konfig',
                        meta:    ['ISO 27001 A.8.15', 'fällig 12.05.'],
                        href:    '#',
                        status:  { variant: 'warning', label: 'Offen' }
                    }) }}
                    {{ _fa_entity_card.render({
                        type:    'risk',
                        icon:    'risk-register',
                        title:   'R-2026-007 Lieferantenausfall Cloud-Provider',
                        meta:    ['Likelihood: hoch', 'Impact: kritisch', 'Owner: CTO'],
                        href:    '#',
                        status:  { variant: 'danger', label: 'Hoch' }
                    }) }}
                    {{ _fa_entity_card.render({
                        type:    'evidence',
                        icon:    'evidence',
                        title:   'EV-2026-091 Penetrationstest-Bericht Q1',
                        meta:    ['ISO 27001 A.8.8', 'sha256 verifiziert'],
                        href:    '#',
                        status:  { variant: 'success', label: 'Validiert' },
                        compact: true
                    }) }}
                </div>

                <details>
                    <summary>Twig snippet</summary>
                    <pre style="background:var(--surface-2); border:1px solid var(--border); border-radius:6px; padding:1rem; overflow-x:auto;"><code>{% verbatim %}{% import '_components/_fa_entity_card.html.twig' as _fa_entity_card %}

{{ _fa_entity_card.render({
    type:    'finding',                           {# entity-type sets accent-line + icon-color #}
    icon:    'finding',                           {# fa-icon-- name #}
    title:   'F-2026-014 Lückenhafte Logging-Konfig',
    meta:    ['ISO 27001 A.8.15', 'fällig 12.05.'],
    href:    path('audit_finding_show', {id: 14}),
    status:  { variant: 'warning', label: 'Offen' },
