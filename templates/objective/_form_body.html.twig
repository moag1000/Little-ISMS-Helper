{# Shared ISMSObjective form body (outline-rail). Used full-page by new/edit and inside
   the fa-form-modal frame (modal: true). Caller wraps it in form_start/form_end
   and passes title / actions. Section map mirrors ISMSObjectiveType::getSectionMap(). #}
{% trans_default_domain 'objective' %}
{% set modal = modal|default(false) %}
{% set title = title|default(objective is defined and objective and objective.title ? objective.title : ('objective.title.new'|trans({}, 'objective'))) %}
{% set submit_label = submit_label|default('common.save'|trans({}, 'messages')) %}

{% set form_sections = {
    'overview': {
        'label': 'objective.section.basic_info'|trans({}, 'objective'),
        'fields': ['title', 'description', 'category']
    },
    'target_metric': {
        'label': 'objective.section.measurement'|trans({}, 'objective'),
        'fields': ['measurableIndicators', 'targetValue', 'currentValue', 'unit']
    },
    'monitoring': {
        'label': 'objective.section.measurement'|trans({}, 'objective'),
        'fields': ['measurementFrequency', 'measurementMethod']
    },
    'responsibility': {
        'label': 'objective.section.responsibility'|trans({}, 'objective'),
        'fields': ['responsiblePerson', 'responsibleForMeasurement', 'targetDate']
    },
    'audit_metadata': {
        'label': 'objective.section.status_progress'|trans({}, 'objective'),
        'fields': ['status', 'progressNotes']
    }
} %}

{% include '_components/_auto_form.html.twig' with {
    'form': form,
    'layout': 'outline-rail',
    'modal': modal,
    'eyebrow': 'ISO 27001 Kl. 6.2 · ISMS-Ziele',
    'title': title,
    'sections': form_sections,
    'col_widths': {
        'title': 12,
        'description': 12,
        'category': 6,
        'measurableIndicators': 12,
        'targetValue': 4,
        'currentValue': 4,
        'unit': 4,
        'measurementFrequency': 6,
        'measurementMethod': 12,
        'responsiblePerson': 6,
        'responsibleForMeasurement': 6,
        'targetDate': 6,
        'status': 6,
        'progressNotes': 12
    },
    'tooltips': {
        'measurableIndicators': 'objective.tooltip.measurable_indicators',
        'currentValue': 'objective.tooltip.current_value',
        'targetValue': 'objective.tooltip.target_value',
        'category': 'objective.tooltip.category',
        'status': 'objective.tooltip.status'
    },
    'translation_domain': 'objective',
    'actions': actions|default({
        'close': { 'label': 'common.cancel'|trans({}, 'messages'), 'variant': 'ghost' },
        'submit': { 'label': submit_label, 'variant': 'primary' }
    })
} %}
