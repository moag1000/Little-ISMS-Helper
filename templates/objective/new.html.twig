{% extends 'base.html.twig' %}
{% trans_default_domain 'objective' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'objective.title.new'|trans({}, 'objective') }}{% endblock %}

{% block body %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.objectives'|trans({}, 'nav'), url: path('app_objective_index') },
            { label: 'objective.title.new'|trans({}, 'objective') }
        ]
    } %}

    {{ _fa_page_header.render({
        title: 'objective.title.new'|trans({}, 'objective'),
        badge: { icon: 'plus', label: '' },
        actions: [
            { label: 'common.back_to_list'|trans({}, 'messages'), href: path('app_objective_index'), variant: 'ghost', icon: 'util-arrow-left' }
        ]
    }) }}

    {{ form_start(form) }}
    {% include '_components/_auto_form.html.twig' with {
        'form': form,
        'layout': 'outline-rail',
        'eyebrow': 'ISO 27001 Cl. 6.2 · ISMS Objectives',
        'title': 'objective.title.new'|trans({}, 'objective'),
        'sections': {
            'overview': {
                'label': 'form.section.overview'|trans({}, 'messages'),
                'fields': ['title', 'description', 'category']
            },
            'target_metric': {
                'label': 'form.section.target_metric'|trans({}, 'messages'),
                'fields': ['measurableIndicators', 'targetValue', 'currentValue', 'unit']
            },
            'monitoring': {
                'label': 'form.section.monitoring'|trans({}, 'messages'),
                'fields': ['measurementFrequency', 'measurementMethod']
            },
            'responsibility': {
                'label': 'form.section.responsibility'|trans({}, 'messages'),
                'fields': ['responsiblePerson', 'responsibleForMeasurement', 'targetDate']
            },
            'audit_metadata': {
                'label': 'form.section.audit_metadata'|trans({}, 'messages'),
                'fields': ['status', 'progressNotes']
            }
        },
        'col_widths': {
            'title': 8,
            'category': 4,
            'description': 12,
            'measurableIndicators': 12,
            'targetValue': 4,
            'currentValue': 4,
            'unit': 4,
            'measurementFrequency': 6,
            'measurementMethod': 6,
            'responsiblePerson': 6,
            'responsibleForMeasurement': 6,
            'targetDate': 6,
            'status': 6,
            'progressNotes': 12
        },
        'tooltips': {
            'measurableIndicators': 'objective.tooltip.measurable_indicators',
            'currentValue': 'objective.tooltip.current_value',
            'targetValue': 'objective.tooltip.target_value',
            'category': 'objective.tooltip.category',
            'status': 'objective.tooltip.status'
        },
        'translation_domain': 'objective',
        'actions': {
            'close': { 'label': 'common.cancel'|trans({}, 'messages'), 'variant': 'ghost' },
            'submit': { 'label': 'objective.action.create'|trans({}, 'objective'), 'variant': 'primary' }
        }
    } %}
    {{ form_end(form) }}
</div>
{% endblock %}
