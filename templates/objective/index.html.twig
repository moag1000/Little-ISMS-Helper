{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% trans_default_domain 'objective'%}
{% import '_macros/cards.html.twig' as cards %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'objective.page.title'|trans({}, 'objective') }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.objectives'|trans({}, 'nav') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'target', label: 'nav.objectives'|trans({}, 'nav') },
        title: 'objective.page.title'|trans({}, 'objective'),
        actions: is_granted('ROLE_ADMIN') ? [
            { label: 'objective.action.add_new'|trans({}, 'objective'), variant: 'primary', icon: 'plus-circle', href: path('app_objective_new') }
        ] : []
    }) }}

    <main class="fa-aurora-surface">

    <turbo-frame id="objective-stats">
        <div class="row mb-4">
            <div class="col-md-3">
                {{ cards.kpi_card(('objective.stats.total'|trans({}, 'objective')), statistics.total, null, null, 'primary', 'border-primary') }}
            </div>
            <div class="col-md-3">
                {{ cards.kpi_card(('objective.stats.active'|trans({}, 'objective')), statistics.active, null, null, 'info', 'border-info') }}
            </div>
            <div class="col-md-3">
                {{ cards.kpi_card(('objective.stats.achieved'|trans({}, 'objective')), statistics.achieved, null, null, 'success', 'border-success') }}
            </div>
            <div class="col-md-3">
                {{ cards.kpi_card(('objective.stats.delayed'|trans({}, 'objective')), statistics.delayed, null, null, 'warning', 'border-warning') }}
            </div>
        </div>
    </turbo-frame>

    {% embed '_components/_card.html.twig' %}
        {% block card_header %}
            <div class="card-header"><h2 class="mb-0"><i class="fa-icon fa-icon--nav-bullseye" aria-hidden="true"></i> {{ 'objective.list.title'|trans({'%count%': objectives|length}, 'objective') }}</h2></div>
        {% endblock %}
        {% block card_body %}
            {% if objectives|length == 0 %}
            {% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
            {{ _fa_empty_state.render({
                mood: 'sleeping',
                title: 'objective.message.no_objectives'|trans({}, 'objective'),
                actions: is_granted('ROLE_ADMIN') ? [
                    { label: 'objective.action.add_new'|trans({}, 'objective'), variant: 'primary', icon: 'plus-circle', href: path('app_objective_new') }
                ] : []
            }) }}
            {% else %}
            {% embed '_components/_table.html.twig' with {
                'noMargin': true
            } %}
                {% block table_head %}
                    <tr>
                        <th scope="col">{{ 'objective.table.title'|trans({}, 'objective') }}</th>
                        <th scope="col">{{ 'objective.table.category'|trans({}, 'objective') }}</th>
                        <th scope="col">{{ 'objective.table.target_date'|trans({}, 'objective') }}</th>
                        <th scope="col">{{ 'objective.table.progress'|trans({}, 'objective') }}</th>
                        <th scope="col">{{ 'objective.table.status'|trans({}, 'objective') }}</th>
                        <th scope="col">{{ 'common.actions'|trans({}, 'messages') }}</th>
                    </tr>
                {% endblock %}
                {% block table_body %}
                    {% for objective in objectives %}
                    <tr>
                        <td><strong>{{ objective.title }}</strong></td>
                        <td>{% include '_components/_badge.html.twig' with { variant: 'secondary', content: objective.category } %}</td>
                        <td>{{ objective.targetDate|date('d.m.Y') }}</td>
                        <td>
                            <div class="progress progress-h-20">
                                <div class="progress-bar {% if objective.progressPercentage >= 75 %}bg-success{% elseif objective.progressPercentage >= 50 %}bg-warning{% else %}bg-danger{% endif %}"
                                     style="width: {{ objective.progressPercentage }}%">{{ objective.progressPercentage }}%</div>
                            </div>
                        </td>
                        <td>{% include '_components/_badge.html.twig' with { variant: objective.status == 'achieved' ? 'success' : (objective.status == 'in_progress' ? 'info' : 'warning'), content: ('objective.status.' ~ objective.status)|trans({}, 'objective') } %}</td>
                        <td>
                            <a href="{{ path('app_objective_show', {id: objective.id}) }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost" aria-label="{{ 'common.view'|trans({}, 'messages') }}" title="{{ 'common.view'|trans({}, 'messages') }}"><i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i></a>
                            {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('app_objective_edit', {id: objective.id}) }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost" aria-label="{{ 'common.edit'|trans({}, 'messages') }}" title="{{ 'common.edit'|trans({}, 'messages') }}"><i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i></a>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                {% endblock %}
            {% endembed %}
            {% endif %}
        {% endblock %}
    {% endembed %}
    </main>
</div>
{% endblock %}
