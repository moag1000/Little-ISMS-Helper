{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% trans_default_domain 'objective'%}

{% block title %}{{ objective.title }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.objectives'|trans({}, 'nav'), url: path('app_objective_index') },
            { label: objective.title }
        ]
    } %}

    {% set _show_actions = [] %}
    {% if is_granted('ROLE_ADMIN') %}
        {% set _show_actions = _show_actions|merge([{ label: 'common.edit'|trans({}, 'messages'), variant: 'primary', icon: 'pencil', href: path('app_objective_edit', {id: objective.id}) }]) %}
    {% endif %}
    {% set _show_actions = _show_actions|merge([{ label: 'common.back_to_list'|trans({}, 'messages'), variant: 'ghost', icon: 'arrow-left', href: path('app_objective_index') }]) %}
    {{ _fa_page_header.render({
        badge: { icon: 'bullseye', label: ('objective.status.' ~ objective.status)|trans({}, 'objective') },
        title: objective.title,
        subtitle: objective.category|default(''),
        actions: _show_actions
    }) }}

    <div class="row">
        <div class="col-lg-8">
            {% embed '_components/_card.html.twig' with {class: 'mb-4'} %}
                {% block card_header %}
                    <div class="card-header d-flex justify-content-between"><h2 class="mb-0">{{ objective.title }}</h2>
                        {% include '_components/_badge.html.twig' with { variant: objective.status == 'achieved' ? 'success' : 'info', class: 'fs-6', content: ('objective.status.' ~ objective.status)|trans({}, 'objective') } %}
                    </div>
                {% endblock %}
                {% block card_body %}
    {% import '_components/_fa_progress.html.twig' as _fa_progress %}
                    {% import '_components/_fa_alert.html.twig' as _fa_alert %}
                    <p class="lead">{{ objective.description }}</p>

                    <div class="row mb-3">
                        <div class="col-md-6"><div class="fw-semibold text-muted small text-uppercase mb-2">{{ 'objective.field.category'|trans({}, 'objective') }}</div><p>{{ objective.category }}</p></div>
                        <div class="col-md-6"><div class="fw-semibold text-muted small text-uppercase mb-2">{{ 'objective.field.responsible_person'|trans({}, 'objective') }}</div><p>{{ objective.responsiblePerson }}</p></div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6"><div class="fw-semibold text-muted small text-uppercase mb-2">{{ 'objective.field.target_date'|trans({}, 'objective') }}</div><p>{{ objective.targetDate|date('d.m.Y') }}</p></div>
                        <div class="col-md-6"><div class="fw-semibold text-muted small text-uppercase mb-2">{{ 'objective.field.achieved_date'|trans({}, 'objective') }}</div><p>{{ objective.achievedDate ? objective.achievedDate|date('d.m.Y') : '-' }}</p></div>
                    </div>

                    {% if objective.measurableIndicators %}
                    <div class="fw-semibold text-muted small text-uppercase mb-2">{{ 'objective.field.measurable_indicators'|trans({}, 'objective') }}</div>
                    <p>{{ objective.measurableIndicators|nl2br }}</p>
                    {% endif %}

                    <div class="fw-semibold text-muted small text-uppercase mb-2">{{ 'objective.table.progress'|trans({}, 'objective') }}</div>
                    {{ _fa_progress.render({ value: objective.progressPercentage, tone: objective.progressPercentage >= 75 ? 'success' : (objective.progressPercentage >= 50 ? 'warning' : 'danger'), showText: true, class: 'mb-2' }) }}
                    <p><strong>{{ 'objective.label.current'|trans({}, 'objective') }}:</strong> {{ objective.currentValue }} {{ objective.unit }} / <strong>{{ 'objective.label.target'|trans({}, 'objective') }}:</strong> {{ objective.targetValue }} {{ objective.unit }}</p>

                    {% if objective.progressNotes %}
                    <div class="fw-semibold text-muted small text-uppercase mb-2 mt-3">{{ 'objective.field.progress_notes'|trans({}, 'objective') }}</div>
                    {{ _fa_alert.render({ variant: 'info', body: objective.progressNotes|nl2br }) }}
                    {% endif %}
                {% endblock %}
            {% endembed %}
        </div>

        <div class="col-lg-4">
            {% embed '_components/_card.html.twig' with {class: 'mb-4'} %}
                {% block card_header %}
                    <div class="card-header bg-body-secondary"><h2 class="mb-0">{{ 'common.actions'|trans({}, 'messages') }}</h2></div>
                {% endblock %}
                {% block card_body %}
                    <div class="d-grid gap-2">
                        {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_objective_edit', {id: objective.id}) }}" class="fa-cyber-btn fa-cyber-btn--primary"><i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i> {{ 'common.edit'|trans({}, 'messages') }}</a>
                        {% endif %}
                        <a href="{{ path('app_objective_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">{{ 'common.back_to_list'|trans({}, 'messages') }}</a>
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header bg-body-secondary"><h2 class="mb-0">{{ 'common.metadata'|trans({}, 'messages') }}</h2></div>
                {% endblock %}
                {% block card_body %}
                    <dl class="row mb-0 small">
                        <dt class="col-sm-5">{{ 'common.created_at'|trans({}, 'messages') }}</dt><dd class="col-sm-7">{{ objective.createdAt|date('d.m.Y H:i') }}</dd>
                        <dt class="col-sm-5">{{ 'common.updated_at'|trans({}, 'messages') }}</dt><dd class="col-sm-7">{{ objective.updatedAt ? objective.updatedAt|date('d.m.Y H:i') : '-' }}</dd>
                        <dt class="col-sm-5">{{ 'common.id'|trans({}, 'messages') }}</dt><dd class="col-sm-7"><code>{{ objective.id }}</code></dd>
                    </dl>
                {% endblock %}
            {% endembed %}
        </div>
    </div>
</div>
{% endblock %}
