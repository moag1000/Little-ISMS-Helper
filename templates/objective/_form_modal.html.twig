{# ISMSObjective create/edit rendered inside the fa-form-modal Turbo Frame.
   Explicit form action (the document URL stays on the list). On valid submit the
   controller returns a Turbo Stream (row replace/append). #}
{% trans_default_domain 'objective' %}
{% set is_edit = objective is defined and objective and objective.id is not null %}
{% set form_action = is_edit ? path('app_objective_edit', { id: objective.id }) : path('app_objective_new') %}
<turbo-frame id="fa-form-modal">
    {{ form_start(form, { action: form_action, method: 'POST', attr: {
        id: 'objective-modal-form',
        'data-turbo-frame': 'fa-form-modal'
    } }) }}
    {% include 'objective/_form_body.html.twig' with {
        form: form,
        modal: true,
        title: is_edit ? objective.title : 'objective.title.new'|trans({}, 'objective'),
        actions: {
            close: { label: 'common.cancel'|trans({}, 'messages'), variant: 'ghost', action: 'fa-form-modal#close' },
            submit: { label: 'common.save'|trans({}, 'messages'), variant: 'primary' }
        }
    } %}
    {{ form_end(form) }}
</turbo-frame>
