{% extends 'base.html.twig' %}
{% trans_default_domain 'privacy' %}

{% block title %}{{ 'privacy.data_breach.management'|trans({}, 'privacy') }}{% endblock %}

{% block body %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
<div class="container-fluid mt-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'privacy.breadcrumb.privacy'|trans({}, 'privacy'), icon: 'bi-shield-lock' },
            { label: 'privacy.breadcrumb.data_breaches'|trans({}, 'privacy') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'exclamation-triangle-fill', label: 'privacy.data_breach.management'|trans({}, 'privacy') },
        title: 'privacy.data_breach.management'|trans({}, 'privacy'),
        subtitle: 'privacy.data_breach.subtitle'|trans({}, 'privacy'),
        actions: [
            { label: 'privacy.data_breach.actions.dashboard'|trans({}, 'privacy'), href: path('app_data_breach_dashboard'), variant: 'ghost', icon: 'speedometer2' },
            { label: 'privacy.data_breach.actions.new'|trans({}, 'privacy'), href: path('app_data_breach_new'), variant: 'danger', icon: 'plus-lg' }
        ]
    }) }}
    <main class="fa-aurora-surface">

    {# CRITICAL: Overdue Notifications Alert #}
    {% if compliance_score.overdue_notifications > 0 %}
        {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'danger', dismissible: true } } %}
            {% block alert_body %}
                <div class="fa-alert__title">{{ 'privacy.data_breach.alert.overdue_title'|trans({}, 'privacy') }}</div>
                <p class="fa-alert__message">{{ 'privacy.data_breach.alert.overdue_text'|trans({'%count%': compliance_score.overdue_notifications}, 'privacy')|raw }}</p>
                <hr>
                <p class="mb-0">
                    <a href="{{ path('app_data_breach_index', {filter: 'overdue'}) }}" class="fa-alert__link">
                        {{ 'privacy.data_breach.alert.view_overdue'|trans({}, 'privacy') }}
                    </a>
                </p>
            {% endblock %}
        {% endembed %}
    {% endif %}

    {# Overall Compliance Score #}
    {% embed '_components/_card.html.twig' with {class: 'mb-4 text-center'} %}
        {% block card_body %}
            <div class="small fw-semibold text-muted mb-2">{{ 'privacy.data_breach.score.heading'|trans({}, 'privacy') }}</div>
            {% set score = compliance_score.overall_score %}
            <h1 class="display-1 mb-0
                {% if score >= 80 %}text-success
                {% elseif score >= 60 %}text-warning
                {% else %}text-danger{% endif %}">
                {{ score }}%
            </h1>
            <div class="row mt-4">
                <div class="col-md-4">
                    <small class="text-muted">{{ 'privacy.data_breach.score.notification_compliance'|trans({}, 'privacy') }}</small>
                    <h4>{{ compliance_score.notification_compliance }}%</h4>
                </div>
                <div class="col-md-4">
                    <small class="text-muted">{{ 'privacy.data_breach.score.timeliness'|trans({}, 'privacy') }}</small>
                    <h4 class="{% if compliance_score.timeliness_score < 80 %}text-danger{% else %}text-success{% endif %}">
                        {{ compliance_score.timeliness_score }}%
                    </h4>
                </div>
                <div class="col-md-4">
                    <small class="text-muted">{{ 'privacy.data_breach.score.completeness'|trans({}, 'privacy') }}</small>
                    <h4>{{ compliance_score.completeness_score }}%</h4>
                </div>
            </div>
            <p class="text-muted mt-3">
                {{ 'privacy.data_breach.score.summary'|trans({'%total%': statistics.total, '%subjects%': compliance_score.total_affected_subjects}, 'privacy') }}
            </p>
        {% endblock %}
    {% endembed %}

    {# Key Metrics #}
    <div class="row mb-4">
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' %}
                {% block card_body %}
                    <div class="text-muted small">{{ 'privacy.data_breach.kpi.total_breaches'|trans({}, 'privacy') }}</div>
                    <div class="fs-2 fw-bold">{{ statistics.total }}</div>
                    <div class="mt-2">
                        <small class="text-danger"><i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> {{ statistics.high_risk + statistics.critical_risk }} {{ 'privacy.data_breach.kpi.high_critical_risk'|trans({}, 'privacy') }}</small>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' with {variant: 'bordered', borderColor: 'warning'} %}
                {% block card_body %}
                    <div class="text-muted small">{{ 'privacy.data_breach.kpi.pending_authority'|trans({}, 'privacy') }}</div>
                    <div class="fs-2 fw-bold text-warning">{{ statistics.requires_authority_notification - statistics.authority_notified }}</div>
                    <div class="mt-2">
                        <small class="text-muted"><i class="bi bi-clock" aria-hidden="true"></i> {{ 'privacy.data_breach.kpi.deadline_72h'|trans({}, 'privacy') }}</small>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' %}
                {% block card_body %}
                    <div class="text-muted small">{{ 'privacy.data_breach.kpi.special_categories'|trans({}, 'privacy') }}</div>
                    <div class="fs-2 fw-bold text-info">{{ statistics.special_categories_affected }}</div>
                    <div class="mt-2">
                        <small class="text-muted"><i class="fa-icon fa-icon--control" aria-hidden="true"></i> {{ 'privacy.data_breach.kpi.art9_data'|trans({}, 'privacy') }}</small>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' %}
                {% block card_body %}
                    <div class="text-muted small">{{ 'privacy.data_breach.kpi.affected_subjects'|trans({}, 'privacy') }}</div>
                    <div class="fs-2 fw-bold">{{ compliance_score.total_affected_subjects }}</div>
                    <div class="mt-2">
                        <small class="text-muted"><i class="fa-icon fa-icon--group" aria-hidden="true"></i> {{ 'privacy.data_breach.kpi.total_count'|trans({}, 'privacy') }}</small>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    {# Filters #}
    {% embed '_components/_card.html.twig' with {class: 'mb-4'} %}
        {% block card_header %}
            <div class="card-header"><h2 class="mb-0"><i class="bi bi-filter" aria-hidden="true"></i> {{ 'privacy.data_breach.filter.title'|trans({}, 'privacy') }}</h2></div>
        {% endblock %}
        {% block card_body %}
            <div class="btn-group flex-wrap" role="group">
                <a href="{{ path('app_data_breach_index') }}"
                   class="fa-cyber-btn fa-cyber-btn--ghost {{ current_filter == 'all' ? 'active' : '' }}">
                    {{ 'privacy.data_breach.filter.all'|trans({'%count%': statistics.total}, 'privacy') }}
                </a>
                <a href="{{ path('app_data_breach_index', {filter: 'overdue'}) }}"
                   class="fa-cyber-btn fa-cyber-btn--danger {{ current_filter == 'overdue' ? 'active' : '' }}">
                    {{ 'privacy.data_breach.filter.overdue'|trans({'%count%': compliance_score.overdue_notifications}, 'privacy') }}
                </a>
                <a href="{{ path('app_data_breach_index', {filter: 'pending_authority'}) }}"
                   class="fa-cyber-btn fa-cyber-btn--warning {{ current_filter == 'pending_authority' ? 'active' : '' }}">
                    {{ 'privacy.data_breach.filter.pending_authority'|trans({}, 'privacy') }}
                </a>
                <a href="{{ path('app_data_breach_index', {filter: 'pending_subjects'}) }}"
                   class="fa-cyber-btn fa-cyber-btn--warning {{ current_filter == 'pending_subjects' ? 'active' : '' }}">
                    {{ 'privacy.data_breach.filter.pending_subjects'|trans({}, 'privacy') }}
                </a>
                <a href="{{ path('app_data_breach_index', {filter: 'draft'}) }}"
                   class="fa-cyber-btn fa-cyber-btn--ghost {{ current_filter == 'draft' ? 'active' : '' }}">
                    {{ 'privacy.data_breach.filter.draft'|trans({'%count%': statistics.draft}, 'privacy') }}
                </a>
                <a href="{{ path('app_data_breach_index', {filter: 'under_assessment'}) }}"
                   class="fa-cyber-btn fa-cyber-btn--ghost {{ current_filter == 'under_assessment' ? 'active' : '' }}">
                    {{ 'privacy.data_breach.filter.under_assessment'|trans({'%count%': statistics.under_assessment}, 'privacy') }}
                </a>
                <a href="{{ path('app_data_breach_index', {filter: 'authority_notified'}) }}"
                   class="fa-cyber-btn fa-cyber-btn--success {{ current_filter == 'authority_notified' ? 'active' : '' }}">
                    {{ 'privacy.data_breach.filter.authority_notified'|trans({'%count%': statistics.authority_notified}, 'privacy') }}
                </a>
                <a href="{{ path('app_data_breach_index', {filter: 'closed'}) }}"
                   class="fa-cyber-btn fa-cyber-btn--ghost {{ current_filter == 'closed' ? 'active' : '' }}">
                    {{ 'privacy.data_breach.filter.closed'|trans({'%count%': statistics.closed}, 'privacy') }}
                </a>
            </div>
        {% endblock %}
    {% endembed %}

    {# Breaches Table #}
    {% embed '_components/_card.html.twig' with {noPadding: true} %}
        {% block card_header %}
            <div class="card-header"><h2 class="mb-0"><i class="bi bi-list-check" aria-hidden="true"></i> {{ 'privacy.data_breach.table.heading'|trans({'%count%': breaches|length}, 'privacy') }}</h2></div>
        {% endblock %}
        {% block card_body %}
            {% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
            {% if breaches|length > 0 %}
                {% embed '_components/_table.html.twig' with {
                    'noMargin': true
                } %}
                    {% block table_head %}
                        <tr>
                            <th scope="col">{{ 'privacy.data_breach.table.reference'|trans({}, 'privacy') }}</th>
                            <th scope="col">{{ 'privacy.data_breach.table.title'|trans({}, 'privacy') }}</th>
                            <th scope="col">{{ 'privacy.data_breach.table.status'|trans({}, 'privacy') }}</th>
                            <th scope="col">{{ 'privacy.data_breach.table.risk'|trans({}, 'privacy') }}</th>
                            <th scope="col">{{ 'privacy.data_breach.table.affected_subjects'|trans({}, 'privacy') }}</th>
                            <th scope="col">{{ 'privacy.data_breach.table.deadline_72h'|trans({}, 'privacy') }}</th>
                            <th scope="col">{{ 'privacy.data_breach.table.authority'|trans({}, 'privacy') }}</th>
                            <th scope="col">{{ 'privacy.data_breach.table.subjects'|trans({}, 'privacy') }}</th>
                            <th scope="col">{{ 'common.actions'|trans({}, 'messages') }}</th>
                        </tr>
                    {% endblock %}
                    {% block table_body %}
                        {% for breach in breaches %}
                            <tr class="{% if breach.isAuthorityNotificationOverdue %}table-danger{% endif %}">
                                <td>
                                    <a href="{{ path('app_data_breach_show', {id: breach.id}) }}">
                                        {{ breach.referenceNumber }}
                                    </a>
                                </td>
                                <td>{{ breach.title }}</td>
                                <td>
                                    {% set status_class = {
                                        'draft': 'secondary',
                                        'under_assessment': 'info',
                                        'authority_notified': 'success',
                                        'subjects_notified': 'success',
                                        'closed': 'dark'
                                    }[breach.status] %}
                                    {% include '_components/_badge.html.twig' with { variant: status_class, content: breach.status|replace({'_': ' '})|upper } %}
                                </td>
                                <td>
                                    {% if breach.riskLevel %}
                                        {% set risk_class = {
                                            'low': 'success',
                                            'medium': 'info',
                                            'high': 'warning',
                                            'critical': 'danger'
                                        }[breach.riskLevel] %}
                                        {% include '_components/_badge.html.twig' with { variant: risk_class, content: breach.riskLevel|upper } %}
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if breach.affectedDataSubjects %}
                                        {{ breach.affectedDataSubjects|number_format }}
                                    {% else %}
                                        <span class="text-muted">{{ 'privacy.data_breach.table.unknown'|trans({}, 'privacy') }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if breach.requiresAuthorityNotification and not breach.supervisoryAuthorityNotifiedAt %}
                                        {% set hours = breach.hoursUntilAuthorityDeadline %}
                                        {% if hours < 0 %}
                                            {% include '_components/_badge.html.twig' with { variant: 'danger', content: 'OVERDUE ' ~ (hours * -1)|number_format ~ 'h' } %}
                                        {% elseif hours < 24 %}
                                            {% include '_components/_badge.html.twig' with { variant: 'warning', content: hours|number_format ~ 'h left' } %}
                                        {% else %}
                                            {% include '_components/_badge.html.twig' with { variant: 'info', content: hours|number_format ~ 'h left' } %}
                                        {% endif %}
                                    {% elseif breach.supervisoryAuthorityNotifiedAt %}
                                        <i class="fa-icon fa-icon--status-ok" aria-hidden="true" title="{{ 'data_breach.notified_at'|trans({'%date%': breach.supervisoryAuthorityNotifiedAt|date('Y-m-d H:i')}, 'privacy') }}"></i>
                                    {% else %}
                                        <span class="text-muted">{{ 'data_breach.not_required'|trans({}, 'privacy') }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if breach.supervisoryAuthorityNotifiedAt %}
                                        <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
                                    {% elseif breach.requiresAuthorityNotification %}
                                        <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i>
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if breach.dataSubjectsNotifiedAt %}
                                        <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
                                    {% elseif breach.requiresSubjectNotification %}
                                        <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i>
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group" aria-label="{{ 'common.actions'|trans({}, 'messages') }}">
                                        <a href="{{ path('app_data_breach_show', {id: breach.id}) }}"
                                           class="fa-cyber-btn fa-cyber-btn--ghost"
                                           title="{{ 'common.view'|trans({}, 'messages') }}" aria-label="{{ 'common.view'|trans({}, 'messages') }}">
                                            <i class="bi bi-eye" aria-hidden="true"></i>
                                        </a>
                                        {% if breach.status in ['draft', 'under_assessment'] %}
                                            <a href="{{ path('app_data_breach_edit', {id: breach.id}) }}"
                                               class="fa-cyber-btn fa-cyber-btn--ghost"
                                               title="{{ 'common.edit'|trans({}, 'messages') }}" aria-label="{{ 'common.edit'|trans({}, 'messages') }}">
                                                <i class="bi bi-pencil" aria-hidden="true"></i>
                                            </a>
                                        {% endif %}
                                        <a href="{{ path('app_data_breach_export_pdf', {id: breach.id}) }}"
                                           class="fa-cyber-btn fa-cyber-btn--success"
                                           title="{{ 'common.export_pdf'|trans({}, 'messages') }}" aria-label="{{ 'common.export_pdf'|trans({}, 'messages') }}">
                                            <i class="bi bi-file-pdf" aria-hidden="true"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            {% else %}
                {{ _fa_empty_state.render({
                    mood: current_filter != 'all' ? 'curious' : 'celebrating',
                    title: 'data_breach.index.no_breaches_found'|trans({}, 'privacy'),
                    actions: current_filter != 'all' ? [
                        { label: 'data_breach.index.view_all_breaches'|trans({}, 'privacy'), variant: 'ghost', icon: 'list', href: path('app_data_breach_index') }
                    ] : []
                }) }}
            {% endif %}
        {% endblock %}
    {% endembed %}
    </main>
</div>
{% endblock %}
