{% extends 'base.html.twig' %}
{% trans_default_domain 'privacy' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_modal_wizard.html.twig' as _fa_modal_wizard %}

{% block title %}{{ 'privacy.data_breach.page.new_title'|trans({}, 'privacy') }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'privacy.breadcrumb.privacy'|trans({}, 'privacy'), icon: 'nav-shield-lock' },
            { label: 'privacy.breadcrumb.data_breaches'|trans({}, 'privacy'), url: path('app_data_breach_index') },
            { label: 'privacy.data_breach.page.new_title'|trans({}, 'privacy') }
        ]
    } %}

    {{ _fa_page_header.render({
        title: 'privacy.data_breach.page.new_title'|trans({}, 'privacy'),
        subtitle: 'privacy.data_breach.page.new_subtitle'|trans({}, 'privacy'),
        badge: { icon: 'status-warning', label: '' },
        actions: [
            { label: 'common.cancel'|trans({}, 'messages'), href: path('app_data_breach_index'), variant: 'secondary', icon: 'ui-close' }
        ]
    }) }}

    {# fa-modal--wizard wraps the entire Symfony form so POST submission works as-is.
       The Stimulus modal-wizard controller enforces per-step HTML5 validation before
       advancing. The final submit button on step 4 submits the whole form. #}
    {{ form_start(form, { attr: { class: 'fa-aurora-surface' } }) }}

        {{ _fa_modal_wizard.render({
            id: 'gdpr-breach-wizard',
            title: 'data_breach.wizard.new_title'|trans({}, 'privacy'),
            subtitle: 'data_breach.wizard.new_subtitle'|trans({}, 'privacy'),
            steps: [
                {
                    id: 'detection',
                    label: 'data_breach.wizard.step.detection'|trans({}, 'privacy'),
                    title: 'data_breach.wizard.step.detection_title'|trans({}, 'privacy'),
                    required: true,
                    body: include('data_breach/wizard/_step_detection.html.twig', { form: form })
                },
                {
                    id: 'notification',
                    label: 'data_breach.wizard.step.notification'|trans({}, 'privacy'),
                    title: 'data_breach.wizard.step.notification_title'|trans({}, 'privacy'),
                    required: true,
                    body: include('data_breach/wizard/_step_notification.html.twig', { form: form })
                },
                {
                    id: 'record',
                    label: 'data_breach.wizard.step.record'|trans({}, 'privacy'),
                    title: 'data_breach.wizard.step.record_title'|trans({}, 'privacy'),
                    required: true,
                    body: include('data_breach/wizard/_step_record.html.twig', { form: form })
                },
                {
                    id: 'review',
                    label: 'data_breach.wizard.step.review'|trans({}, 'privacy'),
                    title: 'data_breach.wizard.step.review_title'|trans({}, 'privacy'),
                    required: false,
                    body: include('data_breach/wizard/_step_review.html.twig', { form: form, data_breach: null })
                }
            ],
            actions: {
                cancel: { label: 'common.cancel'|trans({}, 'messages'), route: path('app_data_breach_index') },
                submit: { label: 'data_breach.wizard.action.submit'|trans({}, 'privacy'), variant: 'danger' }
            }
        }) }}

    {{ form_end(form) }}
</div>
{% endblock %}
