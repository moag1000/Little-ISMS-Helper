{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block title %}{{ 'data_breach.dashboard.title'|trans({}, 'privacy') }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'data_breach.dashboard.breadcrumb.privacy'|trans({}, 'privacy'), icon: 'nav-shield-lock' },
            { label: 'data_breach.dashboard.breadcrumb.data_breaches'|trans({}, 'privacy'), url: path('app_data_breach_index') },
            { label: 'data_breach.dashboard.breadcrumb.dashboard'|trans({}, 'privacy') }
        ]
    } %}

    {% include '_components/_page_header.html.twig' with {
        title: 'data_breach.dashboard.title'|trans({}, 'privacy'),
        subtitle: 'data_breach.dashboard.subtitle'|trans({}, 'privacy'),
        icon: 'nav-dashboard',
        actions: [
            { label: 'data_breach.dashboard.action.view_all'|trans({}, 'privacy'), url: path('app_data_breach_index'), variant: 'primary', icon: 'ui-list' },
            { label: 'data_breach.dashboard.action.new'|trans({}, 'privacy'), url: path('app_data_breach_new'), variant: 'danger', icon: 'plus' }
        ]
    } %}

    {# Overall Compliance Score #}
    {% embed '_components/_card.html.twig' with {class: 'mb-4 text-center'} %}
        {% block card_body %}
            <div class="small fw-semibold text-muted mb-2">{{ 'data_breach.dashboard.overall_score'|trans({}, 'privacy') }}</div>
            {% set score = compliance_score.overall_score %}
            <h1 class="display-1 mb-0
                {% if score >= 80 %}text-success
                {% elseif score >= 60 %}text-warning
                {% else %}text-danger{% endif %}">
                {{ score }}%
            </h1>
            <div class="row mt-4">
                <div class="col-md-4">
                    <small class="text-muted">{{ 'data_breach.dashboard.kpi.notification_compliance'|trans({}, 'privacy') }}</small>
                    <h4>{{ compliance_score.notification_compliance }}%</h4>
                    <small class="text-muted">{{ 'data_breach.dashboard.kpi.notified'|trans({'%done%': statistics.authority_notified, '%total%': statistics.requires_authority_notification}, 'privacy') }}</small>
                </div>
                <div class="col-md-4">
                    <small class="text-muted">{{ 'data_breach.dashboard.kpi.timeliness'|trans({}, 'privacy') }}</small>
                    <h4 class="{% if compliance_score.timeliness_score < 80 %}text-danger{% else %}text-success{% endif %}">
                        {{ compliance_score.timeliness_score }}%
                    </h4>
                    <small class="text-muted">{{ 'data_breach.dashboard.kpi.overdue_notifications'|trans({'%count%': compliance_score.overdue_notifications}, 'privacy') }}</small>
                </div>
                <div class="col-md-4">
                    <small class="text-muted">{{ 'data_breach.dashboard.kpi.completeness'|trans({}, 'privacy') }}</small>
                    <h4>{{ compliance_score.completeness_score }}%</h4>
                    <small class="text-muted">{{ 'data_breach.dashboard.kpi.avg_completeness'|trans({}, 'privacy') }}</small>
                </div>
            </div>
            <p class="text-muted mt-3">
                {{ 'data_breach.dashboard.kpi.total_breaches'|trans({'%count%': statistics.total}, 'privacy') }} ·
                {{ 'data_breach.dashboard.kpi.affected_subjects'|trans({'%count%': compliance_score.total_affected_subjects|number_format}, 'privacy') }}
            </p>
        {% endblock %}
    {% endembed %}

    {# CRITICAL: Action Items #}
    {% if action_items|length > 0 %}
        {% embed '_components/_card.html.twig' with {class: 'mb-4'} %}
            {% block card_header %}
                <div class="card-header"><h2 class="mb-0"><i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> {{ 'data_breach.dashboard.action_items'|trans({}, 'privacy') }}</h2></div>
            {% endblock %}
            {% block card_body %}
                <div class="list-group">
                    {% for item in action_items %}
                        <a href="{{ path('app_data_breach_show', {id: item.breach_id}) }}"
                           class="list-group-item list-group-item-action
                           {% if item.priority == 'critical' %}list-group-item-danger
                           {% elseif item.priority == 'high' %}list-group-item-warning
                           {% elseif item.priority == 'medium' %}list-group-item-info
                           {% endif %}">
                            <div class="d-flex w-100 justify-content-between">
                                <div class="fw-bold mb-1">
                                    {% if item.priority == 'critical' %}
                                        <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i>
                                    {% elseif item.priority == 'high' %}
                                        <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i>
                                    {% elseif item.priority == 'medium' %}
                                        <i class="fa-icon fa-icon--ui-info text-info" aria-hidden="true"></i>
                                    {% else %}
                                        <i class="fa-icon text-secondary fa-icon--status-pending" aria-hidden="true"></i>
                                    {% endif %}
                                    {{ item.title }}
                                </div>
                                <small>{{ item.reference_number }}</small>
                            </div>
                            <p class="mb-1">
                                {% if item.type == 'overdue_authority_notification' %}
                                    {% include '_components/_badge.html.twig' with { variant: 'danger', content: ('data_breach.dashboard.badge.overdue'|trans({}, 'privacy')) } %}
                                    {{ 'data_breach.dashboard.action_msg.overdue_authority'|trans({'%hours%': item.hours_overdue|number_format}, 'privacy') }}
                                {% elseif item.type == 'pending_authority_notification' %}
                                    {% include '_components/_badge.html.twig' with { variant: 'warning', content: ('data_breach.dashboard.badge.urgent'|trans({}, 'privacy')) } %}
                                    {{ 'data_breach.dashboard.action_msg.pending_authority'|trans({'%hours%': item.hours_remaining|number_format}, 'privacy') }}
                                {% elseif item.type == 'pending_subject_notification' %}
                                    {% include '_components/_badge.html.twig' with { variant: 'info', content: ('data_breach.dashboard.badge.pending'|trans({}, 'privacy')) } %}
                                    {{ 'data_breach.dashboard.action_msg.pending_subject'|trans({}, 'privacy') }}
                                {% elseif item.type == 'incomplete' %}
                                    {% include '_components/_badge.html.twig' with { variant: 'secondary', content: item.completeness ~ '%' } %}
                                    {{ 'data_breach.dashboard.action_msg.incomplete'|trans({}, 'privacy') }}
                                {% endif %}
                            </p>
                        </a>
                    {% endfor %}
                </div>
            {% endblock %}
        {% endembed %}
    {% else %}
        {{ _fa_alert.render({ variant: 'success', body: 'data_breach.dashboard.empty_state'|trans({}, 'privacy') }) }}
    {% endif %}

    {# Statistics by Status #}
    <div class="row mb-4">
        <div class="col-md-12">
            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header"><h2 class="mb-0"><i class="fa-icon fa-icon--nav-bar-chart" aria-hidden="true"></i> {{ 'data_breach.dashboard.stats_status_title'|trans({}, 'privacy') }}</h2></div>
                {% endblock %}
                {% block card_body %}
                    <div class="row">
                        <div class="col-md-2">
                            <div class="text-muted small">{{ 'data_breach.dashboard.status.draft'|trans({}, 'privacy') }}</div>
                            <div class="h2">{{ statistics.draft }}</div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-muted small">{{ 'data_breach.dashboard.under_assessment'|trans({}, 'privacy') }}</div>
                            <div class="h3">{{ statistics.under_assessment }}</div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-muted small">{{ 'data_breach.stats.authority_notified'|trans({}, 'privacy') }}</div>
                            <div class="h3 text-success">{{ statistics.authority_notified }}</div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-muted small">{{ 'data_breach.stats.subjects_notified'|trans({}, 'privacy') }}</div>
                            <div class="h3 text-success">{{ statistics.subjects_notified }}</div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-muted small">{{ 'data_breach.stats.closed'|trans({}, 'privacy') }}</div>
                            <div class="h3">{{ statistics.closed }}</div>
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    {# Statistics by Risk Level #}
    <div class="row mb-4">
        <div class="col-md-6">
            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header"><h2 class="mb-0"><i class="fa-icon fa-icon--breach" aria-hidden="true"></i> {{ 'data_breach.dashboard.risk_section_title'|trans({}, 'privacy') }}</h2></div>
                {% endblock %}
                {% block card_body %}
                    <div class="row text-center">
                        <div class="col-3">
                            <div class="text-muted small">{{ 'data_breach.dashboard.risk_level.low'|trans({}, 'privacy') }}</div>
                            <div class="h3 text-success">{{ statistics.low_risk }}</div>
                        </div>
                        <div class="col-3">
                            <div class="text-muted small">{{ 'data_breach.dashboard.risk_level.medium'|trans({}, 'privacy') }}</div>
                            <div class="h3 text-info">{{ statistics.medium_risk }}</div>
                        </div>
                        <div class="col-3">
                            <div class="text-muted small">{{ 'data_breach.dashboard.risk_level.high'|trans({}, 'privacy') }}</div>
                            <div class="h3 text-warning">{{ statistics.high_risk }}</div>
                        </div>
                        <div class="col-3">
                            <div class="text-muted small">{{ 'data_breach.dashboard.risk_level.critical'|trans({}, 'privacy') }}</div>
                            <div class="h3 text-danger">{{ statistics.critical_risk }}</div>
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>

        <div class="col-md-6">
            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header"><h2 class="mb-0"><i class="fa-icon fa-icon--control" aria-hidden="true"></i> {{ 'data_breach.dashboard.special_categories_title'|trans({}, 'privacy') }}</h2></div>
                {% endblock %}
                {% block card_body %}
                    <p><strong>{{ 'data_breach.dashboard.special_categories_label'|trans({}, 'privacy') }}</strong></p>
                    <h2 class="text-info">{{ statistics.special_categories_affected }}</h2>
                    <small class="text-muted">
                        {{ 'data_breach.dashboard.special_categories_help'|trans({}, 'privacy') }}
                    </small>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    {# Recent Breaches #}
    {% if recent_breaches|length > 0 %}
        {% embed '_components/_card.html.twig' with {class: 'mb-4', noPadding: true} %}
            {% block card_header %}
                <div class="card-header"><h2 class="mb-0"><i class="fa-icon fa-icon--nav-calendar-check" aria-hidden="true"></i> {{ 'data_breach.dashboard.recent_title'|trans({}, 'privacy') }}</h2></div>
            {% endblock %}
            {% block card_body %}
                {% embed '_components/_table.html.twig' with {
                    'class': 'table-hover mb-0',
                    'noMargin': true,
                    'responsive': true
                } %}
                    {% block table_head %}
                        <tr>
                            <th scope="col">{{ 'data_breach.dashboard.col.reference'|trans({}, 'privacy') }}</th>
                            <th scope="col">{{ 'data_breach.dashboard.col.title'|trans({}, 'privacy') }}</th>
                            <th scope="col">{{ 'data_breach.dashboard.col.detected'|trans({}, 'privacy') }}</th>
                            <th scope="col">{{ 'data_breach.dashboard.col.status'|trans({}, 'privacy') }}</th>
                            <th scope="col">{{ 'data_breach.dashboard.col.risk'|trans({}, 'privacy') }}</th>
                            <th scope="col">{{ 'data_breach.dashboard.col.affected_subjects'|trans({}, 'privacy') }}</th>
                        </tr>
                    {% endblock %}
                    {% block table_body %}
                        {% for breach in recent_breaches|slice(0, 10) %}
                            <tr>
                                <td>
                                    <a href="{{ path('app_data_breach_show', {id: breach.id}) }}">
                                        {{ breach.referenceNumber }}
                                    </a>
                                </td>
                                <td>{{ breach.title }}</td>
                                <td>{{ breach.detectedAt|date('Y-m-d H:i') }}</td>
                                <td>
                                    {% set status_class = {
                                        'draft': 'secondary',
                                        'under_assessment': 'info',
                                        'authority_notified': 'success',
                                        'subjects_notified': 'success',
                                        'closed': 'dark'
                                    }[breach.status] %}
                                    {% include '_components/_badge.html.twig' with { variant: status_class, content: breach.status|replace({'_': ' '})|upper } %}
                                </td>
                                <td>
                                    {% if breach.riskLevel %}
                                        {% set risk_class = {'low': 'success', 'medium': 'info', 'high': 'warning', 'critical': 'danger'}[breach.riskLevel] %}
                                        {% include '_components/_badge.html.twig' with { variant: risk_class, content: breach.riskLevel|upper } %}
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td>{{ breach.affectedDataSubjects|default('-')|number_format }}</td>
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            {% endblock %}
        {% endembed %}
    {% endif %}
</div>
{% endblock %}
