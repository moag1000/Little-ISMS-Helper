{% extends 'base.html.twig' %}
{% trans_default_domain 'privacy' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% block title %}{{ 'dpia.new.title'|trans({}, 'privacy')}}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'dpia.new.breadcrumb_gdpr'|trans({}, 'privacy'), icon: 'shield-check' },
            { label: 'dpia.new.breadcrumb_dpia'|trans({}, 'privacy'), url: path('app_dpia_index') },
            { label: 'dpia.new.breadcrumb_new'|trans({}, 'privacy') }
        ]
    } %}

    {{ _fa_page_header.render({
        title: 'dpia.new.page_title'|trans({}, 'privacy'),
        subtitle: 'dpia.new.page_subtitle'|trans({}, 'privacy'),
        badge: { icon: 'plus', label: '' },
        actions: [
            { label: 'dpia.new.button_cancel'|trans({}, 'privacy'), href: path('app_dpia_index'), variant: 'secondary', icon: 'ui-close' }
        ]
    }) }}

    {# ── F31 Sectoral DPIA Template Picker ─────────────────────────────────── #}
    {% if is_module_active('privacy') and sector_templates is defined and sector_templates is not empty %}
    <div class="mb-4">
        {% if applied_template_key is defined and applied_template_key %}
        {# Compact "template active" banner with reset link #}
        <div class="alert alert-info d-flex align-items-center gap-2 mb-3" role="status">
            <i data-lucide="check-circle" class="text-info flex-shrink-0" aria-hidden="true"></i>
            <span>
                <strong>{{ 'dpia.template.picker.selected'|trans({}, 'privacy') }}</strong>
                {% for tpl in sector_templates %}
                    {% if tpl.key == applied_template_key %}
                        &mdash; {{ tpl.nameTransKey|trans({}, 'privacy') }}
                    {% endif %}
                {% endfor %}
            </span>
            <a href="{{ path('app_dpia_new', {_locale: app.request.locale}) }}" class="ms-auto btn btn-sm btn-outline-secondary">
                {{ 'dpia.template.picker.skip'|trans({}, 'privacy') }}
            </a>
        </div>
        {% else %}
        {# Full picker card row #}
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h6 class="fw-semibold mb-1">{{ 'dpia.template.picker.title'|trans({}, 'privacy') }}</h6>
                <p class="text-muted small mb-3">{{ 'dpia.template.picker.subtitle'|trans({}, 'privacy') }}</p>
                <div class="row g-3">
                    {% for tpl in sector_templates %}
                    <div class="col-md-4">
                        <a href="{{ path('app_dpia_new', {_locale: app.request.locale, sector_template: tpl.key}) }}"
                           class="card h-100 text-decoration-none border"
                           aria-label="{{ tpl.nameTransKey|trans({}, 'privacy') }}">
                            <div class="card-body d-flex flex-column gap-2">
                                <div class="d-flex align-items-center gap-2">
                                    <i data-lucide="{{ tpl.icon }}" class="text-primary" aria-hidden="true"></i>
                                    <span class="fw-semibold text-body">{{ tpl.nameTransKey|trans({}, 'privacy') }}</span>
                                </div>
                                <p class="text-muted small mb-0 flex-grow-1">{{ tpl.usageHint|trans({}, 'privacy') }}</p>
                                <span class="badge bg-primary-subtle text-primary-emphasis mt-auto">
                                    {% if tpl.key starts with 'healthcare' %}{{ 'dpia.template.picker.norm_badge.healthcare'|trans({}, 'privacy') }}
                                    {% elseif tpl.key starts with 'financial' %}{{ 'dpia.template.picker.norm_badge.financial'|trans({}, 'privacy') }}
                                    {% else %}{{ 'dpia.template.picker.norm_badge.ai_act'|trans({}, 'privacy') }}
                                    {% endif %}
                                </span>
                            </div>
                        </a>
                    </div>
                    {% endfor %}
                </div>
                <div class="mt-3">
                    <a href="{{ path('app_dpia_new', {_locale: app.request.locale}) }}" class="btn btn-sm btn-outline-secondary">
                        {{ 'dpia.template.picker.skip'|trans({}, 'privacy') }}
                    </a>
                </div>
            </div>
        </div>
        {% endif %}
    </div>
    {% endif %}

    {{ form_start(form) }}
    {% include '_components/_auto_form.html.twig' with {
        'form': form,
        'layout': 'outline-rail',
        'eyebrow': 'DSGVO Art. 35 · DPIA',
        'title': 'dpia.new.page_title'|trans({}, 'privacy'),
        'subtitle': 'dpia.new.page_subtitle'|trans({}, 'privacy'),
        'sections': {
            'basic_info': {
                'label': 'dpia.new.section_basic_info'|trans({}, 'privacy'),
                'fields': ['title', 'referenceNumber', 'processingActivity']
            },
            'processing_operations': {
                'label': 'dpia.new.section_processing_operations'|trans({}, 'privacy'),
                'fields': ['processingDescription', 'processingPurposes', 'dataCategories', 'dataSubjectCategories', 'estimatedDataSubjects', 'dataRetentionPeriod', 'dataFlowDescription']
            },
            'necessity_proportionality': {
                'label': 'dpia.new.section_necessity_proportionality'|trans({}, 'privacy'),
                'fields': ['necessityAssessment', 'proportionalityAssessment', 'legalBasis', 'legislativeCompliance']
            },
            'risk_assessment': {
                'label': 'dpia.new.section_risk_assessment'|trans({}, 'privacy'),
                'fields': ['riskLevel', 'likelihood', 'impact', 'dataSubjectRisks']
            },
            'measures': {
                'label': 'dpia.new.section_measures'|trans({}, 'privacy'),
                'fields': ['technicalMeasures', 'organizationalMeasures', 'implementedControls', 'complianceMeasures', 'residualRiskAssessment', 'residualRiskLevel', 'sdmAssessmentSummary']
            },
            'consultation': {
                'label': 'dpia.new.section_consultation'|trans({}, 'privacy'),
                'fields': ['dataProtectionOfficer', 'dataProtectionOfficerPerson', 'dataProtectionOfficerDeputyPersons', 'dpoConsultationDate', 'dpoAdvice', 'dataSubjectsConsulted', 'dataSubjectConsultationDetails']
            },
            'supervisory': {
                'label': 'dpia.new.section_supervisory'|trans({}, 'privacy'),
                'fields': ['requiresSupervisoryConsultation', 'supervisoryConsultationDate', 'supervisoryAuthorityFeedback']
            },
            'workflow': {
                'label': 'dpia.new.section_workflow'|trans({}, 'privacy'),
                'fields': ['conductor', 'conductorPerson', 'conductorDeputyPersons', 'approverPerson', 'approverDeputyPersons', 'reviewFrequencyMonths', 'nextReviewDate']
            }
        },
        'col_widths': {
            'title': 8,
            'referenceNumber': 4,
            'processingActivity': 12,
            'processingDescription': 12,
            'processingPurposes': 12,
            'dataCategories': 12,
            'dataSubjectCategories': 12,
            'estimatedDataSubjects': 6,
            'dataRetentionPeriod': 6,
            'dataFlowDescription': 12,
            'necessityAssessment': 12,
            'proportionalityAssessment': 12,
            'legalBasis': 6,
            'legislativeCompliance': 6,
            'riskLevel': 4,
            'likelihood': 4,
            'impact': 4,
            'dataSubjectRisks': 12,
            'technicalMeasures': 12,
            'organizationalMeasures': 12,
            'implementedControls': 12,
            'complianceMeasures': 12,
            'residualRiskAssessment': 6,
            'residualRiskLevel': 6,
            'sdmAssessmentSummary': 12,
            'dataProtectionOfficer': 6,
            'dataProtectionOfficerPerson': 6,
            'dataProtectionOfficerDeputyPersons': 12,
            'dpoConsultationDate': 6,
            'dpoAdvice': 12,
            'dataSubjectsConsulted': 12,
            'dataSubjectConsultationDetails': 12,
            'requiresSupervisoryConsultation': 12,
            'supervisoryConsultationDate': 6,
            'supervisoryAuthorityFeedback': 6,
            'conductor': 6,
            'conductorPerson': 6,
            'conductorDeputyPersons': 12,
            'approverPerson': 6,
            'approverDeputyPersons': 6,
            'reviewFrequencyMonths': 6,
            'nextReviewDate': 6
        },
        'translation_domain': 'privacy',
        'actions': {
            'close': { 'label': 'dpia.new.button_cancel'|trans({}, 'privacy'), 'variant': 'ghost' },
            'submit': { 'label': 'dpia.new.button_create'|trans({}, 'privacy'), 'variant': 'primary' }
        }
    } %}
    {{ form_end(form) }}
</div>
{% endblock %}
