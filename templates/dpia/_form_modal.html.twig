{# DPIA create/edit rendered inside the fa-form-modal Turbo Frame.
   Explicit form action (the document URL stays on the list). On valid submit the
   controller returns a Turbo Stream (row replace/append); the controller closes
   the modal on the successful turbo:submit-end. #}
{% trans_default_domain 'privacy' %}
{% set is_edit = dpia is defined and dpia and dpia.id is not null %}
{% set form_action = is_edit ? path('app_dpia_edit', { id: dpia.id }) : path('app_dpia_new') %}
<turbo-frame id="fa-form-modal">
    {{ form_start(form, { action: form_action, method: 'POST', attr: { id: 'dpia-modal-form', 'data-turbo-frame': 'fa-form-modal' } }) }}
    {% include 'dpia/_form_body.html.twig' with {
        form: form,
        modal: true,
        title: is_edit ? dpia.title : 'dpia.new.page_title'|trans({}, 'privacy'),
        subtitle: is_edit ? dpia.referenceNumber : 'dpia.new.page_subtitle'|trans({}, 'privacy'),
        actions: {
            close: { label: 'common.cancel'|trans({}, 'messages'), variant: 'ghost', action: 'fa-form-modal#close' },
            submit: { label: 'common.save'|trans({}, 'messages'), variant: 'primary' }
        }
    } %}
    {{ form_end(form) }}
</turbo-frame>
