{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% trans_default_domain 'privacy' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'dpia.edit.title'|default('Edit DPIA') }} - {{ dpia.referenceNumber }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'dpia.new.breadcrumb_gdpr'|trans({}, 'privacy'), icon: 'shield-check' },
            { label: 'dpia.new.breadcrumb_dpia'|trans({}, 'privacy'), url: path('app_dpia_index') },
            { label: dpia.referenceNumber, url: path('app_dpia_show', {id: dpia.id}) },
            { label: 'common.edit'|trans({}, 'messages') }
        ]
    } %}

    {{ _fa_page_header.render({
        title: dpia.title,
        subtitle: dpia.referenceNumber,
        badge: { icon: 'ui-edit', label: '' },
        actions: [
            { label: 'common.cancel'|trans({}, 'messages'), href: path('app_dpia_show', {id: dpia.id}), variant: 'secondary', icon: 'ui-close' }
        ]
    }) }}

    {% if dpia.status == 'requires_revision' and dpia.rejectionReason %}
        {{ _fa_alert.render({ variant: 'warning', title: 'Revision Required', body: dpia.rejectionReason }) }}
    {% endif %}

    {{ form_start(form) }}
    {% include 'dpia/_form_body.html.twig' with {
        form: form,
        title: dpia.title,
        subtitle: dpia.referenceNumber,
        actions: {
            close: { label: 'common.cancel'|trans({}, 'messages'), variant: 'ghost', href: path('app_dpia_show', {id: dpia.id}) },
            submit: { label: 'common.save_changes'|trans({}, 'messages'), variant: 'primary' }
        }
    } %}
    {{ form_end(form) }}
</div>
{% endblock %}
