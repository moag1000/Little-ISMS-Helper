{% extends 'base.html.twig' %}
{% trans_default_domain 'data_import' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_entity_badge.html.twig' as _fa_entity_badge %}

{% block title %}{{ 'import.wizard.step.diff.title'|trans({}, 'data_import') }}{% endblock %}

{% block body %}
{# Resolve status badge type for _fa_entity_badge #}
{% set statusBadgeType = {
    'completed': 'control',
    'failed': 'finding',
    'committing': 'training'
}[batch.status] ?? 'audit' %}

<div class="container"
     data-controller="import-progress"
     data-import-progress-batch-url-value="{{ path('app_bulk_import_diff', { _locale: app.request.locale, entityType: entityType, batchId: batch.id }) }}"
     data-import-progress-poll-interval-value="3000"
     data-import-progress-status-value="{{ batch.status }}">

    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'import.page.title'|trans({}, 'data_import'), url: path('app_bulk_import_index', { _locale: app.request.locale, entityType: entityType }) },
            { label: 'import.wizard.step.diff.title'|trans({}, 'data_import') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'clipboard-data', label: ('import.entity.' ~ entityType)|trans({}, 'data_import') },
        title: 'import.page.title'|trans({}, 'data_import'),
        subtitle: 'import.wizard.step.diff.title'|trans({}, 'data_import'),
        actions: batch.rowCountError > 0 ? [
            {
                label: 'import.action.download_error_csv'|trans({}, 'data_import'),
                href: path('app_bulk_import_error_csv', { _locale: app.request.locale, entityType: entityType, batchId: batch.id }),
                variant: 'ghost',
                icon: 'download'
            }
        ] : []
    }) }}

    <main class="fa-aurora-surface mt-4">

        {% include 'import/wizard/_steps_header.html.twig' with {
            currentStep: 3,
            entityType: entityType,
            batchId: batch.id
        } %}

        {# ── Status banner ─────────────────────────────────────────────────── #}
        <div class="d-flex align-items-center gap-3 mb-4">
            <span data-import-progress-target="statusBadge">
                {{ _fa_entity_badge.render({
                    type: statusBadgeType,
                    label: batch.status
                }) }}
            </span>
            {% if isCommitting %}
                <span class="spinner-border spinner-border-sm text-primary" role="status" aria-hidden="true"></span>
                <span class="small" style="color: var(--text-muted);" aria-live="polite">
                    {{ 'import.wizard.step.commit.title'|trans({}, 'data_import') }}…
                </span>
            {% endif %}
        </div>

        {# ── Committing info alert ──────────────────────────────────────────── #}
        {% if isCommitting %}
            {{ _fa_alert.render({
                variant: 'info',
                icon: 'bi-hourglass-split',
                body: 'import.wizard.step.commit.title'|trans({}, 'data_import') ~ '…'
            }) }}
        {% endif %}

        {# ── Counters ──────────────────────────────────────────────────────── #}
        <div class="row mb-4" data-import-progress-target="counters">
            <div class="col-6 col-md-3">
                {{ _fa_feature_card.render({
                    label: 'import.delta.creates'|trans({}, 'data_import'),
                    value: batch.rowCountSuccess - batch.rowCountUpdated,
                    variant: 'success',
                    icon: 'plus-circle'
                }) }}
            </div>
            <div class="col-6 col-md-3">
                {{ _fa_feature_card.render({
                    label: 'import.delta.updates'|trans({}, 'data_import'),
                    value: batch.rowCountUpdated,
                    variant: 'primary',
                    icon: 'pencil-square'
                }) }}
            </div>
            <div class="col-6 col-md-3">
                {{ _fa_feature_card.render({
                    label: 'import.delta.unchanged'|trans({}, 'data_import'),
                    value: batch.rowCountSkipped,
                    variant: 'primary',
                    icon: 'dash-circle'
                }) }}
            </div>
            <div class="col-6 col-md-3">
                {{ _fa_feature_card.render({
                    label: 'import.delta.errors'|trans({}, 'data_import'),
                    value: batch.rowCountError,
                    variant: batch.rowCountError > 0 ? 'danger' : 'primary',
                    icon: 'exclamation-triangle'
                }) }}
            </div>
        </div>

        {# ── Error rows table ──────────────────────────────────────────────── #}
        {% if errorRows|length > 0 %}
        <section class="fa-section" data-import-progress-target="errorList">
            <div class="fa-section__header">
                <h2 class="fa-section__title">{{ 'import.delta.errors'|trans({}, 'data_import') }} ({{ errorRows|length }})</h2>
                <div class="fa-section__tools">
                    <a href="{{ path('app_bulk_import_error_csv', { _locale: app.request.locale, entityType: entityType, batchId: batch.id }) }}"
                       class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                        <i class="fa-icon fa-icon--nav-download" aria-hidden="true"></i>
                        <span class="fa-cyber-btn__label">{{ 'import.action.download_error_csv'|trans({}, 'data_import') }}</span>
                    </a>
                </div>
            </div>
            <div class="fa-section__body">
                <div class="table-responsive">
                    <table class="table table-sm align-middle" aria-label="{{ 'import.delta.errors'|trans({}, 'data_import') }}">
                        <thead>
                            <tr>
                                <th scope="col">{{ 'import.diff.col_row'|trans({}, 'data_import') }}</th>
                                <th scope="col">{{ 'import.diff.col_error'|trans({}, 'data_import') }}</th>
                                <th scope="col">{{ 'import.diff.col_data'|trans({}, 'data_import') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in errorRows %}
                            <tr class="isms-diff__line isms-diff__line--del">
                                <td class="fw-semibold">{{ row.rowNumber }}</td>
                                <td>
                                    <span style="color: var(--color-danger);">
                                        <i class="fa-icon fa-icon--status-warning me-1" aria-hidden="true"></i>
                                        {{ row.errorMessage }}
                                    </span>
                                </td>
                                <td>
                                    <code class="small">{{ row.parsedData|json_encode }}</code>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
        {% else %}
        <div data-import-progress-target="errorList"></div>
        {% endif %}

        {# ── Back to index ─────────────────────────────────────────────────── #}
        <div class="mt-4">
            <a href="{{ path('app_bulk_import_index', { _locale: app.request.locale, entityType: entityType }) }}"
               class="fa-cyber-btn fa-cyber-btn--ghost">
                <i class="fa-icon fa-icon--util-arrow-left" aria-hidden="true"></i>
                <span class="fa-cyber-btn__label">{{ 'import.page.title'|trans({}, 'data_import') }}</span>
            </a>
        </div>

    </main>
</div>
{% endblock %}
