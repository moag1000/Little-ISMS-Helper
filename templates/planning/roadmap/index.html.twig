{% extends 'base.html.twig' %}
{% trans_default_domain 'planning' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'planning.roadmap.title'|trans({}, 'planning') }} - Little ISMS Helper{% endblock %}

{% block body %}
<div class="container-fluid">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.planning'|trans({}, 'nav'), url: path('app_planning_admin') },
            { label: 'planning.roadmap.title'|trans({}, 'planning') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'calendar-check', label: 'nav.planning'|trans({}, 'nav') },
        title: 'planning.roadmap.title'|trans({}, 'planning'),
        subtitle: 'planning.roadmap.subtitle'|trans({}, 'planning')
    }) }}

    {# Mode toggle #}
    <div class="btn-group btn-group-sm mb-3" role="group" aria-label="mode">
        {% for m in ['plan', 'capacity', 'reconcile'] %}
            <a class="btn {{ mode == m ? 'btn-primary' : 'btn-outline-primary' }}"
               href="{{ path('app_planning_roadmap', { mode: m, weeks: weeks }) }}">
                {{ ('planning.roadmap.mode.' ~ m)|trans({}, 'planning') }}
            </a>
        {% endfor %}
    </div>

    {% if tasks is empty %}
        <p class="text-muted">{{ 'planning.roadmap.empty'|trans({}, 'planning') }}</p>
    {% else %}
    <form method="post" action="{{ path('app_planning_roadmap_save') }}" data-controller="roadmap-grid">
        <input type="hidden" name="_token" value="{{ csrf_token('roadmap_save') }}">
        <input type="hidden" name="weeks" value="{{ weeks }}">

        <div class="table-responsive">
            <table class="table fa-table table-sm align-middle text-center" style="min-width: max-content">
                <thead>
                    <tr>
                        <th scope="col" class="text-start" style="position:sticky;left:0;background:var(--surface)">{{ 'planning.roadmap.col.task'|trans({}, 'planning') }}</th>
                        {% for w in window %}
                            <th scope="col" title="{{ w.year }}">{{ w.label }}</th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody>
                    {# Capacity (read-only) #}
                    <tr class="table-light">
                        <th scope="row" class="text-start" style="position:sticky;left:0;background:var(--surface-2)">{{ 'planning.roadmap.row.capacity'|trans({}, 'planning') }}</th>
                        {% for w in window %}
                            {% set key = w.year ~ '-' ~ w.week %}
                            <td class="text-muted">{{ capacityPerWeek[key] ?? 0 }}</td>
                        {% endfor %}
                    </tr>
                    {# Planned total (read-only) with over/under colouring #}
                    <tr>
                        <th scope="row" class="text-start" style="position:sticky;left:0;background:var(--surface-2)">{{ 'planning.roadmap.row.planned'|trans({}, 'planning') }}</th>
                        {% for w in window %}
                            {% set key = w.year ~ '-' ~ w.week %}
                            {% set planned = plannedPerWeek[key] ?? 0 %}
                            {% set cap = capacityPerWeek[key] ?? 0 %}
                            {% set threshold = cap * (overbookingPct / 100) %}
                            <td class="{{ planned > threshold ? 'text-danger fw-bold' : (planned > 0 ? 'text-success' : 'text-muted') }}">{{ planned }}</td>
                        {% endfor %}
                    </tr>
                    {# One row per task #}
                    {% for task in tasks %}
                        <tr>
                            <th scope="row" class="text-start fw-normal" style="position:sticky;left:0;background:var(--surface)">{{ task.name }}</th>
                            {% for w in window %}
                                {% set key = w.year ~ '-' ~ w.week %}
                                {% set val = allocations[task.id ~ '-' ~ key] ?? '' %}
                                <td>
                                    {% if mode == 'plan' %}
                                        <input type="number" step="0.5" min="0"
                                               class="form-control form-control-sm text-center"
                                               style="width:4.5rem"
                                               name="cell[{{ task.id }}][{{ key }}]"
                                               value="{{ val }}"
                                               data-roadmap-grid-target="cell"
                                               data-action="input->roadmap-grid#dirty">
                                    {% else %}
                                        <span class="{{ val and val > 0 ? '' : 'text-muted' }}">{{ val ?: '·' }}</span>
                                    {% endif %}
                                </td>
                            {% endfor %}
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {% if mode == 'plan' %}
        <div class="fa-savebar" data-roadmap-grid-target="savebar" hidden>
            <span class="fa-savebar__icon"><i class="bi bi-save"></i></span>
            <div class="fa-savebar__text">
                <div class="fa-savebar__title">{{ 'planning.roadmap.savebar.title'|trans({}, 'planning') }}</div>
                <div class="fa-savebar__detail" data-roadmap-grid-target="count">0</div>
            </div>
            <div class="fa-savebar__actions">
                <button type="button" class="fa-savebar__btn fa-savebar__btn--discard" data-action="roadmap-grid#discard">{{ 'common.cancel'|trans({}, 'messages') }}</button>
                <button type="submit" class="fa-savebar__btn fa-savebar__btn--save">{{ 'common.save'|trans({}, 'messages') }}</button>
            </div>
        </div>
        {# Always-available fallback save (works without JS) #}
        <div class="mt-3">
            <button type="submit" class="btn btn-primary">{{ 'common.save'|trans({}, 'messages') }}</button>
        </div>
        {% endif %}
    </form>
    {% endif %}
</div>
{% endblock %}
