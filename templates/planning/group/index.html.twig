{% extends 'base.html.twig' %}
{% trans_default_domain 'planning' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'planning.group.title.list'|trans({}, 'planning') }} - Little ISMS Helper{% endblock %}

{% block body %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.planning'|trans({}, 'nav') }
        ]
    } %}
</div>

{{ _fa_page_header.render({
    badge: { icon: 'collection', label: 'nav.planning'|trans({}, 'nav') },
    title: 'planning.group.title.list'|trans({}, 'planning'),
    actions: [
        { label: 'planning.group.action.create'|trans({}, 'planning'), variant: 'primary', icon: 'plus', href: path('app_planning_group_new') }
    ]
}) }}

<main class="fa-aurora-surface">

{% embed '_components/_table.html.twig' with {
    'wrapperClass': 'table-container'
} %}
    {% block table_head %}
        <tr>
            <th scope="col">{{ 'planning.group.col.name'|trans({}, 'planning') }}</th>
            <th scope="col" class="text-center">{{ 'planning.group.col.sort_order'|trans({}, 'planning') }}</th>
            <th scope="col">{{ 'planning.group.col.default_visibility'|trans({}, 'planning') }}</th>
            <th scope="col" class="text-center">{{ 'planning.common.active'|trans({}, 'planning') }}</th>
            <th scope="col" class="text-center">{{ 'common.actions'|trans({}, 'messages') }}</th>
        </tr>
    {% endblock %}
    {% block table_body %}
        {% for group in groups %}
        <tr>
            <td><strong>{{ group.name }}</strong></td>
            <td class="text-center">{{ group.sortOrder }}</td>
            <td>
                {% include '_components/_badge.html.twig' with {
                    variant: group.defaultVisibility == 'all' ? 'info' : 'secondary',
                    content: ('planning.visibility.' ~ group.defaultVisibility)|trans({}, 'planning')
                } %}
            </td>
            <td class="text-center">
                {% if group.active %}
                    {% include '_components/_badge.html.twig' with { variant: 'success', content: '✓' } %}
                {% else %}
                    {% include '_components/_badge.html.twig' with { variant: 'secondary', content: '✗' } %}
                {% endif %}
            </td>
            <td class="text-center">
                <div class="btn-group btn-group-sm" role="group">
                    <a href="{{ path('app_planning_group_edit', {id: group.id}) }}"
                       class="fa-cyber-btn fa-cyber-btn--ghost"
                       aria-label="{{ 'planning.common.edit'|trans({}, 'planning') }} {{ group.name }}">
                        <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                    </a>
                    <form method="post" action="{{ path('app_planning_group_delete', {id: group.id}) }}" style="display:inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete'~group.id) }}">
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--danger"
                                aria-label="{{ 'planning.common.delete'|trans({}, 'planning') }} {{ group.name }}"
                                onclick="return confirm('{{ 'planning.common.confirm_delete'|trans({}, 'planning')|e('js') }}')">
                            <i class="fa-icon fa-icon--ui-trash" aria-hidden="true"></i>
                        </button>
                    </form>
                </div>
            </td>
        </tr>
        {% else %}
        <tr>
            <td colspan="5" class="text-center-p-xl-muted">
                {{ 'planning.group.message.no_groups'|trans({}, 'planning') }}
            </td>
        </tr>
        {% endfor %}
    {% endblock %}
{% endembed %}

</main>
{% endblock %}
