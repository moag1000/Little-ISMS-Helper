{% extends 'base.html.twig' %}

{% block title %}{{ 'reuse.heatmap.title'|trans({}, 'messages') }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .reuse-heatmap-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
            gap: 0.5rem;
        }
        .reuse-tile {
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 0.5rem 0.75rem;
            border-radius: 0.375rem;
            border: 1px solid var(--border);
            color: var(--fg);
            text-decoration: none;
            min-height: 72px;
            transition: transform 0.1s ease;
        }
        .reuse-tile:hover {
            transform: translateY(-1px);
            color: var(--fg);
        }
        .reuse-tile .tile-title {
            font-size: 0.8125rem;
            font-weight: 600;
            line-height: 1.15;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
        }
        .reuse-tile .tile-count {
            font-size: 1.1rem;
            font-weight: 700;
        }
        .reuse-tile-b0 { background: var(--surface-2); color: var(--fg-3); }
        .reuse-tile-b1 { background: var(--warning-glow); }
        .reuse-tile-b2 { background: var(--warning-tint, rgba(217, 119, 6, 0.25)); }
        .reuse-tile-b3 { background: var(--warning); color: var(--on-warning); }
        .reuse-tile-b4 { background: var(--danger); color: var(--on-danger); }
    </style>
{% endblock %}

{% macro bucket(count, max) %}
    {%- if count == 0 -%}0
    {%- elseif max <= 0 -%}1
    {%- else -%}
        {%- set ratio = count / max -%}
        {%- if ratio >= 0.75 -%}4
        {%- elseif ratio >= 0.5 -%}3
        {%- elseif ratio >= 0.25 -%}2
        {%- else -%}1
        {%- endif -%}
    {%- endif -%}
{% endmacro %}

{% block body %}
{% import _self as h %}
<div class="container-fluid">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'reuse.page.title'|trans({}, 'messages'), url: path('app_data_reuse_hub') },
            { label: 'reuse.heatmap.title'|trans({}, 'messages') }
        ]
    } %}

    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="h3 mb-1">
                <i class="bi bi-grid-3x3-gap" aria-hidden="true"></i>
                {{ 'reuse.heatmap.title'|trans({}, 'messages') }}
            </h1>
            <p class="text-muted mb-0">{{ 'reuse.heatmap.description'|trans({}, 'messages') }}</p>
        </div>
        <a href="{{ path('app_data_reuse_hub') }}" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left" aria-hidden="true"></i>
            {{ 'common.back'|trans({}, 'messages') }}
        </a>
    </div>

    {# Legende #}
    <div class="d-flex gap-3 flex-wrap align-items-center small mb-3">
        <strong>{{ 'reuse.heatmap.legend.title'|trans({}, 'messages') }}</strong>
        <span><span class="d-inline-block reuse-tile-b0" style="width:18px;height:12px;border:1px solid var(--border);"></span> 0</span>
        <span><span class="d-inline-block reuse-tile-b1" style="width:18px;height:12px;"></span> {{ 'reuse.heatmap.legend.low'|trans({}, 'messages') }}</span>
        <span><span class="d-inline-block reuse-tile-b2" style="width:18px;height:12px;"></span> {{ 'reuse.heatmap.legend.medium'|trans({}, 'messages') }}</span>
        <span><span class="d-inline-block reuse-tile-b3" style="width:18px;height:12px;"></span> {{ 'reuse.heatmap.legend.high'|trans({}, 'messages') }}</span>
        <span><span class="d-inline-block reuse-tile-b4" style="width:18px;height:12px;"></span> {{ 'reuse.heatmap.legend.top'|trans({}, 'messages') }}</span>
    </div>

    {# Dokumente #}
    <h2 class="h5 mb-2">
        <i class="bi bi-file-earmark-text" aria-hidden="true"></i>
        {{ 'reuse.heatmap.documents.heading'|trans({'%count%': documents|length, '%max%': doc_max}, 'messages') }}
    </h2>
    {% if documents|length == 0 %}
        <p class="text-muted small">{{ 'reuse.documents.empty'|trans({}, 'messages') }}</p>
    {% else %}
        <div class="reuse-heatmap-grid mb-4">
            {% for row in documents %}
                {% set bucket = h.bucket(row.requirement_count, doc_max) %}
                <a href="{{ path('app_document_show', {id: row.document.id}) }}"
                   class="reuse-tile reuse-tile-b{{ bucket }}"
                   title="{{ row.requirement_count }} Requirements / {{ row.framework_count }} Frameworks">
                    <div class="tile-title">
                        {{ row.document.originalFilename|default('#' ~ row.document.id) }}
                    </div>
                    <div class="d-flex justify-content-between align-items-end">
                        <span class="tile-count">{{ row.requirement_count }}</span>
                        <small>{{ row.framework_count }} fw</small>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}

    {# Lieferanten #}
    <h2 class="h5 mb-2">
        <i class="bi bi-building" aria-hidden="true"></i>
        {{ 'reuse.heatmap.suppliers.heading'|trans({'%count%': suppliers|length, '%max%': sup_max}, 'messages') }}
    </h2>
    {% if suppliers|length == 0 %}
        <p class="text-muted small">{{ 'reuse.suppliers.empty'|trans({}, 'messages') }}</p>
    {% else %}
        <div class="reuse-heatmap-grid mb-4">
            {% for row in suppliers %}
                {% set bucket = h.bucket(row.requirement_count, sup_max) %}
                <a href="{{ path('app_supplier_show', {id: row.supplier.id}) }}"
                   class="reuse-tile reuse-tile-b{{ bucket }}"
                   title="{{ row.requirement_count }} Requirements / {{ row.framework_count }} Frameworks">
                    <div class="tile-title">{{ row.supplier.name }}</div>
                    <div class="d-flex justify-content-between align-items-end">
                        <span class="tile-count">{{ row.requirement_count }}</span>
                        <small>{{ row.framework_count }} fw</small>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}

    <div class="alert alert-secondary small mb-0">
        <i class="bi bi-info-circle" aria-hidden="true"></i>
        {{ 'reuse.heatmap.hint_monoculture'|trans({}, 'messages') }}
    </div>
</div>
{% endblock %}
