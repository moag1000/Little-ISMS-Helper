{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'reuse.page.title'|trans({}, 'messages') }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'reuse.page.title'|trans({}, 'messages') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'arrows-collapse', label: 'reuse.page.title'|trans({}, 'messages') },
        title: 'reuse.page.title'|trans({}, 'messages'),
        subtitle: 'reuse.page.description'|trans({}, 'messages'),
        actions: [
            { label: 'reuse.cta.heatmap'|trans({}, 'messages'), variant: 'ghost', icon: 'grid-3x3-gap', href: path('app_data_reuse_heatmap') },
            { label: 'reuse.cta.portfolio'|trans({}, 'messages'), variant: 'primary', icon: 'graph-up-arrow', href: path('app_management_reports_portfolio') }
        ]
    }) }}

    <main class="fa-aurora-surface fa-aurora-surface--dots">

    {# Hero KPI — FTE-saved, identisch zur Home-Landing-Karte — 8H.4 migrated #}
    {% embed '_components/_card.html.twig' with { class: 'shadow-sm mb-4 border-success' } %}
        {% block card_body %}
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                <div>
                    <div class="small text-uppercase text-muted mb-1">
                        <i class="bi bi-lightning-charge-fill text-success" aria-hidden="true"></i>
                        {{ 'reuse.fte.title'|trans({}, 'messages') }}
                    </div>
                    <div class="display-5 fw-bold text-success">
                        {{ fte_saved|number_format(1, '.', ',') }}
                        <small class="fs-5 text-muted">{{ 'reuse.fte.days_suffix'|trans({}, 'messages') }}</small>
                    </div>
                    <div class="small text-muted">{{ 'reuse.fte.subtitle'|trans({}, 'messages') }}</div>
                </div>
                <div class="d-flex flex-column align-items-end gap-1">
                    <span class="badge bg-body-secondary border fa-status-pill fa-status-pill--neutral">
                        <i class="bi bi-file-earmark" aria-hidden="true"></i>
                        {{ 'reuse.stats.documents'|trans({
                            '%reused%': stats.documents_reused,
                            '%total%': stats.documents_total
                        }, 'messages') }}
                    </span>
                    <span class="badge bg-body-secondary border fa-status-pill fa-status-pill--neutral">
                        <i class="fa-icon fa-icon--nav-building" aria-hidden="true"></i>
                        {{ 'reuse.stats.suppliers'|trans({
                            '%reused%': stats.suppliers_reused,
                            '%total%': stats.suppliers_total
                        }, 'messages') }}
                    </span>
                    <span class="badge bg-body-secondary border fa-status-pill fa-status-pill--neutral">
                        <i class="bi bi-ui-checks" aria-hidden="true"></i>
                        {{ 'reuse.stats.requirements'|trans({'%count%': stats.requirements_total}, 'messages') }}
                    </span>
                </div>
            </div>
        {% endblock %}
    {% endembed %}

    {# 9001-Brücke für Junior-Einstieg #}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', icon: 'bi-lightbulb', class: 'small mb-4' } } %}
        {% block alert_body %}<strong>{{ 'reuse.iso9001_bridge.title'|trans({}, 'messages') }}</strong> {{ 'reuse.iso9001_bridge.text'|trans({}, 'messages') }}{% endblock %}
    {% endembed %}

    <div class="row g-3">
        {# TOP DOKUMENTE — 8H.4 migrated #}
        <div class="col-lg-6">
            {% embed '_components/_card.html.twig' with { class: 'shadow-sm h-100' } %}
                {% block card_header %}
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h2 class="h6 mb-0">
                            <i class="bi bi-file-earmark-text" aria-hidden="true"></i>
                            {{ 'reuse.documents.heading'|trans({}, 'messages') }}
                        </h2>
                        <a href="{{ path('app_document_index') }}" class="small">
                            {{ 'reuse.documents.all_link'|trans({}, 'messages') }}
                        </a>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {% if top_documents|length == 0 %}
                        <p class="text-muted small mb-0">
                            {{ 'reuse.documents.empty'|trans({}, 'messages') }}
                        </p>
                    {% else %}
                        <ol class="list-unstyled mb-0">
                            {% for row in top_documents %}
                                <li class="d-flex justify-content-between align-items-start border-bottom py-2">
                                    <div class="flex-grow-1">
                                        <a href="{{ path('app_document_show', {id: row.document.id}) }}" class="fw-semibold">
                                            {{ row.document.originalFilename|default('Dokument #' ~ row.document.id) }}
                                        </a>
                                        {% if row.document.category %}
                                            <div class="small text-muted">{{ row.document.category }}</div>
                                        {% endif %}
                                    </div>
                                    <div class="text-end ms-2">
                                        <div class="h5 mb-0 text-primary">{{ row.requirement_count }}</div>
                                        <div class="small text-muted">
                                            {{ 'reuse.unit.requirements_in_frameworks'|trans({'%fw%': row.framework_count}, 'messages') }}
                                        </div>
                                    </div>
                                </li>
                            {% endfor %}
                        </ol>
                    {% endif %}
                {% endblock %}
            {% endembed %}
        </div>

        {# TOP LIEFERANTEN — 8H.4 migrated #}
        <div class="col-lg-6">
            {% embed '_components/_card.html.twig' with { class: 'shadow-sm h-100' } %}
                {% block card_header %}
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h2 class="h6 mb-0">
                            <i class="fa-icon fa-icon--nav-building" aria-hidden="true"></i>
                            {{ 'reuse.suppliers.heading'|trans({}, 'messages') }}
                        </h2>
                        <a href="{{ path('app_supplier_index') }}" class="small">
                            {{ 'reuse.suppliers.all_link'|trans({}, 'messages') }}
                        </a>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {% if top_suppliers|length == 0 %}
                        <p class="text-muted small mb-0">
                            {{ 'reuse.suppliers.empty'|trans({}, 'messages') }}
                        </p>
                    {% else %}
                        <ol class="list-unstyled mb-0">
                            {% for row in top_suppliers %}
                                <li class="d-flex justify-content-between align-items-start border-bottom py-2">
                                    <div class="flex-grow-1">
                                        <a href="{{ path('app_supplier_show', {id: row.supplier.id}) }}" class="fw-semibold">
                                            {{ row.supplier.name }}
                                        </a>
                                        {% if row.supplier.criticality %}
                                            <div class="small text-muted">
                                                {{ 'supplier.field.criticality'|trans({}, 'suppliers') }}: {{ row.supplier.criticality }}
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div class="text-end ms-2">
                                        <div class="h5 mb-0 text-primary">{{ row.requirement_count }}</div>
                                        <div class="small text-muted">
                                            {{ 'reuse.unit.requirements_in_frameworks'|trans({'%fw%': row.framework_count}, 'messages') }}
                                        </div>
                                    </div>
                                </li>
                            {% endfor %}
                        </ol>
                    {% endif %}
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', icon: 'bi-info-circle', class: 'small mt-4 mb-0' } } %}
        {% block alert_body %}{{ 'reuse.page.footer_hint'|trans({}, 'messages') }}{% endblock %}
    {% endembed %}
    </main>
</div>
{% endblock %}
