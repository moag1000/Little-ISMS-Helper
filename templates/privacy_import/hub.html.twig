{% extends 'base.html.twig' %}
{% trans_default_domain 'data_import' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'privacy_import.hub.title'|trans({}, 'data_import') }}{% endblock %}

{% block body %}
{{ _fa_page_header.render({
    badge: { icon: 'ui-upload', label: 'privacy_import.hub.badge'|trans({}, 'data_import') },
    title: 'privacy_import.hub.title'|trans({}, 'data_import'),
    subtitle: 'privacy_import.hub.subtitle'|trans({}, 'data_import'),
}) }}

<main class="fa-aurora-surface">
    <div class="row g-3">
        {% for import in imports %}
            <div class="col-md-4">
                <a href="{{ path('app_bulk_import_index', { entityType: import.slug }) }}"
                   class="card h-100 text-decoration-none" data-turbo-action="advance">
                    <div class="card-body d-flex align-items-start gap-3">
                        <i class="fa-icon fa-icon--{{ import.icon }} fs-3 text-primary" aria-hidden="true"></i>
                        <div class="flex-grow-1">
                            <h2 class="h6 mb-1">{{ import.label|trans({}, 'data_import') }}</h2>
                            <p class="small text-muted mb-0">{{ import.desc|trans({}, 'data_import') }}</p>
                        </div>
                        <i class="fa-icon fa-icon--util-arrow-right text-muted" aria-hidden="true"></i>
                    </div>
                </a>
            </div>
        {% endfor %}
    </div>

    <p class="text-muted small mt-3">
        <i class="fa-icon fa-icon--ui-info" aria-hidden="true"></i>
        {{ 'privacy_import.hub.help'|trans({}, 'data_import') }}
    </p>
</main>
{% endblock %}
