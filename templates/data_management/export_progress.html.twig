{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'admin' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'admin.job.export.data_label'|trans({}, 'admin') }} — {{ 'admin.data_export.title'|trans({}, 'admin') }}{% endblock %}

{% block admin_title %}
    <i class="fa-icon fa-icon--nav-download" aria-hidden="true"></i> {{ 'admin.job.export.data_label'|trans({}, 'admin') }}
{% endblock %}

{% block admin_content %}
<div class="container-fluid">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.admin'|trans({}, 'nav'), url: path('admin_dashboard') },
            { label: 'admin.nav.export'|trans({}, 'admin'), url: path('data_export_index') },
            { label: 'admin.job.export.data_label'|trans({}, 'admin') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'nav-download', label: 'admin.data_export.title'|trans({}, 'admin') },
        title: 'admin.job.export.data_label'|trans({}, 'admin'),
        subtitle: 'admin.job.export.data_subtitle'|trans({}, 'admin'),
    }) }}

    {# Turbo cache disabled — live status changes every 3 s #}
    <meta name="turbo-cache-control" content="no-cache">

    <div class="row justify-content-center mt-4">
        <div class="col-lg-8 col-xl-6">
            {% include '_components/_async_job_progress.html.twig' with {
                job_id:    jobId,
                job_name:  'admin.data_export.dispatch',
                job_label: 'admin.job.export.data_label'|trans({}, 'admin'),
                cancel_url: cancelUrl,
                download_url: downloadUrl,
                download_label: 'admin.job.download'|trans({}, 'admin') ~ ' (' ~ format|upper ~ ')',
            } %}

            <div class="mt-3 text-center text-muted small">
                <i class="fa-icon fa-icon--status-info" aria-hidden="true"></i>
                {{ 'admin.job.worker_hint'|trans({}, 'admin') }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
