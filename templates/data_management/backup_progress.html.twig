{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'admin' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'data_management.backup.progress.title'|trans({}, 'admin') }} — {{ 'data_management.backup.title'|trans({}, 'admin') }}{% endblock %}

{% block admin_title %}
    <i class="fa-icon fa-icon--threat" aria-hidden="true"></i> {{ 'data_management.backup.progress.title'|trans({}, 'admin') }}
{% endblock %}

{% block admin_content %}
<div class="container-fluid">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.admin'|trans({}, 'nav'), url: path('admin_dashboard') },
            { label: 'data_management.backup.title'|trans({}, 'admin'), url: path('data_backup_index') },
            { label: 'data_management.backup.progress.title'|trans({}, 'admin') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'nav-tools', label: 'data_management.backup.progress.badge'|trans({}, 'admin') },
        title: 'data_management.backup.progress.title'|trans({}, 'admin'),
        subtitle: 'data_management.backup.progress.subtitle'|trans({}, 'admin'),
    }) }}

    {# Turbo cache disabled — live status changes every 3 s #}
    <meta name="turbo-cache-control" content="no-cache">

    <div class="row justify-content-center mt-4">
        <div class="col-lg-8 col-xl-6">
            {% include '_components/_async_job_progress.html.twig' with {
                job_id:    jobId,
                job_name:  'admin.backup',
                job_label: 'data_management.backup.progress.title'|trans({}, 'admin'),
                cancel_url: cancelUrl,
            } %}

            <div class="mt-3 text-center text-muted small">
                <i class="fa-icon fa-icon--status-info" aria-hidden="true"></i>
                {{ 'admin.job.worker_hint'|trans({}, 'admin') }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
