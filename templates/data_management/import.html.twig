{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block title %}Data Import - Data Management{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-box-arrow-in-down" aria-hidden="true"></i> Data Import</h1>
    </div>

    {# Warning Banner #}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'danger', class: 'mb-4' } } %}
        {% block alert_body %}
        <div class="fa-alert__title">Critical Warning</div>
        <p class="mb-0">
            <strong>Data import can overwrite existing data!</strong>
            Always create a backup before importing data. This feature is currently in preview mode
            and does not execute actual imports yet.
        </p>
        {% endblock %}
    {% endembed %}

    {# Import Form #}
    {% embed '_components/_card.html.twig' %}
        {% block card_header %}
            <div class="card-header">
                <h3 class="mb-0">
                    <i class="fa-icon fa-icon--nav-upload" aria-hidden="true"></i> Upload Import File
                </h3>
            </div>
        {% endblock %}
        {% block card_body %}
            <form method="post" action="{{ path('data_import_upload') }}" enctype="multipart/form-data"
                  data-controller="wizard-busy"
                  data-wizard-busy-message-value="{{ 'data.alva.busy.import_preview'|trans({}, 'data_management') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('data_import') }}">

                <div class="mb-4">
                    <label for="import_file" class="form-label">
                        <strong>Select JSON File:</strong>
                    </label>
                    <input type="file"
                           class="form-control"
                           id="import_file"
                           name="import_file"
                           accept=".json"
                           required>
                    <div class="form-text">
                        Upload a JSON file exported from this system. Only JSON format is currently supported.
                    </div>
                </div>

                {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info' } } %}
                    {% block alert_body %}
                    <div class="fa-alert__title">Import Process</div>
                    <ol class="mb-0">
                        <li>{{ 'data_management.import.step_upload'|trans({}, 'messages')}}</li>
                        <li>{{ 'data_management.import.step_preview'|trans({}, 'messages')}}</li>
                        <li>{{ 'data_management.import.step_confirm'|trans({}, 'messages')}}</li>
                        <li>{{ 'data_management.import.step_validate'|trans({}, 'messages')}}</li>
                    </ol>
                    {% endblock %}
                {% endembed %}

                <div class="d-grid gap-2">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--lg">
                        <i class="fa-icon fa-icon--nav-upload" aria-hidden="true"></i> Upload and Preview
                    </button>
                </div>
            </form>
        {% endblock %}
    {% endembed %}

    {# Requirements #}
    {% embed '_components/_card.html.twig' with {class: 'mt-4'} %}
        {% block card_header %}
            <div class="card-header">
                <h3 class="mb-0">
                    <i class="fa-icon fa-icon--nav-list-check" aria-hidden="true"></i> Import Requirements
                </h3>
            </div>
        {% endblock %}
        {% block card_body %}
            <h4>File Format:</h4>
            <ul>
                <li>{{ 'data_management.import.format_json'|trans({}, 'messages')}}</li>
                <li>{{ 'data_management.import.format_export'|trans({}, 'messages')}}</li>
                <li>Maximum file size: 50 MB (configurable)</li>
            </ul>

            <h4>Before Importing:</h4>
            <ul>
                <li><strong>Create a database backup</strong> using the <a href="{{ path('data_backup_index') }}">Backup</a> function</li>
                <li>{{ 'data_management.import.ensure_disk_space'|trans({}, 'messages')}}</li>
                <li>{{ 'data_management.import.plan_downtime'|trans({}, 'messages')}}</li>
                <li>{{ 'data_management.import.test_small'|trans({}, 'messages')}}</li>
            </ul>

            <h4>Limitations:</h4>
            <ul class="mb-0">
                <li>This feature is currently in <strong>preview mode</strong></li>
                <li>{{ 'data_management.import.validation_required'|trans({}, 'messages')}}</li>
                <li>Entity relationships need manual verification</li>
                <li>{{ 'data_management.import.no_duplicate_detection'|trans({}, 'messages')}}</li>
            </ul>
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
