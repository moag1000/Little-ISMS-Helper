{% extends 'base.html.twig' %}
{% trans_default_domain 'patches' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'patch.new'|trans({}, 'patches') }} - {{ parent() }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.patches'|trans({}, 'nav'), url: path('app_patch_index') },
            { label: 'patch.new'|trans({}, 'patches') }
        ]
    } %}

    {{ _fa_page_header.render({
        title: 'patch.new'|trans({}, 'patches'),
        badge: { icon: 'plus', label: '' },
        actions: [
            { label: 'common.back'|trans({}, 'messages'), href: path('app_patch_index'), variant: 'ghost', icon: 'util-arrow-left' }
        ]
    }) }}

    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

    {% include '_components/_auto_form.html.twig' with {
        'form': form,
        'layout': 'outline-rail',
        'eyebrow': 'ISO 27001 A.8.8 · Vulnerability Management',
        'title': 'patch.new'|trans({}, 'patches'),
        'sections': {
            'overview': {
                'label': 'patch.section.overview'|trans({}, 'patches'),
                'fields': ['patchId', 'title', 'description', 'patchType', 'priority', 'status']
            },
            'vulnerability_link': {
                'label': 'patch.section.vulnerability_link'|trans({}, 'patches'),
                'fields': ['vulnerability', 'vendor', 'product', 'version', 'downloadUrl', 'documentationUrl']
            },
            'affected_systems': {
                'label': 'patch.section.affected_systems'|trans({}, 'patches'),
                'fields': ['affectedAssets']
            },
            'testing': {
                'label': 'patch.section.testing'|trans({}, 'patches'),
                'fields': ['testingNotes', 'requiresDowntime', 'estimatedDowntimeMinutes', 'requiresReboot', 'knownIssues']
            },
            'rollout': {
                'label': 'patch.section.rollout'|trans({}, 'patches'),
                'fields': ['releaseDate', 'deploymentDeadline', 'deployedDate', 'responsiblePerson', 'deploymentNotes']
            },
            'verification': {
                'label': 'patch.section.verification'|trans({}, 'patches'),
                'fields': ['rollbackPlan']
            }
        },
        'col_widths': {
            'patchId': 4,
            'title': 8,
            'description': 12,
            'patchType': 6,
            'priority': 6,
            'status': 6,
            'vulnerability': 12,
            'vendor': 6,
            'product': 6,
            'version': 6,
            'downloadUrl': 12,
            'documentationUrl': 12,
            'affectedAssets': 12,
            'testingNotes': 12,
            'requiresDowntime': 6,
            'estimatedDowntimeMinutes': 6,
            'requiresReboot': 6,
            'knownIssues': 12,
            'releaseDate': 6,
            'deploymentDeadline': 6,
            'deployedDate': 6,
            'responsiblePerson': 6,
            'deploymentNotes': 12,
            'rollbackPlan': 12
        },
        'actions': {
            'close': { 'label': 'common.back'|trans({}, 'messages'), 'variant': 'ghost' },
            'submit': { 'label': 'common.save'|trans({}, 'messages'), 'variant': 'primary' }
        }
    } %}

    {{ form_end(form) }}
</div>
{% endblock %}
