{# Patch create/edit rendered inside the fa-form-modal Turbo Frame.
   Explicit form action (the document URL stays on the list). On valid submit the
   controller returns a Turbo Stream (row replace/append). #}
{% trans_default_domain 'patches' %}
{% set is_edit = patch is defined and patch and patch.id is not null %}
{% set form_action = is_edit ? path('app_patch_edit', { id: patch.id }) : path('app_patch_new') %}
<turbo-frame id="fa-form-modal">
    {{ form_start(form, { action: form_action, method: 'POST', attr: {
        id: 'patch-modal-form',
        'data-turbo-frame': 'fa-form-modal'
    } }) }}
    {% include 'patch/_form_body.html.twig' with {
        form: form,
        modal: true,
        title: is_edit ? patch.title : 'patch.new'|trans({}, 'patches'),
        actions: {
            close: { label: 'common.cancel'|trans({}, 'messages'), variant: 'ghost', action: 'fa-form-modal#close' },
            submit: { label: 'common.save'|trans({}, 'messages'), variant: 'primary' }
        }
    } %}
    {{ form_end(form) }}
</turbo-frame>
