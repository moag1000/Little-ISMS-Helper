{% extends 'base.html.twig' %}
{% trans_default_domain 'crisis_team' %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}

{% block title %}{{ 'crisis_team.title'|trans({}, 'crisis_team') }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}
{% block body %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_alva_hint.html.twig' as _fa_alva_hint %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.bcm'|trans({}, 'nav'), url: path('app_bcm_index') },
            { label: 'nav.crisis_team'|trans({}, 'nav') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'nav-shield-alert', label: 'crisis_team.title'|trans({}, 'crisis_team') },
        title: 'crisis_team.title'|trans({}, 'crisis_team'),
        actions: [
            { label: 'crisis_team.new'|trans({}, 'crisis_team'), href: path('app_crisis_team_new'), variant: 'primary', icon: 'plus', attrs: {'data-turbo-frame': 'fa-form-modal'} }
        ]
    }) }}
{% set _global_hints = alva_hints('crisis_team_index') %}
{% if _global_hints|length > 0 %}
    {% for _h in _global_hints %}
        {{ _fa_alva_hint.render(_h) }}
    {% endfor %}
{% endif %}

    <main class="fa-aurora-surface">
    <div class="row mb-4">
        <div class="col-md-4">
            {{ _fa_feature_card.render({ label: 'crisis_team.kpi.active'|trans({}, 'crisis_team'), value: active_count, variant: 'success' }) }}
        </div>
        <div class="col-md-4">
            {{ _fa_feature_card.render({ label: 'crisis_team.type.operational'|trans({}, 'crisis_team'), value: operational_count, variant: 'primary' }) }}
        </div>
        <div class="col-md-4">
            {{ _fa_feature_card.render({ label: 'crisis_team.type.strategic'|trans({}, 'crisis_team'), value: strategic_count, variant: 'info' }) }}
        </div>
    </div>
    {% if crisis_teams|length == 0 %}
        {% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
        {{ _fa_empty_state.render({
            mood: 'sleeping',
            title: 'crisis_team.empty'|trans({}, 'crisis_team'),
            actions: [
                { label: 'crisis_team.new'|trans({}, 'crisis_team'), variant: 'primary', icon: 'plus', href: path('app_crisis_team_new') }
            ]
        }) }}
    {% else %}
        {% embed '_components/_card.html.twig' %}
            {% block card_attrs %}data-controller="filter"{% endblock %}
            {% block card_header %}
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h2 class="mb-0">{{ 'crisis_team.title'|trans({}, 'crisis_team') }} ({{ crisis_teams|length }})</h2>
                    <input type="search" class="form-control form-control-sm w-250px fa-cyber-input__field"
                           data-filter-target="searchInput"
                           data-action="input->filter#filterRows"
                           placeholder="{{ 'common.search'|trans({}, 'messages') }}...">
                </div>
            {% endblock %}
            {% block card_body %}
                {% embed '_components/_table.html.twig' with {
                    'noMargin': true
                } %}
                    {% block table_head %}
                        <tr>
                            <th scope="col">{{ 'crisis_team.field.team_name'|trans({}, 'crisis_team') }}</th>
                            <th scope="col">{{ 'crisis_team.field.team_type'|trans({}, 'crisis_team') }}</th>
                            <th scope="col">{{ 'crisis_team.field.team_leader'|trans({}, 'crisis_team') }}</th>
                            <th scope="col">{{ 'common.actions'|trans({}, 'messages') }}</th>
                        </tr>
                    {% endblock %}
                    {% block table_body %}
                        <tbody id="crisis-team-rows">
                        {% for team in crisis_teams %}
                            {% include 'crisis_team/_row.html.twig' with { team: team } %}
                        {% endfor %}
                        </tbody>
                    {% endblock %}
                {% endembed %}
            {% endblock %}
        {% endembed %}
    {% endif %}
    </main>
</div>
{% endblock %}
