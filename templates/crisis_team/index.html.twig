{% extends 'base.html.twig' %}
{% trans_default_domain 'crisis_team' %}
{% import '_macros/cards.html.twig' as cards %}

{% block title %}{{ 'crisis_team.title'|trans({}, 'crisis_team') }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}
{% block body %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.bcm'|trans({}, 'nav'), url: path('app_bcm_index') },
            { label: 'nav.crisis_team'|trans({}, 'nav') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'shield-exclamation', label: 'crisis_team.title'|trans({}, 'crisis_team') },
        title: 'crisis_team.title'|trans({}, 'crisis_team'),
        actions: [
            { label: 'crisis_team.new'|trans({}, 'crisis_team'), href: path('app_crisis_team_new'), variant: 'primary', icon: 'plus-circle' }
        ]
    }) }}
    <main class="fa-aurora-surface">
    <div class="row mb-4">
        <div class="col-md-4">
            {{ cards.kpi_card('crisis_team.kpi.active'|trans({}, 'crisis_team'), active_count, null, null, 'success', 'border-success') }}
        </div>
        <div class="col-md-4">
            {{ cards.kpi_card('crisis_team.type.operational'|trans({}, 'crisis_team'), operational_count, null, null, 'primary', null) }}
        </div>
        <div class="col-md-4">
            {{ cards.kpi_card('crisis_team.type.strategic'|trans({}, 'crisis_team'), strategic_count, null, null, 'info', null) }}
        </div>
    </div>
    {% if crisis_teams|length == 0 %}
        {% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
        {{ _fa_empty_state.render({
            mood: 'sleeping',
            title: 'crisis_team.empty'|trans({}, 'crisis_team'),
            actions: [
                { label: 'crisis_team.new'|trans({}, 'crisis_team'), variant: 'primary', icon: 'plus-circle', href: path('app_crisis_team_new') }
            ]
        }) }}
    {% else %}
        {% embed '_components/_card.html.twig' %}
            {% block card_body %}
                {% embed '_components/_table.html.twig' with {
                    'noMargin': true
                } %}
                    {% block table_head %}
                        <tr>
                            <th scope="col">{{ 'crisis_team.field.team_name'|trans({}, 'crisis_team') }}</th>
                            <th scope="col">{{ 'crisis_team.field.team_type'|trans({}, 'crisis_team') }}</th>
                            <th scope="col">{{ 'crisis_team.field.team_leader'|trans({}, 'crisis_team') }}</th>
                            <th scope="col">{{ 'common.actions'|trans({}, 'messages') }}</th>
                        </tr>
                    {% endblock %}
                    {% block table_body %}
                        {% for team in crisis_teams %}
                            <tr class="{{ team.isActive ? '' : 'table-secondary' }}">
                                <td><strong>{{ team.teamName }}</strong></td>
                                <td>{% include '_components/_badge.html.twig' with { variant: 'primary', content: ('crisis_team.type.' ~ team.teamType)|trans({}, 'crisis_team') } %}</td>
                                <td>{{ team.teamLeader ? team.teamLeader.fullName|default(team.teamLeader.email) : 'not_assigned'|trans({}, 'messages') }}</td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group" aria-label="{{ 'common.actions'|trans({}, 'messages') }}">
                                        <a href="{{ path('app_crisis_team_show', {id: team.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost" title="{{ 'common.view'|trans({}, 'messages') }}" aria-label="{{ 'common.view'|trans({}, 'messages') }}"><i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i></a>
                                        <a href="{{ path('app_crisis_team_edit', {id: team.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost" title="{{ 'common.edit'|trans({}, 'messages') }}" aria-label="{{ 'common.edit'|trans({}, 'messages') }}"><i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i></a>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            {% endblock %}
        {% endembed %}
    {% endif %}
    </main>
</div>
{% endblock %}
