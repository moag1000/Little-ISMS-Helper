{% extends 'base.html.twig' %}
{% trans_default_domain 'crisis_team' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'crisis_team.new'|trans({}, 'crisis_team')}}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.crisis_teams'|trans({}, 'nav'), url: path('app_crisis_team_index') },
            { label: 'crisis_team.new'|trans({}, 'crisis_team')}
        ]
    } %}

    {{ _fa_page_header.render({
        title: 'crisis_team.new'|trans({}, 'crisis_team'),
        badge: { icon: 'plus', label: '' },
        actions: [
            { label: 'common.back_to_list'|trans({}, 'messages'), href: path('app_crisis_team_index'), variant: 'ghost', icon: 'util-arrow-left' }
        ]
    }) }}

    {{ form_start(form) }}

    {% include '_components/_auto_form.html.twig' with {
        'form': form,
        'layout': 'outline-rail',
        'eyebrow': 'ISO 22301 Cl. 8.4 · Crisis Team',
        'title': 'crisis_team.new'|trans({}, 'crisis_team'),
        'sections': {
            'overview': {
                'label': 'crisis_team.section.overview'|trans({}, 'crisis_team'),
                'fields': ['teamName', 'description', 'teamType', 'isActive']
            },
            'members': {
                'label': 'crisis_team.section.members'|trans({}, 'crisis_team'),
                'fields': ['teamLeader', 'teamLeaderPerson', 'teamLeaderDeputyPersons', 'deputyLeader', 'deputyLeaderPerson', 'deputyLeaderDeputyPersons', 'personMembers']
            },
            'communication': {
                'label': 'crisis_team.section.communication'|trans({}, 'crisis_team'),
                'fields': ['primaryPhone', 'primaryEmail', 'meetingLocation', 'backupMeetingLocation', 'virtualMeetingUrl', 'communicationProtocols']
            },
            'escalation': {
                'label': 'crisis_team.section.escalation'|trans({}, 'crisis_team'),
                'fields': ['alertProcedures', 'decisionAuthority', 'escalationMatrix']
            },
            'activation': {
                'label': 'crisis_team.section.activation'|trans({}, 'crisis_team'),
                'fields': ['businessContinuityPlans', 'activationCount', 'lastActivatedAt', 'notes']
            },
            'testing': {
                'label': 'crisis_team.section.testing'|trans({}, 'crisis_team'),
                'fields': ['trainingSchedule', 'lastTrainingAt', 'nextTrainingAt']
            }
        },
        'col_widths': {
            'teamName': 6,
            'teamType': 6,
            'description': 12,
            'isActive': 12,
            'teamLeader': 6,
            'teamLeaderPerson': 6,
            'teamLeaderDeputyPersons': 12,
            'deputyLeader': 6,
            'deputyLeaderPerson': 6,
            'deputyLeaderDeputyPersons': 12,
            'personMembers': 12,
            'primaryPhone': 6,
            'primaryEmail': 6,
            'meetingLocation': 6,
            'backupMeetingLocation': 6,
            'virtualMeetingUrl': 12,
            'communicationProtocols': 12,
            'alertProcedures': 12,
            'decisionAuthority': 12,
            'escalationMatrix': 12,
            'businessContinuityPlans': 12,
            'activationCount': 6,
            'lastActivatedAt': 6,
            'notes': 12,
            'trainingSchedule': 12,
            'lastTrainingAt': 6,
            'nextTrainingAt': 6
        },
        'translation_domain': 'crisis_team',
        'actions': {
            'close': { 'label': 'common.cancel'|trans({}, 'messages'), 'variant': 'ghost' },
            'submit': { 'label': 'common.create'|trans({}, 'messages'), 'variant': 'primary' }
        }
    } %}

    {{ form_end(form) }}
</div>
{% endblock %}
