{% extends 'base.html.twig' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% trans_default_domain 'crisis_team' %}
{% block title %}{{ crisis_team.teamName }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}
{% block body %}
{% import '_components/_fa_alva_hint.html.twig' as _fa_alva_hint %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.bcm'|trans({}, 'nav'), url: path('app_bcm_index') },
            { label: 'nav.crisis_team'|trans({}, 'nav'), url: path('app_crisis_team_index') },
            { label: crisis_team.teamName }
        ]
    } %}

    {% set hint = alva_hint(crisis_team) %}
    {% if hint %}{{ _fa_alva_hint.render(hint) }}{% endif %}

    {{ _fa_page_header.render({
        badge: { icon: 'nav-people', label: 'nav.crisis_team'|trans({}, 'nav') },
        title: crisis_team.teamName,
        actions: [
            { label: 'common.edit'|trans({}, 'messages'), variant: 'primary', icon: 'ui-edit',     href: path('app_crisis_team_edit',  {id: crisis_team.id}) },
            { label: 'common.back'|trans({}, 'messages'), variant: 'ghost',   icon: 'util-arrow-left', href: path('app_crisis_team_index') }
        ]
    }) }}
    {% embed '_components/_card.html.twig' %}
        {% block card_body %}
            <dl class="row">
                <dt class="col-sm-3">{{ ('crisis_team.type.' ~ crisis_team.teamType)|trans({}, 'crisis_team') }}</dt><dd class="col-sm-9">{% include '_components/_badge.html.twig' with { variant: 'primary', content: ('crisis_team.type.' ~ crisis_team.teamType)|trans({}, 'crisis_team') } %}</dd>
                <dt class="col-sm-3">{{ 'crisis_team.field.is_active'|trans({}, 'crisis_team') }}</dt><dd class="col-sm-9">{% include '_components/_badge.html.twig' with { variant: crisis_team.isActive ? 'success' : 'danger', content: crisis_team.isActive ? 'yes'|trans({}, 'messages') : 'no'|trans({}, 'messages') } %}</dd>
                {% if crisis_team.teamLeader %}<dt class="col-sm-3">{{ 'crisis_team.field.team_leader'|trans({}, 'crisis_team') }}</dt><dd class="col-sm-9">{{ crisis_team.teamLeader.email }}</dd>{% endif %}
                {% if crisis_team.description %}<dt class="col-sm-3">{{ 'crisis_team.field.description'|trans({}, 'crisis_team') }}</dt><dd class="col-sm-9">{{ crisis_team.description|nl2br }}</dd>{% endif %}
            </dl>
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
