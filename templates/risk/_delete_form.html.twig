<form method="post" action="{{ path('app_risk_delete', {id: risk.id}) }}"
      data-controller="ui-actions"
      data-action="submit->ui-actions#confirm"
      data-ui-actions-message-param="{{ 'risk.confirm.delete'|trans({}, 'risk') }}">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ risk.id) }}">
    <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger">
        <i class="fa-icon fa-icon--ui-trash" aria-hidden="true"></i>
        {{ 'common.delete'|trans({}, 'messages') }}
    </button>
</form>
