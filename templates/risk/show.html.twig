{% extends 'base.html.twig' %}
{% trans_default_domain 'risk' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_status_pill.html.twig' as pill %}
{% import '_components/_fa_status_chip.html.twig' as _fa_status_chip %}
{% import '_components/_lifecycle_actions.html.twig' as _lifecycle_actions %}
{% import '_components/_lifecycle_history_tab.html.twig' as _lifecycle_history %}
{% import '_components/_lifecycle_pending_banner.html.twig' as _lifecycle_pending_banner %}

{% block title %}{{ risk.title }}{% endblock %}

{% block body %}
{% import '_components/_fa_alva_hint.html.twig' as _fa_alva_hint %}
<div class="container">
    {# M-4 — module-gating: Risk Management (ISO 27001 Cl. 6.1.2 + ISO 27005) #}
    {% if not is_module_active('risks') %}
        {{ _fa_alert.render({
            variant: 'info',
            icon: 'nav-shield-alert',
            body: 'common.module_not_active'|trans({'%module%': 'Risk Management'}, 'messages')
        }) }}
    {% else %}
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.risks'|trans({}, 'nav'), url: path('app_risk_index') },
            { label: risk.title }
        ]
    } %}

    {% set hint = alva_hint(risk) %}
    {% if hint %}{{ _fa_alva_hint.render(hint) }}{% endif %}

    {% set _show_actions = [] %}
    {% if canEdit is defined and canEdit %}
        {% set _show_actions = _show_actions|merge([{ label: 'action.edit'|trans({}, 'messages'), variant: 'primary', icon: 'ui-edit', href: path('app_risk_edit', {id: risk.id}) }]) %}
    {% endif %}
    {% set _show_actions = _show_actions|merge([
        { label: 'action.back_to_list'|trans({}, 'messages'), variant: 'ghost', href: path('app_risk_index') }
    ]) %}
    {{ _fa_page_header.render({
        badge: (isInherited is defined and isInherited) ? { icon: 'nav-building', label: 'corporate.inherited'|trans({}, 'tenant') } : null,
        title: risk.title,
        actions: _show_actions
    }) }}

    {# Inline POST-delete and disabled-edit kept below header (cannot be expressed via _fa_page_header GET-only actions) #}
    {% if (canEdit is defined and not canEdit) or (is_granted('ROLE_ADMIN') and (canEdit is not defined or canEdit)) %}
        <div class="d-flex justify-content-end gap-2 mb-3">
            {% if canEdit is defined and not canEdit %}
                <button class="fa-cyber-btn fa-cyber-btn--primary" disabled title="{{ 'corporate.inheritance.cannot_edit_inherited'|trans({}, 'tenant') }}">
                    <i class="fa-icon fa-icon--ui-lock" aria-hidden="true"></i> {{ 'action.edit'|trans({}, 'messages') }}
                </button>
            {% endif %}
            {% if is_granted('ROLE_ADMIN') and (canEdit is not defined or canEdit) %}
                <form method="post" action="{{ path('app_risk_delete', {id: risk.id}) }}" class="d-inline"
                      data-controller="ui-actions"
                      data-action="submit->ui-actions#confirm"
                      data-ui-actions-message-param="{{ 'risk.delete.confirm_message'|trans({}, 'risk') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ risk.id) }}">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger"><i class="fa-icon fa-icon--ui-trash" aria-hidden="true"></i> {{ 'action.delete'|trans({}, 'messages') }}</button>
                </form>
            {% endif %}
        </div>
    {% endif %}

    {% if isInherited is defined and isInherited %}
        {{ _fa_alert.render({ variant: 'info', class: 'mb-3', title: 'corporate.inheritance.view_only_title'|trans({}, 'tenant'), body: 'corporate.inheritance.risk_inherited_message'|trans({}, 'tenant') }) }}
    {% endif %}

    {# Z.0 — Workflow pending action banner #}
    {{ _lifecycle_pending_banner.render(workflow_info|default({})) }}

    {# Lifecycle X.3b — status chip + transition dropdown #}
    <div class="d-flex align-items-center gap-2 mb-3" data-testid="lifecycle-toolbar">
        {{ _fa_status_chip.render({ entity_class: 'App\\Entity\\Risk', status_key: risk.status ? risk.status.value : 'unknown' }) }}
        {{ _lifecycle_actions.dropdown(risk, 'risk', 'risk_lifecycle') }}
    </div>

    {# Data-Reuse: Entity Link Matrix (Junior-Finding #8 / CM-Blocker) #}
    {% include '_components/_entity_link_matrix.html.twig' with {
        source_type: 'risk',
        entity: risk,
        linked_vulnerabilities: linkedVulnerabilities|default([]),
        linked_incidents: linkedIncidents|default([])
    } only %}

    {# ISO 27001 compliant thresholds: 20/12/6 #}
    {% set riskClass = risk.inherentRiskLevel >= 20 ? 'critical' : (risk.inherentRiskLevel >= 12 ? 'high' : (risk.inherentRiskLevel >= 6 ? 'medium' : 'low')) %}

    {% embed '_components/_card.html.twig' %}
        {% block card_header %}
            <div class="card-header d-flex justify-content-between align-items-center">
                <h2>{{ 'risk.section.details'|trans({}, 'risk') }}</h2>
                <span class="{{ badge_risk(riskClass) }}">
                    {{ riskClass|upper }} ({{ risk.inherentRiskLevel }})
                </span>
            </div>
        {% endblock %}
        {% block card_body %}
            {% import '_components/_fa_alert.html.twig' as _fa_alert %}
            {% import '_components/_status_pill.html.twig' as pill %}
            {# Phase 8H.1: standardised via _detail_group component #}
            {% include '_components/_detail_group.html.twig' with {
                items: [
                    { label: 'risk.field.status'|trans({}, 'risk'), value: (risk.status ? risk.status.value : '')|upper|replace({'_': ' '}) },
                    { label: 'risk.field.created'|trans({}, 'risk'), value: risk.createdAt|date('d.m.Y') },
                    { label: 'risk.field.last_review'|trans({}, 'risk'), value: risk.reviewDate ? risk.reviewDate|date('d.m.Y') : ('risk.not_reviewed'|trans({}, 'risk')) }
                ]
            } only %}

            {% if risk.description %}
                <div class="detail-section">
                    <h3>{{ 'risk.section.description'|trans({}, 'risk') }}</h3>
                    <p>{{ risk.description }}</p>
                </div>
            {% endif %}

            {# ISMS Risk-Score-Cards (Aurora-Pattern, replaces hand-rolled risk-matrix-mini) #}
            {% set inherentLevel = risk.inherentRiskLevel >= 20 ? 5 : (risk.inherentRiskLevel >= 12 ? 4 : (risk.inherentRiskLevel >= 8 ? 3 : (risk.inherentRiskLevel >= 4 ? 2 : 1))) %}
            <div class="risk-assessment-grid">
                <div class="assessment-card">
                    <h3>{{ 'risk.assessment.inherent_risk'|trans({}, 'risk') }}</h3>
                    <div class="isms-risk-score" data-level="{{ inherentLevel }}">
                        <div class="isms-risk-score__value">{{ risk.inherentRiskLevel }}</div>
                        <div class="isms-risk-score__components">
                            <div class="isms-risk-score__component">
                                <span class="isms-risk-score__component-label">{{ 'risk.assessment.probability'|trans({}, 'risk') }}</span>
                                <span class="isms-risk-score__component-value">{{ risk.probability }}/5</span>
                            </div>
                            <div class="isms-risk-score__component">
                                <span class="isms-risk-score__component-label">{{ 'risk.assessment.impact'|trans({}, 'risk') }}</span>
                                <span class="isms-risk-score__component-value">{{ risk.impact }}/5</span>
                            </div>
                            <div class="isms-risk-score__level">{{ riskClass }}</div>
                        </div>
                    </div>
                </div>

                {% if risk.residualProbability and risk.residualImpact %}
                {# ISO 27001 compliant thresholds: 20/12/6 #}
                {% set residualClass = risk.residualRiskLevel >= 20 ? 'critical' : (risk.residualRiskLevel >= 12 ? 'high' : (risk.residualRiskLevel >= 6 ? 'medium' : 'low')) %}
                {% set residualLevel = risk.residualRiskLevel >= 20 ? 5 : (risk.residualRiskLevel >= 12 ? 4 : (risk.residualRiskLevel >= 8 ? 3 : (risk.residualRiskLevel >= 4 ? 2 : 1))) %}
                <div class="assessment-card">
                    <h3>{{ 'risk.assessment.residual_risk'|trans({}, 'risk') }}</h3>
                    <div class="isms-risk-score" data-level="{{ residualLevel }}">
                        <div class="isms-risk-score__value">{{ risk.residualRiskLevel }}</div>
                        <div class="isms-risk-score__components">
                            <div class="isms-risk-score__component">
                                <span class="isms-risk-score__component-label">{{ 'risk.assessment.probability'|trans({}, 'risk') }}</span>
                                <span class="isms-risk-score__component-value">{{ risk.residualProbability }}/5</span>
                            </div>
                            <div class="isms-risk-score__component">
                                <span class="isms-risk-score__component-label">{{ 'risk.assessment.impact'|trans({}, 'risk') }}</span>
                                <span class="isms-risk-score__component-value">{{ risk.residualImpact }}/5</span>
                            </div>
                            <div class="isms-risk-score__level">{{ residualClass }}</div>
                        </div>
                    </div>
                </div>
                {% endif %}
            </div>

            <div class="detail-section">
                <h3>{{ 'risk.section.treatment_strategy'|trans({}, 'risk') }}</h3>
                <p><strong>{{ (risk.treatmentStrategy ? risk.treatmentStrategy.value : '')|upper|replace({'_': ' '}) }}</strong></p>

                {% if risk.reviewDate %}
                    <p>{{ 'risk.field.next_review'|trans({}, 'risk') }}: {{ risk.reviewDate|date('d.m.Y') }}</p>
                {% endif %}
            </div>

            {# Data Reuse: Risk Owner #}
            {% if risk.effectiveRiskOwner %}
                <div class="detail-section">
                    <h3>{{ 'risk.section.risk_owner'|trans({}, 'risk') }}</h3>
                    <p><strong>{{ risk.effectiveRiskOwner }}</strong>{% if risk.riskOwner %} ({{ risk.riskOwner.email }}){% endif %}</p>
                </div>
            {% endif %}

            {# Data Reuse: Mitigating Controls #}
            {% if risk.controls is defined and risk.controls|length > 0 %}
                <div class="detail-section">
                    <h3>{{ 'risk.section.mitigating_controls'|trans({}, 'risk') }} ({{ risk.controls|length }})</h3>
                    <div class="controls-list">
                        {% for control in risk.controls %}
                            <div class="control-item">
                                {% include '_components/_iso_reference_label.html.twig' with { control: control, code_class: 'fw-bold' } only %}
                                <span class="{{ badge_status(control.implementationStatus) }}">
                                    {{ control.implementationStatus|upper }}
                                </span>
                                <small>({{ control.implementationPercentage }}%)</small>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# Data Reuse: Realized Risks (Incidents) #}
            {% if risk.incidents is defined and risk.incidents|length > 0 %}
                <div class="detail-section">
                    <h3>{{ 'risk.section.realization_history'|trans({}, 'risk') }} ({{ risk.incidents|length }} {{ 'risk.incidents'|trans({}, 'risk') }})</h3>
                    {{ _fa_alert.render({ variant: 'warning', body: '<strong>' ~ 'risk.realization.warning'|trans({'%count%': risk.incidents|length}, 'risk') ~ '</strong> ' ~ 'risk.realization.review_suggestion'|trans({}, 'risk') }) }}
                    <div class="incidents-list">
                        {% for incident in risk.incidents %}
                            <div class="incident-item">
                                <strong>{{ incident.title }}</strong>
                                <span class="{{ badge_severity(incident.severity) }}">
                                    {{ incident.severity ? incident.severity.value|upper : '' }}
                                </span>
                                <small>{{ incident.detectedAt|date('Y-m-d') }}</small>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# V3 W2-FV-2 — Unified "All linked Assets" overview.
               Aggregates the primary risk-subject asset and every
               ictAssetDependency entry into a single explorable list so
               the auditor can see EVERY asset behind the risk at a
               glance, including the maximum CIA Schutzbedarf. #}
            {% set _all_linked_assets = [] %}
            {% if risk.asset %}
                {% set _all_linked_assets = _all_linked_assets|merge([risk.asset]) %}
            {% endif %}
            {% if risk.ictAssetDependency is defined %}
                {% for ictAsset in risk.ictAssetDependency %}
                    {% if ictAsset.id not in _all_linked_assets|map(a => a.id) %}
                        {% set _all_linked_assets = _all_linked_assets|merge([ictAsset]) %}
                    {% endif %}
                {% endfor %}
            {% endif %}
            {% if _all_linked_assets|length > 1 %}
                <div class="detail-section">
                    <h3>
                        <i class="fa-icon fa-icon--nav-cpu" aria-hidden="true"></i>
                        {{ 'risk.section.all_linked_assets'|trans({}, 'risk') }}
                        {{ pill.render(_all_linked_assets|length, 'primary', {size: 'sm', class: 'ms-2', noDot: true}) }}
                    </h3>
                    <p class="text-muted small mb-3">{{ 'risk.section.all_linked_assets_help'|trans({}, 'risk') }}</p>
                    <div class="row g-2">
                        {% for a in _all_linked_assets %}
                            {% set _max_cia = max(a.confidentialityValue|default(0), a.integrityValue|default(0), a.availabilityValue|default(0)) %}
                            {% set _cia_class = _max_cia >= 4 ? 'danger' : (_max_cia == 3 ? 'warning' : 'secondary') %}
                            <div class="col-md-6">
                                <div class="card fa-section h-100">
                                    <div class="card-body py-2 px-3">
                                        <div class="d-flex align-items-center justify-content-between gap-2">
                                            <a href="{{ path('app_asset_show', {id: a.id}) }}" class="text-decoration-none flex-grow-1">
                                                <strong>{{ a.name }}</strong>
                                            </a>
                                            {{ pill.render('CIA ' ~ _max_cia ~ '/5', _cia_class == 'danger' ? 'danger' : (_cia_class == 'warning' ? 'warning' : 'neutral'), {size: 'sm'}) }}
                                        </div>
                                        <small class="text-muted d-block">
                                            {% if a.assetType %}{{ a.assetType }}{% endif %}
                                            {% if a.dataClassification %} · {{ a.dataClassification }}{% endif %}
                                        </small>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# Risk Subject: Asset, Person, Location, or Supplier #}
            {% if risk.asset or risk.person or risk.location or risk.supplier %}
                <div class="detail-section">
                    <h3>
                        <i class="fa-icon fa-icon--nav-bullseye" aria-hidden="true"></i>
                        {{ 'risk.section.risk_subject'|trans({}, 'risk') }}
                        {% include '_components/_badge.html.twig' with { variant: 'secondary', class: 'ms-2', content: risk.riskSubjectType|upper } %}
                    </h3>

                    {% if risk.asset %}
                        <div class="subject-info card fa-section mb-3">
                            <div class="card-header">
                                <i class="fa-icon fa-icon--nav-cpu text-primary" aria-hidden="true"></i> {{ 'asset.title'|trans({}, 'asset') }}
                            </div>
                            <div class="card-body">
                                <div class="fw-bold fs-5">{{ risk.asset.name }}</div>
                                <p><strong>{{ 'asset.field.type'|trans({}, 'asset') }}:</strong> {{ risk.asset.assetType }}</p>
                                {% if risk.asset.monetaryValue %}
                                    <p><strong>{{ 'asset.field.monetary_value'|trans({}, 'asset') }}:</strong> €{{ risk.asset.monetaryValue|number_format(2, ',', '.') }}</p>
                                    {{ _fa_alert.render({ variant: 'info', class: 'mb-0', body: '<small>' ~ 'risk.subject.asset.monetary_value_hint'|trans({}, 'risk') ~ '</small>' }) }}
                                {% endif %}
                                {% if risk.asset.dataClassification %}
                                    <p><strong>{{ 'asset.field.classification'|trans({}, 'asset') }}:</strong>
                                        <span class="{{ badge_classification(risk.asset.dataClassification) }}">
                                            {{ ('asset.classification.' ~ risk.asset.dataClassification|lower)|trans({}, 'asset') }}
                                        </span>
                                    </p>
                                {% endif %}
                                <a href="{{ path('app_asset_show', {id: risk.asset.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                    <i class="fa-icon fa-icon--util-external-link" aria-hidden="true"></i> {{ 'asset.action.view_details'|trans({}, 'asset') }}
                                </a>
                            </div>
                        </div>
                    {% endif %}

                    {% if risk.person %}
                        <div class="subject-info card fa-section mb-3">
                            <div class="card-header">
                                <i class="fa-icon fa-icon--ui-person text-info" aria-hidden="true"></i> {{ 'person.title'|trans({}, 'messages') }}
                            </div>
                            <div class="card-body">
                                <div class="fw-bold fs-5">{{ risk.person.fullName }}</div>
                                {% if risk.person.email %}
                                    <p><strong>{{ 'person.field.email'|trans({}, 'messages') }}:</strong> <a href="mailto:{{ risk.person.email }}">{{ risk.person.email }}</a></p>
                                {% endif %}
                                {% if risk.person.department %}
                                    <p><strong>{{ 'person.field.department'|trans({}, 'messages') }}:</strong> {{ risk.person.department }}</p>
                                {% endif %}
                                <a href="{{ path('app_person_show', {id: risk.person.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                    <i class="fa-icon fa-icon--util-external-link" aria-hidden="true"></i> {{ 'person.action.view_details'|trans({}, 'messages') }}
                                </a>
                            </div>
                        </div>
                    {% endif %}

                    {% if risk.location %}
                        <div class="subject-info card fa-section mb-3">
                            <div class="card-header">
                                <i class="fa-icon fa-icon--nav-location text-warning" aria-hidden="true"></i> {{ 'location.title'|trans({}, 'locations') }}
                            </div>
                            <div class="card-body">
                                <div class="fw-bold fs-5">{{ risk.location.name }}</div>
                                {% if risk.location.address %}
                                    <p><strong>{{ 'location.field.address'|trans({}, 'locations') }}:</strong> {{ risk.location.address }}</p>
                                {% endif %}
                                {% if risk.location.city and risk.location.country %}
                                    <p><strong>{{ 'risk.subject.location.city_country'|trans({}, 'risk') }}:</strong> {{ risk.location.city }}, {{ risk.location.country }}</p>
                                {% endif %}
                                <a href="{{ path('app_location_show', {id: risk.location.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                    <i class="fa-icon fa-icon--util-external-link" aria-hidden="true"></i> {{ 'location.action.view_details'|trans({}, 'locations') }}
                                </a>
                            </div>
                        </div>
                    {% endif %}

                    {% if risk.supplier %}
                        <div class="subject-info card fa-section mb-3">
                            <div class="card-header">
                                <i class="fa-icon fa-icon--nav-truck fa-icon--success" aria-hidden="true"></i> {{ 'supplier.title'|trans({}, 'suppliers') }}
                            </div>
                            <div class="card-body">
                                <div class="fw-bold fs-5">{{ risk.supplier.name }}</div>
                                {% if risk.supplier.contactEmail %}
                                    <p><strong>{{ 'supplier.field.contact'|trans({}, 'suppliers') }}:</strong> <a href="mailto:{{ risk.supplier.contactEmail }}">{{ risk.supplier.contactEmail }}</a></p>
                                {% endif %}
                                {% if risk.supplier.riskLevel %}
                                    <p><strong>{{ 'supplier.field.risk_level'|trans({}, 'suppliers') }}:</strong>
                                        <span class="{{ badge_risk(risk.supplier.riskLevel) }}">
                                            {{ risk.supplier.riskLevel|upper }}
                                        </span>
                                    </p>
                                {% endif %}
                                <a href="{{ path('app_supplier_show', {id: risk.supplier.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                    <i class="fa-icon fa-icon--util-external-link" aria-hidden="true"></i> {{ 'supplier.action.view_details'|trans({}, 'suppliers') }}
                                </a>
                            </div>
                        </div>
                    {% endif %}
                </div>
            {% endif %}

            {# ICT Asset Dependencies (DORA Art. 8 + ISO 27001 A.5.9) — gated on nis2_dora #}
            {% if is_module_active('nis2_dora') and risk.ictAssetDependency is defined and risk.ictAssetDependency|length > 0 %}
                <div class="detail-section">
                    <h3>
                        <i class="fa-icon fa-icon--cpu" aria-hidden="true"></i>
                        {{ 'risk.section.ict_dependencies'|trans({}, 'risk') }}
                        {{ pill.render(risk.ictAssetDependency|length, 'primary', {size: 'sm', class: 'ms-2', noDot: true}) }}
                    </h3>
                    <p class="text-muted small mb-3">{{ 'risk.section.ict_dependencies_help'|trans({}, 'risk') }}</p>
                    <div class="row g-2">
                        {% for ictAsset in risk.ictAssetDependency %}
                            <div class="col-md-6">
                                <div class="card fa-section h-100">
                                    <div class="card-body py-2 px-3">
                                        <div class="d-flex align-items-center justify-content-between gap-2">
                                            <a href="{{ path('app_asset_show', {id: ictAsset.id}) }}" class="text-decoration-none flex-grow-1">
                                                <strong>{{ ictAsset.name }}</strong>
                                            </a>
                                            {% if ictAsset.assetType is defined and ictAsset.assetType %}
                                                {{ pill.render(ictAsset.assetType, 'neutral', {size: 'sm'}) }}
                                            {% endif %}
                                        </div>
                                        {% if ictAsset.dataClassification is defined and ictAsset.dataClassification %}
                                            <small class="text-muted d-block">{{ 'asset.field.data_classification'|trans({}, 'assets') }}: {{ ictAsset.dataClassification }}</small>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# Risk Treatment Plans (ISO 27005:2022 + ISO 27001 Cl.6.1.3) #}
            {% if treatmentPlans is defined and treatmentPlans|length > 0 %}
                <div class="detail-section">
                    <h3>
                        <i class="fa-icon fa-icon--nav-clipboard-check" aria-hidden="true"></i>
                        {{ 'risk.section.treatment_plans'|trans({}, 'risk') }}
                        {{ pill.render(treatmentPlans|length, 'primary', {size: 'sm', class: 'ms-2', noDot: true}) }}
                    </h3>
                    <p class="text-muted small mb-3">{{ 'risk.section.treatment_plans_help'|trans({}, 'risk') }}</p>
                    {% set _status_variants = {
                        'planned': 'secondary', 'in_progress': 'info',
                        'completed': 'success', 'cancelled': 'danger', 'on_hold': 'warning'
                    } %}
                    <div class="d-flex flex-column gap-2">
                        {% for plan in treatmentPlans %}
                            <div class="card fa-section">
                                <div class="card-body py-2 px-3">
                                    <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                                        <a href="{{ path('app_risk_treatment_plan_show', {id: plan.id}) }}" class="text-decoration-none">
                                            <strong>{{ plan.title }}</strong>
                                        </a>
                                        <div class="d-flex gap-2 align-items-center">
                                            {% set _v = _status_variants[plan.status]|default('secondary') %}
                                            {{ pill.render(('risk_treatment_plan.status.' ~ plan.status)|trans({}, 'risk_treatment_plan'), _v == 'info' ? 'primary' : (_v == 'secondary' ? 'neutral' : _v)) }}
                                            {% if plan.priority is defined and plan.priority %}
                                                {{ pill.render(plan.priority|upper, 'warning', {size: 'sm'}) }}
                                            {% endif %}
                                            {% if plan.targetCompletionDate is defined and plan.targetCompletionDate %}
                                                <small class="text-muted">
                                                    <i class="fa-icon fa-icon--ui-calendar" aria-hidden="true"></i>
                                                    {{ plan.targetCompletionDate|date('Y-m-d') }}
                                                </small>
                                            {% endif %}
                                        </div>
                                    </div>
                                    {% if plan.description %}
                                        <small class="text-muted d-block mt-1">{{ plan.description|u.truncate(140, '…') }}</small>
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                    <div class="mt-3">
                        <a href="{{ path('app_risk_treatment_plan_new', {risk: risk.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                            <i class="fa-icon fa-icon--ui-plus" aria-hidden="true"></i>
                            {{ 'risk_treatment_plan.action.new'|trans({}, 'risk_treatment_plan') }}
                        </a>
                    </div>
                </div>
            {% endif %}

            {# Risk History: Audit Log #}
            {% if auditLogs is defined and auditLogs|length > 0 %}
                <div class="detail-section">
                    <h3>{{ 'risk.section.history'|trans({}, 'risk') }} ({{ totalAuditLogs }} {{ 'audit_log.entries'|trans({}, 'audit_log') }})</h3>
                    <div class="fa-audit-feed">
                        {% for log in auditLogs %}
                            <div class="fa-audit-row{% if log.isSealed is defined and log.isSealed %} fa-audit-row--sealed{% endif %}">
                                <span class="fa-audit-row__ts">{{ log.createdAt|date('Y-m-d H:i:s') }}</span>
                                <span class="fa-audit-row__sev fa-audit-row__sev--{% if log.action in ['create', 'read'] %}info{% elseif log.action == 'update' %}warning{% elseif log.action in ['error', 'failed'] %}danger{% else %}critical{% endif %}"></span>
                                <span class="fa-audit-row__actor">{{ log.userName|default('System') }}</span>
                                <span class="fa-audit-row__action">{{ log.action|upper }}</span>
                                <span class="fa-audit-row__target">{{ log.entityType|default('Risk') }}#{{ log.entityId|default('') }}</span>
                                <span class="fa-audit-row__hash">{{ log.hash is defined ? log.hash|slice(0,12) : '' }}</span>
                            </div>
                        {% endfor %}
                    </div>
                    {% if totalAuditLogs > 10 %}
                        <div class="text-center mt-3">
                            <a href="{{ path('app_audit_log_index', {entity: 'Risk', entityId: risk.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                <i class="fa-icon fa-icon--audit-trail" aria-hidden="true"></i> {{ 'action.view_all'|trans({}, 'messages') }} ({{ totalAuditLogs }})
                            </a>
                        </div>
                    {% endif %}
                </div>
            {% endif %}
        {% endblock %}
    {% endembed %}

    {# V3 B6 / EF-4: Inverse-Coverage Impact-Analyse #}
    {% include '_components/_impact_coverage.html.twig' with {
        impact: impact_coverage|default({total: 0, frameworks: []}),
        entity_label: 'risk'
    } %}

    {# F16: Risk-Incident cross-links #}
    {% include 'risk/_linked_incidents.html.twig' with {
        risk: risk,
        riskIncidentLinks: riskIncidentLinks|default([])
    } only %}

    {# V3 W2-H3: Comment-Thread adoption (C7 macro). #}
    {% include '_components/_isms_comment_thread.html.twig' with {
        comments: comments|default([]),
        entityType: 'Risk',
        entityId: risk.id,
        showForm: canEdit is not defined or canEdit,
        formAction: path('app_comment_post', {entityType: 'Risk', entityId: risk.id}),
        csrfToken: csrf_token('isms-comment')
    } only %}
</div>

