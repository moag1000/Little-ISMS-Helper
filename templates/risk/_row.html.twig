{# Single Risk table row — shared by the index and the Turbo Stream that
   replaces/appends a row after an in-modal save. The title cell opens the
   read-only detail in the fa-form-modal frame; the eye/edit actions do the
   same. The edit action is gated on ROLE_USER, matching the full-page index
   behaviour (the server enforces the inherited-risk guard in edit()). #}
{% trans_default_domain 'risk' %}
{% import '_macros/inheritance_badge.html.twig' as inheritance %}
{% set currentTenant = currentTenant|default(null) %}
{% set riskScore = risk.getRiskScore() %}
{% set residual = risk.getResidualRiskLevel() %}
<tr id="risk-row-{{ risk.id }}"
    data-risk-id="{{ risk.id }}"
    data-risk-level="{{ riskScore >= 20 ? 'critical' : (riskScore >= 12 ? 'high' : (riskScore >= 6 ? 'medium' : 'low')) }}">
    <td class="bulk-select-column">
        <input type="checkbox"
               class="form-check-input"
               data-bulk-actions-target="item"
               data-action="bulk-actions#selectItem"
               value="{{ risk.id }}"
               aria-label="{{ 'common.select'|trans({}, 'messages') }} {{ risk.title }}">
    </td>
    <td>
        <a href="{{ path('app_risk_show', {id: risk.id}) }}" data-turbo-frame="fa-form-modal" class="fa-row-link"><strong>{{ risk.title }}</strong></a>
        {{ inheritance.small_badge(risk, currentTenant) }}
        {% if risk.description %}
        <br><small class="text-muted">{{ risk.description|length > 60 ? risk.description|slice(0, 60) ~ '...' : risk.description }}</small>
        {% endif %}
    </td>
    <td>
        {% include '_components/_badge.html.twig' with { variant: 'secondary', content: risk.threat } %}
    </td>
    <td class="text-center">
        <span class="{{ badge_score(risk.probability) }}">
            {{ risk.probability }}/5
        </span>
    </td>
    <td class="text-center">
        <span class="{{ badge_score(risk.impact) }}">
            {{ risk.impact }}/5
        </span>
    </td>
    <td class="text-center">
        <span class="risk-score risk-score-{{ riskScore >= 20 ? 'critical' : (riskScore >= 12 ? 'high' : (riskScore >= 6 ? 'medium' : 'low')) }}">
            {{ riskScore }}
        </span>
    </td>
    <td class="text-center">
        {% if residual < riskScore %}
            <span class="risk-score risk-score-improved">
                {{ residual }}
                <i class="fa-icon fa-icon--util-arrow-down text-success" aria-hidden="true"></i>
            </span>
        {% else %}
            <span class="risk-score">{{ residual }}</span>
        {% endif %}
    </td>
    <td>
        {% if risk.treatmentStrategy %}
            {% include '_components/_badge.html.twig' with { variant: 'info', content: ('risk.index.treatment.' ~ risk.treatmentStrategy.value)|trans({}, 'risk') } %}
        {% else %}
            <span class="text-muted">{{ 'risk.index.table.not_defined'|trans({}, 'risk') }}</span>
        {% endif %}
    </td>
    <td class="text-center">
        {% if risk.asset %}
            <a href="{{ path('app_asset_show', {id: risk.asset.id}) }}" class="fa-status-pill fa-status-pill--primary" title="{{ risk.asset.name }}">
                <i class="fa-icon fa-icon--nav-cpu" aria-hidden="true"></i> {{ 'risk.index.table.asset'|trans({}, 'risk') }}
            </a>
        {% elseif risk.person %}
            <a href="{{ path('app_person_show', {id: risk.person.id}) }}" class="fa-status-pill fa-status-pill--primary" title="{{ risk.person.fullName }}">
                <i class="fa-icon fa-icon--ui-person" aria-hidden="true"></i> {{ 'risk.index.table.person'|trans({}, 'risk') }}
            </a>
        {% elseif risk.location %}
            <a href="{{ path('app_location_show', {id: risk.location.id}) }}" class="fa-status-pill fa-status-pill--warning" title="{{ risk.location.name }}">
                <i class="fa-icon fa-icon--nav-location" aria-hidden="true"></i> {{ 'risk.index.table.location'|trans({}, 'risk') }}
            </a>
        {% elseif risk.supplier %}
            <a href="{{ path('app_supplier_show', {id: risk.supplier.id}) }}" class="fa-status-pill fa-status-pill--success" title="{{ risk.supplier.name }}">
                <i class="fa-icon fa-icon--nav-process" aria-hidden="true"></i> {{ 'risk.index.table.supplier'|trans({}, 'risk') }}
            </a>
        {% else %}
            {% include '_components/_badge.html.twig' with { variant: 'secondary', content: 'risk.index.table.none'|trans({}, 'risk') } %}
        {% endif %}
    </td>
    <td class="text-center">
        <div class="btn-group btn-group-sm" role="group" aria-label="{{ 'common.actions'|trans({}, 'messages') }}">
            <a href="{{ path('app_risk_show', {id: risk.id}) }}"
               class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
               data-turbo-frame="fa-form-modal"
               title="{{ 'common.view'|trans({}, 'messages') }}" aria-label="{{ 'common.view'|trans({}, 'messages') }}">
                <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
            </a>
            {% if is_granted('ROLE_USER') %}
            <a href="{{ path('app_risk_edit', {id: risk.id}) }}"
               class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
               data-turbo-frame="fa-form-modal"
               title="{{ 'common.edit'|trans({}, 'messages') }}" aria-label="{{ 'common.edit'|trans({}, 'messages') }}">
                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
            </a>
            {% endif %}
        </div>
    </td>
</tr>
