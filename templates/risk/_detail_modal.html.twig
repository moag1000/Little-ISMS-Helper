{# Risk read-only detail — rendered inside the fa-form-modal Turbo Frame.
   Uses the drawer chrome (header/body/footer/kv) which renders cleanly as a
   flex column; condensed, with a "Vollansicht" link to the full page.
   Edit button is gated on BOTH the canEdit domain flag (inherited risks are not
   editable) AND is_granted — when locked it renders as a disabled control. #}
{% trans_default_domain 'risk' %}
{% set riskScore = risk.getRiskScore() %}
{% set residual = risk.getResidualRiskLevel() %}
{% set _band = riskScore >= 20 ? 'critical' : (riskScore >= 12 ? 'high' : (riskScore >= 6 ? 'medium' : 'low')) %}
{% set _band_variant = {'critical':'danger','high':'warning','medium':'warning','low':'success'}[_band]|default('secondary') %}
{% set canEdit = canEdit|default(false) %}
<turbo-frame id="fa-form-modal">
    <div class="fa-drawer__header">
        <div class="fa-drawer__header-text">
            <div class="fa-drawer__eyebrow">ISO 27001 Cl. 6.1.2 · Risk Assessment</div>
            <div class="fa-drawer__title">{{ risk.title }}</div>
        </div>
        <button type="button" class="fa-drawer__close" data-action="fa-form-modal#close"
                aria-label="{{ 'common.close'|trans({}, 'messages') }}">
            <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i>
        </button>
    </div>
    <div class="fa-drawer__body">
        <div class="fa-drawer__section">
            {% include '_components/_badge.html.twig' with { variant: _band_variant, content: risk_level_label(_band) ~ ' · ' ~ riskScore } %}
            {% if risk.status %}
                {% include '_components/_badge.html.twig' with { variant: 'info', content: (risk.status.value)|upper|replace({'_': ' '}) } %}
            {% endif %}
        </div>

        <div class="fa-drawer__kv">
            <span class="label">{{ 'risk.field.inherent_risk'|trans({}, 'risk') }}</span>
            <span>{{ riskScore }} ({{ risk.probability }}/5 × {{ risk.impact }}/5) — {{ risk_level_label(_band) }}</span>
        </div>
        <div class="fa-drawer__kv">
            <span class="label">{{ 'risk.field.residual_risk'|trans({}, 'risk') }}</span>
            <span>{{ residual }}{% if residual < riskScore %} <i class="fa-icon fa-icon--util-arrow-down text-success" aria-hidden="true"></i>{% endif %}</span>
        </div>
        {% if risk.treatmentStrategy %}
            <div class="fa-drawer__kv">
                <span class="label">{{ 'risk.field.treatment_strategy'|trans({}, 'risk') }}</span>
                <span>{% include '_components/_badge.html.twig' with { variant: 'info', content: ('risk.index.treatment.' ~ risk.treatmentStrategy.value)|trans({}, 'risk') } %}</span>
            </div>
        {% endif %}
        {% if risk.asset %}
            <div class="fa-drawer__kv">
                <span class="label">{{ 'risk.field.asset'|trans({}, 'risk') }}</span>
                <span>{{ risk.asset.name }}</span>
            </div>
        {% endif %}
        {% if risk.riskOwner %}
            <div class="fa-drawer__kv">
                <span class="label">{{ 'risk.field.risk_owner'|trans({}, 'risk') }}</span>
                <span>{{ risk.riskOwner.fullName }}</span>
            </div>
        {% endif %}
        {% if risk.description %}
            <div class="fa-drawer__section">
                <span class="label">{{ 'risk.field.description'|trans({}, 'risk') }}</span>
                <p class="fa-drawer__desc">{{ risk.description|u.truncate(280, '…') }}</p>
            </div>
        {% endif %}
        <div class="fa-drawer__section">
            <a href="{{ path('app_risk_show', {id: risk.id}) }}" data-turbo="false" class="fa-row-link">
                {{ 'common.open_full_view'|trans({}, 'messages') }} →
            </a>
        </div>
    </div>
    <div class="fa-drawer__footer" style="display:flex;gap:10px;justify-content:flex-end">
        <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--md" data-action="fa-form-modal#close">
            <span class="fa-cyber-btn__label">{{ 'common.close'|trans({}, 'messages') }}</span>
        </button>
        {% if canEdit and is_granted('ROLE_USER') %}
            <a href="{{ path('app_risk_edit', {id: risk.id}) }}" data-turbo-frame="fa-form-modal"
               class="fa-cyber-btn fa-cyber-btn--md">
                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                <span class="fa-cyber-btn__label">{{ 'common.edit'|trans({}, 'messages') }}</span>
            </a>
        {% else %}
            <span class="fa-cyber-btn fa-cyber-btn--md" aria-disabled="true"
                  title="{{ 'corporate.inheritance.cannot_edit_inherited'|trans({}, 'messages') }}"
                  style="opacity:.5;pointer-events:none">
                <i class="fa-icon fa-icon--ui-lock" aria-hidden="true"></i>
                <span class="fa-cyber-btn__label">{{ 'common.edit'|trans({}, 'messages') }}</span>
            </span>
        {% endif %}
    </div>
</turbo-frame>
