{# Shared Risk form body (outline-rail). Used full-page by new/edit and inside
   the fa-form-modal frame (modal: true). Caller wraps it in form_start/form_end
   and passes title / submit_label / actions. The live mini-heatmap and the GDPR
   section (privacy-module-gated) are preserved across all three call-sites. #}
{% trans_default_domain 'risk' %}
{% set modal = modal|default(false) %}
{% set title = title|default(risk is defined and risk and risk.title ? risk.title : ('risk.new'|trans({}, 'risk'))) %}
{% set submit_label = submit_label|default('common.save'|trans({}, 'messages')) %}

{# Build sections map dynamically — GDPR section only when 'privacy' module is active (T31/S2-P6). #}
{% set form_sections = {
    'basic_info': {
        'label': 'risk.section.basic_info'|trans({}, 'risk'),
        'fields': ['title', 'asset', 'description', 'threat', 'vulnerability', 'category', 'person', 'location', 'supplier', 'threatIntelligence', 'linkedVulnerability']
    }
} %}
{% if is_module_active('privacy') %}
    {% set form_sections = form_sections|merge({
        'gdpr_assessment': {
            'label': 'risk.section.gdpr_assessment'|trans({}, 'risk'),
            'fields': ['involvesPersonalData', 'involvesSpecialCategoryData', 'legalBasis', 'processingScale', 'requiresDPIA', 'dataSubjectImpact']
        }
    }) %}
{% endif %}
{% set form_sections = form_sections|merge({
    'inherent_risk': {
        'label': 'risk.section.inherent_risk'|trans({}, 'risk'),
        'intro': 'risk.section.inherent_risk_intro'|trans({}, 'risk'),
        'fields': ['probability', 'impact', 'likelihoodJustification', 'impactJustification']
    },
    'residual_risk': {
        'label': 'risk.section.residual_risk'|trans({}, 'risk'),
        'intro': 'risk.section.residual_risk_intro'|trans({}, 'risk'),
        'fields': ['residualProbability', 'residualImpact']
    },
    'treatment': {
        'label': 'risk.section.treatment'|trans({}, 'risk'),
        'fields': ['treatmentStrategy', 'riskOwner', 'riskOwnerPerson', 'riskOwnerDeputyPersons', 'treatmentDescription']
    },
    'acceptance': {
        'label': 'risk.section.acceptance'|trans({}, 'risk'),
        'fields': ['acceptanceApprovedByUser', 'acceptanceApprovedBy', 'acceptanceApprovedAt', 'acceptanceExpiryDate', 'acceptanceJustification', 'decisionRationale', 'decisionApprovedByUser', 'decisionApprovalDate', 'status', 'reviewDate']
    }
}) %}

{# T6.8 — Live mini-heatmap; rendered here so it can be passed via extras_before_actions #}
{% set _risk_live_matrix %}
<div class="row mt-3">
    <div class="col-md-6">
        {% include '_components/_fa_risk_mini_heatmap.html.twig' with {
            probability_selector: '#risk_probability',
            impact_selector: '#risk_impact',
            residual: false,
        } %}
    </div>
    <div class="col-md-6">
        {% include '_components/_fa_risk_mini_heatmap.html.twig' with {
            probability_selector: '#risk_residualProbability',
            impact_selector: '#risk_residualImpact',
            residual: true,
        } %}
    </div>
</div>
{% endset %}

{% include '_components/_auto_form.html.twig' with {
    'form': form,
    'layout': 'outline-rail',
    'modal': modal,
    'eyebrow': 'ISO 27001 Cl. 6.1.2 · Risk Assessment',
    'title': title,
    'sections': form_sections,
    'extras_before_actions': _risk_live_matrix,
    'col_widths': {
        'title': 6,
        'asset': 6,
        'description': 12,
        'threat': 6,
        'vulnerability': 6,
        'category': 6,
        'person': 6,
        'location': 6,
        'supplier': 6,
        'threatIntelligence': 6,
        'linkedVulnerability': 6,
        'involvesPersonalData': 6,
        'involvesSpecialCategoryData': 6,
        'legalBasis': 6,
        'processingScale': 6,
        'requiresDPIA': 6,
        'dataSubjectImpact': 12,
        'probability': 6,
        'impact': 6,
        'likelihoodJustification': 12,
        'impactJustification': 12,
        'residualProbability': 6,
        'residualImpact': 6,
        'treatmentStrategy': 6,
        'riskOwner': 6,
        'riskOwnerPerson': 6,
        'riskOwnerDeputyPersons': 12,
        'treatmentDescription': 12,
        'acceptanceApprovedByUser': 6,
        'acceptanceApprovedBy': 6,
        'acceptanceApprovedAt': 6,
        'acceptanceExpiryDate': 6,
        'acceptanceJustification': 12,
        'decisionRationale': 12,
        'decisionApprovedByUser': 6,
        'decisionApprovalDate': 6,
        'status': 6,
        'reviewDate': 6
    },
    'tooltips': {
        'probability': 'risk.tooltip.probability',
        'impact': 'risk.tooltip.impact',
        'residualProbability': 'risk.tooltip.residual_probability',
        'residualImpact': 'risk.tooltip.residual_impact',
        'treatmentStrategy': 'risk.tooltip.treatment_strategy',
        'category': 'risk.tooltip.category',
        'involvesPersonalData': 'risk.tooltip.involves_personal_data',
        'requiresDPIA': 'risk.tooltip.requires_dpia',
        'legalBasis': 'risk.tooltip.legal_basis',
        'processingScale': 'risk.tooltip.processing_scale',
        'dataSubjectImpact': 'risk.tooltip.data_subject_impact'
    },
    'translation_domain': 'risk',
    'actions': actions|default({
        'close': { 'label': 'common.cancel'|trans({}, 'messages'), 'variant': 'ghost' },
        'submit': { 'label': submit_label, 'variant': 'primary' }
    })
} %}
