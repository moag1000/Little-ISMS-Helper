{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_norm_bridge.html.twig' as _fa_norm_bridge %}
{% trans_default_domain 'risk' %}

{% block title %}{{ 'risk.new'|trans({}, 'risk')}} - {{ parent() }}{% endblock %}

{% block body %}
{# Breadcrumb Navigation #}
{% include '_components/_breadcrumb.html.twig' with {
    breadcrumbs: [
        { label: 'nav.risks'|trans({}, 'nav'), url: path('app_risk_index'), icon: 'status-warning' },
        { label: 'risk.new'|trans({}, 'risk')}
    ]
} %}

{# Page Header #}
{{ _fa_page_header.render({
    title: 'risk.new'|trans({}, 'risk'),
    badge: { icon: 'plus', label: '' },
    actions: [
        { label: 'common.back'|trans({}, 'messages'), href: path('app_risk_index'), variant: 'secondary', icon: 'util-arrow-left' }
    ]
}) }}

{# 9001-bridge for users with previousQmsBackground = iso_9001. P-12 rollout. #}
{{ _fa_norm_bridge.render({
    from_norm: 'ISO 27001 6.1',
    to_norm:   'ISO 9001 6.1 / 8.5.6',
    bridge_text: ('iso_9001_bridge.threat'|trans({}, 'risk')),
    prominence: 'subtle'
}) }}

{# ISO 27005 reference — Junior-ISB-Audit-2026-05-22 item 5.5. Always visible. #}
{{ _fa_norm_bridge.render({
    from_norm: 'ISO 27001 6.1.2',
    to_norm:   'ISO 27005',
    bridge_text: ('risk.help.iso27005'|trans({}, 'risk')),
    prominence: 'always_visible'
}) }}

{# Junior-ISB glossary intro: hover the core concepts for an inline definition
   (loaded via /api/glossary/{acronym}). Addresses the recurring
   "Bedrohung vs. Schwachstelle?" confusion. #}
{% from '_components/_fa_glossary_tooltip.html.twig' import fa_glossary_tooltip %}
<div class="text-muted small mb-3">
    {{ 'risk.help.concepts_intro'|trans({}, 'risk') }}
    {{ fa_glossary_tooltip(glossary('Bedrohung', app.request.locale)) }} ·
    {{ fa_glossary_tooltip(glossary('Schwachstelle', app.request.locale)) }} ·
    {{ fa_glossary_tooltip(glossary('Restrisiko', app.request.locale)) }}
</div>

{# P-19 — Form-Step-Inline-Hint controller. See assets/controllers/alva_hint_in_form_controller.js. #}
{{ form_start(form, {'attr': {
    'data-controller': 'alva-hint-in-form',
    'data-alva-hint-in-form-entity-type-value': 'risk',
    'data-alva-hint-in-form-form-name-value': 'risk',
    'data-alva-hint-in-form-endpoint-value': path('api_alva_hint_form_evaluate', {'entityType': 'risk'}),
    'data-alva-hint-in-form-csrf-token-value': csrf_token('alva_hint_form'),
    'data-action': 'input->alva-hint-in-form#scheduleEvaluate change->alva-hint-in-form#scheduleEvaluate',
}}) }}

{% include 'risk/_form_body.html.twig' with {
    form: form,
    title: 'risk.new'|trans({}, 'risk'),
    actions: {
        'close': { 'label': 'common.cancel'|trans({}, 'messages'), 'variant': 'ghost' },
        'submit': { 'label': 'risk.create'|trans({}, 'risk'), 'variant': 'primary' }
    }
} %}

{{ form_end(form) }}

{# Risk Assessment Guidance Helper — reference card, placed after form #}
{% embed '_components/_card.html.twig' with {class: 'mt-4'} %}
    {% block card_body %}
        <fieldset class="mb-0">
            <legend class="h3 mb-3">
                <i class="fa-icon fa-icon--ui-lightbulb" aria-hidden="true"></i>
                {{ 'risk.guidance.title'|trans({}, 'risk')}}
            </legend>

            <div class="card fa-section border-primary mb-3">
                <div class="card-header">
                    <div class="mb-0">
                        <button class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--full p-0 w-100 text-start"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#riskAssessmentGuidance"
                                aria-expanded="true"
                                aria-controls="riskAssessmentGuidance">
                            <i class="fa-icon fa-icon--nav-help text-primary" aria-hidden="true"></i>
                            {{ 'risk.guidance.title'|trans({}, 'risk')}}
                            <i class="fa-icon fa-icon--util-chevron-down float-end" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>
                <div class="collapse show" id="riskAssessmentGuidance">
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            {{ 'risk.guidance.intro'|trans({}, 'risk')}}
                        </p>

                        {# Probability Scale #}
                        <div class="fw-bold mb-2">
                            <i class="fa-icon fa-icon--risk-score" aria-hidden="true"></i>
                            {{ 'risk.guidance.probability_title'|trans({}, 'risk')}}
                        </div>
                        <div class="mb-4">
                            {% embed '_components/_table.html.twig' with {
                                'class': 'table-sm table-bordered',
                                'noMargin': true,
                                'responsive': true
                            } %}
                                {% block table_head %}
                                    <tr>
                                        <th scope="col" class="w-25">{{ 'risk.guidance.scale'|trans({}, 'risk') }}</th>
                                        <th scope="col">{{ 'risk.guidance.description'|trans({}, 'risk') }}</th>
                                    </tr>
                                {% endblock %}
                                {% block table_body %}
                                    <tr>
                                        <td><strong>1 - {{ 'risk.guidance.probability.very_unlikely'|trans({}, 'risk') }}</strong></td>
                                        <td>{{ 'risk.guidance.probability.very_unlikely_desc'|trans({}, 'risk') }}</td>
                                    </tr>
                                    <tr>
                                        <td><strong>2 - {{ 'risk.guidance.probability.unlikely'|trans({}, 'risk') }}</strong></td>
                                        <td>{{ 'risk.guidance.probability.unlikely_desc'|trans({}, 'risk') }}</td>
                                    </tr>
                                    <tr>
                                        <td><strong>3 - {{ 'risk.guidance.probability.possible'|trans({}, 'risk') }}</strong></td>
                                        <td>{{ 'risk.guidance.probability.possible_desc'|trans({}, 'risk') }}</td>
                                    </tr>
                                    <tr>
                                        <td><strong>4 - {{ 'risk.guidance.probability.likely'|trans({}, 'risk') }}</strong></td>
                                        <td>{{ 'risk.guidance.probability.likely_desc'|trans({}, 'risk') }}</td>
                                    </tr>
                                    <tr>
                                        <td><strong>5 - {{ 'risk.guidance.probability.very_likely'|trans({}, 'risk') }}</strong></td>
                                        <td>{{ 'risk.guidance.probability.very_likely_desc'|trans({}, 'risk') }}</td>
                                    </tr>
                                {% endblock %}
                            {% endembed %}
                        </div>

                        {# Impact Scale #}
                        <div class="fw-bold mb-2">
                            <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i>
                            {{ 'risk.guidance.impact_title'|trans({}, 'risk')}}
                        </div>
                        {% embed '_components/_table.html.twig' with {
                            'class': 'table-sm table-bordered',
                            'noMargin': true,
                            'responsive': true
                        } %}
                            {% block table_head %}
                                <tr>
                                    <th scope="col" class="w-25">{{ 'risk.guidance.scale'|trans({}, 'risk') }}</th>
                                    <th scope="col">{{ 'risk.guidance.description'|trans({}, 'risk') }}</th>
                                </tr>
                            {% endblock %}
                            {% block table_body %}
                                <tr>
                                    <td><strong>1 - {{ 'risk.guidance.impact.negligible'|trans({}, 'risk') }}</strong></td>
                                    <td>{{ 'risk.guidance.impact.negligible_desc'|trans({}, 'risk') }}</td>
                                </tr>
                                <tr>
                                    <td><strong>2 - {{ 'risk.guidance.impact.minor'|trans({}, 'risk') }}</strong></td>
                                    <td>{{ 'risk.guidance.impact.minor_desc'|trans({}, 'risk') }}</td>
                                </tr>
                                <tr>
                                    <td><strong>3 - {{ 'risk.guidance.impact.moderate'|trans({}, 'risk') }}</strong></td>
                                    <td>{{ 'risk.guidance.impact.moderate_desc'|trans({}, 'risk') }}</td>
                                </tr>
                                <tr>
                                    <td><strong>4 - {{ 'risk.guidance.impact.major'|trans({}, 'risk') }}</strong></td>
                                    <td>{{ 'risk.guidance.impact.major_desc'|trans({}, 'risk') }}</td>
                                </tr>
                                <tr>
                                    <td><strong>5 - {{ 'risk.guidance.impact.catastrophic'|trans({}, 'risk') }}</strong></td>
                                    <td>{{ 'risk.guidance.impact.catastrophic_desc'|trans({}, 'risk') }}</td>
                                </tr>
                            {% endblock %}
                        {% endembed %}

                        {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning', icon: 'ui-lightbulb', class: 'mt-3 mb-0' } } %}
                            {% block alert_body %}<small> <i class="fa-icon fa-icon--ui-lightbulb" aria-hidden="true"></i> {{ 'risk.guidance.tip'|trans({}, 'risk')}} </small>{% endblock %}
                        {% endembed %}
                    </div>
                </div>
            </div>
        </fieldset>
    {% endblock %}
{% endembed %}
{% endblock %}
