{% extends 'base.html.twig' %}
{% trans_default_domain 'risk' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'risk.export.progress_title'|trans({}, 'risk') }} — {{ 'risk.modern.header.title'|trans({}, 'risk') }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.risks'|trans({}, 'nav'), url: path('app_risk_index') },
            { label: 'risk.export.progress_title'|trans({}, 'risk') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'nav-download', label: 'risk.export.badge'|trans({}, 'risk') },
        title: 'risk.export.progress_title'|trans({}, 'risk'),
        subtitle: 'risk.export.progress_subtitle'|trans({}, 'risk'),
    }) }}

    {# Turbo cache disabled — live status changes every 3 s #}
    <meta name="turbo-cache-control" content="no-cache">

    <div class="row justify-content-center mt-4">
        <div class="col-lg-8 col-xl-6">
            {% include '_components/_async_job_progress.html.twig' with {
                job_id:    jobId,
                job_name:  'risk.export',
                job_label: 'risk.export.progress_title'|trans({}, 'risk'),
                cancel_url: cancelUrl,
                download_url: downloadUrl,
                download_label: 'risk.export.download_button'|trans({}, 'risk'),
            } %}

            <div class="mt-3 text-center text-muted small">
                <i class="fa-icon fa-icon--status-info" aria-hidden="true"></i>
                {{ 'admin.job.worker_hint'|trans({}, 'admin') }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
