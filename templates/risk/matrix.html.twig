{% extends 'base.html.twig' %}
{% trans_default_domain 'risk' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'risk.matrix.title'|trans({}, 'risk') }}{% endblock %}

{% block body %}
<div class="container py-4">
    {{ _fa_page_header.render({
        badge: { icon: 'shield-exclamation', label: '5 × 5' },
        title: 'risk.matrix.title'|trans({}, 'risk'),
        subtitle: 'risk.matrix.description'|trans({}, 'risk'),
        actions: [
            { label: 'risk.matrix.back_to_risks'|trans({}, 'risk'), variant: 'ghost', icon: 'arrow-left', href: path('app_risk_index') }
        ]
    }) }}

    <section class="fa-section">
        <div class="fa-section__header">
            <h2 class="ds-h3 m-0">{{ 'risk.matrix.header'|trans({}, 'risk') }}</h2>
        </div>
        <div class="fa-section__body">
            <div data-controller="riskmatrix"
                 data-riskmatrix-risks-value="{{ risks|json_encode|e('html_attr') }}">

                <div class="isms-risk-matrix" role="figure" aria-label="{{ 'risk.matrix.title'|trans({}, 'risk') }}">
                    <div class="isms-risk-matrix__y-label">{{ 'risk.matrix.impact'|trans({}, 'risk') }}</div>

                    <div class="isms-risk-matrix__grid">
                        {# Empty corner + X-Header (Probability 1..5) #}
                        <div></div>
                        {% for p in 1..5 %}
                            <div class="isms-risk-matrix__hd">
                                {{ p }}<span>{{ ('risk.matrix.probability_label.' ~ p)|trans({}, 'risk') }}</span>
                            </div>
                        {% endfor %}

                        {# Rows: Impact 5..1 (highest top) × Probability 1..5 #}
                        {% for impact in 5..1 %}
                            <div class="isms-risk-matrix__hd-y">{{ impact }}</div>
                            {% for probability in 1..5 %}
                                {% set score = probability * impact %}
                                {# 4-Tier Mapping aligned with App\Risk\RiskMatrixThresholds (SSoT, ISO 27001 Cl. 6.1.2 b).
                                   data-level 2..5 retained for CSS heat-map coloring continuity (low/medium/high/critical). #}
                                {% set level = score >= 20 ? 5 : (score >= 12 ? 4 : (score >= 6 ? 3 : 2)) %}
                                <div class="isms-risk-cell"
                                     data-level="{{ level }}"
                                     data-probability="{{ probability }}"
                                     data-impact="{{ impact }}"
                                     tabindex="0"
                                     role="button"
                                     aria-label="{{ 'risk.matrix.cell_title'|trans({'%probability%': probability, '%impact%': impact, '%score%': score}, 'risk') }}">
                                    {{ score }}
                                </div>
                            {% endfor %}
                        {% endfor %}
                    </div>

                    <div class="isms-risk-matrix__x-label">{{ 'risk.matrix.probability'|trans({}, 'risk') }}</div>

                    <div class="isms-risk-legend">
                        <span class="isms-risk-legend__chip" data-level="2">{{ 'risk.matrix.level.low'|trans({}, 'risk') }} ({{ risk_threshold('low') }})</span>
                        <span class="isms-risk-legend__chip" data-level="3">{{ 'risk.matrix.level.medium'|trans({}, 'risk') }} ({{ risk_threshold('medium') }})</span>
                        <span class="isms-risk-legend__chip" data-level="4">{{ 'risk.matrix.level.high'|trans({}, 'risk') }} ({{ risk_threshold('high') }})</span>
                        <span class="isms-risk-legend__chip" data-level="5">{{ 'risk.matrix.level.critical'|trans({}, 'risk') }} ({{ risk_threshold('critical') }})</span>
                        <span class="ms-auto fa-mono fa-text-muted small">{{ risks|length }} {{ 'risk.matrix.risks_total'|trans({}, 'risk') }}</span>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
{% endblock %}
