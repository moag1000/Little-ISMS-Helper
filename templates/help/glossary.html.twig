{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% trans_default_domain 'help' %}

{% block title %}{{ 'help.glossary.title'|trans({}, 'help') }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {# Breadcrumb Navigation #}
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.dashboard'|trans({}, 'nav'), url: path('app_dashboard') },
            { label: 'help.glossary.title'|trans({}, 'help') }
        ]
    } only %}

    {# Page Header #}
    {% include '_components/_page_header.html.twig' with {
        title: 'help.glossary.title'|trans({}, 'help'),
        subtitle: 'help.glossary.subtitle'|trans({}, 'help'),
        icon: 'bi-book'
    } only %}

    {# Introduction Card #}
    <div class="card fa-section mb-4">
        <div class="card-body">
            <div class="d-flex align-items-start">
                <i class="bi bi-lightbulb-fill text-warning me-3 fs-3" aria-hidden="true"></i>
                <div>
                    <h5 class="card-title mb-2">{{ 'help.glossary.intro_title'|trans({}, 'help') }}</h5>
                    <p class="card-text mb-0">{{ 'help.glossary.intro_text'|trans({}, 'help') }}</p>
                </div>
            </div>
        </div>
    </div>

    {# Search/Filter #}
    <div class="card fa-section mb-4" data-controller="filter">
        <div class="card-header">
            <div class="row align-items-center g-3">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-search" aria-hidden="true"></i>
                        </span>
                        <input type="text"
                               class="form-control"
                               placeholder="{{ 'help.glossary.search_placeholder'|trans({}, 'help') }}"
                               data-filter-target="searchInput"
                               data-action="input->filter#filterRows">
                    </div>
                </div>
                <div class="col-md-4">
                    <select class="form-select" data-action="change->filter#filterByCategory">
                        <option value="">{{ 'help.glossary.all_categories'|trans({}, 'help') }}</option>
                        <option value="basics">{{ 'help.glossary.category.basics'|trans({}, 'help') }}</option>
                        <option value="risk">{{ 'help.glossary.category.risk'|trans({}, 'help') }}</option>
                        <option value="compliance">{{ 'help.glossary.category.compliance'|trans({}, 'help') }}</option>
                        <option value="bcm">{{ 'help.glossary.category.bcm'|trans({}, 'help') }}</option>
                        <option value="privacy">{{ 'help.glossary.category.privacy'|trans({}, 'help') }}</option>
                        <option value="operations">{{ 'help.glossary.category.operations'|trans({}, 'help') }}</option>
                        <option value="governance">{{ 'help.glossary.category.governance'|trans({}, 'help') }}</option>
                        <option value="technical">{{ 'help.glossary.category.technical'|trans({}, 'help') }}</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-secondary w-100" data-action="click->filter#reset">
                        <i class="bi bi-x-circle me-1" aria-hidden="true"></i>
                        {{ 'help.glossary.reset'|trans({}, 'help') }}
                    </button>
                </div>
            </div>
        </div>

        <div class="card-body">
            {# ===== Grundbegriffe ===== #}
            <h4 class="mb-3 mt-2">
                <i class="bi bi-mortarboard text-primary me-2" aria-hidden="true"></i>
                {{ 'help.glossary.category.basics'|trans({}, 'help') }}
            </h4>

            <div class="accordion mb-4" id="glossaryBasics">
                {# ISMS #}
                <div class="accordion-item" data-filter-target="filterableRow" data-category="basics">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#glossary-isms" aria-expanded="false" aria-controls="glossary-isms">
                            <strong>{{ 'help.glossary.term.isms.name'|trans({}, 'help') }}</strong>
                        </button>
                    </h2>
                    <div id="glossary-isms" class="accordion-collapse collapse" data-bs-parent="#glossaryBasics">
                        <div class="accordion-body">
                            <p>{{ 'help.glossary.term.isms.definition'|trans({}, 'help') }}</p>
                            {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', icon: 'bi-arrow-left-right', class: 'mb-0' } } %}
                                {% block alert_body %}<strong>{{ 'help.glossary.analogy_label'|trans({}, 'help') }}</strong> {{ 'help.glossary.term.isms.analogy'|trans({}, 'help') }}{% endblock %}
                            {% endembed %}
                        </div>
                    </div>
                </div>

