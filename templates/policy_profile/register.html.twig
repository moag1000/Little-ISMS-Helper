{% extends 'base.html.twig' %}
{% trans_default_domain 'compliance_policy' %}

{% block body %}
<div class="container py-4">
    <h1 class="h3 mb-1">{{ 'compliance_policy.policy_profile.register.title'|trans({}, 'compliance_policy') }}</h1>
    <p class="text-muted">
        {{ 'compliance_policy.policy_profile.register.lead'|trans({}, 'compliance_policy') }}{% if frameworks is not empty %} — {{ 'compliance_policy.policy_profile.register.lead'|trans({}, 'compliance_policy') }}: <strong>{{ frameworks|join(', ')|upper }}</strong>{% endif %}.
        {{ 'compliance_policy.policy_profile.register.regulatory_hint'|trans({}, 'compliance_policy') }}
    </p>
    <table class="table table-sm">
        <thead><tr>
            <th>{{ 'compliance_policy.policy_profile.th.parameter'|trans({}, 'compliance_policy') }}</th>
            <th>{{ 'compliance_policy.policy_profile.th.value'|trans({}, 'compliance_policy') }}</th>
            <th>{{ 'compliance_policy.policy_profile.th.authority'|trans({}, 'compliance_policy') }}</th>
            <th>{{ 'compliance_policy.policy_profile.th.source'|trans({}, 'compliance_policy') }}</th>
            <th>{{ 'compliance_policy.policy_profile.th.iso_clause'|trans({}, 'compliance_policy') }}</th>
            <th>{{ 'compliance_policy.policy_profile.th.frameworks'|trans({}, 'compliance_policy') }}</th>
        </tr></thead>
        <tbody>
            {% for row in rows %}
                <tr class="{{ row.isRegulatory() ? 'table-warning' : '' }}">
                    <td>{{ row.label }}<br><small class="text-muted">{{ row.paramKey }}</small></td>
                    <td>{{ row.value }}</td>
                    <td>{% if row.authority %}<span class="badge {{ row.isRegulatory() ? 'bg-danger' : 'bg-secondary' }}">{{ row.authority }}</span>{% else %}<span class="text-muted">–</span>{% endif %}</td>
                    <td><small>{{ row.source ?? '–' }}</small></td>
                    <td><small>{{ row.isoClauses|join(', ') }}</small></td>
                    <td><small>{{ row.frameworks is not empty ? row.frameworks|join(', ')|upper : '–' }}</small></td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
    <a href="{{ path('app_policy_profile_index', {_locale: app.request.locale}) }}" class="btn btn-outline-secondary">{{ 'compliance_policy.policy_profile.register.back'|trans({}, 'compliance_policy') }}</a>
</div>
{% endblock %}
