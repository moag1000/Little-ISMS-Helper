{% extends 'base.html.twig' %}
{% trans_default_domain 'dashboards' %}

{% block title %}{{ 'risk_manager.title'|trans({}, 'dashboards') }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_kpi_card.html.twig' as _fa_kpi_card %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}

{% block body %}
<main class="fa-aurora-surface role-dashboard risk-manager-dashboard">
    {# Page Header — Aurora v4 fa-page-header #}
    {{ _fa_page_header.render({
        badge:    { icon: 'bar-chart-line', label: 'risk_manager.badge'|trans({}, 'dashboards') },
        title:    'risk_manager.title'|trans({}, 'dashboards'),
        subtitle: 'risk_manager.subtitle'|trans({}, 'dashboards'),
        actions: [
            { label: 'action.standard_dashboard'|trans({}, 'dashboards'), variant: 'ghost',   icon: 'house', href: path('app_dashboard') },
            { label: 'action.risk_register'|trans({}, 'dashboards'),      variant: 'primary', icon: 'list',  href: path('app_risk_index') }
        ]
    }) }}

    {# Phase 8H.1: Skeleton placeholder during first paint. #}
    <div data-controller="skeleton" data-skeleton-duration-value="600">
        <div data-skeleton-target="skeleton">
            {% include '_components/_skeleton.html.twig' with { type: 'kpi-grid', count: 6 } %}
        </div>

        <div data-skeleton-target="content" class="hidden">

    {# Summary KPIs — Aurora _fa_kpi_card macro #}
    <div class="row g-3 mb-4">
        <div class="col-md-2">{{ _fa_kpi_card.render({
            value: dashboard.summary.total_risks,
            label: 'risk_manager.kpi.total_risks'|trans({}, 'dashboards')
        }) }}</div>
        <div class="col-md-2">{{ _fa_kpi_card.render({
            value: dashboard.summary.high_critical,
            label: 'risk_manager.kpi.high_critical'|trans({}, 'dashboards'),
            valueDanger: true
        }) }}</div>
        <div class="col-md-2">{{ _fa_kpi_card.render({
            value: dashboard.summary.treated_percentage,
            unit: '%',
            label: 'risk_manager.kpi.treated'|trans({}, 'dashboards')
        }) }}</div>
        <div class="col-md-2">{{ _fa_kpi_card.render({
            value: dashboard.summary.overdue_treatments,
            label: 'risk_manager.kpi.overdue'|trans({}, 'dashboards'),
            valueDanger: dashboard.summary.overdue_treatments > 0
        }) }}</div>
        <div class="col-md-4">
            {% set isCompliant = dashboard.summary.appetite_status == 'compliant' %}
            <article class="fa-rag-card fa-rag-card--{{ isCompliant ? 'green' : 'red' }}">
                <h3 class="mb-0">
                    {% if isCompliant %}
                        <span class="text-success"><i class="bi bi-check-circle" aria-hidden="true"></i> {{ 'status.compliant'|trans({}, 'dashboards') }}</span>
                    {% else %}
                        <span class="text-danger"><i class="bi bi-x-circle" aria-hidden="true"></i> {{ 'status.breach'|trans({}, 'dashboards') }}</span>
                    {% endif %}
                </h3>
                <small class="fa-rag-card__detail">{{ 'risk_manager.kpi.appetite_status'|trans({}, 'dashboards') }}</small>
            </article>
        </div>
    </div>

    <div class="row g-4">
        {# Treatment Pipeline #}
        <div class="col-lg-6">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100' } %}
                {% block card_header %}
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-funnel me-2" aria-hidden="true"></i>
                            {{ 'risk_manager.section.treatment_pipeline'|trans({}, 'dashboards') }}
                        </h5>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="row text-center mb-3">
                        <div class="col">
                            <div class="p-2 bg-body-secondary rounded">
                                <h4 class="mb-0">{{ dashboard.treatment_pipeline.total }}</h4>
                                <small>{{ 'risk_manager.pipeline.total'|trans({}, 'dashboards') }}</small>
                            </div>
                        </div>
                        <div class="col">
                            <div class="p-2 bg-success bg-opacity-10 rounded">
                                <h4 class="mb-0 text-success">{{ dashboard.treatment_pipeline.treated }}</h4>
                                <small>{{ 'risk_manager.pipeline.treated'|trans({}, 'dashboards') }}</small>
                            </div>
                        </div>
                        <div class="col">
                            <div class="p-2 bg-warning bg-opacity-10 rounded">
                                <h4 class="mb-0 text-warning">{{ dashboard.treatment_pipeline.untreated }}</h4>
                                <small>{{ 'risk_manager.pipeline.untreated'|trans({}, 'dashboards') }}</small>
                            </div>
                        </div>
                    </div>
                    <div class="small fw-semibold text-muted mb-1">{{ 'risk_manager.by_strategy'|trans({}, 'dashboards') }}</div>
                    {% for strategy, count in dashboard.treatment_pipeline.by_strategy %}
                        {% if strategy != 'untreated' %}
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span>{{ ('risk.treatment.' ~ strategy)|trans({}, 'risk') }}</span>
                            {% include '_components/_badge.html.twig' with { variant: 'secondary', content: count } %}
                        </div>
                        {% endif %}
                    {% endfor %}
                {% endblock %}
            {% endembed %}
        </div>

        {# Risk Appetite #}
        <div class="col-lg-6">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100' } %}
                {% block card_header %}
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-speedometer2 me-2" aria-hidden="true"></i>
                            {{ 'risk_manager.section.risk_appetite'|trans({}, 'dashboards') }}
                        </h5>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="text-center mb-3">
                        <div class="display-5 {% if dashboard.risk_appetite.compliance_score >= 80 %}text-success{% elseif dashboard.risk_appetite.compliance_score >= 60 %}text-warning{% else %}text-danger{% endif %}">
                            {{ dashboard.risk_appetite.compliance_score }}%
                        </div>
                        <small class="text-muted">{{ 'risk_manager.appetite_score'|trans({}, 'dashboards') }}</small>
                    </div>
                    <div class="row text-center">
                        {% for level, data in dashboard.risk_appetite.actual %}
                        <div class="col-3">
                            <small class="d-block text-muted text-capitalize">{{ level }}</small>
                            <span class="fw-bold {% if data > (dashboard.risk_appetite.appetite[level ~ '_max'] ?? 999) %}text-danger{% endif %}">
                                {{ data }}/{{ dashboard.risk_appetite.appetite[level ~ '_max'] ?? '-' }}
                            </span>
                        </div>
                        {% endfor %}
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    <div class="row g-4 mt-2">
        {# Risks by Category #}
        <div class="col-lg-6">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100', 'noPadding': true } %}
                {% block card_header %}
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-tags me-2" aria-hidden="true"></i>
                            {{ 'risk_manager.section.by_category'|trans({}, 'dashboards') }}
                        </h5>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="table-responsive">
                        <table class="fa-data-table">
                            <thead>
                                <tr>
                                    <th scope="col">{{ 'risk_manager.table.category'|trans({}, 'dashboards') }}</th>
                                    <th scope="col" class="th--center">{{ 'risk_manager.table.total'|trans({}, 'dashboards') }}</th>
                                    <th scope="col" class="th--center">{{ 'risk_manager.table.high'|trans({}, 'dashboards') }}</th>
                                    <th scope="col" class="th--center">{{ 'risk_manager.table.critical'|trans({}, 'dashboards') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for category, data in dashboard.risks_by_category %}
                                <tr>
                                    <td>{{ category }}</td>
                                    <td class="td--center">{{ data.total }}</td>
                                    <td class="td--center">{% include '_components/_badge.html.twig' with { variant: 'warning', content: data.high } %}</td>
                                    <td class="td--center">{% include '_components/_badge.html.twig' with { variant: 'danger', content: data.critical } %}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>

        {# Risk Forecast #}
        <div class="col-lg-6">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100' } %}
                {% block card_header %}
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="bi bi-graph-up-arrow me-2" aria-hidden="true"></i>
                            {{ 'risk_manager.section.forecast'|trans({}, 'dashboards') }}
                        </h5>
                        <a href="{{ path('app_analytics_risk_forecast') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                            {{ 'action.view_details'|trans({}, 'dashboards') }}
                        </a>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="mb-3">
                        <strong>{{ 'risk_manager.velocity.label'|trans({}, 'dashboards') }}:</strong>
                        {% if dashboard.risk_velocity.trend == 'increasing' %}
                            <span class="text-danger"><i class="bi bi-arrow-up" aria-hidden="true"></i> +{{ dashboard.risk_velocity.last_30_days.net_change }}</span>
                        {% elseif dashboard.risk_velocity.trend == 'decreasing' %}
                            <span class="text-success"><i class="bi bi-arrow-down" aria-hidden="true"></i> {{ dashboard.risk_velocity.last_30_days.net_change }}</span>
                        {% else %}
                            <span class="text-secondary"><i class="bi bi-arrow-right" aria-hidden="true"></i> {{ 'trend.stable'|trans({}, 'dashboards') }}</span>
                        {% endif %}
                        <small class="text-muted">({{ 'risk_manager.last_30_days'|trans({}, 'dashboards') }})</small>
                    </div>
                    <h6>{{ 'risk_manager.next_3_months'|trans({}, 'dashboards') }}</h6>
                    {% for month in dashboard.risk_forecast.next_3_months %}
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span>{{ month.label }}</span>
                        {% include '_components/_badge.html.twig' with { variant: 'secondary', content: '~' ~ month.total ~ ' ' ~ 'risks'|trans({}, 'dashboards') } %}
                    </div>
                    {% endfor %}
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    <div class="row g-4 mt-2">
        {# Untreated Risks #}
        <div class="col-lg-6">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100', 'noPadding': true } %}
                {% block card_header %}
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="bi bi-exclamation-diamond text-warning me-2" aria-hidden="true"></i>
                            {{ 'risk_manager.section.untreated_risks'|trans({}, 'dashboards') }}
                        </h5>
                        {% include '_components/_badge.html.twig' with { variant: 'warning', content: dashboard.untreated_risks|length } %}
                    </div>
                {% endblock %}
                {% block card_body %}
                    {% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
                    {% if dashboard.untreated_risks|length > 0 %}
                    <div class="list-group list-group-flush">
                        {% for risk in dashboard.untreated_risks %}
                        <a href="{{ path('app_risk_show', {id: risk.id}) }}" class="list-group-item list-group-item-action">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1">{{ risk.title }}</h6>
                                    <small class="text-muted">{{ risk.category }}</small>
                                </div>
                                {% include '_components/_badge.html.twig' with {
                                    variant: risk.level >= 16 ? 'danger' : (risk.level >= 12 ? 'warning' : 'secondary'),
                                    content: risk.level
                                } %}
                            </div>
                        </a>
                        {% endfor %}
                    </div>
                    {% else %}
                    {{ _fa_empty_state.render({
                        mood: 'celebrating',
                        title: 'risk_manager.all_treated'|trans({}, 'dashboards')
                    }) }}
                    {% endif %}
                {% endblock %}
            {% endembed %}
        </div>

        {# Overdue Treatments #}
        <div class="col-lg-6">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100', 'noPadding': true } %}
                {% block card_header %}
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="bi bi-clock-history text-danger me-2" aria-hidden="true"></i>
                            {{ 'risk_manager.section.overdue_treatments'|trans({}, 'dashboards') }}
                        </h5>
                        {% include '_components/_badge.html.twig' with { variant: 'danger', content: dashboard.overdue_treatments|length } %}
                    </div>
                {% endblock %}
                {% block card_body %}
                    {% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
                    {% if dashboard.overdue_treatments|length > 0 %}
                    <div class="list-group list-group-flush">
                        {% for treatment in dashboard.overdue_treatments %}
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1">{{ treatment.risk_title }}</h6>
                                    <small class="text-muted">{{ 'risk_manager.target_date'|trans({}, 'dashboards') }}: {{ treatment.target_date|date('d.m.Y') }}</small>
                                </div>
                                {% include '_components/_badge.html.twig' with { variant: 'danger', content: treatment.days_overdue ~ ' ' ~ 'days'|trans({}, 'dashboards') } %}
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                    {% else %}
                    {{ _fa_empty_state.render({
                        mood: 'celebrating',
                        title: 'risk_manager.no_overdue'|trans({}, 'dashboards')
                    }) }}
                    {% endif %}
                {% endblock %}
            {% endembed %}
        </div>
    </div>

        </div>{# /skeleton-content #}
    </div>{# /skeleton-controller #}
</main>
{% endblock %}
