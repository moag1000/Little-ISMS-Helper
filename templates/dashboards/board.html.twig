{% extends 'base.html.twig' %}
{% trans_default_domain 'dashboards' %}

{% block title %}{{ 'board.title'|trans({}, 'dashboards') }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_kpi_card.html.twig' as _fa_kpi_card %}
{% import '_components/_fa_rag_card.html.twig' as _fa_rag_card %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}

{% block body %}
<main class="fa-aurora-surface role-dashboard board-dashboard">
    {# Page Header — Aurora v4 fa-page-header #}
    {{ _fa_page_header.render({
        badge:    { icon: 'briefcase', label: 'board.badge'|trans({}, 'dashboards') },
        title:    'board.title'|trans({}, 'dashboards'),
        subtitle: 'board.subtitle'|trans({}, 'dashboards'),
        actions: [
            { label: 'action.standard_dashboard'|trans({}, 'dashboards'), variant: 'ghost',   icon: 'house',       href: path('app_dashboard') },
            { label: 'action.ciso_view'|trans({}, 'dashboards'),          variant: 'primary', icon: 'shield-lock', href: path('app_dashboard_ciso') }
        ]
    }) }}

    {# Phase 8H.1: Skeleton placeholder during first paint. #}
    <div data-controller="skeleton" data-skeleton-duration-value="600">
        <div data-skeleton-target="skeleton">
            {% include '_components/_skeleton.html.twig' with { type: 'kpi-grid', count: 4 } %}
        </div>

        <div data-skeleton-target="content" class="hidden">

    {# Executive RAG Status Overview — Aurora .fa-rag-card via macro #}
    <div class="row g-3 mb-4">
        <div class="col-md-3">{{ _fa_rag_card.render({ status: dashboard.rag_status.security,    title: 'board.rag.security'|trans({}, 'dashboards'),    detail: dashboard.rag_details.security }) }}</div>
        <div class="col-md-3">{{ _fa_rag_card.render({ status: dashboard.rag_status.compliance,  title: 'board.rag.compliance'|trans({}, 'dashboards'),  detail: dashboard.rag_details.compliance }) }}</div>
        <div class="col-md-3">{{ _fa_rag_card.render({ status: dashboard.rag_status.risk,        title: 'board.rag.risk'|trans({}, 'dashboards'),        detail: dashboard.rag_details.risk }) }}</div>
        <div class="col-md-3">{{ _fa_rag_card.render({ status: dashboard.rag_status.operations,  title: 'board.rag.operations'|trans({}, 'dashboards'),  detail: dashboard.rag_details.operations }) }}</div>
    </div>

    {# Key Metrics with Trends — Aurora _fa_kpi_card macro #}
    <div class="row g-3 mb-4">
        <div class="col-md-2">{{ _fa_kpi_card.render({
            value: dashboard.metrics.overall_compliance,
            unit: '%',
            label: 'board.metric.compliance'|trans({}, 'dashboards'),
            trend: dashboard.trends.compliance,
            trendUnit: '%'
        }) }}</div>
        <div class="col-md-2">{{ _fa_kpi_card.render({
            value: dashboard.metrics.total_risks,
            label: 'board.metric.risks'|trans({}, 'dashboards'),
            trend: dashboard.trends.risks,
            trendInverse: true
        }) }}</div>
        <div class="col-md-2">{{ _fa_kpi_card.render({
            value: dashboard.metrics.critical_risks,
            label: 'board.metric.critical'|trans({}, 'dashboards'),
            trend: dashboard.trends.critical,
            trendInverse: true,
            valueDanger: dashboard.metrics.critical_risks > 0
        }) }}</div>
        <div class="col-md-2">{{ _fa_kpi_card.render({
            value: dashboard.metrics.incidents_ytd,
            label: 'board.metric.incidents'|trans({}, 'dashboards'),
            trend: dashboard.trends.incidents,
            trendInverse: true
        }) }}</div>
        <div class="col-md-2">{{ _fa_kpi_card.render({
            value: dashboard.metrics.controls_implemented,
            unit: '%',
            label: 'board.metric.controls'|trans({}, 'dashboards'),
            trend: dashboard.trends.controls,
            trendUnit: '%'
        }) }}</div>
        <div class="col-md-2">{{ _fa_kpi_card.render({
            value: dashboard.metrics.audits_completed,
            label: 'board.metric.audits'|trans({}, 'dashboards'),
            sublabel: 'board.of_planned'|trans({'%count%': dashboard.metrics.audits_planned}, 'dashboards')
        }) }}</div>
    </div>

    <div class="row g-4">
        {# Executive Summary #}
        <div class="col-lg-8">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100' } %}
                {% block card_header %}
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="fa-icon fa-icon--policy me-2" aria-hidden="true"></i>
                            {{ 'board.section.executive_summary'|trans({}, 'dashboards') }}
                        </h5>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
                    <div class="mb-4">
                        <h6 class="mb-2">{{ 'board.summary.security_posture'|trans({}, 'dashboards') }}</h6>
                        <p class="mb-0">{{ dashboard.executive_summary.security_posture }}</p>
                    </div>
                    <div class="mb-4">
                        <h6 class="mb-2">{{ 'board.summary.key_achievements'|trans({}, 'dashboards') }}</h6>
                        {% if dashboard.executive_summary.achievements|length > 0 %}
                            <ul class="mb-0">
                                {% for achievement in dashboard.executive_summary.achievements %}
                                    <li>{{ achievement }}</li>
                                {% endfor %}
                            </ul>
                        {% else %}
                            {{ _fa_empty_state.render({
                                mood: 'celebrating',
                                title: 'board.no_achievements'|trans({}, 'dashboards')
                            }) }}
                        {% endif %}
                    </div>
                    <div>
                        <h6 class="mb-2">{{ 'board.summary.key_concerns'|trans({}, 'dashboards') }}</h6>
                        {% if dashboard.executive_summary.concerns|length > 0 %}
                            <ul class="fa-issue-list">
                                {% for concern in dashboard.executive_summary.concerns %}
                                    <li class="fa-issue-list__item fa-issue-list__item--warning">{{ concern }}</li>
                                {% endfor %}
                            </ul>
                        {% else %}
                            <p class="text-success mb-0"><i class="fa-icon fa-icon--status-ok me-1" aria-hidden="true"></i>{{ 'board.no_concerns'|trans({}, 'dashboards') }}</p>
                        {% endif %}
                    </div>
                {% endblock %}
            {% endembed %}
        </div>

        {# Upcoming Milestones #}
        <div class="col-lg-4">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100', 'noPadding': true } %}
                {% block card_header %}
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="fa-icon fa-icon--ui-flag me-2" aria-hidden="true"></i>
                            {{ 'board.section.milestones'|trans({}, 'dashboards') }}
                        </h5>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
                    {% if dashboard.milestones|length > 0 %}
                        <div class="list-group list-group-flush">
                            {% for milestone in dashboard.milestones %}
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h6 class="mb-1">{{ milestone.title }}</h6>
                                        <small class="text-muted">{{ milestone.type }}</small>
                                    </div>
                                    {% include '_components/_badge.html.twig' with {
                                        variant: milestone.status == 'on_track' ? 'success' : (milestone.status == 'at_risk' ? 'warning' : 'danger'),
                                        content: milestone.date|date('d.m.Y')
                                    } %}
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        {{ _fa_empty_state.render({
                            mood: 'sleeping',
                            title: 'board.no_milestones'|trans({}, 'dashboards')
                        }) }}
                    {% endif %}
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    <div class="row g-4 mt-2">
        {# Items Requiring Board Attention #}
        <div class="col-lg-6">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100', 'noPadding': true } %}
                {% block card_header %}
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="fa-icon fa-icon--status-warning text-danger me-2" aria-hidden="true"></i>
                            {{ 'board.section.attention_required'|trans({}, 'dashboards') }}
                        </h5>
                        {% include '_components/_badge.html.twig' with { variant: 'danger', content: dashboard.attention_items|length } %}
                    </div>
                {% endblock %}
                {% block card_body %}
                    {% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
                    {% if dashboard.attention_items|length > 0 %}
                        <div class="list-group list-group-flush">
                            {% for item in dashboard.attention_items %}
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        {% include '_components/_badge.html.twig' with {
                                            variant: item.priority == 'critical' ? 'danger' : (item.priority == 'high' ? 'warning' : 'secondary'),
                                            content: item.priority|upper,
                                            class: 'me-2'
                                        } %}
                                        <strong>{{ item.title }}</strong>
                                        <p class="mb-0 mt-1 text-muted small">{{ item.description }}</p>
                                    </div>
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        {{ _fa_empty_state.render({
                            mood: 'celebrating',
                            title: 'board.no_attention_items'|trans({}, 'dashboards')
                        }) }}
                    {% endif %}
                {% endblock %}
            {% endembed %}
        </div>

        {# Budget & Resource Overview #}
        <div class="col-lg-6">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100' } %}
                {% block card_header %}
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-currency-euro me-2" aria-hidden="true"></i>
                            {{ 'board.section.resources'|trans({}, 'dashboards') }}
                        </h5>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
                    <div class="row text-center mb-4">
                        <div class="col-6">
                            <h4 class="mb-0">{{ dashboard.resources.fte_security }}</h4>
                            <small class="text-muted">{{ 'board.resource.fte_security'|trans({}, 'dashboards') }}</small>
                        </div>
                        <div class="col-6">
                            <h4 class="mb-0">{{ dashboard.resources.open_positions }}</h4>
                            <small class="text-muted">{{ 'board.resource.open_positions'|trans({}, 'dashboards') }}</small>
                        </div>
                    </div>
                    <h6 class="mb-2">{{ 'board.resource.initiatives'|trans({}, 'dashboards') }}</h6>
                    {% if dashboard.resources.initiatives|length > 0 %}
                        {% for initiative in dashboard.resources.initiatives %}
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span>{{ initiative.name }}</span>
                            {% include '_components/_badge.html.twig' with {
                                variant: initiative.status == 'on_track' ? 'success' : (initiative.status == 'at_risk' ? 'warning' : 'danger'),
                                content: initiative.progress ~ '%'
                            } %}
                        </div>
                        <div class="progress progress-h-6 mb-3">
                            <div class="progress-bar bg-{% if initiative.status == 'on_track' %}success{% elseif initiative.status == 'at_risk' %}warning{% else %}danger{% endif %}"
                                 style="width: {{ initiative.progress }}%"></div>
                        </div>
                        {% endfor %}
                    {% else %}
                        {{ _fa_empty_state.render({
                            mood: 'sleeping',
                            title: 'board.no_initiatives'|trans({}, 'dashboards')
                        }) }}
                    {% endif %}
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    {# Quarterly Comparison #}
    <div class="row g-4 mt-2">
        <div class="col-12">
            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="fa-icon fa-icon--nav-bar-chart me-2" aria-hidden="true"></i>
                            {{ 'board.section.quarterly_comparison'|trans({}, 'dashboards') }}
                        </h5>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="table-responsive">
                        <table class="fa-data-table">
                            <thead>
                                <tr>
                                    <th scope="col">{{ 'board.table.metric'|trans({}, 'dashboards') }}</th>
                                    <th scope="col" class="th--center">Q{{ dashboard.quarterly.previous_quarter }}</th>
                                    <th scope="col" class="th--center">Q{{ dashboard.quarterly.current_quarter }}</th>
                                    <th scope="col" class="th--center">{{ 'board.table.change'|trans({}, 'dashboards') }}</th>
                                    <th scope="col" class="th--center">{{ 'board.table.target'|trans({}, 'dashboards') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for metric in dashboard.quarterly.metrics %}
                                <tr>
                                    <td>{{ metric.name }}</td>
                                    <td class="td--center">{{ metric.previous }}{{ metric.unit }}</td>
                                    <td class="td--center">{{ metric.current }}{{ metric.unit }}</td>
                                    <td class="td--center">
                                        {% if metric.change > 0 %}
                                            <span class="fa-trend fa-trend--{% if metric.positive_is_good %}up{% else %}up-bad{% endif %}">
                                                <i class="fa-icon fa-icon--util-arrow-up" aria-hidden="true"></i> +{{ metric.change }}{{ metric.unit }}
                                            </span>
                                        {% elseif metric.change < 0 %}
                                            <span class="fa-trend fa-trend--{% if metric.positive_is_good %}down-bad{% else %}down{% endif %}">
                                                <i class="fa-icon fa-icon--util-arrow-down" aria-hidden="true"></i> {{ metric.change }}{{ metric.unit }}
                                            </span>
                                        {% else %}
                                            <span class="fa-trend fa-trend--flat"><i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i> 0{{ metric.unit }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="td--center">
                                        {% include '_components/_badge.html.twig' with {
                                            variant: metric.on_target ? 'success' : 'warning',
                                            content: metric.target ~ metric.unit
                                        } %}
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    {# Last Updated Timestamp #}
    <div class="text-muted text-end small mt-3">
        {{ 'dashboard.last_updated'|trans({'%time%': 'now'|date('H:i')}, 'dashboard') }}
    </div>

        </div>{# /skeleton-content #}
    </div>{# /skeleton-controller #}
</main>
{% endblock %}
