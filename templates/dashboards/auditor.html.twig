{% extends 'base.html.twig' %}
{% trans_default_domain 'dashboards' %}

{% block title %}{{ 'auditor.title'|trans({}, 'dashboards') }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_kpi_card.html.twig' as _fa_kpi_card %}

{% block body %}
<main class="fa-aurora-surface role-dashboard auditor-dashboard">
    {# Page Header — Aurora v4 fa-page-header #}
    {{ _fa_page_header.render({
        badge:    { icon: 'clipboard-check', label: 'auditor.badge'|trans({}, 'dashboards') },
        title:    'auditor.title'|trans({}, 'dashboards'),
        subtitle: 'auditor.subtitle'|trans({}, 'dashboards'),
        actions: [
            { label: 'action.standard_dashboard'|trans({}, 'dashboards'), variant: 'ghost',   icon: 'house',          href: path('app_dashboard') },
            { label: 'action.audit_plan'|trans({}, 'dashboards'),         variant: 'primary', icon: 'journal-check',  href: path('app_audit_index') }
        ]
    }) }}

    {# Phase 8H.1: Skeleton placeholder during first paint. #}
    <div data-controller="skeleton" data-skeleton-duration-value="600">
        <div data-skeleton-target="skeleton">
            {% include '_components/_skeleton.html.twig' with { type: 'kpi-grid', count: 6 } %}
        </div>

        <div data-skeleton-target="content" class="hidden">

    {# Summary KPIs — Aurora _fa_kpi_card macro #}
    <div class="row g-3 mb-4">
        <div class="col-md-2">{{ _fa_kpi_card.render({
            value: dashboard.summary.audits_this_year,
            label: 'auditor.kpi.audits_ytd'|trans({}, 'dashboards')
        }) }}</div>
        <div class="col-md-2">{{ _fa_kpi_card.render({
            value: dashboard.summary.upcoming_audits,
            label: 'auditor.kpi.upcoming'|trans({}, 'dashboards')
        }) }}</div>
        <div class="col-md-2">{{ _fa_kpi_card.render({
            value: dashboard.summary.open_findings,
            label: 'auditor.kpi.open_findings'|trans({}, 'dashboards'),
            valueDanger: dashboard.summary.open_findings > 0
        }) }}</div>
        <div class="col-md-2">{{ _fa_kpi_card.render({
            value: dashboard.summary.overdue_actions,
            label: 'auditor.kpi.overdue_actions'|trans({}, 'dashboards'),
            valueDanger: dashboard.summary.overdue_actions > 0
        }) }}</div>
        <div class="col-md-4">{{ _fa_kpi_card.render({
            value: dashboard.summary.evidence_coverage,
            unit: '%',
            label: 'auditor.kpi.evidence_coverage'|trans({}, 'dashboards'),
            valueDanger: dashboard.summary.evidence_coverage < 60
        }) }}</div>
    </div>

    <div class="row g-4">
        {# Audit Schedule #}
        <div class="col-lg-6">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100', 'noPadding': true } %}
                {% block card_header %}
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="bi bi-calendar-event me-2" aria-hidden="true"></i>
                            {{ 'auditor.section.audit_schedule'|trans({}, 'dashboards') }}
                        </h5>
                        <a href="{{ path('app_audit_index') }}" class="btn btn-sm btn-outline-primary">
                            {{ 'action.view_all'|trans({}, 'dashboards') }}
                        </a>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {% if dashboard.audit_status.upcoming|length > 0 %}
                    <div class="list-group list-group-flush">
                        {% for audit in dashboard.audit_status.upcoming %}
                        <a href="{{ path('app_audit_show', {id: audit.id}) }}" class="list-group-item list-group-item-action">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1">{{ audit.title }}</h6>
                                    <small class="text-muted">{{ audit.type }}</small>
                                </div>
                                {% include '_components/_badge.html.twig' with { variant: 'info', content: audit.planned_date|date('d.m.Y') } %}
                            </div>
                        </a>
                        {% endfor %}
                    </div>
                    {% else %}
                    <p class="text-muted text-center py-4 mb-0">{{ 'auditor.no_upcoming_audits'|trans({}, 'dashboards') }}</p>
                    {% endif %}
                {% endblock %}
            {% endembed %}
        </div>

        {# Evidence Collection Status #}
        <div class="col-lg-6">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100' } %}
                {% block card_header %}
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="fa-icon fa-icon--evidence me-2" aria-hidden="true"></i>
                            {{ 'auditor.section.evidence_status'|trans({}, 'dashboards') }}
                        </h5>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="text-center mb-3">
                        <div class="display-5 {% if dashboard.evidence_status.coverage_percentage >= 80 %}text-success{% elseif dashboard.evidence_status.coverage_percentage >= 60 %}text-warning{% else %}text-danger{% endif %}">
                            {{ dashboard.evidence_status.coverage_percentage }}%
                        </div>
                        <small class="text-muted">{{ 'auditor.evidence_coverage_label'|trans({}, 'dashboards') }}</small>
                    </div>
                    <div class="progress progress-h-20 mb-3">
                        <div class="progress-bar bg-success" style="width: {{ dashboard.evidence_status.coverage_percentage }}%">
                            {{ dashboard.evidence_status.with_evidence }} / {{ dashboard.evidence_status.total_controls }}
                        </div>
                    </div>
                    <div class="row text-center">
                        <div class="col-6">
                            <h4 class="text-success">{{ dashboard.evidence_status.with_evidence }}</h4>
                            <small class="text-muted">{{ 'auditor.with_evidence'|trans({}, 'dashboards') }}</small>
                        </div>
                        <div class="col-6">
                            <h4 class="text-warning">{{ dashboard.evidence_status.total_controls - dashboard.evidence_status.with_evidence }}</h4>
                            <small class="text-muted">{{ 'auditor.needs_evidence'|trans({}, 'dashboards') }}</small>
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    <div class="row g-4 mt-2">
        {# Compliance Gaps #}
        <div class="col-lg-6">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100' } %}
                {% block card_header %}
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="fa-icon fa-icon--status-warning me-2" aria-hidden="true"></i>
                            {{ 'auditor.section.compliance_gaps'|trans({}, 'dashboards') }}
                        </h5>
                        <a href="{{ path('app_analytics_compliance_frameworks') }}" class="btn btn-sm btn-outline-warning">
                            {{ 'action.view_details'|trans({}, 'dashboards') }}
                        </a>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="row text-center">
                        <div class="col-4">
                            <div class="p-3 bg-danger bg-opacity-10 rounded">
                                <h3 class="text-danger mb-0">{{ dashboard.compliance_gaps.critical }}</h3>
                                <small>{{ 'auditor.gaps.critical'|trans({}, 'dashboards') }}</small>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="p-3 bg-warning bg-opacity-10 rounded">
                                <h3 class="text-warning mb-0">{{ dashboard.compliance_gaps.high }}</h3>
                                <small>{{ 'auditor.gaps.high'|trans({}, 'dashboards') }}</small>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="p-3 bg-secondary bg-opacity-10 rounded">
                                <h3 class="mb-0">{{ dashboard.compliance_gaps.total }}</h3>
                                <small>{{ 'auditor.gaps.total'|trans({}, 'dashboards') }}</small>
                            </div>
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>

        {# Control Implementation Status #}
        <div class="col-lg-6">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100' } %}
                {% block card_header %}
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-toggles me-2" aria-hidden="true"></i>
                            {{ 'auditor.section.control_status'|trans({}, 'dashboards') }}
                        </h5>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="row text-center">
                        <div class="col-4">
                            <div class="p-3 bg-success bg-opacity-10 rounded">
                                <h3 class="text-success mb-0">{{ dashboard.control_status.implemented }}</h3>
                                <small>{{ 'auditor.controls.implemented'|trans({}, 'dashboards') }}</small>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="p-3 bg-warning bg-opacity-10 rounded">
                                <h3 class="text-warning mb-0">{{ dashboard.control_status.partially }}</h3>
                                <small>{{ 'auditor.controls.partially'|trans({}, 'dashboards') }}</small>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="p-3 bg-danger bg-opacity-10 rounded">
                                <h3 class="text-danger mb-0">{{ dashboard.control_status.not_implemented }}</h3>
                                <small>{{ 'auditor.controls.not_implemented'|trans({}, 'dashboards') }}</small>
                            </div>
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    <div class="row g-4 mt-2">
        {# Non-Conformities Summary #}
        <div class="col-lg-6">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100' } %}
                {% block card_header %}
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-x-octagon me-2" aria-hidden="true"></i>
                            {{ 'auditor.section.non_conformities'|trans({}, 'dashboards') }}
                        </h5>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="row text-center">
                        <div class="col-4">
                            <div class="p-3 bg-danger bg-opacity-10 rounded">
                                <h3 class="text-danger mb-0">{{ dashboard.non_conformities.major }}</h3>
                                <small>{{ 'auditor.nc.major'|trans({}, 'dashboards') }}</small>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="p-3 bg-warning bg-opacity-10 rounded">
                                <h3 class="text-warning mb-0">{{ dashboard.non_conformities.minor }}</h3>
                                <small>{{ 'auditor.nc.minor'|trans({}, 'dashboards') }}</small>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="p-3 bg-info bg-opacity-10 rounded">
                                <h3 class="text-info mb-0">{{ dashboard.non_conformities.observations }}</h3>
                                <small>{{ 'auditor.nc.observations'|trans({}, 'dashboards') }}</small>
                            </div>
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>

        {# Corrective Actions #}
        <div class="col-lg-6">
            {% embed '_components/_card.html.twig' with { 'class': 'h-100' } %}
                {% block card_header %}
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-wrench me-2" aria-hidden="true"></i>
                            {{ 'auditor.section.corrective_actions'|trans({}, 'dashboards') }}
                        </h5>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="row text-center">
                        <div class="col-4">
                            <h3 class="mb-0">{{ dashboard.corrective_actions.total }}</h3>
                            <small class="text-muted">{{ 'auditor.ca.total'|trans({}, 'dashboards') }}</small>
                        </div>
                        <div class="col-4">
                            <h3 class="mb-0 text-warning">{{ dashboard.corrective_actions.open }}</h3>
                            <small class="text-muted">{{ 'auditor.ca.open'|trans({}, 'dashboards') }}</small>
                        </div>
                        <div class="col-4">
                            <h3 class="mb-0 {% if dashboard.corrective_actions.overdue_count > 0 %}text-danger{% else %}text-success{% endif %}">
                                {{ dashboard.corrective_actions.overdue_count }}
                            </h3>
                            <small class="text-muted">{{ 'auditor.ca.overdue'|trans({}, 'dashboards') }}</small>
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

        </div>{# /skeleton-content #}
    </div>{# /skeleton-controller #}
</main>
{% endblock %}
