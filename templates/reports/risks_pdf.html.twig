<!DOCTYPE html>
<html lang="{{ app.request.locale|default('de') }}">
<head>
    <meta charset="UTF-8">
    <title>{{ 'pdf.risk.title'|trans({}, 'reports') }}</title>
    <style>
        :root {
            --primary:       #0ea5e9;
            --surface:       #ffffff;
            --surface-2:     #f1f5f9;
            --fg:            #0f172a;
            --fg-2:          #475569;
            --fg-3:          #94a3b8;
            --border:        #cbd5e1;
            --success:       #166534;
            --success-tint:  #dcfce7;
            --danger:        #991b1b;
            --danger-tint:   #fecaca;
            --warning:       #92400e;
            --warning-tint:  #fef3c7;
        }
        * { box-sizing: border-box; }
        body {
            font-family: 'DejaVu Sans', Arial, sans-serif;
            font-size: 10pt;
            margin: 0;
            padding: 20px;
            color: var(--fg);
            background: var(--surface);
        }

        /* ── Cover ── */
        .report-cover {
            text-align: center;
            margin-bottom: 16px;
            border-bottom: 3px solid var(--primary);
            padding-bottom: 8px;
        }
        .report-cover h1 {
            color: var(--fg);
            margin: 0;
            font-size: 18pt;
            text-transform: uppercase;
            letter-spacing: 0.5pt;
        }
        .report-cover .date { color: var(--fg-2); font-size: 8pt; margin-top: 4px; }

        /* ── Table ── */
        table { width: 100%; border-collapse: collapse; margin: 8px 0; }
        th {
            background: var(--fg);
            color: var(--surface);
            padding: 6px 5px;
            text-align: left;
            font-size: 8pt;
            border: 1px solid var(--border);
            text-transform: uppercase;
            letter-spacing: 0.3pt;
        }
        td { padding: 6px 5px; border: 1px solid var(--border); font-size: 8.5pt; }

        /* ── Row tinting ── */
        .risk-critical { background: var(--danger-tint); font-weight: bold; }
        .risk-high     { background: var(--warning-tint); }
        .risk-medium   { background: #fef9c3; }
        .risk-low      { background: var(--success-tint); }

        /* ── Score badge ── */
        .score-badge {
            display: inline-block;
            padding: 1px 6px;
            border-radius: 3px;
            font-weight: bold;
            color: var(--surface);
            font-size: 8pt;
        }
        .score-critical { background: var(--danger); }
        .score-high     { background: var(--warning); }
        .score-medium   { background: #ca8a04; }
        .score-low      { background: var(--success); }

        /* ── Legend box ── */
        .legend-box {
            margin-top: 24px;
            padding: 10px 12px;
            background: var(--warning-tint);
            border-left: 4px solid #d97706;
            font-size: 8pt;
        }

        /* ── Footer ── */
        .report-footer { position: fixed; bottom: 16px; text-align: center; font-size: 7.5pt; color: var(--fg-3); }
    </style>
</head>
<body>
    <div class="report-cover">
        <h1>{{ 'pdf.risk.title'|trans({}, 'reports') }}</h1>
        <div class="date">
            {{ 'pdf.common.generated'|trans({}, 'reports') }}: {{ generated_at|date('d.m.Y H:i') }}
            &nbsp;|&nbsp;
            {{ 'pdf.common.total'|trans({}, 'reports') }}: {{ risks|length }}
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th scope="col">{{ 'pdf.risk.header.id'|trans({}, 'reports') }}</th>
                <th scope="col">{{ 'pdf.risk.header.title'|trans({}, 'reports') }}</th>
                <th scope="col">{{ 'pdf.risk.header.category'|trans({}, 'reports') }}</th>
                <th scope="col">{{ 'pdf.risk.header.likelihood'|trans({}, 'reports') }}</th>
                <th scope="col">{{ 'pdf.risk.header.impact'|trans({}, 'reports') }}</th>
                <th scope="col">{{ 'pdf.risk.header.score'|trans({}, 'reports') }}</th>
                <th scope="col">{{ 'pdf.risk.header.level'|trans({}, 'reports') }}</th>
                <th scope="col">{{ 'pdf.risk.header.treatment'|trans({}, 'reports') }}</th>
                <th scope="col">{{ 'pdf.risk.header.status'|trans({}, 'reports') }}</th>
                <th scope="col">{{ 'pdf.risk.header.owner'|trans({}, 'reports') }}</th>
            </tr>
        </thead>
        <tbody>
            {% for risk in risks %}
            {% set riskLevel = risk.riskScore >= 20 ? 'critical' : (risk.riskScore >= 12 ? 'high' : (risk.riskScore >= 6 ? 'medium' : 'low')) %}
            <tr class="risk-{{ riskLevel }}">
                <td>{{ risk.id }}</td>
                <td>{{ risk.title|length > 40 ? risk.title|slice(0, 40) ~ '…' : risk.title }}</td>
                <td>{{ risk.category }}</td>
                <td>{{ risk.probability }}</td>
                <td>{{ risk.impact }}</td>
                <td><span class="score-badge score-{{ riskLevel }}">{{ risk.riskScore }}</span></td>
                <td>{{ riskLevel|upper }}</td>
                <td>{{ risk.treatmentDescription|length > 25 ? risk.treatmentDescription|slice(0, 25) ~ '…' : risk.treatmentDescription|default('-') }}</td>
                <td>{{ risk.status ? risk.status.value : '' }}</td>
                <td>{{ (risk.effectiveRiskOwner ?? '-')|slice(0, 20) }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="legend-box">
        <strong>{{ 'pdf.risk.legend'|trans({}, 'reports') }}:</strong>
        {{ 'pdf.risk.legend_text'|trans({}, 'reports') }}
    </div>

    <div class="report-footer">
        <p>{{ 'pdf.risk.footer'|trans({}, 'reports') }} | {{ 'pdf.common.page'|trans({}, 'reports') }} {PAGE_NUM}</p>
    </div>
</body>
</html>
