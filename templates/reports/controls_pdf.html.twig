<!DOCTYPE html>
<html lang="{{ app.request.locale|default('de') }}">
<head>
    <meta charset="UTF-8">
    <title>{{ 'soa.page.title'|trans({}, 'soa') }}</title>
    <style>
        :root {
            --primary:       #0ea5e9;
            --surface:       #ffffff;
            --surface-2:     #f1f5f9;
            --fg:            #0f172a;
            --fg-2:          #475569;
            --fg-3:          #94a3b8;
            --border:        #cbd5e1;
            --success:       #166534;
            --success-tint:  #dcfce7;
            --danger:        #991b1b;
            --danger-tint:   #fecaca;
            --warning:       #92400e;
            --warning-tint:  #fef3c7;
        }
        * { box-sizing: border-box; }
        @page { size: A4 landscape; margin: 15mm; }
        body {
            font-family: 'DejaVu Sans', Arial, sans-serif;
            font-size: 9pt;
            margin: 0;
            padding: 0;
            color: var(--fg);
            background: var(--surface);
        }

        /* ── Cover ── */
        .report-cover {
            text-align: center;
            margin-bottom: 16px;
            border-bottom: 3px solid var(--primary);
            padding-bottom: 8px;
        }
        .report-cover h1 {
            color: var(--fg);
            margin: 0;
            font-size: 16pt;
            text-transform: uppercase;
            letter-spacing: 0.5pt;
        }
        .report-cover .subtitle { color: var(--fg-2); font-size: 8pt; margin-top: 4px; }

        /* ── Table ── */
        table { width: 100%; border-collapse: collapse; margin: 8px 0; }
        th {
            background: var(--fg);
            color: var(--surface);
            padding: 5px 4px;
            text-align: left;
            font-size: 7.5pt;
            border: 1px solid var(--border);
            text-transform: uppercase;
            letter-spacing: 0.3pt;
        }
        td { padding: 5px 4px; border: 1px solid var(--border); font-size: 8pt; }
        tr:nth-child(even) { background: var(--surface-2); }

        /* ── Status ── */
        .applicable     { color: var(--success); font-weight: bold; }
        .not-applicable { color: var(--danger); }

        /* ── Progress ── */
        .progress-bar  { background: var(--border); height: 10px; border-radius: 3px; }
        .progress-fill { background: var(--primary); height: 100%; border-radius: 3px; }

        /* ── Column widths ── */
        .w-8  { width: 8%;  }
        .w-10 { width: 10%; }
        .w-12 { width: 12%; }
        .w-18 { width: 18%; }
        .w-22 { width: 22%; }

        /* ── Footer ── */
        .report-footer { position: fixed; bottom: 8px; left: 0; right: 0; text-align: center; font-size: 7pt; color: var(--fg-3); }
    </style>
</head>
<body>
    {%- set generatedDateTime = generated_at|date('d.m.Y H:i') -%}

    <div class="report-cover">
        <h1>{{ 'soa.page.title'|trans({}, 'soa') }}</h1>
        <div class="subtitle">
            ISO/IEC 27001:2022 Annex A Controls
            &nbsp;|&nbsp;
            {{ 'soa.report.generated_at'|trans({'%datetime%': generatedDateTime}, 'soa') }}
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th scope="col" class="w-8">{{ 'soa.table.control_id'|trans({}, 'soa') }}</th>
                <th scope="col" class="w-22">{{ 'soa.table.name'|trans({}, 'soa') }}</th>
                <th scope="col" class="w-10">{{ 'soa.table.category'|trans({}, 'soa') }}</th>
                <th scope="col" class="w-12">{{ 'soa.table.applicable'|trans({}, 'soa') }}</th>
                <th scope="col" class="w-12">{{ 'soa.table.implementation_status'|trans({}, 'soa') }}</th>
                <th scope="col" class="w-8">{{ 'soa.table.progress'|trans({}, 'soa') }}</th>
                <th scope="col" class="w-18">{{ 'soa.table.justification'|trans({}, 'soa') }}</th>
                <th scope="col" class="w-10">{{ 'soa.table.target_date'|trans({}, 'soa') }}</th>
            </tr>
        </thead>
        <tbody>
            {% for control in controls %}
            <tr>
                <td>{{ control.controlId }}</td>
                <td>{{ control.name|length > 40 ? control.name|slice(0, 40) ~ '…' : control.name }}</td>
                <td>{{ ('soa.category.' ~ control.category)|trans({}, 'soa')|default(control.category) }}</td>
                <td class="{{ control.applicability == 'applicable' ? 'applicable' : 'not-applicable' }}">
                    {{ control.applicability == 'applicable' ? ('soa.value.yes'|trans({}, 'soa')) : ('soa.value.no'|trans({}, 'soa')) }}
                </td>
                <td>{{ ('soa.status.' ~ control.implementationStatus)|trans({}, 'soa')|default(control.implementationStatus) }}</td>
                <td>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: {{ control.implementationProgress }}%;"></div>
                    </div>
                    {{ control.implementationProgress }}%
                </td>
                <td>{{ control.justification|length > 35 ? control.justification|slice(0, 35) ~ '…' : control.justification|default('-') }}</td>
                <td>{{ control.targetDate ? control.targetDate|date('Y-m-d') : '-' }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="report-footer">
        <p>{{ 'soa.footer.note'|trans({}, 'soa') }}</p>
    </div>
</body>
</html>
