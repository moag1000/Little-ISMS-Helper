<!DOCTYPE html>
<html lang="{{ app.request.locale|default('de') }}">
<head>
    <meta charset="UTF-8">
    <title>{{ 'pdf.incident.title'|trans({}, 'reports') }}</title>
    <style>
        :root {
            --primary:       #0ea5e9;
            --surface:       #ffffff;
            --surface-2:     #f1f5f9;
            --fg:            #0f172a;
            --fg-2:          #475569;
            --fg-3:          #94a3b8;
            --border:        #cbd5e1;
            --success:       #166534;
            --success-tint:  #dcfce7;
            --danger:        #991b1b;
            --danger-tint:   #fecaca;
            --warning:       #92400e;
            --warning-tint:  #fef3c7;
        }
        * { box-sizing: border-box; }
        body {
            font-family: 'DejaVu Sans', Arial, sans-serif;
            font-size: 10pt;
            margin: 0;
            padding: 20px;
            color: var(--fg);
            background: var(--surface);
        }

        /* ── Cover ── */
        .report-cover {
            text-align: center;
            margin-bottom: 16px;
            border-bottom: 3px solid var(--primary);
            padding-bottom: 8px;
        }
        .report-cover h1 {
            color: var(--fg);
            margin: 0;
            font-size: 18pt;
            text-transform: uppercase;
            letter-spacing: 0.5pt;
        }
        .report-cover .meta { color: var(--fg-2); font-size: 8pt; margin-top: 4px; }

        /* ── Table ── */
        table { width: 100%; border-collapse: collapse; margin: 8px 0; }
        th {
            background: var(--fg);
            color: var(--surface);
            padding: 6px 4px;
            text-align: left;
            font-size: 8pt;
            border: 1px solid var(--border);
            text-transform: uppercase;
            letter-spacing: 0.3pt;
        }
        td { padding: 6px 4px; border: 1px solid var(--border); font-size: 8.5pt; }

        /* ── Severity row tinting ── */
        .severity-critical { background: var(--danger-tint); }
        .severity-high     { background: var(--warning-tint); }
        .severity-medium   { background: #fef9c3; }
        .severity-low      { background: var(--success-tint); }
    </style>
</head>
<body>
    <div class="report-cover">
        <h1>{{ 'pdf.incident.title'|trans({}, 'reports') }}</h1>
        <div class="meta">
            {{ 'pdf.common.generated'|trans({}, 'reports') }}: {{ generated_at|date('d.m.Y H:i') }}
            &nbsp;|&nbsp;
            {{ 'pdf.common.total'|trans({}, 'reports') }}: {{ incidents|length }}
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th scope="col">{{ 'pdf.incident.header.id'|trans({}, 'reports') }}</th>
                <th scope="col">{{ 'pdf.incident.header.title'|trans({}, 'reports') }}</th>
                <th scope="col">{{ 'pdf.incident.header.severity'|trans({}, 'reports') }}</th>
                <th scope="col">{{ 'pdf.incident.header.category'|trans({}, 'reports') }}</th>
                <th scope="col">{{ 'pdf.incident.header.detected'|trans({}, 'reports') }}</th>
                <th scope="col">{{ 'pdf.incident.header.resolved'|trans({}, 'reports') }}</th>
                <th scope="col">{{ 'pdf.incident.header.status'|trans({}, 'reports') }}</th>
                <th scope="col">{{ 'pdf.incident.header.reporter'|trans({}, 'reports') }}</th>
            </tr>
        </thead>
        <tbody>
            {% for incident in incidents %}
            <tr class="severity-{{ incident.severity ? incident.severity.value : '' }}">
                <td>{{ incident.id }}</td>
                <td>{{ incident.title|length > 30 ? incident.title|slice(0, 30) ~ '…' : incident.title }}</td>
                <td><strong>{{ incident.severity ? incident.severity.value|upper : '' }}</strong></td>
                <td>{{ incident.category }}</td>
                <td>{{ incident.detectedDate|date('Y-m-d') }}</td>
                <td>{{ incident.resolvedDate ? incident.resolvedDate|date('Y-m-d') : ('pdf.common.open'|trans({}, 'reports')) }}</td>
                <td>{{ incident.status ? incident.status.value : '' }}</td>
                <td>{{ incident.reportedBy ? (incident.reportedBy.email|length > 20 ? incident.reportedBy.email|slice(0, 20) ~ '…' : incident.reportedBy.email) : '-' }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</body>
</html>
