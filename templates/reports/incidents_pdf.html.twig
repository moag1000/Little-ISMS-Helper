<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{{ 'pdf.incident.title'|trans({}, 'reports') }}</title>
    <style>
        body { font-family: 'DejaVu Sans', sans-serif; font-size: 10pt; }
        .header {
            text-align: center;
            margin-bottom: 20px;
            border-bottom: 3px solid transparent;
            border-image: linear-gradient(90deg, var(--primary) 0%, var(--accent) 50%, var(--accent) 100%) 1;
            padding-bottom: 10px;
        }
        .header h1 {
            color: var(--bg);
            margin: 0;
            font-size: 20pt;
            text-transform: uppercase;
            letter-spacing: 0.5pt;
        }
        table { width: 100%; border-collapse: collapse; margin: 10px 0; }
        th {
            background: linear-gradient(90deg, var(--bg) 0%, var(--surface) 100%);
            color: var(--primary);
            padding: 8px;
            text-align: left;
            font-size: 9pt;
            border: 1px solid #1e3a8a;
            text-transform: uppercase;
            letter-spacing: 0.3pt;
        }
        td { padding: 8px; border: 1px solid #ddd; font-size: 9pt; }
        tr:nth-child(even) { background: linear-gradient(135deg, var(--bg) 0%, var(--surface-2) 100%); }
        .severity-critical { background: #fee2e2; }
        .severity-high { background: #fed7aa; }
        .severity-medium { background: #fef3c7; }
        .severity-low { background: #d1fae5; }
    </style>
</head>
<body>
    <div class="header">
        <h1>{{ 'pdf.incident.title'|trans({}, 'reports') }}</h1>
        <div style="color: #666; font-size: 9pt; margin-top: 5px;">{{ 'pdf.common.generated'|trans({}, 'reports') }}: {{ generated_at|date('d.m.Y H:i') }} | {{ 'pdf.common.total'|trans({}, 'reports') }}: {{ incidents|length }}</div>
    </div>

    <table>
        <thead>
            <tr>
                <th scope="col">{{ 'pdf.incident.header.id'|trans({}, 'reports') }}</th>
                <th scope="col">{{ 'pdf.incident.header.title'|trans({}, 'reports') }}</th>
                <th scope="col">{{ 'pdf.incident.header.severity'|trans({}, 'reports') }}</th>
                <th scope="col">{{ 'pdf.incident.header.category'|trans({}, 'reports') }}</th>
                <th scope="col">{{ 'pdf.incident.header.detected'|trans({}, 'reports') }}</th>
                <th scope="col">{{ 'pdf.incident.header.resolved'|trans({}, 'reports') }}</th>
                <th scope="col">{{ 'pdf.incident.header.status'|trans({}, 'reports') }}</th>
                <th scope="col">{{ 'pdf.incident.header.reporter'|trans({}, 'reports') }}</th>
            </tr>
        </thead>
        <tbody>
            {% for incident in incidents %}
            <tr class="severity-{{ incident.severity ? incident.severity.value : '' }}">
                <td>{{ incident.id }}</td>
                <td>{{ incident.title|slice(0, 30) }}{% if incident.title|length > 30 %}...{% endif %}</td>
                <td><strong>{{ incident.severity ? incident.severity.value|upper : '' }}</strong></td>
                <td>{{ incident.category }}</td>
                <td>{{ incident.detectedDate|date('Y-m-d') }}</td>
                <td>{{ incident.resolvedDate ? incident.resolvedDate|date('Y-m-d') : 'pdf.common.open'|trans({}, 'reports') }}</td>
                <td>{{ incident.status ? incident.status.value : '' }}</td>
                <td>{{ incident.reportedBy ? incident.reportedBy.email|slice(0, 20) : '-' }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</body>
</html>
