{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block admin_title %}{{ 'permission.title'|trans({}, 'messages') }}{% endblock %}
{% block admin_subtitle %}
    <p class="text-muted">{{ 'permission.subtitle'|trans({}, 'messages') }}</p>
{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item active" aria-current="page">{{ 'admin.nav.permissions'|trans({}, 'admin') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'shield-check', label: 'admin.nav.permissions'|trans({}, 'admin') },
        title: 'permission.title'|trans({}, 'messages'),
        subtitle: 'permission.subtitle'|trans({}, 'messages')
    }) }}

    <main class="fa-aurora-surface">
    {# Statistics Cards #}
    <div class="row mb-4">
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' with { 'variant': 'bordered', 'borderColor': 'primary', 'value': statistics.total } only %}
                {% block card_body %}
                    <div class="text-center">
                        <div class="card-title text-muted fw-semibold small text-uppercase">{{ 'permission.statistics.total'|trans({}, 'messages') }}</div>
                        <p class="display-6 text-primary">{{ value }}</p>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' with { 'variant': 'bordered', 'borderColor': 'success', 'value': statistics.system } only %}
                {% block card_body %}
                    <div class="text-center">
                        <div class="card-title text-muted fw-semibold small text-uppercase">{{ 'permission.statistics.system'|trans({}, 'messages') }}</div>
                        <p class="display-6 text-success">{{ value }}</p>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' with { 'variant': 'bordered', 'borderColor': 'info', 'value': statistics.custom } only %}
                {% block card_body %}
                    <div class="text-center">
                        <div class="card-title text-muted fw-semibold small text-uppercase">{{ 'permission.statistics.custom'|trans({}, 'messages') }}</div>
                        <p class="display-6 text-info">{{ value }}</p>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' with { 'variant': 'bordered', 'borderColor': 'warning', 'value': statistics.categories_count } only %}
                {% block card_body %}
                    <div class="text-center">
                        <div class="card-title text-muted fw-semibold small text-uppercase">{{ 'permission.statistics.categories'|trans({}, 'messages') }}</div>
                        <p class="display-6 text-warning">{{ value }}</p>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    {# Category Filter #}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4', 'categories': categories, 'currentCategory': currentCategory } only %}
        {% block card_body %}
            <div class="btn-group btn-group-sm" role="group">
                <a href="{{ path('permission_index') }}"
                   class="fa-cyber-btn fa-cyber-btn--sm {{ currentCategory is null ? 'fa-cyber-btn--primary' : 'fa-cyber-btn--ghost' }}">
                    Alle
                </a>
                {% for category in categories %}
                    <a href="{{ path('permission_index', {category: category}) }}"
                       class="fa-cyber-btn fa-cyber-btn--sm {{ currentCategory == category ? 'fa-cyber-btn--primary' : 'fa-cyber-btn--ghost' }}">
                        {{ category|title }}
                    </a>
                {% endfor %}
            </div>
        {% endblock %}
    {% endembed %}

    {# Permissions by Category #}
    {% for category, permissions in groupedPermissions %}
        {% embed '_components/_card.html.twig' with { 'class': 'mb-4', 'category': category, 'permissions': permissions } only %}
            {% block card_header %}
                <div class="card-header">
                    <h2 class="mb-0">
                        <i class="bi bi-folder" aria-hidden="true"></i> {{ category|title }}
                        {% include '_components/_badge.html.twig' with { variant: 'light', content: permissions|length } only %}
                    </h2>
                </div>
            {% endblock %}
            {% block card_body %}
                {% embed '_components/_table.html.twig' with { 'noMargin': true, 'permissions': permissions } only %}
                    {% block table_head %}
                        <tr>
                            <th scope="col">{{ 'permission.action'|trans({}, 'messages') }}</th>
                            <th scope="col">{{ 'permission.description'|trans({}, 'messages') }}</th>
                            <th scope="col" class="text-center">{{ 'permission.system_permission'|trans({}, 'messages') }}</th>
                            <th scope="col" class="text-end">Aktionen</th>
                        </tr>
                    {% endblock %}
                    {% block table_body %}
                        {% for permission in permissions %}
                            <tr>
                                <td>
                                    <code>{{ permission.name }}</code>
                                </td>
                                <td>{{ permission.description }}</td>
                                <td class="text-center">
                                    {% if permission.isSystemPermission %}
                                        {% include '_components/_badge.html.twig' with { variant: 'info', content: 'System' } only %}
                                    {% else %}
                                        {% include '_components/_badge.html.twig' with { variant: 'secondary', content: 'Custom' } only %}
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    <a href="{{ path('permission_show', {id: permission.id}) }}"
                                       class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                        <i class="bi bi-eye" aria-hidden="true"></i> Details
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            {% endblock %}
        {% endembed %}
    {% endfor %}

    {% if groupedPermissions|length == 0 %}
        <div class="fa-alert fa-alert--info" role="alert">
            <i class="fa-icon fa-icon--status-info fa-alert__icon" aria-hidden="true"></i>
            <div class="fa-alert__body">Keine Berechtigungen gefunden.</div>
        </div>
    {% endif %}
    </main>
{% endblock %}
