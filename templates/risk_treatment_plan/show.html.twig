{% extends 'base.html.twig' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% trans_default_domain 'risk_treatment_plan' %}

{% block title %}{{ plan.title }} - {{ 'risk_treatment_plan.title'|trans({}, 'risk_treatment_plan') }}{% endblock %}

{% block body %}
    {% import '_components/_fa_progress.html.twig' as _fa_progress %}
    {% import '_components/_fa_alert.html.twig' as _fa_alert %}
<div class="container">
    {# M-4 — module-gating: Risk Treatment Plans (ISO 27001 Cl. 6.1.3) #}
    {% if not is_module_active('risk_treatment_plans') %}
        {{ _fa_alert.render({
            variant: 'info',
            icon: 'nav-shield-alert',
            body: 'common.module_not_active'|trans({'%module%': 'Risk Treatment Plans'}, 'messages')
        }) }}
    {% else %}
    {# Lifecycle Y.5 — status transition dropdown (risk_treatment_plan_lifecycle) #}
    {% include '_components/_lifecycle_toolbar.html.twig' with {
        entity: plan,
        entity_type: 'risk-treatment-plan',
        workflow_name: 'risk_treatment_plan_lifecycle'
    } only %}
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.risks'|trans({}, 'nav'), url: path('app_risk_index') },
            { label: 'nav.treatment_plans'|trans({}, 'nav'), url: path('app_risk_treatment_plan_index') },
            { label: plan.title }
        ]
    } %}
</div>

{{ _fa_page_header.render({
    badge:    { icon: 'ui-list', label: 'risk_treatment_plan.title'|trans({}, 'risk_treatment_plan') },
    title:    plan.title,
    subtitle: 'risk_treatment_plan.show.subtitle'|trans({}, 'risk_treatment_plan') ~ (plan.isOverdue() ? ' • ' ~ 'risk_treatment_plan.overdue'|trans({}, 'risk_treatment_plan') : ''),
    actions: [
        { label: 'common.edit'|trans({}, 'messages'), variant: 'primary', icon: 'ui-edit',     href: path('app_risk_treatment_plan_edit',  {id: plan.id}) },
        { label: 'common.back'|trans({}, 'messages'), variant: 'ghost',   icon: 'util-arrow-left', href: path('app_risk_treatment_plan_index') }
    ]
}) }}

{# Status Cards #}
<div class="row mb-4">
    <div class="col-md-3">
        <div class="info-card">
            <div class="info-label">{{ 'risk_treatment_plan.field.status'|trans({}, 'risk_treatment_plan') }}</div>
            <div class="info-value">
                {% set status_variant = plan.status == 'completed' ? 'success' : (plan.status == 'in_progress' ? 'primary' : (plan.status == 'cancelled' ? 'secondary' : (plan.status == 'on_hold' ? 'warning' : 'info'))) %}
                {% include '_components/_badge.html.twig' with { variant: status_variant, class: 'fa-status-pill--lg', content: ('risk_treatment_plan.status.' ~ plan.status)|trans({}, 'risk_treatment_plan') } %}
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="info-card">
            <div class="info-label">{{ 'risk_treatment_plan.field.priority'|trans({}, 'risk_treatment_plan') }}</div>
            <div class="info-value">
                {% set priority_variant = plan.priority == 'critical' ? 'danger' : (plan.priority == 'high' ? 'warning' : (plan.priority == 'medium' ? 'info' : 'secondary')) %}
                {% include '_components/_badge.html.twig' with { variant: priority_variant, class: 'fa-status-pill--lg', content: ('risk_treatment_plan.priority.' ~ plan.priority)|trans({}, 'risk_treatment_plan')|upper } %}
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="info-card">
            <div class="info-label">{{ 'risk_treatment_plan.field.completion'|trans({}, 'risk_treatment_plan') }}</div>
            <div class="info-value">
                {{ _fa_progress.render({ value: plan.completionPercentage, tone: plan.completionPercentage >= 75 ? 'success' : (plan.completionPercentage >= 50 ? 'info' : (plan.completionPercentage >= 25 ? 'warning' : 'danger')), showText: true }) }}
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="info-card {{ plan.isOverdue() ? 'info-card--danger' : '' }}">
            <div class="info-label">{{ 'risk_treatment_plan.days_until_target'|trans({}, 'risk_treatment_plan') }}</div>
            <div class="info-value">
                {% set daysUntil = plan.daysUntilTarget %}
                {% if daysUntil < 0 %}
                    <span class="text-danger fw-bold">{{ daysUntil|abs }} {{ 'risk_treatment_plan.days_overdue'|trans({}, 'risk_treatment_plan') }}</span>
                {% elseif daysUntil == 0 %}
                    <span class="text-warning fw-bold">{{ 'risk_treatment_plan.due_today'|trans({}, 'risk_treatment_plan') }}</span>
                {% else %}
                    {{ daysUntil }} {{ 'risk_treatment_plan.days_remaining'|trans({}, 'risk_treatment_plan') }}
                {% endif %}
            </div>
        </div>
    </div>
</div>

{# Main Details #}
{% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
    {% block card_header %}
        <div class="card-header">
            <h2><i class="fa-icon fa-icon--ui-info" aria-hidden="true"></i> {{ 'risk_treatment_plan.section.details'|trans({}, 'risk_treatment_plan') }}</h2>
        </div>
    {% endblock %}
    {% block card_body %}
        <div class="row">
            <div class="col-md-6">
                <div class="detail-item">
                    <strong>{{ 'risk_treatment_plan.field.risk'|trans({}, 'risk_treatment_plan') }}:</strong>
                    {% if plan.risk %}
                        <a href="{{ path('app_risk_show', {id: plan.risk.id}) }}">{{ plan.risk.title }}</a>
                        {% include '_components/_badge.html.twig' with { variant: 'danger', class: 'ms-2', content: 'Score: ' ~ plan.risk.riskScore } %}
                    {% else %}
                        <span class="text-muted">-</span>
                    {% endif %}
                </div>

                <div class="detail-item">
                    <strong>{{ 'risk_treatment_plan.field.responsible_person'|trans({}, 'risk_treatment_plan') }}:</strong>
                    {% if plan.effectiveResponsiblePerson %}
                        {{ plan.effectiveResponsiblePerson }}
                    {% else %}
                        <span class="text-muted">{{ 'common.not_assigned'|trans({}, 'messages') }}</span>
                    {% endif %}
                </div>

                <div class="detail-item">
                    <strong>{{ 'risk_treatment_plan.field.budget'|trans({}, 'risk_treatment_plan') }}:</strong>
                    {% if plan.budget %}
                        {{ plan.budget|number_format(2, '.', ',') }} €
                    {% else %}
                        <span class="text-muted">{{ 'common.not_set'|trans({}, 'messages') }}</span>
                    {% endif %}
                </div>
            </div>

            <div class="col-md-6">
                <div class="detail-item">
                    <strong>{{ 'risk_treatment_plan.field.start_date'|trans({}, 'risk_treatment_plan') }}:</strong>
                    {% if plan.startDate %}
                        {{ plan.startDate|date('Y-m-d') }}
                    {% else %}
                        <span class="text-muted">{{ 'common.not_started'|trans({}, 'messages') }}</span>
                    {% endif %}
                </div>

                <div class="detail-item">
                    <strong>{{ 'risk_treatment_plan.field.target_completion_date'|trans({}, 'risk_treatment_plan') }}:</strong>
                    {{ plan.targetCompletionDate|date('Y-m-d') }}
                </div>

                <div class="detail-item">
                    <strong>{{ 'risk_treatment_plan.field.actual_completion_date'|trans({}, 'risk_treatment_plan') }}:</strong>
                    {% if plan.actualCompletionDate %}
                        {{ plan.actualCompletionDate|date('Y-m-d') }}
                    {% else %}
                        <span class="text-muted">{{ 'common.not_completed'|trans({}, 'messages') }}</span>
                    {% endif %}
                </div>
            </div>
        </div>

        <hr>

        <div class="detail-item">
            <strong>{{ 'risk_treatment_plan.field.description'|trans({}, 'risk_treatment_plan') }}:</strong>
            <div class="mt-2">{{ plan.description|nl2br }}</div>
        </div>

        {% if plan.implementationNotes %}
        <hr>
        <div class="detail-item">
            <strong>{{ 'risk_treatment_plan.field.implementation_notes'|trans({}, 'risk_treatment_plan') }}:</strong>
            <div class="mt-2">{{ plan.implementationNotes|nl2br }}</div>
        </div>
        {% endif %}
    {% endblock %}
{% endembed %}

{# Linked Controls #}
{% if plan.controls|length > 0 %}
{% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
    {% block card_header %}
        <div class="card-header">
            <h2><i class="fa-icon fa-icon--compliance-shield" aria-hidden="true"></i> {{ 'risk_treatment_plan.section.controls'|trans({}, 'risk_treatment_plan') }} ({{ plan.controls|length }})</h2>
        </div>
    {% endblock %}
    {% block card_body %}
        {% embed '_components/_table.html.twig' with {
            'class': 'table-sm',
            'responsive': true,
            'noMargin': true
        } %}
            {% block table_head %}
                <tr>
                    <th scope="col">{{ 'control.field.control_id'|trans({}, 'control') }}</th>
                    <th scope="col">{{ 'control.field.title'|trans({}, 'control') }}</th>
                    <th scope="col">{{ 'control.field.status'|trans({}, 'control') }}</th>
                </tr>
            {% endblock %}
            {% block table_body %}
                {% for control in plan.controls %}
                <tr>
                    <td>
                        <a href="{{ path('app_soa_show', {id: control.id}) }}">{% include '_components/_iso_reference_label.html.twig' with { control: control, show_name: false } only %}</a>
                    </td>
                    <td>{{ control.title }}</td>
                    <td>
                        {% set ctrl_variant = control.implementationStatus == 'implemented' ? 'success' : (control.implementationStatus == 'in_progress' ? 'warning' : (control.implementationStatus == 'not_started' ? 'secondary' : 'dark')) %}
                        {% include '_components/_badge.html.twig' with { variant: ctrl_variant, content: ('control.status.' ~ control.implementationStatus)|trans({}, 'control') } %}
                    </td>
                </tr>
                {% endfor %}
            {% endblock %}
        {% endembed %}
    {% endblock %}
{% endembed %}
{% endif %}

{# Evidence Documents #}
{% include 'evidence/_upload_widget.html.twig' with {
    entityType: 'risk_treatment_plan',
    entityId: plan.id,
    documents: plan.evidenceDocuments
} %}

{# Audit Log History #}
{% if auditLogs is defined and auditLogs|length > 0 %}
{% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
    {% block card_header %}
        <div class="card-header">
            <h2><i class="fa-icon fa-icon--nav-calendar-check" aria-hidden="true"></i> {{ 'risk_treatment_plan.section.history'|trans({}, 'risk_treatment_plan') }} ({{ totalAuditLogs }} {{ 'audit_log.entries'|trans({}, 'audit_log') }})</h2>
        </div>
    {% endblock %}
    {% block card_body %}
        <div class="fa-audit-feed">
            {% for log in auditLogs %}
            <div class="fa-audit-row{% if log.isSealed is defined and log.isSealed %} fa-audit-row--sealed{% endif %}">
                <span class="fa-audit-row__ts">{{ log.createdAt|date('Y-m-d H:i:s') }}</span>
                <span class="fa-audit-row__sev fa-audit-row__sev--{% if log.action in ['create', 'read'] %}info{% elseif log.action == 'update' %}warning{% elseif log.action in ['error', 'failed'] %}danger{% else %}critical{% endif %}"></span>
                <span class="fa-audit-row__actor">{{ log.userName|default('System') }}</span>
                <span class="fa-audit-row__action">{{ log.action|upper }}</span>
                <span class="fa-audit-row__target">{{ log.entityType|default('RiskTreatmentPlan') }}#{{ log.entityId|default('') }}</span>
                <span class="fa-audit-row__hash">{{ log.hash is defined ? log.hash|slice(0,12) : '' }}</span>
            </div>
            {% endfor %}
        </div>
        {% if totalAuditLogs > 10 %}
        <div class="text-center mt-3">
            <small class="text-muted">{{ 'audit_log.showing_recent'|trans({'%count%': 10, '%total%': totalAuditLogs}, 'audit_log') }}</small>
        </div>
        {% endif %}
    {% endblock %}
{% endembed %}
{% endif %}

{# Delete Section - Admin Only #}
{% if is_granted('ROLE_ADMIN') %}
{% embed '_components/_card.html.twig' with { 'class': 'border-danger' } %}
    {% block card_header %}
        <div class="card-header">
            <h2><i class="fa-icon fa-icon--status-warning text-danger" aria-hidden="true"></i> {{ 'common.danger_zone'|trans({}, 'messages') }}</h2>
        </div>
    {% endblock %}
    {% block card_body %}
        <p>{{ 'risk_treatment_plan.delete.warning'|trans({}, 'risk_treatment_plan') }}</p>
        <form method="post" action="{{ path('app_risk_treatment_plan_delete', {id: plan.id}) }}"
              data-controller="ui-actions"
              data-action="submit->ui-actions#confirm"
              data-ui-actions-message-param="{{ 'risk_treatment_plan.delete.confirm'|trans({}, 'risk_treatment_plan') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ plan.id) }}">
            <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger">
                <i class="fa-icon fa-icon--ui-trash" aria-hidden="true"></i> {{ 'common.delete'|trans({}, 'messages') }}
            </button>
        </form>
    {% endblock %}
{% endembed %}
{% endif %}
{% endif %} {# /M-4 risk_treatment_plans module gate #}

<style>
.page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--spacing-xl);
}

.button-group {
    display: flex;
    gap: var(--spacing-sm);
}

.info-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    padding: var(--spacing-lg);
    text-align: center;
    height: 100%;
}

/* Aurora pitfall-#11 compliant tonal variants — colored left-border instead
   of bg-* (which Aurora's --surface token silently overrides). */
.info-card--danger {
    border-left: 4px solid var(--danger);
}
.info-card--danger .info-value {
    color: var(--danger);
}
.info-card--success {
    border-left: 4px solid var(--success);
}
.info-card--success .info-value {
    color: var(--success);
}

.info-label {
    color: var(--fg-2);
    font-size: 0.875rem;
    margin-bottom: var(--spacing-sm);
}

.info-value {
    font-size: 1.25rem;
    font-weight: bold;
}

.detail-item {
    margin-bottom: var(--spacing-md);
}

.mb-4 {
    margin-bottom: var(--spacing-xl);
}
</style>
{% endblock %}
