{% extends 'base.html.twig' %}
{% trans_default_domain 'risk_treatment_plan' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'risk_treatment_plan.edit'|trans({}, 'risk_treatment_plan') }}: {{ plan.title }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.risk_treatment_plans'|trans({}, 'nav'), url: path('app_risk_treatment_plan_index') },
            { label: plan.title, url: path('app_risk_treatment_plan_show', {id: plan.id}) },
            { label: 'common.edit'|trans({}, 'messages') }
        ]
    } %}

    {{ _fa_page_header.render({
        title: 'risk_treatment_plan.edit'|trans({}, 'risk_treatment_plan') ~ ': ' ~ plan.title,
        badge: { icon: 'ui-edit', label: '' },
        actions: [
            { label: 'common.back'|trans({}, 'messages'), href: path('app_risk_treatment_plan_show', {id: plan.id}), variant: 'ghost', icon: 'util-arrow-left' }
        ]
    }) }}

    {{ form_start(form) }}
    {% include '_components/_auto_form.html.twig' with {
        'form': form,
        'layout': 'outline-rail',
        'eyebrow': 'ISO 27001 Cl. 6.1.3 · Risk Treatment Plan',
        'title': plan.title,
        'sections': {
            'overview': {
                'label': 'form.section.overview'|trans({}, 'messages'),
                'fields': ['risk', 'title', 'description']
            },
            'treatment_option': {
                'label': 'form.section.treatment_option'|trans({}, 'messages'),
                'fields': ['status', 'priority', 'completionPercentage']
            },
            'details': {
                'label': 'form.section.details'|trans({}, 'messages'),
                'fields': ['startDate', 'targetCompletionDate', 'actualCompletionDate', 'budget']
            },
            'responsibility': {
                'label': 'form.section.responsibility'|trans({}, 'messages'),
                'fields': ['responsiblePersonUser', 'responsiblePerson', 'responsibleDeputyPersons']
            },
            'controls': {
                'label': 'form.section.controls'|trans({}, 'messages'),
                'fields': ['controls']
            },
            'residual_risk': {
                'label': 'form.section.residual_risk'|trans({}, 'messages'),
                'fields': ['implementationNotes']
            }
        },
        'col_widths': {
            'risk': 6,
            'title': 6,
            'description': 12,
            'status': 4,
            'priority': 4,
            'completionPercentage': 4,
            'startDate': 4,
            'targetCompletionDate': 4,
            'actualCompletionDate': 4,
            'budget': 6,
            'responsiblePersonUser': 6,
            'responsiblePerson': 6,
            'responsibleDeputyPersons': 12,
            'controls': 12,
            'implementationNotes': 12
        },
        'actions': {
            'close': { 'label': 'common.cancel'|trans({}, 'messages'), 'variant': 'ghost' },
            'submit': { 'label': 'common.save_changes'|trans({}, 'messages'), 'variant': 'primary' }
        }
    } %}
    {{ form_end(form) }}
</div>
{% endblock %}
