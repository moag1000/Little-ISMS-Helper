{% extends 'base.html.twig' %}
{% trans_default_domain 'scheduled_reports' %}

{% block title %}{{ 'scheduled_report.title'|trans({}, 'scheduled_reports') }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% block body %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}

{% include '_components/_breadcrumb.html.twig' with {
    breadcrumbs: [
        { label: 'nav.reports'|trans({}, 'nav'), url: path('app_reports_index') },
        { label: 'scheduled_report.title'|trans({}, 'scheduled_reports') }
    ]
} %}

{{ _fa_page_header.render({
    badge: { icon: 'nav-clock-history', label: 'nav.reports'|trans({}, 'nav') },
    title: 'scheduled_report.title'|trans({}, 'scheduled_reports'),
    actions: [
        { label: 'scheduled_report.action.new'|trans({}, 'scheduled_reports'), variant: 'primary', icon: 'plus', href: path('app_scheduled_report_new'), attrs: { 'data-turbo-frame': 'fa-form-modal' } }
    ]
}) }}

<main class="fa-aurora-surface">
<div class="container-fluid py-4">

    {# Statistics #}
    <div class="row mb-4">
        <div class="col-md-3">
            {{ _fa_feature_card.render({
                label:   'scheduled_report.stats.total'|trans({}, 'scheduled_reports'),
                value:   statistics.total,
                variant: 'primary',
                icon:    'ui-calendar-event'
            }) }}
        </div>
        <div class="col-md-3">
            {{ _fa_feature_card.render({
                label:   'scheduled_report.stats.active'|trans({}, 'scheduled_reports'),
                value:   statistics.active,
                variant: 'success',
                icon:    'status-ok'
            }) }}
        </div>
        <div class="col-md-3">
            {{ _fa_feature_card.render({
                label:   'scheduled_report.stats.inactive'|trans({}, 'scheduled_reports'),
                value:   statistics.inactive,
                variant: 'primary',
                icon:    'status-pending'
            }) }}
        </div>
        <div class="col-md-3">
            {{ _fa_feature_card.render({
                label:   'scheduled_report.stats.due'|trans({}, 'scheduled_reports'),
                value:   due_reports|length,
                variant: 'warning',
                icon:    'ui-hourglass'
            }) }}
        </div>
    </div>

    {# Info Alert #}
    <div class="fa-alert fa-alert--info mb-4" role="alert">
        <i class="fa-icon fa-icon--status-info fa-alert__icon" aria-hidden="true"></i>
        <div class="fa-alert__body">{{ 'scheduled_report.info.activation_required'|trans({}, 'scheduled_reports') }}
        <br><small class="text-muted">{{ 'scheduled_report.info.cron_hint'|trans({}, 'scheduled_reports') }}</small></div>
    </div>

    {# Due Reports Warning #}
    {% if due_reports|length > 0 %}
    <div class="fa-alert fa-alert--warning mb-4" role="alert">
        <i class="fa-icon fa-icon--status-warning fa-alert__icon" aria-hidden="true"></i>
        <div class="fa-alert__body"><h5><i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> {{ 'scheduled_report.due_reports.title'|trans({}, 'scheduled_reports') }}</h5>
        <p class="mb-2">{{ 'scheduled_report.due_reports.text'|trans({'%count%': due_reports|length}, 'scheduled_reports') }}</p>
        <code>php bin/console app:process-scheduled-reports</code></div>
    </div>
    {% endif %}

    {# Reports Table — V3 W3-UX: migrated to fa-table Aurora pattern #}
    {% if reports|length > 0 %}
    {% embed '_components/_fa_table.html.twig' with { hover: true, sortable: true } %}
        {% block table_head %}
            <tr>
                <th class="fa-table__th fa-table__th--sortable" data-sort-key="name" tabindex="0" role="columnheader" aria-sort="none" data-action="click->fa-table-sort#sort keydown.enter->fa-table-sort#sort keydown.space->fa-table-sort#sort">{{ 'scheduled_report.table.name'|trans({}, 'scheduled_reports') }}</th>
                <th class="fa-table__th">{{ 'scheduled_report.table.type'|trans({}, 'scheduled_reports') }}</th>
                <th class="fa-table__th">{{ 'scheduled_report.table.schedule'|trans({}, 'scheduled_reports') }}</th>
                <th class="fa-table__th">{{ 'scheduled_report.table.format'|trans({}, 'scheduled_reports') }}</th>
                <th class="fa-table__th">{{ 'scheduled_report.table.status'|trans({}, 'scheduled_reports') }}</th>
                <th class="fa-table__th fa-table__th--sortable" data-sort-key="next_run" tabindex="0" role="columnheader" aria-sort="none" data-action="click->fa-table-sort#sort keydown.enter->fa-table-sort#sort keydown.space->fa-table-sort#sort">{{ 'scheduled_report.table.next_run'|trans({}, 'scheduled_reports') }}</th>
                <th class="fa-table__th">{{ 'scheduled_report.table.recipients'|trans({}, 'scheduled_reports') }}</th>
                <th class="fa-table__th fa-table__th--actions">{{ 'scheduled_report.table.actions'|trans({}, 'scheduled_reports') }}</th>
            </tr>
        {% endblock %}
        {% block table_body_attrs %}id="scheduled-report-rows"{% endblock %}
        {% block table_body %}
            {% for report in reports %}
                {% include 'scheduled_report/_row.html.twig' with { report: report } %}
            {% endfor %}
        {% endblock %}
    {% endembed %}
    {% else %}
    {% embed '_components/_card.html.twig' with { 'class': 'shadow-sm' } %}
        {% block card_body %}
            {% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
            {{ _fa_empty_state.render({
                mood: 'sleeping',
                title: 'scheduled_report.empty.title'|trans({}, 'scheduled_reports'),
                text: 'scheduled_report.empty.text'|trans({}, 'scheduled_reports'),
                actions: [
                    { label: 'scheduled_report.action.new'|trans({}, 'scheduled_reports'), variant: 'primary', icon: 'plus', href: path('app_scheduled_report_new') }
                ]
            }) }}
        {% endblock %}
    {% endembed %}
    {% endif %}
</div>
</main>
{% endblock %}
