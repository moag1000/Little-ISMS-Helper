{# Single ScheduledReport table row — shared by the index and the Turbo Stream that
   replaces/appends a row after an in-modal save. The title cell opens the
   read-only detail in the fa-form-modal frame; the eye/edit actions do the same.
   Edit action is gated on ROLE_MANAGER, matching controller-level access. #}
{% trans_default_domain 'scheduled_reports' %}
<tr id="scheduled-report-row-{{ report.id }}" class="fa-table__row">
    <td class="fa-table__cell" data-sort-value="{{ report.name }}">
        <a href="{{ path('app_scheduled_report_show', {id: report.id}) }}"
           class="fa-row-link"
           data-turbo-frame="fa-form-modal"><strong>{{ report.name }}</strong></a>
    </td>
    <td class="fa-table__cell">
        {% include '_components/_badge.html.twig' with { variant: 'info', content: ('scheduled_report.type.' ~ report.reportType)|trans({}, 'scheduled_reports') } %}
    </td>
    <td class="fa-table__cell">{{ ('scheduled_report.schedule.' ~ report.schedule)|trans({}, 'scheduled_reports') }}</td>
    <td class="fa-table__cell">
        {% if report.format == 'pdf' %}
            {% include '_components/_badge.html.twig' with { variant: 'danger', icon: 'nav-file-pdf', content: 'PDF' } %}
        {% else %}
            {% include '_components/_badge.html.twig' with { variant: 'success', icon: 'nav-file-earmark-spreadsheet', content: 'Excel' } %}
        {% endif %}
    </td>
    <td class="fa-table__cell">
        {% if report.active %}
            {% include '_components/_badge.html.twig' with { variant: 'success', content: 'scheduled_report.status.active'|trans({}, 'scheduled_reports') } %}
        {% else %}
            {% include '_components/_badge.html.twig' with { variant: 'secondary', content: 'scheduled_report.status.inactive'|trans({}, 'scheduled_reports') } %}
        {% endif %}
    </td>
    <td class="fa-table__cell" data-sort-value="{{ report.nextRunAt ? report.nextRunAt|date('Y-m-d H:i') : '' }}">
        {% if report.nextRunAt %}
            {{ report.nextRunAt|date('Y-m-d H:i') }}
            {% if report.isDue() %}
                {% include '_components/_badge.html.twig' with { variant: 'warning', content: 'scheduled_report.status.due'|trans({}, 'scheduled_reports') } %}
            {% endif %}
        {% else %}
            <span class="text-muted">-</span>
        {% endif %}
    </td>
    <td class="fa-table__cell">
        {% include '_components/_badge.html.twig' with { variant: 'primary', content: report.recipients|length } %}
    </td>
    <td class="fa-table__cell fa-table__cell--actions">
        <div class="btn-group btn-group-sm" role="group" aria-label="{{ 'common.actions'|trans({}, 'messages') }}">
            <a href="{{ path('app_scheduled_report_show', {id: report.id}) }}"
               class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
               data-turbo-frame="fa-form-modal"
               title="{{ 'scheduled_report.action.view'|trans({}, 'scheduled_reports') }}"
               aria-label="{{ 'scheduled_report.action.view'|trans({}, 'scheduled_reports') }}">
                <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
            </a>
            <a href="{{ path('app_scheduled_report_edit', {id: report.id}) }}"
               class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
               data-turbo-frame="fa-form-modal"
               title="{{ 'scheduled_report.action.edit'|trans({}, 'scheduled_reports') }}"
               aria-label="{{ 'scheduled_report.action.edit'|trans({}, 'scheduled_reports') }}">
                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
            </a>
        </div>
    </td>
</tr>
