{# DoraDataFlow read-only detail — rendered inside the fa-form-modal Turbo Frame.
   Uses the drawer chrome (header/body/footer/kv) which renders cleanly as a
   flex column; condensed, with a "Vollansicht" link to the full page. #}
{% trans_default_domain 'dora_data_flow' %}
<turbo-frame id="fa-form-modal">
    <div class="fa-drawer__header">
        <div class="fa-drawer__header-text">
            <div class="fa-drawer__eyebrow">DORA Art. 28 · RT_03 · Register of Information</div>
            <div class="fa-drawer__title">{{ flow.displayLabel }}</div>
        </div>
        <button type="button" class="fa-drawer__close" data-action="fa-form-modal#close"
                aria-label="{{ 'common.close'|trans({}, 'messages') }}">
            <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i>
        </button>
    </div>
    <div class="fa-drawer__body">
        {% if flow.supplier %}
        <div class="fa-drawer__kv">
            <span class="label">{{ 'dora_data_flow.field.supplier'|trans({}, 'dora_data_flow') }}</span>
            <span>{{ flow.supplier.name }}</span>
        </div>
        {% endif %}
        <div class="fa-drawer__kv">
            <span class="label">{{ 'dora_data_flow.field.direction'|trans({}, 'dora_data_flow') }}</span>
            <span>{% include '_components/_badge.html.twig' with {
                variant: 'info',
                content: ('dora_data_flow.direction.' ~ flow.direction)|trans({}, 'dora_data_flow')
            } %}</span>
        </div>
        {% if flow.processingPurpose %}
        <div class="fa-drawer__section">
            <span class="label">{{ 'dora_data_flow.field.processing_purpose'|trans({}, 'dora_data_flow') }}</span>
            <p class="fa-drawer__desc">{{ flow.processingPurpose|u.truncate(280, '…') }}</p>
        </div>
        {% endif %}
        {% if flow.dataCategories is not empty %}
        <div class="fa-drawer__kv">
            <span class="label">{{ 'dora_data_flow.field.data_categories'|trans({}, 'dora_data_flow') }}</span>
            <span>
                {% for cat in flow.dataCategories %}
                    {% include '_components/_badge.html.twig' with { variant: 'secondary', content: cat } %}
                {% endfor %}
            </span>
        </div>
        {% endif %}
        {% if flow.dataVolume %}
        <div class="fa-drawer__kv">
            <span class="label">{{ 'dora_data_flow.field.data_volume'|trans({}, 'dora_data_flow') }}</span>
            <span>{{ flow.dataVolume }}</span>
        </div>
        {% endif %}
        {% if flow.securityMeasures is not empty %}
        <div class="fa-drawer__kv">
            <span class="label">{{ 'dora_data_flow.field.security_measures'|trans({}, 'dora_data_flow') }}</span>
            <span>
                {% for measure in flow.securityMeasures %}
                    {% include '_components/_badge.html.twig' with { variant: 'success', content: measure } %}
                {% endfor %}
            </span>
        </div>
        {% endif %}
        <div class="fa-drawer__kv">
            <span class="label">{{ 'dora_data_flow.field.cross_border'|trans({}, 'dora_data_flow') }}</span>
            <span>
                {% if flow.crossBorder %}
                    {% include '_components/_badge.html.twig' with { variant: 'warning', content: 'common.yes'|trans({}, 'messages') } %}
                {% else %}
                    {% include '_components/_badge.html.twig' with { variant: 'success', content: 'common.no'|trans({}, 'messages') } %}
                {% endif %}
            </span>
        </div>
        {% if flow.receivingCountry %}
        <div class="fa-drawer__kv">
            <span class="label">{{ 'dora_data_flow.field.receiving_country'|trans({}, 'dora_data_flow') }}</span>
            <span><code>{{ flow.receivingCountry }}</code></span>
        </div>
        {% endif %}
        <div class="fa-drawer__section">
            <a href="{{ path('app_dora_data_flow_show', {id: flow.id}) }}" data-turbo="false" class="fa-row-link">
                {{ 'common.open_full_view'|trans({}, 'messages') }} →
            </a>
        </div>
    </div>
    <div class="fa-drawer__footer" style="display:flex;gap:10px;justify-content:flex-end">
        <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--md" data-action="fa-form-modal#close">
            <span class="fa-cyber-btn__label">{{ 'common.close'|trans({}, 'messages') }}</span>
        </button>
        {% if is_granted('ROLE_USER') %}
            <a href="{{ path('app_dora_data_flow_edit', {id: flow.id}) }}" data-turbo-frame="fa-form-modal"
               class="fa-cyber-btn fa-cyber-btn--md">
                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                <span class="fa-cyber-btn__label">{{ 'common.edit'|trans({}, 'messages') }}</span>
            </a>
        {% endif %}
    </div>
</turbo-frame>
