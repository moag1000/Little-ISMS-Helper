{# Single DoraDataFlow table row — shared by index and the Turbo Stream that
   replaces/appends a row after an in-modal save. The supplier cell opens the
   read-only detail in the fa-form-modal frame; the eye/edit actions do the same. #}
{% trans_default_domain 'dora_data_flow' %}
<tr id="dora-data-flow-row-{{ flow.id }}">
    <td>
        <a href="{{ path('app_dora_data_flow_show', {id: flow.id}) }}"
           data-turbo-frame="fa-form-modal"
           class="fa-row-link">
            <strong>{% if flow.supplier %}{{ flow.supplier.name }}{% else %}<span class="text-muted-color">-</span>{% endif %}</strong>
        </a>
    </td>
    <td>
        {% include '_components/_badge.html.twig' with {
            variant: 'info',
            content: ('dora_data_flow.direction.' ~ flow.direction)|trans({}, 'dora_data_flow')
        } %}
    </td>
    <td>
        {% for cat in flow.dataCategories %}
            {% include '_components/_badge.html.twig' with { variant: 'secondary', content: cat } %}
        {% else %}
            <span class="text-muted-color">-</span>
        {% endfor %}
    </td>
    <td>
        {% if flow.crossBorder %}
            {% include '_components/_badge.html.twig' with { variant: 'warning', content: 'common.yes'|trans({}, 'messages') } %}
        {% else %}
            {% include '_components/_badge.html.twig' with { variant: 'success', content: 'common.no'|trans({}, 'messages') } %}
        {% endif %}
    </td>
    <td>
        {% if flow.receivingCountry %}<code>{{ flow.receivingCountry }}</code>{% else %}<span class="text-muted-color">-</span>{% endif %}
    </td>
    <td class="text-center">
        <div class="btn-group btn-group-sm" role="group" aria-label="{{ 'common.actions'|trans({}, 'messages') }}">
            <a href="{{ path('app_dora_data_flow_show', {id: flow.id}) }}"
               class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
               data-turbo-frame="fa-form-modal"
               title="{{ 'common.view'|trans({}, 'messages') }}"
               aria-label="{{ 'common.view'|trans({}, 'messages') }}">
                <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
            </a>
            {% if is_granted('ROLE_USER') %}
            <a href="{{ path('app_dora_data_flow_edit', {id: flow.id}) }}"
               class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
               data-turbo-frame="fa-form-modal"
               title="{{ 'common.edit'|trans({}, 'messages') }}"
               aria-label="{{ 'common.edit'|trans({}, 'messages') }}">
                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
            </a>
            {% endif %}
        </div>
    </td>
</tr>
