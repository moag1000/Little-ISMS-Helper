{# DoraDataFlow create/edit rendered inside the fa-form-modal Turbo Frame.
   Explicit form action (the document URL stays on the list). On valid submit the
   controller returns a Turbo Stream (row replace/append). #}
{% trans_default_domain 'dora_data_flow' %}
{% set is_edit = flow is defined and flow and flow.id is not null %}
{% set form_action = is_edit
    ? path('app_dora_data_flow_edit', { id: flow.id })
    : path('app_dora_data_flow_new') %}
<turbo-frame id="fa-form-modal">
    {{ form_start(form, { action: form_action, method: 'POST', attr: {
        id: 'dora-data-flow-modal-form',
        'data-turbo-frame': 'fa-form-modal'
    } }) }}
    {% include 'dora_data_flow/_form_body.html.twig' with {
        form: form,
        modal: true,
        title: is_edit
            ? flow.displayLabel
            : 'dora_data_flow.title.create'|trans({}, 'dora_data_flow'),
        actions: {
            close: { label: 'common.cancel'|trans({}, 'messages'), variant: 'ghost', action: 'fa-form-modal#close' },
            submit: { label: 'common.save'|trans({}, 'messages'), variant: 'primary' }
        }
    } %}
    {{ form_end(form) }}
</turbo-frame>
