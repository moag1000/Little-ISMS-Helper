{% extends 'base.html.twig' %}
{% trans_default_domain 'tisax_isa' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_stepper.html.twig' as _fa_stepper %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block title %}{{ 'tisax.import.disclaimer.title'|trans({}, 'tisax_isa') }}{% endblock %}

{% block body %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'tisax.import.nav.title'|trans({}, 'tisax_isa'), href: path('app_tisax_import_disclaimer', { _locale: app.request.locale }) },
            { label: 'tisax.import.disclaimer.title'|trans({}, 'tisax_isa') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'status-shield', label: 'TISAX' },
        title: 'tisax.import.page.title'|trans({}, 'tisax_isa'),
        subtitle: 'tisax.import.page.subtitle'|trans({}, 'tisax_isa')
    }) }}

    {{ _fa_stepper.render([
        { label: 'tisax.import.step.disclaimer'|trans({}, 'tisax_isa') },
        { label: 'tisax.import.step.upload'|trans({}, 'tisax_isa') },
        { label: 'tisax.import.step.validate'|trans({}, 'tisax_isa') },
        { label: 'tisax.import.step.preview'|trans({}, 'tisax_isa') },
        { label: 'tisax.import.step.commit'|trans({}, 'tisax_isa') },
        { label: 'tisax.import.step.assess'|trans({}, 'tisax_isa') }
    ], 0) }}

    <div class="row justify-content-center mt-4">
        <div class="col-lg-8">

            {# ── ENX Legal Notice: why the catalogue is incomplete + BYO-Import guide ── #}
            {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', title: 'tisax.import.disclaimer.enx_notice.title'|trans({}, 'tisax_isa'), class: 'mb-4' } } %}
                {% block alert_body %}
                    {% trans_default_domain 'tisax_isa' %}
                    <p class="fa-alert__message mb-2">{{ 'tisax.import.disclaimer.enx_notice.body'|trans({}, 'tisax_isa') }}</p>
                    <p class="fa-alert__message fw-semibold mb-1">{{ 'tisax.import.disclaimer.enx_notice.steps_heading'|trans({}, 'tisax_isa') }}</p>
                    <ol class="mb-2 ps-3">
                        <li>
                            {{ 'tisax.import.disclaimer.enx_notice.steps.1'|trans({}, 'tisax_isa') }}
                            <a href="https://enx.com/tisax" target="_blank" rel="noopener noreferrer" class="fw-semibold">ENX Association (enx.com/tisax)</a>
                        </li>
                        <li>{{ 'tisax.import.disclaimer.enx_notice.steps.2'|trans({}, 'tisax_isa') }}</li>
                        <li>{{ 'tisax.import.disclaimer.enx_notice.steps.3'|trans({}, 'tisax_isa') }}</li>
                    </ol>
                    <p class="fa-alert__message small mb-0">
                        <strong>{{ 'tisax.import.disclaimer.enx_notice.after_import_label'|trans({}, 'tisax_isa') }}:</strong>
                        {{ 'tisax.import.disclaimer.enx_notice.after_import'|trans({}, 'tisax_isa') }}
                    </p>
                {% endblock %}
            {% endembed %}

            <div class="card border-warning">
                <div class="card-body">
                    <h5 class="card-title text-warning">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        {{ 'tisax.import.disclaimer.legal_notice'|trans({}, 'tisax_isa') }}
                    </h5>
                    <p>{{ 'tisax.import.disclaimer.body_1'|trans({}, 'tisax_isa') }}</p>
                    <p>{{ 'tisax.import.disclaimer.body_2'|trans({}, 'tisax_isa') }}</p>
                    <ul>
                        <li>{{ 'tisax.import.disclaimer.bullet_1'|trans({}, 'tisax_isa') }}</li>
                        <li>{{ 'tisax.import.disclaimer.bullet_2'|trans({}, 'tisax_isa') }}</li>
                        <li>{{ 'tisax.import.disclaimer.bullet_3'|trans({}, 'tisax_isa') }}</li>
                    </ul>
                    <p class="text-muted small">{{ 'tisax.import.disclaimer.body_3'|trans({}, 'tisax_isa') }}</p>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-body">
                    {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}
                        <div class="mb-3">
                            {{ form_row(form.licenceConfirmed) }}
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-1"></i>
                                {{ 'tisax.import.disclaimer.confirm_button'|trans({}, 'tisax_isa') }}
                            </button>
                            <a href="{{ path('app_prototype_protection_index', { _locale: app.request.locale }) }}" class="btn btn-outline-secondary">
                                {{ 'common.cancel'|trans({}, 'messages') }}
                            </a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
