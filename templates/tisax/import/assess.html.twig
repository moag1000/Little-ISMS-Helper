{% extends 'base.html.twig' %}
{% trans_default_domain 'tisax_isa' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_stepper.html.twig' as _fa_stepper %}
{% import '_components/_fa_table.html.twig' as _fa_table %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}
{% import '_components/_fa_progress.html.twig' as _fa_progress %}

{% block title %}{{ 'tisax.import.assess.title'|trans({}, 'tisax_isa') }}{% endblock %}

{% block body %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'tisax.import.nav.title'|trans({}, 'tisax_isa'), url: path('app_tisax_import_disclaimer') },
            { label: 'tisax.import.assess.title'|trans({}, 'tisax_isa') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'status-gauge', label: 'TISAX' },
        title: 'tisax.import.assess.title'|trans({}, 'tisax_isa'),
        subtitle: 'tisax.import.assess.subtitle'|trans({}, 'tisax_isa'),
        actions: [
            {
                label: 'tisax.import.assess.export_enx'|trans({}, 'tisax_isa'),
                href: path('app_tisax_import_export_enx', { _locale: app.request.locale, frameworkId: framework.id }),
                variant: 'outline-secondary',
                icon: 'ui-download'
            }
        ]
    }) }}

    {{ _fa_stepper.render([
        { label: 'tisax.import.step.disclaimer'|trans({}, 'tisax_isa') },
        { label: 'tisax.import.step.upload'|trans({}, 'tisax_isa') },
        { label: 'tisax.import.step.validate'|trans({}, 'tisax_isa') },
        { label: 'tisax.import.step.preview'|trans({}, 'tisax_isa') },
        { label: 'tisax.import.step.commit'|trans({}, 'tisax_isa') },
        { label: 'tisax.import.step.assess'|trans({}, 'tisax_isa') }
    ], 5) }}

    <div class="mt-4">
        {# Aggregate KPI tiles — IS/PP use Reifegrad, DP uses tristate #}
        <div class="row mb-4">
            <div class="col-md-3">
                {{ _fa_feature_card.render({
                    label: 'tisax.import.assess.avg_reifegrad'|trans({}, 'tisax_isa'),
                    value: aggregate.average ~ ' / 5',
                    variant: 'primary',
                    icon: 'status-gauge'
                }) }}
            </div>
            <div class="col-md-3">
                {{ _fa_feature_card.render({
                    label: 'tisax.import.assess.assessed'|trans({}, 'tisax_isa'),
                    value: aggregate.assessed ~ ' / ' ~ aggregate.total,
                    variant: 'success',
                    icon: 'status-ok'
                }) }}
            </div>
            {# IS/PP tier tiles (Reifegrad) #}
            {% for tier, tierData in aggregate.byTier %}
                {% if tierData.model is defined and tierData.model == 'reifegrad' %}
                <div class="col-md-3">
                    {{ _fa_feature_card.render({
                        label: tier|replace({'_': ' '})|title,
                        value: tierData.average ~ ' / 5',
                        variant: 'info',
                        icon: 'nav-collection'
                    }) }}
                </div>
                {% endif %}
            {% endfor %}
            {# DP tier tile (tristate) #}
            {% if aggregate.dp.total > 0 %}
            <div class="col-md-3">
                {{ _fa_feature_card.render({
                    label: 'tisax.import.assess.dp.tile_label'|trans({}, 'tisax_isa'),
                    value: aggregate.dp.compliant ~ ' / ' ~ aggregate.dp.total ~ ' OK',
                    variant: aggregate.dp.non_compliant > 0 ? 'danger' : 'success',
                    icon: 'nav-collection'
                }) }}
            </div>
            {% endif %}
        </div>

        {# DP tier info banner #}
        {% if aggregate.dp.total > 0 %}
        <div class="alert alert-info d-flex align-items-start mb-4" role="alert">
            <i class="fa-icon fa-icon--nav-info-circle me-2 mt-1 flex-shrink-0"></i>
            <div>
                <strong>{{ 'tisax.import.assess.dp.legend'|trans({}, 'tisax_isa') }}</strong>
                {{ 'tisax.import.assess.dp.hint'|trans({}, 'tisax_isa') }}
            </div>
        </div>
        {% endif %}

        {# Assessment form #}
        <form method="post" action="{{ path('app_tisax_import_assess', { _locale: app.request.locale, frameworkId: framework.id }) }}">
            <input type="hidden" name="_token" value="{{ token }}">

            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">{{ 'tisax.import.assess.requirements_heading'|trans({}, 'tisax_isa') }}</h6>
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="fa-icon fa-icon--save me-1"></i>
                        {{ 'tisax.import.assess.save_button'|trans({}, 'tisax_isa') }}
                    </button>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead>
                            <tr>
                                <th>{{ 'tisax.import.assess.col.id'|trans({}, 'tisax_isa') }}</th>
                                <th>{{ 'tisax.import.assess.col.title'|trans({}, 'tisax_isa') }}</th>
                                <th>{{ 'tisax.import.assess.col.tier'|trans({}, 'tisax_isa') }}</th>
                                <th title="{{ 'tisax.import.assess.col.req_levels_tooltip'|trans({}, 'tisax_isa') }}">
                                    {{ 'tisax.import.assess.col.req_levels'|trans({}, 'tisax_isa') }}
                                </th>
                                <th>{{ 'tisax.import.assess.col.assessment'|trans({}, 'tisax_isa') }}</th>
                                <th>{{ 'tisax.import.assess.col.target'|trans({}, 'tisax_isa') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% set dimLabels = {
                                'information_security': 'Informationssicherheit',
                                'prototype_protection': 'Prototypenschutz',
                                'data_protection': 'Datenschutz'
                            } %}
                            {% set prevCat = null %}
                            {% for req in requirements %}
                            {% set isDataProtection = req.category == 'data_protection' %}
                            {% if req.category != prevCat %}
                                <tr class="table-active">
                                    <th colspan="6" class="py-2">
                                        <i class="fa-icon fa-icon--folder me-1"></i>
                                        {{ dimLabels[req.category]|default(req.category|replace({'_': ' '})|capitalize) }}
                                        {% if isDataProtection %}<span class="text-muted fw-normal small ms-2">— Bewertung mit OK / Nicht OK (kein Reifegrad)</span>{% endif %}
                                    </th>
                                </tr>
                                {% set prevCat = req.category %}
                            {% endif %}
                            <tr>
                                <td><code>{{ req.requirementId }}</code></td>
                                <td class="text-truncate" style="max-width:300px" title="{{ req.title }}">{{ req.title }}</td>
                                <td>
                                    {% if isDataProtection %}
                                        <span class="badge bg-info text-dark">{{ dimLabels['data_protection'] }}</span>
                                    {% else %}
                                        <span class="badge bg-secondary">{{ dimLabels[req.category]|default(req.category|replace({'_': ' '})|capitalize) }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {# ── Requirement tiers M/S/H/VH/SGA (B3 tiers-first-class, §9.2) ── #}
                                    {% set tierMap = req.dataSourceMapping ?? {} %}
                                    {% set tiers = [
                                        { key: 'tisax_must',     abbr: 'must',     css: 'bg-secondary' },
                                        { key: 'tisax_should',   abbr: 'should',   css: 'bg-secondary' },
                                        { key: 'tisax_high',     abbr: 'high',     css: 'bg-warning text-dark' },
                                        { key: 'tisax_veryHigh', abbr: 'very_high', css: 'bg-danger' },
                                        { key: 'tisax_sga',      abbr: 'sga',      css: 'bg-info text-dark' }
                                    ] %}
                                    <div class="d-flex gap-1 flex-wrap" role="group"
                                         aria-label="{{ 'tisax.import.assess.req_levels.aria'|trans({}, 'tisax_isa') }}">
                                        {% set anyTier = false %}
                                        {% for tier in tiers %}
                                            {% if tierMap[tier.key] is defined and tierMap[tier.key] is not empty %}
                                                {% set anyTier = true %}
                                                <span class="badge {{ tier.css }}"
                                                      title="{{ ('tisax.import.assess.req_level.' ~ tier.abbr ~ '_tooltip')|trans({}, 'tisax_isa') }}">
                                                    {{ ('tisax.import.assess.req_level.' ~ tier.abbr ~ '_abbr')|trans({}, 'tisax_isa') }}
                                                </span>
                                            {% endif %}
                                        {% endfor %}
                                        {% if not anyTier %}
                                            <span class="text-muted small">{{ 'tisax.import.assess.req_levels.none'|trans({}, 'tisax_isa') }}</span>
                                        {% endif %}
                                    </div>
                                </td>
                                <td>
                                    {% if isDataProtection %}
                                        {# ── Data Protection: 3-state radio (NA / OK / Nicht OK) ── #}
                                        {% set currentDpState = req.assessmentStateDp %}
                                        <div class="d-flex gap-2 align-items-center flex-wrap" role="group"
                                             aria-label="{{ 'tisax.import.assess.dp.aria_group'|trans({}, 'tisax_isa') }}">
                                            <div class="form-check form-check-inline mb-0">
                                                <input class="form-check-input"
                                                       type="radio"
                                                       name="dp[{{ req.id }}]"
                                                       id="dp_na_{{ req.id }}"
                                                       value="not_applicable"
                                                       {{ currentDpState == 'not_applicable' or currentDpState is null ? 'checked' }}>
                                                <label class="form-check-label text-muted" for="dp_na_{{ req.id }}">
                                                    {{ 'tisax.import.assess.dp.state.na'|trans({}, 'tisax_isa') }}
                                                </label>
                                            </div>
                                            <div class="form-check form-check-inline mb-0">
                                                <input class="form-check-input"
                                                       type="radio"
                                                       name="dp[{{ req.id }}]"
                                                       id="dp_ok_{{ req.id }}"
                                                       value="compliant"
                                                       {{ currentDpState == 'compliant' ? 'checked' }}>
                                                <label class="form-check-label text-success fw-semibold" for="dp_ok_{{ req.id }}">
                                                    {{ 'tisax.import.assess.dp.state.ok'|trans({}, 'tisax_isa') }}
                                                </label>
                                            </div>
                                            <div class="form-check form-check-inline mb-0">
                                                <input class="form-check-input"
                                                       type="radio"
                                                       name="dp[{{ req.id }}]"
                                                       id="dp_nok_{{ req.id }}"
                                                       value="non_compliant"
                                                       {{ currentDpState == 'non_compliant' ? 'checked' }}>
                                                <label class="form-check-label text-danger fw-semibold" for="dp_nok_{{ req.id }}">
                                                    {{ 'tisax.import.assess.dp.state.not_ok'|trans({}, 'tisax_isa') }}
                                                </label>
                                            </div>
                                        </div>
                                    {% else %}
                                        {# ── IS / PP: 0-5 Reifegrad select ── #}
                                        {% set currentLevel = req.maturityCurrent %}
                                        <select name="reifegrad[{{ req.id }}]" class="form-select form-select-sm" style="width:auto">
                                            <option value="" {% if currentLevel is null %}selected{% endif %}>
                                                {{ 'tisax.import.assess.level.unrated'|trans({}, 'tisax_isa') }}
                                            </option>
                                            {% for levelInt, levelStr in levels %}
                                            <option value="{{ levelInt }}"
                                                {% if currentLevel == levelStr %}selected{% endif %}>
                                                {{ levelInt }} — {{ ('tisax.import.assess.level.' ~ levelStr)|trans({}, 'tisax_isa') }}
                                            </option>
                                            {% endfor %}
                                        </select>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if isDataProtection %}
                                        <span class="badge bg-success-subtle text-success-emphasis">
                                            {{ 'tisax.import.assess.dp.target_label'|trans({}, 'tisax_isa') }}
                                        </span>
                                    {% elseif req.maturityTarget %}
                                        <span class="text-muted">{{ req.maturityTarget }}</span>
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                </td>
                            </tr>
                            {% else %}
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    {{ 'tisax.import.assess.no_requirements'|trans({}, 'tisax_isa') }}
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% if requirements|length > 0 %}
                <div class="card-footer d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <span class="text-muted small">
                        {{ aggregate.assessed|default(0) }} / {{ requirements|length }} bewertet.
                        Unbewertete Zeilen stehen auf „Bitte wählen …" und zählen als offen.
                    </span>
                    <button type="submit" class="btn btn-primary">
                        <i class="fa-icon fa-icon--save me-1"></i>
                        {{ 'tisax.import.assess.save_button'|trans({}, 'tisax_isa') }}
                    </button>
                </div>
                {% endif %}
            </div>
        </form>

        {# Done / result — the import's red thread ends here: send the user to the
           TISAX overview so they actually SEE their readiness (the wizard never
           linked the result before). #}
        <div class="card border-success mt-3">
            <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <strong>Import abgeschlossen.</strong>
                    <span class="text-muted">Ihre TISAX-Bewertung ist gespeichert — sehen Sie Abdeckung, Bereiche und Lücken in der Übersicht.</span>
                </div>
                <a href="{{ path('app_compliance_framework_show', { id: framework.id }) }}" class="btn btn-success">
                    <i class="fa-icon fa-icon--arrow-right me-1"></i> Zur TISAX-Übersicht
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
