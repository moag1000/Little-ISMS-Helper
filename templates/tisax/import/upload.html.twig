{% extends 'base.html.twig' %}
{% trans_default_domain 'tisax_isa' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_stepper.html.twig' as _fa_stepper %}

{% block title %}{{ 'tisax.import.upload.title'|trans({}, 'tisax_isa') }}{% endblock %}

{% block body %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'tisax.import.nav.title'|trans({}, 'tisax_isa'), url: path('app_tisax_import_disclaimer', { _locale: app.request.locale }) },
            { label: 'tisax.import.upload.title'|trans({}, 'tisax_isa') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'ui-upload', label: 'TISAX' },
        title: 'tisax.import.upload.title'|trans({}, 'tisax_isa'),
        subtitle: 'tisax.import.upload.subtitle'|trans({}, 'tisax_isa')
    }) }}

    {{ _fa_stepper.render([
        { label: 'tisax.import.step.disclaimer'|trans({}, 'tisax_isa') },
        { label: 'tisax.import.step.upload'|trans({}, 'tisax_isa') },
        { label: 'tisax.import.step.validate'|trans({}, 'tisax_isa') },
        { label: 'tisax.import.step.preview'|trans({}, 'tisax_isa') },
        { label: 'tisax.import.step.commit'|trans({}, 'tisax_isa') },
        { label: 'tisax.import.step.assess'|trans({}, 'tisax_isa') }
    ], 1) }}

    <div class="row justify-content-center mt-4">
        <div class="col-lg-8">
            <div class="card mb-3">
                <div class="card-body">
                    <p class="text-muted mb-3">{{ 'tisax.import.upload.instruction'|trans({}, 'tisax_isa') }}</p>

                    {{ form_start(form, { attr: { enctype: 'multipart/form-data', novalidate: 'novalidate' } }) }}
                        <div class="mb-3">
                            {{ form_label(form.workbook) }}
                            {{ form_widget(form.workbook) }}
                            {{ form_errors(form.workbook) }}
                            <div class="form-text text-muted">{{ 'tisax.import.upload.help'|trans({}, 'tisax_isa') }}</div>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fa-icon fa-icon--nav-upload me-1"></i>
                                {{ 'tisax.import.upload.submit_button'|trans({}, 'tisax_isa') }}
                            </button>
                            <a href="{{ path('app_tisax_import_disclaimer', { _locale: app.request.locale }) }}" class="btn btn-outline-secondary">
                                {{ 'common.back'|trans({}, 'messages') }}
                            </a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>

            <div class="card border-info-subtle">
                <div class="card-header">
                    <i class="fa-icon fa-icon--nav-info-circle me-1"></i>
                    {{ 'tisax.import.upload.workbook_help.title'|trans({}, 'tisax_isa') }}
                </div>
                <div class="card-body small">
                    <p class="mb-2">{{ 'tisax.import.upload.workbook_help.download_intro'|trans({}, 'tisax_isa') }}</p>
                    <ul class="mb-3">
                        <li>
                            <strong>{{ 'tisax.import.upload.workbook_help.en_label'|trans({}, 'tisax_isa') }}:</strong>
                            <a href="https://portal.enx.com/isa6-en.xlsx" target="_blank" rel="noopener noreferrer" class="text-break">https://portal.enx.com/isa6-en.xlsx</a>
                        </li>
                        <li>
                            <strong>{{ 'tisax.import.upload.workbook_help.de_label'|trans({}, 'tisax_isa') }}:</strong>
                            <a href="https://portal.enx.com/isa6-de.xlsx" target="_blank" rel="noopener noreferrer" class="text-break">https://portal.enx.com/isa6-de.xlsx</a>
                        </li>
                    </ul>
                    <p class="mb-1 fw-semibold">{{ 'tisax.import.upload.workbook_help.expected_sheets_title'|trans({}, 'tisax_isa') }}</p>
                    <ul class="mb-3">
                        <li>{{ 'tisax.import.upload.workbook_help.sheets_en_label'|trans({}, 'tisax_isa') }}: <code>Information Security</code>, <code>Prototype Protection</code>, <code>Data Protection</code></li>
                        <li>{{ 'tisax.import.upload.workbook_help.sheets_de_label'|trans({}, 'tisax_isa') }}: <code>Informationssicherheit</code>, <code>Prototypenschutz</code>, <code>Datenschutz</code></li>
                    </ul>
                    <p class="mb-0 text-muted">
                        <i class="fa-icon fa-icon--ui-lightbulb me-1"></i>
                        {{ 'tisax.import.upload.workbook_help.troubleshoot_hint'|trans({}, 'tisax_isa') }}
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
