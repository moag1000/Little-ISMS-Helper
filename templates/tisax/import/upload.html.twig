{% extends 'base.html.twig' %}
{% trans_default_domain 'tisax_isa' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_stepper.html.twig' as _fa_stepper %}

{% block title %}{{ 'tisax.import.upload.title'|trans({}, 'tisax_isa') }}{% endblock %}

{% block body %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'tisax.import.nav.title'|trans({}, 'tisax_isa'), href: path('app_tisax_import_disclaimer', { _locale: app.request.locale }) },
            { label: 'tisax.import.upload.title'|trans({}, 'tisax_isa') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'ui-upload', label: 'TISAX' },
        title: 'tisax.import.upload.title'|trans({}, 'tisax_isa'),
        subtitle: 'tisax.import.upload.subtitle'|trans({}, 'tisax_isa')
    }) }}

    {{ _fa_stepper.render([
        { label: 'tisax.import.step.disclaimer'|trans({}, 'tisax_isa') },
        { label: 'tisax.import.step.upload'|trans({}, 'tisax_isa') },
        { label: 'tisax.import.step.validate'|trans({}, 'tisax_isa') },
        { label: 'tisax.import.step.preview'|trans({}, 'tisax_isa') },
        { label: 'tisax.import.step.commit'|trans({}, 'tisax_isa') },
        { label: 'tisax.import.step.assess'|trans({}, 'tisax_isa') }
    ], 1) }}

    <div class="row justify-content-center mt-4">
        <div class="col-lg-7">
            <div class="card">
                <div class="card-body">
                    <p class="text-muted mb-3">{{ 'tisax.import.upload.instruction'|trans({}, 'tisax_isa') }}</p>

                    {{ form_start(form, { attr: { enctype: 'multipart/form-data', novalidate: 'novalidate' } }) }}
                        <div class="mb-3">
                            {{ form_label(form.workbook) }}
                            {{ form_widget(form.workbook) }}
                            {{ form_errors(form.workbook) }}
                            <div class="form-text text-muted">{{ 'tisax.import.upload.help'|trans({}, 'tisax_isa') }}</div>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-upload me-1"></i>
                                {{ 'tisax.import.upload.submit_button'|trans({}, 'tisax_isa') }}
                            </button>
                            <a href="{{ path('app_tisax_import_disclaimer', { _locale: app.request.locale }) }}" class="btn btn-outline-secondary">
                                {{ 'common.back'|trans({}, 'messages') }}
                            </a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
