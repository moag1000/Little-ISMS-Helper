{% extends 'base.html.twig' %}
{% trans_default_domain 'fte_tracking' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_settings_table.html.twig' as _fa_settings %}

{% block title %}{{ 'fte_tracking.calibration.title'|trans({}, 'fte_tracking') }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% block body %}
<div class="fa-aurora-surface">

    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.dashboard'|trans({}, 'nav'), url: path('app_dashboard', {_locale: app.request.locale}) },
            { label: 'fte_tracking.dashboard.title'|trans({}, 'fte_tracking'), url: path('analytics_fte_index', {_locale: app.request.locale}) },
            { label: 'fte_tracking.calibration.title'|trans({}, 'fte_tracking') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'nav-sliders', label: 'fte_tracking.calibration.badge'|trans({}, 'fte_tracking') },
        title: 'fte_tracking.calibration.title'|trans({}, 'fte_tracking'),
        subtitle: 'fte_tracking.calibration.subtitle'|trans({}, 'fte_tracking')
    }) }}

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fa-icon fa-icon--ui-edit me-2" aria-hidden="true"></i>
                        {{ 'fte_tracking.calibration.form_title'|trans({}, 'fte_tracking') }}
                    </h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-4">{{ 'fte_tracking.calibration.help'|trans({}, 'fte_tracking') }}</p>

                    <form method="post" action="{{ path('analytics_fte_calibration', {_locale: app.request.locale}) }}" novalidate>
                        <input type="hidden" name="_token" value="{{ csrf_token('fte_calibration') }}">

                        {%- set calib_rows = [] -%}
                        {%- for opType in operation_types -%}
                            {%- set calib_rows = calib_rows|merge([{
                                kind:  'number',
                                label: ('fte_tracking.op.' ~ opType)|trans({}, 'fte_tracking'),
                                hint:  ('fte_tracking.op.' ~ opType ~ '.desc')|trans({}, 'fte_tracking'),
                                name:  'calibration[' ~ opType ~ ']',
                                value: constants[opType]|number_format(2),
                                min:   0.1,
                                max:   9999,
                                step:  0.5,
                                attrs: { id: 'calib_' ~ opType }
                            }]) -%}
                        {%- endfor -%}

                        {{ _fa_settings.render({
                            title: 'fte_tracking.calibration.form_title'|trans({}, 'fte_tracking'),
                            rows:  calib_rows
                        }) }}

                        <div class="d-flex justify-content-between mt-3">
                            <a href="{{ path('analytics_fte_index', {_locale: app.request.locale}) }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                                <i class="fa-icon fa-icon--util-arrow-left me-1" aria-hidden="true"></i>
                                {{ 'common.back'|trans({}, 'messages') }}
                            </a>
                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                                <i class="fa-icon fa-icon--ui-save me-1" aria-hidden="true"></i>
                                {{ 'fte_tracking.calibration.save'|trans({}, 'fte_tracking') }}
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}
