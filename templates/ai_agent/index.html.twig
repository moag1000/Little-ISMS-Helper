{% extends 'base.html.twig' %}

{% block title %}{{ 'ai_agent.page.title'|trans({}, 'mris') }}{% endblock %}

{% block body %}
<div class="container">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'ai_agent.page.title'|trans({}, 'mris') }}</li>
        </ol>
    </nav>

    <div class="page-header mb-4" data-tour="mris-ai-inventory">
        <h1>
            <i class="bi bi-robot" aria-hidden="true"></i>
            {{ 'ai_agent.page.title'|trans({}, 'mris') }}
        </h1>
        <p class="text-muted small mb-0">
            {{ 'ai_agent.page.intro'|trans({}, 'mris')|raw }}<br>
            <em>{{ 'ai_agent.page.source'|trans({}, 'mris') }}</em>
        </p>
    </div>

    {# Inventory Stats #}
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' with { 'class': 'text-center h-100' } %}
                {% block card_body %}
                    <div class="display-4 fw-bold">{{ stats.total }}</div>
                    <div class="small text-muted">{{ 'ai_agent.stats.total'|trans({}, 'mris') }}</div>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' with { 'class': 'text-center h-100' } %}
                {% block card_body %}
                    <div class="display-4 fw-bold text-danger">{{ stats.by_classification.high_risk }}</div>
                    <div class="small text-muted">{{ 'ai_agent.stats.high_risk'|trans({}, 'mris') }}</div>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' with { 'class': 'text-center h-100' } %}
                {% block card_body %}
                    <div class="display-4 fw-bold text-warning">{{ stats.unclassified }}</div>
                    <div class="small text-muted">{{ 'ai_agent.stats.unclassified'|trans({}, 'mris') }}</div>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' with { 'class': 'text-center h-100' } %}
                {% block card_body %}
                    <div class="display-4 fw-bold text-{{ stats.avg_completeness >= 80 ? 'success' : (stats.avg_completeness >= 50 ? 'warning' : 'danger') }}">{{ stats.avg_completeness }}%</div>
                    <div class="small text-muted">{{ 'ai_agent.stats.avg_completeness'|trans({}, 'mris') }}</div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    {# High-Risk Warning #}
    {% if high_risk_incomplete|length > 0 %}
        <div class="alert alert-danger mb-4">
            <i class="bi bi-exclamation-octagon-fill" aria-hidden="true"></i>
            <strong>{{ high_risk_incomplete|length }}</strong> — {{ 'ai_agent.alert.high_risk_incomplete'|trans({}, 'mris') }}
        </div>
    {% endif %}

    {# Inventory Table #}
    {% if agents|length == 0 %}
        <div class="alert alert-info">
            <i class="bi bi-info-circle" aria-hidden="true"></i>
            {{ 'ai_agent.alert.empty'|trans({}, 'mris')|raw }}
        </div>
    {% else %}
        {% embed '_components/_card.html.twig' %}
            {% block card_body %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th scope="col">{{ 'ai_agent.table.name'|trans({}, 'mris') }}</th>
                                <th scope="col">{{ 'ai_agent.table.provider'|trans({}, 'mris') }}</th>
                                <th scope="col">{{ 'ai_agent.table.model'|trans({}, 'mris') }}</th>
                                <th scope="col">{{ 'ai_agent.table.risk_class'|trans({}, 'mris') }}</th>
                                <th scope="col" class="text-center">{{ 'ai_agent.table.completeness'|trans({}, 'mris') }}</th>
                                <th scope="col"></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for agent in agents %}
                                {% set comp = completeness[agent.id] %}
                                <tr>
                                    <td>
                                        <strong>{{ agent.name }}</strong>
                                        {% if agent.aiAgentPurpose %}
                                            <div class="small text-muted">{{ agent.aiAgentPurpose|slice(0, 60) }}{% if agent.aiAgentPurpose|length > 60 %}…{% endif %}</div>
                                        {% endif %}
                                    </td>
                                    <td>{{ agent.aiAgentProvider|default('—') }}</td>
                                    <td><code>{{ agent.aiAgentModelVersion|default('—') }}</code></td>
                                    <td>
                                        {% if agent.aiAgentClassification == 'prohibited' %}
                                            {% include '_components/_badge.html.twig' with { variant: 'dark', content: 'ai_agent.risk.prohibited'|trans({}, 'mris') } %}
                                        {% elseif agent.aiAgentClassification == 'high_risk' %}
                                            {% include '_components/_badge.html.twig' with { variant: 'danger', content: 'ai_agent.risk.high_risk'|trans({}, 'mris') } %}
                                        {% elseif agent.aiAgentClassification == 'limited_risk' %}
                                            {% include '_components/_badge.html.twig' with { variant: 'warning', content: 'ai_agent.risk.limited_risk'|trans({}, 'mris') } %}
                                        {% elseif agent.aiAgentClassification == 'minimal_risk' %}
                                            {% include '_components/_badge.html.twig' with { variant: 'success', content: 'ai_agent.risk.minimal_risk'|trans({}, 'mris') } %}
                                        {% else %}
                                            {% include '_components/_badge.html.twig' with { variant: 'secondary', content: 'ai_agent.risk.unclassified'|trans({}, 'mris') } %}
                                        {% endif %}
                                    </td>
                                    <td class="text-center">
                                        <div class="progress" style="height: 18px; min-width: 120px;" title="{{ comp.missing|join(', ') }}">
                                            <div class="progress-bar bg-{{ comp.percentage >= 80 ? 'success' : (comp.percentage >= 50 ? 'warning' : 'danger') }}" style="width: {{ comp.percentage }}%">
                                                {{ comp.filled }}/{{ comp.total }}
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-end">
                                        <a href="{{ path('app_asset_show', {id: agent.id}) }}" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye" aria-hidden="true"></i>
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endblock %}
        {% endembed %}
    {% endif %}

    <div class="alert alert-light mt-4 small">
        <strong><i class="bi bi-info-circle" aria-hidden="true"></i></strong>
        {{ 'ai_agent.alert.mandatory_fields'|trans({}, 'mris')|nl2br }}
    </div>
</div>
{% endblock %}
