{% extends 'base.html.twig' %}
{% trans_default_domain 'bcm' %}

{% block title %}{{ 'bcm.page.title'|trans({}, 'bcm') }}{% endblock %}

{% block body %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.bcm'|trans({}, 'nav') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'diagram-3', label: 'bcm.page.title'|trans({}, 'bcm') },
        title: 'bcm.page.title'|trans({}, 'bcm'),
        subtitle: 'bcm.page.subtitle'|trans({}, 'bcm'),
        actions: [
            { label: 'bcm.action.data_reuse'|trans({}, 'bcm'), href: path('app_bcm_data_reuse'), variant: 'ghost', icon: 'link-45deg' },
            { label: 'bcm.action.add_process'|trans({}, 'bcm'), href: path('app_business_process_new'), variant: 'primary', icon: 'plus-lg' }
        ]
    }) }}
    <main class="fa-aurora-surface fa-aurora-surface--dots">

    {# KPI Overview Cards #}
    <div class="kpi-grid">
        <div class="col-auto">
            {{ _fa_feature_card.render({ label: 'bcm.stats.total_processes'|trans({}, 'bcm'), value: stats.total, variant: 'primary' }) }}
        </div>
        <div class="col-auto">
            {{ _fa_feature_card.render({ label: 'bcm.stats.critical_processes'|trans({}, 'bcm'), value: stats.critical, variant: 'danger' }) }}
        </div>
        <div class="col-auto">
            {{ _fa_feature_card.render({ label: 'bcm.stats.high_priority'|trans({}, 'bcm'), value: stats.high, variant: 'warning' }) }}
        </div>
        <div class="col-auto">
            {{ _fa_feature_card.render({ label: 'bcm.stats.avg_rto'|trans({}, 'bcm'), value: stats.avg_rto|number_format(1) ~ 'h', variant: 'success' }) }}
        </div>
        <div class="col-auto">
            {{ _fa_feature_card.render({ label: 'bcm.stats.avg_mtpd'|trans({}, 'bcm'), value: stats.avg_mtpd|number_format(1) ~ 'h', variant: 'info' }) }}
        </div>
    </div>

    {# Filters #}
    {% embed '_components/_search_filter_form.html.twig' with {
        action: path('app_bcm_index'),
        filter_keys: ['criticality'],
        show_search: false,
        form_id: 'bcm-filter-form'
    } %}
        {% block filters %}
            <div class="col-md-4">
                <label for="filter-criticality" class="form-label">{{ 'bcm.filter.all_criticality'|trans({}, 'bcm') }}</label>
                <select class="form-select" id="filter-criticality" name="criticality">
                    <option value="">{{ 'bcm.filter.all_criticality'|trans({}, 'bcm') }}</option>
                    <option value="critical" {{ current_criticality == 'critical' ? 'selected' : '' }}>{{ 'bcm.criticality.critical'|trans({}, 'bcm') }}</option>
                    <option value="high" {{ current_criticality == 'high' ? 'selected' : '' }}>{{ 'bcm.criticality.high'|trans({}, 'bcm') }}</option>
                    <option value="medium" {{ current_criticality == 'medium' ? 'selected' : '' }}>{{ 'bcm.criticality.medium'|trans({}, 'bcm') }}</option>
                    <option value="low" {{ current_criticality == 'low' ? 'selected' : '' }}>{{ 'bcm.criticality.low'|trans({}, 'bcm') }}</option>
                </select>
            </div>
        {% endblock %}
    {% endembed %}

    {# Business Processes Table #}
    {% embed '_components/_card.html.twig' %}
        {% block card_header %}
            <div class="card-header">
                <h2>{{ 'bcm.section.business_processes'|trans({}, 'bcm') }}</h2>
            </div>
        {% endblock %}
        {% block card_body %}
        {% embed '_components/_table.html.twig' with {
            'noMargin': true,
            'responsive': true
        } %}
            {% block table_head %}
                <tr>
                    <th scope="col">{{ 'bcm.table.process_name'|trans({}, 'bcm') }}</th>
                    <th scope="col">{{ 'bcm.table.owner'|trans({}, 'bcm') }}</th>
                    <th scope="col">{{ 'bcm.table.criticality'|trans({}, 'bcm') }}</th>
                    <th scope="col">{{ 'bcm.table.rto'|trans({}, 'bcm') }}</th>
                    <th scope="col">{{ 'bcm.table.rpo'|trans({}, 'bcm') }}</th>
                    <th scope="col">{{ 'bcm.table.mtpd'|trans({}, 'bcm') }}</th>
                    <th scope="col">{{ 'bcm.table.impact'|trans({}, 'bcm') }}</th>
                    <th scope="col">{{ 'bcm.table.assets'|trans({}, 'bcm') }}</th>
                    <th scope="col" class="actions-column">{{ 'common.actions'|trans({}, 'messages') }}</th>
                </tr>
            {% endblock %}
            {% block table_body %}
                {% for process in processes %}
                    <tr>
                        <td>
                            <strong>{{ process.name }}</strong>
                            {% if process.description %}
                                <br><small class="text-muted">{{ process.description|length > 60 ? process.description|slice(0, 60) ~ '...' : process.description }}</small>
                            {% endif %}
                        </td>
                        <td>{{ process.effectiveProcessOwner ?? '-' }}</td>
                        <td>
                            {% set criticality_colors = {
                                'critical': 'danger',
                                'high': 'warning',
                                'medium': 'info',
                                'low': 'success'
                            } %}
                            {% include '_components/_badge.html.twig' with { variant: criticality_colors[process.criticality] ?? 'secondary', content: ('bcm.criticality.' ~ process.criticality)|trans({}, 'bcm')|upper } %}
                        </td>
                        <td>
                            <span class="metric-value">{{ process.rto }}h</span>
                        </td>
                        <td>
                            <span class="metric-value">{{ process.rpo }}h</span>
                        </td>
                        <td>
                            <span class="metric-value">{{ process.mtpd }}h</span>
                        </td>
                        <td>
                            <div class="impact-scores">
                                <span class="tooltip-trigger" title="{{ 'bcm.field.reputational_impact'|trans({}, 'bcm') }}">{{ process.reputationalImpact|default(0) }}/5</span>
                                <span class="tooltip-trigger" title="{{ 'bcm.field.regulatory_impact'|trans({}, 'bcm') }}">{{ process.regulatoryImpact|default(0) }}/5</span>
                                <span class="tooltip-trigger" title="{{ 'bcm.field.operational_impact'|trans({}, 'bcm') }}">{{ process.operationalImpact|default(0) }}/5</span>
                            </div>
                        </td>
                        <td>
                            {% include '_components/_badge.html.twig' with { variant: 'info', content: process.supportingAssets|length ~ ' Assets' } %}
                        </td>
                        <td class="actions-column">
                            <a href="{{ path('app_business_process_show', {id: process.id}) }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost" title="{{ 'common.view'|trans({}, 'messages') }}">
                                <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
                            </a>
                            <a href="{{ path('app_business_process_edit', {id: process.id}) }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost" title="{{ 'common.edit'|trans({}, 'messages') }}">
                                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="9">
                            {% include '_components/_empty_state.html.twig' with {
                                icon: 'bi-diagram-3',
                                title: 'bcm.empty.title'|trans({}, 'bcm'),
                                description: 'bcm.empty.description'|trans({}, 'bcm'),
                                action: { label: 'bcm.action.add_process'|trans({}, 'bcm'), url: path('app_business_process_new'), icon: 'bi-plus-circle' }
                            } %}
                        </td>
                    </tr>
                {% endfor %}
            {% endblock %}
        {% endembed %}

        {% endblock %}
    {% endembed %}

    {# Help Section #}
    {% embed '_components/_card.html.twig' with {class: 'mt-lg'} %}
        {% block card_header %}
            <div class="card-header">
                <h2>{{ 'bcm.section.understanding'|trans({}, 'bcm') }}</h2>
            </div>
        {% endblock %}
        {% block card_body %}
            <div class="info-grid">
                <div class="info-item">
                    <strong>RTO (Recovery Time Objective)</strong>
                    <p>{{ 'bcm.message.rto_tooltip'|trans({}, 'bcm') }}</p>
                </div>
                <div class="info-item">
                    <strong>RPO (Recovery Point Objective)</strong>
                    <p>{{ 'bcm.message.rpo_tooltip'|trans({}, 'bcm') }}</p>
                </div>
                <div class="info-item">
                    <strong>MTPD (Maximum Tolerable Period of Disruption)</strong>
                    <p>{{ 'bcm.message.mtd_tooltip'|trans({}, 'bcm') }}</p>
                </div>
                <div class="info-item">
                    <strong>{{ 'common.data_reuse'|trans({}, 'messages') }}</strong>
                    <p>{{ 'bcm.message.bcm_influences_asset_ratings'|trans({}, 'bcm') }}</p>
                </div>
            </div>
        {% endblock %}
    {% endembed %}
    </main>
</div>

<style>
.impact-scores {
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 0.85rem;
}

.metric-value {
    font-weight: 600;
    color: var(--primary-strong);
}

.info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--spacing-md);
}

.info-item {
    padding: var(--spacing-md);
    background: var(--surface);
    border-radius: var(--r-md);
    border-left: 3px solid var(--primary-strong);
}

.info-item strong {
    display: block;
    margin-bottom: var(--spacing-xs);
    color: var(--primary-strong);
}

.info-item p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--fg-2);
}
</style>
{% endblock %}
