{% extends 'base.html.twig' %}
{% trans_default_domain 'bcm' %}

{% block title %}{{ 'bcm.page.title'|trans({}, 'bcm') }}{% endblock %}

{% block body %}
{% import '_macros/cards.html.twig' as cards %}

<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.bcm'|trans({}, 'nav') }
        ]
    } %}

    <div class="page-header">
        <div>
            <h1>{{ 'bcm.page.title'|trans({}, 'bcm') }}</h1>
            <p class="text-muted">{{ 'bcm.page.subtitle'|trans({}, 'bcm') }}</p>
        </div>
        <div class="button-group">
            <a href="{{ path('app_bcm_data_reuse') }}" class="btn btn-secondary">
                <i class="bi bi-link-45deg" aria-hidden="true"></i> {{ 'bcm.action.data_reuse'|trans({}, 'bcm') }}
            </a>
            <a href="{{ path('app_business_process_new') }}" class="btn btn-primary">
                <i class="bi bi-plus-lg" aria-hidden="true"></i> {{ 'bcm.action.add_process'|trans({}, 'bcm') }}
            </a>
        </div>
    </div>

    {# KPI Overview Cards #}
    <div class="kpi-grid">
        <div class="col-auto">
            {{ cards.kpi_card('bcm.stats.total_processes'|trans({}, 'bcm'), stats.total, null, null, 'primary', null) }}
        </div>
        <div class="col-auto">
            {{ cards.kpi_card('bcm.stats.critical_processes'|trans({}, 'bcm'), stats.critical, null, null, 'danger', null) }}
        </div>
        <div class="col-auto">
            {{ cards.kpi_card('bcm.stats.high_priority'|trans({}, 'bcm'), stats.high, null, null, 'warning', null) }}
        </div>
        <div class="col-auto">
            {{ cards.kpi_card('bcm.stats.avg_rto'|trans({}, 'bcm'), stats.avg_rto|number_format(1) ~ 'h', null, null, 'success', null) }}
        </div>
        <div class="col-auto">
            {{ cards.kpi_card('bcm.stats.avg_mtpd'|trans({}, 'bcm'), stats.avg_mtpd|number_format(1) ~ 'h', null, null, 'info', null) }}
        </div>
    </div>

    {# Business Processes Table #}
    {% embed '_components/_card.html.twig' %}
        {% block card_attrs %}data-controller="filter" data-filter-filterable-columns-value="{{ ['name', 'description', 'criticality']|json_encode }}"{% endblock %}
        {% block card_header %}
            <div class="card-header">
                <h2>{{ 'bcm.section.business_processes'|trans({}, 'bcm') }}</h2>
                <div class="filter-panel">
                    <input type="text"
                           class="search-input"
                           placeholder="{{ 'common.search_processes'|trans({}, 'messages') }}"
                           data-filter-target="searchInput"
                           data-action="input->filter#filterRows">

                    <select class="filter-select" data-action="change->filter#filterByCategory">
                        <option value="">{{ 'bcm.filter.all_criticality'|trans({}, 'bcm') }}</option>
                        <option value="critical">{{ 'bcm.criticality.critical'|trans({}, 'bcm') }}</option>
                        <option value="high">{{ 'bcm.criticality.high'|trans({}, 'bcm') }}</option>
                        <option value="medium">{{ 'bcm.criticality.medium'|trans({}, 'bcm') }}</option>
                        <option value="low">{{ 'bcm.criticality.low'|trans({}, 'bcm') }}</option>
                    </select>
                </div>
            </div>
        {% endblock %}
        {% block card_body %}
        {% embed '_components/_table.html.twig' with {
            'noMargin': true,
            'responsive': true
        } %}
            {% block table_head %}
                <tr>
                    <th scope="col">{{ 'bcm.table.process_name'|trans({}, 'bcm') }}</th>
                    <th scope="col">{{ 'bcm.table.owner'|trans({}, 'bcm') }}</th>
                    <th scope="col">{{ 'bcm.table.criticality'|trans({}, 'bcm') }}</th>
                    <th scope="col">{{ 'bcm.table.rto'|trans({}, 'bcm') }}</th>
                    <th scope="col">{{ 'bcm.table.rpo'|trans({}, 'bcm') }}</th>
                    <th scope="col">{{ 'bcm.table.mtpd'|trans({}, 'bcm') }}</th>
                    <th scope="col">{{ 'bcm.table.impact'|trans({}, 'bcm') }}</th>
                    <th scope="col">{{ 'bcm.table.assets'|trans({}, 'bcm') }}</th>
                    <th scope="col" class="actions-column">{{ 'common.actions'|trans({}, 'messages') }}</th>
                </tr>
            {% endblock %}
            {% block table_body %}
                {% for process in processes %}
                    <tr data-filter-target="filterableRow"
                        data-category="{{ process.criticality }}">
                        <td>
                            <strong>{{ process.name }}</strong>
                            {% if process.description %}
                                <br><small class="text-muted">{{ process.description|length > 60 ? process.description|slice(0, 60) ~ '...' : process.description }}</small>
                            {% endif %}
                        </td>
                        <td>{{ process.effectiveProcessOwner ?? '-' }}</td>
                        <td>
                            {% set criticality_colors = {
                                'critical': 'danger',
                                'high': 'warning',
                                'medium': 'info',
                                'low': 'success'
                            } %}
                            {% include '_components/_badge.html.twig' with { variant: criticality_colors[process.criticality] ?? 'secondary', content: ('bcm.criticality.' ~ process.criticality)|trans({}, 'bcm')|upper } %}
                        </td>
                        <td>
                            <span class="metric-value">{{ process.rto }}h</span>
                        </td>
                        <td>
                            <span class="metric-value">{{ process.rpo }}h</span>
                        </td>
                        <td>
                            <span class="metric-value">{{ process.mtpd }}h</span>
                        </td>
                        <td>
                            <div class="impact-scores">
                                <span class="tooltip-trigger" title="{{ 'bcm.field.reputational_impact'|trans({}, 'bcm') }}">{{ process.reputationalImpact|default(0) }}/5</span>
                                <span class="tooltip-trigger" title="{{ 'bcm.field.regulatory_impact'|trans({}, 'bcm') }}">{{ process.regulatoryImpact|default(0) }}/5</span>
                                <span class="tooltip-trigger" title="{{ 'bcm.field.operational_impact'|trans({}, 'bcm') }}">{{ process.operationalImpact|default(0) }}/5</span>
                            </div>
                        </td>
                        <td>
                            {% include '_components/_badge.html.twig' with { variant: 'info', content: process.supportingAssets|length ~ ' Assets' } %}
                        </td>
                        <td class="actions-column">
                            <a href="{{ path('app_business_process_show', {id: process.id}) }}" class="btn btn-sm btn-outline-primary" title="{{ 'common.view'|trans({}, 'messages') }}">
                                <i class="bi bi-eye" aria-hidden="true"></i>
                            </a>
                            <a href="{{ path('app_business_process_edit', {id: process.id}) }}" class="btn btn-sm btn-outline-secondary" title="{{ 'common.edit'|trans({}, 'messages') }}">
                                <i class="bi bi-pencil" aria-hidden="true"></i>
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="9">
                            {% include '_components/_empty_state.html.twig' with {
                                icon: 'bi-diagram-3',
                                title: 'bcm.empty.title'|trans({}, 'bcm'),
                                description: 'bcm.empty.description'|trans({}, 'bcm'),
                                action: { label: 'bcm.action.add_process'|trans({}, 'bcm'), url: path('app_business_process_new'), icon: 'bi-plus-circle' }
                            } %}
                        </td>
                    </tr>
                {% endfor %}
            {% endblock %}
        {% endembed %}

        <div data-filter-target="noResults" class="no-results d-none">
            <p>{{ 'bcm.message.no_matching_processes'|trans({}, 'bcm') }}</p>
        </div>
        {% endblock %}
    {% endembed %}

    {# Help Section #}
    {% embed '_components/_card.html.twig' with {class: 'mt-lg'} %}
        {% block card_header %}
            <div class="card-header">
                <h2>{{ 'bcm.section.understanding'|trans({}, 'bcm') }}</h2>
            </div>
        {% endblock %}
        {% block card_body %}
            <div class="info-grid">
                <div class="info-item">
                    <strong>RTO (Recovery Time Objective)</strong>
                    <p>{{ 'bcm.message.rto_tooltip'|trans({}, 'bcm') }}</p>
                </div>
                <div class="info-item">
                    <strong>RPO (Recovery Point Objective)</strong>
                    <p>{{ 'bcm.message.rpo_tooltip'|trans({}, 'bcm') }}</p>
                </div>
                <div class="info-item">
                    <strong>MTPD (Maximum Tolerable Period of Disruption)</strong>
                    <p>{{ 'bcm.message.mtd_tooltip'|trans({}, 'bcm') }}</p>
                </div>
                <div class="info-item">
                    <strong>{{ 'common.data_reuse'|trans({}, 'messages') }}</strong>
                    <p>{{ 'bcm.message.bcm_influences_asset_ratings'|trans({}, 'bcm') }}</p>
                </div>
            </div>
        {% endblock %}
    {% endembed %}
</div>

<style>
.impact-scores {
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 0.85rem;
}

.metric-value {
    font-weight: 600;
    color: var(--primary-strong);
}

.info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--spacing-md);
}

.info-item {
    padding: var(--spacing-md);
    background: var(--surface);
    border-radius: var(--r-md);
    border-left: 3px solid var(--primary-strong);
}

.info-item strong {
    display: block;
    margin-bottom: var(--spacing-xs);
    color: var(--primary-strong);
}

.info-item p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--fg-2);
}
</style>
{% endblock %}
