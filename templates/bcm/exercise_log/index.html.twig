{% extends 'base.html.twig' %}
{% trans_default_domain 'bsi_200_4_exercise' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
{% import '_components/_fa_alva_hint.html.twig' as _fa_alva_hint %}
{% import '_components/_fa_table.html.twig' as _fa_table %}

{% block title %}{{ 'page.index_title'|trans({}, 'bsi_200_4_exercise') }}{% endblock %}

{% block body %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.bcm'|trans({}, 'nav'), url: path('app_bcm_index') },
            { label: 'nav.bc_exercises'|trans({}, 'nav'), url: path('app_bc_exercise_index') },
            { label: 'nav.exercise_log'|trans({}, 'bsi_200_4_exercise') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'nav-clipboard-check', label: 'BSI 200-4' },
        title: 'page.index_title'|trans({}, 'bsi_200_4_exercise'),
        subtitle: 'page.index_subtitle'|trans({}, 'bsi_200_4_exercise'),
        actions: [
            { label: 'nav.exercise_log_calendar'|trans({}, 'bsi_200_4_exercise'), href: path('bcm_exercise_log_calendar'), variant: 'secondary', icon: 'ui-calendar' }
        ]
    }) }}

    {# Alva hints #}
    {% set _hints = alva_hints('bcm_exercise_log_index') %}
    {% for _h in _hints %}
        {{ _fa_alva_hint.render(_h) }}
    {% endfor %}

    {# Overdue warning #}
    {% if overdueCount > 0 %}
    <div class="alert alert-warning d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i>
        <span>{{ 'alva.improvement_action_overdue.body'|trans({'%count%': overdueCount, '%log_count%': logs|length}, 'bsi_200_4_exercise') }}</span>
    </div>
    {% endif %}

    {% if logs|length == 0 %}
        {{ _fa_empty_state.render({
            icon: 'nav-clipboard-check',
            title: 'empty_state.title'|trans({}, 'bsi_200_4_exercise'),
            body: 'empty_state.body'|trans({}, 'bsi_200_4_exercise'),
            action: {
                label: 'empty_state.action'|trans({}, 'bsi_200_4_exercise'),
                href: path('app_bc_exercise_index')
            }
        }) }}
    {% else %}
        <div class="card">
            <div class="card-body p-0">
                {% embed '_components/_fa_table.html.twig' with {
                    id: 'exercise-log-list-table',
                    class: 'mb-0'
                } %}
                    {% block table_head %}
                        <tr>
                            <th scope="col" class="fa-table__th">{{ 'table.header_exercise'|trans({}, 'bsi_200_4_exercise') }}</th>
                            <th scope="col" class="fa-table__th">{{ 'table.header_type'|trans({}, 'bsi_200_4_exercise') }}</th>
                            <th scope="col" class="fa-table__th">{{ 'table.header_template'|trans({}, 'bsi_200_4_exercise') }}</th>
                            <th scope="col" class="fa-table__th">{{ 'table.header_status'|trans({}, 'bsi_200_4_exercise') }}</th>
                            <th scope="col" class="fa-table__th">{{ 'table.header_rating'|trans({}, 'bsi_200_4_exercise') }}</th>
                            <th scope="col" class="fa-table__th">{{ 'table.header_submitted'|trans({}, 'bsi_200_4_exercise') }}</th>
                            <th scope="col" class="fa-table__th fa-table__th--actions">{{ 'table.header_actions'|trans({}, 'bsi_200_4_exercise') }}</th>
                        </tr>
                    {% endblock %}
                    {% block table_body %}
                        {% for log in logs %}
                        <tr class="fa-table__row">
                            <td class="fa-table__cell">
                                <a href="{{ path('bcm_exercise_log_show', {id: log.id}) }}" class="fw-semibold text-decoration-none">
                                    {{ log.bcExercise.name ?? '—' }}
                                </a>
                                {% if log.hasOverdueImprovementActions %}
                                    <span class="fa-status-pill fa-status-pill--warning ms-1" title="{{ 'alva.improvement_action_overdue.title'|trans({}, 'bsi_200_4_exercise') }}">
                                        <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i>
                                    </span>
                                {% endif %}
                            </td>
                            <td class="fa-table__cell">
                                <span class="badge bg-secondary">{{ ('exercise_type.' ~ log.exerciseType)|trans({}, 'bsi_200_4_exercise') }}</span>
                            </td>
                            <td class="fa-table__cell">{{ ('template.' ~ log.bsi2004Template)|trans({}, 'bsi_200_4_exercise') }}</td>
                            <td class="fa-table__cell">
                                {% if log.isConfirmed %}
                                    <span class="fa-status-pill fa-status-pill--success">{{ 'status.confirmed'|trans({}, 'bsi_200_4_exercise') }}</span>
                                {% elseif log.isSubmitted %}
                                    <span class="fa-status-pill fa-status-pill--info">{{ 'status.submitted'|trans({}, 'bsi_200_4_exercise') }}</span>
                                {% else %}
                                    <span class="badge bg-light text-muted border">{{ 'status.draft'|trans({}, 'bsi_200_4_exercise') }}</span>
                                {% endif %}
                            </td>
                            <td class="fa-table__cell">
                                {% if log.overallRating %}
                                    {{ ('rating.' ~ log.overallRating)|trans({}, 'bsi_200_4_exercise') }}
                                {% else %}—{% endif %}
                            </td>
                            <td class="fa-table__cell">{{ log.submittedAt ? log.submittedAt|date('d.m.Y') : '—' }}</td>
                            <td class="fa-table__cell fa-table__cell--actions">
                                <a href="{{ path('bcm_exercise_log_show', {id: log.id}) }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost">
                                    <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
                                </a>
                                {% if not log.isSubmitted %}
                                <a href="{{ path('bcm_exercise_log_edit', {id: log.id}) }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost">
                                    <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                                </a>
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
