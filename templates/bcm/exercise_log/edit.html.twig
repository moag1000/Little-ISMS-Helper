{% extends 'base.html.twig' %}
{% trans_default_domain 'bsi_200_4_exercise' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'page.edit_title'|trans({}, 'bsi_200_4_exercise') }}{% endblock %}

{% block body %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.bcm'|trans({}, 'nav'), url: path('app_bcm_index') },
            { label: 'nav.bc_exercises'|trans({}, 'nav'), url: path('app_bc_exercise_index') },
            { label: 'nav.exercise_log'|trans({}, 'bsi_200_4_exercise'), url: path('bcm_exercise_log_index') },
            { label: log.bcExercise.name ?? '', url: path('bcm_exercise_log_show', {id: log.id}) },
            { label: 'page.edit_title'|trans({}, 'bsi_200_4_exercise') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'ui-edit', label: 'BSI 200-4' },
        title: 'page.edit_title'|trans({}, 'bsi_200_4_exercise'),
        subtitle: log.bcExercise.name ?? ''
    }) }}

    {{ form_start(form, {attr: {class: 'card p-4'}}) }}
        {{ form_errors(form) }}

        <div class="row g-3 mb-4">
            <div class="col-md-6">{{ form_row(form.exerciseType) }}</div>
            <div class="col-md-6">{{ form_row(form.bsi2004Template) }}</div>
        </div>

        <div class="mb-4">{{ form_row(form.scenarioSummary) }}</div>

        <div class="row g-3 mb-4">
            <div class="col-md-6">{{ form_row(form.objectivesText) }}</div>
            <div class="col-md-6">{{ form_row(form.participantsText) }}</div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-4">{{ form_row(form.actionsBefore) }}</div>
            <div class="col-md-4">{{ form_row(form.actionsDuring) }}</div>
            <div class="col-md-4">{{ form_row(form.actionsAfter) }}</div>
        </div>

        <div class="mb-4">{{ form_row(form.lessonsLearned) }}</div>

        <h5 class="mb-3">{{ 'section.improvement_actions'|trans({}, 'bsi_200_4_exercise') }}</h5>
        <div class="mb-4" data-prototype="{{ form_widget(form.improvementActionsCollection.vars.prototype)|e('html_attr') }}">
            {{ form_widget(form.improvementActionsCollection) }}
            <button type="button" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost mt-2" data-add-improvement-action>
                <i class="fa-icon fa-icon--plus" aria-hidden="true"></i>
                {{ 'section.improvement_actions'|trans({}, 'bsi_200_4_exercise') }}
            </button>
        </div>

        <div class="col-md-4 mb-4">{{ form_row(form.overallRating) }}</div>

        <div class="d-flex gap-2">
            <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                <i class="fa-icon fa-icon--save" aria-hidden="true"></i>
                {{ 'action.saved'|trans({}, 'bsi_200_4_exercise') }}
            </button>
            <a href="{{ path('bcm_exercise_log_show', {id: log.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                {{ 'common.cancel'|trans({}, 'messages') }}
            </a>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
