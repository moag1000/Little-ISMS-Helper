{% extends 'base.html.twig' %}
{% trans_default_domain 'messages' %}

{% block title %}Activity-Feed - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block body %}
<main class="fa-aurora-surface">
    {{ _fa_page_header.render({
        badge:    { icon: 'activity', label: 'Feed' },
        title:    'Activity-Feed',
        subtitle: 'Letzte Aktivitäten aus Audit-Log, Workflows, Dokumenten und Risiken',
        actions: [
            { label: 'Standard-Dashboard', variant: 'ghost', icon: 'house', href: path('app_dashboard') }
        ]
    }) }}

    {% include '_components/_activity_feed_widget.html.twig' with { items: items, max: 50 } %}
</main>
{% endblock %}
