{% use "bootstrap_5_layout.html.twig" %}

{#
    Aurora v4 Cyber-Input Form Theme for Symfony

    Renders every form row using the .fa-cyber-input visual pattern:
    - Monospace uppercase label OUTSIDE the frame
    - Bordered frame with 4-corner tick-marks
    - Focus-within glow via CSS

    CSS lives in assets/styles/fairy-aurora-components.css (lines ~347-460 + appended rules).

    Blocks overridden here:
      - form_row          Main wrapper + header + frame + tick marks + hint + errors
      - form_label        Adds .fa-cyber-input__label class
      - form_label_required  Renders the red asterisk as .fa-cyber-input__req
      - form_widget_simple   Adds .fa-cyber-input__field (strips Bootstrap border)
      - textarea_widget      Same as above for <textarea>
      - choice_widget        Routes expanded (radio/checkbox) through Bootstrap, collapsed gets .fa-cyber-input__field
      - form_errors          Renders errors as .fa-cyber-input__errors list below the frame
      - button_row           Buttons rendered plain (not wrapped in cyber-input frame)

    Blocks inherited unchanged from bootstrap_5_layout.html.twig:
      - form_widget (dispatches to type-specific blocks)
      - choice_widget_expanded (radio/checkbox groups — Bootstrap look)
      - choice_widget_collapsed (select — receives .fa-cyber-input__field via choice_widget)
      - money_widget, percent_widget
      - hidden_widget (no visible output)
      - form_start, form_end
      - form_rest

    Aurora v4 Coverage (post form-audit Sprint):
    ───────────────────────────────────────────────
    COVERED (via form_widget_simple → .fa-cyber-input__field):
      text, email, password, number, tel, url, search, hidden → OK
      textarea → OK (explicit textarea_widget block)
      select (collapsed) → OK (choice_widget routes to __field)
      radio/checkbox (expanded) → OK (choice_widget → Bootstrap look, frame border stripped via :has())

    COVERED (added in form-audit Sprint — explicit blocks below):
      file_widget     → fa-cyber-input__field--file (Aurora-tinted ::file-selector-button)
      range_widget    → fa-cyber-input__field--range (cyan track + glow thumb)
      date_widget     → single_text → __field--date; 3-select group → .fa-cyber-input__date-group flex
      time_widget     → single_text → __field--time; group → .fa-cyber-input__time-group flex
      datetime_widget → single_text → __field--datetime; group → .fa-cyber-input__datetime-group flex

      color_widget    → not a standard field in this app; no coverage needed currently.

    ATTR.CLASS FORWARDING: All blocks that override widget rendering use
      attr|merge({class: (attr.class|default('') ~ ' fa-cyber-input__field')|trim})
    which correctly appends without dropping any caller-supplied classes. ✓

    HAND-ROLLED FILTER INPUTS: Filter-Bars (GET-method) outside the Symfony form
    system carry .fa-cyber-input__field alongside .form-control/.form-select
    explicitly (T21 — 232 substitutions across 98 templates). Bridge CSS in
    fairy-aurora-components.css (~:3751) still handles bare .form-control as
    fallback for any new inline use, but new code MUST add .fa-cyber-input__field.
#}

{# ─── Main row wrapper ───────────────────────────────────────────────────── #}
{% block form_row %}
    {%- set widget_attr = {} -%}
    {%- if help is not empty -%}
        {%- set widget_attr = {attr: {'aria-describedby': id ~ '_help'}} -%}
    {%- endif -%}

    {%- set row_classes = ['fa-cyber-input'] -%}
    {%- if errors|length > 0 -%}
        {%- set row_classes = row_classes|merge(['has-error']) -%}
    {%- endif -%}
    {%- if disabled -%}
        {%- set row_classes = row_classes|merge(['is-disabled']) -%}
    {%- endif -%}

    <div class="{{ row_classes|join(' ') }}">
        {%- if label is not same as false -%}
        <div class="fa-cyber-input__header">
            {{- form_label(form) -}}
        </div>
        {%- endif -%}
        <div class="fa-cyber-input__frame">
            <span class="fa-cyber-input__tick fa-cyber-input__tick--tl" aria-hidden="true"></span>
            <span class="fa-cyber-input__tick fa-cyber-input__tick--tr" aria-hidden="true"></span>
            <span class="fa-cyber-input__tick fa-cyber-input__tick--bl" aria-hidden="true"></span>
            <span class="fa-cyber-input__tick fa-cyber-input__tick--br" aria-hidden="true"></span>
            {{- form_widget(form, widget_attr) -}}
        </div>
        {%- if help is not empty -%}
            <small id="{{ id }}_help" class="fa-cyber-input__hint">
                {{- help|trans(help_translation_parameters, translation_domain) -}}
            </small>
        {%- endif -%}
        {{- form_errors(form) -}}
    </div>
{% endblock %}

{# ─── Label ──────────────────────────────────────────────────────────────── #}
{% block form_label %}
    {%- if label is not same as false -%}
        {%- set label_attr = label_attr|merge({class: (label_attr.class|default('') ~ ' fa-cyber-input__label')|trim}) -%}
        {{- parent() -}}
    {%- endif -%}
{% endblock %}

{# ─── Required asterisk ──────────────────────────────────────────────────── #}
{% block form_label_required %}
    <span class="fa-cyber-input__req" aria-label="{{ 'form.required'|trans({}, 'messages') }}">*</span>
{% endblock %}

{# ─── Simple inputs (text, email, password, number, tel, url, …) ─────────── #}
{% block form_widget_simple %}
    {%- set type = type|default('text') -%}
    {%- set attr = attr|merge({class: (attr.class|default('') ~ ' fa-cyber-input__field')|trim}) -%}
    {{- parent() -}}
{% endblock %}

{# ─── Textarea ───────────────────────────────────────────────────────────── #}
{% block textarea_widget %}
    {%- set attr = attr|merge({class: (attr.class|default('') ~ ' fa-cyber-input__field')|trim}) -%}
    {{- parent() -}}
{% endblock %}

{# ─── Choice (select / radio / checkbox groups) ──────────────────────────── #}
{% block choice_widget %}
    {%- if expanded -%}
        {{- block('choice_widget_expanded') -}}
    {%- else -%}
        {%- set attr = attr|merge({class: (attr.class|default('') ~ ' fa-cyber-input__field')|trim}) -%}
        {{- block('choice_widget_collapsed') -}}
    {%- endif -%}
{% endblock %}

{# ─── Error list ─────────────────────────────────────────────────────────── #}
{% block form_errors %}
    {%- if errors|length > 0 -%}
        <ul class="fa-cyber-input__errors" role="alert">
            {%- for error in errors -%}
                <li>{{ error.message }}</li>
            {%- endfor -%}
        </ul>
    {%- endif -%}
{% endblock %}

{# ─── File-Upload (Aurora frame) ──────────────────────────────────────────── #}
{# NB: Twig 'use' (horizontal reuse) does NOT support parent() — use form_widget_simple
   block which routes through the standard simple-input renderer. #}
{% block file_widget %}
    {%- set type = type|default('file') -%}
    {%- set attr = attr|merge({class: (attr.class|default('') ~ ' fa-cyber-input__field fa-cyber-input__field--file')|trim}) -%}
    {{- block('form_widget_simple') -}}
{% endblock %}

{# ─── Range-Slider (Aurora track) ─────────────────────────────────────────── #}
{% block range_widget %}
    {%- set attr = attr|merge({class: (attr.class|default('') ~ ' fa-cyber-input__field fa-cyber-input__field--range')|trim}) -%}
    {{- block('form_widget_simple') -}}
{% endblock %}

{# ─── Date-Widget (single-input default; Aurora-class on each select if 3-select) ─── #}
{% block date_widget %}
    {%- if widget == 'single_text' -%}
        {%- set attr = attr|merge({class: (attr.class|default('') ~ ' fa-cyber-input__field fa-cyber-input__field--date')|trim}) -%}
        {{- block('form_widget_simple') -}}
    {%- else -%}
        {# Symfony's default 3-select date widget (day/month/year) — propagate cyber-class via choice_widget #}
        <div class="fa-cyber-input__date-group" role="group">
            {{- date_pattern|replace({
                '{{ year }}':  form_widget(form.year),
                '{{ month }}': form_widget(form.month),
                '{{ day }}':   form_widget(form.day)
            })|raw -}}
        </div>
    {%- endif -%}
{% endblock %}

{# ─── Time-Widget (Aurora frame) ──────────────────────────────────────────── #}
{% block time_widget %}
    {%- if widget == 'single_text' -%}
        {%- set attr = attr|merge({class: (attr.class|default('') ~ ' fa-cyber-input__field fa-cyber-input__field--time')|trim}) -%}
        {{- block('form_widget_simple') -}}
    {%- else -%}
        <div class="fa-cyber-input__time-group" role="group">
            {{- form_widget(form.hour) -}}{% if with_minutes %}:{{ form_widget(form.minute) }}{% endif %}
            {%- if with_seconds %}:{{ form_widget(form.second) }}{% endif -%}
        </div>
    {%- endif -%}
{% endblock %}

{# ─── DateTime-Widget (combine date + time blocks) ────────────────────────── #}
{% block datetime_widget %}
    {%- if widget == 'single_text' -%}
        {%- set attr = attr|merge({class: (attr.class|default('') ~ ' fa-cyber-input__field fa-cyber-input__field--datetime')|trim}) -%}
        {{- block('form_widget_simple') -}}
    {%- else -%}
        <div class="fa-cyber-input__datetime-group" role="group">
            {{- form_widget(form.date) -}} {{- form_widget(form.time) -}}
        </div>
    {%- endif -%}
{% endblock %}

{# ─── Buttons: skip cyber-input frame, render plain ──────────────────────── #}
{% block button_row %}
    <div class="mb-3">
        {{- form_widget(form) -}}
    </div>
{% endblock %}
