{% extends 'base.html.twig' %}
{% trans_default_domain 'suppliers' %}

{% block title %}{{ 'supplier.ict_library.title'|trans({}, 'suppliers') }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [{ label: 'supplier.ict_library.title'|trans({}, 'suppliers') }]
    } %}

    <h1 class="h3 mb-1">{{ 'supplier.ict_library.title'|trans({}, 'suppliers') }}</h1>
    <p class="text-body-secondary mb-4">{{ 'supplier.ict_library.intro'|trans({}, 'suppliers') }}</p>

    {% if entries|length == 0 %}
        <div class="alert alert-info">{{ 'supplier.ict_library.empty'|trans({}, 'suppliers') }}</div>
    {% else %}
    <table class="table">
        <thead>
            <tr>
                <th scope="col">{{ 'supplier.ict_library.field.name'|trans({}, 'suppliers') }}</th>
                <th scope="col">{{ 'supplier.ict_library.field.category'|trans({}, 'suppliers') }}</th>
                <th scope="col">{{ 'supplier.ict_library.field.country'|trans({}, 'suppliers') }}</th>
                <th scope="col" class="text-end">{{ 'common.actions'|trans({}, 'messages') }}</th>
            </tr>
        </thead>
        <tbody>
            {% for entry in entries %}
                <tr>
                    <td>
                        <strong>{{ entry.name }}</strong>
                        {% if entry.eeaHosted %}<span class="badge bg-success">EEA</span>{% endif %}
                        <div class="text-body-secondary small">{{ entry.serviceType }}</div>
                    </td>
                    <td>{{ ('supplier.ict_library.category.' ~ entry.category)|trans({}, 'suppliers') }}</td>
                    <td>{{ entry.headquartersCountry ?? '—' }}</td>
                    <td class="text-end">
                        <form method="post" action="{{ path('ict_provider_library_apply', {id: entry.id}) }}" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('ict_provider_library_apply') }}">
                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--sm">
                                {{ 'supplier.ict_library.action.apply'|trans({}, 'suppliers') }}
                            </button>
                        </form>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}
</div>
{% endblock %}
