{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}
{% trans_default_domain 'certification_bundle' %}

{% block title %}{{ 'certification_bundle.title'|trans({}, 'certification_bundle') }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% block body %}

<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.compliance'|trans({}, 'nav'), path: 'app_management_reports' },
            { label: 'certification_bundle.title'|trans({}, 'certification_bundle') }
        ]
    } only %}

    {# V3 W2-H1: migrate hand-rolled <h1 class="h2"> to fa-page-header. #}
    {{ _fa_page_header.render({
        badge: { icon: 'download', label: 'ISO 27001' },
        title: 'certification_bundle.title'|trans({}, 'certification_bundle'),
        subtitle: 'certification_bundle.subtitle'|trans({}, 'certification_bundle')
    }) }}

    {# Tenant & Framework Info — Audit-V3 EF-3 + task #122: multi-framework
       bundle. Single-framework dropdown stays for back-compat (default
       ISO27001) AND a checkbox-list lets compliance-managers compose a
       composite bundle (e.g. ISO27001 + DORA + NIS2) so subsequent audits
       across frameworks share the same evidence chain. #}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
        {% block card_body %}
            <div class="row align-items-start">
                <div class="col-md-6 mb-3 mb-md-0">
                    <strong>{{ 'certification_bundle.preview.organization'|trans({}, 'certification_bundle') }}:</strong>
                    {{ tenant.name }}
                </div>
                <div class="col-md-6">
                    <label for="cert-bundle-framework-select" class="form-label fw-semibold mb-1">
                        {{ 'certification_bundle.preview.framework'|trans({}, 'certification_bundle') }}
                    </label>
                    {% if frameworks is defined and frameworks|length > 0 %}
                        <select id="cert-bundle-framework-select"
                                class="form-select form-select-sm"
                                aria-describedby="cert-bundle-framework-help"
                                onchange="document.getElementById('cert-bundle-framework-input').value = this.value;">
                            {# Always offer ISO27001 even if not loaded as ComplianceFramework. #}
                            {% set has_iso = false %}
                            {% for fw in frameworks %}
                                {% if fw.code == 'ISO27001' %}{% set has_iso = true %}{% endif %}
                            {% endfor %}
                            {% if not has_iso %}
                                <option value="ISO27001" {% if (selected_framework_code|default('ISO27001')) == 'ISO27001' %}selected{% endif %}>ISO/IEC 27001:2022</option>
                            {% endif %}
                            {% for fw in frameworks %}
                                <option value="{{ fw.code }}" {% if (selected_framework_code|default('ISO27001')) == fw.code %}selected{% endif %}>{{ fw.name }}</option>
                            {% endfor %}
                        </select>
                        <small id="cert-bundle-framework-help" class="form-text text-muted">
                            {{ 'certification_bundle.preview.framework_help'|trans({}, 'certification_bundle') }}
                        </small>
                    {% else %}
                        <div>ISO/IEC 27001:2022</div>
                    {% endif %}

                    {# V3 W2-H1: Multi-framework composite bundle (task #122).
                       Checked codes are POST'd as `frameworks[]` and each
                       contributes a 02_FRAMEWORK_MAPPING/<code>_coverage.csv.
                       Dropdown always-visible (was hidden in <details>). #}
                    {% if frameworks is defined and frameworks|length > 1 %}
                        <div class="mt-3">
                            <label class="form-label fw-semibold small mb-1">
                                <i class="fa-icon fa-icon--nav-collection" aria-hidden="true"></i>
                                {{ 'certification_bundle.preview.multi_framework_toggle'|trans({}, 'certification_bundle') }}
                            </label>
                            <div class="ps-2 border-start" id="cert-bundle-multi-framework">
                                {% for fw in frameworks %}
                                    <div class="form-check">
                                        <input class="form-check-input cert-bundle-fw-checkbox"
                                               type="checkbox"
                                               name="frameworks[]"
                                               value="{{ fw.code }}"
                                               id="cert-bundle-fw-{{ fw.code|lower|replace({'_':'-'}) }}"
                                               form="cert-bundle-export-form">
                                        <label class="form-check-label small" for="cert-bundle-fw-{{ fw.code|lower|replace({'_':'-'}) }}">
                                            {{ fw.name }} <span class="text-muted">({{ fw.code }})</span>
                                        </label>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        {% endblock %}
    {% endembed %}

    {# Gap Warning #}
    {% if counts.gaps > 0 %}
        {{ _fa_alert.render({
            variant: 'warning',
            class: 'mb-4',
            body: 'certification_bundle.warning_gaps'|trans({'%count%': counts.gaps}, 'certification_bundle')
        }) }}
    {% endif %}

    {# V3 W2-H1: 6× legacy variant:'kpi' replaced by Aurora fa-feature-card. #}
    <div class="row mb-4">
        <div class="col-md-4 col-lg-2 mb-3">
            {{ _fa_feature_card.render({
                label: 'certification_bundle.preview.assets'|trans({}, 'certification_bundle'),
                value: counts.assets,
                variant: 'primary',
                icon: 'nav-boxes',
                class: 'h-100'
            }) }}
        </div>
        <div class="col-md-4 col-lg-2 mb-3">
            {{ _fa_feature_card.render({
                label: 'certification_bundle.preview.risks'|trans({}, 'certification_bundle'),
                value: counts.risks,
                variant: 'warning',
                icon: 'status-warning',
                class: 'h-100'
            }) }}
        </div>
        <div class="col-md-4 col-lg-2 mb-3">
            {{ _fa_feature_card.render({
                label: 'certification_bundle.preview.controls_applicable'|trans({}, 'certification_bundle'),
                value: counts.controls_applicable,
                variant: 'success',
                icon: 'shield-check',
                class: 'h-100'
            }) }}
        </div>
        <div class="col-md-4 col-lg-2 mb-3">
            {{ _fa_feature_card.render({
                label: 'certification_bundle.preview.controls_implemented'|trans({}, 'certification_bundle'),
                value: counts.controls_implemented,
                variant: 'success',
                icon: 'status-ok',
                class: 'h-100'
            }) }}
        </div>
        <div class="col-md-4 col-lg-2 mb-3">
            {{ _fa_feature_card.render({
                label: 'certification_bundle.preview.evidence_documents'|trans({}, 'certification_bundle'),
                value: counts.evidence_documents,
                variant: 'primary',
                icon: 'nav-file-earmark-text',
                class: 'h-100'
            }) }}
        </div>
        <div class="col-md-4 col-lg-2 mb-3">
            {{ _fa_feature_card.render({
                label: 'certification_bundle.preview.gaps'|trans({}, 'certification_bundle'),
                value: counts.gaps,
                variant: counts.gaps > 0 ? 'danger' : 'success',
                icon: counts.gaps > 0 ? 'exclamation-octagon' : 'check2-circle',
                class: 'h-100'
            }) }}
        </div>
    </div>

    {# Bundle Contents Preview #}
    {% embed '_components/_card.html.twig' with { 'header': 'certification_bundle.preview.bundle_contents'|trans({}, 'certification_bundle'), 'class': 'mb-4' } %}
        {% block card_body %}
            {% embed '_components/_fa_table.html.twig' with { compact: true } %}
                {% block table_head %}
                    <tr>
                        <th scope="col" class="fa-table__th">{{ 'certification_bundle.preview.file'|trans({}, 'certification_bundle') }}</th>
                        <th scope="col" class="fa-table__th">{{ 'certification_bundle.preview.description'|trans({}, 'certification_bundle') }}</th>
                    </tr>
                {% endblock %}
                {% block table_body %}
                    <tr class="fa-table__row">
                        <td class="fa-table__cell"><i class="fa-icon text-danger fa-icon--nav-file-pdf" aria-hidden="true"></i> 00_ISMS_OVERVIEW.pdf</td>
                        <td class="fa-table__cell">{{ 'certification_bundle.preview.desc_overview'|trans({}, 'certification_bundle') }}</td>
                    </tr>
                    <tr class="fa-table__row">
                        <td class="fa-table__cell"><i class="fa-icon text-danger fa-icon--nav-file-pdf" aria-hidden="true"></i> 01_STATEMENT_OF_APPLICABILITY.pdf</td>
                        <td class="fa-table__cell">{{ 'certification_bundle.preview.desc_soa'|trans({}, 'certification_bundle') }}</td>
                    </tr>
                    <tr class="fa-table__row">
                        <td class="fa-table__cell"><i class="fa-icon text-danger fa-icon--nav-file-pdf" aria-hidden="true"></i> 02_RISK_TREATMENT_PLAN.pdf</td>
                        <td class="fa-table__cell">{{ 'certification_bundle.preview.desc_rtp'|trans({}, 'certification_bundle') }}</td>
                    </tr>
                    <tr class="fa-table__row">
                        <td class="fa-table__cell"><i class="fa-icon text-danger fa-icon--nav-file-pdf" aria-hidden="true"></i> 03_ASSET_REGISTER.pdf</td>
                        <td class="fa-table__cell">{{ 'certification_bundle.preview.desc_assets'|trans({}, 'certification_bundle') }}</td>
                    </tr>
                    <tr class="fa-table__row">
                        <td class="fa-table__cell"><i class="fa-icon text-warning fa-icon--nav-collection" aria-hidden="true"></i> 04_EVIDENCE/</td>
                        <td class="fa-table__cell">{{ 'certification_bundle.preview.desc_evidence'|trans({'%count%': counts.evidence_documents}, 'certification_bundle') }}</td>
                    </tr>
                    <tr class="fa-table__row">
                        <td class="fa-table__cell"><i class="fa-icon text-success fa-icon--nav-file-check" aria-hidden="true"></i> 05_GAP_ANALYSIS.csv</td>
                        <td class="fa-table__cell">{{ 'certification_bundle.preview.desc_gaps'|trans({'%count%': counts.gaps}, 'certification_bundle') }}</td>
                    </tr>
                    <tr class="fa-table__row">
                        <td class="fa-table__cell"><i class="fa-icon text-info fa-icon--nav-document" aria-hidden="true"></i> METADATA.json</td>
                        <td class="fa-table__cell">{{ 'certification_bundle.preview.desc_metadata'|trans({}, 'certification_bundle') }}</td>
                    </tr>
                {% endblock %}
            {% endembed %}
        {% endblock %}
    {% endembed %}

    {# Konzern Bundle (Holding) — Task #129: only visible when current
       tenant has subsidiaries. ROLE_GROUP_CISO / ROLE_KONZERN_AUDITOR
       can dispatch a holding-wide export that aggregates per-subsidiary
       bundles into one ZIP with INDEX/RACI/OVERVIEW. #}
    {% if tenant.subsidiaries is defined and tenant.subsidiaries|length > 0 and (is_granted('ROLE_GROUP_CISO') or is_granted('ROLE_KONZERN_AUDITOR')) %}
        {% embed '_components/_card.html.twig' with {
            'header': 'certification_bundle.konzern_export.title'|trans({}, 'certification_bundle'),
            'class': 'mb-4 border-info'
        } %}
            {% block card_body %}
                <p class="mb-3">
                    <i class="fa-icon fa-icon--nav-info-circle text-info" aria-hidden="true"></i>
                    {{ 'certification_bundle.konzern_export.subtitle'|trans({}, 'certification_bundle') }}
                </p>

                <form method="post"
                      action="{{ path('app_certification_bundle_konzern_export') }}"
                      data-turbo="false"
                      id="konzern-export-form">
                    <input type="hidden" name="_token" value="{{ csrf_token('certification_bundle_konzern_export') }}">

                    {# Frameworks (multi). Default: ISO27001 stays primary. #}
                    <div class="mb-3">
                        <label class="form-label fw-semibold mb-1">
                            {{ 'certification_bundle.konzern_export.frameworks'|trans({}, 'certification_bundle') }}
                        </label>
                        <div class="ps-2 border-start">
                            <div class="form-check">
                                <input class="form-check-input"
                                       type="checkbox"
                                       name="frameworks[]"
                                       value="ISO27001"
                                       id="konzern-fw-iso27001"
                                       checked>
                                <label class="form-check-label small" for="konzern-fw-iso27001">
                                    ISO/IEC 27001:2022 <span class="text-muted">(ISO27001)</span>
                                </label>
                            </div>
                            {% for fw in frameworks|default([]) %}
                                {% if fw.code != 'ISO27001' %}
                                    <div class="form-check">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               name="frameworks[]"
                                               value="{{ fw.code }}"
                                               id="konzern-fw-{{ fw.code|lower|replace({'_':'-'}) }}">
                                        <label class="form-check-label small" for="konzern-fw-{{ fw.code|lower|replace({'_':'-'}) }}">
                                            {{ fw.name }} <span class="text-muted">({{ fw.code }})</span>
                                        </label>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>

                    {# Optional as-of date for the SoA-Stichtag (Item H wiring). #}
                    <div class="mb-3">
                        <label for="konzern-as-of-date" class="form-label fw-semibold mb-1">
                            {{ 'certification_bundle.konzern_export.as_of_date'|trans({}, 'certification_bundle') }}
                        </label>
                        <div class="fa-cyber-input" style="max-width: 240px;">
                            <div class="fa-cyber-input__frame">
                                <input type="date"
                                       name="as_of_date"
                                       id="konzern-as-of-date"
                                       class="fa-cyber-input__field">
                            </div>
                        </div>
                        <small class="form-text text-muted">
                            {{ 'certification_bundle.konzern_export.as_of_date_help'|trans({}, 'certification_bundle') }}
                        </small>
                    </div>

                    {# Subsidiary picker. Empty selection == include all subsidiaries (default). #}
                    <div class="mb-3">
                        <label class="form-label fw-semibold mb-1">
                            {{ 'certification_bundle.konzern_export.subsidiaries'|trans({}, 'certification_bundle') }}
                        </label>
                        <small class="form-text text-muted d-block mb-2">
                            {{ 'certification_bundle.konzern_export.subsidiaries_help'|trans({}, 'certification_bundle') }}
                        </small>
                        <div class="ps-2 border-start" style="max-height: 220px; overflow-y: auto;">
                            {% for sub in tenant.subsidiaries %}
                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           name="subsidiary_ids[]"
                                           value="{{ sub.id }}"
                                           id="konzern-sub-{{ sub.id }}">
                                    <label class="form-check-label small" for="konzern-sub-{{ sub.id }}">
                                        {{ sub.name }}
                                        {% if sub.code is not empty %}
                                            <span class="text-muted">({{ sub.code }})</span>
                                        {% endif %}
                                    </label>
                                </div>
                            {% endfor %}
                        </div>
                    </div>

                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--secondary">
                        <i class="fa-icon fa-icon--nav-download" aria-hidden="true"></i>
                        {{ 'certification_bundle.konzern_export.generate'|trans({}, 'certification_bundle') }}
                    </button>
                    <p class="text-muted mt-2 small mb-0">
                        {{ 'certification_bundle.konzern_export.note'|trans({}, 'certification_bundle') }}
                    </p>
                </form>
            {% endblock %}
        {% endembed %}
    {% endif %}

    {# Generate Button — data-turbo="false" weil Server BinaryFileResponse (ZIP) returnt.
       Audit-V3 EF-3: hidden #cert-bundle-framework-input mirrors the dropdown above
       (kept in sync via inline onchange) so POST carries the chosen framework code. #}
    <div class="text-center">
        <form method="post" action="{{ path('app_certification_bundle_export') }}" data-turbo="false" id="cert-bundle-export-form">
            <input type="hidden" name="_token" value="{{ csrf_token('certification_bundle_export') }}">
            <input type="hidden" name="framework" id="cert-bundle-framework-input" value="{{ selected_framework_code|default('ISO27001') }}">
            <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--lg">
                <i class="fa-icon fa-icon--nav-download" aria-hidden="true"></i>
                {{ 'certification_bundle.generate'|trans({}, 'certification_bundle') }}
            </button>
            <p class="text-muted mt-2 small">
                {{ 'certification_bundle.preview.note_generation'|trans({}, 'certification_bundle') }}
            </p>
        </form>
    </div>
</div>

{% endblock %}
