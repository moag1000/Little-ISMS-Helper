{% extends 'base.html.twig' %}
{% trans_default_domain 'cert_bundle' %}

{% block title %}{{ 'cert_bundle.preflight.title'|trans }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}

{% block body %}
    {% import '_components/_fa_progress.html.twig' as _fa_progress %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.compliance'|trans({}, 'nav'), path: 'app_management_reports' },
            { label: 'certification_bundle.title'|trans({}, 'certification_bundle'), path: 'app_certification_bundle_index' },
            { label: 'cert_bundle.preflight.breadcrumb'|trans }
        ]
    } only %}

    {{ _fa_page_header.render({
        badge: { icon: 'shield-check', label: selected_framework_code|default('ISO27001') },
        title: 'cert_bundle.preflight.title'|trans,
        subtitle: 'cert_bundle.preflight.subtitle'|trans,
        actions: [
            { label: 'cert_bundle.preflight.back'|trans, variant: 'ghost', icon: 'arrow-left', href: path('app_certification_bundle_index') }
        ]
    }) }}

    {# Readiness Score Card #}
    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            {% set scoreVariant = readiness.score >= 80 ? 'success' : (readiness.score >= 60 ? 'warning' : 'danger') %}
            {{ _fa_feature_card.render({
                icon: 'speedometer',
                label: 'cert_bundle.preflight.score.label'|trans,
                value: readiness.score,
                unit: '%',
                variant: scoreVariant,
                class: 'h-100'
            }) }}
        </div>
        <div class="col-md-4 mb-3">
            {{ _fa_feature_card.render({
                icon: readiness.ready ? 'check-circle-fill' : 'x-circle-fill',
                label: 'cert_bundle.preflight.status.label'|trans,
                value: readiness.ready ? 'cert_bundle.preflight.status.ready'|trans : 'cert_bundle.preflight.status.not_ready'|trans,
                variant: readiness.ready ? 'success' : 'danger',
                class: 'h-100'
            }) }}
        </div>
        <div class="col-md-4 mb-3">
            {{ _fa_feature_card.render({
                icon: 'exclamation-triangle',
                label: 'cert_bundle.preflight.blockers.count_label'|trans,
                value: readiness.blockers|length,
                variant: readiness.blockers|length > 0 ? 'danger' : 'success',
                class: 'h-100'
            }) }}
        </div>
    </div>

    {# Progress bar #}
    <div class="mb-4">
        {% set scoreVariant = readiness.score >= 80 ? 'success' : (readiness.score >= 60 ? 'warning' : 'danger') %}
        <div class="d-flex justify-content-between mb-1">
            <span class="small fw-semibold">{{ 'cert_bundle.preflight.score.label'|trans }}</span>
            <span class="small fw-bold">{{ readiness.score }}%</span>
        </div>
        {{ _fa_progress.render({ value: readiness.score, tone: scoreVariant }) }}
    </div>

    {# Checks Overview #}
    <div class="card mb-4">
        <div class="card-header fw-semibold">
            <i class="bi bi-list-check me-1" aria-hidden="true"></i>
            {{ 'cert_bundle.preflight.checks.title'|trans }}
        </div>
        <ul class="list-group list-group-flush">
            {% set checkLabels = {
                'documents_approved': 'cert_bundle.preflight.checks.documents_approved',
                'policy_acknowledgements': 'cert_bundle.preflight.checks.policy_acknowledgements',
                'findings_closed': 'cert_bundle.preflight.checks.findings_closed',
                'risk_assessment_current': 'cert_bundle.preflight.checks.risk_assessment_current',
                'management_review_current': 'cert_bundle.preflight.checks.management_review_current'
            } %}
            {% for checkKey, passed in readiness.checks %}
                <li class="list-group-item d-flex align-items-center gap-2">
                    {% if passed %}
                        <i class="bi bi-check-circle-fill text-success flex-shrink-0" aria-hidden="true"></i>
                    {% else %}
                        <i class="bi bi-x-circle-fill text-danger flex-shrink-0" aria-hidden="true"></i>
                    {% endif %}
                    <span>{{ (checkLabels[checkKey])|default(checkKey)|trans }}</span>
                    <span class="ms-auto badge {% if passed %}text-bg-success{% else %}text-bg-danger{% endif %}">
                        {{ passed ? 'cert_bundle.preflight.checks.passed'|trans : 'cert_bundle.preflight.checks.failed'|trans }}
                    </span>
                </li>
            {% endfor %}
        </ul>
    </div>

    {# Blockers #}
    {% if readiness.blockers|length > 0 %}
        <div class="card mb-4 border-danger">
            <div class="card-header fw-semibold">
                <i class="bi bi-shield-x text-danger me-1" aria-hidden="true"></i>
                {{ 'cert_bundle.preflight.blockers.title'|trans }}
            </div>
            <ul class="list-group list-group-flush">
                {% for blocker in readiness.blockers %}
                    <li class="list-group-item d-flex align-items-start gap-2">
                        <i class="bi bi-x-circle-fill text-danger flex-shrink-0 mt-1" aria-hidden="true"></i>
                        <div>
                            <div class="fw-semibold">{{ ('cert_bundle.preflight.blocker.' ~ blocker.type)|trans({'%count%': blocker.count|default(0)|number_format(0, '.', '')}) }}</div>
                            <small class="text-muted">{{ ('cert_bundle.preflight.blocker.' ~ blocker.type ~ '_hint')|trans({}, 'cert_bundle') }}</small>
                        </div>
                        <span class="ms-auto badge text-bg-danger flex-shrink-0">{{ blocker.severity }}</span>
                    </li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    {# Warnings #}
    {% if readiness.warnings|length > 0 %}
        <div class="card mb-4 border-warning">
            <div class="card-header fw-semibold">
                <i class="bi bi-exclamation-triangle-fill text-warning me-1" aria-hidden="true"></i>
                {{ 'cert_bundle.preflight.warnings.title'|trans }}
            </div>
            <ul class="list-group list-group-flush">
                {% for warning in readiness.warnings %}
                    <li class="list-group-item d-flex align-items-start gap-2">
                        <i class="bi bi-exclamation-triangle-fill text-warning flex-shrink-0 mt-1" aria-hidden="true"></i>
                        <div>
                            <div class="fw-semibold">{{ ('cert_bundle.preflight.warning.' ~ warning.type)|trans({'%count%': warning.count|default(0)}) }}</div>
                            <small class="text-muted">{{ ('cert_bundle.preflight.warning.' ~ warning.type ~ '_hint')|trans({}, 'cert_bundle', null, '') }}</small>
                        </div>
                        <span class="ms-auto badge text-bg-warning text-dark flex-shrink-0">{{ warning.severity }}</span>
                    </li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    {# All clear #}
    {% if readiness.ready and readiness.warnings|length == 0 %}
        {{ _fa_alert.render({
            variant: 'success',
            class: 'mb-4',
            body: 'cert_bundle.preflight.all_clear'|trans
        }) }}
    {% endif %}

    {# Action Buttons #}
    <div class="d-flex flex-wrap gap-3 align-items-center">
        {# Fix blockers first #}
        {% if readiness.blockers|length > 0 %}
            <a class="fa-cyber-btn fa-cyber-btn--primary" href="{{ path('app_certification_bundle_index') }}">
                <i class="bi bi-arrow-left" aria-hidden="true"></i>
                {{ 'cert_bundle.preflight.action.fix'|trans }}
            </a>
        {% else %}
            {# Green path: export directly #}
            <form method="post" action="{{ path('app_certification_bundle_export') }}" data-turbo="false">
                <input type="hidden" name="_token" value="{{ csrf_token('certification_bundle_export') }}">
                <input type="hidden" name="framework" value="{{ selected_framework_code|default('ISO27001') }}">
                <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                    <i class="bi bi-download" aria-hidden="true"></i>
                    {{ 'cert_bundle.preflight.action.export'|trans }}
                </button>
            </form>
        {% endif %}

        {# Override: export anyway despite blockers (shows warning) #}
        {% if readiness.blockers|length > 0 %}
            <div>
                {{ _fa_alert.render({
                    variant: 'danger',
                    class: 'mb-0',
                    body: 'cert_bundle.preflight.override_warning'|trans
                }) }}
                <form method="post" action="{{ path('app_certification_bundle_export') }}" data-turbo="false" class="mt-2">
                    <input type="hidden" name="_token" value="{{ csrf_token('certification_bundle_export') }}">
                    <input type="hidden" name="framework" value="{{ selected_framework_code|default('ISO27001') }}">
                    <input type="hidden" name="bypass_preflight" value="1">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger fa-cyber-btn--sm">
                        <i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i>
                        {{ 'cert_bundle.preflight.action.export_anyway'|trans }}
                    </button>
                </form>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
