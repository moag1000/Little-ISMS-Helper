{% extends 'base.html.twig' %}
{% trans_default_domain 'consent' %}

{% block title %}{{ form.vars.data.id ? 'consent.edit'|trans({}, 'consent') : 'consent.new'|trans({}, 'consent') }} - {{ parent() }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="{{ path('app_consent_index') }}" data-turbo-action="advance">
                    <i class="bi bi-hand-thumbs-up" aria-hidden="true"></i> {{ 'nav.consents'|trans({}, 'nav') }}
                </a>
            </li>
            {% if form.vars.data.id %}
            <li class="breadcrumb-item">
                <a href="{{ path('app_consent_show', {id: form.vars.data.id}) }}" data-turbo-action="advance">
                    {{ form.vars.data.dataSubjectIdentifier }}
                </a>
            </li>
            {% endif %}
            <li class="breadcrumb-item active" aria-current="page">{{ form.vars.data.id ? 'consent.edit'|trans({}, 'consent') : 'consent.new'|trans({}, 'consent') }}</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">
            {# TODO(aurora-migration): dynamic icon — keep bi-* #}
            <i class="bi {{ form.vars.data.id ? 'bi-pencil' : 'bi-plus-circle' }}" aria-hidden="true"></i>
            {{ form.vars.data.id ? 'consent.edit'|trans({}, 'consent') : 'consent.new'|trans({}, 'consent') }}
        </h1>
        <a href="{{ form.vars.data.id ? path('app_consent_show', {id: form.vars.data.id}) : path('app_consent_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost" data-turbo-action="advance">
            <i class="bi bi-arrow-left" aria-hidden="true"></i> {{ 'common.back'|trans({}, 'messages') }}
        </a>
    </div>

    <div class="row">
        <div class="col-lg-8">
            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header">
                        <h2 class="mb-0">{{ form.vars.data.id ? 'consent.edit'|trans({}, 'consent') : 'consent.new'|trans({}, 'consent') }}</h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'id': 'consent-form'}}) }}

                    {# Section 1: Data Subject #}
                    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
                        {% block card_header %}
                            <div class="card-header bg-body-secondary">
                                <h3 class="mb-0">
                                    <i class="fa-icon fa-icon--user" aria-hidden="true"></i>
                                    {{ 'consent.section.data_subject'|trans({}, 'consent') }}
                                </h3>
                            </div>
                        {% endblock %}
                        {% block card_body %}
                            <div class="row">
                                <div class="col-md-8">
                                    {{ form_row(form.dataSubjectIdentifier) }}
                                </div>
                                <div class="col-md-4">
                                    {{ form_row(form.identifierType) }}
                                </div>
                            </div>
                        {% endblock %}
                    {% endembed %}

                    {# Section 2: Processing Activity #}
                    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
                        {% block card_header %}
                            <div class="card-header bg-body-secondary">
                                <h3 class="mb-0">
                                    <i class="bi bi-gear" aria-hidden="true"></i>
                                    {{ 'consent.section.processing_activity'|trans({}, 'consent') }}
                                </h3>
                            </div>
                        {% endblock %}
                        {% block card_body %}
                            <div class="row">
                                <div class="col-md-6">
                                    {{ form_row(form.processingActivity) }}
                                </div>
                                <div class="col-md-6">
                                    {{ form_row(form.purposes) }}
                                </div>
                            </div>
                        {% endblock %}
                    {% endembed %}

                    {# Section 3: Consent Grant #}
                    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
                        {% block card_header %}
                            <div class="card-header bg-body-secondary">
                                <h3 class="mb-0">
                                    <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
                                    {{ 'consent.section.consent_grant'|trans({}, 'consent') }}
                                </h3>
                            </div>
                        {% endblock %}
                        {% block card_body %}
                            <div class="row">
                                <div class="col-md-4">
                                    {{ form_row(form.grantedAt) }}
                                </div>
                                <div class="col-md-4">
                                    {{ form_row(form.consentMethod) }}
                                </div>
                                <div class="col-md-4">
                                    {{ form_row(form.consentChannel) }}
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-12">
                                    {{ form_row(form.consentText) }}
                                </div>
                            </div>
                        {% endblock %}
                    {% endembed %}

                    {# Section 4: Proof Documentation #}
                    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
                        {% block card_header %}
                            <div class="card-header bg-body-secondary">
                                <h3 class="mb-0">
                                    <i class="bi bi-file-earmark-pdf" aria-hidden="true"></i>
                                    {{ 'consent.section.proof_documentation'|trans({}, 'consent') }}
                                </h3>
                            </div>
                        {% endblock %}
                        {% block card_body %}
                            <div class="row">
                                <div class="col-md-12">
                                    {{ form_row(form.proofDocument) }}
                                </div>
                            </div>
                        {% endblock %}
                    {% endembed %}

                    {# Section 5: Expiry #}
                    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
                        {% block card_header %}
                            <div class="card-header bg-body-secondary">
                                <h3 class="mb-0">
                                    <i class="bi bi-calendar-event" aria-hidden="true"></i>
                                    {{ 'consent.section.expiry'|trans({}, 'consent') }}
                                </h3>
                            </div>
                        {% endblock %}
                        {% block card_body %}
                            <div class="row">
                                <div class="col-md-6">
                                    {{ form_row(form.expiresAt) }}
                                    <small class="text-muted d-block">{{ 'consent.hint.expiry_optional'|trans({}, 'consent') }}</small>
                                </div>
                            </div>
                        {% endblock %}
                    {% endembed %}

                    {# Section 6: Notes #}
                    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
                        {% block card_header %}
                            <div class="card-header bg-body-secondary">
                                <h3 class="mb-0">
                                    <i class="bi bi-sticky" aria-hidden="true"></i>
                                    {{ 'consent.section.notes'|trans({}, 'consent') }}
                                </h3>
                            </div>
                        {% endblock %}
                        {% block card_body %}
                            <div class="row">
                                <div class="col-md-12">
                                    {{ form_row(form.notes) }}
                                </div>
                            </div>
                        {% endblock %}
                    {% endembed %}

                    {# Form Actions #}
                    <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                        <a href="{{ form.vars.data.id ? path('app_consent_show', {id: form.vars.data.id}) : path('app_consent_index') }}"
                           class="fa-cyber-btn fa-cyber-btn--ghost"
                           data-turbo-action="advance">
                            <i class="bi bi-arrow-left" aria-hidden="true"></i> {{ 'common.back'|trans({}, 'messages') }}
                        </a>
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--lg">
                            <i class="bi bi-save" aria-hidden="true"></i> {{ 'consent.action.save'|trans({}, 'consent') }}
                        </button>
                    </div>

                    {{ form_end(form) }}
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-lg-4">
            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header bg-body-secondary">
                        <h2 class="mb-0"><i class="fa-icon fa-icon--status-info" aria-hidden="true"></i> {{ 'consent.sidebar.title'|trans({}, 'consent') }}</h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <h3 class="h6">{{ 'consent.sidebar.valid_title'|trans({}, 'consent') }}</h3>
                    <p class="small text-muted">{{ 'consent.sidebar.valid_text'|trans({}, 'consent') }}</p>

                    <h3 class="h6">{{ 'consent.sidebar.conditions_title'|trans({}, 'consent') }}</h3>
                    <ul class="small text-muted ps-3">
                        <li>{{ 'consent.sidebar.condition_1'|trans({}, 'consent') }}</li>
                        <li>{{ 'consent.sidebar.condition_2'|trans({}, 'consent') }}</li>
                        <li>{{ 'consent.sidebar.condition_3'|trans({}, 'consent') }}</li>
                        <li>{{ 'consent.sidebar.condition_4'|trans({}, 'consent') }}</li>
                    </ul>

                    <h3 class="h6">{{ 'consent.sidebar.methods_title'|trans({}, 'consent') }}</h3>
                    <p class="small text-muted">{{ 'consent.sidebar.methods_text'|trans({}, 'consent') }}</p>

                    <h3 class="h6">{{ 'consent.sidebar.proof_title'|trans({}, 'consent') }}</h3>
                    <p class="small text-muted">{{ 'consent.sidebar.proof_text'|trans({}, 'consent') }}</p>
                {% endblock %}
            {% endembed %}
        </div>
    </div>
</div>
{% endblock %}
