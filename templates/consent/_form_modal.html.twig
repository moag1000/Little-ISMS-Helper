{# Consent create/edit rendered inside the fa-form-modal Turbo Frame.
   Explicit form action (the document URL stays on the list). On valid submit the
   controller returns a Turbo Stream (row replace/append). #}
{% trans_default_domain 'consent' %}
{% set is_edit = consent is defined and consent and consent.id is not null %}
{% set form_action = is_edit ? path('app_consent_edit', { id: consent.id }) : path('app_consent_new') %}
<turbo-frame id="fa-form-modal">
    {{ form_start(form, { action: form_action, method: 'POST', attr: {
        id: 'consent-modal-form',
        'data-turbo-frame': 'fa-form-modal'
    } }) }}
    {% include 'consent/_form_body.html.twig' with {
        form: form,
        modal: true,
        title: is_edit ? consent.dataSubjectIdentifier : 'consent.new'|trans({}, 'consent'),
        actions: {
            close: { label: 'common.cancel'|trans({}, 'messages'), variant: 'ghost', action: 'fa-form-modal#close' },
            submit: { label: 'consent.action.save'|trans({}, 'consent'), variant: 'primary' }
        }
    } %}
    {{ form_end(form) }}
</turbo-frame>
