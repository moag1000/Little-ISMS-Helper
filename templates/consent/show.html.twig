{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% trans_default_domain 'consent' %}

{% block title %}{{ consent.dataSubjectIdentifier }} - {{ 'consent.header.title'|trans({}, 'consent') }}{% endblock %}

{% block body %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.consents'|trans({}, 'nav'), url: path('app_consent_index') },
            { label: consent.dataSubjectIdentifier }
        ]
    } %}

    <div class="page-header">
        <h1>
            <i class="bi bi-hand-thumbs-up" aria-hidden="true"></i>
            {{ consent.dataSubjectIdentifier }}
        </h1>
        <div class="actions">
            {% if is_granted('ROLE_USER') and (consent.status == 'pending_verification' or consent.status == 'active') %}
            <a href="{{ path('app_consent_edit', {id: consent.id}) }}" class="fa-cyber-btn fa-cyber-btn--primary">
                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i> {{ 'common.edit'|trans({}, 'messages') }}
            </a>
            {% endif %}
            {% if is_granted('ROLE_DPO') and not consent.verifiedBy %}
            <button class="fa-cyber-btn fa-cyber-btn--success" data-bs-toggle="modal" data-bs-target="#verifyModal">
                <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i> {{ 'consent.action.verify'|trans({}, 'consent') }}
            </button>
            {% endif %}
            {% if consent.status == 'active' %}
            <button class="fa-cyber-btn fa-cyber-btn--warning" data-bs-toggle="modal" data-bs-target="#revokeModal">
                <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> {{ 'consent.action.document_revocation'|trans({}, 'consent') }}
            </button>
            {% endif %}
            {% if is_granted('ROLE_ADMIN') %}
            <form method="post" action="{{ path('app_consent_delete', {id: consent.id}) }}" class="d-inline"
                  data-controller="ui-actions"
                  data-action="submit->ui-actions#confirm"
                  data-ui-actions-message-param="{{ 'consent.delete.confirm'|trans({}, 'consent') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ consent.id) }}">
                <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger">
                    <i class="fa-icon fa-icon--ui-trash" aria-hidden="true"></i> {{ 'common.delete'|trans({}, 'messages') }}
                </button>
            </form>
            {% endif %}
            <a href="{{ path('app_consent_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                <i class="fa-icon fa-icon--util-arrow-left" aria-hidden="true"></i> {{ 'common.back_to_list'|trans({}, 'messages') }}
            </a>
        </div>
    </div>

    {# Status Badges #}
    <div class="mb-4">
        {% set statusBadgeClass = {
            'pending_verification': 'warning',
            'active': 'success',
            'revoked': 'danger'
        }[consent.status] ?? 'secondary' %}

        {% include '_components/_badge.html.twig' with { variant: statusBadgeClass, class: 'me-2 fs-6 px-3 py-2', content: ('consent.status.' ~ consent.status)|trans({}, 'consent') } %}

        {% if consent.verifiedBy %}
        {% include '_components/_badge.html.twig' with { variant: 'info', icon: 'bi-check-circle', class: 'me-2 fs-6 px-3 py-2', content: 'consent.verified'|trans({}, 'consent') } %}
        {% endif %}

        {% if consent.revokedAt %}
        {% include '_components/_badge.html.twig' with { variant: 'danger', icon: 'bi-x-circle', class: 'fs-6 px-3 py-2', content: 'consent.revoked'|trans({}, 'consent') } %}
        {% endif %}
    </div>

    {# Data Subject Section #}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
        {% block card_header %}
            <div class="card-header bg-body-secondary">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--user" aria-hidden="true"></i>
                    {{ 'consent.section.data_subject'|trans({}, 'consent') }}
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            <div class="row">
                <div class="col-md-6">
                    <div class="detail-item">
                        <span class="label">{{ 'consent.field.data_subject'|trans({}, 'consent') }}:</span>
                        <span class="value">{{ consent.dataSubjectIdentifier }}</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="detail-item">
                        <span class="label">{{ 'consent.field.identifier_type'|trans({}, 'consent') }}:</span>
                        <span class="value">{{ ('consent.identifier_type.' ~ consent.identifierType)|trans({}, 'consent') }}</span>
                    </div>
                </div>
            </div>
        {% endblock %}
    {% endembed %}

    {# Processing Activity Section #}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
        {% block card_header %}
            <div class="card-header bg-body-secondary">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--ui-settings" aria-hidden="true"></i>
                    {{ 'consent.section.processing_activity'|trans({}, 'consent') }}
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            <div class="row">
                <div class="col-md-6">
                    <div class="detail-item">
                        <span class="label">{{ 'consent.field.processing_activity'|trans({}, 'consent') }}:</span>
                        <span class="value">
                            {% if consent.processingActivity %}
                                {{ consent.processingActivity.name|default(consent.processingActivity) }}
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="detail-item">
                        <span class="label">{{ 'consent.field.purposes'|trans({}, 'consent') }}:</span>
                        <span class="value">{{ consent.purposes|default('-') }}</span>
                    </div>
                </div>
            </div>
        {% endblock %}
    {% endembed %}

    {# Consent Grant Section #}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
        {% block card_header %}
            <div class="card-header bg-body-secondary">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
                    {{ 'consent.section.consent_grant'|trans({}, 'consent') }}
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            <div class="row">
                <div class="col-md-4">
                    <div class="detail-item">
                        <span class="label">{{ 'consent.field.granted_at'|trans({}, 'consent') }}:</span>
                        <span class="value">{{ consent.grantedAt|date('d.m.Y H:i') }}</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="detail-item">
                        <span class="label">{{ 'consent.field.consent_method'|trans({}, 'consent') }}:</span>
                        <span class="value">{{ ('consent.method.' ~ consent.consentMethod)|trans({}, 'consent') }}</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="detail-item">
                        <span class="label">{{ 'consent.field.consent_channel'|trans({}, 'consent') }}:</span>
                        <span class="value">{{ ('consent.channel.' ~ consent.consentChannel)|trans({}, 'consent') }}</span>
                    </div>
                </div>
            </div>
            {% if consent.consentText %}
            <div class="row mt-3">
                <div class="col-md-12">
                    <div class="detail-item">
                        <span class="label">{{ 'consent.field.consent_text'|trans({}, 'consent') }}:</span>
                        <div class="value bg-body-secondary p-3 rounded mt-2">
                            {{ consent.consentText }}
                        </div>
                    </div>
                </div>
            </div>
            {% endif %}
        {% endblock %}
    {% endembed %}

    {# Proof Documentation Section #}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
        {% block card_header %}
            <div class="card-header bg-body-secondary">
                <h2 class="mb-0">
                    <i class="bi bi-file-earmark-pdf" aria-hidden="true"></i>
                    {{ 'consent.section.proof_documentation'|trans({}, 'consent') }}
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% if consent.proofDocument %}
            <div class="detail-item">
                <span class="label">{{ 'consent.field.proof_document'|trans({}, 'consent') }}:</span>
                <span class="value">
                    <a href="{{ consent.proofDocument }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm" target="_blank" rel="noopener noreferrer">
                        <i class="fa-icon fa-icon--nav-download" aria-hidden="true"></i> {{ 'common.download'|trans({}, 'messages') }}
                    </a>
                </span>
            </div>
            {% else %}
            {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', icon: 'bi-info-circle', class: 'mb-0' } } %}
                {% block alert_body %}{{ 'consent.no_proof_document'|trans({}, 'consent') }}{% endblock %}
            {% endembed %}
            {% endif %}
        {% endblock %}
    {% endembed %}

    {# Expiry Section #}
    {% if consent.expiresAt %}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
        {% block card_header %}
            <div class="card-header bg-body-secondary">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--ui-calendar-event" aria-hidden="true"></i>
                    {{ 'consent.section.expiry'|trans({}, 'consent') }}
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            <div class="detail-item">
                <span class="label">{{ 'consent.field.expires_at'|trans({}, 'consent') }}:</span>
                <span class="value">{{ consent.expiresAt|date('d.m.Y') }}</span>
            </div>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {# DPO Verification Section #}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
        {% block card_header %}
            <div class="card-header bg-body-secondary">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--compliance-shield" aria-hidden="true"></i>
                    {{ 'consent.section.dpo_verification'|trans({}, 'consent') }}
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% if consent.verifiedBy %}
            {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'success', icon: 'status-ok', class: 'mb-0' } } %}
                {% block alert_body %}<div class="d-flex align-items-center"> <i class="fa-icon fa-icon--status-ok me-2" aria-hidden="true"></i> <div> <strong>{{ 'consent.verified'|trans({}, 'consent') }}</strong> <br> <small>{{ 'consent.verified_by_user'|trans({'%user%': consent.verifiedBy}, 'consent') }}</small> {% if consent.verifiedAt %} <br> <small>{{ consent.verifiedAt|date('d.m.Y H:i') }}</small> {% endif %} </div> </div>{% endblock %}
            {% endembed %}
            {% else %}
            {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning', icon: 'status-warning', class: 'mb-0' } } %}
                {% block alert_body %}{{ 'consent.not_verified'|trans({}, 'consent') }}{% endblock %}
            {% endembed %}
            {% endif %}
        {% endblock %}
    {% endembed %}

    {# Revocation Section #}
    {% if consent.revokedAt %}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
        {% block card_header %}
            <div class="card-header bg-body-secondary">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i>
                    {{ 'consent.section.revocation'|trans({}, 'consent') }}
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'danger', class: 'mb-0' } } %}
                {% block alert_body %}<strong>{{ 'consent.revoked'|trans({}, 'consent') }}</strong> <br> <small>{{ 'consent.revoked_at'|trans({'%date%': consent.revokedAt|date('d.m.Y H:i')}, 'consent') }}</small> {% if consent.revocationReason %} <br> <small>{{ 'consent.revocation_reason'|trans({}, 'consent') }}: {{ consent.revocationReason }}</small> {% endif %}{% endblock %}
            {% endembed %}
        {% endblock %}
    {% endembed %}
    {% endif %}

    {# Notes Section #}
    {% if consent.notes %}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
        {% block card_header %}
            <div class="card-header bg-body-secondary">
                <h2 class="mb-0">
                    <i class="bi bi-sticky" aria-hidden="true"></i>
                    {{ 'consent.section.notes'|trans({}, 'consent') }}
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            <div class="bg-body-secondary p-3 rounded">
                {{ consent.notes }}
            </div>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {# Metadata Section #}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
        {% block card_header %}
            <div class="card-header bg-body-secondary">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--ui-info" aria-hidden="true"></i>
                    {{ 'consent.section.metadata'|trans({}, 'consent') }}
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            <div class="row">
                <div class="col-md-6">
                    <div class="detail-item">
                        <span class="label">{{ 'consent.field.id'|trans({}, 'consent') }}:</span>
                        <span class="value"><code>{{ consent.id }}</code></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="detail-item">
                        <span class="label">{{ 'consent.field.created_at'|trans({}, 'consent') }}:</span>
                        <span class="value">{{ consent.createdAt|date('d.m.Y H:i') }}</span>
                    </div>
                </div>
                {% if consent.updatedAt %}
                <div class="col-md-6">
                    <div class="detail-item">
                        <span class="label">{{ 'consent.field.updated_at'|trans({}, 'consent') }}:</span>
                        <span class="value">{{ consent.updatedAt|date('d.m.Y H:i') }}</span>
                    </div>
                </div>
                {% endif %}
            </div>
        {% endblock %}
    {% endembed %}
</div>

{# Verify Modal #}
<div class="modal fade" id="verifyModal" tabindex="-1" aria-labelledby="verifyModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title h5" id="verifyModalLabel">{{ 'consent.action.verify'|trans({}, 'consent') }}</h3>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'common.close'|trans({}, 'messages') }}"></button>
            </div>
            <form method="post" action="{{ path('app_consent_verify', {id: consent.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('verify' ~ consent.id) }}">
                <div class="modal-body">
                    <p>{{ 'consent.verify.confirmation'|trans({}, 'consent') }}</p>
                    <p class="text-muted small">{{ 'consent.verify.hint'|trans({}, 'consent') }}</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost" data-bs-dismiss="modal">{{ 'common.cancel'|trans({}, 'messages') }}</button>
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--success">
                        <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i> {{ 'consent.action.verify'|trans({}, 'consent') }}
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

{# Revoke Modal #}
<div class="modal fade" id="revokeModal" tabindex="-1" aria-labelledby="revokeModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title h5" id="revokeModalLabel">{{ 'consent.action.document_revocation'|trans({}, 'consent') }}</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'common.close'|trans({}, 'messages') }}"></button>
            </div>
            <form method="post" action="{{ path('app_consent_revoke', {id: consent.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('revoke' ~ consent.id) }}">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="revocationReason" class="form-label">{{ 'consent.field.revocation_reason'|trans({}, 'consent') }}</label>
                        <textarea class="form-control" id="revocationReason" name="revocationReason" rows="3" required></textarea>
                    </div>
                    <p class="text-muted small">{{ 'consent.revoke.hint'|trans({}, 'consent') }}</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost" data-bs-dismiss="modal">{{ 'common.cancel'|trans({}, 'messages') }}</button>
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger">
                        <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> {{ 'consent.action.document_revocation'|trans({}, 'consent') }}
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
.detail-item {
    margin-bottom: 1rem;
}

.detail-item:last-child {
    margin-bottom: 0;
}

.detail-item .label {
    font-weight: 500;
    color: var(--fg-3);
    font-size: 0.875rem;
    display: block;
    margin-bottom: 0.25rem;
}

.detail-item .value {
    color: var(--fg);
    font-size: 1rem;
}

.card-header.bg-body-secondary {
    background-color: var(--surface-2) !important;
}
</style>

{% endblock %}
