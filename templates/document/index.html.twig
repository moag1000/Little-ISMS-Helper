{% extends 'base.html.twig' %}
{% import '_components/_fa_alva_hint.html.twig' as _fa_alva_hint %}
{% trans_default_domain 'document' %}
{% import '_macros/inheritance_badge.html.twig' as inheritance %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_status_pill.html.twig' as pill %}

{% block title %}{{ 'document.title'|trans({}, 'document') }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {# Breadcrumb Navigation #}
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'common.dashboard'|trans({}, 'messages'), url: path('app_dashboard') },
            { label: 'document.title'|trans({}, 'document') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'nav-file-earmark-text', label: 'document.title'|trans({}, 'document') },
        title: 'document.title'|trans({}, 'document'),
        subtitle: 'document.subtitle'|trans({}, 'document'),
        actions: [
            { label: 'document.action.policy_wizard'|trans({}, 'document'), variant: 'success', icon: 'nav-magic', href: path('app_policy_wizard_index') },
            { label: 'document.action.upload'|trans({}, 'document'), variant: 'primary', icon: 'ui-upload', href: path('app_document_new') }
        ]|merge(is_granted('ROLE_MANAGER') ? [{ label: 'filtered_export.button.label'|trans({}, 'filtered_export'), href: path('app_filtered_export_entity', { entityType: 'document', format: 'xlsx' }) ~ (app.request.queryString ? '?' ~ app.request.queryString : ''), variant: 'ghost', icon: 'nav-file-earmark-spreadsheet' }] : [])
    }) }}
{% set _global_hints = alva_hints('document_index') %}
{% if _global_hints|length > 0 %}
    {% for _h in _global_hints %}
        {{ _fa_alva_hint.render(_h) }}
    {% endfor %}
{% endif %}


    <main class="fa-aurora-surface">

    {# Alva-Tipp: Policy-Wizard generates ISO 27001 / DORA / BSI / BCM / GDPR mandatory policies — V3 W2-L3 Aurora alert migration #}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', class: 'mb-3' } } %}
        {% block alert_body %}
            <div class="d-flex align-items-start gap-3">
                <i class="fa-icon fa-icon--nav-magic flex-shrink-0" aria-hidden="true"></i>
                <div class="flex-grow-1">
                    <strong>{{ 'document.alva_tipp.policy_wizard.title'|trans({}, 'document') }}</strong>
                    <p class="mb-2 mt-1">{{ 'document.alva_tipp.policy_wizard.body'|trans({}, 'document') }}</p>
                    <a href="{{ path('app_policy_wizard_index') }}" class="fa-cyber-btn fa-cyber-btn--success fa-cyber-btn--sm">
                        <i class="fa-icon fa-icon--nav-magic me-1" aria-hidden="true"></i>
                        {{ 'document.alva_tipp.policy_wizard.cta'|trans({}, 'document') }}
                    </a>
                </div>
            </div>
        {% endblock %}
    {% endembed %}

    {# View Filter #}
    {% if currentTenant %}
    {% embed '_components/_card.html.twig' with {class: 'mb-3'} %}
        {% block card_body %}
            <form method="get" action="{{ path('app_document_index') }}" class="d-flex flex-wrap align-items-center gap-2 py-0">
                <label for="view-filter" class="mb-0 fw-bold">
                    <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i> {{ 'common.view'|trans({}, 'messages') }}:
                </label>
                <select class="form-select fa-cyber-input__field form-select-sm w-auto" id="view-filter" name="view" data-controller="ui-actions" data-action="change->ui-actions#autoSubmit">
                    <option value="own" {{ inheritanceInfo.currentView == 'own' ? 'selected' : '' }}>
                        {{ 'corporate.view.own_only'|trans({}, 'messages') }}
                    </option>
                    {% if inheritanceInfo.hasParent %}
                    <option value="inherited" {{ inheritanceInfo.currentView == 'inherited' ? 'selected' : '' }}>
                        {{ 'corporate.view.including_inherited'|trans({}, 'messages') }}
                    </option>
                    {% endif %}
                    {% if inheritanceInfo.hasSubsidiaries %}
                    <option value="subsidiaries" {{ inheritanceInfo.currentView == 'subsidiaries' ? 'selected' : '' }}>
                        {{ 'corporate.view.including_subsidiaries'|trans({}, 'messages') }}
                    </option>
                    {% endif %}
                </select>

                {# Policy-Wizard W7-C — history toggle (default OFF). #}
                <span class="ms-3 text-muted">|</span>
                <label for="include-history-toggle" class="mb-0 fw-bold">
                    <i class="fa-icon fa-icon--ui-clock" aria-hidden="true"></i>
                    {{ 'policy_wizard.history_toggle.label'|trans({}, 'policy_wizard') }}:
                </label>
                <select class="form-select fa-cyber-input__field form-select-sm w-auto"
                        id="include-history-toggle"
                        name="include_history"
                        data-controller="ui-actions"
                        data-action="change->ui-actions#autoSubmit">
                    <option value="0" {{ includeHistory ? '' : 'selected' }}>
                        {{ 'policy_wizard.history_toggle.current_only'|trans({}, 'policy_wizard') }}
                    </option>
                    <option value="1" {{ includeHistory ? 'selected' : '' }}>
                        {{ 'policy_wizard.history_toggle.with_history'|trans({}, 'policy_wizard') }}
                    </option>
                </select>

                <noscript>
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">{{ 'common.apply'|trans({}, 'messages') }}</button>
                </noscript>
            </form>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {# Calculate Stats #}
    {% set total = detailedStats.total %}
    {% set totalSize = documents|reduce((carry, doc) => carry + doc.fileSize, 0) %}
    {% set totalSizeMB = (totalSize / 1024 / 1024)|number_format(2) %}
    {% set pdfDocs = documents|filter(d => d.mimeType == 'application/pdf')|length %}
    {% set imageDocs = documents|filter(d => d.mimeType starts with 'image/')|length %}
    {% set excelDocs = documents|filter(d => d.mimeType matches '/spreadsheet/')|length %}

    {# KPI Cards #}
    <div class="kpi-grid">
        {{ _fa_feature_card.render({
            icon: 'nav-file-earmark-text',
            label: 'document.kpi.total_documents'|trans({}, 'document'),
            value: total,
            hint: currentTenant ? ('corporate.stats.breakdown'|trans({'%own%': detailedStats.own, '%inherited%': detailedStats.inherited, '%subsidiaries%': detailedStats.subsidiaries}, 'messages')) : null,
            variant: 'primary'
        }) }}

        {{ _fa_feature_card.render({
            icon: 'nav-hdd',
            label: 'document.kpi.total_size'|trans({}, 'document'),
            value: totalSizeMB,
            unit: 'MB',
            variant: 'primary'
        }) }}

        {{ _fa_feature_card.render({
            icon: 'nav-file-pdf',
            label: 'document.type.pdf'|trans({}, 'document'),
            value: pdfDocs,
            variant: 'danger'
        }) }}

        {{ _fa_feature_card.render({
            icon: 'nav-file-earmark-spreadsheet',
            label: 'document.type.excel'|trans({}, 'document'),
            value: excelDocs,
            variant: 'success'
        }) }}

        {{ _fa_feature_card.render({
            icon: 'nav-file-earmark-text',
            label: 'document.kpi.drafts'|trans({}, 'document'),
            value: kpiDrafts,
            variant: 'secondary'
        }) }}

        {{ _fa_feature_card.render({
            icon: 'ui-hourglass',
            label: 'document.kpi.in_review'|trans({}, 'document'),
            value: kpiInReview,
            variant: 'warning'
        }) }}
    </div>

    {# Document Type Distribution #}
    {% embed '_components/_card.html.twig' with {class: 'mb-4'} %}
        {% block card_header %}
            <div class="card-header">
                <h2 class="mb-0">
                    <i class="fa-icon fa-icon--nav-pie-chart" aria-hidden="true"></i>
                    {{ 'document.section.type_overview'|trans({}, 'document') }}
                </h2>
            </div>
        {% endblock %}
        {% block card_body %}
            <div class="row g-4">
                {# PDF #}
                <div class="col-md-3">
                    <div class="type-card text-center p-4 bg-pdf-light">
                        <div class="type-icon mb-3 fs-25 color-pdf">
                            <i class="fa-icon fa-icon--nav-file-pdf" aria-hidden="true"></i>
                        </div>
                        <div class="type-label text-muted mb-2">{{ 'document.type.pdf'|trans({}, 'document') }}</div>
                        <div class="type-count fs-2 fw-700 color-pdf">
                            {{ pdfDocs }}
                        </div>
                    </div>
                </div>

                {# Images #}
                <div class="col-md-3">
                    <div class="type-card text-center p-4 bg-image-light">
                        <div class="type-icon mb-3 fs-25 color-image">
                            <i class="fa-icon fa-icon--nav-document" aria-hidden="true"></i>
                        </div>
                        <div class="type-label text-muted mb-2">{{ 'document.type.images'|trans({}, 'document') }}</div>
                        <div class="type-count fs-2 fw-700 color-image">
                            {{ imageDocs }}
                        </div>
                    </div>
                </div>

                {# Excel/Spreadsheets #}
                <div class="col-md-3">
                    <div class="type-card text-center p-4 bg-excel-light">
                        <div class="type-icon mb-3 fs-25 color-excel">
                            <i class="fa-icon fa-icon--nav-file-check" aria-hidden="true"></i>
                        </div>
                        <div class="type-label text-muted mb-2">{{ 'document.type.tables'|trans({}, 'document') }}</div>
                        <div class="type-count fs-2 fw-700 color-excel">
                            {{ excelDocs }}
                        </div>
                    </div>
                </div>

                {# Other #}
                <div class="col-md-3">
                    <div class="type-card text-center p-4 bg-other-light">
                        <div class="type-icon mb-3 fs-25 color-other">
                            <i class="fa-icon fa-icon--nav-document" aria-hidden="true"></i>
                        </div>
                        <div class="type-label text-muted mb-2">{{ 'document.type.other'|trans({}, 'document') }}</div>
                        <div class="type-count fs-2 fw-700 color-other">
                            {{ total - pdfDocs - imageDocs - excelDocs }}
                        </div>
                    </div>
                </div>
            </div>
        {% endblock %}
    {% endembed %}

    {# Aurora filter-chip quick row (Audit V3 C5) — quick toggles for status #}
    {% import '_components/_fa_filter_chip.html.twig' as _fa_filter_chip %}
    {% set _activeDocStatus = currentStatus %}
    {% set _baseDocUrl = path('app_document_index') %}
    {{ _fa_filter_chip.group([
        { label: 'common.all'|trans({}, 'messages'),                    href: _baseDocUrl },
        { label: 'document.status.draft'|trans({}, 'document'),         href: _baseDocUrl ~ '?status=draft' },
        { label: 'document.status.in_review'|trans({}, 'document'),     href: _baseDocUrl ~ '?status=in_review' },
        { label: 'document.status.approved'|trans({}, 'document'),      href: _baseDocUrl ~ '?status=approved' },
        { label: 'document.status.published'|trans({}, 'document'),     href: _baseDocUrl ~ '?status=published' },
        { label: 'document.status.archived'|trans({}, 'document'),      href: _baseDocUrl ~ '?status=archived' }
    ],
        _activeDocStatus == 'draft' ? 1
        : (_activeDocStatus == 'in_review' ? 2
        : (_activeDocStatus == 'approved' ? 3
        : (_activeDocStatus == 'published' ? 4
        : (_activeDocStatus == 'archived' ? 5 : 0)))),
        { class: 'mb-3', ariaLabel: 'document.section.all_documents'|trans({}, 'document') }
    ) }}

    {# Document List with Bulk Actions #}
    {% embed '_components/_card.html.twig' %}
        {% block card_attrs %}data-controller="bulk-actions document-filter" data-bulk-actions-endpoint-value="/{{ app.request.locale }}/document"{% endblock %}
        {% block card_header %}
            <div class="card-header d-flex justify-content-between align-items-center">
            <h2 class="mb-0">
                <i class="fa-icon fa-icon--ui-list" aria-hidden="true"></i>
                {{ 'document.section.all_documents'|trans({}, 'document') }}
            </h2>

            {# Filter Controls #}
            <div class="d-flex gap-2">
                <select class="form-select fa-cyber-input__field form-select-sm" id="categoryFilter"
                        data-document-filter-target="categoryFilter"
                        data-action="change->document-filter#filter">
                    <option value="">{{ 'document.filter.all_categories'|trans({}, 'document') }}</option>
                {% set categories = [] %}
                    {% for doc in documents %}
                        {% if doc.category not in categories %}
                            {% set categories = categories|merge([doc.category]) %}
                        {% endif %}
                    {% endfor %}
                    {% for category in categories %}
                        <option value="{{ category }}">{{ category|capitalize }}</option>
                    {% endfor %}
                </select>

                <label for="documentSearch" class="visually-hidden">{{ 'common.search'|trans({}, 'messages') }}</label>
                <input type="search"
                       class="form-control form-control-sm w-250px fa-cyber-input__field"
                       id="documentSearch"
                       placeholder="{{ 'document.filter.search_placeholder'|trans({}, 'document') }}"
                       data-document-filter-target="searchInput"
                       data-action="input->document-filter#filter">
            </div>
            </div>
        {% endblock %}
        {% block card_body %}
            {% if documents|length > 0 %}
            {% embed '_components/_fa_table.html.twig' with {
                'stickyHead': true,
                'hover': true,
                'id': 'documentTable'
            } %}
                {% block table_head %}
                    {% import '_macros/inheritance_badge.html.twig' as inheritance %}
                    {% import '_components/_status_pill.html.twig' as pill %}
                    <tr>
                        <th scope="col" class="fa-table__th fa-table__th--checkbox bulk-select-column">
                            <input type="checkbox"
                                   data-action="bulk-actions#selectAll"
                                   data-bulk-actions-target="selectAllCheckbox"
                                   aria-label="{{ 'bulk_actions.select_all'|trans({}, 'messages') }}">
                        </th>
                        <th scope="col" class="fa-table__th w-50px"><span class="visually-hidden">{{ 'document.table.icon'|trans({}, 'document') }}</span></th>
                        <th scope="col" class="fa-table__th">{{ 'common.name'|trans({}, 'messages') }}</th>
                        <th scope="col" class="fa-table__th w-130px">{{ 'common.status'|trans({}, 'messages') }}</th>
                        <th scope="col" class="fa-table__th w-150px">{{ 'common.category'|trans({}, 'messages') }}</th>
                        <th scope="col" class="fa-table__th w-100px">{{ 'common.size'|trans({}, 'messages') }}</th>
                        <th scope="col" class="fa-table__th w-150px">{{ 'document.table.uploaded_by'|trans({}, 'document') }}</th>
                        <th scope="col" class="fa-table__th w-130px">{{ 'common.date'|trans({}, 'messages') }}</th>
                        <th scope="col" class="fa-table__th w-180px text-right">{{ 'common.actions'|trans({}, 'messages') }}</th>
                    </tr>
                {% endblock %}
                {% block table_body_attrs %}id="documentTableBody" data-document-filter-target="tableBody"{% endblock %}
                {% block table_body %}
                    {% import '_macros/inheritance_badge.html.twig' as inheritance %}
                    {% import '_components/_status_pill.html.twig' as pill %}
                    {% for document in documents %}
                    <tr class="fa-table__row document-row"
                        data-document-filter-target="row"
                        data-category="{{ document.category|lower }}"
                        data-name="{{ document.originalFilename|lower }}">
                        <td class="fa-table__cell fa-table__cell--checkbox bulk-select-column">
                            <input type="checkbox"
                                   data-bulk-actions-target="item"
                                   data-action="bulk-actions#selectItem"
                                   value="{{ document.id }}"
                                   aria-label="{{ 'common.select'|trans({}, 'messages') }} {{ document.originalFilename }}">
                        </td>
                        <td class="fa-table__cell">
                            {# File Type Icon #}
                            {% if document.mimeType == 'application/pdf' %}
                                <i class="fa-icon fa-icon--nav-file-pdf text-danger fs-15" aria-hidden="true"></i>
                            {% elseif document.mimeType starts with 'image/' %}
                                <i class="fa-icon text-primary fs-15 fa-icon--nav-document" aria-hidden="true"></i>
                            {% elseif document.mimeType matches '/spreadsheet/' %}
                                <i class="fa-icon text-success fs-15 fa-icon--nav-file-check" aria-hidden="true"></i>
                            {% elseif document.mimeType matches '/word/' or document.mimeType matches '/document/' %}
                                <i class="fa-icon text-info fs-15 fa-icon--nav-document" aria-hidden="true"></i>
                            {% else %}
                                <i class="fa-icon text-secondary fs-15 fa-icon--nav-document" aria-hidden="true"></i>
                            {% endif %}
                        </td>
                        <td class="fa-table__cell">
                            <a href="{{ path('app_document_show', {id: document.id}) }}" class="text-decoration-none">
                                <strong>{{ document.originalFilename }}</strong>
                            </a>
                            {{ inheritance.small_badge(document, currentTenant) }}
                            {# Policy-Wizard W7-C — settings-drift badge. #}
                            {% if driftMap[document.id] is defined and driftMap[document.id] %}
                                {{ pill.render('policy_wizard.drift_badge.settings_drift.label'|trans({}, 'policy_wizard'), 'warning', {size: 'sm', icon: 'status-warning', class: 'ms-1', title: 'policy_wizard.drift_badge.settings_drift.tooltip'|trans({}, 'policy_wizard')}) }}
                            {% endif %}
                            {% if document.supersedes %}
                                <a href="{{ path('app_policy_wizard_diff', {currentDocId: document.id}) }}"
                                   class="text-decoration-none ms-1"
                                   title="{{ 'policy_wizard.diff.title'|trans({}, 'policy_wizard') }}">
                                    {{ pill.render('policy_wizard.diff.title'|trans({}, 'policy_wizard'), 'primary', {size: 'sm', icon: 'util-arrow-left'}) }}
                                </a>
                            {% endif %}
                            {# Editable-policy-body — "Lokal angepasst"
                               chip for wizard-generated docs that carry
                               post-generation tenant edits. Auditor
                               signal: this body deviates from the
                               wizard baseline. #}
                            {% if document.generatedFromTemplate is not null and document.hasPostGenerationEdits %}
                                {{ pill.render('document.policy_body.drift_badge.label'|trans({}, 'document'), 'neutral', {size: 'sm', icon: 'ui-edit', class: 'ms-1', title: 'document.policy_body.drift_badge.tooltip'|trans({}, 'document')}) }}
                            {% endif %}
                            {# Junior-ISB Wish #5 — Auditor-Score badge.
                               Only rendered for Wizard-generated docs
                               (provenance via generatedFromTemplate). #}
                            {% if document.generatedFromTemplate is not null and auditorScores[document.id] is defined %}
                                {% set _score = auditorScores[document.id] %}
                                {% set _tone = _score.tier == 'green' ? 'success' : (_score.tier == 'yellow' ? 'warning' : 'danger') %}
                                {% set _icon = _score.tier == 'green' ? 'bi-shield-check' : (_score.tier == 'yellow' ? 'bi-shield-exclamation' : 'bi-shield-x') %}
                                {% set _reason_lines = [] %}
                                {% for r in _score.reasons %}
                                    {% set _key = 'policy_wizard.auditor_score.reason.' ~ (r|split(':')|first) %}
                                    {% set _reason_lines = _reason_lines|merge([_key|trans({}, 'policy_wizard')]) %}
                                {% endfor %}
                                {{ pill.render('policy_wizard.auditor_score.label'|trans({}, 'policy_wizard') ~ ': ' ~ _score.score, _tone, {size: 'sm', icon: _icon, class: 'ms-1', title: ('policy_wizard.auditor_score.tier_' ~ _score.tier)|trans({}, 'policy_wizard') ~ ' — ' ~ _reason_lines|join('; ')|default('OK')}) }}
                            {% endif %}
                            {# Effectiveness-Review overdue marker —
                               red "faellig" badge when no review has
                               ever been recorded OR the last review
                               is older than 12 months (standard
                               cadence; per-policy overrides may relax
                               but never lengthen). Auditor signal:
                               policy lacks Wirksamkeitspruefung. #}
                            {% if document.isEffectivenessOverdue(12) %}
                                {{ pill.render('document.effectiveness.badge.overdue.label'|trans({}, 'document'), 'danger', {size: 'sm', icon: 'nav-shield-alert', class: 'ms-1', title: 'document.effectiveness.badge.overdue.tooltip'|trans({}, 'document')}) }}
                            {% endif %}
                            {% if document.description %}
                            <br>
                            <small class="text-muted">{{ document.description|length > 60 ? document.description|slice(0, 60) ~ '...' : document.description }}</small>
                            {% endif %}
                        </td>
                        <td class="fa-table__cell">
                            {# Status pill — direct Aurora tone mapping for document statuses.
                               S3 P-4: legacy 'active' tone removed (rows migrated to 'published'). #}
                            {# Lifecycle-aware tone resolved via LifecycleRegistry. #}
                            {% import '_components/_fa_status_chip.html.twig' as _fa_status_chip %}
                            {{ _fa_status_chip.render({
                                entity_class: 'App\\Entity\\Document',
                                status_key: document.status,
                                label: ('document.status.' ~ document.status)|trans({}, 'document'),
                                size: 'sm'
                            }) }}
                            {# Superseded marker — only visible when history toggle is on #}
                            {% if document.id in supersededIds|keys %}
                                {{ pill.render('document.status.superseded'|trans({}, 'document'), 'warning', {size: 'sm', class: 'ms-1'}) }}
                            {% endif %}
                        </td>
                        <td class="fa-table__cell">
                            {% include '_components/_badge.html.twig' with { variant: 'secondary', content: document.category|capitalize } %}
                        </td>
                        <td class="fa-table__cell">
                            {{ document.fileSizeFormatted }}
                        </td>
                        <td class="fa-table__cell">
                            <div class="d-flex align-items-center">
                                <i class="fa-icon fa-icon--ui-person me-1" aria-hidden="true"></i>
                                {{ document.uploadedBy ? document.uploadedBy.fullName : '-' }}
                            </div>
                        </td>
                        <td class="fa-table__cell">
                            <i class="fa-icon fa-icon--ui-calendar" aria-hidden="true"></i>
                            {{ document.uploadedAt|date('d.m.Y') }}
                            <br>
                            <small class="text-muted">{{ document.uploadedAt|date('H:i') }}</small>
                        </td>
                        <td class="fa-table__cell fa-table__cell--actions text-right">
                            <div class="btn-group btn-group-sm" role="group" aria-label="{{ 'common.actions'|trans({}, 'messages') }}">
                                <a href="{{ path('app_document_download', {id: document.id}) }}"
                                   class="fa-cyber-btn fa-cyber-btn--success fa-cyber-btn--sm"
                                   data-turbo="false"
                                   title="{{ 'common.download'|trans({}, 'messages') }}" aria-label="{{ 'common.download'|trans({}, 'messages') }}">
                                    <i class="fa-icon fa-icon--nav-download" aria-hidden="true"></i>
                                </a>
                                <a href="{{ path('app_document_show', {id: document.id}) }}"
                                   class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
                                   title="{{ 'common.details'|trans({}, 'messages') }}" aria-label="{{ 'common.view'|trans({}, 'messages') }}">
                                    <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
                                </a>
                                <a href="{{ path('app_document_edit', {id: document.id}) }}"
                                   class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
                                   title="{{ 'common.edit'|trans({}, 'messages') }}" aria-label="{{ 'common.edit'|trans({}, 'messages') }}">
                                    <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                {% endblock %}
            {% endembed %}

            {# No Results Message #}
            <div id="noResults" class="text-center p-5 d-none" data-document-filter-target="noResults">
                <i class="fa-icon fa-icon--ui-search icon-search-empty" aria-hidden="true"></i>
                <p class="text-muted mt-3">{{ 'document.message.no_results'|trans({}, 'document') }}</p>
            </div>

            {# Bulk Action Bar #}
            {% include '_components/_bulk_action_bar.html.twig' with {
                actions: ['status_change', 'approve', 'export', 'delete'],
                variant: 'brand'
            } %}
            {% else %}
            {# Empty State #}
            {% set _system_templates = system_templates('App\\Entity\\Document') %}
            {% include '_components/_empty_state.html.twig' with {
                icon: 'nav-file-earmark-text',
                title: 'document.message.no_documents'|trans({}, 'document'),
                description: 'document.message.upload_first'|trans({}, 'document'),
                action: {
                    label: 'document.action.upload'|trans({}, 'document'),
                    url: path('app_document_new'),
                    icon: 'ui-upload'
                }
            } %}
            {# Foundation P-14 — ISO 27001 policy starter set #}
            {% if _system_templates|length > 0 %}
                <div class="text-center mt-3">
                    <button type="button" class="btn btn-outline-primary"
                            data-bs-toggle="modal" data-bs-target="#systemTemplateModalDocument">
                        <i class="fa-icon fa-icon--nav-collection" aria-hidden="true"></i>
                        {{ 'system_templates.cta.button'|trans({}, 'system_templates') }}
                    </button>
                    <div class="form-text small">
                        {{ 'system_templates.cta.hint'|trans({}, 'system_templates') }}
                    </div>
                </div>
                {% include '_components/_system_template_selector.html.twig' with {
                    templates: _system_templates,
                    entity_class: 'App\\Entity\\Document',
                    redirect_to: 'app_document_index',
                    modal_id: 'systemTemplateModalDocument'
                } %}
            {% endif %}
            {% endif %}
        {% endblock %}
    {% endembed %}
    </main>
</div>

