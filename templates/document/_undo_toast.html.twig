{% trans_default_domain 'document' %}
{#
  F4 — 5-second Undo Toast for document version upload.
  Include on document/show.html.twig after a new version is uploaded.
  Variables: version_id (int), document_id (int), csrf_token_value (string)
#}
<div class="fa-toast-stack"
     data-controller="evidence-undo"
     data-evidence-undo-version-id-value="{{ version_id }}"
     data-evidence-undo-window-value="5"
     role="status"
     aria-live="polite">

    <div class="fa-toast fa-toast--warning is-visible" id="undo-toast-{{ version_id }}">
        <div class="fa-toast__body d-flex align-items-center gap-3">
            <i class="fa-icon fa-icon--clock" aria-hidden="true"></i>
            <div class="flex-grow-1">
                <div class="fw-semibold">{{ 'document.undo.title'|trans({}, 'document') }}</div>
                <div class="small text-muted">
                    {{ 'document.undo.body'|trans({}, 'document') }}
                    <span data-evidence-undo-target="countdown">5</span>s
                </div>
            </div>
            <form method="post" action="{{ path('app_document_version_undo', {id: document_id, vid: version_id}) }}"
                  data-evidence-undo-target="form">
                <input type="hidden" name="_token" value="{{ csrf_token_value }}">
                <button type="submit" class="fa-cyber-btn fa-cyber-btn--warning fa-cyber-btn--sm"
                        data-evidence-undo-target="cancelBtn">
                    {{ 'document.undo.action'|trans({}, 'document') }}
                </button>
            </form>
        </div>
    </div>
</div>
