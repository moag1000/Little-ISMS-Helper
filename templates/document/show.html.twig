{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% trans_default_domain 'document' %}

{% block title %}{{ document.originalFilename }}{% endblock %}

{% block body %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.documents'|trans({}, 'nav'), url: path('app_document_index') },
            { label: document.originalFilename }
        ]
    } %}

    {% set _show_actions = [
        { label: 'common.download'|trans({}, 'messages'), variant: 'primary', icon: 'download', href: path('app_document_download', {id: document.id}), attrs: {'data-turbo': 'false'} }
    ] %}
    {% if canEdit is defined and canEdit %}
        {% set _show_actions = _show_actions|merge([{ label: 'common.edit'|trans({}, 'messages'), variant: 'ghost', icon: 'pencil', href: path('app_document_edit', {id: document.id}) }]) %}
    {% endif %}
    {% set _show_actions = _show_actions|merge([{ label: 'common.back_to_list'|trans({}, 'messages'), variant: 'ghost', icon: 'arrow-left', href: path('app_document_index') }]) %}
    {{ _fa_page_header.render({
        badge: (isInherited is defined and isInherited) ? { icon: 'building', label: 'corporate.inherited'|trans({}, 'messages') } : { icon: 'file-earmark-text', label: 'nav.documents'|trans({}, 'nav') },
        title: document.originalFilename,
        actions: _show_actions
    }) }}

    {# Inline disabled-edit + POST-delete kept below header (cannot be expressed via _fa_page_header GET-only actions) #}
    {% if (canEdit is defined and not canEdit) or (is_granted('ROLE_ADMIN') and (canEdit is not defined or canEdit)) %}
        <div class="d-flex justify-content-end gap-2 mb-3">
            {% if canEdit is defined and not canEdit %}
                <button class="fa-cyber-btn fa-cyber-btn--ghost" disabled title="{{ 'corporate.inheritance.cannot_edit_inherited'|trans({}, 'messages') }}">
                    <i class="fa-icon fa-icon--ui-lock" aria-hidden="true"></i> {{ 'common.edit'|trans({}, 'messages') }}
                </button>
            {% endif %}
            {% if is_granted('ROLE_ADMIN') and (canEdit is not defined or canEdit) %}
                <form method="post" action="{{ path('app_document_delete', {id: document.id}) }}" class="d-inline"
                      data-controller="ui-actions"
                      data-action="submit->ui-actions#confirm"
                      data-ui-actions-message-param="{{ 'document.confirm.delete'|trans({}, 'document') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ document.id) }}">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger"><i class="fa-icon fa-icon--ui-trash" aria-hidden="true"></i> {{ 'common.delete'|trans({}, 'messages') }}</button>
                </form>
            {% endif %}
        </div>
    {% endif %}

    {% if isInherited is defined and isInherited %}
        {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', icon: 'status-info', class: 'mb-3' } } %}
            {% block alert_body %}<div class="d-flex align-items-start"> <i class="fa-icon fa-icon--status-info me-2 mt-1" aria-hidden="true"></i> <div> <strong>{{ 'corporate.inheritance.view_only_title'|trans({}, 'messages') }}</strong> <p class="mb-0">{{ 'corporate.inheritance.document_inherited_message'|trans({}, 'messages') }}</p> </div> </div>{% endblock %}
        {% endembed %}
    {% endif %}

    {# Junior-ISB Wish #5 — Auditor-Score detail section. Only for
       Wizard-generated docs; controller injects the auditorScore DTO. #}
    {% if document.generatedFromTemplate is not null and auditorScore is defined and auditorScore is not null %}
        {% set _score = auditorScore %}
        {% set _variant = _score.tier == 'green' ? 'success' : (_score.tier == 'yellow' ? 'warning' : 'danger') %}
        {% set _icon = _score.tier == 'green' ? 'shield-check' : (_score.tier == 'yellow' ? 'shield-exclamation' : 'shield-x') %}
        {% embed '_components/_fa_alert.html.twig' with { props: { variant: _variant, icon: 'bi-' ~ _icon, class: 'mb-3' } } %}
            {% block alert_body %}
                <div class="fa-alert__title">
                    {{ ('policy_wizard.auditor_score.tier_' ~ _score.tier)|trans({}, 'policy_wizard') }}
                    — {{ 'policy_wizard.auditor_score.label'|trans({}, 'policy_wizard') }}: {{ _score.score }} / 100
                </div>
                {% if _score.reasons|length > 0 %}
                    <p class="mb-2 small">{{ 'policy_wizard.auditor_score.reasons_heading'|trans({}, 'policy_wizard') }}</p>
                    <ul class="mb-2 small">
                        {% for r in _score.reasons %}
                            {% set _code = r|split(':')|first %}
                            {% set _detail = r|split(':')|slice(1)|join(':') %}
                            <li>
                                {{ ('policy_wizard.auditor_score.reason.' ~ _code)|trans({}, 'policy_wizard') }}
                                {% if _detail %}<small class="text-muted">({{ _detail }})</small>{% endif %}
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
                {% if _score.tier == 'red' and document.generatedFromTemplate.topic %}
                    <a href="{{ path('app_policy_wizard_index') }}"
                       class="fa-cyber-btn fa-cyber-btn--{{ _variant }} fa-cyber-btn--sm mt-1">
                        <i class="bi bi-arrow-clockwise" aria-hidden="true"></i>
                        {{ 'policy_wizard.auditor_score.regenerate_cta'|trans({}, 'policy_wizard') }}
                    </a>
                {% endif %}
            {% endblock %}
        {% endembed %}
    {% endif %}

    {% embed '_components/_card.html.twig' %}
        {% block card_header %}
            <div class="card-header">
                <h2>{{ 'document.details.title'|trans({}, 'document') }}</h2>
                {% include '_components/_badge.html.twig' with { variant: 'secondary', content: document.category|upper } %}
            </div>
        {% endblock %}
        {% block card_body %}
            <div class="detail-grid">
                <div class="detail-item">
                    <span class="label">{{ 'document.label.type'|trans({}, 'document') }}</span>
                    <span class="value">{{ document.category|upper|replace({'_': ' '}) }}</span>
                </div>
                <div class="detail-item">
                    <span class="label">{{ 'document.label.file_name'|trans({}, 'document') }}</span>
                    <span class="value">{{ document.originalFilename }}</span>
                </div>
                <div class="detail-item">
                    <span class="label">{{ 'document.label.size'|trans({}, 'document') }}</span>
                    <span class="value">{{ document.fileSizeFormatted }}</span>
                </div>
                <div class="detail-item">
                    <span class="label">{{ 'document.label.mime_type'|trans({}, 'document') }}</span>
                    <span class="value">{{ document.mimeType }}</span>
                </div>
                <div class="detail-item">
                    <span class="label">{{ 'document.label.uploaded_by'|trans({}, 'document') }}</span>
                    <span class="value">{{ document.uploadedBy ? document.uploadedBy.fullName : '-' }}</span>
                </div>
                <div class="detail-item">
                    <span class="label">{{ 'document.label.uploaded_at'|trans({}, 'document') }}</span>
                    <span class="value">{{ document.uploadedAt|date('d.m.Y H:i') }}</span>
                </div>
                {% if document.updatedAt %}
                <div class="detail-item">
                    <span class="label">{{ 'document.label.last_updated'|trans({}, 'document') }}</span>
                    <span class="value">{{ document.updatedAt|date('d.m.Y H:i') }}</span>
                </div>
                {% endif %}
            </div>

            {% if document.description %}
                <div class="detail-section">
                    <h3>{{ 'common.description'|trans({}, 'messages') }}</h3>
                    <p>{{ document.description }}</p>
                </div>
            {% endif %}

            {# Wizard-generated docs: render the resolved policy body
               via the same safe-subset Markdown renderer the PDF uses.
               Hidden for legacy uploads (controller passes null). #}
            {% if policyBodyHtml is defined and policyBodyHtml is not null %}
                <div class="detail-section">
                    <h3>
                        <i class="bi bi-file-earmark-richtext" aria-hidden="true"></i>
                        {{ 'document.policy_body.preview.heading'|trans({}, 'document') }}
                        {% if document.hasPostGenerationEdits() %}
                            <span class="badge bg-warning text-dark ms-2"
                                  data-bs-toggle="tooltip"
                                  title="{{ 'document.policy_body.drift_badge.tooltip'|trans({}, 'document') }}">
                                <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                {{ 'document.policy_body.drift_badge.label'|trans({}, 'document') }}
                            </span>
                        {% endif %}
                    </h3>
                    {% if document.hasPostGenerationEdits() %}
                        <p class="small text-muted mb-2">
                            <i class="bi bi-info-circle" aria-hidden="true"></i>
                            {{ 'document.policy_body.edited_by'|trans({
                                '%name%': document.policyBodyEditedBy ? document.policyBodyEditedBy.fullName : '—',
                                '%date%': document.policyBodyEditedAt ? document.policyBodyEditedAt|date('d.m.Y H:i') : '—',
                            }, 'document') }}
                        </p>
                    {% endif %}
                    <div class="policy-body-preview border rounded p-3 bg-body-tertiary">
                        {{ policyBodyHtml|raw }}
                    </div>
                    {% if canEdit is defined and canEdit %}
                        <div class="mt-2">
                            <a href="{{ path('app_document_edit', {id: document.id}) }}#policy-body"
                               class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                <i class="bi bi-pencil" aria-hidden="true"></i>
                                {{ 'document.policy_body.preview.edit_cta'|trans({}, 'document') }}
                            </a>
                        </div>
                    {% endif %}
                </div>
            {% endif %}

            {% if document.entityType and document.entityId %}
                <div class="detail-section">
                    <h3>{{ 'document.label.related_entity'|trans({}, 'document') }}</h3>
                    <p>{{ document.entityType }} #{{ document.entityId }}</p>
                </div>
            {% endif %}

            {% if inverse_coverage is defined %}
                <div class="detail-section">
                    <h3>
                        <i class="fa-icon fa-icon--ui-link" aria-hidden="true"></i>
                        {{ 'inverse_coverage.document.heading'|trans({}, 'control') }}
                    </h3>
                    {% include '_components/_inverse_coverage_widget.html.twig' with {
                        coverage: inverse_coverage,
                        scope_key: 'document'
                    } %}
                </div>
            {% endif %}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
