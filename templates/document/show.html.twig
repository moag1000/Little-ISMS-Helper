{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_policy_doc.html.twig' as _fa_policy_doc %}
{% trans_default_domain 'document' %}
{% import '_components/_status_pill.html.twig' as pill %}

{% block title %}{{ document.originalFilename }}{% endblock %}

{% block body %}
{# Twig {% extends %} requires re-import inside the block where used. #}
{% import '_components/_fa_policy_doc.html.twig' as _fa_policy_doc %}
{% import '_components/_fa_alva_hint.html.twig' as _fa_alva_hint %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.documents'|trans({}, 'nav'), url: path('app_document_index') },
            { label: document.originalFilename }
        ]
    } %}

    {% set hint = alva_hint(document) %}
    {% if hint %}{{ _fa_alva_hint.render(hint) }}{% endif %}

    {% set _show_actions = [
        { label: 'common.download'|trans({}, 'messages'), variant: 'primary', icon: 'download', href: path('app_document_download', {id: document.id}), attrs: {'data-turbo': 'false'} }
    ] %}
    {% if canEdit is defined and canEdit %}
        {% set _show_actions = _show_actions|merge([{ label: 'common.edit'|trans({}, 'messages'), variant: 'ghost', icon: 'ui-edit', href: path('app_document_edit', {id: document.id}) }]) %}
    {% endif %}
    {% set _show_actions = _show_actions|merge([{ label: 'common.back_to_list'|trans({}, 'messages'), variant: 'ghost', icon: 'util-arrow-left', href: path('app_document_index') }]) %}
    {{ _fa_page_header.render({
        badge: (isInherited is defined and isInherited) ? { icon: 'nav-building', label: 'corporate.inherited'|trans({}, 'messages') } : { icon: 'nav-file-earmark-text', label: 'nav.documents'|trans({}, 'nav') },
        title: document.originalFilename,
        actions: _show_actions
    }) }}

    {# Inline disabled-edit + POST-delete kept below header (cannot be expressed via _fa_page_header GET-only actions) #}
    {% if (canEdit is defined and not canEdit) or (is_granted('ROLE_ADMIN') and (canEdit is not defined or canEdit)) %}
        <div class="d-flex justify-content-end gap-2 mb-3">
            {% if canEdit is defined and not canEdit %}
                <button class="fa-cyber-btn fa-cyber-btn--ghost" disabled title="{{ 'corporate.inheritance.cannot_edit_inherited'|trans({}, 'messages') }}">
                    <i class="fa-icon fa-icon--ui-lock" aria-hidden="true"></i> {{ 'common.edit'|trans({}, 'messages') }}
                </button>
            {% endif %}
            {% if is_granted('ROLE_ADMIN') and (canEdit is not defined or canEdit) %}
                <form method="post" action="{{ path('app_document_delete', {id: document.id}) }}" class="d-inline"
                      data-controller="ui-actions"
                      data-action="submit->ui-actions#confirm"
                      data-ui-actions-message-param="{{ 'document.confirm.delete'|trans({}, 'document') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ document.id) }}">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger"><i class="fa-icon fa-icon--ui-trash" aria-hidden="true"></i> {{ 'common.delete'|trans({}, 'messages') }}</button>
                </form>
            {% endif %}
        </div>
    {% endif %}

    {% if isInherited is defined and isInherited %}
        {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', icon: 'status-info', class: 'mb-3' } } %}
            {% block alert_body %}<div class="d-flex align-items-start"> <i class="fa-icon fa-icon--status-info me-2 mt-1" aria-hidden="true"></i> <div> <strong>{{ 'corporate.inheritance.view_only_title'|trans({}, 'messages') }}</strong> <p class="mb-0">{{ 'corporate.inheritance.document_inherited_message'|trans({}, 'messages') }}</p> </div> </div>{% endblock %}
        {% endembed %}
    {% endif %}

    {# Compliance-Manager / Auditor-External Wish — prominent norm-anchor row.
       DORA-Stand (validity-from) + Climate-Change-Amendment marker live as
       EntityTag rows; surface them as header chips so auditors see the
       regulatory-clock + Amd. 1:2024 marker without expanding the tag list. #}
    {% if (doraValidityDate is defined and doraValidityDate is not null) or (climateChangeAware is defined and climateChangeAware) %}
        <div class="d-flex flex-wrap gap-2 mb-3" data-test="document-norm-anchor-chips">
            {% if doraValidityDate is defined and doraValidityDate is not null %}
                <span data-test="document-dora-validity-badge">
                    {{ pill.render('document.dora_validity.badge'|trans({'%date%': doraValidityDate|date('d.m.Y')}, 'document'), 'primary', {icon: 'ui-calendar-event', title: 'document.dora_validity.tooltip'|trans({'%date%': doraValidityDate|date('d.m.Y')}, 'document')}) }}
                </span>
            {% endif %}
            {% if climateChangeAware is defined and climateChangeAware %}
                <span data-test="document-climate-change-badge">
                    {{ pill.render('document.climate_change.badge'|trans({}, 'document'), 'success', {icon: 'ui-globe', title: 'document.climate_change.tooltip'|trans({}, 'document')}) }}
                </span>
            {% endif %}
        </div>

        {% if doraValidityDate is defined and doraValidityDate is not null %}
            {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', icon: 'ui-calendar-event', class: 'mb-3' } } %}
                {% block alert_body %}
                    <div class="fa-alert__title">{{ 'document.dora_validity.heading'|trans({}, 'document') }}</div>
                    <p class="fa-alert__message mb-0 small">{{ 'document.dora_validity.body'|trans({'%date%': doraValidityDate|date('d.m.Y')}, 'document') }}</p>
                {% endblock %}
            {% endembed %}
        {% endif %}
    {% endif %}

    {# F4 — Evidence Reuse Badge + Version History link #}
    {% if document.currentVersion is not null or document.versions is not empty %}
        <div class="d-flex align-items-center gap-3 mb-3 flex-wrap" data-controller="reuse-drawer">
            <a href="{{ path('app_document_versions', {id: document.id}) }}"
               class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
               data-turbo-frame="version-drawer"
               aria-label="{{ 'document.version.history.title'|trans({}, 'document') }}">
                <i class="fa-icon fa-icon--document-history me-1" aria-hidden="true"></i>
                {{ 'document.version.history.title'|trans({}, 'document') }}
                {% if document.versions|length > 0 %}
                    <span class="badge bg-secondary ms-1">{{ document.versions|length }}</span>
                {% endif %}
            </a>
            {% if document.currentVersion is not null %}
                <span class="text-muted small">
                    {{ 'document.version.current_label'|trans({'%n%': document.currentVersion.versionNumber}, 'document') }}
                    · {{ 'document.version.hash_label'|trans({'%hash%': document.currentVersion.contentHash|slice(0, 8) ~ '…'}, 'document') }}
                </span>
            {% endif %}
        </div>
    {% endif %}

    {# Junior-ISB Wish #5 — Auditor-Score detail section. Only for
       Wizard-generated docs; controller injects the auditorScore DTO. #}
    {% if document.generatedFromTemplate is not null and auditorScore is defined and auditorScore is not null %}
        {% set _score = auditorScore %}
        {% set _variant = _score.tier == 'green' ? 'success' : (_score.tier == 'yellow' ? 'warning' : 'danger') %}
        {% set _icon = _score.tier == 'green' ? 'shield-check' : (_score.tier == 'yellow' ? 'nav-shield-alert' : 'nav-shield-alert') %}
        {% embed '_components/_fa_alert.html.twig' with { props: { variant: _variant, icon: _icon, class: 'mb-3' } } %}
            {% block alert_body %}
                <div class="fa-alert__title">
                    {{ ('policy_wizard.auditor_score.tier_' ~ _score.tier)|trans({}, 'policy_wizard') }}
                    — {{ 'policy_wizard.auditor_score.label'|trans({}, 'policy_wizard') }}: {{ _score.score }} / 100
                </div>
                {% if _score.reasons|length > 0 %}
                    <p class="mb-2 small">{{ 'policy_wizard.auditor_score.reasons_heading'|trans({}, 'policy_wizard') }}</p>
                    <ul class="mb-2 small">
                        {% for r in _score.reasons %}
                            {% set _code = r|split(':')|first %}
                            {% set _detail = r|split(':')|slice(1)|join(':') %}
                            <li>
                                {{ ('policy_wizard.auditor_score.reason.' ~ _code)|trans({}, 'policy_wizard') }}
                                {% if _detail %}<small class="text-muted">({{ _detail }})</small>{% endif %}
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
                {% if _score.tier == 'red' and document.generatedFromTemplate.topic %}
                    <a href="{{ path('app_policy_wizard_index') }}"
                       class="fa-cyber-btn fa-cyber-btn--{{ _variant }} fa-cyber-btn--sm mt-1">
                        <i class="fa-icon fa-icon--ui-refresh" aria-hidden="true"></i>
                        {{ 'policy_wizard.auditor_score.regenerate_cta'|trans({}, 'policy_wizard') }}
                    </a>
                {% endif %}
            {% endblock %}
        {% endembed %}
    {% endif %}

    {% embed '_components/_card.html.twig' %}
        {% block card_header %}
            <div class="card-header">
                <h2>{{ 'document.details.title'|trans({}, 'document') }}</h2>
                {% include '_components/_badge.html.twig' with { variant: 'secondary', content: document.category|upper } %}
            </div>
        {% endblock %}
        {% block card_body %}
            {# embed creates a new scope — re-import macros used inside. #}
            {% import '_components/_fa_policy_doc.html.twig' as _fa_policy_doc %}
            {% import '_components/_status_pill.html.twig' as pill %}
            <div class="detail-grid">
                <div class="detail-item">
                    <span class="label">{{ 'document.label.type'|trans({}, 'document') }}</span>
                    <span class="value">{{ document.category|upper|replace({'_': ' '}) }}</span>
                </div>
                <div class="detail-item">
                    <span class="label">{{ 'document.label.file_name'|trans({}, 'document') }}</span>
                    <span class="value">{{ document.originalFilename }}</span>
                </div>
                <div class="detail-item">
                    <span class="label">{{ 'document.label.size'|trans({}, 'document') }}</span>
                    <span class="value">{{ document.fileSizeFormatted }}</span>
                </div>
                <div class="detail-item">
                    <span class="label">{{ 'document.label.mime_type'|trans({}, 'document') }}</span>
                    <span class="value">{{ document.mimeType }}</span>
                </div>
                <div class="detail-item">
                    <span class="label">{{ 'document.label.uploaded_by'|trans({}, 'document') }}</span>
                    <span class="value">{{ document.uploadedBy ? document.uploadedBy.fullName : '-' }}</span>
                </div>
                <div class="detail-item">
                    <span class="label">{{ 'document.label.uploaded_at'|trans({}, 'document') }}</span>
                    <span class="value">{{ document.uploadedAt|date('d.m.Y H:i') }}</span>
                </div>
                {% if document.updatedAt %}
                <div class="detail-item">
                    <span class="label">{{ 'document.label.last_updated'|trans({}, 'document') }}</span>
                    <span class="value">{{ document.updatedAt|date('d.m.Y H:i') }}</span>
                </div>
                {% endif %}
            </div>

            {% if document.description %}
                <div class="detail-section">
                    <h3>{{ 'common.description'|trans({}, 'messages') }}</h3>
                    <p>{{ document.description }}</p>
                </div>
            {% endif %}

            {# Wizard-generated docs: render the resolved policy body
               via the same safe-subset Markdown renderer the PDF uses.
               Hidden for legacy uploads (controller passes null). #}
            {% if policyBodyHtml is defined and policyBodyHtml is not null %}
                <div class="detail-section">
                    <h3>
                        <i class="fa-icon fa-icon--nav-document" aria-hidden="true"></i>
                        {{ 'document.policy_body.preview.heading'|trans({}, 'document') }}
                        {% if document.hasPostGenerationEdits() %}
                            {{ pill.render('document.policy_body.drift_badge.label'|trans({}, 'document'), 'warning', {class: 'ms-2', icon: 'ui-edit', title: 'document.policy_body.drift_badge.tooltip'|trans({}, 'document')}) }}
                        {% endif %}
                    </h3>
                    {% if document.hasPostGenerationEdits() %}
                        <p class="small text-muted mb-2">
                            <i class="fa-icon fa-icon--ui-info" aria-hidden="true"></i>
                            {{ 'document.policy_body.edited_by'|trans({
                                '%name%': document.policyBodyEditedBy ? document.policyBodyEditedBy.fullName : '—',
                                '%date%': document.policyBodyEditedAt ? document.policyBodyEditedAt|date('d.m.Y H:i') : '—',
                            }, 'document') }}
                        </p>
                    {% endif %}
                    {# Design-system policy-doc 5-slot template (Mai 2026).
                       Renders cover/toc/history/body/signature in the show
                       view using the same Aurora macro the PDF export uses
                       — guarantees visual parity between the on-screen
                       preview and the printed audit-pack. #}
                    {{ _fa_policy_doc.render({
                        document: document,
                        body_html: policyBodyHtml,
                        cover: {
                            title:               document.originalFilename,
                            kicker:              document.generatedFromTemplate ? (document.generatedFromTemplate.standard|upper ~ ' · ' ~ document.generatedFromTemplate.topic|replace({'_': ' '})) : 'ISMS-Policy',
                            version:             document.version,
                            valid_from:          document.uploadedAt ? document.uploadedAt|date('d.m.Y') : null,
                            next_review:         document.nextReviewDate ? document.nextReviewDate|date('d.m.Y') : null,
                            owner:               document.effectiveOwnerName,
                            classification:      document.tisaxInformationClassification,
                            standard:            document.generatedFromTemplate ? document.generatedFromTemplate.standard : null,
                            topic:               document.generatedFromTemplate ? document.generatedFromTemplate.topic : null,
                            generated_on:        document.uploadedAt ? document.uploadedAt|date('d.m.Y') : null,
                            dora_validity_date:  doraValidityDate ? doraValidityDate|date('d.m.Y') : null,
                            climate_change_aware: climateChangeAware|default(false),
                            owner_label:         'policy_wizard.export.cover.owner'|trans({}, 'policy_wizard'),
                            version_label:       'policy_wizard.export.cover.version'|trans({}, 'policy_wizard'),
                            valid_from_label:    'policy_wizard.export.cover.valid_from'|trans({}, 'policy_wizard'),
                            next_review_label:   'policy_wizard.export.cover.next_review'|trans({}, 'policy_wizard'),
                            classification_label:'policy_wizard.export.cover.classification'|trans({}, 'policy_wizard'),
                            standard_label:      'policy_wizard.export.cover.standard'|trans({}, 'policy_wizard'),
                            generated_on_label:  'policy_wizard.export.cover.generated_on'|trans({}, 'policy_wizard'),
                            dora_validity_label: 'policy_wizard.export.cover.dora_validity'|trans({}, 'policy_wizard'),
                            climate_change_label:'policy_wizard.export.cover.climate_change'|trans({}, 'policy_wizard'),
                            climate_change_value:'policy_wizard.export.cover.climate_change_value'|trans({}, 'policy_wizard'),
                            history_label:       'policy_wizard.export.history.heading'|trans({}, 'policy_wizard'),
                            history_col_version: 'policy_wizard.export.history.col_version'|trans({}, 'policy_wizard'),
                            history_col_date:    'policy_wizard.export.history.col_date'|trans({}, 'policy_wizard'),
                            history_col_change:  'policy_wizard.export.history.col_change'|trans({}, 'policy_wizard'),
                            history_col_author:  'policy_wizard.export.history.col_author'|trans({}, 'policy_wizard'),
                            history_col_approver:'policy_wizard.export.history.col_approver'|trans({}, 'policy_wizard'),
                            toc_label:           'policy_wizard.export.toc.heading'|trans({}, 'policy_wizard'),
                            signature_intro_label:'policy_wizard.export.signature.intro_label'|trans({}, 'policy_wizard'),
                            signature_intro:     'policy_wizard.export.signature.intro'|trans({}, 'policy_wizard'),
                        },
                        tenant_branding: tenant_branding|default(null),
                        brand_name: currentTenant ? currentTenant.legalName|default(currentTenant.name)|default('') : '',
                        brand_meta: 'policy_wizard.export.cover.brand_meta'|trans({}, 'policy_wizard'),
                    }) }}
                    {% if canEdit is defined and canEdit %}
                        <div class="mt-2">
                            <a href="{{ path('app_document_edit', {id: document.id}) }}#policy-body"
                               class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                                {{ 'document.policy_body.preview.edit_cta'|trans({}, 'document') }}
                            </a>
                        </div>
                    {% endif %}
                </div>
            {% endif %}

            {% if document.entityType and document.entityId %}
                <div class="detail-section">
                    <h3>{{ 'document.label.related_entity'|trans({}, 'document') }}</h3>
                    <p>{{ document.entityType }} #{{ document.entityId }}</p>
                </div>
            {% endif %}

            {# Effectiveness Review (Auditor MINOR-NC reply, 2026-05-10).
               Surfaces the most recent ISB / Auditor effectiveness
               review evidence + an action button that opens a modal
               with a notes textarea. Visible to all readers; the
               action button is gated to ROLE_AUDITOR (server-side
               enforcement still wins). #}
            <div class="detail-section">
                <h3>
                    <i class="fa-icon fa-icon--compliance-shield" aria-hidden="true"></i>
                    {{ 'document.effectiveness.section_title'|trans({}, 'document') }}
                </h3>
                {% if document.lastEffectivenessReviewAt %}
                    <dl class="row mb-2 small">
                        <dt class="col-sm-4">{{ 'document.effectiveness.last_reviewed_at'|trans({}, 'document') }}</dt>
                        <dd class="col-sm-8">{{ document.lastEffectivenessReviewAt|date('d.m.Y H:i') }}</dd>
                        <dt class="col-sm-4">{{ 'document.effectiveness.last_reviewed_by'|trans({}, 'document') }}</dt>
                        <dd class="col-sm-8">{{ document.lastEffectivenessReviewBy ? document.lastEffectivenessReviewBy.fullName : '—' }}</dd>
                        {% if document.effectivenessReviewNotes %}
                            <dt class="col-sm-4">{{ 'document.effectiveness.notes'|trans({}, 'document') }}</dt>
                            <dd class="col-sm-8"><pre class="small mb-0" style="white-space:pre-wrap">{{ document.effectivenessReviewNotes }}</pre></dd>
                        {% endif %}
                    </dl>
                {% else %}
                    <p class="small text-muted mb-2">
                        <i class="fa-icon fa-icon--ui-info" aria-hidden="true"></i>
                        {{ 'document.effectiveness.never_reviewed'|trans({}, 'document') }}
                    </p>
                {% endif %}
                {% if is_granted('ROLE_AUDITOR') and (canEdit is not defined or canEdit) %}
                    <button type="button"
                            class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
                            data-bs-toggle="modal"
                            data-bs-target="#effectivenessReviewModal">
                        <i class="fa-icon fa-icon--nav-clipboard-check" aria-hidden="true"></i>
                        {{ 'document.effectiveness.action.record'|trans({}, 'document') }}
                    </button>
                    <p class="small text-muted mt-2 mb-0">
                        <i class="fa-icon fa-icon--ui-info" aria-hidden="true"></i>
                        {{ 'document.effectiveness.no_soa_bump_hint'|trans({}, 'document') }}
                    </p>
                {% endif %}
            </div>

            {% if inverse_coverage is defined %}
                <div class="detail-section">
                    <h3>
                        <i class="fa-icon fa-icon--ui-link" aria-hidden="true"></i>
                        {{ 'inverse_coverage.document.heading'|trans({}, 'control') }}
                    </h3>
                    {% include '_components/_inverse_coverage_widget.html.twig' with {
                        coverage: inverse_coverage,
                        scope_key: 'document'
                    } %}
                </div>
            {% endif %}

            {# Phase 1+2 — Linked ISO 27001 Controls (DocumentControlLink rows) #}
            {% if controlLinks is defined and controlLinks|length > 0 %}
                <div class="detail-section" data-test="document-control-links">
                    <h3>
                        <i class="fa-icon fa-icon--nav-clipboard-check" aria-hidden="true"></i>
                        {{ 'document.evidence.controls.heading'|trans({}, 'document') }}
                    </h3>
                    {# Group by source for visual separation #}
                    {% set linksBySource = {} %}
                    {% for link in controlLinks %}
                        {% set src = link.source %}
                        {% if linksBySource[src] is not defined %}
                            {% set linksBySource = linksBySource|merge({(src): []}) %}
                        {% endif %}
                        {% set linksBySource = linksBySource|merge({(src): linksBySource[src]|merge([link])}) %}
                    {% endfor %}
                    {% for source, links in linksBySource %}
                        <p class="small text-muted mb-1">
                            <strong>{{ ('document.evidence.source.' ~ source)|trans({}, 'document') }}</strong>
                        </p>
                        <ul class="list-unstyled mb-2">
                            {% for link in links %}
                                {% set ctrl = link.control %}
                                <li class="d-flex align-items-center gap-2 mb-1">
                                    <span class="badge bg-secondary font-monospace">{{ ctrl.controlId }}</span>
                                    <span>{{ ctrl.name }}</span>
                                    <span class="badge bg-light text-dark small">{{ ('document.evidence.type.' ~ link.evidenceType)|trans({}, 'document') }}</span>
                                    <span class="badge rounded-pill" style="background:var(--state-info-bg,#e0f0ff);color:var(--state-info-fg,#0050a0)">
                                        {{ ctrl.implementationStatus|replace({'_': ' '})|title }}
                                    </span>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endfor %}
                </div>
            {% endif %}

            {# Phase 1+2 — Linked Requirements (other frameworks) #}
            {% if requirementsByFramework is defined and requirementsByFramework|length > 0 %}
                <div class="detail-section" data-test="document-requirement-links">
                    <h3>
                        <i class="fa-icon fa-icon--ui-link" aria-hidden="true"></i>
                        {{ 'document.evidence.requirements.heading'|trans({}, 'document') }}
                    </h3>
                    {% for fwCode, fwGroup in requirementsByFramework %}
                        <p class="small text-muted mb-1">
                            <strong>{{ fwGroup.framework.name }}</strong>
                            <span class="badge bg-secondary ms-1">{{ fwCode }}</span>
                        </p>
                        <ul class="list-unstyled mb-2">
                            {% for req in fwGroup.requirements %}
                                <li class="d-flex align-items-center gap-2 mb-1">
                                    <span class="badge bg-secondary font-monospace">{{ req.requirementId }}</span>
                                    <span>{{ req.title }}</span>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endfor %}
                </div>
            {% endif %}
        {% endblock %}
    {% endembed %}

    {# V3 W2-H3: Comment-Thread adoption (C7 macro). #}
    {% include '_components/_isms_comment_thread.html.twig' with {
        comments: comments|default([]),
        entityType: 'Document',
        entityId: document.id,
        showForm: canEdit is not defined or canEdit,
        formAction: path('app_comment_post', {entityType: 'Document', entityId: document.id}),
        csrfToken: csrf_token('isms-comment')
    } only %}

    {% if is_granted('ROLE_AUDITOR') and (canEdit is not defined or canEdit) %}
        {# Effectiveness-Review Modal — Bootstrap modal (lazy-loaded
           via the existing modal-pattern documented in CLAUDE.md). #}
        <div  class="modal fade"  id="effectivenessReviewModal" tabindex="-1"
             aria-labelledby="effectivenessReviewModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <form method="post" action="{{ path('app_document_mark_effectiveness_reviewed', {id: document.id}) }}"
                      class="modal-content"
                      data-turbo="false">
                    <input type="hidden" name="_token" value="{{ csrf_token('document_effectiveness_review_' ~ document.id) }}">
                    <div class="modal-header">
                        <h5 class="modal-title" id="effectivenessReviewModalLabel">
                            <i class="fa-icon fa-icon--compliance-shield" aria-hidden="true"></i>
                            {{ 'document.effectiveness.modal.title'|trans({}, 'document') }}
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"
                                aria-label="{{ 'common.close'|trans({}, 'messages') }}"></button>
                    </div>
                    <div class="modal-body">
                        <p class="small text-muted">{{ 'document.effectiveness.modal.intro'|trans({}, 'document') }}</p>
                        <div class="mb-3">
                            <label for="effectivenessReviewNotes" class="form-label">
                                {{ 'document.effectiveness.modal.notes_label'|trans({}, 'document') }}
                            </label>
                            <div class="fa-cyber-input">
                                <div class="fa-cyber-input__frame">
                                    <textarea class="fa-cyber-input__field" id="effectivenessReviewNotes" name="notes" rows="4"
                                              placeholder="{{ 'document.effectiveness.modal.notes_placeholder'|trans({}, 'document') }}"></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="effectivenessReviewConfirmed" name="confirmed" value="1">
                            <label class="form-check-label small" for="effectivenessReviewConfirmed">
                                {{ 'document.effectiveness.modal.confirm_label'|trans({}, 'document') }}
                            </label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost" data-bs-dismiss="modal">
                            {{ 'common.cancel'|trans({}, 'messages') }}
                        </button>
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                            <i class="fa-icon fa-icon--nav-clipboard-check" aria-hidden="true"></i>
                            {{ 'document.effectiveness.modal.submit'|trans({}, 'document') }}
                        </button>
                    </div>
                </form>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
