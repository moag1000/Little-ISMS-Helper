{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% trans_default_domain 'document' %}

{% block title %}{{ 'document.edit'|trans({}, 'document') }} - {{ parent() }}{% endblock %}

{% block body %}
{# Breadcrumb Navigation #}
{% include '_components/_breadcrumb.html.twig' with {
    breadcrumbs: [
        { label: 'nav.documents'|trans({}, 'nav'), url: path('app_document_index'), icon: 'bi-file-earmark-text' },
        { label: document.originalFilename, url: path('app_document_show', {id: document.id}) },
        { label: 'document.edit'|trans({}, 'document') }
    ]
} %}

{# Page Header #}
{% include '_components/_page_header.html.twig' with {
    title: 'document.edit'|trans({}, 'document') ~ ': ' ~ document.originalFilename,
    icon: 'bi-pencil',
    actions: [
        { label: 'common.back'|trans({}, 'messages'), url: path('app_document_show', {id: document.id}), variant: 'secondary', icon: 'bi-arrow-left' }
    ]
} %}

{% embed '_components/_card.html.twig' %}
    {% block card_body %}
        {% import '_components/_fa_alert.html.twig' as _fa_alert %}
        {{ _fa_alert.render({ variant: 'info', body: 'document.help.edit_file'|trans({}, 'document') }) }}

        {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}
            {% include '_components/_auto_form.html.twig' with {
                'form': form,
                'sections': {
                    'basic_info': {
                        'label': 'document.section.basic_info'|trans({}, 'document'),
                        'fields': ['originalFilename', 'description', 'category', 'tisaxInformationClassification']
                    },
                    'file_upload': {
                        'label': 'document.section.file_upload'|trans({}, 'document'),
                        'fields': ['file']
                    }
                },
                'col_widths': {
                    'originalFilename': 12,
                    'description': 12,
                    'category': 6,
                    'tisaxInformationClassification': 6,
                    'file': 12
                },
                'tooltips': {
                    'category': 'document.tooltip.category',
                    'tisaxInformationClassification': 'document.tooltip.classification'
                }
            } %}

            <div class="form-actions d-flex gap-2 justify-content-end">
                <a href="{{ path('app_document_show', {id: document.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                    <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i>
                    {{ 'common.cancel'|trans({}, 'messages') }}
                </a>
                <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                    <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
                    {{ 'document.action.update'|trans({}, 'document') }}
                </button>
            </div>
        {{ form_end(form) }}
    {% endblock %}
{% endembed %}

{# Delete Danger Zone #}
{% embed '_components/_card.html.twig' with {borderColor: 'danger', class: 'mt-4'} %}
    {% block card_header %}
        <div class="card-header bg-danger text-white">
            <h2 class="mb-0">
                <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i>
                {{ 'common.danger_zone'|trans({}, 'messages') }}
            </h2>
        </div>
    {% endblock %}
    {% block card_body %}
        <p class="text-muted">
            {{ 'document.delete_warning'|trans({}, 'document') }}
        </p>
        {{ include('document/_delete_form.html.twig') }}
    {% endblock %}
{% endembed %}
{% endblock %}
