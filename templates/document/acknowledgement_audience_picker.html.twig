{% extends 'base.html.twig' %}
{% trans_default_domain 'alva' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'document.acknowledgement_audience.picker_title'|trans({}, 'alva') }}{% endblock %}

{% block body %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.documents'|trans({}, 'nav'), url: path('app_document_index') },
            { label: document.title, url: path('app_document_show', {id: document.id}) },
            { label: 'document.acknowledgement_audience.picker_breadcrumb'|trans({}, 'alva') }
        ]
    } %}

    {{ _fa_page_header.render({
        title: 'document.acknowledgement_audience.picker_title'|trans({}, 'alva'),
        subtitle: 'document.acknowledgement_audience.picker_subtitle'|trans({}, 'alva'),
        actions: [
            { label: 'action.back_to_list'|trans({}, 'messages'), variant: 'ghost', href: path('app_document_show', {id: document.id}) }
        ]
    }) }}

    <form method="post" action="{{ path('app_document_acknowledgement_audience_picker', {id: document.id}) }}">
        <input type="hidden" name="_token" value="{{ csrf_token('ack_audience_' ~ document.id) }}">
        <section class="fa-section">
            <header class="fa-section__header">
                <h2 class="fa-section__title">{{ 'document.acknowledgement_audience.picker_section_title'|trans({}, 'alva') }}</h2>
            </header>
            <div class="fa-section__body">
                {% if candidates is empty %}
                    <p class="text-muted">{{ 'document.acknowledgement_audience.no_candidates'|trans({}, 'alva') }}</p>
                {% else %}
                    <div class="mb-2">
                        <input type="text" id="ack-audience-filter" class="form-control form-control-sm"
                               placeholder="{{ 'document.acknowledgement_audience.filter_placeholder'|trans({}, 'alva') }}">
                    </div>
                    <div class="d-flex flex-column gap-2" id="ack-audience-list">
                    {% for u in candidates %}
                        <label class="d-flex align-items-start gap-2 ack-audience-row"
                               data-haystack="{{ (u.email ~ ' ' ~ (u.fullName ?? ''))|lower }}">
                            <input type="checkbox" name="user_ids[]" value="{{ u.id }}"
                                   {% if already_selected is defined and u in already_selected %}checked{% endif %}>
                            <span>
                                <strong>{{ u.email }}</strong>
                                {% if u.fullName is defined and u.fullName %}
                                    <span class="text-muted ms-2">{{ u.fullName }}</span>
                                {% endif %}
                            </span>
                        </label>
                    {% endfor %}
                    </div>
                    <div class="mt-3">
                        <button class="fa-cyber-btn fa-cyber-btn--primary" type="submit">
                            {{ 'document.acknowledgement_audience.save'|trans({}, 'alva') }}
                        </button>
                        <span class="text-muted ms-3 small">
                            {{ 'document.acknowledgement_audience.empty_means_all'|trans({}, 'alva') }}
                        </span>
                    </div>
                {% endif %}
            </div>
        </section>
    </form>
</div>

<script>
(() => {
    const input = document.getElementById('ack-audience-filter');
    if (!input) return;
    input.addEventListener('input', () => {
        const needle = input.value.trim().toLowerCase();
        document.querySelectorAll('.ack-audience-row').forEach(row => {
            const hay = row.getAttribute('data-haystack') || '';
            row.style.display = (needle === '' || hay.includes(needle)) ? '' : 'none';
        });
    });
})();
</script>
{% endblock %}
