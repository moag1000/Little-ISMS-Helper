{% extends 'base.html.twig' %}
{% trans_default_domain 'incident' %}
{% import '_macros/workflow.html.twig' as workflow_macros %}

{% block title %}{{ incident.title }}{% endblock %}

{% block body %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.incidents'|trans({}, 'nav'), url: path('app_incident_index') },
            { label: incident.title }
        ]
    } %}

    <div class="page-header">
        <h1>{{ incident.title }}</h1>
        <div class="actions">
            <a href="{{ path('app_incident_edit', {id: incident.id}) }}" class="btn btn-primary"><i class="bi bi-pencil" aria-hidden="true"></i> {{ 'incident.action.edit'|trans({}, 'incident') }}</a>
            {% if is_nis2_active() and incident.requiresNis2Reporting %}
                <a href="{{ path('app_incident_nis2_report', {id: incident.id}) }}" class="btn btn-success" data-turbo="false" title="{{ 'incident.action.download_nis2_report'|trans({}, 'incident') }}">
                    <i class="bi bi-file-earmark-pdf" aria-hidden="true"></i> {{ 'incident.action.download_nis2_report'|trans({}, 'incident') }}
                </a>
            {% endif %}
            <a href="{{ path('app_incident_index') }}" class="btn btn-secondary">{{ 'incident.action.back_to_list'|trans({}, 'incident') }}</a>
            {% if is_granted('ROLE_ADMIN') %}
                <form method="post" action="{{ path('app_incident_delete', {id: incident.id}) }}" style="display:inline;"
                      data-controller="ui-actions"
                      data-action="submit->ui-actions#confirm"
                      data-ui-actions-message-param="{{ 'incident.confirm.delete'|trans({}, 'incident') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ incident.id) }}">
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash" aria-hidden="true"></i> {{ 'incident.action.delete'|trans({}, 'incident') }}</button>
                </form>
            {% endif %}
        </div>
    </div>

    {# Workflow Status Section #}
    {% if workflowStatus.has_active_workflow %}
        {% set escalationLevel = workflowStatus.escalation_level %}
        {% set isDataBreach = escalationLevel == 'data_breach' %}

        {# Determine alert level based on escalation #}
        {% set alertClass = {
            'low': 'info',
            'medium': 'warning',
            'high': 'warning',
            'critical': 'danger',
            'data_breach': 'danger'
        }[escalationLevel] ?? 'info' %}

        <div class="alert alert-{{ alertClass }} workflow-status-alert" role="alert">
            <div class="workflow-status-header">
                <div class="workflow-status-title">
                    <i class="bi bi-{{ isDataBreach ? 'exclamation-triangle-fill' : 'gear-fill' }}" aria-hidden="true"></i>
                    <strong>
                        {% if isDataBreach %}
                            {{ 'incident.workflow.data_breach_active'|trans({}, 'incident') }}
                        {% else %}
                            {{ 'incident.workflow.active'|trans({}, 'incident') }}
                        {% endif %}
                    </strong>
                </div>
                {% include '_components/_badge.html.twig' with { variant: alertClass, content: ('incident.workflow.escalation.' ~ escalationLevel)|trans({}, 'incident') } %}
            </div>

            <div class="workflow-status-content">
                <div class="workflow-info-grid">
                    <div class="workflow-info-item">
                        <span class="label">{{ 'workflow.field.status'|trans({}, 'workflows') }}:</span>
                        <span class="value">{{ workflowStatus.workflow_status|upper }}</span>
                    </div>
                    <div class="workflow-info-item">
                        <span class="label">{{ 'workflow.field.current_step'|trans({}, 'workflows') }}:</span>
                        <span class="value">{{ workflowStatus.current_step ?? 'N/A' }}</span>
                    </div>
                    {% if workflowStatus.due_date %}
                        <div class="workflow-info-item">
                            <span class="label">{{ 'workflow.field.due_date'|trans({}, 'workflows') }}:</span>
                            <div class="mt-2">
                                {{ workflow_macros.sla_timeline(workflowStatus.due_date, null, null, null, false) }}
                            </div>
                        </div>
                    {% endif %}
                </div>

                {% if isDataBreach and workflowStatus.due_date %}
                    <div class="gdpr-deadline-warning">
                        <i class="bi bi-clock-history" aria-hidden="true"></i>
                        <strong>{{ 'incident.workflow.gdpr_72h_deadline'|trans({}, 'incident') }}</strong>
                        {% set hoursRemaining = ((workflowStatus.due_date.timestamp - "now"|date('U')) / 3600)|round(1) %}
                        {% if workflowStatus.is_overdue %}
                            <span class="text-danger">{{ 'workflow.badge.overdue'|trans({}, 'workflows') }}!</span>
                        {% else %}
                            <span>{{ hoursRemaining }} {{ 'incident.timeline.hours_remaining'|trans({}, 'incident') }}</span>
                        {% endif %}
                    </div>
                {% endif %}

                {# Replaced with inline workflow actions macro #}
                {{ workflow_macros.inline_actions(workflowStatus.workflow_instance, incident, canApproveWorkflow ?? false, false) }}
            </div>
        </div>
    {% endif %}

    {# Data-Reuse: Entity Link Matrix (Junior-Finding #8 / CM-Blocker) #}
    {% include '_components/_entity_link_matrix.html.twig' with {
        source_type: 'incident',
        entity: incident,
        linked_risks: linkedRisks|default([]),
        linked_vulnerabilities: linkedVulnerabilities|default([])
    } only %}

    {% embed '_components/_card.html.twig' %}
        {% block card_header %}
            <div class="card-header">
                <h2 class="h5">Incident #{{ incident.incidentNumber }}</h2>
                <div class="badges">
                    <span class="{{ badge_severity(incident.severity) }}">{{ incident.severity|upper }}</span>
                    <span class="{{ badge_status(incident.status) }}">{{ incident.status|upper|replace({'_': ' '}) }}</span>
                    {% if is_nis2_active() and incident.requiresNis2Reporting %}
                        {% set nis2Status = incident.nis2ComplianceStatus %}
                        <span class="{{ badge_nis2(nis2Status) }}">
                            <i class="bi bi-shield-check" aria-hidden="true"></i>
                            {{ ('incident.nis2_compliance.' ~ nis2Status)|trans({}, 'incident') }}
                        </span>
                    {% endif %}
                </div>
            </div>
        {% endblock %}
        {% block card_body %}
            {# Phase 8H.1: standardised via _detail_group component #}
            {% set incidentItems = [
                { label: 'incident.field.category'|trans({}, 'incident'), value: incident.category|upper|replace({'_': ' '}) },
                { label: 'incident.field.detected'|trans({}, 'incident'), value: incident.detectedAt ? incident.detectedAt|date('d.m.Y H:i') : 'N/A' },
                { label: 'incident.field.reported_by'|trans({}, 'incident'), value: incident.reportedBy ?? 'N/A' }
            ] %}
            {% if incident.occurredAt %}
                {% set incidentItems = incidentItems|merge([{ label: 'incident.field.occurred'|trans({}, 'incident'), value: incident.occurredAt|date('d.m.Y H:i') }]) %}
            {% endif %}
            {% include '_components/_detail_group.html.twig' with { items: incidentItems } only %}

            {# NIS2 Article 23 Reporting Timeline #}
            {% if is_nis2_active() and incident.requiresNis2Reporting and incident.detectedAt %}
                <div class="detail-section nis2-timeline-section">
                    <h3 class="h5">
                        <i class="bi bi-clock-history" aria-hidden="true"></i>
                        {{ 'incident.nis2_timeline.title'|trans({}, 'incident') }}
                    </h3>
                    <p class="text-muted">{{ 'incident.nis2_timeline.description'|trans({}, 'incident') }}</p>

                    <div class="timeline-container">
                        {# Stage 1: Early Warning (24h) #}
                        <div class="timeline-stage {% if incident.earlyWarningReportedAt %}completed{% elseif incident.isEarlyWarningOverdue %}overdue{% else %}pending{% endif %}">
                            <div class="timeline-icon">
                                {% if incident.earlyWarningReportedAt %}
                                    <i class="bi bi-check-circle-fill text-success" aria-hidden="true"></i>
                                {% elseif incident.isEarlyWarningOverdue %}
                                    <i class="bi bi-exclamation-triangle-fill text-danger" aria-hidden="true"></i>
                                {% else %}
                                    <i class="bi bi-clock-fill text-warning" aria-hidden="true"></i>
                                {% endif %}
                            </div>
                            <div class="timeline-content">
                                <div class="fw-bold fs-6">{{ 'incident.timeline.early_warning'|trans({}, 'incident') }}</div>
                                <p class="timeline-deadline">
                                    <strong>{{ 'incident.timeline.deadline'|trans({}, 'incident') }}:</strong>
                                    {{ incident.earlyWarningDeadline|date('d.m.Y H:i') }}
                                </p>
                                {% if incident.earlyWarningReportedAt %}
                                    <div class="timeline-completed">
                                        <i class="bi bi-check-circle" aria-hidden="true"></i>
                                        {{ 'incident.timeline.reported_at'|trans({}, 'incident') }}:
                                        <strong>{{ incident.earlyWarningReportedAt|date('d.m.Y H:i') }}</strong>
                                    </div>
                                {% elseif incident.isEarlyWarningOverdue %}
                                    <div class="timeline-overdue">
                                        <i class="bi bi-exclamation-triangle" aria-hidden="true"></i>
                                        {{ 'incident.timeline.overdue'|trans({}, 'incident') }}
                                    </div>
                                {% else %}
                                    <div class="timeline-countdown">
                                        {% set hoursRemaining = incident.hoursUntilEarlyWarningDeadline %}
                                        <i class="bi bi-hourglass-split" aria-hidden="true"></i>
                                        {{ 'incident.timeline.hours_remaining'|trans({'%hours%': hoursRemaining}, 'incident') }}
                                    </div>
                                {% endif %}
                            </div>
                        </div>

                        {# Stage 2: Detailed Notification (72h) #}
                        <div class="timeline-stage {% if incident.detailedNotificationReportedAt %}completed{% elseif incident.isDetailedNotificationOverdue %}overdue{% else %}pending{% endif %}">
                            <div class="timeline-icon">
                                {% if incident.detailedNotificationReportedAt %}
                                    <i class="bi bi-check-circle-fill text-success" aria-hidden="true"></i>
                                {% elseif incident.isDetailedNotificationOverdue %}
                                    <i class="bi bi-exclamation-triangle-fill text-danger" aria-hidden="true"></i>
                                {% else %}
                                    <i class="bi bi-clock-fill text-secondary" aria-hidden="true"></i>
                                {% endif %}
                            </div>
                            <div class="timeline-content">
                                <div class="fw-bold fs-6">{{ 'incident.timeline.detailed_notification'|trans({}, 'incident') }}</div>
                                <p class="timeline-deadline">
                                    <strong>{{ 'incident.timeline.deadline'|trans({}, 'incident') }}:</strong>
                                    {{ incident.detailedNotificationDeadline|date('d.m.Y H:i') }}
                                </p>
                                {% if incident.detailedNotificationReportedAt %}
                                    <div class="timeline-completed">
                                        <i class="bi bi-check-circle" aria-hidden="true"></i>
                                        {{ 'incident.timeline.reported_at'|trans({}, 'incident') }}:
                                        <strong>{{ incident.detailedNotificationReportedAt|date('d.m.Y H:i') }}</strong>
                                    </div>
                                {% elseif incident.isDetailedNotificationOverdue %}
                                    <div class="timeline-overdue">
                                        <i class="bi bi-exclamation-triangle" aria-hidden="true"></i>
                                        {{ 'incident.timeline.overdue'|trans({}, 'incident') }}
                                    </div>
                                {% else %}
                                    <div class="timeline-countdown">
                                        {% set hoursRemaining = incident.hoursUntilDetailedNotificationDeadline %}
                                        <i class="bi bi-hourglass-split" aria-hidden="true"></i>
                                        {{ 'incident.timeline.hours_remaining'|trans({'%hours%': hoursRemaining}, 'incident') }}
                                    </div>
                                {% endif %}
                            </div>
                        </div>

                        {# Stage 3: Final Report (1 month) #}
                        <div class="timeline-stage {% if incident.finalReportSubmittedAt %}completed{% elseif incident.isFinalReportOverdue %}overdue{% else %}pending{% endif %}">
                            <div class="timeline-icon">
                                {% if incident.finalReportSubmittedAt %}
                                    <i class="bi bi-check-circle-fill text-success" aria-hidden="true"></i>
                                {% elseif incident.isFinalReportOverdue %}
                                    <i class="bi bi-exclamation-triangle-fill text-danger" aria-hidden="true"></i>
                                {% else %}
                                    <i class="bi bi-clock-fill text-secondary" aria-hidden="true"></i>
                                {% endif %}
                            </div>
                            <div class="timeline-content">
                                <div class="fw-bold fs-6">{{ 'incident.timeline.final_report'|trans({}, 'incident') }}</div>
                                <p class="timeline-deadline">
                                    <strong>{{ 'incident.timeline.deadline'|trans({}, 'incident') }}:</strong>
                                    {{ incident.finalReportDeadline|date('d.m.Y H:i') }}
                                </p>
                                {% if incident.finalReportSubmittedAt %}
                                    <div class="timeline-completed">
                                        <i class="bi bi-check-circle" aria-hidden="true"></i>
                                        {{ 'incident.timeline.reported_at'|trans({}, 'incident') }}:
                                        <strong>{{ incident.finalReportSubmittedAt|date('d.m.Y H:i') }}</strong>
                                    </div>
                                {% elseif incident.isFinalReportOverdue %}
                                    <div class="timeline-overdue">
                                        <i class="bi bi-exclamation-triangle" aria-hidden="true"></i>
                                        {{ 'incident.timeline.overdue'|trans({}, 'incident') }}
                                    </div>
                                {% else %}
                                    <div class="timeline-countdown">
                                        {% set daysRemaining = incident.daysUntilFinalReportDeadline %}
                                        <i class="bi bi-hourglass-split" aria-hidden="true"></i>
                                        {{ 'incident.timeline.days_remaining'|trans({'%days%': daysRemaining}, 'incident') }}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    {# NIS2 Impact Assessment #}
                    <div class="nis2-impact-grid">
                        {% if incident.nis2Category %}
                            <div class="impact-item">
                                <span class="label">{{ 'incident.field.nis2_category'|trans({}, 'incident') }}:</span>
                                <span class="value">{{ ('incident.nis2_category.' ~ incident.nis2Category)|trans({}, 'incident') }}</span>
                            </div>
                        {% endif %}
                        <div class="impact-item">
                            <span class="label">{{ 'incident.field.cross_border_impact'|trans({}, 'incident') }}:</span>
                            <span class="value">
                                {% if incident.isCrossBorderImpact %}
                                    {% include '_components/_badge.html.twig' with { variant: 'danger', content: 'common.yes'|trans({}, 'messages') } %}
                                {% else %}
                                    {% include '_components/_badge.html.twig' with { variant: 'secondary', content: 'common.no'|trans({}, 'messages') } %}
                                {% endif %}
                            </span>
                        </div>
                        {% if incident.affectedUsersCount %}
                            <div class="impact-item">
                                <span class="label">{{ 'incident.field.affected_users_count'|trans({}, 'incident') }}:</span>
                                <span class="value"><strong>{{ incident.affectedUsersCount|number_format }}</strong></span>
                            </div>
                        {% endif %}
                        {% if incident.estimatedFinancialImpact %}
                            <div class="impact-item">
                                <span class="label">{{ 'incident.field.estimated_financial_impact'|trans({}, 'incident') }}:</span>
                                <span class="value"><strong>{{ incident.estimatedFinancialImpact|number_format(2) }} EUR</strong></span>
                            </div>
                        {% endif %}
                        {% if incident.nationalAuthorityNotified %}
                            <div class="impact-item">
                                <span class="label">{{ 'incident.field.national_authority_notified'|trans({}, 'incident') }}:</span>
                                <span class="value">{{ incident.nationalAuthorityNotified }}</span>
                            </div>
                        {% endif %}
                        {% if incident.authorityReferenceNumber %}
                            <div class="impact-item">
                                <span class="label">{{ 'incident.field.authority_reference_number'|trans({}, 'incident') }}:</span>
                                <span class="value"><code>{{ incident.authorityReferenceNumber }}</code></span>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endif %}

            {% if incident.description %}
                <div class="detail-section">
                    <h3 class="h5">{{ 'incident.field.description'|trans({}, 'incident') }}</h3>
                    <p>{{ incident.description }}</p>
                </div>
            {% endif %}

            {% if incident.affectedSystems %}
                <div class="detail-section">
                    <h3 class="h5">{{ 'incident.field.affected_systems'|trans({}, 'incident') }}</h3>
                    <p>{{ incident.affectedSystems }}</p>
                </div>
            {% endif %}

            {% if incident.rootCause %}
                <div class="detail-section">
                    <h3 class="h5">{{ 'incident.section.root_cause'|trans({}, 'incident') }}</h3>
                    <p>{{ incident.rootCause }}</p>
                </div>
            {% endif %}

            {% if incident.correctiveActions %}
                <div class="detail-section">
                    <h3 class="h5">{{ 'incident.field.corrective_actions'|trans({}, 'incident') }}</h3>
                    <p>{{ incident.correctiveActions }}</p>
                </div>
            {% endif %}

            {% if incident.lessonsLearned %}
                <div class="detail-section">
                    <h3 class="h5">{{ 'incident.field.lessons_learned'|trans({}, 'incident') }}</h3>
                    <p>{{ incident.lessonsLearned }}</p>
                </div>
            {% endif %}

            {% if incident.closedAt %}
                <div class="detail-section">
                    <h3 class="h5">{{ 'incident.section.closure'|trans({}, 'incident') }}</h3>
                    <p>{{ 'incident.field.closed_date'|trans({}, 'incident') }}: <strong>{{ incident.closedAt|date('d.m.Y H:i') }}</strong></p>
                </div>
            {% endif %}

            {# Audit Log History #}
            {% if auditLogs is defined and auditLogs|length > 0 %}
                <div class="detail-section">
                    <h3 class="h5"><i class="bi bi-clock-history" aria-hidden="true"></i> {{ 'incident.section.history'|trans({}, 'incident') }} ({{ totalAuditLogs }} {{ 'audit_log.entries'|trans({}, 'audit_log') }})</h3>
                    <div class="audit-log-list">
                        {% for log in auditLogs %}
                        <div class="audit-log-entry">
                            <div class="audit-log-header">
                                <span class="{{ badge_action(log.action) }}">
                                    {{ log.action|upper }}
                                </span>
                                <span class="text-muted">
                                    {{ log.userName|default('System') }}
                                    &bull; {{ log.createdAt|date('d.m.Y H:i:s') }}
                                </span>
                            </div>
                            {% if log.action == 'update' %}
                                {% set oldValues = log.oldValuesArray %}
                                {% set newValues = log.newValuesArray %}
                                {% if oldValues and newValues %}
                                    <div class="audit-log-changes">
                                        {% for field, newValue in newValues %}
                                            {% if oldValues[field] is defined and oldValues[field] != newValue %}
                                                <div class="change-item">
                                                    <strong>{{ field }}:</strong>
                                                    <span class="text-danger">{{ oldValues[field] }}</span>
                                                    &rarr;
                                                    <span class="text-success">{{ newValue }}</span>
                                                </div>
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            {% endif %}
                        </div>
                        {% endfor %}
                    </div>
                    {% if totalAuditLogs > 10 %}
                    <div class="text-center mt-3">
                        <small class="text-muted">{{ 'audit_log.showing_recent'|trans({'%count%': 10, '%total%': totalAuditLogs}, 'audit') }}</small>
                    </div>
                    {% endif %}
                </div>
            {% endif %}

            {# Data Reuse: Affected Assets #}
            {% if incident.affectedAssets is defined and incident.affectedAssets|length > 0 %}
                <div class="detail-section">
                    <h3 class="h5"><i class="bi bi-building" aria-hidden="true"></i> {{ 'incident.section.affected_assets'|trans({'%count%': incident.affectedAssets|length}, 'incident') }}</h3>
                    <div class="data-reuse-list">
                        {% for asset in incident.affectedAssets %}
                            <div class="data-reuse-item">
                                <strong>{{ asset.name }}</strong>
                                {% include '_components/_badge.html.twig' with { variant: 'info', content: asset.assetType } %}
                                <small>CIA: {{ asset.confidentialityValue }}/{{ asset.integrityValue }}/{{ asset.availabilityValue }}</small>
                                {% if asset.monetaryValue %}
                                    <small class="text-danger">{{ 'incident.bcm.value'|trans({}, 'incident') }}: €{{ asset.monetaryValue }}</small>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# CRITICAL-05: BCM Impact Analysis #}
            <div class="detail-section">
                <h3 class="h5"><i class="bi bi-bar-chart-line" aria-hidden="true"></i> {{ 'incident.section.bcm_impact'|trans({}, 'incident') }}</h3>

                {% if incident.affectedBusinessProcesses|length > 0 %}
                    <div class="row mb-3">
                        <div class="col-md-4">
                            {% embed '_components/_card.html.twig' with { 'class': 'bg-body-secondary' } %}
                                {% block card_body %}
                                    <div class="text-center">
                                        <div class="fs-5 fw-bold">{{ incident.affectedProcessCount }}</div>
                                        <small class="text-muted">{{ 'incident.bcm.affected_processes'|trans({}, 'incident') }}</small>
                                        {% if incident.hasCriticalProcessesAffected %}
                                            <br>{% include '_components/_badge.html.twig' with { variant: 'danger', class: 'mt-1', content: 'incident.severity.critical'|trans({}, 'incident') } %}
                                        {% endif %}
                                    </div>
                                {% endblock %}
                            {% endembed %}
                        </div>
                        <div class="col-md-4">
                            {% embed '_components/_card.html.twig' with { 'class': 'bg-body-secondary' } %}
                                {% block card_body %}
                                    <div class="text-center">
                                        <div class="fs-5">
                                            {% set priority_class = {
                                                'immediate': 'danger',
                                                'high': 'warning',
                                                'medium': 'info',
                                                'low': 'secondary'
                                            }[incident.suggestedRecoveryPriority] %}
                                            {% include '_components/_badge.html.twig' with { variant: priority_class, content: incident.suggestedRecoveryPriority|upper } %}
                                        </div>
                                        <small class="text-muted">{{ 'incident.bcm.recovery_priority'|trans({}, 'incident') }}</small>
                                    </div>
                                {% endblock %}
                            {% endembed %}
                        </div>
                        <div class="col-md-4">
                            {% embed '_components/_card.html.twig' with { 'class': 'bg-body-secondary' } %}
                                {% block card_body %}
                                    <div class="text-center">
                                        <div class="fs-5 fw-bold">€{{ incident.calculateEstimatedFinancialImpact(24)|number_format(0) }}</div>
                                        <small class="text-muted">{{ 'incident.bcm.est_impact_24h'|trans({}, 'incident') }}</small>
                                    </div>
                                {% endblock %}
                            {% endembed %}
                        </div>
                    </div>

                    <div class="data-reuse-list mb-3">
                        {% for process in incident.affectedBusinessProcesses %}
                            <div class="data-reuse-item">
                                <strong>{{ process.name }}</strong>
                                {% set crit_class = {
                                    'critical': 'danger',
                                    'high': 'warning',
                                    'medium': 'info',
                                    'low': 'secondary'
                                }[process.criticality] %}
                                {% include '_components/_badge.html.twig' with { variant: crit_class, content: process.criticality|upper } %}
                                <small>RTO: {{ process.rto }}h | {{ 'incident.bcm.owner'|trans({}, 'incident') }}: {{ process.processOwner }}</small>
                            </div>
                        {% endfor %}
                    </div>

                    <div class="d-flex gap-2">
                        <a href="{{ path('app_incident_bcm_impact', {id: incident.id}) }}" class="btn btn-primary">
                            <i class="bi bi-diagram-3" aria-hidden="true"></i> {{ 'incident.bcm.detailed_analysis'|trans({}, 'incident') }}
                        </a>
                        <form method="post" action="{{ path('app_incident_auto_detect_processes', {id: incident.id}) }}" style="display:inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('auto-detect' ~ incident.id) }}">
                            <button type="submit" class="btn btn-outline-secondary">
                                <i class="bi bi-magic" aria-hidden="true"></i> {{ 'incident.bcm.auto_detect_more'|trans({}, 'incident') }}
                            </button>
                        </form>
                    </div>
                {% else %}
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle" aria-hidden="true"></i>
                        <strong>{{ 'incident.bcm.empty_title'|trans({}, 'incident') }}</strong>
                        {{ 'incident.bcm.empty_description'|trans({}, 'incident') }}
                    </div>
                    <form method="post" action="{{ path('app_incident_auto_detect_processes', {id: incident.id}) }}" style="display:inline;">
                        <input type="hidden" name="_token" value="{{ csrf_token('auto-detect' ~ incident.id) }}">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-magic" aria-hidden="true"></i> {{ 'incident.bcm.auto_detect'|trans({}, 'incident') }}
                        </button>
                    </form>
                {% endif %}
            </div>

            {# Data Reuse: Realized Risks #}
            {% if incident.realizedRisks is defined and incident.realizedRisks|length > 0 %}
                <div class="detail-section">
                    <h3 class="h5"><i class="bi bi-exclamation-triangle text-warning" aria-hidden="true"></i> {{ 'incident.section.realized_risks'|trans({'%count%': incident.realizedRisks|length}, 'incident') }}</h3>
                    <div class="alert alert-warning">
                        <strong>{{ 'incident.reuse.risk_realization'|trans({}, 'incident') }}:</strong> {{ 'incident.reuse.risk_realization_detail'|trans({'%count%': incident.realizedRisks|length}, 'incident') }}
                    </div>
                    <div class="data-reuse-list">
                        {% for risk in incident.realizedRisks %}
                            <div class="data-reuse-item">
                                <strong>{{ risk.title }}</strong>
                                {% set riskClass = risk.inherentRiskLevel >= 16 ? 'danger' : (risk.inherentRiskLevel >= 9 ? 'warning' : 'success') %}
                                {% include '_components/_badge.html.twig' with { variant: riskClass, content: 'incident.reuse.risk_level'|trans({'%level%': risk.inherentRiskLevel}, 'incident') } %}
                                <small>{{ 'incident.reuse.probability'|trans({'%value%': risk.probability}, 'incident') }}</small>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# Data Reuse: Related Controls #}
            {% if incident.relatedControls is defined and incident.relatedControls|length > 0 %}
                <div class="detail-section">
                    <h3 class="h5"><i class="bi bi-shield-check" aria-hidden="true"></i> {{ 'incident.section.related_controls'|trans({'%count%': incident.relatedControls|length}, 'incident') }}</h3>
                    <p class="text-muted">{{ 'incident.controls_should_prevent'|trans({}, 'incident') }}</p>
                    <div class="data-reuse-list">
                        {% for control in incident.relatedControls %}
                            <div class="data-reuse-item">
                                {% include '_components/_iso_reference_label.html.twig' with { control: control, code_class: 'fw-bold' } only %}
                                {% include '_components/_badge.html.twig' with { variant: control.implementationStatus == 'implemented' ? 'success' : (control.implementationStatus == 'in_progress' ? 'warning' : 'danger'), content: control.implementationStatus|upper } %}
                                {% if control.implementationStatus != 'implemented' %}
                                    <small class="text-warning"><i class="bi bi-exclamation-triangle" aria-hidden="true"></i> {{ 'incident.reuse.control_not_implemented'|trans({}, 'incident') }}</small>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        {% endblock %}
    {% endembed %}
</div>

<style>
/* Workflow Status Alert Styles */
.workflow-status-alert {
    margin-bottom: 1.5rem;
    border-left: 4px solid currentColor;
    padding: 1.25rem;
}

.workflow-status-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
}

.workflow-status-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.1rem;
}

.workflow-status-title i {
    font-size: 1.25rem;
}

.workflow-status-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.workflow-info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
}

.workflow-info-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
}

.workflow-info-item .label {
    font-size: 0.875rem;
    font-weight: 500;
    opacity: 0.8;
}

.workflow-info-item .value {
    font-size: 1rem;
    font-weight: 600;
}

.gdpr-deadline-warning {
    background: rgba(220, 38, 38, 0.1);
    border: 2px solid var(--danger);
    border-radius: 6px;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
}

.gdpr-deadline-warning i {
    font-size: 1.25rem;
    color: var(--danger);
}

.workflow-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
}

.badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
}
/* badge-status-* and badge-nis2-* removed: dead code.
   BadgeExtension::getStatusBadgeClass() returns "badge bg-<color>" —
   styled centrally by Aurora's .badge.bg-* rules. */

@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
}

/* NIS2 Timeline Section */
.nis2-timeline-section {
    background: linear-gradient(135deg, var(--bg) 0%, var(--primary-tint) 100%);
    border-left: 4px solid var(--primary);
    padding: 1.5rem;
    margin: 1.5rem 0;
    border-radius: 8px;
}

.nis2-timeline-section h3 {
    color: var(--primary-strong);
    margin-bottom: 0.5rem;
}

.nis2-timeline-section .text-muted {
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
}

.timeline-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 1.5rem 0;
}

.timeline-stage {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    background: var(--bs-body-bg);
    border-radius: 8px;
    border: 2px solid var(--bs-border-color);
    transition: all 0.3s ease;
}

.timeline-stage.completed {
    border-color: var(--success);
    background: var(--success-glow);
}

.timeline-stage.overdue {
    border-color: var(--danger);
    background: var(--danger-glow);
    box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1);
}

.timeline-stage.pending {
    border-color: var(--primary);
    background: var(--primary-tint);
}

.timeline-icon {
    font-size: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 3rem;
}

.timeline-content {
    flex: 1;
}

.timeline-content .fw-bold {
    margin-bottom: 0.5rem;
    display: block;
}

.timeline-deadline {
    font-size: 0.9rem;
    color: var(--bs-secondary-color);
    margin: 0.5rem 0;
}

.timeline-completed {
    padding: 0.5rem;
    background: var(--success-glow);
    border-radius: 4px;
    color: var(--success);
    font-weight: 500;
}

.timeline-overdue {
    padding: 0.5rem;
    background: var(--danger-glow);
    border-radius: 4px;
    color: var(--danger);
    font-weight: 600;
    animation: pulse 2s infinite;
}

.timeline-countdown {
    padding: 0.5rem;
    background: var(--warning-glow);
    border-radius: 4px;
    color: var(--warning-text);
    font-weight: 500;
}

/* NIS2 Impact Grid */
.nis2-impact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 2px solid var(--bs-border-color);
}

.impact-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
}

.impact-item .label {
    font-size: 0.85rem;
    color: var(--bs-secondary-color);
    font-weight: 500;
}

.impact-item .value {
    font-size: 1rem;
    color: var(--bs-body-color);
}

.impact-item code {
    background: var(--bs-tertiary-bg);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-family: 'Courier New', monospace;
    color: var(--bs-body-color);
}

/* Data Reuse Sections */
.data-reuse-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 1rem;
}
.data-reuse-item {
    padding: 0.75rem;
    background: var(--bs-tertiary-bg);
    color: var(--bs-body-color);
    border-left: 3px solid var(--primary);
    border-radius: 4px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
}
/* .alert and .alert-* — handled centrally in fairy-aurora-components.css */
/* .badge-risk-* removed: dead code, never referenced in markup */

/* Audit Log Styles */
.audit-log-list {
    margin-top: 1rem;
}

.audit-log-entry {
    border-left: 3px solid var(--bs-border-color);
    padding-left: 1rem;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--bs-border-color);
}

.audit-log-entry:last-child {
    border-bottom: none;
}

.audit-log-header {
    margin-bottom: 0.5rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
}

.audit-log-changes {
    font-size: 0.875rem;
    margin-top: 0.5rem;
    padding-left: 1rem;
}

.change-item {
    margin-bottom: 0.25rem;
}

.change-item strong {
    color: var(--fg);
}

.text-danger {
    color: var(--danger);
}

.text-success {
    color: var(--success);
}

/* Responsive adjustments */
@media (max-width: 768px) {
    .timeline-stage {
        flex-direction: column;
    }

    .timeline-icon {
        align-self: flex-start;
    }

    .nis2-impact-grid {
        grid-template-columns: 1fr;
    }
}
</style>
{% endblock %}
