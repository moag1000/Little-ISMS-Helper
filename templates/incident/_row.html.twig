{# Single Incident table row — shared by the index and the Turbo Stream that
   replaces/appends a row after an in-modal save. The title cell opens the
   read-only detail in the fa-form-modal frame; the eye/edit actions do the
   same. PDF/export links bypass Turbo with data-turbo="false". #}
{% trans_default_domain 'incident' %}
{% set severityColors = {
    'critical': 'danger',
    'high': 'warning',
    'medium': 'info',
    'low': 'success'
} %}
{% set statusIcons = {
    'reported': 'status-critical text-danger',
    'in_investigation': 'ui-search text-warning',
    'in_resolution': 'util-refresh text-info',
    'resolved': 'status-ok text-success',
    'closed': 'status-ok text-secondary'
} %}
<tr id="incident-row-{{ incident.id }}"
    data-incident-id="{{ incident.id }}"
    data-incident-status="{{ incident.status.value }}"
    data-incident-severity="{{ incident.severity ? incident.severity.value : '' }}">
    <td class="bulk-select-column">
        <input type="checkbox"
               class="form-check-input"
               data-bulk-actions-target="item"
               data-action="bulk-actions#selectItem"
               value="{{ incident.id }}"
               aria-label="{{ 'common.select'|trans({}, 'messages') }} {{ incident.title }}">
    </td>
    <td>
        <a href="{{ path('app_incident_show', {id: incident.id}) }}"
           data-turbo-frame="fa-form-modal"
           class="fa-row-link"><strong>{{ incident.title }}</strong></a>
        {% if incident.status.value == 'reported' %}
            {% include '_components/_badge.html.twig' with { variant: 'danger', class: 'ms-2', content: 'common.new'|trans({}, 'messages') } %}
        {% endif %}
        {% if incident.description %}
        <br><small class="text-muted">{{ incident.description|length > 60 ? incident.description|slice(0, 60) ~ '...' : incident.description }}</small>
        {% endif %}
    </td>
    <td>
        {% if incident.category %}
            {% include '_components/_badge.html.twig' with { variant: 'secondary', content: ('incident.category.' ~ incident.category)|trans({}, 'incident') } %}
        {% else %}
            <span class="text-muted">-</span>
        {% endif %}
    </td>
    <td class="text-center">
        {% include '_components/_badge.html.twig' with {
            variant: severityColors[incident.severity ? incident.severity.value : ''] ?? 'secondary',
            content: ('incident.severity.' ~ (incident.severity ? incident.severity.value : ''))|trans({}, 'incident')
        } %}
    </td>
    <td>
        <i class="fa-icon fa-icon--{{ statusIcons[incident.status.value] ?? 'status-info' }}" aria-hidden="true"></i>
        {{ ('incident.status.' ~ incident.status.value)|trans({}, 'incident') }}
    </td>
    <td>
        {{ incident.detectedAt|locale_datetime }}
    </td>
    <td class="text-center">
        {% if incident.affectedAssets|length > 0 %}
            <a href="{{ path('app_incident_show', {id: incident.id}) }}#affected-assets"
               data-turbo="false"
               class="fa-status-pill fa-status-pill--warning"
               title="{{ 'incident.field.affected_assets'|trans({}, 'incident') }}">
                {{ incident.affectedAssets|length }}
            </a>
        {% else %}
            <span class="text-muted">0</span>
        {% endif %}
    </td>
    <td class="text-center">
        {% if incident.dataBreachOccurred %}
            {% include '_components/_badge.html.twig' with { variant: 'danger', icon: 'nav-shield-alert', title: 'incident.field.data_breach_occurred'|trans({}, 'incident'), content: 'common.yes'|trans({}, 'messages') } %}
        {% else %}
            <span class="text-muted">{{ 'common.no'|trans({}, 'messages') }}</span>
        {% endif %}
    </td>
    <td class="text-center">
        <div class="btn-group btn-group-sm" role="group" aria-label="{{ 'common.actions'|trans({}, 'messages') }}">
            <a href="{{ path('app_incident_show', {id: incident.id}) }}"
               class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
               data-turbo-frame="fa-form-modal"
               title="{{ 'common.view'|trans({}, 'messages') }}" aria-label="{{ 'common.view'|trans({}, 'messages') }}">
                <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
            </a>
            {% if is_granted('ROLE_USER') and incident.status.value != 'closed' %}
            <a href="{{ path('app_incident_edit', {id: incident.id}) }}"
               class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
               data-turbo-frame="fa-form-modal"
               title="{{ 'common.edit'|trans({}, 'messages') }}" aria-label="{{ 'common.edit'|trans({}, 'messages') }}">
                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
            </a>
            {% endif %}
        </div>
    </td>
</tr>
