{# GDPR Data Breach Assessment Wizard Modal — Aurora v4-conformant #}
{% trans_default_domain 'privacy' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_stepper.html.twig' as _fa_stepper %}

{% set wizardSteps = [
    { label: 'data_breach.wizard.step1_short'|trans({}, 'privacy') },
    { label: 'data_breach.wizard.step2_short'|trans({}, 'privacy') },
    { label: 'data_breach.wizard.step3_short'|trans({}, 'privacy') },
    { label: 'data_breach.wizard.step4_short'|trans({}, 'privacy') },
] %}

<div class="gdpr-wizard"
     data-translations='{
         "calculating": "{{ 'data_breach.wizard.calculating'|trans({}, 'privacy')|e('js') }}",
         "yes_reportable": "{{ 'data_breach.wizard.yes_reportable'|trans({}, 'privacy')|e('js') }}",
         "no_not_reportable": "{{ 'data_breach.wizard.no_not_reportable'|trans({}, 'privacy')|e('js') }}",
         "risk_low": "{{ 'data_breach.wizard.risk_level.low'|trans({}, 'privacy')|e('js') }}",
         "risk_medium": "{{ 'data_breach.wizard.risk_level.medium'|trans({}, 'privacy')|e('js') }}",
         "risk_high": "{{ 'data_breach.wizard.risk_level.high'|trans({}, 'privacy')|e('js') }}",
         "risk_very_high": "{{ 'data_breach.wizard.risk_level.very_high'|trans({}, 'privacy')|e('js') }}",
         "recommendation_not_reportable": "{{ 'data_breach.wizard.recommendation.not_reportable'|trans({}, 'privacy')|e('js') }}",
         "recommendation_reportable_low": "{{ 'data_breach.wizard.recommendation.reportable_low'|trans({}, 'privacy')|e('js') }}",
         "recommendation_reportable_medium": "{{ 'data_breach.wizard.recommendation.reportable_medium'|trans({}, 'privacy')|e('js') }}",
         "recommendation_reportable_high": "{{ 'data_breach.wizard.recommendation.reportable_high'|trans({}, 'privacy')|e('js') }}",
         "recommendation_reportable_very_high": "{{ 'data_breach.wizard.recommendation.reportable_very_high'|trans({}, 'privacy')|e('js') }}",
         "step_of": "{{ 'data_breach.wizard.step_of'|trans({}, 'privacy')|e('js') }}"
     }'>
    {# Modal Backdrop #}
    <div data-gdpr-breach-wizard-target="backdrop"
         class="gdpr-wizard__backdrop"
         data-action="click->gdpr-breach-wizard#close">
    </div>

    {# Modal Container #}
    <div data-gdpr-breach-wizard-target="modal"
         class="gdpr-wizard__modal"
         tabindex="-1"
         role="dialog"
         aria-labelledby="gdpr-wizard-title"
         aria-modal="true">
        <div class="gdpr-wizard__dialog">
            <div class="gdpr-wizard__content">
                {# Modal Header #}
                <div class="gdpr-wizard__header">
                    <div class="gdpr-wizard__header-row">
                        <div class="gdpr-wizard__title-block">
                            <div class="gdpr-wizard__title" id="gdpr-wizard-title">
                                <i class="fa-icon fa-icon--breach gdpr-wizard__title-icon" aria-hidden="true"></i>
                                <span>{{ 'data_breach.wizard.title'|trans({}, 'privacy') }}</span>
                            </div>
                            <p class="gdpr-wizard__subtitle">{{ 'data_breach.wizard.subtitle'|trans({}, 'privacy') }}</p>
                        </div>
                        <button type="button"
                                class="gdpr-wizard__close"
                                data-action="click->gdpr-breach-wizard#close"
                                aria-label="{{ 'common.close'|trans({}, 'messages') }}">
                            <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i>
                        </button>
                    </div>

                    {# Aurora Stepper — replaces hand-rolled progress bar #}
                    <div class="gdpr-wizard__stepper">
                        {{ _fa_stepper.render(wizardSteps, 0, {
                            ariaLabel: 'data_breach.wizard.title'|trans({}, 'privacy'),
                            class: 'fa-stepper--horizontal'
                        }) }}
                    </div>

                    {# Hidden Bootstrap progress-bar kept for Stimulus controller targets.
                       Aurora-tokenized + visually hidden — controller can still update width
                       without driving the visible UI. Stepper handles the visible cue. #}
                    <div class="gdpr-wizard__progress-sr-only"
                         role="progressbar"
                         aria-label="Wizard progress">
                        <div data-gdpr-breach-wizard-target="progressBar"
                             style="width: 25%"
                             aria-valuenow="25"
                             aria-valuemin="0"
                             aria-valuemax="100">
                        </div>
                        <small data-gdpr-breach-wizard-target="progressText">1 {{ 'data_breach.wizard.step_of'|trans({}, 'privacy') }} 4</small>
                    </div>
                </div>

                {# Modal Body #}
                <div class="gdpr-wizard__body">
                    {# Step 1: Personal Data Involvement Check #}
                    <div data-gdpr-breach-wizard-target="step1" class="gdpr-wizard__step">
                        <div class="gdpr-wizard__step-header">
                            <span class="gdpr-wizard__step-number" aria-hidden="true">1</span>
                            <h3 class="gdpr-wizard__step-title">{{ 'data_breach.wizard.step1_title'|trans({}, 'privacy') }}</h3>
                        </div>
                        <p class="gdpr-wizard__step-question">{{ 'data_breach.wizard.personal_data_question'|trans({}, 'privacy') }}</p>

                        <div class="gdpr-wizard__radio-group" role="radiogroup" aria-labelledby="gdpr-wizard-title">
                            <label class="gdpr-wizard__radio-card" for="personalDataYes">
                                <input class="gdpr-wizard__radio-input"
                                       type="radio"
                                       name="personalDataInvolved"
                                       id="personalDataYes"
                                       data-gdpr-breach-wizard-target="personalDataYes"
                                       value="1">
                                <span class="gdpr-wizard__radio-marker" aria-hidden="true"></span>
                                <span class="gdpr-wizard__radio-body">
                                    <span class="gdpr-wizard__radio-label">{{ 'common.yes'|trans({}, 'messages') }}</span>
                                    <span class="gdpr-wizard__radio-desc">{{ 'data_breach.wizard.personal_data_yes'|trans({}, 'privacy') }}</span>
                                </span>
                            </label>

                            <label class="gdpr-wizard__radio-card" for="personalDataNo">
                                <input class="gdpr-wizard__radio-input"
                                       type="radio"
                                       name="personalDataInvolved"
                                       id="personalDataNo"
                                       data-gdpr-breach-wizard-target="personalDataNo"
                                       value="0">
                                <span class="gdpr-wizard__radio-marker" aria-hidden="true"></span>
                                <span class="gdpr-wizard__radio-body">
                                    <span class="gdpr-wizard__radio-label">{{ 'common.no'|trans({}, 'messages') }}</span>
                                    <span class="gdpr-wizard__radio-desc">{{ 'data_breach.wizard.personal_data_no'|trans({}, 'privacy') }}</span>
                                </span>
                            </label>
                        </div>

                        {{ _fa_alert.render({ variant: 'info', class: 'mt-4', body: 'data_breach.wizard.personal_data_hint'|trans({}, 'privacy') }) }}
                    </div>

                    {# Step 2: Data Type Classification #}
                    <div data-gdpr-breach-wizard-target="step2" class="gdpr-wizard__step d-none">
                        <div class="gdpr-wizard__step-header">
                            <span class="gdpr-wizard__step-number" aria-hidden="true">2</span>
                            <h3 class="gdpr-wizard__step-title">{{ 'data_breach.wizard.step2_title'|trans({}, 'privacy') }}</h3>
                        </div>
                        <p class="gdpr-wizard__step-question">{{ 'data_breach.wizard.data_type_question'|trans({}, 'privacy') }}</p>

                        <div class="gdpr-wizard__radio-group">
                            <label class="gdpr-wizard__radio-card gdpr-wizard__radio-card--success" for="dataType1">
                                <input class="gdpr-wizard__radio-input"
                                       type="checkbox"
                                       data-gdpr-breach-wizard-target="dataTypeCheckbox"
                                       value="names_contact"
                                       id="dataType1">
                                <span class="gdpr-wizard__radio-marker gdpr-wizard__radio-marker--check" aria-hidden="true"></span>
                                <span class="gdpr-wizard__radio-body">
                                    <span class="gdpr-wizard__radio-label">{{ 'data_breach.wizard.data_types.names_contact'|trans({}, 'privacy') }}</span>
                                    <span class="gdpr-wizard__radio-desc">{{ 'data_breach.wizard.data_types.names_contact_desc'|trans({}, 'privacy') }}</span>
                                </span>
                                <span class="fa-status-pill fa-status-pill--success fa-status-pill--sm">{{ 'data_breach.wizard.risk_score'|trans({}, 'privacy') }}: 1</span>
                            </label>

                            <label class="gdpr-wizard__radio-card gdpr-wizard__radio-card--warning" for="dataType2">
                                <input class="gdpr-wizard__radio-input"
                                       type="checkbox"
                                       data-gdpr-breach-wizard-target="dataTypeCheckbox"
                                       value="financial"
                                       id="dataType2">
                                <span class="gdpr-wizard__radio-marker gdpr-wizard__radio-marker--check" aria-hidden="true"></span>
                                <span class="gdpr-wizard__radio-body">
                                    <span class="gdpr-wizard__radio-label">{{ 'data_breach.wizard.data_types.financial'|trans({}, 'privacy') }}</span>
                                    <span class="gdpr-wizard__radio-desc">{{ 'data_breach.wizard.data_types.financial_desc'|trans({}, 'privacy') }}</span>
                                </span>
                                <span class="fa-status-pill fa-status-pill--warning fa-status-pill--sm">{{ 'data_breach.wizard.risk_score'|trans({}, 'privacy') }}: 2</span>
                            </label>

                            <label class="gdpr-wizard__radio-card gdpr-wizard__radio-card--danger" for="dataType3">
                                <input class="gdpr-wizard__radio-input"
                                       type="checkbox"
                                       data-gdpr-breach-wizard-target="dataTypeCheckbox"
                                       value="health_biometric"
                                       id="dataType3">
                                <span class="gdpr-wizard__radio-marker gdpr-wizard__radio-marker--check" aria-hidden="true"></span>
                                <span class="gdpr-wizard__radio-body">
                                    <span class="gdpr-wizard__radio-label">{{ 'data_breach.wizard.data_types.health_biometric'|trans({}, 'privacy') }}</span>
                                    <span class="gdpr-wizard__radio-desc">{{ 'data_breach.wizard.data_types.health_biometric_desc'|trans({}, 'privacy') }}</span>
                                </span>
                                <span class="fa-status-pill fa-status-pill--danger fa-status-pill--sm">{{ 'data_breach.wizard.risk_score'|trans({}, 'privacy') }}: 3</span>
                            </label>

                            <label class="gdpr-wizard__radio-card gdpr-wizard__radio-card--danger" for="dataType4">
                                <input class="gdpr-wizard__radio-input"
                                       type="checkbox"
                                       data-gdpr-breach-wizard-target="dataTypeCheckbox"
                                       value="special_category_art9"
                                       id="dataType4">
                                <span class="gdpr-wizard__radio-marker gdpr-wizard__radio-marker--check" aria-hidden="true"></span>
                                <span class="gdpr-wizard__radio-body">
                                    <span class="gdpr-wizard__radio-label">{{ 'data_breach.wizard.data_types.special_category_art9'|trans({}, 'privacy') }}</span>
                                    <span class="gdpr-wizard__radio-desc">{{ 'data_breach.wizard.data_types.special_category_art9_desc'|trans({}, 'privacy') }}</span>
                                </span>
                                <span class="fa-status-pill fa-status-pill--danger fa-status-pill--sm">{{ 'data_breach.wizard.risk_score'|trans({}, 'privacy') }}: 4</span>
                            </label>

                            <label class="gdpr-wizard__radio-card gdpr-wizard__radio-card--danger" for="dataType5">
                                <input class="gdpr-wizard__radio-input"
                                       type="checkbox"
                                       data-gdpr-breach-wizard-target="dataTypeCheckbox"
                                       value="criminal_records_art10"
                                       id="dataType5">
                                <span class="gdpr-wizard__radio-marker gdpr-wizard__radio-marker--check" aria-hidden="true"></span>
                                <span class="gdpr-wizard__radio-body">
                                    <span class="gdpr-wizard__radio-label">{{ 'data_breach.wizard.data_types.criminal_records_art10'|trans({}, 'privacy') }}</span>
                                    <span class="gdpr-wizard__radio-desc">{{ 'data_breach.wizard.data_types.criminal_records_art10_desc'|trans({}, 'privacy') }}</span>
                                </span>
                                <span class="fa-status-pill fa-status-pill--danger fa-status-pill--sm">{{ 'data_breach.wizard.risk_score'|trans({}, 'privacy') }}: 4</span>
                            </label>
                        </div>
                    </div>

                    {# Step 3: Scale Assessment #}
                    <div data-gdpr-breach-wizard-target="step3" class="gdpr-wizard__step d-none">
                        <div class="gdpr-wizard__step-header">
                            <span class="gdpr-wizard__step-number" aria-hidden="true">3</span>
                            <h3 class="gdpr-wizard__step-title">{{ 'data_breach.wizard.step3_title'|trans({}, 'privacy') }}</h3>
                        </div>
                        <p class="gdpr-wizard__step-question">{{ 'data_breach.wizard.affected_count_question'|trans({}, 'privacy') }}</p>

                        <div class="gdpr-wizard__radio-group" role="radiogroup">
                            <label class="gdpr-wizard__radio-card gdpr-wizard__radio-card--success" for="scale1">
                                <input class="gdpr-wizard__radio-input"
                                       type="radio"
                                       name="scale"
                                       data-gdpr-breach-wizard-target="scaleRadio"
                                       value="under_100"
                                       id="scale1">
                                <span class="gdpr-wizard__radio-marker" aria-hidden="true"></span>
                                <span class="gdpr-wizard__radio-body">
                                    <span class="gdpr-wizard__radio-label">{{ 'data_breach.wizard.scale_options.under_100'|trans({}, 'privacy') }}</span>
                                </span>
                                <span class="fa-status-pill fa-status-pill--success fa-status-pill--sm">{{ 'data_breach.wizard.scale_score'|trans({}, 'privacy') }}: 1</span>
                            </label>

                            <label class="gdpr-wizard__radio-card gdpr-wizard__radio-card--warning" for="scale2">
                                <input class="gdpr-wizard__radio-input"
                                       type="radio"
                                       name="scale"
                                       data-gdpr-breach-wizard-target="scaleRadio"
                                       value="100_to_1000"
                                       id="scale2">
                                <span class="gdpr-wizard__radio-marker" aria-hidden="true"></span>
                                <span class="gdpr-wizard__radio-body">
                                    <span class="gdpr-wizard__radio-label">{{ 'data_breach.wizard.scale_options.100_to_1000'|trans({}, 'privacy') }}</span>
                                </span>
                                <span class="fa-status-pill fa-status-pill--warning fa-status-pill--sm">{{ 'data_breach.wizard.scale_score'|trans({}, 'privacy') }}: 2</span>
                            </label>

                            <label class="gdpr-wizard__radio-card gdpr-wizard__radio-card--danger" for="scale3">
                                <input class="gdpr-wizard__radio-input"
                                       type="radio"
                                       name="scale"
                                       data-gdpr-breach-wizard-target="scaleRadio"
                                       value="1001_to_10000"
                                       id="scale3">
                                <span class="gdpr-wizard__radio-marker" aria-hidden="true"></span>
                                <span class="gdpr-wizard__radio-body">
                                    <span class="gdpr-wizard__radio-label">{{ 'data_breach.wizard.scale_options.1001_to_10000'|trans({}, 'privacy') }}</span>
                                </span>
                                <span class="fa-status-pill fa-status-pill--danger fa-status-pill--sm">{{ 'data_breach.wizard.scale_score'|trans({}, 'privacy') }}: 3</span>
                            </label>

                            <label class="gdpr-wizard__radio-card gdpr-wizard__radio-card--danger" for="scale4">
                                <input class="gdpr-wizard__radio-input"
                                       type="radio"
                                       name="scale"
                                       data-gdpr-breach-wizard-target="scaleRadio"
                                       value="over_10000"
                                       id="scale4">
                                <span class="gdpr-wizard__radio-marker" aria-hidden="true"></span>
                                <span class="gdpr-wizard__radio-body">
                                    <span class="gdpr-wizard__radio-label">{{ 'data_breach.wizard.scale_options.over_10000'|trans({}, 'privacy') }}</span>
                                </span>
                                <span class="fa-status-pill fa-status-pill--danger fa-status-pill--sm">{{ 'data_breach.wizard.scale_score'|trans({}, 'privacy') }}: 4</span>
                            </label>
                        </div>
                    </div>

                    {# Step 4: Results & Recommendation #}
                    <div data-gdpr-breach-wizard-target="step4" class="gdpr-wizard__step d-none">
                        <div class="gdpr-wizard__step-header">
                            <span class="gdpr-wizard__step-number" aria-hidden="true">4</span>
                            <h3 class="gdpr-wizard__step-title">{{ 'data_breach.wizard.step4_title'|trans({}, 'privacy') }}</h3>
                        </div>

                        {# Result blocks — Aurora surface-2 tiles #}
                        <div class="gdpr-wizard__result-grid">
                            <div class="gdpr-wizard__result-tile">
                                <div class="gdpr-wizard__result-label">{{ 'data_breach.wizard.risk_level_label'|trans({}, 'privacy') }}</div>
                                <div data-gdpr-breach-wizard-target="resultRiskLevel" class="fa-status-pill fa-status-pill--neutral fa-status-pill--lg">
                                    {{ 'data_breach.wizard.calculating'|trans({}, 'privacy') }}
                                </div>
                            </div>

                            <div class="gdpr-wizard__result-tile">
                                <div class="gdpr-wizard__result-label">{{ 'data_breach.wizard.gdpr_article_33_requirement'|trans({}, 'privacy') }}</div>
                                <div data-gdpr-breach-wizard-target="resultReportable" class="fa-status-pill fa-status-pill--neutral fa-status-pill--lg">
                                    {{ 'data_breach.wizard.calculating'|trans({}, 'privacy') }}
                                </div>
                            </div>
                        </div>

                        {# 72h Deadline (conditional, shown by JS when reportable) #}
                        <div class="fa-alert fa-alert--danger gdpr-wizard__deadline d-none" role="alert">
                            <i class="fa-icon fa-icon--status-pending fa-alert__icon" aria-hidden="true"></i>
                            <div class="fa-alert__body">
                                <div class="fa-alert__title">{{ 'data_breach.wizard.deadline_warning'|trans({}, 'privacy') }}</div>
                                <p class="fa-alert__message">
                                    {{ 'data_breach.wizard.deadline_date'|trans({}, 'privacy') }}:
                                    <strong data-gdpr-breach-wizard-target="resultDeadline">--</strong>
                                </p>
                            </div>
                        </div>

                        {# Recommendation block — Aurora warning panel #}
                        <div class="gdpr-wizard__recommendation">
                            <div class="gdpr-wizard__recommendation-label">
                                <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i>
                                {{ 'data_breach.wizard.recommendation_label'|trans({}, 'privacy') }}
                            </div>
                            <p data-gdpr-breach-wizard-target="resultRecommendation" class="gdpr-wizard__recommendation-text">
                                {{ 'data_breach.wizard.calculating'|trans({}, 'privacy') }}
                            </p>
                        </div>

                        {# Legal References — Aurora muted surface-2 #}
                        <div class="gdpr-wizard__legal-refs">
                            <div class="gdpr-wizard__legal-refs-title">{{ 'data_breach.wizard.legal_references'|trans({}, 'privacy') }}</div>
                            <ul class="gdpr-wizard__legal-refs-list">
                                <li>GDPR Art. 33 (Notification to supervisory authority)</li>
                                <li>GDPR Art. 34 (Communication to data subjects)</li>
                                <li>ISO 27001 A.16.1.6 (Learning from information security incidents)</li>
                            </ul>
                        </div>
                    </div>
                </div>

                {# Modal Footer — Aurora surface-2 + cyber-btn action row #}
                <div class="gdpr-wizard__footer">
                    <button type="button"
                            class="fa-cyber-btn fa-cyber-btn--ghost"
                            data-gdpr-breach-wizard-target="backBtn"
                            data-action="click->gdpr-breach-wizard#back">
                        <i class="fa-icon fa-icon--util-arrow-left" aria-hidden="true"></i>
                        <span class="fa-cyber-btn__label">{{ 'common.back'|trans({}, 'messages') }}</span>
                    </button>

                    <div class="gdpr-wizard__footer-spacer"></div>

                    <button type="button"
                            class="fa-cyber-btn fa-cyber-btn--primary"
                            data-gdpr-breach-wizard-target="nextBtn"
                            data-action="click->gdpr-breach-wizard#next">
                        <span class="fa-cyber-btn__label">{{ 'common.next'|trans({}, 'messages') }}</span>
                        <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                    </button>

                    <button type="button"
                            class="fa-cyber-btn fa-cyber-btn--success d-none"
                            data-gdpr-breach-wizard-target="completeBtn"
                            data-action="click->gdpr-breach-wizard#completeWizard">
                        <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
                        <span class="fa-cyber-btn__label">{{ 'data_breach.wizard.complete_and_create'|trans({}, 'privacy') }}</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
