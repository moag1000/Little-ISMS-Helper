{% extends 'base.html.twig' %}
{% trans_default_domain 'change_requests' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'change_request.new'|trans({}, 'change_requests') }} - {{ parent() }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'change_request.title'|trans({}, 'change_requests'), url: path('app_change_request_index') },
            { label: 'change_request.new'|trans({}, 'change_requests') }
        ]
    } %}

    {{ _fa_page_header.render({
        title: 'change_request.page.new'|trans({}, 'change_requests'),
        badge: { icon: 'plus', label: '' },
        actions: [
            { label: 'common.back'|trans({}, 'messages'), href: path('app_change_request_index'), variant: 'ghost', icon: 'util-arrow-left' }
        ]
    }) }}

    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

    {% include '_components/_auto_form.html.twig' with {
        'form': form,
        'layout': 'outline-rail',
        'eyebrow': 'ITIL · Change Management',
        'title': 'change_request.page.new'|trans({}, 'change_requests'),
        'sections': {
            'overview': {
                'label': 'change_request.section.overview'|trans({}, 'change_requests'),
                'fields': ['changeNumber', 'title', 'changeType', 'description', 'justification']
            },
            'details': {
                'label': 'change_request.section.details'|trans({}, 'change_requests'),
                'fields': ['requestedBy', 'requestedDate', 'priority', 'status', 'clauseReference']
            },
            'impact_assessment': {
                'label': 'change_request.section.impact_assessment'|trans({}, 'change_requests'),
                'fields': ['ismsImpact', 'riskAssessment']
            },
            'approval': {
                'label': 'change_request.section.approval'|trans({}, 'change_requests'),
                'fields': ['approvedBy', 'approvedDate', 'approvalComments']
            },
            'implementation': {
                'label': 'change_request.section.implementation'|trans({}, 'change_requests'),
                'fields': ['implementationPlan', 'rollbackPlan', 'testingRequirements', 'plannedImplementationDate', 'actualImplementationDate', 'implementedBy', 'implementationNotes']
            },
            'verification': {
                'label': 'change_request.section.verification'|trans({}, 'change_requests'),
                'fields': ['verifiedBy', 'verifiedDate', 'verificationResults', 'closedDate', 'closureNotes']
            }
        },
        'col_widths': {
            'changeNumber': 4,
            'title': 8,
            'changeType': 12,
            'description': 12,
            'justification': 12,
            'requestedBy': 6,
            'requestedDate': 6,
            'priority': 6,
            'status': 6,
            'clauseReference': 12,
            'ismsImpact': 12,
            'riskAssessment': 12,
            'approvedBy': 6,
            'approvedDate': 6,
            'approvalComments': 12,
            'implementationPlan': 12,
            'rollbackPlan': 12,
            'testingRequirements': 12,
            'plannedImplementationDate': 6,
            'actualImplementationDate': 6,
            'implementedBy': 12,
            'implementationNotes': 12,
            'verifiedBy': 6,
            'verifiedDate': 6,
            'verificationResults': 12,
            'closedDate': 6,
            'closureNotes': 12
        },
        'tooltips': {
            'riskAssessment': 'change_request.tooltip.risk_assessment',
            'rollbackPlan': 'change_request.tooltip.rollback_plan',
            'ismsImpact': 'change_request.tooltip.isms_impact',
            'priority': 'change_request.tooltip.priority',
            'changeType': 'change_request.tooltip.change_type'
        },
        'translation_domain': 'change_requests',
        'actions': {
            'close': { 'label': 'common.cancel'|trans({}, 'messages'), 'variant': 'ghost' },
            'submit': { 'label': 'common.save'|trans({}, 'messages'), 'variant': 'primary' }
        }
    } %}

    {{ form_end(form) }}
</div>
{% endblock %}
