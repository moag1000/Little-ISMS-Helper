{% extends 'base.html.twig' %}
{% trans_default_domain 'change_requests' %}
{% import '_macros/cards.html.twig' as cards %}

{% block title %}{{ 'change_request.title'|trans({}, 'change_requests') }}{% endblock %}

{% block body %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.change_requests'|trans({}, 'nav') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'arrow-repeat', label: 'change_request.title'|trans({}, 'change_requests') },
        title: 'change_request.page.title'|trans({}, 'change_requests'),
        actions: [
            { label: 'change_request.action.create'|trans({}, 'change_requests'), href: path('app_change_request_new'), variant: 'primary', icon: 'plus-lg' }
        ]
    }) }}
    <main class="fa-aurora-surface">

    {% if statistics %}
    <div class="row mb-4">
        <div class="col-md-3">
            {{ cards.kpi_card('change_request.statistics.total'|trans({}, 'change_requests'), statistics.total, null, null, 'primary', null) }}
        </div>
        <div class="col-md-3">
            {{ cards.kpi_card('change_request.statistics.pending_approval'|trans({}, 'change_requests'), statistics.pending_approval, null, null, 'warning', null) }}
        </div>
        <div class="col-md-3">
            {{ cards.kpi_card('change_request.statistics.in_implementation'|trans({}, 'change_requests'), statistics.in_implementation, null, null, 'info', null) }}
        </div>
        <div class="col-md-3">
            {{ cards.kpi_card('change_request.statistics.overdue'|trans({}, 'change_requests'), statistics.overdue, null, null, 'danger', null) }}
        </div>
    </div>
    {% endif %}

    {% if pending_approval|length > 0 %}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info' } } %}
        {% block alert_body %}
            <div class="fw-bold mb-2">{{ 'change_request.alert.pending_approval'|trans({}, 'change_requests') }}</div>
            <ul class="mb-0">
                {% for change in pending_approval %}
                <li>
                    <a href="{{ path('app_change_request_show', {id: change.id}) }}">{{ change.changeNumber }} - {{ change.title }}</a>
                    ({{ ('change_request.priority.' ~ change.priority)|trans({}, 'change_requests') }})
                </li>
                {% endfor %}
            </ul>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {% if overdue|length > 0 %}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'danger' } } %}
        {% block alert_body %}
            <div class="fw-bold mb-2">{{ 'change_request.alert.overdue'|trans({}, 'change_requests') }}</div>
            <ul class="mb-0">
                {% for change in overdue %}
                <li>
                    <a href="{{ path('app_change_request_show', {id: change.id}) }}">{{ change.changeNumber }} - {{ change.title }}</a>
                </li>
                {% endfor %}
            </ul>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {% embed '_components/_card.html.twig' %}
        {% block card_header %}
            <div class="card-header">
                {%- set requestCount = change_requests|length -%}
                <h2>{{ 'change_request.list.title'|trans({'count': requestCount}, 'change_requests') }}</h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% if change_requests|length > 0 %}
            {% embed '_components/_table.html.twig' with {
                'wrapperClass': 'card-body',
                'noMargin': true
            } %}
                {% block table_head %}
                    <tr>
                        <th scope="col">{{ 'change_request.table.change_number'|trans({}, 'change_requests') }}</th>
                        <th scope="col">{{ 'change_request.table.title'|trans({}, 'change_requests') }}</th>
                        <th scope="col">{{ 'change_request.table.type'|trans({}, 'change_requests') }}</th>
                        <th scope="col">{{ 'change_request.table.priority'|trans({}, 'change_requests') }}</th>
                        <th scope="col">{{ 'change_request.table.status'|trans({}, 'change_requests') }}</th>
                        <th scope="col">{{ 'change_request.table.complexity'|trans({}, 'change_requests') }}</th>
                        <th scope="col">{{ 'change_request.table.requested'|trans({}, 'change_requests') }}</th>
                        <th scope="col">{{ 'change_request.table.actions'|trans({}, 'change_requests') }}</th>
                    </tr>
                {% endblock %}
                {% block table_body %}
                    {% for change in change_requests %}
                    <tr>
                        <td><a href="{{ path('app_change_request_show', {id: change.id}) }}">{{ change.changeNumber }}</a></td>
                        <td>{{ change.title|slice(0, 40) }}...</td>
                        <td><span class="badge badge-{{ change.changeType }}">{{ ('change_request.change_type.' ~ change.changeType)|trans({}, 'change_requests') }}</span></td>
                        <td><span class="badge badge-{{ change.priority }}">{{ ('change_request.priority.' ~ change.priority)|trans({}, 'change_requests') }}</span></td>
                        <td><span class="{{ badge_status(change.status) }}">{{ ('change_request.status.' ~ change.status)|trans({}, 'change_requests') }}</span></td>
                        <td>{{ change.getComplexityScore() }}</td>
                        <td>{{ change.requestedDate|date('Y-m-d') }}</td>
                        <td>
                            <a href="{{ path('app_change_request_show', {id: change.id}) }}" class="btn btn-sm btn-secondary">{{ 'change_request.action.view'|trans({}, 'change_requests') }}</a>
                            <a href="{{ path('app_change_request_edit', {id: change.id}) }}" class="btn btn-sm btn-primary">{{ 'change_request.action.edit'|trans({}, 'change_requests') }}</a>
                        </td>
                    </tr>
                    {% endfor %}
                {% endblock %}
            {% endembed %}
            {% else %}
            {{ _fa_empty_state.render({
                mood: 'sleeping',
                title: 'change_request.empty.message'|trans({}, 'change_requests'),
                actions: [
                    { label: 'change_request.empty.create_first'|trans({}, 'change_requests'), variant: 'primary', icon: 'plus-circle', href: path('app_change_request_new') }
                ]
            }) }}
            {% endif %}
        {% endblock %}
    {% endembed %}
    </main>
</div>

<style>
.stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-top: 1rem; }
.stat-item { display: flex; flex-direction: column; padding: 1rem; background: var(--surface-2); border-radius: 4px; }
.stat-label { font-size: 0.875rem; color: var(--fg-3); }
.stat-value { font-size: 1.5rem; font-weight: bold; color: var(--fg); }
.stat-value.warning { color: var(--warning); }
.stat-value.danger { color: var(--danger); }
</style>
{% endblock %}
