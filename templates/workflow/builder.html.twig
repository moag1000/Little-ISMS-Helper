{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_cyber_field.html.twig' as _fa_cyber %}

{% block title %}{{ 'workflow.builder.title'|trans({}, 'workflows') }} - {{ workflow.name }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .sortable-ghost {
            opacity: 0.4;
            background-color: var(--primary-tint);
        }
        .sortable-chosen {
            background-color: var(--surface-2);
        }
        .sortable-drag {
            opacity: 0.9;
        }
        .drag-handle {
            cursor: grab;
        }
        .drag-handle:active {
            cursor: grabbing;
        }
        .step-card {
            transition: transform 0.2s ease;
        }
        .step-card:hover {
            transform: translateX(5px);
        }
        .cursor-grab {
            cursor: grab;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_workflow_index') }}">{{ 'workflow.breadcrumb.home'|trans({}, 'workflows') }}</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('app_workflow_definitions') }}">{{ 'workflow.breadcrumb.definitions'|trans({}, 'workflows') }}</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('app_workflow_definition_show', {id: workflow.id}) }}">{{ workflow.name }}</a></li>
                    <li class="breadcrumb-item active">{{ 'workflow.builder.breadcrumb'|trans({}, 'workflows') }}</li>
                </ol>
            </nav>
            <h1>
                <i class="fa-icon fa-icon--nav-process" aria-hidden="true"></i> {{ 'workflow.builder.heading'|trans({}, 'workflows') }}
                <small class="text-muted">{{ workflow.name }}</small>
            </h1>
        </div>
        <div>
            <a href="{{ path('app_workflow_definition_show', {id: workflow.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                <i class="fa-icon fa-icon--util-arrow-left" aria-hidden="true"></i> {{ 'workflow.action.back'|trans({}, 'workflows') }}
            </a>
        </div>
    </div>

    {{ include('workflow/_steps_builder.html.twig', { workflow: workflow }) }}
</div>
{% endblock %}
