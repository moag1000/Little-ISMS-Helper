{% extends 'base.html.twig' %}
{% trans_default_domain 'workflows' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'workflow.title.active'|trans({}, 'workflows') }} - Little ISMS Helper{% endblock %}

{% block body %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{{ _fa_page_header.render({
    badge: { icon: 'nav-workflow', label: 'nav.workflows'|trans({}, 'nav') },
    title: 'workflow.title.active'|trans({}, 'workflows'),
    subtitle: 'workflow.description.active_detail'|trans({}, 'workflows'),
    actions: [
        { label: 'common.back'|trans({}, 'messages'), variant: 'ghost', icon: 'util-arrow-left', href: path('app_workflow_index') }
    ]
}) }}

{# Statistics Cards #}
<div class="kpi-grid">
    <div class="col-auto">
        {{ _fa_feature_card.render({ label: 'workflow.stats.active'|trans({}, 'workflows'), value: active_workflows|length, variant: 'info' }) }}
    </div>
    <div class="col-auto">
        {% set overdueCount = 0 %}
        {% for instance in active_workflows %}
            {% if instance.dueDate and instance.dueDate < date() and instance.status not in ['approved', 'rejected', 'cancelled'] %}
                {% set overdueCount = overdueCount + 1 %}
            {% endif %}
        {% endfor %}
        {{ _fa_feature_card.render({ label: 'workflow.stats.overdue'|trans({}, 'workflows'), value: overdueCount, variant: 'danger' }) }}
    </div>
    <div class="col-auto">
        {% set myCount = 0 %}
        {% for instance in active_workflows %}
            {% if instance.initiatedBy and instance.initiatedBy.id == app.user.id %}
                {% set myCount = myCount + 1 %}
            {% endif %}
        {% endfor %}
        {{ _fa_feature_card.render({ label: 'workflow.stats.my_workflows'|trans({}, 'workflows'), value: myCount, variant: 'success' }) }}
    </div>
</div>

{# Active Workflows Table #}
{% embed '_components/_table.html.twig' with {
    'wrapperClass': 'table-container',
    'noMargin': true
} %}
    {% block table_head %}
        <tr>
            <th scope="col">{{ 'workflow.field.entity'|trans({}, 'workflows') }}</th>
            <th scope="col">{{ 'workflow.field.workflow'|trans({}, 'workflows') }}</th>
            <th scope="col">{{ 'workflow.field.current_step'|trans({}, 'workflows') }}</th>
            <th scope="col">{{ 'workflow.field.status'|trans({}, 'workflows') }}</th>
            <th scope="col">{{ 'workflow.field.initiated_by'|trans({}, 'workflows') }}</th>
            <th scope="col">{{ 'workflow.field.due_date'|trans({}, 'workflows') }}</th>
            <th scope="col" class="text-center">{{ 'common.actions'|trans({}, 'messages') }}</th>
        </tr>
    {% endblock %}
    {% block table_body %}
        {% for instance in active_workflows %}
        {% set isOverdue = instance.dueDate and instance.dueDate < date() and instance.status not in ['approved', 'rejected', 'cancelled'] %}
        <tr{% if isOverdue %} class="table-danger"{% endif %}>
            <td>
                <strong>{{ instance.entityType|split('\\')|last }} #{{ instance.entityId }}</strong>
                {% if isOverdue %}
                    {% include '_components/_badge.html.twig' with { variant: 'danger', class: 'ms-1', content: 'workflow.badge.overdue'|trans({}, 'workflows') } %}
                {% endif %}
            </td>
            <td>
                {% include '_components/_badge.html.twig' with { variant: 'info', content: instance.workflow ? instance.workflow.name : '-' } %}
            </td>
            <td>{{ instance.currentStep ? instance.currentStep.name : '-' }}</td>
            <td>
                {% set statusColors = {
                    'pending': 'warning',
                    'in_progress': 'info',
                    'approved': 'success',
                    'rejected': 'danger',
                    'cancelled': 'secondary'
                } %}
                {% include '_components/_badge.html.twig' with { variant: statusColors[instance.status] ?? 'secondary', content: ('workflow.status.' ~ instance.status)|trans({}, 'workflows') } %}
            </td>
            <td>
                {% if instance.initiatedBy %}
                    {{ instance.initiatedBy.firstName ~ ' ' ~ instance.initiatedBy.lastName }}
                    {% if instance.initiatedBy.id == app.user.id %}
                        {% include '_components/_badge.html.twig' with { variant: 'success', class: 'ms-1', content: 'workflow.badge.my_task'|trans({}, 'workflows') } %}
                    {% endif %}
                {% else %}
                    <span class="text-muted">{{ 'workflow.message.unassigned'|trans({}, 'workflows') }}</span>
                {% endif %}
            </td>
            <td>
                {% if instance.dueDate %}
                    {{ instance.dueDate|date('d.m.Y') }}
                {% else %}
                    <span class="text-muted">-</span>
                {% endif %}
            </td>
            <td class="text-center">
                <div class="btn-group" role="group">
                    {% if instance.status in ['pending', 'in_progress'] and (userCanApprove[instance.id] ?? false) %}
                        <button type="button"
                                class="fa-cyber-btn fa-cyber-btn--success fa-cyber-btn--sm" data-controller="fa-modal-dispatcher" data-action="click->fa-modal-dispatcher#open" data-fa-modal-id="approveWorkflow{{ instance.id }}"
                                title="{{ 'workflow.widget.action.approve'|trans({}, 'workflows') }}">
                            <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i>
                        </button>
                        <button type="button"
                                class="fa-cyber-btn fa-cyber-btn--danger fa-cyber-btn--sm" data-controller="fa-modal-dispatcher" data-action="click->fa-modal-dispatcher#open" data-fa-modal-id="rejectWorkflow{{ instance.id }}"
                                title="{{ 'workflow.widget.action.reject'|trans({}, 'workflows') }}">
                            <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i>
                        </button>
                    {% endif %}
                    <a href="{{ path('app_workflow_instance_show', {id: instance.id}) }}"
                       class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
                       title="{{ 'common.view'|trans({}, 'messages') }}">
                        <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
                    </a>
                </div>
            </td>
        </tr>
        {% else %}
        <tr>
            <td colspan="7" class="text-center text-muted p-4">
                {{ 'workflow.message.no_active'|trans({}, 'workflows') }}
            </td>
        </tr>
        {% endfor %}
    {% endblock %}
{% endembed %}

{# Modals for Approve/Reject Actions #}
{% for instance in active_workflows %}
    {% if instance.status in ['pending', 'in_progress'] and (userCanApprove[instance.id] ?? false) %}
        {# Approve Modal #}
        <div class="fa-modal fa-modal--confirm fa-modal--success" id="approveWorkflow{{ instance.id }}"
     data-controller="fa-modal" data-fa-modal-mode-value="confirm" data-fa-modal-tone-value="success"
     role="alertdialog" aria-modal="true" aria-labelledby="approveWorkflow{{ instance.id }}Label" aria-hidden="true">
    <div class="fa-modal__backdrop" data-fa-modal-target="backdrop" data-action="click->fa-modal#backdropClick" aria-hidden="true"></div>
    <div class="fa-modal__container" data-fa-modal-target="dialog"><form method="post" action="{{ path('app_workflow_instance_approve', {id: instance.id}) }}" data-fa-modal-target="form">
                        <input type="hidden" name="_token" value="{{ csrf_token('approve' ~ instance.id) }}">
                        <div class="fa-modal__header-old">
                            <h2  id="approveWorkflow{{ instance.id }}Label" class="modal-title h5">
                                <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
                                {{ 'workflow.widget.action.approve'|trans({}, 'workflows') }}
                            </h2>
                            <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost" data-action="fa-modal#cancel"></button>
                        </div>
                        <div class="fa-modal__body">
                            <p>{{ 'workflow.widget.confirm.approve'|trans({workflow: instance.workflow.name}, 'workflows') }}</p>
                            {{ _fa_alert.render({ variant: 'info', class: 'mb-3', body: '<strong>' ~ 'workflow.field.entity'|trans({}, 'workflows') ~ ':</strong> ' ~ instance.entityType|split('\\')|last ~ ' #' ~ instance.entityId }) }}
                            <div class="mb-3">
                                <label class="form-label">
                                    {{ 'workflow.widget.field.comments'|trans({}, 'workflows') }}
                                    <span class="text-muted">({{ 'common.optional'|trans({}, 'messages') }})</span>
                                </label>
                                <textarea class="form-control fa-cyber-input__field" name="comments" rows="3"></textarea>
                            </div>
                        </div>
                        <footer class="fa-modal__footer">
                            <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost" data-action="fa-modal#cancel">{{ 'workflow.action.cancel'|trans({}, 'workflows') }}</button>
                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--success">
                                <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i>
                                {{ 'workflow.widget.action.approve'|trans({}, 'workflows') }}
                            </button>
                        </footer></form></div>
</div>

        {# Reject Modal #}
        <div class="fa-modal fa-modal--confirm fa-modal--danger" id="rejectWorkflow{{ instance.id }}"
     data-controller="fa-modal" data-fa-modal-mode-value="confirm" data-fa-modal-tone-value="danger"
     role="alertdialog" aria-modal="true" aria-labelledby="rejectWorkflow{{ instance.id }}Label" aria-hidden="true">
    <div class="fa-modal__backdrop" data-fa-modal-target="backdrop" data-action="click->fa-modal#backdropClick" aria-hidden="true"></div>
    <div class="fa-modal__container" data-fa-modal-target="dialog"><form method="post" action="{{ path('app_workflow_instance_reject', {id: instance.id}) }}" data-fa-modal-target="form">
                        <input type="hidden" name="_token" value="{{ csrf_token('reject' ~ instance.id) }}">
                        <header class="fa-modal__header"><span class="fa-modal__icon" aria-hidden="true"><i class="fa-icon fa-icon--status-critical"></i></span><div class="fa-modal__heading"><h2  id="rejectWorkflow{{ instance.id }}Label" class="fa-modal__title">
                                {{ 'workflow.widget.action.reject'|trans({}, 'workflows') }}
                            </h2></div><button type="button" class="fa-modal__close" data-action="fa-modal#cancel" aria-label="Close"><i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i></button></header>
                        <div class="fa-modal__body">
                            <p>{{ 'workflow.widget.confirm.reject'|trans({workflow: instance.workflow.name}, 'workflows') }}</p>
                            {{ _fa_alert.render({ variant: 'warning', class: 'mb-3', body: '<strong>' ~ 'workflow.field.entity'|trans({}, 'workflows') ~ ':</strong> ' ~ instance.entityType|split('\\')|last ~ ' #' ~ instance.entityId }) }}
                            <div class="mb-3">
                                <label class="form-label">
                                    {{ 'workflow.widget.field.reason'|trans({}, 'workflows') }}
                                    <span class="text-danger">*</span>
                                </label>
                                <textarea class="form-control fa-cyber-input__field" name="comments" rows="4" required></textarea>
                            </div>
                        </div>
                        <footer class="fa-modal__footer">
                            <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost" data-action="fa-modal#cancel">{{ 'workflow.action.cancel'|trans({}, 'workflows') }}</button>
                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger">
                                <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i>
                                {{ 'workflow.widget.action.reject'|trans({}, 'workflows') }}
                            </button>
                        </footer></form></div>
</div>
    {% endif %}
{% endfor %}

{% endblock %}
