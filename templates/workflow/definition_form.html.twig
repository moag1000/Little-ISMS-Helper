{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block title %}
    {{ is_edit ? 'workflow.definition.edit_title'|trans({}, 'workflows') : 'workflow.definition.new_title'|trans({}, 'workflows') }}
{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-lg-8 offset-lg-2">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_workflow_index') }}">{{ 'workflow.breadcrumb.home'|trans({}, 'workflows') }}</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('app_workflow_definitions') }}">{{ 'workflow.breadcrumb.definitions'|trans({}, 'workflows') }}</a></li>
                    {% if is_edit %}
                        <li class="breadcrumb-item"><a href="{{ path('app_workflow_definition_show', {id: workflow.id}) }}">{{ workflow.name }}</a></li>
                        <li class="breadcrumb-item active">{{ 'workflow.breadcrumb.edit'|trans({}, 'workflows') }}</li>
                    {% else %}
                        <li class="breadcrumb-item active">{{ 'workflow.breadcrumb.new'|trans({}, 'workflows') }}</li>
                    {% endif %}
                </ol>
            </nav>

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>
                    <i class="bi bi-{{ is_edit ? 'pencil' : 'plus-circle' }}" aria-hidden="true"></i>
                    {{ is_edit ? 'workflow.definition.edit_title'|trans({}, 'workflows') : 'workflow.definition.new_title'|trans({}, 'workflows') }}
                </h1>
            </div>

            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header">
                        <h2 class="mb-0">
                            <i class="fa-icon fa-icon--nav-process" aria-hidden="true"></i> {{ 'workflow.section.basic_information'|trans({}, 'workflows') }}
                        </h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {% import '_components/_fa_alert.html.twig' as _fa_alert %}
                    {{ form_start(form) }}

                    {{ form_row(form.name) }}
                    {{ form_row(form.description) }}
                    {{ form_row(form.entityType) }}
                    {{ form_row(form.isActive) }}

                    {{ form_rest(form) }}

                    {% if not is_edit %}
                        {{ _fa_alert.render({ variant: 'info', title: 'workflow.info.steps_note_title'|trans({}, 'workflows'), body: 'workflow.info.steps_note_text'|trans({}, 'workflows') }) }}
                    {% endif %}

                    <div class="d-flex justify-content-between mt-4">
                        <a href="{{ is_edit ? path('app_workflow_definition_show', {id: workflow.id}) : path('app_workflow_definitions') }}"
                           class="fa-cyber-btn fa-cyber-btn--ghost">
                            <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i> {{ 'common.cancel'|trans({}, 'messages') }}
                        </a>
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                            <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
                            {{ is_edit ? 'workflow.action.update'|trans({}, 'workflows') : 'workflow.action.create'|trans({}, 'workflows') }}
                        </button>
                    </div>

                    {{ form_end(form) }}
                {% endblock %}
            {% endembed %}
        </div>
    </div>{# /col-lg-8 row — basic-info form ends here #}

    {# ------------------------------------------------------------------ #}
    {# Step builder — edit mode only, rendered AFTER the form is closed    #}
    {# No HTML form nesting: the add-step <form> inside the partial is a   #}
    {# sibling of the basic-info <form>, not nested inside it.             #}
    {# ------------------------------------------------------------------ #}
    {% if is_edit %}
        <div class="mt-4">
            <h2 class="mb-3">
                <i class="fa-icon fa-icon--nav-list-check" aria-hidden="true"></i>
                {{ 'workflow.section.steps_builder'|trans({}, 'workflows') }}
            </h2>
            <p class="text-muted mb-0">{{ 'workflow.help.steps_builder_intro'|trans({}, 'workflows') }}</p>
        </div>

        {{ include('workflow/_steps_builder.html.twig', { workflow: workflow }) }}

        <div class="row mt-4">
            <div class="col-lg-8 offset-lg-2">
                {% embed '_components/_card.html.twig' with { 'class': 'mt-2' } %}
                    {% block card_header %}
                        <div class="card-header">
                            <h2 class="mb-0">
                                <i class="fa-icon fa-icon--status-warning text-warning" aria-hidden="true"></i> {{ 'workflow.section.danger_zone'|trans({}, 'workflows') }}
                            </h2>
                        </div>
                    {% endblock %}
                    {% block card_body %}
                        <p class="text-muted">{{ 'workflow.help.delete_warning'|trans({}, 'workflows') }}</p>
                        <form method="post" action="{{ path('app_workflow_definition_delete', {id: workflow.id}) }}"
                              data-controller="ui-actions"
                              data-action="submit->ui-actions#confirm"
                              data-ui-actions-message-param="{{ 'workflow.confirm.delete'|trans({}, 'workflows') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ workflow.id) }}">
                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger">
                                <i class="fa-icon fa-icon--ui-trash" aria-hidden="true"></i> {{ 'workflow.action.delete_definition'|trans({}, 'workflows') }}
                            </button>
                        </form>
                    {% endblock %}
                {% endembed %}
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
