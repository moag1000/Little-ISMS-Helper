{% extends 'base.html.twig' %}
{% trans_default_domain 'workflows' %}

{% block title %}{{ 'workflow.title.overdue'|trans({}, 'workflows') }} - Little ISMS Helper{% endblock %}

{% block body %}
{% import '_macros/cards.html.twig' as cards %}
{% import '_macros/workflow.html.twig' as workflow_macros %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

<div class="page-header">
    <div>
        <h1>{{ 'workflow.title.overdue'|trans({}, 'workflows') }}</h1>
        <p class="text-muted">{{ 'workflow.description.overdue_detail'|trans({}, 'workflows') }}</p>
    </div>
    <div class="button-group">
        <a href="{{ path('app_workflow_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
            <i class="fa-icon fa-icon--util-arrow-left" aria-hidden="true"></i> {{ 'common.back'|trans({}, 'messages') }}
        </a>
    </div>
</div>

{# Alert Banner #}
{% if overdue_workflows|length > 0 %}
{{ _fa_alert.render({ variant: 'danger', class: 'mb-4', body: '<p><strong>' ~ 'workflow.warning.overdue_count'|trans({'%count%': overdue_workflows|length}, 'workflows') ~ '</strong></p><p class="mb-0">' ~ 'workflow.warning.overdue_message'|trans({}, 'workflows') ~ '</p>' }) }}
{% endif %}

{# Statistics Cards #}
<div class="kpi-grid">
    <div class="col-auto">
        {{ cards.kpi_card('workflow.stats.overdue'|trans({}, 'workflows'), overdue_workflows|length, null, null, 'danger', 'border-danger') }}
    </div>
    <div class="col-auto">
        {% set myOverdue = 0 %}
        {% for instance in overdue_workflows %}
            {% if instance.initiatedBy and instance.initiatedBy.id == app.user.id %}
                {% set myOverdue = myOverdue + 1 %}
            {% endif %}
        {% endfor %}
        {{ cards.kpi_card('workflow.stats.my_overdue'|trans({}, 'workflows'), myOverdue, null, null, 'warning', null) }}
    </div>
    <div class="col-auto">
        {% set totalDaysOverdue = 0 %}
        {% for instance in overdue_workflows %}
            {% if instance.dueDate %}
                {% set daysOverdue = ('now'|date('U') - instance.dueDate.timestamp) / 86400 %}
                {% set totalDaysOverdue = totalDaysOverdue + daysOverdue %}
            {% endif %}
        {% endfor %}
        {{ cards.kpi_card('workflow.stats.overdue_days_avg'|trans({}, 'workflows'), overdue_workflows|length > 0 ? (totalDaysOverdue / overdue_workflows|length)|round : 0, null, null, 'info', null) }}
    </div>
    <div class="col-auto">
        {% set criticalOverdue = 0 %}
        {% for instance in overdue_workflows %}
            {% if instance.dueDate %}
                {% set daysOverdue = ('now'|date('U') - instance.dueDate.timestamp) / 86400 %}
                {% if daysOverdue > 7 %}
                    {% set criticalOverdue = criticalOverdue + 1 %}
                {% endif %}
            {% endif %}
        {% endfor %}
        {{ cards.kpi_card('workflow.stats.critical_overdue'|trans({}, 'workflows'), criticalOverdue, null, null, 'danger', null) }}
    </div>
</div>

{# Overdue Workflows Table #}
{% embed '_components/_table.html.twig' with {
    'wrapperClass': 'table-container',
    'noMargin': true
} %}
    {% block table_head %}
        <tr>
            <th scope="col">{{ 'workflow.field.entity'|trans({}, 'workflows') }}</th>
            <th scope="col">{{ 'workflow.field.workflow'|trans({}, 'workflows') }}</th>
            <th scope="col">{{ 'workflow.field.current_step'|trans({}, 'workflows') }}</th>
            <th scope="col">{{ 'workflow.field.status'|trans({}, 'workflows') }}</th>
            <th scope="col">{{ 'workflow.field.initiated_by'|trans({}, 'workflows') }}</th>
            <th scope="col">{{ 'workflow.field.due_date'|trans({}, 'workflows') }}</th>
            <th scope="col" class="text-center">{{ 'workflow.field.days_overdue'|trans({}, 'workflows') }}</th>
            <th scope="col" class="text-center">{{ 'common.actions'|trans({}, 'messages') }}</th>
        </tr>
    {% endblock %}
    {% block table_body %}
        {% for instance in overdue_workflows %}
        {% set daysOverdue = instance.dueDate ? (('now'|date('U') - instance.dueDate.timestamp) / 86400)|round : 0 %}
        <tr class="{% if daysOverdue > 7 %}table-danger{% else %}table-warning{% endif %}">
            <td>
                <strong>{{ instance.entityType|split('\\')|last }} #{{ instance.entityId }}</strong>
                {% if daysOverdue > 7 %}
                    {% include '_components/_badge.html.twig' with { variant: 'danger', class: 'ms-1', content: 'workflow.badge.critical'|trans({}, 'workflows') } %}
                {% endif %}
            </td>
            <td>
                {% include '_components/_badge.html.twig' with { variant: 'info', content: instance.workflow ? instance.workflow.name : '-' } %}
            </td>
            <td>{{ instance.currentStep ? instance.currentStep.name : '-' }}</td>
            <td>
                {% set statusColors = {
                    'pending': 'warning',
                    'in_progress': 'info',
                    'approved': 'success',
                    'rejected': 'danger',
                    'cancelled': 'secondary'
                } %}
                {% include '_components/_badge.html.twig' with { variant: statusColors[instance.status] ?? 'secondary', content: ('workflow.status.' ~ instance.status)|trans({}, 'workflows') } %}
            </td>
            <td>
                {% if instance.initiatedBy %}
                    {{ instance.initiatedBy.firstName ~ ' ' ~ instance.initiatedBy.lastName }}
                    {% if instance.initiatedBy.id == app.user.id %}
                        {% include '_components/_badge.html.twig' with { variant: 'success', class: 'ms-1', content: 'workflow.badge.my_task'|trans({}, 'workflows') } %}
                    {% endif %}
                {% else %}
                    <span class="text-muted">{{ 'workflow.message.unassigned'|trans({}, 'workflows') }}</span>
                {% endif %}
            </td>
            <td>
                {% if instance.dueDate %}
                    {{ instance.dueDate|date('d.m.Y H:i') }}
                {% else %}
                    <span class="text-muted">-</span>
                {% endif %}
            </td>
            <td class="text-center">
                {% include '_components/_badge.html.twig' with { variant: 'danger', class: 'fw-bold', content: daysOverdue ~ ' ' ~ 'workflow.days'|trans({}, 'workflows') } %}
            </td>
            <td class="text-center">
                <div class="btn-group" role="group">
                    {% if instance.status in ['pending', 'in_progress'] and (userCanApprove[instance.id] ?? false) %}
                        <button type="button"
                                class="fa-cyber-btn fa-cyber-btn--success fa-cyber-btn--sm"
                                data-bs-toggle="modal"
                                data-bs-target="#approveWorkflow{{ instance.id }}"
                                title="{{ 'workflow.widget.action.approve'|trans({}, 'workflows') }}">
                            <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i>
                        </button>
                        <button type="button"
                                class="fa-cyber-btn fa-cyber-btn--danger fa-cyber-btn--sm"
                                data-bs-toggle="modal"
                                data-bs-target="#rejectWorkflow{{ instance.id }}"
                                title="{{ 'workflow.widget.action.reject'|trans({}, 'workflows') }}">
                            <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i>
                        </button>
                    {% endif %}
                    <a href="{{ path('app_workflow_instance_show', {id: instance.id}) }}"
                       class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
                       title="{{ 'common.view'|trans({}, 'messages') }}">
                        <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
                    </a>
                </div>
            </td>
        </tr>
        {% else %}
        <tr>
            <td colspan="8" class="text-center text-muted p-4">
                <div class="fs-2 mb-2"><i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i></div>
                <p><strong>{{ 'workflow.message.no_overdue'|trans({}, 'workflows') }}</strong></p>
                <p class="text-muted mb-0">
                    {{ 'workflow.message.no_overdue_desc'|trans({}, 'workflows') }}
                </p>
            </td>
        </tr>
        {% endfor %}
    {% endblock %}
{% endembed %}

{# Modals for Approve/Reject Actions #}
{% for instance in overdue_workflows %}
    {% if instance.status in ['pending', 'in_progress'] and (userCanApprove[instance.id] ?? false) %}
        {# Approve Modal #}
        <div class="modal fade" id="approveWorkflow{{ instance.id }}" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <form method="post" action="{{ path('app_workflow_instance_approve', {id: instance.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('approve' ~ instance.id) }}">
                        <div class="modal-header">
                            <h2 class="modal-title h5">
                                <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
                                {{ 'workflow.widget.action.approve'|trans({}, 'workflows') }}
                            </h2>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'common.close'|trans({}, 'messages') }}"></button>
                        </div>
                        <div class="modal-body">
                            <p>{{ 'workflow.widget.confirm.approve'|trans({workflow: instance.workflow.name}, 'workflows') }}</p>
                            {{ _fa_alert.render({ variant: 'info', class: 'mb-3', body: '<strong>' ~ 'workflow.field.entity'|trans({}, 'workflows') ~ ':</strong> ' ~ instance.entityType|split('\\')|last ~ ' #' ~ instance.entityId }) }}
                            <div class="mb-3">
                                <label class="form-label">
                                    {{ 'workflow.widget.field.comments'|trans({}, 'workflows') }}
                                    <span class="text-muted">({{ 'common.optional'|trans({}, 'messages') }})</span>
                                </label>
                                <textarea class="form-control" name="comments" rows="3"></textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost" data-bs-dismiss="modal">
                                {{ 'workflow.action.cancel'|trans({}, 'workflows') }}
                            </button>
                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--success">
                                <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i>
                                {{ 'workflow.widget.action.approve'|trans({}, 'workflows') }}
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        {# Reject Modal #}
        <div class="modal fade" id="rejectWorkflow{{ instance.id }}" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <form method="post" action="{{ path('app_workflow_instance_reject', {id: instance.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('reject' ~ instance.id) }}">
                        <div class="modal-header bg-danger text-white">
                            <h2 class="modal-title h5">
                                <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i>
                                {{ 'workflow.widget.action.reject'|trans({}, 'workflows') }}
                            </h2>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <p>{{ 'workflow.widget.confirm.reject'|trans({workflow: instance.workflow.name}, 'workflows') }}</p>
                            {{ _fa_alert.render({ variant: 'warning', class: 'mb-3', body: '<strong>' ~ 'workflow.field.entity'|trans({}, 'workflows') ~ ':</strong> ' ~ instance.entityType|split('\\')|last ~ ' #' ~ instance.entityId }) }}
                            <div class="mb-3">
                                <label class="form-label">
                                    {{ 'workflow.widget.field.reason'|trans({}, 'workflows') }}
                                    <span class="text-danger">*</span>
                                </label>
                                <textarea class="form-control" name="comments" rows="4" required></textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost" data-bs-dismiss="modal">
                                {{ 'workflow.action.cancel'|trans({}, 'workflows') }}
                            </button>
                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger">
                                <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i>
                                {{ 'workflow.widget.action.reject'|trans({}, 'workflows') }}
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    {% endif %}
{% endfor %}

{% endblock %}
