{#
 # Reusable step-builder partial — include with { workflow: workflow }
 # Used by: workflow/builder.html.twig (standalone page)
 #          workflow/definition_form.html.twig (embedded in edit view)
 #
 # NOTE: uses {% embed %}, so macro imports are repeated inside each embed block.
 # NOTE: no outer <form> wrapping — the add-step form inside is self-contained
 #       and must remain a sibling of (not nested inside) the basic-info form.
 #}
{% trans_default_domain 'workflows' %}

<div class="row mt-4">
    <div class="col-lg-8">
        {# Main Builder Area #}
        {% embed '_components/_card.html.twig' %}
            {% block card_attrs %}data-controller="workflow-builder"
             data-workflow-builder-workflow-id-value="{{ workflow.id }}"
             data-workflow-builder-api-url-value="/api/workflow"
             data-workflow-builder-csrf-token-value="{{ csrf_token('workflow_api') }}"
             data-workflow-builder-edit-title-value="{{ 'workflow.builder.action.edit'|trans({}, 'workflows') }}"
             data-workflow-builder-duplicate-title-value="{{ 'workflow.builder.action.duplicate'|trans({}, 'workflows') }}"
             data-workflow-builder-delete-title-value="{{ 'workflow.builder.action.delete'|trans({}, 'workflows') }}"{% endblock %}
            {% block card_header %}
                {# Notifications #}
                <div data-workflow-builder-target="notification"></div>
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h2 class="mb-0">
                        <i class="fa-icon fa-icon--nav-list-check" aria-hidden="true"></i> {{ 'workflow.builder.steps'|trans({}, 'workflows') }}
                    </h2>
                    <div class="d-flex align-items-center">
                        <span data-workflow-builder-target="loadingSpinner" class="spinner-border spinner-border-sm me-2 d-none" role="status">
                            <span class="visually-hidden">{{ 'common.loading'|trans({}, 'messages') }}</span>
                        </span>
                        {% include '_components/_badge.html.twig' with { variant: 'primary', pill: true, content: workflow.steps is defined and workflow.steps ? workflow.steps|length : 0 } %}
                    </div>
                </div>
            {% endblock %}
            {% block card_body %}
                {% import '_components/_fa_alert.html.twig' as _fa_alert %}
                <div class="mb-3">
                    {{ _fa_alert.render({ variant: 'info', dismissible: true, body: 'workflow.builder.drag_help'|trans({}, 'workflows') }) }}
                </div>

                {# Steps List - Dynamic Content #}
                <div data-workflow-builder-target="stepsList" class="steps-container">
                    {# Steps will be loaded dynamically #}
                </div>
            {% endblock %}
            {% block card_footer %}
                <div class="card-footer">
                    <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost" data-bs-toggle="collapse" data-bs-target="#addStepForm">
                        <i class="fa-icon fa-icon--ui-plus" aria-hidden="true"></i> {{ 'workflow.builder.add_step'|trans({}, 'workflows') }}
                    </button>
                </div>
            {% endblock %}
        {% endembed %}

        {# Add Step Form (collapsible) — standalone <form>, NOT nested inside any parent form #}
        <div class="collapse mt-3" id="addStepForm">
            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header">
                        <h2 class="mb-0">
                            <i class="fa-icon fa-icon--ui-plus" aria-hidden="true"></i> {{ 'workflow.builder.new_step'|trans({}, 'workflows') }}
                        </h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {% import '_components/_fa_cyber_field.html.twig' as _fa_cyber %}
                    <form data-action="submit->workflow-builder#addStep" data-workflow-builder-target="stepForm">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ _fa_cyber.text('name', {
                                    id: 'stepName',
                                    label: 'workflow.step.name'|trans({}, 'workflows'),
                                    required: true,
                                    max: 255
                                }) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="stepType" class="form-label">{{ 'workflow.step.type'|trans({}, 'workflows') }} *</label>
                                <select class="form-select fa-cyber-input__field" id="stepType" name="stepType" required>
                                    <option value="approval">{{ 'workflow.step.type.approval'|trans({}, 'workflows') }}</option>
                                    <option value="notification">{{ 'workflow.step.type.notification'|trans({}, 'workflows') }}</option>
                                    <option value="auto_action">{{ 'workflow.step.type.auto_action'|trans({}, 'workflows') }}</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="stepDescription" class="form-label">{{ 'workflow.step.description'|trans({}, 'workflows') }}</label>
                            <textarea class="form-control fa-cyber-input__field" id="stepDescription" name="description" rows="2"></textarea>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="approverRole" class="form-label">{{ 'workflow.step.approver_role'|trans({}, 'workflows') }}</label>
                                <select class="form-select fa-cyber-input__field" id="approverRole" name="approverRole">
                                    <option value="">{{ 'common.select'|trans({}, 'messages') }}</option>
                                    <option value="ROLE_USER">{{ 'role.user'|trans({}, 'role_management') }}</option>
                                    <option value="ROLE_MANAGER">{{ 'role.manager'|trans({}, 'role_management') }}</option>
                                    <option value="ROLE_ISO_OFFICER">{{ 'role.iso_officer'|trans({}, 'role_management') }}</option>
                                    <option value="ROLE_RISK_MANAGER">{{ 'role.risk_manager'|trans({}, 'role_management') }}</option>
                                    <option value="ROLE_AUDITOR">{{ 'role.auditor'|trans({}, 'role_management') }}</option>
                                    <option value="ROLE_ADMIN">{{ 'role.admin'|trans({}, 'role_management') }}</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ _fa_cyber.text('daysToComplete', {
                                    id: 'daysToComplete',
                                    type: 'number',
                                    label: 'workflow.step.days_to_complete'|trans({}, 'workflows'),
                                    help: 'workflow.step.days_help'|trans({}, 'workflows'),
                                    extra_attrs: {'min': '1', 'max': '365'}
                                }) }}
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="isRequired" name="isRequired" checked>
                                <label class="form-check-label" for="isRequired">
                                    {{ 'workflow.step.is_required'|trans({}, 'workflows') }}
                                </label>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--success">
                                <i class="fa-icon fa-icon--ui-plus" aria-hidden="true"></i> {{ 'workflow.builder.add_step'|trans({}, 'workflows') }}
                            </button>
                            <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost" data-bs-toggle="collapse" data-bs-target="#addStepForm">
                                {{ 'common.cancel'|trans({}, 'messages') }}
                            </button>
                        </div>
                    </form>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    <div class="col-lg-4">
        {# Templates #}
        {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
            {% block card_header %}
                <div class="card-header">
                    <h2 class="mb-0">
                        <i class="fa-icon fa-icon--threat" aria-hidden="true"></i> {{ 'workflow.builder.templates'|trans({}, 'workflows') }}
                    </h2>
                </div>
            {% endblock %}
            {% block card_body %}
                <p class="text-muted small">{{ 'workflow.builder.templates_help'|trans({}, 'workflows') }}</p>
                <div class="d-grid gap-2">
                    <button class="fa-cyber-btn fa-cyber-btn--ghost text-start"
                            data-action="click->workflow-builder#applyTemplate"
                            data-template-key="risk_assessment">
                        <i class="fa-icon fa-icon--breach me-2" aria-hidden="true"></i>
                        <strong>{{ 'workflow.template.risk_assessment'|trans({}, 'workflows') }}</strong>
                        <br>
                        <small class="text-muted">{{ 'workflow.template.risk_assessment_desc'|trans({}, 'workflows') }}</small>
                    </button>
                    <button class="fa-cyber-btn fa-cyber-btn--success text-start"
                            data-action="click->workflow-builder#applyTemplate"
                            data-template-key="control_implementation">
                        <i class="fa-icon fa-icon--nav-sliders me-2" aria-hidden="true"></i>
                        <strong>{{ 'workflow.template.control_implementation'|trans({}, 'workflows') }}</strong>
                        <br>
                        <small class="text-muted">{{ 'workflow.template.control_implementation_desc'|trans({}, 'workflows') }}</small>
                    </button>
                    <button class="fa-cyber-btn fa-cyber-btn--danger text-start"
                            data-action="click->workflow-builder#applyTemplate"
                            data-template-key="incident_response">
                        <i class="fa-icon fa-icon--status-warning me-2" aria-hidden="true"></i>
                        <strong>{{ 'workflow.template.incident_response'|trans({}, 'workflows') }}</strong>
                        <br>
                        <small class="text-muted">{{ 'workflow.template.incident_response_desc'|trans({}, 'workflows') }}</small>
                    </button>
                    <button class="fa-cyber-btn fa-cyber-btn--warning text-start"
                            data-action="click->workflow-builder#applyTemplate"
                            data-template-key="document_review">
                        <i class="fa-icon fa-icon--policy me-2" aria-hidden="true"></i>
                        <strong>{{ 'workflow.template.document_review'|trans({}, 'workflows') }}</strong>
                        <br>
                        <small class="text-muted">{{ 'workflow.template.document_review_desc'|trans({}, 'workflows') }}</small>
                    </button>
                    <button class="fa-cyber-btn fa-cyber-btn--ghost text-start"
                            data-action="click->workflow-builder#applyTemplate"
                            data-template-key="change_request">
                        <i class="fa-icon fa-icon--nav-workflow me-2" aria-hidden="true"></i>
                        <strong>{{ 'workflow.template.change_request'|trans({}, 'workflows') }}</strong>
                        <br>
                        <small class="text-muted">{{ 'workflow.template.change_request_desc'|trans({}, 'workflows') }}</small>
                    </button>
                </div>
            {% endblock %}
        {% endembed %}

        {# Workflow Info #}
        {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
            {% block card_header %}
                <div class="card-header">
                    <h2 class="mb-0">
                        <i class="fa-icon fa-icon--ui-info" aria-hidden="true"></i> {{ 'workflow.builder.info'|trans({}, 'workflows') }}
                    </h2>
                </div>
            {% endblock %}
            {% block card_body %}
                <dl class="row mb-0">
                    <dt class="col-sm-5">{{ 'workflow.field.name'|trans({}, 'workflows') }}</dt>
                    <dd class="col-sm-7">{{ workflow.name }}</dd>

                    <dt class="col-sm-5">{{ 'workflow.field.entity_type'|trans({}, 'workflows') }}</dt>
                    <dd class="col-sm-7">{% include '_components/_badge.html.twig' with { variant: 'info', content: workflow.entityType } %}</dd>

                    <dt class="col-sm-5">{{ 'workflow.field.status'|trans({}, 'workflows') }}</dt>
                    <dd class="col-sm-7">
                        {% if workflow.isActive %}
                            {% include '_components/_badge.html.twig' with { variant: 'success', content: 'workflow.status.active'|trans({}, 'workflows') } %}
                        {% else %}
                            {% include '_components/_badge.html.twig' with { variant: 'secondary', content: 'workflow.status.inactive'|trans({}, 'workflows') } %}
                        {% endif %}
                    </dd>

                    <dt class="col-sm-5">{{ 'workflow.field.created_at'|trans({}, 'workflows') }}</dt>
                    <dd class="col-sm-7">{{ workflow.createdAt ? workflow.createdAt|date('d.m.Y') : 'N/A' }}</dd>
                </dl>
            {% endblock %}
        {% endembed %}

        {# Help #}
        {% embed '_components/_card.html.twig' %}
            {% block card_header %}
                <div class="card-header bg-body-secondary">
                    <h2 class="mb-0">
                        <i class="fa-icon fa-icon--nav-help" aria-hidden="true"></i> {{ 'workflow.builder.help'|trans({}, 'workflows') }}
                    </h2>
                </div>
            {% endblock %}
            {% block card_body %}
                <ul class="list-unstyled mb-0 small">
                    <li class="mb-2">
                        <i class="fa-icon fa-icon--util-drag-handle me-1" aria-hidden="true"></i>
                        {{ 'workflow.builder.help_drag'|trans({}, 'workflows') }}
                    </li>
                    <li class="mb-2">
                        <i class="fa-icon fa-icon--ui-edit text-primary me-1" aria-hidden="true"></i>
                        {{ 'workflow.builder.help_edit'|trans({}, 'workflows') }}
                    </li>
                    <li class="mb-2">
                        <i class="fa-icon text-secondary me-1 fa-icon--ui-copy" aria-hidden="true"></i>
                        {{ 'workflow.builder.help_duplicate'|trans({}, 'workflows') }}
                    </li>
                    <li class="mb-2">
                        <i class="fa-icon fa-icon--ui-trash text-danger me-1" aria-hidden="true"></i>
                        {{ 'workflow.builder.help_delete'|trans({}, 'workflows') }}
                    </li>
                    <li>
                        <i class="fa-icon fa-icon--threat fa-icon--info me-1" aria-hidden="true"></i>
                        {{ 'workflow.builder.help_template'|trans({}, 'workflows') }}
                    </li>
                </ul>
            {% endblock %}
        {% endembed %}
    </div>
</div>
