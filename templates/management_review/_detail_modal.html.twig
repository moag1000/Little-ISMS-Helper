{# ManagementReview read-only detail — rendered inside the fa-form-modal Turbo Frame.
   Uses the drawer chrome (header/body/footer/kv) which renders cleanly as a
   flex column; condensed ISO 9.3 key fields, with a "Vollansicht" link to the full page. #}
{% trans_default_domain 'management_review' %}
{% set statusClass = {
    'planned': 'warning',
    'in_progress': 'info',
    'completed': 'success',
    'cancelled': 'danger',
    'follow_up_required': 'warning'
} %}
<turbo-frame id="fa-form-modal">
    <div class="fa-drawer__header">
        <div class="fa-drawer__header-text">
            <div class="fa-drawer__eyebrow">ISO 27001 Cl. 9.3 · Management Review</div>
            <div class="fa-drawer__title">{{ review.title }}</div>
        </div>
        <button type="button" class="fa-drawer__close" data-action="fa-form-modal#close"
                aria-label="{{ 'common.close'|trans({}, 'messages') }}">
            <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i>
        </button>
    </div>
    <div class="fa-drawer__body">
        <div class="fa-drawer__section">
            {% include '_components/_badge.html.twig' with {
                variant: statusClass[review.status] ?? 'secondary',
                content: ('management_review.status.' ~ review.status)|trans({}, 'management_review')
            } %}
        </div>

        <div class="fa-drawer__kv">
            <span class="label">{{ 'management_review.field.review_date'|trans({}, 'management_review') }}</span>
            <span>{{ review.reviewDate|date('d.m.Y') }}</span>
        </div>

        {% if review.reviewedBy %}
            <div class="fa-drawer__kv">
                <span class="label">{{ 'management_review.field.reviewed_by'|trans({}, 'management_review') }}</span>
                <span>{{ review.reviewedBy.firstName }} {{ review.reviewedBy.lastName }}</span>
            </div>
        {% elseif review.reviewedByPerson %}
            <div class="fa-drawer__kv">
                <span class="label">{{ 'management_review.field.reviewed_by_person'|trans({}, 'management_review') }}</span>
                <span>{{ review.reviewedByPerson.fullName }}</span>
            </div>
        {% endif %}

        {% if review.participants|length > 0 %}
            <div class="fa-drawer__kv">
                <span class="label">{{ 'management_review.field.participants'|trans({}, 'management_review') }}</span>
                <span>
                    <i class="fa-icon fa-icon--group" aria-hidden="true"></i>
                    {% include '_components/_badge.html.twig' with { variant: 'primary', content: review.participants|length } %}
                </span>
            </div>
        {% endif %}

        {% if review.decisions %}
            <div class="fa-drawer__section">
                <span class="label">{{ 'management_review.field.decisions'|trans({}, 'management_review') }}</span>
                <p class="fa-drawer__desc">{{ review.decisions|u.truncate(280, '…') }}</p>
            </div>
        {% endif %}

        {% if review.actionItems %}
            <div class="fa-drawer__section">
                <span class="label">{{ 'management_review.field.action_items'|trans({}, 'management_review') }}</span>
                <p class="fa-drawer__desc">{{ review.actionItems|u.truncate(280, '…') }}</p>
            </div>
        {% endif %}

        <div class="fa-drawer__section">
            <a href="{{ path('app_management_review_show', {id: review.id, _locale: app.request.locale}) }}"
               data-turbo="false"
               class="fa-row-link">
                {{ 'common.open_full_view'|trans({}, 'messages') }} →
            </a>
        </div>
    </div>
    <div class="fa-drawer__footer" style="display:flex;gap:10px;justify-content:flex-end">
        <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--md" data-action="fa-form-modal#close">
            <span class="fa-cyber-btn__label">{{ 'common.close'|trans({}, 'messages') }}</span>
        </button>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_management_review_edit', {id: review.id, _locale: app.request.locale}) }}"
               data-turbo-frame="fa-form-modal"
               class="fa-cyber-btn fa-cyber-btn--md">
                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                <span class="fa-cyber-btn__label">{{ 'common.edit'|trans({}, 'messages') }}</span>
            </a>
        {% endif %}
    </div>
</turbo-frame>
