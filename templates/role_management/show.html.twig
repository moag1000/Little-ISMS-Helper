{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'role_management' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_kpi_card.html.twig' as _fa_kpi_card %}

{% block title %}{{ role.name }} - {{ 'role_management.title.show'|trans({}, 'role_management') }} - Little ISMS Helper{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('role_management_index') }}">{{ 'nav.roles'|trans({}, 'nav') }}</a></li>
    <li class="breadcrumb-item active">{{ role.name }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'shield-lock', label: role.systemRole ? 'role_management.badge.system'|trans({}, 'role_management') : 'role_management.badge.custom'|trans({}, 'role_management') },
        title: role.name,
        actions: [
            { label: 'common.edit'|trans({}, 'messages'), variant: 'primary', icon: 'pencil', href: path('role_management_edit', {id: role.id}) },
            { label: 'common.back_to_list'|trans({}, 'messages'), variant: 'ghost', icon: 'arrow-left', href: path('role_management_index') }
        ]
    }) }}

    {# Stats #}
    <div class="row g-3 mb-4">
        <div class="col-md-4">{{ _fa_kpi_card.render({ value: role.users|length, label: 'role_management.field.users'|trans({}, 'role_management') }) }}</div>
        <div class="col-md-4">{{ _fa_kpi_card.render({ value: role.permissions|length, label: 'role_management.field.permissions'|trans({}, 'role_management') }) }}</div>
        <div class="col-md-4">{{ _fa_kpi_card.render({ value: role.systemRole ? 'System' : 'Custom', label: 'role_management.field.type'|trans({}, 'role_management') }) }}</div>
    </div>

    {# Description #}
    {% if role.description %}
        <section class="fa-section mb-4">
            <div class="fa-section__header">
                <h2 class="fa-section__title">{{ 'role_management.field.description'|trans({}, 'role_management') }}</h2>
            </div>
            <div class="fa-section__body">
                <p class="pre-wrap mb-0">{{ role.description }}</p>
            </div>
        </section>
    {% endif %}

    {# Permissions #}
    <section class="fa-section mb-4">
        <div class="fa-section__header">
            <h2 class="fa-section__title">
                <i class="fa-icon fa-icon--ui-key" aria-hidden="true"></i>
                {{ 'role_management.section.permissions'|trans({}, 'role_management') }}
                <span class="badge bg-secondary ms-2">{{ role.permissions|length }}</span>
            </h2>
        </div>
        <div class="fa-section__body">
            {% if role.permissions|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th scope="col">{{ 'role_management.permission.name'|trans({}, 'role_management') }}</th>
                                <th scope="col">{{ 'role_management.permission.resource'|trans({}, 'role_management') }}</th>
                                <th scope="col">{{ 'role_management.permission.action'|trans({}, 'role_management') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for permission in role.permissions %}
                                <tr>
                                    <td><strong>{{ permission.name }}</strong></td>
                                    <td><span class="badge bg-info">{{ permission.resource }}</span></td>
                                    <td><span class="badge bg-secondary">{{ permission.action }}</span></td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <p class="text-muted mb-0">{{ 'role_management.message.no_permissions'|trans({}, 'role_management') }}</p>
            {% endif %}
        </div>
    </section>

    {# Assigned Users #}
    <section class="fa-section mb-4">
        <div class="fa-section__header">
            <h2 class="fa-section__title">
                <i class="fa-icon fa-icon--group" aria-hidden="true"></i>
                {{ 'role_management.section.users'|trans({}, 'role_management') }}
                <span class="badge bg-secondary ms-2">{{ role.users|length }}</span>
            </h2>
        </div>
        <div class="fa-section__body">
            {% if role.users|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th scope="col">{{ 'role_management.user.name'|trans({}, 'role_management') }}</th>
                                <th scope="col">{{ 'role_management.user.email'|trans({}, 'role_management') }}</th>
                                <th scope="col">{{ 'role_management.user.assigned_date'|trans({}, 'role_management') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for user in role.users %}
                                <tr>
                                    <td><strong>{{ user.fullName }}</strong></td>
                                    <td>{{ user.email|default('-') }}</td>
                                    <td>{{ user.roleAssignedAt|date('d.m.Y H:i') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <p class="text-muted mb-0">{{ 'role_management.message.no_users'|trans({}, 'role_management') }}</p>
            {% endif %}
        </div>
    </section>

    {# Action Buttons #}
    <div class="d-flex gap-2 mt-4">
        <a href="{{ path('role_management_edit', {id: role.id}) }}" class="fa-cyber-btn fa-cyber-btn--primary">
            <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i> {{ 'common.edit'|trans({}, 'messages') }}
        </a>
        <a href="{{ path('role_management_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
            <i class="fa-icon fa-icon--ui-list" aria-hidden="true"></i> {{ 'common.back_to_list'|trans({}, 'messages') }}
        </a>
        {% if not role.systemRole %}
            <form method="post" action="{{ path('role_management_delete', {id: role.id}) }}" class="d-inline"
                  data-controller="ui-actions"
                  data-action="submit->ui-actions#confirm"
                  data-ui-actions-message-param="{{ 'role_management.confirm.delete'|trans({}, 'role_management') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ role.id) }}">
                <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger">
                    <i class="fa-icon fa-icon--ui-trash" aria-hidden="true"></i> {{ 'common.delete'|trans({}, 'messages') }}
                </button>
            </form>
        {% endif %}
    </div>
{% endblock admin_content %}
