{% extends 'admin/layout.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'role.templates.title'|trans({}, 'role_management') }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('role_management_index') }}">{{ 'nav.roles'|trans({}, 'nav') }}</a></li>
    <li class="breadcrumb-item active">{{ 'role.templates.title'|trans({}, 'role_management') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'nav-collection', label: 'role.templates.title'|trans({}, 'role_management') },
        title: 'role.templates.title'|trans({}, 'role_management'),
        actions: [
            { label: 'common.back'|trans({}, 'messages'), variant: 'ghost', icon: 'util-arrow-left', href: path('role_management_index') }
        ]
    }) }}

    {# Description #}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', class: 'mb-4' } } %}
        {% block alert_body %}
        <strong>{{ 'role.templates.description'|trans({}, 'role_management') }}</strong>
        <p class="mb-0 mt-2">
            Wählen Sie eine vordefinierte Rollenvorlage aus und passen Sie optional den Namen an.
            Die Vorlage enthält bereits eine sinnvolle Kombination von Berechtigungen für den jeweiligen Anwendungsfall.
        </p>
        {% endblock %}
    {% endembed %}

    {# Template Cards #}
    <div class="row">
        {% for key, template in templates %}
            <div class="col-md-6 col-lg-4 mb-4">
                <section class="fa-section h-100">
                    <div class="fa-section__header">
                        <h2 class="fa-section__title">
                            {% if key == 'auditor' %}
                                <i class="fa-icon fa-icon--ui-search" aria-hidden="true"></i>
                            {% elseif key == 'risk_manager' %}
                                <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i>
                            {% elseif key == 'compliance_officer' %}
                                <i class="fa-icon fa-icon--ui-copy" aria-hidden="true"></i>
                            {% elseif key == 'incident_manager' %}
                                <i class="fa-icon fa-icon--nav-shield-alert" aria-hidden="true"></i>
                            {% elseif key == 'asset_manager' %}
                                <i class="fa-icon fa-icon--nav-hdd" aria-hidden="true"></i>
                            {% elseif key == 'readonly' %}
                                <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
                            {% endif %}
                            {{ template.name }}
                        </h2>
                    </div>
                    <div class="fa-section__body">
                        <p>{{ template.description }}</p>

                        <h3 class="h6 mt-3 mb-2">Berechtigungen:</h3>
                        <div class="permissions-list" style="max-height: 200px; overflow-y: auto;">
                            {% for permission in template.permissions %}
                                <div class="mb-1">
                                    <code class="small">{{ permission }}</code>
                                </div>
                            {% endfor %}
                        </div>

                        <div class="mt-3">
                            <span class="fa-status-pill fa-status-pill--neutral">{{ template.permissions|length }} Berechtigungen</span>
                        </div>
                    </div>
                    <div class="fa-section__footer">
                        <button type="button"
                                class="fa-cyber-btn fa-cyber-btn--primary w-100"
                                data-bs-toggle="modal"
                                data-bs-target="#templateModal{{ key }}">
                            <i class="fa-icon fa-icon--ui-plus" aria-hidden="true"></i> Vorlage verwenden
                        </button>
                    </div>
                </section>
            </div>

            {# Modal for template application #}
            <div  class="modal fade" aria-labelledby="templateModal{{ key }}Label"  id="templateModal{{ key }}" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form method="post">
                            <input type="hidden" name="_token" value="{{ csrf_token('role_template_apply') }}">
                            <div class="modal-header">
                                <h4  id="templateModal{{ key }}Label" class="modal-title h5">{{ template.name }} erstellen</h4>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'action.close'|trans({}, 'messages') }}"></button>
                            </div>
                            <div class="modal-body">
                                <input type="hidden" name="template" value="{{ key }}">

                                <div class="mb-3">
                                    <label for="custom_name_{{ key }}" class="form-label">
                                        {{ 'role.templates.custom_name'|trans({}, 'role_management') }}
                                    </label>
                                    <input type="text"
                                           class="form-control fa-cyber-input__field"
                                           id="custom_name_{{ key }}"
                                           name="custom_name"
                                           placeholder="{{ template.name }}">
                                    <div class="form-text">
                                        Leer lassen, um den Standard-Namen "{{ template.name }}" zu verwenden
                                    </div>
                                </div>

                                {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info' } } %}
                                    {% block alert_body %}
                                    <strong>Diese Vorlage enthält:</strong>
                                    <ul class="mb-0 mt-2">
                                        {% for permission in template.permissions|slice(0, 5) %}
                                            <li><code>{{ permission }}</code></li>
                                        {% endfor %}
                                        {% if template.permissions|length > 5 %}
                                            <li class="text-muted">
                                                und {{ template.permissions|length - 5 }} weitere...
                                            </li>
                                        {% endif %}
                                    </ul>
                                    {% endblock %}
                                {% endembed %}
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost" data-bs-dismiss="modal">
                                    {{ 'common.cancel'|trans({}, 'messages') }}
                                </button>
                                <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                                    <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i> Rolle erstellen
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    {# Info Box #}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning', class: 'mt-4' } } %}
        {% block alert_body %}
        <div class="fa-alert__title">Wichtige Hinweise</div>
        <ul class="mb-0">
            <li>Die erstellte Rolle kann nach der Erstellung angepasst werden</li>
            <li>Fehlende Berechtigungen werden übersprungen (z.B. wenn sie noch nicht existieren)</li>
            <li>Die Rolle wird als benutzerdefinierte Rolle (nicht System-Rolle) erstellt</li>
            <li>Nach der Erstellung können Sie Berechtigungen hinzufügen oder entfernen</li>
        </ul>
        {% endblock %}
    {% endembed %}

<style>
.permissions-list {
    background-color: var(--surface-2);
    padding: 0.5rem;
    border-radius: 0.25rem;
}
</style>
{% endblock admin_content %}
