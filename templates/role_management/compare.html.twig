{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'role_management' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'role.compare.title'|trans }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('role_management_index') }}">{{ 'nav.roles'|trans({}, 'nav') }}</a></li>
    <li class="breadcrumb-item active">{{ 'role.compare.title'|trans }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'columns-gap', label: 'role.compare.title'|trans },
        title: 'role.compare.title'|trans,
        actions: [
            { label: 'common.back'|trans({}, 'messages'), variant: 'ghost', icon: 'arrow-left', href: path('role_management_index') }
        ]
    }) }}

    {# Role Selection #}
    <section class="fa-section mb-4">
        <div class="fa-section__header">
            <h2 class="fa-section__title">
                <i class="fa-icon fa-icon--ui-funnel" aria-hidden="true"></i>
                {{ 'role.compare.select_roles'|trans }}
            </h2>
        </div>
        <div class="fa-section__body">
            <form method="get">
                <div class="row g-3">
                    <div class="col-md-10">
                        <label class="form-label" for="role-select">{{ 'role.compare.select_label'|trans }}</label>
                        <select name="roles[]" id="role-select" class="form-select fa-cyber-input__field" multiple size="8" required>
                            {% for role in all_roles %}
                                <option value="{{ role.id }}" {{ role.id in selected_role_ids ? 'selected' : '' }}>
                                    {{ role.name }}
                                    {% if role.isSystemRole %}({{ 'role.compare.system_badge'|trans }}){% endif %}
                                </option>
                            {% endfor %}
                        </select>
                        <div class="form-text">{{ 'role.compare.select_hint'|trans }}</div>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary w-100">
                            <i class="fa-icon fa-icon--nav-workflow" aria-hidden="true"></i>
                            {{ 'role.compare.submit'|trans }}
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </section>

    {% if roles|length > 0 %}
        {# Comparison Matrix #}
        <section class="fa-section mb-4">
            <div class="fa-section__header">
                <h3 class="fa-section__title">
                    <i class="fa-icon fa-icon--nav-grid" aria-hidden="true"></i>
                    {{ 'role.compare.permission_matrix'|trans }}
                </h3>
            </div>
            <div class="fa-section__body">
                {% embed '_components/_fa_table.html.twig' with { hover: true, stickyHead: true } %}
                    {% block table_head %}
                        {% trans_default_domain 'role_management' %}
                        <tr>
                            <th scope="col" class="fa-table__th" style="width: 30%">{{ 'role.compare.permission_column'|trans }}</th>
                            {% for role in roles %}
                                <th scope="col" class="fa-table__th fa-table__th--center" style="width: {{ 70 / roles|length }}%">
                                    <div>{{ role.name }}</div>
                                    {% if role.isSystemRole %}
                                        <span class="fa-status-pill fa-status-pill--warning">{{ 'role.compare.system_badge'|trans }}</span>
                                    {% endif %}
                                </th>
                            {% endfor %}
                        </tr>
                    {% endblock %}
                    {% block table_body %}
                        {% set current_category = null %}
                        {% for permission_id, data in comparison_matrix %}
                            {% if current_category != data.category %}
                                {% set current_category = data.category %}
                                <tr class="fa-table__row bg-body-secondary">
                                    <td colspan="{{ roles|length + 1 }}" class="fa-table__cell fw-bold">
                                        <i class="fa-icon fa-icon--nav-collection" aria-hidden="true"></i> {{ data.category|title }}
                                    </td>
                                </tr>
                            {% endif %}
                            <tr class="fa-table__row">
                                <td class="fa-table__cell">
                                    <code>{{ data.permission.name }}</code>
                                    <br>
                                    <small class="text-muted">{{ data.permission.description }}</small>
                                </td>
                                {% for role in roles %}
                                    {% set has_permission = data.roles[role.id] ?? false %}
                                    <td class="fa-table__cell fa-table__cell--center {{ has_permission ? 'table-success' : 'table-light' }}">
                                        {% if has_permission %}
                                            <i class="fa-icon fa-icon--ui-check text-success fs-4" aria-hidden="true"></i>
                                        {% else %}
                                            <i class="fa-icon fa-icon--status-critical fs-4" aria-hidden="true"></i>
                                        {% endif %}
                                    </td>
                                {% endfor %}
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            </div>
        </section>

        {# Legend #}
        <section class="fa-section">
            <div class="fa-section__body">
                <h4 class="h6 mb-3">{{ 'role.compare.legend_title'|trans }}</h4>
                <div class="d-flex gap-4">
                    <div>
                        <i class="fa-icon fa-icon--ui-check text-success" aria-hidden="true"></i>
                        {{ 'role.compare.has_permission'|trans }}
                    </div>
                    <div>
                        <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i>
                        {{ 'role.compare.no_permission'|trans }}
                    </div>
                </div>
            </div>
        </section>
    {% else %}
        {{ _fa_alert.render({ variant: 'info', body: 'role.compare.select_prompt'|trans }) }}
    {% endif %}
{% endblock admin_content %}
