{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'role_management.title.list'|trans({}, 'role_management') }} - Little ISMS Helper{% endblock %}

{% block admin_content %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}
{% import '_components/_status_pill.html.twig' as pill %}

{% include '_components/_breadcrumb.html.twig' with {
    breadcrumbs: [
        { label: 'nav.admin'|trans({}, 'nav'), url: path('admin_dashboard') },
        { label: 'nav.roles'|trans({}, 'nav') }
    ]
} %}

{{ _fa_page_header.render({
    badge: { icon: 'shield-lock', label: 'nav.roles'|trans({}, 'nav') },
    title: 'role_management.title.list'|trans({}, 'role_management'),
    subtitle: 'role_management.description.overview'|trans({}, 'role_management'),
    actions: [
        { label: 'role_management.action.create'|trans({}, 'role_management'), variant: 'primary', icon: 'plus-lg', href: path('role_management_new') }
    ]
}) }}

<main class="fa-aurora-surface">

{# Statistics Cards #}
<div class="kpi-grid">
    <div class="col-auto">
        {{ _fa_feature_card.render({ label: 'role_management.stats.total'|trans({}, 'role_management'), value: roles|length, variant: 'primary' }) }}
    </div>
    <div class="col-auto">
        {{ _fa_feature_card.render({ label: 'role_management.stats.system_roles'|trans({}, 'role_management'), value: roles|filter(r => r.systemRole)|length, variant: 'info' }) }}
    </div>
    <div class="col-auto">
        {{ _fa_feature_card.render({ label: 'role_management.stats.with_users'|trans({}, 'role_management'), value: roles|filter(r => r.users|length > 0)|length, variant: 'success' }) }}
    </div>
    <div class="col-auto">
        {% set totalPerms = 0 %}
        {% for role in roles %}
            {% set totalPerms = totalPerms + role.permissions|length %}
        {% endfor %}
        {{ _fa_feature_card.render({ label: 'role_management.stats.avg_permissions'|trans({}, 'role_management'), value: roles|length > 0 ? (totalPerms / roles|length)|round : 0, variant: 'warning' }) }}
    </div>
</div>

{# Roles Table #}
<section class="fa-section">
    <div class="fa-section__body">
        {% embed '_components/_fa_table.html.twig' with { hover: true } %}
            {% block table_head %}
                <tr>
                    <th scope="col" class="fa-table__th">{{ 'role_management.field.name'|trans({}, 'role_management') }}</th>
                    <th scope="col" class="fa-table__th">{{ 'role_management.field.description'|trans({}, 'role_management') }}</th>
                    <th scope="col" class="fa-table__th fa-table__th--center">{{ 'role_management.field.permissions'|trans({}, 'role_management') }}</th>
                    <th scope="col" class="fa-table__th fa-table__th--center">{{ 'role_management.field.users'|trans({}, 'role_management') }}</th>
                    <th scope="col" class="fa-table__th fa-table__th--center">{{ 'role_management.field.type'|trans({}, 'role_management') }}</th>
                    <th scope="col" class="fa-table__th fa-table__th--actions">{{ 'common.actions'|trans({}, 'messages') }}</th>
                </tr>
            {% endblock %}
            {% block table_body %}
                {% import '_components/_status_pill.html.twig' as pill %}
                {% for role in roles %}
                <tr class="fa-table__row">
                    <td class="fa-table__cell">
                        <strong>{{ role.name }}</strong>
                        {% if role.systemRole %}
                            {{ pill.render('role_management.badge.system'|trans({}, 'role_management'), 'primary', {class: 'ms-1'}) }}
                        {% endif %}
                    </td>
                    <td class="fa-table__cell">
                        <small class="text-muted-color">
                            {{ role.description|default('-') }}
                        </small>
                    </td>
                    <td class="fa-table__cell fa-table__cell--center">
                        {{ pill.render(role.permissions|length, 'neutral') }}
                    </td>
                    <td class="fa-table__cell fa-table__cell--center">
                        {{ pill.render(role.users|length, 'primary') }}
                    </td>
                    <td class="fa-table__cell fa-table__cell--center">
                        {% if role.systemRole %}
                            {{ pill.render('role_management.type.system'|trans({}, 'role_management'), 'primary') }}
                        {% else %}
                            {{ pill.render('role_management.type.custom'|trans({}, 'role_management'), 'neutral') }}
                        {% endif %}
                    </td>
                    <td class="fa-table__cell fa-table__cell--actions">
                        <div class="btn-group btn-group-sm" role="group" aria-label="{{ 'role_management.aria.actions_for_role'|trans({'%name%': role.name}, 'role_management') }}">
                            <a href="{{ path('role_management_show', {id: role.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                                👁 {{ 'common.view'|trans({}, 'messages') }}
                            </a>
                            <a href="{{ path('role_management_edit', {id: role.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i> {{ 'common.edit'|trans({}, 'messages') }}
                            </a>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="6" class="fa-table__cell text-center text-muted">
                        {{ 'role_management.message.no_roles'|trans({}, 'role_management') }}
                    </td>
                </tr>
                {% endfor %}
            {% endblock %}
        {% endembed %}
    </div>
</section>
</main>
{% endblock admin_content %}
