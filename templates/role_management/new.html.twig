{% extends 'admin/layout.html.twig' %}
{% trans_default_domain 'role_management' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'role_management.title.create'|trans({}, 'role_management')}} - Little ISMS Helper{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item"><a href="{{ path('role_management_index') }}">{{ 'nav.roles'|trans({}, 'nav') }}</a></li>
    <li class="breadcrumb-item active">{{ 'role_management.title.create'|trans({}, 'role_management') }}</li>
{% endblock %}

{% block admin_content %}
    {{ _fa_page_header.render({
        badge: { icon: 'nav-shield-lock', label: 'role_management.title.create'|trans({}, 'role_management') },
        title: 'role_management.title.create'|trans({}, 'role_management'),
        actions: [
            { label: 'role_management.action.compare'|trans({}, 'role_management'), variant: 'ghost', icon: 'util-arrow-left', href: path('role_management_compare') },
            { label: 'common.back_to_list'|trans({}, 'messages'), variant: 'ghost', icon: 'util-arrow-left', href: path('role_management_index') }
        ]
    }) }}

    <div class="fa-alert fa-alert--info mb-3" role="alert">
        <i class="fa-alert__icon fa-icon fa-icon--ui-info" aria-hidden="true"></i>
        <div class="fa-alert__body">
            <span class="fa-alert__message">
                {{ 'role_management.help.compare_before_create'|trans({}, 'role_management') }}
                <a href="{{ path('role_management_compare') }}" class="alert-link">{{ 'role_management.action.compare'|trans({}, 'role_management') }}</a>
            </span>
        </div>
    </div>

    <section class="fa-section">
        <div class="fa-section__body">
            {{ form_start(form, {'action': path('role_management_new')}) }}

                {% include '_components/_auto_form.html.twig' with {
                    'form': form,
                    'sections': {
                        'basic_info': {
                            'label': 'role_management.section.basic_info'|trans({}, 'role_management'),
                            'fields': ['name', 'description', 'isSystemRole']
                        }
                    },
                    'exclude': ['permissions'],
                    'translation_domain': 'role_management'
                } %}

                {# Rich permissions table — replaces flat checkbox list #}
                <fieldset class="mb-4">
                    <legend class="h5 mb-3">{{ 'role_management.section.permissions'|trans({}, 'role_management') }}</legend>
                    <p class="text-muted small mb-3">{{ 'role_management.help.permissions'|trans({}, 'role_management') }}</p>
                    {% include 'role_management/_permissions_rich_table.html.twig' with {
                        form_field: form.permissions
                    } %}
                    {{ form_errors(form.permissions) }}
                </fieldset>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--success">
                        <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i> {{ 'common.create'|trans({}, 'messages') }}
                    </button>
                    <a href="{{ path('role_management_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                        <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i> {{ 'common.cancel'|trans({}, 'messages') }}
                    </a>
                </div>

            {{ form_row(form._token) }}
            {{ form_end(form, {render_rest: false}) }}
        </div>
    </section>
{% endblock admin_content %}
