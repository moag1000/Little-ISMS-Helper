{# BC-Plan create/edit rendered inside the fa-form-modal Turbo Frame.
   Explicit form action (the document URL stays on the list). On valid submit the
   controller returns a Turbo Stream (row replace/append). #}
{% trans_default_domain 'bc_plans' %}
{% set is_edit = bc_plan is defined and bc_plan and bc_plan.id is not null %}
{% set form_action = is_edit ? path('app_bc_plan_edit', { id: bc_plan.id }) : path('app_bc_plan_new') %}
<turbo-frame id="fa-form-modal">
    {{ form_start(form, { action: form_action, method: 'POST', attr: {
        id: 'business-continuity-plan-modal-form',
        'data-turbo-frame': 'fa-form-modal'
    } }) }}
    {% include 'business_continuity_plan/_form_body.html.twig' with {
        form: form,
        modal: true,
        title: is_edit ? bc_plan.name : 'bc_plans.action.add_new'|trans({}, 'bc_plans'),
        actions: {
            close: { label: 'common.cancel'|trans({}, 'messages'), variant: 'ghost', action: 'fa-form-modal#close' },
            submit: { label: 'common.save'|trans({}, 'messages'), variant: 'primary' }
        }
    } %}
    {{ form_end(form) }}
</turbo-frame>
