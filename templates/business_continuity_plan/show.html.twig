{% extends 'base.html.twig' %}
{% trans_default_domain 'bc_plans' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ bc_plan.name }}{% endblock %}

{% block body %}
{% import '_components/_fa_alva_hint.html.twig' as _fa_alva_hint %}
<div class="container">
    {# Lifecycle Y.5 — status transition dropdown (business_continuity_plan_lifecycle) #}
    {% include '_components/_lifecycle_toolbar.html.twig' with {
        entity: bc_plan,
        entity_type: 'business-continuity-plan',
        workflow_name: 'business_continuity_plan_lifecycle'
    } only %}
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.bcm'|trans({}, 'nav'), url: path('app_bcm_index') },
            { label: 'nav.bc_plans'|trans({}, 'nav'), url: path('app_bc_plan_index') },
            { label: bc_plan.name }
        ]
    } %}

    {% set hint = alva_hint(bc_plan) %}
    {% if hint %}{{ _fa_alva_hint.render(hint) }}{% endif %}

    {{ _fa_page_header.render({
        badge: { icon: 'shield-check', label: ('bc_plans.status.' ~ bc_plan.status)|trans({}, 'bc_plans') },
        title: bc_plan.name,
        actions: [
            { label: 'common.edit'|trans({}, 'messages'), variant: 'primary', icon: 'ui-edit', href: path('app_bc_plan_edit', {id: bc_plan.id}) },
            { label: 'common.back_to_list'|trans({}, 'messages'), variant: 'ghost', href: path('app_bc_plan_index') }
        ]
    }) }}

    {# Inline POST-delete kept below header (cannot be expressed via _fa_page_header GET-only actions) #}
    {% if is_granted('ROLE_ADMIN') %}
        <div class="d-flex justify-content-end mb-3">
            <form method="post" action="{{ path('app_bc_plan_delete', {id: bc_plan.id}) }}" class="d-inline"
                  data-controller="ui-actions"
                  data-action="submit->ui-actions#confirm"
                  data-ui-actions-message-param="{{ 'common.confirm_delete'|trans({}, 'messages') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ bc_plan.id) }}">
                <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger"><i class="fa-icon fa-icon--ui-trash" aria-hidden="true"></i> {{ 'common.delete'|trans({}, 'messages') }}</button>
            </form>
        </div>
    {% endif %}

    {% embed '_components/_card.html.twig' %}
        {% block card_header %}
            <div class="card-header">
                <h2>{{ 'bc_plans.section.details'|trans({}, 'bc_plans') }}</h2>
                <span class="{{ badge_status(bc_plan.status) }}">{{ ('bc_plans.status.' ~ bc_plan.status)|trans({}, 'bc_plans') }}</span>
            </div>
        {% endblock %}
        {% block card_body %}
            {% import '_components/_fa_alert.html.twig' as _fa_alert %}
            {% set readiness = bc_plan.getReadinessScore() %}
            {% set readinessVariant = readiness >= 80 ? 'success' : (readiness >= 60 ? 'info' : 'warning') %}
            {{ _fa_alert.render({ variant: readinessVariant, body: '<strong>' ~ 'bc_plans.message.readiness_score'|trans({'%score%': readiness}, 'bc_plans') ~ '</strong>' }) }}

            <div class="detail-grid">
                <div class="detail-item">
                    <span class="label">{{ 'bc_plans.field.business_process'|trans({}, 'bc_plans') }}:</span>
                    <span class="value"><a href="{{ path('app_business_process_show', {id: bc_plan.businessProcess.id}) }}">{{ bc_plan.businessProcess.name }}</a></span>
                </div>
                <div class="detail-item">
                    <span class="label">{{ 'bc_plans.field.plan_owner'|trans({}, 'bc_plans') }}:</span>
                    <span class="value">{{ bc_plan.effectivePlanOwner }}</span>
                </div>
                <div class="detail-item">
                    <span class="label">{{ 'bc_plans.field.version'|trans({}, 'bc_plans') }}:</span>
                    <span class="value">{{ bc_plan.version }}</span>
                </div>
            </div>

            {% if bc_plan.description %}
            <div class="detail-section">
                <h3>{{ 'common.description'|trans({}, 'messages') }}</h3>
                <p>{{ bc_plan.description }}</p>
            </div>
            {% endif %}

            <div class="detail-section">
                <h3>{{ 'bcm.field.activation_criteria'|trans({}, 'bc_plans') }}</h3>
                <p>{{ bc_plan.activationCriteria }}</p>
            </div>

            <div class="detail-section">
                <h3>{{ 'bcm.field.recovery_plan'|trans({}, 'bc_plans') }}</h3>
                <p>{{ bc_plan.recoveryProcedures|nl2br }}</p>
            </div>

            {% if bc_plan.rolesAndResponsibilities %}
            <div class="detail-section">
                <h3>{{ 'common.roles_and_responsibilities'|trans({}, 'messages') }}</h3>
                <p>{{ bc_plan.rolesAndResponsibilities|nl2br }}</p>
            </div>
            {% endif %}

            {% if bc_plan.bcTeam %}
            <div class="detail-section">
                <h3>{{ 'common.team_members'|trans({}, 'messages') }}</h3>
                <p>{{ bc_plan.bcTeam|nl2br }}</p>
            </div>
            {% endif %}

            <div class="detail-section">
                <h3>{{ 'bc_plans.section.testing_review'|trans({}, 'bc_plans') }}</h3>
                <div class="detail-grid">
                    <div class="detail-item">
                        <span class="label">{{ 'bc_plans.field.last_tested'|trans({}, 'bc_plans') }}:</span>
                        <span class="value">{{ bc_plan.lastTested ? bc_plan.lastTested|date('Y-m-d') : ('bc_plans.message.never'|trans({}, 'bc_plans')) }}</span>
                    </div>
                    <div class="detail-item">
                        <span class="label">{{ 'bc_plans.field.next_test'|trans({}, 'bc_plans') }}:</span>
                        <span class="value {{ bc_plan.isTestOverdue() ? 'text-danger' : '' }}">
                            {{ bc_plan.nextTestDate ? bc_plan.nextTestDate|date('Y-m-d') : ('bc_plans.message.not_scheduled'|trans({}, 'bc_plans')) }}
                            {{ bc_plan.isTestOverdue() ? ('bc_plans.badge.overdue'|trans({}, 'bc_plans')) : '' }}
                        </span>
                    </div>
                    <div class="detail-item">
                        <span class="label">{{ 'bc_plans.field.last_review'|trans({}, 'bc_plans') }}:</span>
                        <span class="value">{{ bc_plan.lastReviewDate ? bc_plan.lastReviewDate|date('Y-m-d') : ('bc_plans.message.never'|trans({}, 'bc_plans')) }}</span>
                    </div>
                    <div class="detail-item">
                        <span class="label">{{ 'bc_plans.field.next_review'|trans({}, 'bc_plans') }}:</span>
                        <span class="value {{ bc_plan.isReviewOverdue() ? 'text-danger' : '' }}">
                            {{ bc_plan.nextReviewDate ? bc_plan.nextReviewDate|date('Y-m-d') : ('bc_plans.message.not_scheduled'|trans({}, 'bc_plans')) }}
                            {{ bc_plan.isReviewOverdue() ? ('bc_plans.badge.overdue'|trans({}, 'bc_plans')) : '' }}
                        </span>
                    </div>
                </div>
            </div>

            {% if bc_plan.reviewNotes %}
            <div class="detail-section">
                <h3>{{ 'bc_plans.section.review_notes'|trans({}, 'bc_plans') }}</h3>
                <p>{{ bc_plan.reviewNotes }}</p>
            </div>
            {% endif %}

            {% if bc_plan.communicationPlan %}
            <div class="detail-section">
                <h3>{{ 'bc_plans.section.communication_plan'|trans({}, 'bc_plans') }}</h3>
                <p>{{ bc_plan.communicationPlan|nl2br }}</p>
            </div>
            {% endif %}

            {% if bc_plan.alternativeSite %}
            <div class="detail-section">
                <h3>{{ 'bc_plans.section.alternative_site'|trans({}, 'bc_plans') }}</h3>
                <p>{{ bc_plan.alternativeSite }}</p>
                {% if bc_plan.alternativeSiteAddress %}
                    <p><strong>{{ 'bc_plans.field.address'|trans({}, 'bc_plans') }}:</strong> {{ bc_plan.alternativeSiteAddress }}</p>
                {% endif %}
                {% if bc_plan.alternativeSiteCapacity %}
                    <p><strong>{{ 'bc_plans.field.capacity'|trans({}, 'bc_plans') }}:</strong> {{ bc_plan.alternativeSiteCapacity }}</p>
                {% endif %}
            </div>
            {% endif %}

            {% if bc_plan.businessProcess and bc_plan.businessProcess.identifiedRisks|length > 0 %}
            <div class="detail-section">
                <h3>{{ 'bc_plans.section.related_risks'|trans({}, 'bc_plans') }} ({{ bc_plan.businessProcess.identifiedRisks|length }})</h3>
                <ul>
                    {% for risk in bc_plan.businessProcess.identifiedRisks %}
                    <li><a href="{{ path('app_risk_show', {id: risk.id}) }}">{{ risk.title }}</a></li>
                    {% endfor %}
                </ul>
            </div>
            {% endif %}
        {% endblock %}
    {% endembed %}
</div>

<style>
.text-danger { color: var(--danger); font-weight: bold; }
</style>
{% endblock %}
