{% extends 'base.html.twig' %}
{% trans_default_domain 'bc_plans' %}

{% block title %}{{ 'bc_plans.page.title'|trans({}, 'bc_plans') }}{% endblock %}

{% block body %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.bcm'|trans({}, 'nav'), url: path('app_bcm_index') },
            { label: 'nav.bc_plans'|trans({}, 'nav') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'shield-check', label: 'bc_plans.page.title'|trans({}, 'bc_plans') },
        title: 'bc_plans.page.header'|trans({}, 'bc_plans'),
        subtitle: 'bc_plans.page.subtitle'|trans({}, 'bc_plans'),
        actions: [
            { label: 'bc_plans.action.add_new'|trans({}, 'bc_plans'), href: path('app_bc_plan_new'), variant: 'primary', icon: 'plus-circle' }
        ]
    }) }}
    <main class="fa-aurora-surface">

    {% if overdue_tests|length > 0 %}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning' } } %}
        {% block alert_body %}
            <div class="fa-alert__title">{{ 'bc_plans.alert.overdue_tests'|trans({}, 'bc_plans') }}</div>
            <ul class="mb-0">
                {% for plan in overdue_tests %}
                <li>
                    <a href="{{ path('app_bc_plan_show', {id: plan.id}) }}">{{ plan.name }}</a>
                    - {{ 'bc_plans.field.next_test'|trans({}, 'bc_plans') }}: {{ plan.nextTestDate ? plan.nextTestDate|date('Y-m-d') : ('bc_plans.message.not_scheduled'|trans({}, 'bc_plans')) }}
                </li>
                {% endfor %}
            </ul>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {% if overdue_reviews|length > 0 %}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning' } } %}
        {% block alert_body %}
            <div class="fa-alert__title">{{ 'bc_plans.alert.overdue_reviews'|trans({}, 'bc_plans') }}</div>
            <ul class="mb-0">
                {% for plan in overdue_reviews %}
                <li>
                    <a href="{{ path('app_bc_plan_show', {id: plan.id}) }}">{{ plan.name }}</a>
                    - {{ 'bc_plans.field.next_review'|trans({}, 'bc_plans') }}: {{ plan.nextReviewDate ? plan.nextReviewDate|date('Y-m-d') : ('bc_plans.message.not_scheduled'|trans({}, 'bc_plans')) }}
                </li>
                {% endfor %}
            </ul>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {% embed '_components/_card.html.twig' %}
        {% block card_attrs %}data-controller="filter"{% endblock %}
        {% block card_header %}
            <div class="card-header d-flex justify-content-between align-items-center">
                <h2 class="mb-0">{{ 'bc_plans.page.header'|trans({}, 'bc_plans') }} ({{ bc_plans|length }})</h2>
                {% if bc_plans|length > 0 %}
                <input type="search" class="form-control form-control-sm w-250px"
                       data-filter-target="searchInput"
                       data-action="input->filter#filterRows"
                       placeholder="{{ 'common.search'|trans({}, 'messages') }}...">
                {% endif %}
            </div>
        {% endblock %}
        {% block card_body %}
            {% if bc_plans|length > 0 %}
            {% embed '_components/_table.html.twig' with {
                'wrapperClass': 'card-body',
                'noMargin': true
            } %}
                {% block table_head %}
                    <tr>
                        <th scope="col">{{ 'bc_plans.table.name'|trans({}, 'bc_plans') }}</th>
                        <th scope="col">{{ 'bc_plans.table.business_process'|trans({}, 'bc_plans') }}</th>
                        <th scope="col">{{ 'bc_plans.table.owner'|trans({}, 'bc_plans') }}</th>
                        <th scope="col">{{ 'bc_plans.table.status'|trans({}, 'bc_plans') }}</th>
                        <th scope="col">{{ 'bc_plans.table.readiness'|trans({}, 'bc_plans') }}</th>
                        <th scope="col">{{ 'bc_plans.table.last_tested'|trans({}, 'bc_plans') }}</th>
                        <th scope="col">{{ 'bc_plans.table.actions'|trans({}, 'bc_plans') }}</th>
                    </tr>
                {% endblock %}
                {% block table_body %}
                    {% for plan in bc_plans %}
                    <tr data-filter-target="filterableRow">
                        <td><a href="{{ path('app_bc_plan_show', {id: plan.id}) }}">{{ plan.name }}</a></td>
                        <td>{{ plan.businessProcess ? plan.businessProcess.name : '-' }}</td>
                        <td>{{ plan.planOwner }}</td>
                        <td><span class="{{ badge_status(plan.status) }}">{{ ('bc_plans.status.' ~ plan.status)|trans({}, 'bc_plans')|upper }}</span></td>
                        <td>
                            {% set readiness = plan.getReadinessScore() %}
                            {% include '_components/_badge.html.twig' with { variant: readiness >= 80 ? 'success' : (readiness >= 60 ? 'warning' : 'danger'), content: readiness ~ '%' } %}
                        </td>
                        <td>{{ plan.lastTested ? plan.lastTested|date('Y-m-d') : ('bc_plans.message.never'|trans({}, 'bc_plans')) }}</td>
                        <td>
                            <div class="btn-group btn-group-sm" role="group" aria-label="{{ 'common.actions'|trans({}, 'messages') }}">
                                <a href="{{ path('app_bc_plan_show', {id: plan.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost" title="{{ 'common.view'|trans({}, 'messages') }}">
                                    <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
                                </a>
                                <a href="{{ path('app_bc_plan_edit', {id: plan.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost" title="{{ 'common.edit'|trans({}, 'messages') }}">
                                    <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                {% endblock %}
            {% endembed %}
            {% else %}
            {% include '_components/_empty_state.html.twig' with {
                icon: 'bi-shield-check',
                title: 'bc_plans.message.no_plans'|trans({}, 'bc_plans'),
                description: 'bc_plans.message.create_first'|trans({}, 'bc_plans'),
                action: { label: 'bc_plans.action.add_new'|trans({}, 'bc_plans'), url: path('app_bc_plan_new'), icon: 'bi-plus-circle' }
            } %}
            {% endif %}
        {% endblock %}
    {% endembed %}
    </main>
</div>
{% endblock %}
