{# Turbo Stream after a successful in-modal BC-Plan save. #}
{% if is_new %}
    <turbo-stream action="append" target="bc-plan-rows">
        <template>{% include 'business_continuity_plan/_row.html.twig' with { bc_plan: bc_plan } %}</template>
    </turbo-stream>
{% else %}
    <turbo-stream action="replace" target="business-continuity-plan-row-{{ bc_plan.id }}">
        <template>{% include 'business_continuity_plan/_row.html.twig' with { bc_plan: bc_plan } %}</template>
    </turbo-stream>
{% endif %}
