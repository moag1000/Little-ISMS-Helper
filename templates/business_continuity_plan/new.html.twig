{% extends 'base.html.twig' %}
{% trans_default_domain 'bc_plans' %}
{% form_theme form 'business_continuity_plan/_bc_plan_form_theme.html.twig' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'bc_plans.action.add_new'|trans({}, 'bc_plans') }} - {{ parent() }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.bcm'|trans({}, 'nav', 'nav'), url: path('app_bc_plan_index'), icon: 'nav-shield-alert' },
            { label: 'bc_plans.page.title'|trans({}, 'bc_plans'), url: path('app_bc_plan_index') },
            { label: 'bc_plans.action.add_new'|trans({}, 'bc_plans') }
        ]
    } %}

    {{ _fa_page_header.render({
        title: 'bc_plans.action.add_new'|trans({}, 'bc_plans'),
        badge: { icon: 'plus', label: '' },
        actions: [{ label: 'common.back'|trans({}, 'messages'), href: path('app_bc_plan_index'), variant: 'secondary', icon: 'util-arrow-left' }]
    }) }}

    <div class="row">
        <div class="col-lg-10 col-xl-9 mx-auto">
            {% embed '_components/_card.html.twig' %}
                {% block card_body %}
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                    {# Junior-ISB-Audit-2026-05-22 C2-06: 3-team-worlds consolidation.
                       responseTeamMembers (canonical per-plan), crisisTeams (cross-plan
                       reusable), bcTeam (deprecated freetext — disabled, kept for legacy
                       visibility only). #}
                    {% include '_components/_auto_form.html.twig' with {
                        'form': form,
                        'sections': {
                            'basic_info': {
                                'label': 'bc_plans.section.basic_info'|trans({}, 'bc_plans'),
                                'fields': ['name', 'businessProcess', 'description', 'planOwner', 'planOwnerUser', 'planOwnerPerson', 'planOwnerDeputyPersons', 'status']
                            },
                            'response_team': {
                                'label': 'bc_plan.section.response_team'|trans({}, 'bc_plans'),
                                'fields': ['responseTeamMembers', 'crisisTeams', 'criticalAssets', 'bcTeam']
                            },
                            'activation': {
                                'label': 'bc_plans.section.activation'|trans({}, 'bc_plans'),
                                'fields': ['activationCriteria', 'rolesAndResponsibilities', 'recoveryProcedures']
                            },
                            'communication': {
                                'label': 'bc_plans.section.communication'|trans({}, 'bc_plans'),
                                'fields': ['communicationPlan', 'internalCommunication', 'externalCommunication']
                            },
                            'alternative_site': {
                                'label': 'bc_plans.section.alternative_site'|trans({}, 'bc_plans'),
                                'fields': ['alternativeSite', 'alternativeSiteAddress', 'alternativeSiteCapacity']
                            },
                            'backup_recovery': {
                                'label': 'bc_plans.section.backup_recovery'|trans({}, 'bc_plans'),
                                'fields': ['backupProcedures', 'restoreProcedures']
                            },
                            'version_review': {
                                'label': 'bc_plans.section.version_review'|trans({}, 'bc_plans'),
                                'fields': ['version', 'lastTested', 'nextTestDate', 'lastReviewDate', 'nextReviewDate', 'reviewNotes']
                            }
                        },
                        'col_widths': {
                            'name': 12,
                            'businessProcess': 12,
                            'description': 12,
                            'planOwner': 6,
                            'planOwnerUser': 6,
                            'planOwnerPerson': 6,
                            'planOwnerDeputyPersons': 12,
                            'status': 6,
                            'responseTeamMembers': 12,
                            'crisisTeams': 12,
                            'bcTeam': 12,
                            'activationCriteria': 12,
                            'rolesAndResponsibilities': 12,
                            'recoveryProcedures': 12,
                            'communicationPlan': 12,
                            'internalCommunication': 6,
                            'externalCommunication': 6,
                            'alternativeSite': 12,
                            'alternativeSiteAddress': 6,
                            'alternativeSiteCapacity': 6,
                            'backupProcedures': 6,
                            'restoreProcedures': 6,
                            'version': 4,
                            'lastTested': 4,
                            'nextTestDate': 4,
                            'lastReviewDate': 6,
                            'nextReviewDate': 6,
                            'reviewNotes': 12
                        },
                        'tooltips': {
                            'activationCriteria': 'bc_plans.tooltip.activation_criteria',
                            'recoveryProcedures': 'bc_plans.tooltip.recovery_procedures',
                            'communicationPlan': 'bc_plans.tooltip.communication_plan',
                            'alternativeSite': 'bc_plans.tooltip.alternative_site',
                            'requiredResources': 'bc_plans.tooltip.required_resources'
                        },
                        'translation_domain': 'bc_plans'
                    } %}

                    {# Form Actions #}
                    <div class="form-actions d-flex gap-2 justify-content-between pt-3 border-top">
                        <a href="{{ path('app_bc_plan_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost"><i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i> {{ 'common.cancel'|trans({}, 'messages') }}</a>
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--lg"><i class="fa-icon fa-icon--ui-save" aria-hidden="true"></i> {{ 'common.save'|trans({}, 'messages') }}</button>
                    </div>

                    {{ form_end(form) }}

                    {# S14 Cluster A — Quick-Create empty-state rescue triggers. #}
                    {# C1-02 CrisisTeam · C1-03 BusinessProcess link (open-in-new-tab). #}
                    <div class="quick-create-empty-state-row mt-3 d-flex flex-wrap gap-3 align-items-center" aria-label="{{ 'quick_create.cta'|trans({}, 'quick_create') }}">
                        <span class="text-muted small">{{ 'quick_create.hint.missing_entry'|trans({}, 'quick_create') }}</span>

                        {% include '_components/_quick_create_modal.html.twig' with {
                            entityType:     'crisis-team',
                            targetSelectId: 'business_continuity_plan_crisisTeams',
                            modalId:        'quickCreateCrisisTeamModal',
                            triggerLabel:   ('bc_plans.action.quick_create_crisis_team'|trans({}, 'bc_plans')),
                            title:          ('bc_plans.action.quick_create_crisis_team'|trans({}, 'bc_plans')),
                            placeholder:    ('crisis_team.placeholder.team_name'|trans({}, 'crisis_team')),
                        } only %}

                        {# C1-03 — Neuen BusinessProcess anlegen (open in new tab, not a modal). #}
                        <a href="{{ path('app_business_process_new') }}"
                           target="_blank"
                           rel="noopener"
                           class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                            <i class="fa-icon fa-icon--plus-circle" aria-hidden="true"></i>
                            <span>{{ 'bc_plans.action.new_business_process'|trans({}, 'bc_plans') }}</span>
                            <i class="fa-icon fa-icon--util-external-link" aria-hidden="true"></i>
                        </a>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>
</div>
{% endblock %}
