{# Turbo Stream after a successful in-modal BC-Exercise save. #}
{% if is_new %}
    <turbo-stream action="append" target="bc-exercise-rows">
        <template>{% include 'bc_exercise/_row.html.twig' with { exercise: bc_exercise } %}</template>
    </turbo-stream>
{% else %}
    <turbo-stream action="replace" target="bc-exercise-row-{{ bc_exercise.id }}">
        <template>{% include 'bc_exercise/_row.html.twig' with { exercise: bc_exercise } %}</template>
    </turbo-stream>
{% endif %}
