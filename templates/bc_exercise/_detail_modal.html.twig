{# BC-Exercise read-only detail — rendered inside the fa-form-modal Turbo Frame.
   Uses drawer chrome (header/body/footer/kv). Condensed, with a "Vollansicht"
   link to the full page. ISO 22301 Cl. 8.5 exercise result-fields shown. #}
{% trans_default_domain 'bc_exercises' %}
<turbo-frame id="fa-form-modal">
    <div class="fa-drawer__header">
        <div class="fa-drawer__header-text">
            <div class="fa-drawer__eyebrow">BCM · ISO 22301 Cl. 8.5 · Exercise</div>
            <div class="fa-drawer__title">{{ bc_exercise.name }}</div>
        </div>
        <button type="button" class="fa-drawer__close" data-action="fa-form-modal#close"
                aria-label="{{ 'common.close'|trans({}, 'messages') }}">
            <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i>
        </button>
    </div>
    <div class="fa-drawer__body">
        <div class="fa-drawer__section">
            {% include '_components/_badge.html.twig' with { variant: 'info', content: ('bc_exercises.exercise_type.' ~ bc_exercise.exerciseType)|trans({}, 'bc_exercises') } %}
            <span class="{{ badge_status(bc_exercise.status) }}">{{ ('bc_exercises.status.' ~ bc_exercise.status)|trans({}, 'bc_exercises') }}</span>
        </div>

        {% if bc_exercise.exerciseDate %}
        <div class="fa-drawer__kv">
            <span class="label">{{ 'bc_exercises.field.exercise_date'|trans({}, 'bc_exercises') }}</span>
            <span>{{ bc_exercise.exerciseDate|locale_date }}</span>
        </div>
        {% endif %}

        {% if bc_exercise.scope %}
        <div class="fa-drawer__kv">
            <span class="label">{{ 'bc_exercises.field.scope'|trans({}, 'bc_exercises') }}</span>
            <span>{{ bc_exercise.scope|u.truncate(120, '…') }}</span>
        </div>
        {% endif %}

        {% if bc_exercise.objectives %}
        <div class="fa-drawer__section">
            <span class="label">{{ 'bc_exercises.field.objectives'|trans({}, 'bc_exercises') }}</span>
            <p class="fa-drawer__desc">{{ bc_exercise.objectives|u.truncate(200, '…') }}</p>
        </div>
        {% endif %}

        {% if bc_exercise.results %}
        <div class="fa-drawer__section">
            <span class="label">{{ 'bc_exercises.field.results'|trans({}, 'bc_exercises') }}</span>
            <p class="fa-drawer__desc">{{ bc_exercise.results|u.truncate(200, '…') }}</p>
        </div>
        {% endif %}

        {% if bc_exercise.lessonsLearned %}
        <div class="fa-drawer__section">
            <span class="label">{{ 'bc_exercises.field.lessons_learned'|trans({}, 'bc_exercises') }}</span>
            <p class="fa-drawer__desc">{{ bc_exercise.lessonsLearned|u.truncate(200, '…') }}</p>
        </div>
        {% endif %}

        {% if bc_exercise.successRating %}
        <div class="fa-drawer__kv">
            <span class="label">{{ 'bc_exercises.field.success_rating'|trans({}, 'bc_exercises') }}</span>
            <span>{{ bc_exercise.successRating }}/5</span>
        </div>
        {% endif %}

        <div class="fa-drawer__section">
            <a href="{{ path('app_bc_exercise_show', {id: bc_exercise.id}) }}" data-turbo="false" class="fa-row-link">
                {{ 'common.open_full_view'|trans({}, 'messages') }} →
            </a>
        </div>
    </div>
    <div class="fa-drawer__footer" style="display:flex;gap:10px;justify-content:flex-end">
        <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--md" data-action="fa-form-modal#close">
            <span class="fa-cyber-btn__label">{{ 'common.close'|trans({}, 'messages') }}</span>
        </button>
        {% if is_granted('ROLE_USER') %}
            <a href="{{ path('app_bc_exercise_edit', {id: bc_exercise.id}) }}" data-turbo-frame="fa-form-modal"
               class="fa-cyber-btn fa-cyber-btn--md">
                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                <span class="fa-cyber-btn__label">{{ 'common.edit'|trans({}, 'messages') }}</span>
            </a>
        {% endif %}
    </div>
</turbo-frame>
