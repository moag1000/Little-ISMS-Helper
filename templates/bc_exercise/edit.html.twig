{% extends 'base.html.twig' %}
{% trans_default_domain 'bc_exercises' %}
{% form_theme form 'bc_exercise/_bc_exercise_form_theme.html.twig' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_norm_bridge.html.twig' as _fa_norm_bridge %}

{% block title %}{{ 'bc_exercises.action.edit'|trans({}, 'bc_exercises') }}: {{ bc_exercise.name }}{% endblock %}

{% block body %}
{# Junior-ISB-Audit-2026-05-22 P-12 rollout — 9001 + 22301 norm-bridge for BC-Exercise. #}
<div class="container-fluid py-4">
    {# Breadcrumb Navigation #}
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.bcm'|trans({}, 'nav', 'nav'), url: path('app_bcm_index'), icon: 'nav-shield-alert' },
            { label: 'bc_exercises.page.title'|trans({}, 'bc_exercises'), url: path('app_bc_exercise_index') },
            { label: bc_exercise.name, url: path('app_bc_exercise_show', {id: bc_exercise.id}) },
            { label: 'common.edit'|trans({}, 'messages') }
        ]
    } %}

    {# Page Header #}
    {{ _fa_page_header.render({
        title: ('bc_exercises.action.edit'|trans({}, 'bc_exercises')) ~ ': ' ~ bc_exercise.name,
        badge: { icon: 'ui-edit', label: '' },
        actions: [
            { label: 'common.view'|trans({}, 'messages'), href: path('app_bc_exercise_show', {id: bc_exercise.id}), variant: 'outline-primary', icon: 'ui-eye' },
            { label: 'common.back'|trans({}, 'messages'), href: path('app_bc_exercise_index'), variant: 'secondary', icon: 'util-arrow-left' }
        ]
    }) }}

    {# 9001-bridge: BC-Exercise is process verification (9001 9.1 evaluation) and mandatory in 22301 8.5. P-12 rollout. #}
    {{ _fa_norm_bridge.render({
        from_norm: 'ISO 22301 8.5',
        to_norm:   'ISO 9001 6.1 / 9.1',
        bridge_text: ('iso_9001_bridge.exercise'|trans({}, 'bc_exercises')),
        prominence: 'subtle'
    }) }}

    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
    {% include '_components/_auto_form.html.twig' with {
        'form': form,
        'layout': 'outline-rail',
        'eyebrow': 'BCM · ISO 22301 Cl. 8.5 · Exercise',
        'title': ('bc_exercises.action.edit'|trans({}, 'bc_exercises')) ~ ': ' ~ bc_exercise.name,
        'sections': {
            'details': {
                'label': 'bc_exercises.section.details'|trans({}, 'bc_exercises'),
                'fields': ['name', 'exerciseType', 'status', 'description', 'scope']
            },
            'planning': {
                'label': 'bc_exercises.section.scenario'|trans({}, 'bc_exercises'),
                'fields': ['objectives', 'scenario', 'exerciseDate', 'durationHours']
            },
            'participants': {
                'label': 'bc_exercises.section.participants'|trans({}, 'bc_exercises'),
                'fields': ['participantPersons', 'participants', 'facilitatorUser', 'facilitatorPerson', 'facilitator', 'exerciseLeaderUser', 'exerciseLeaderPerson', 'observerPersons', 'observers']
            },
            'results': {
                'label': 'bc_exercises.section.results'|trans({}, 'bc_exercises'),
                'fields': ['results', 'whatWentWell', 'areasForImprovement', 'findings', 'actionItems', 'lessonsLearned', 'planUpdatesRequired']
            },
            'targets': {
                'label': 'bc_exercises.section.targets'|trans({}, 'bc_exercises'),
                'fields': ['testedPlans', 'successCriteria', 'actualRtoAchieved', 'actualRpoAchieved']
            },
            'report': {
                'label': 'bc_exercises.section.report'|trans({}, 'bc_exercises'),
                'fields': ['successRating', 'reportCompleted', 'reportDate', 'evidenceArtifacts']
            }
        },
        'col_widths': {
            'name': 12,
            'exerciseType': 6,
            'status': 6,
            'description': 12,
            'scope': 12,
            'objectives': 12,
            'scenario': 12,
            'exerciseDate': 6,
            'durationHours': 6,
            'participantPersons': 12,
            'participants': 12,
            'facilitatorUser': 6,
            'facilitatorPerson': 6,
            'facilitator': 6,
            'exerciseLeaderUser': 6,
            'exerciseLeaderPerson': 6,
            'observerPersons': 12,
            'observers': 12,
            'results': 12,
            'whatWentWell': 6,
            'areasForImprovement': 6,
            'findings': 12,
            'actionItems': 12,
            'lessonsLearned': 12,
            'planUpdatesRequired': 12,
            'testedPlans': 12,
            'successCriteria': 12,
            'actualRtoAchieved': 6,
            'actualRpoAchieved': 6,
            'successRating': 4,
            'reportCompleted': 4,
            'reportDate': 4,
            'evidenceArtifacts': 12
        },
        'tooltips': {
            'scenario': 'bc_exercises.tooltip.scenario',
            'exerciseType': 'bc_exercises.tooltip.exercise_type',
            'successCriteria': 'bc_exercises.tooltip.success_criteria',
            'successRating': 'bc_exercises.tooltip.success_rating'
        },
        'translation_domain': 'bc_exercises',
        'actions': {
            'close': { 'label': 'common.cancel'|trans({}, 'messages'), 'variant': 'ghost' },
            'submit': { 'label': 'common.save'|trans({}, 'messages'), 'variant': 'primary' }
        }
    } %}
    {{ form_end(form) }}
</div>
{% endblock %}
