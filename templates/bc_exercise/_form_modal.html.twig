{# BC-Exercise create/edit rendered inside the fa-form-modal Turbo Frame.
   Explicit form action (the document URL stays on the list). On valid submit the
   controller returns a Turbo Stream (row replace/append). #}
{% trans_default_domain 'bc_exercises' %}
{% set is_edit = bc_exercise is defined and bc_exercise and bc_exercise.id is not null %}
{% set form_action = is_edit ? path('app_bc_exercise_edit', { id: bc_exercise.id }) : path('app_bc_exercise_new') %}
<turbo-frame id="fa-form-modal">
    {{ form_start(form, { action: form_action, method: 'POST', attr: {
        id: 'bc-exercise-modal-form',
        'data-turbo-frame': 'fa-form-modal'
    } }) }}
    {% include 'bc_exercise/_form_body.html.twig' with {
        form: form,
        modal: true,
        title: is_edit ? bc_exercise.name : 'bc_exercises.action.add_new'|trans({}, 'bc_exercises'),
        actions: {
            close: { label: 'common.cancel'|trans({}, 'messages'), variant: 'ghost', action: 'fa-form-modal#close' },
            submit: { label: 'common.save'|trans({}, 'messages'), variant: 'primary' }
        }
    } %}
    {{ form_end(form) }}
</turbo-frame>
