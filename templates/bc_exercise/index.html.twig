{% extends 'base.html.twig' %}
{% trans_default_domain 'bc_exercises' %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}

{% block title %}{{ 'bc_exercises.page.title'|trans({}, 'bc_exercises') }}{% endblock %}

{% block body %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.bcm'|trans({}, 'nav'), url: path('app_bcm_index') },
            { label: 'nav.bc_exercises'|trans({}, 'nav') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'clipboard-data', label: 'bc_exercises.page.title'|trans({}, 'bc_exercises') },
        title: 'bc_exercises.page.header'|trans({}, 'bc_exercises'),
        actions: [
            { label: 'bc_exercises.action.add_new'|trans({}, 'bc_exercises'), href: path('app_bc_exercise_new'), variant: 'primary', icon: 'plus-lg' }
        ]
    }) }}
    <main class="fa-aurora-surface">

    {% if statistics %}
    <div class="row mb-4">
        <div class="col-md-4">
            {{ _fa_feature_card.render({ label: 'bc_exercises.stats.total'|trans({}, 'bc_exercises'), value: statistics.total, variant: 'primary' }) }}
        </div>
        <div class="col-md-4">
            {{ _fa_feature_card.render({ label: 'bc_exercises.stats.completed'|trans({}, 'bc_exercises'), value: statistics.completed, variant: 'success' }) }}
        </div>
        <div class="col-md-4">
            {{ _fa_feature_card.render({ label: 'bc_exercises.stats.planned'|trans({}, 'bc_exercises'), value: statistics.planned, variant: 'info' }) }}
        </div>
    </div>
    {% endif %}

    {% if upcoming|length > 0 %}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info' } } %}
        {% block alert_body %}
            <div class="fa-alert__title">{{ 'bc_exercises.section.upcoming'|trans({}, 'bc_exercises') }}</div>
            <ul>
                {% for exercise in upcoming %}
                <li>
                    <a href="{{ path('app_bc_exercise_show', {id: exercise.id}) }}">{{ exercise.name }}</a>
                    - {{ exercise.exerciseDate|locale_date }} ({{ ('bc_exercises.exercise_type.' ~ exercise.exerciseType)|trans({}, 'bc_exercises') }})
                </li>
                {% endfor %}
            </ul>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {% if incomplete_reports|length > 0 %}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning' } } %}
        {% block alert_body %}
            <div class="fa-alert__title">{{ 'bc_exercises.section.incomplete_reports'|trans({}, 'bc_exercises') }}</div>
            <ul class="mb-0">
                {% for exercise in incomplete_reports %}
                <li>
                    <a href="{{ path('app_bc_exercise_show', {id: exercise.id}) }}">{{ exercise.name }}</a>
                </li>
                {% endfor %}
            </ul>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {% embed '_components/_card.html.twig' %}
        {% block card_attrs %}data-controller="filter"{% endblock %}
        {% block card_header %}
            <div class="card-header d-flex justify-content-between align-items-center">
                <h2 class="mb-0">{{ 'bc_exercises.page.header'|trans({}, 'bc_exercises') }} ({{ bc_exercises|length }})</h2>
                {% if bc_exercises|length > 0 %}
                <input type="search" class="form-control form-control-sm w-250px"
                       data-filter-target="searchInput"
                       data-action="input->filter#filterRows"
                       placeholder="{{ 'common.search'|trans({}, 'messages') }}...">
                {% endif %}
            </div>
        {% endblock %}
        {% block card_body %}
            {% if bc_exercises|length > 0 %}
            {% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
            {% embed '_components/_table.html.twig' with {
                'wrapperClass': 'card-body',
                'noMargin': true
            } %}
                {% block table_head %}
                    <tr>
                        <th scope="col">{{ 'bc_exercises.table.name'|trans({}, 'bc_exercises') }}</th>
                        <th scope="col">{{ 'bc_exercises.table.type'|trans({}, 'bc_exercises') }}</th>
                        <th scope="col">{{ 'bc_exercises.table.date'|trans({}, 'bc_exercises') }}</th>
                        <th scope="col">{{ 'bc_exercises.table.status'|trans({}, 'bc_exercises') }}</th>
                        <th scope="col">{{ 'bc_exercises.table.effectiveness'|trans({}, 'bc_exercises') }}</th>
                        <th scope="col">{{ 'common.actions'|trans({}, 'messages') }}</th>
                    </tr>
                {% endblock %}
                {% block table_body %}
                    {% for exercise in bc_exercises %}
                    <tr data-filter-target="filterableRow">
                        <td><a href="{{ path('app_bc_exercise_show', {id: exercise.id}) }}">{{ exercise.name }}</a></td>
                        <td>{% include '_components/_badge.html.twig' with { variant: 'info', content: ('bc_exercises.exercise_type.' ~ exercise.exerciseType)|trans({}, 'bc_exercises') } %}</td>
                        <td>{{ exercise.exerciseDate|locale_date }}</td>
                        <td><span class="{{ badge_status(exercise.status) }}">{{ ('bc_exercises.status.' ~ exercise.status)|trans({}, 'bc_exercises') }}</span></td>
                        <td>
                            {% if exercise.status == 'completed' %}
                                {{ exercise.getEffectivenessScore() }}%
                            {% else %}
                                {{ 'bc_exercises.message.na'|trans({}, 'bc_exercises') }}
                            {% endif %}
                        </td>
                        <td>
                            <a href="{{ path('app_bc_exercise_show', {id: exercise.id}) }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost">{{ 'common.view'|trans({}, 'messages') }}</a>
                            <a href="{{ path('app_bc_exercise_edit', {id: exercise.id}) }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--primary">{{ 'common.edit'|trans({}, 'messages') }}</a>
                        </td>
                    </tr>
                    {% endfor %}
                {% endblock %}
            {% endembed %}
            {% else %}
            {{ _fa_empty_state.render({
                mood: 'sleeping',
                title: 'bc_exercises.message.no_exercises'|trans({}, 'bc_exercises'),
                actions: [
                    { label: 'bc_exercises.message.schedule_first'|trans({}, 'bc_exercises'), variant: 'primary', icon: 'plus-lg', href: path('app_bc_exercise_new') }
                ]
            }) }}
            {% endif %}
        {% endblock %}
    {% endembed %}
    </main>
</div>

<style>
.stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-top: 1rem; }
.stat-item { display: flex; flex-direction: column; padding: 1rem; background: var(--bg); border-radius: 4px; }
.stat-label { font-size: 0.875rem; color: var(--fg-3); }
.stat-value { font-size: 1.5rem; font-weight: bold; color: var(--fg); }
</style>
{% endblock %}
