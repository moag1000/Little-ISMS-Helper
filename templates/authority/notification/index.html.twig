{% extends 'base.html.twig' %}
{% trans_default_domain 'eu_authorities' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}

{% block title %}{{ 'authority.nav.title'|trans({}, 'eu_authorities') }} — {{ 'eu_authorities.page.title'|trans({}, 'eu_authorities') }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'eu_authorities.page.title'|trans, icon: 'bi-building-check' },
            { label: 'authority.nav.title'|trans({}, 'eu_authorities') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge:    { icon: 'building-check', label: 'EU-Behörden' },
        title:    'eu_authorities.page.title'|trans,
        subtitle: 'eu_authorities.page.subtitle'|trans,
        actions: []
    }) }}

    <main class="fa-aurora-surface">

        {# ── DataBreach exports ─────────────────────────────────────────────── #}
        {% if breaches|length > 0 %}
        <section class="mb-5">
            <h5 class="mb-3"><i class="fa-icon fa-icon--nav-shield-alert me-1 text-danger"></i> {{ 'authority.section.data_breaches'|trans({}, 'eu_authorities') }}</h5>
            <div class="row g-3">
                {% for breach in breaches %}
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card h-100">
                        <div class="card-header d-flex align-items-center gap-2">
                            <i class="fa-icon fa-icon--status-warning text-danger"></i>
                            <span class="fw-semibold">{{ breach.referenceNumber }}</span>
                            <span class="badge bg-secondary ms-auto">{{ breach.severity }}</span>
                        </div>
                        <div class="card-body">
                            <p class="fa-meta small mb-3">{{ breach.title }}</p>
                            <div class="d-flex flex-column gap-2">
                                <a href="{{ path('app_authority_notification_breach_pdf', {_locale: app.request.locale, breachId: breach.id, authorityKey: 'bfdi'}) }}"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="fa-icon fa-icon--nav-file-pdf me-1"></i>
                                    {{ 'authority.action.export_pdf'|trans({}, 'eu_authorities') }} (BfDI)
                                </a>
                                <a href="{{ path('app_authority_notification_breach_json', {_locale: app.request.locale, breachId: breach.id, authorityKey: 'bfdi'}) }}"
                                   class="btn btn-sm btn-outline-secondary">
                                    <i class="fa-icon fa-icon--util-filetype-json me-1" aria-hidden="true"></i>
                                    {{ 'authority.action.export_json'|trans({}, 'eu_authorities') }}
                                </a>
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle w-100" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="fa-icon fa-icon--util-geo me-1" aria-hidden="true"></i>
                                        {{ 'authority.section.lfdi_export'|trans({}, 'eu_authorities') }}
                                    </button>
                                    <ul class="dropdown-menu">
                                        {% set lfdi_keys = ['lfdi_bw','lfdi_by','lfdi_ber','lfdi_brb','lfdi_hb','lfdi_hh','lfdi_he','lfdi_mv','lfdi_ni','lfdi_nrw','lfdi_rlp','lfdi_sl','lfdi_sn','lfdi_st','lfdi_sh','lfdi_th'] %}
                                        {% for key in lfdi_keys %}
                                        <li>
                                            <a class="dropdown-item" href="{{ path('app_authority_notification_breach_pdf', {_locale: app.request.locale, breachId: breach.id, authorityKey: key}) }}">
                                                {{ ('authority.bundesland.' ~ key|replace({'lfdi_': ''}))|trans({}, 'eu_authorities') }}
                                            </a>
                                        </li>
                                        {% endfor %}
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </section>
        {% else %}
            {{ _fa_empty_state.render({
                mood:  'info',
                title: 'authority.empty.no_breaches'|trans({}, 'eu_authorities'),
                text:  'authority.empty.no_breaches_body'|trans({}, 'eu_authorities')
            }) }}
        {% endif %}

        {# ── Incident (BSI-Meldestelle) exports ─────────────────────────────── #}
        {% if incidents|length > 0 %}
        <section class="mb-5">
            <h5 class="mb-3"><i class="fa-icon fa-icon--status-fire fa-icon--warning me-1" aria-hidden="true"></i> {{ 'authority.section.incidents'|trans({}, 'eu_authorities') }}</h5>
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle">
                    <thead>
                        <tr>
                            <th>{{ 'authority.field.incident'|trans({}, 'eu_authorities') }}</th>
                            <th>{{ 'authority.field.severity'|trans({}, 'eu_authorities') }}</th>
                            <th>{{ 'authority.field.detected_at'|trans({}, 'eu_authorities') }}</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for incident in incidents %}
                        <tr>
                            <td>{{ incident.title }}</td>
                            <td><span class="badge bg-warning text-dark">{{ incident.severity }}</span></td>
                            <td>{{ incident.detectedAt ? incident.detectedAt|date('d.m.Y') : '—' }}</td>
                            <td>
                                <a href="{{ path('app_authority_notification_incident_pdf', {_locale: app.request.locale, incidentId: incident.id, authorityKey: 'bsi_meldestelle'}) }}"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="fa-icon fa-icon--nav-file-pdf me-1"></i>
                                    {{ 'authority.action.export_pdf'|trans({}, 'eu_authorities') }} (BSI)
                                </a>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
        {% endif %}

    </main>
</div>
{% endblock %}
