<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    {#
        F25 — LfDI per-Bundesland authority header.
        authority_key is e.g. "lfdi_bw", "lfdi_nrw" etc.
        The Bundesland suffix (e.g. "bw") drives name + address lookups in eu_authorities translations.
    #}
    {% set bl = authority_key|replace({'lfdi_': ''}) %}
    <title>{{ ('authority.lfdi.' ~ bl ~ '.name')|trans({}, 'eu_authorities') }} — Meldung einer Datenschutzverletzung (Art. 33 DSGVO)</title>
    <style>
        body { font-family: DejaVu Sans, sans-serif; font-size: 11pt; color: #1a1a2e; }
        h1 { font-size: 14pt; border-bottom: 2px solid #3d7a45; padding-bottom: 6px; }
        h2 { font-size: 12pt; margin-top: 18px; color: #3d7a45; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 14px; }
        th { background: #E8F5E9; text-align: left; padding: 6px 8px; border: 1px solid #a5d6a7; }
        td { padding: 5px 8px; border: 1px solid #a5d6a7; vertical-align: top; }
        .label { font-weight: bold; width: 40%; }
        .authority-block { background: #f0f9f1; border-left: 4px solid #3d7a45; padding: 8px 12px; margin-bottom: 14px; font-size: 10pt; }
        .footer { font-size: 8pt; color: #666; border-top: 1px solid #ccc; margin-top: 20px; padding-top: 6px; }
    </style>
</head>
<body>
<h1>Meldung einer Datenschutzverletzung gemäß Art. 33 DSGVO</h1>
{#
    F25 — Per-Bundesland authority header block.
    Name and address are resolved from eu_authorities translation data (authority.lfdi.<bl>.*).
    Falls back gracefully if a key is not yet populated (shows the generic bundesland label).
#}
<div class="authority-block">
    <strong>An:</strong> {{ ('authority.lfdi.' ~ bl ~ '.name')|trans({}, 'eu_authorities') }}<br>
    {{ ('authority.lfdi.' ~ bl ~ '.address_line1')|trans({}, 'eu_authorities') }}<br>
    {{ ('authority.lfdi.' ~ bl ~ '.address_line2')|trans({}, 'eu_authorities') }}<br>
    {{ ('authority.lfdi.' ~ bl ~ '.address_line3')|trans({}, 'eu_authorities') }}
</div>
{% if submission_contact_email %}<p><strong>Kontakt:</strong> {{ submission_contact_email }}</p>{% endif %}
{% if submission_url %}<p><strong>Portal:</strong> {{ submission_url }}</p>{% endif %}

{% if header_template %}
<blockquote>{{ header_template }}</blockquote>
{% endif %}

<h2>1. Grunddaten</h2>
<table>
    <tr><td class="label">Aktenzeichen (intern)</td><td>{{ reference_number }}</td></tr>
    <tr><td class="label">Betreff</td><td>{{ title }}</td></tr>
    <tr><td class="label">Schweregrad</td><td>{{ severity }}</td></tr>
    <tr><td class="label">Entdeckungsdatum</td><td>{{ detected_at ? detected_at|date('d.m.Y H:i') : '—' }}</td></tr>
    <tr><td class="label">Meldestatus</td><td>{{ status }}</td></tr>
</table>

<h2>2. Art der Verletzung (Art. 33 Abs. 3 lit. a)</h2>
<table>
    <tr><td class="label">Beschreibung</td><td>{{ breach_nature }}</td></tr>
    <tr><td class="label">Betroffene Datenkategorien</td><td>{{ data_categories|join(', ') }}</td></tr>
    <tr><td class="label">Kategorien betroffener Personen</td><td>{{ data_subject_categories|join(', ') }}</td></tr>
    <tr><td class="label">Anzahl betroffener Personen (ca.)</td><td>{{ affected_data_subjects ?? '—' }}</td></tr>
</table>

<h2>3. Mögliche Folgen (Art. 33 Abs. 3 lit. b)</h2>
<table>
    <tr><td>{{ likely_consequences }}</td></tr>
</table>

<h2>4. Maßnahmen (Art. 33 Abs. 3 lit. c/d)</h2>
<table>
    <tr><td class="label">Ergriffene Maßnahmen</td><td>{{ measures_taken }}</td></tr>
</table>

<h2>5. Behörden-Meldung</h2>
<table>
    <tr><td class="label">Meldepflicht besteht</td><td>{{ requires_authority_notification ? 'Ja' : 'Nein' }}</td></tr>
    <tr><td class="label">Meldedatum</td><td>{{ supervisory_authority_notified_at ? supervisory_authority_notified_at|date('d.m.Y H:i') : 'Noch nicht gemeldet' }}</td></tr>
    <tr><td class="label">Behörde</td><td>{{ supervisory_authority_name ?? ('authority.lfdi.' ~ bl ~ '.name')|trans({}, 'eu_authorities') }}</td></tr>
</table>

<div class="footer">
    Erstellt am: {{ generated_at|date('d.m.Y H:i') }} — Vertraulich / Datenschutzrechtlich relevantes Dokument
</div>
</body>
</html>
