{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% trans_default_domain 'business_process' %}

{% block title %}{{ business_process.name }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.bcm'|trans({}, 'nav'), url: path('app_business_process_index') },
            { label: business_process.name }
        ]
    } %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>{{ business_process.name }}</h1>
        <div>
            <a href="{{ path('app_business_process_bia', {'id': business_process.id}) }}" class="fa-cyber-btn fa-cyber-btn--primary">
                <i class="fa-icon fa-icon--nav-bar-chart" aria-hidden="true"></i> {{ 'business_process.action.bia_view'|trans({}, 'bcm') }}
            </a>
            <a href="{{ path('app_business_process_edit', {'id': business_process.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i> {{ 'common.edit'|trans({}, 'messages') }}
            </a>
            <form method="post" action="{{ path('app_business_process_delete', {'id': business_process.id}) }}" class="d-inline-block"
                  data-controller="ui-actions"
                  data-action="submit->ui-actions#confirm"
                  data-ui-actions-message-param="{{ 'business_process.confirm.delete'|trans({}, 'bcm') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ business_process.id) }}">
                <button class="fa-cyber-btn fa-cyber-btn--danger">
                    <i class="fa-icon fa-icon--ui-trash" aria-hidden="true"></i> {{ 'common.delete'|trans({}, 'messages') }}
                </button>
            </form>
        </div>
    </div>

    {# KPI Cards with Data Reuse #}
    <div class="row mb-4">
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' %}
                {% block card_body %}
                    <div class="h6 mb-2 text-muted">{{ 'business_process.show.criticality'|trans({}, 'business_process') }}</div>
                    <p class="h3">
                        {% set criticality_badge = {
                            'critical': 'danger',
                            'high': 'warning',
                            'medium': 'info',
                            'low': 'success'
                        } %}
                        {% include '_components/_badge.html.twig' with { variant: criticality_badge[business_process.criticality] ?? 'secondary', content: ('business_process.criticality.' ~ business_process.criticality)|trans({}, 'business_process') } %}
                    </p>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' %}
                {% block card_body %}
                    <div class="h6 mb-2 text-muted">{{ 'business_process.show.business_impact_score'|trans({}, 'business_process') }}</div>
                    <p class="h3">{{ metrics.business_impact_score }}/5</p>
                    <small class="text-muted">{{ 'business_process.show.auto_calculated'|trans({}, 'business_process') }}</small>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' %}
                {% block card_body %}
                    <div class="h6 mb-2 text-muted">{{ 'business_process.show.process_risk_level'|trans({}, 'business_process') }}</div>
                    <p class="h3">
                        {% set risk_badge = {
                            'critical': 'danger',
                            'high': 'warning',
                            'medium': 'info',
                            'low': 'success',
                            'unknown': 'secondary'
                        } %}
                        {% include '_components/_badge.html.twig' with { variant: risk_badge[metrics.process_risk_level] ?? 'secondary', content: ('business_process.criticality.' ~ metrics.process_risk_level)|trans({}, 'business_process') } %}
                    </p>
                    <small class="text-muted">{{ 'business_process.show.active_risks'|trans({'%count%': metrics.active_risks}, 'business_process') }}</small>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' with {borderColor: (not metrics.criticality_aligned) ? 'warning' : ''} %}
                {% block card_body %}
                    <div class="h6 mb-2 text-muted">{{ 'business_process.show.alignment_status'|trans({}, 'business_process') }}</div>
                    <p class="h3">
                        {% if metrics.criticality_aligned %}
                            <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
                        {% else %}
                            <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i>
                        {% endif %}
                    </p>
                    <small class="text-muted">
                        {% if metrics.criticality_aligned %}
                            {{ 'business_process.show.bia_risk_aligned'|trans({}, 'business_process') }}
                        {% else %}
                            {{ 'business_process.show.review_required'|trans({}, 'business_process') }}
                        {% endif %}
                    </small>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    {# Main Content in Tabs with Turbo Frame #}
    {% embed '_components/_card.html.twig' %}
        {% block card_header %}
        <div class="card-header" data-controller="toggle">
            <ul class="nav nav-tabs card-header-tabs">
                <li class="nav-item">
                    <a class="nav-link active" data-action="click->toggle#switchTab" data-tab="general" href="#">{{ 'business_process.show.tab.general'|trans({}, 'business_process') }}</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-action="click->toggle#switchTab" data-tab="bia" href="#">{{ 'business_process.show.tab.bia_data'|trans({}, 'business_process') }}</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-action="click->toggle#switchTab" data-tab="assets" href="#">{{ 'business_process.show.tab.assets'|trans({}, 'business_process') }}</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-action="click->toggle#switchTab" data-tab="risks" href="#">{{ 'business_process.show.tab.risks'|trans({}, 'business_process') }}</a>
                </li>
            </ul>
        </div>
        {% endblock %}
        {% block card_body %}
            {% import '_components/_fa_alert.html.twig' as _fa_alert %}
            {# General Tab #}
            <div class="tab-content active" data-tab-content="general">
                {% embed '_components/_table.html.twig' with {
                    'noMargin': true
                } %}
                    {% block table_body %}
                        <tr>
                            <th scope="row" class="w-200px">{{ 'business_process.field.process_owner'|trans({}, 'business_process') }}</th>
                            <td>{{ business_process.effectiveProcessOwner }}</td>
                        </tr>
                        <tr>
                            <th scope="row">{{ 'business_process.field.description'|trans({}, 'business_process') }}</th>
                            <td>{{ business_process.description ?? '-' }}</td>
                        </tr>
                        <tr>
                            <th scope="row">{{ 'business_process.field.dependencies_upstream'|trans({}, 'business_process') }}</th>
                            <td>{{ business_process.dependenciesUpstream ?? '-' }}</td>
                        </tr>
                        <tr>
                            <th scope="row">{{ 'business_process.field.dependencies_downstream'|trans({}, 'business_process') }}</th>
                            <td>{{ business_process.dependenciesDownstream ?? '-' }}</td>
                        </tr>
                        <tr>
                            <th scope="row">{{ 'business_process.field.recovery_strategy'|trans({}, 'business_process') }}</th>
                            <td>{{ business_process.recoveryStrategy ?? '-' }}</td>
                        </tr>
                    {% endblock %}
                {% endembed %}
            </div>

            {# BIA Tab #}
            <div class="tab-content d-none" data-tab-content="bia">
                <div class="row">
                    <div class="col-md-6">
                        <h2>{{ 'business_process.show.recovery_objectives'|trans({}, 'business_process') }}</h2>
                        {% embed '_components/_table.html.twig' with {
                            'noMargin': true
                        } %}
                            {% block table_body %}
                                <tr>
                                    <th scope="row">{{ 'business_process.show.rto'|trans({}, 'business_process') }}</th>
                                    <td>{{ business_process.rto }} {{ 'business_process.show.hours'|trans({}, 'business_process') }}</td>
                                </tr>
                                <tr>
                                    <th scope="row">{{ 'business_process.show.rpo'|trans({}, 'business_process') }}</th>
                                    <td>{{ business_process.rpo }} {{ 'business_process.show.hours'|trans({}, 'business_process') }}</td>
                                </tr>
                                <tr>
                                    <th scope="row">{{ 'business_process.show.mtpd'|trans({}, 'business_process') }}</th>
                                    <td>{{ business_process.mtpd }} {{ 'business_process.show.hours'|trans({}, 'business_process') }}</td>
                                </tr>
                                <tr>
                                    <th scope="row">{{ 'business_process.show.suggested_rto'|trans({}, 'business_process') }}</th>
                                    <td>
                                        {{ metrics.suggested_rto }} {{ 'business_process.show.hours'|trans({}, 'business_process') }}
                                        {% if metrics.suggested_rto != business_process.rto %}
                                            {% include '_components/_badge.html.twig' with { variant: 'warning', content: 'business_process.show.deviation'|trans({}, 'business_process') } %}
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endblock %}
                        {% endembed %}
                    </div>
                    <div class="col-md-6">
                        <h2>{{ 'business_process.show.impact_assessment'|trans({}, 'business_process') }}</h2>
                        {% embed '_components/_table.html.twig' with {
                            'noMargin': true
                        } %}
                            {% block table_body %}
                                <tr>
                                    <th scope="row">{{ 'business_process.field.reputational_impact'|trans({}, 'business_process') }}</th>
                                    <td>{{ business_process.reputationalImpact }}/5</td>
                                </tr>
                                <tr>
                                    <th scope="row">{{ 'business_process.field.regulatory_impact'|trans({}, 'business_process') }}</th>
                                    <td>{{ business_process.regulatoryImpact }}/5</td>
                                </tr>
                                <tr>
                                    <th scope="row">{{ 'business_process.field.operational_impact'|trans({}, 'business_process') }}</th>
                                    <td>{{ business_process.operationalImpact }}/5</td>
                                </tr>
                                <tr>
                                    <th scope="row">{{ 'business_process.field.financial_impact_per_hour'|trans({}, 'business_process') }}</th>
                                    <td>{{ business_process.financialImpactPerHour ? (business_process.financialImpactPerHour|number_format(2, ',', '.') ~ ' €') : '-' }}</td>
                                </tr>
                                <tr>
                                    <th scope="row">{{ 'business_process.field.financial_impact_per_day'|trans({}, 'business_process') }}</th>
                                    <td>{{ business_process.financialImpactPerDay ? (business_process.financialImpactPerDay|number_format(2, ',', '.') ~ ' €') : '-' }}</td>
                                </tr>
                            {% endblock %}
                        {% endembed %}
                    </div>
                </div>

                {% if metrics.unmitigated_high_risks %}
                    {{ _fa_alert.render({ variant: 'danger', class: 'mt-3', body: '<strong>' ~ 'business_process.show.warning'|trans({}, 'business_process') ~ ':</strong> ' ~ 'business_process.show.unmitigated_high_risks'|trans({}, 'business_process') }) }}
                {% endif %}
            </div>

            {# Assets Tab #}
            <turbo-frame id="process-assets" data-tab-content="assets" class="d-none">
                {% if business_process.supportingAssets|length > 0 %}
                    {% embed '_components/_table.html.twig' with {
                        'noMargin': true
                    } %}
                        {% block table_head %}
                            <tr>
                                <th scope="col">{{ 'business_process.show.asset'|trans({}, 'business_process') }}</th>
                                <th scope="col">{{ 'business_process.show.type'|trans({}, 'business_process') }}</th>
                                <th scope="col">{{ 'business_process.show.cia_rating'|trans({}, 'business_process') }}</th>
                                <th scope="col">{{ 'business_process.show.status'|trans({}, 'business_process') }}</th>
                            </tr>
                        {% endblock %}
                        {% block table_body %}
                            {% for asset in business_process.supportingAssets %}
                                <tr>
                                    <td>{{ asset.name }}</td>
                                    <td>{{ asset.assetType }}</td>
                                    <td>
                                        C: {{ asset.confidentialityValue }},
                                        I: {{ asset.integrityValue }},
                                        A: {{ asset.availabilityValue }}
                                    </td>
                                    <td>{{ asset.status }}</td>
                                </tr>
                            {% endfor %}
                        {% endblock %}
                    {% endembed %}
                {% else %}
                    {{ _fa_alert.render({ variant: 'info', body: 'business_process.show.no_supporting_assets'|trans({}, 'business_process') }) }}
                {% endif %}
            </turbo-frame>

            {# Risks Tab #}
            <turbo-frame id="process-risks" data-tab-content="risks" class="d-none">
                {% if business_process.identifiedRisks|length > 0 %}
                    {% embed '_components/_table.html.twig' with {
                        'noMargin': true
                    } %}
                        {% block table_head %}
                            <tr>
                                <th scope="col">{{ 'business_process.show.risk'|trans({}, 'business_process') }}</th>
                                <th scope="col">{{ 'business_process.show.status'|trans({}, 'business_process') }}</th>
                                <th scope="col">{{ 'business_process.show.inherent_risk'|trans({}, 'business_process') }}</th>
                                <th scope="col">{{ 'business_process.show.residual_risk'|trans({}, 'business_process') }}</th>
                                <th scope="col">{{ 'business_process.show.treatment'|trans({}, 'business_process') }}</th>
                            </tr>
                        {% endblock %}
                        {% block table_body %}
                            {% for risk in business_process.identifiedRisks %}
                                <tr>
                                    <td>{{ risk.title }}</td>
                                    <td>
                                        <span class="{{ badge_status(risk.status) }}">
                                            {{ risk.status }}
                                        </span>
                                    </td>
                                    <td>{{ risk.inherentRiskLevel }}</td>
                                    <td>{{ risk.residualRiskLevel }}</td>
                                    <td>{{ risk.treatmentStrategy }}</td>
                                </tr>
                            {% endfor %}
                        {% endblock %}
                    {% endembed %}
                {% else %}
                    {{ _fa_alert.render({ variant: 'info', body: 'business_process.show.no_risks'|trans({}, 'business_process') }) }}
                {% endif %}
            </turbo-frame>
        {% endblock %}
    {% endembed %}
</div>

<style>
.tab-content.active {
    display: block !important;
}
</style>
{% endblock %}
