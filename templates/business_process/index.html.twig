{% extends 'base.html.twig' %}
{% import '_components/_fa_alva_hint.html.twig' as _fa_alva_hint %}
{% trans_default_domain 'business_process' %}
{% import '_macros/inheritance_badge.html.twig' as inheritance %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}

{% block title %}{{ 'business_process.index.title'|trans({}, 'business_process') }}{% endblock %}

{% block body %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
<div class="container-fluid">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.bcm'|trans({}, 'nav'), url: path('app_bcm_index') },
            { label: 'nav.business_processes'|trans({}, 'nav') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'nav-workflow', label: 'business_process.index.title'|trans({}, 'business_process') },
        title: 'business_process.index.page_title'|trans({}, 'business_process'),
        actions: [
            { label: 'business_process.index.new_process'|trans({}, 'business_process'), href: path('app_business_process_new'), variant: 'primary', icon: 'plus' }
        ]|merge(is_granted('ROLE_MANAGER') ? [{ label: 'filtered_export.button.label'|trans({}, 'filtered_export'), href: path('app_filtered_export_entity', { entityType: 'business_process', format: 'xlsx' }) ~ (app.request.queryString ? '?' ~ app.request.queryString : ''), variant: 'ghost', icon: 'nav-file-earmark-spreadsheet' }] : [])
    }) }}
{% set _global_hints = alva_hints('business_process_index') %}
{% if _global_hints|length > 0 %}
    {% for _h in _global_hints %}
        {{ _fa_alva_hint.render(_h) }}
    {% endfor %}
{% endif %}

    <main class="fa-aurora-surface">

    {# Notifications Container for Turbo Streams #}
    <div id="notifications" class="mb-3"></div>

    {# Aurora empty-state shown as top-block when no BPs exist (KPI tiles below remain visible for context) #}
    {% if business_processes is empty %}
        {{ _fa_empty_state.render({
            mood: 'thinking',
            title: 'business_process.empty.title'|trans({}, 'business_process'),
            text: 'business_process.empty.body'|trans({}, 'business_process'),
            norm_ref: 'ISO 27001 A.5.30 · ISO 22301 Klausel 8.2.2',
            actions: [
                { label: 'business_process.action.create_first'|trans({}, 'business_process'), variant: 'primary', icon: 'plus', href: path('app_business_process_new') }
            ],
            help_link: 'business_process.help.empty_link'|trans({}, 'business_process')
        }) }}
    {% endif %}

    {# View Filter #}
    {% if currentTenant %}
    {% embed '_components/_card.html.twig' with {
        'class': 'mb-3'
    } %}
        {% block card_body %}
            <form method="get" action="{{ path('app_business_process_index') }}" class="d-flex align-items-center gap-2">
                <label for="view-filter" class="mb-0 fw-bold">
                    <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i> {{ 'common.view'|trans({}, 'messages') }}:
                </label>
                <select class="form-select fa-cyber-input__field form-select-sm w-auto" id="view-filter" name="view" data-controller="ui-actions" data-action="change->ui-actions#autoSubmit">
                    <option value="own" {{ inheritanceInfo.currentView == 'own' ? 'selected' : '' }}>
                        {{ 'corporate.view.own_only'|trans({}, 'tenant') }}
                    </option>
                    {% if inheritanceInfo.hasParent %}
                    <option value="inherited" {{ inheritanceInfo.currentView == 'inherited' ? 'selected' : '' }}>
                        {{ 'corporate.view.including_inherited'|trans({}, 'tenant') }}
                    </option>
                    {% endif %}
                    {% if inheritanceInfo.hasSubsidiaries %}
                    <option value="subsidiaries" {{ inheritanceInfo.currentView == 'subsidiaries' ? 'selected' : '' }}>
                        {{ 'corporate.view.including_subsidiaries'|trans({}, 'tenant') }}
                    </option>
                    {% endif %}
                </select>
                <noscript>
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost">{{ 'common.apply'|trans({}, 'messages') }}</button>
                </noscript>
            </form>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {# Statistics Cards with Turbo Frame #}
    <turbo-frame id="bcm-stats" src="{{ path('app_business_process_stats_api') }}" loading="lazy">
        <div class="row mb-4">
            <div class="col-md-3">
                {% if currentTenant %}
                    {% set subtitle = 'corporate.stats.breakdown'|trans({'%own%': detailedStats.own, '%inherited%': detailedStats.inherited, '%subsidiaries%': detailedStats.subsidiaries}, 'tenant') %}
                    {{ _fa_feature_card.render({ label: 'business_process.index.stats.total'|trans({}, 'business_process'), value: detailedStats.total, hint: subtitle, variant: 'primary' }) }}
                {% else %}
                    {{ _fa_feature_card.render({ label: 'business_process.index.stats.total'|trans({}, 'business_process'), value: detailedStats.total, hint: 'business_process.index.stats.total_subtitle'|trans({}, 'business_process'), variant: 'primary' }) }}
                {% endif %}
            </div>
            <div class="col-md-3">
                {{ _fa_feature_card.render({ label: 'business_process.index.stats.critical'|trans({}, 'business_process'), value: stats.critical, hint: 'business_process.index.stats.critical_subtitle'|trans({}, 'business_process'), variant: 'danger' }) }}
            </div>
            <div class="col-md-3">
                {{ _fa_feature_card.render({ label: 'business_process.index.stats.avg_rto'|trans({}, 'business_process'), value: stats.avg_rto ~ 'business_process.index.stats.rto_unit'|trans({}, 'business_process'), hint: 'business_process.index.stats.rto_subtitle'|trans({}, 'business_process'), variant: 'info' }) }}
            </div>
            <div class="col-md-3">
                {{ _fa_feature_card.render({ label: 'business_process.index.stats.with_risks'|trans({}, 'business_process'), value: stats.processes_with_risks, hint: 'business_process.index.stats.with_risks_subtitle'|trans({}, 'business_process'), variant: 'warning' }) }}
            </div>
        </div>
    </turbo-frame>

    {# Process List with Turbo Frame #}
    <turbo-frame id="business-processes-list">
        {% embed '_components/_card.html.twig' %}
            {% block card_header %}
                <div class="card-header">
                    <h2 class="mb-0">{{ 'business_process.index.table.title'|trans({}, 'business_process') }}</h2>
                </div>
            {% endblock %}
            {% block card_body %}
                {% if business_processes|length > 0 %}
                    {% embed '_components/_table.html.twig' %}
                        {% import '_macros/inheritance_badge.html.twig' as inheritance %}
                        {% block table_head %}
                            <tr>
                                <th scope="col">{{ 'business_process.index.table.name'|trans({}, 'business_process') }}</th>
                                <th scope="col">{{ 'business_process.index.table.owner'|trans({}, 'business_process') }}</th>
                                <th scope="col">{{ 'business_process.index.table.criticality'|trans({}, 'business_process') }}</th>
                                <th scope="col">{{ 'business_process.index.table.rto'|trans({}, 'business_process') }}</th>
                                <th scope="col">{{ 'business_process.index.table.rpo'|trans({}, 'business_process') }}</th>
                                <th scope="col">{{ 'business_process.index.table.mtpd'|trans({}, 'business_process') }}</th>
                                <th scope="col">{{ 'business_process.index.table.impact_score'|trans({}, 'business_process') }}</th>
                                <th scope="col">{{ 'business_process.index.table.actions'|trans({}, 'business_process') }}</th>
                            </tr>
                        {% endblock %}
                        {% block table_body_attrs %}id="business-processes-table-body"{% endblock %}
                        {% block table_body %}
                            {% import '_macros/inheritance_badge.html.twig' as inheritance %}
                            {% for process in business_processes %}
                                <tr id="business-process-{{ process.id }}">
                                    <td>
                                        <a href="{{ path('app_business_process_show', {'id': process.id}) }}" data-turbo-frame="_top">
                                            {{ process.name }}
                                        </a>
                                        {{ inheritance.small_badge(process, currentTenant) }}
                                    </td>
                                    <td>{{ process.effectiveProcessOwner }}</td>
                                    <td>
                                        {% set criticality_class = {
                                            'critical': 'danger',
                                            'high': 'warning',
                                            'medium': 'info',
                                            'low': 'secondary'
                                        } %}
                                        {% include '_components/_badge.html.twig' with { variant: criticality_class[process.criticality] ?? 'secondary', content: process.criticality|capitalize } %}
                                    </td>
                                    <td>{{ process.rto }}h</td>
                                    <td>{{ process.rpo }}h</td>
                                    <td>{{ process.mtpd }}h</td>
                                    <td>
                                        {% set score = process.businessImpactScore %}
                                        <span class="{{ badge_score(score) }}">
                                            {{ score }}/5
                                        </span>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a href="{{ path('app_business_process_show', {'id': process.id}) }}"
                                               class="fa-cyber-btn fa-cyber-btn--ghost" title="{{ 'common.view'|trans({}, 'messages') }}" data-turbo-frame="_top" aria-label="{{ 'common.view'|trans({}, 'messages') }}">
                                                <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
                                            </a>
                                            <a href="{{ path('app_business_process_edit', {'id': process.id}) }}"
                                               class="fa-cyber-btn fa-cyber-btn--ghost" title="{{ 'common.edit'|trans({}, 'messages') }}" data-turbo-frame="_top" aria-label="{{ 'common.edit'|trans({}, 'messages') }}">
                                                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                                            </a>
                                            <a href="{{ path('app_business_process_bia', {'id': process.id}) }}"
                                               class="fa-cyber-btn fa-cyber-btn--ghost" title="{{ 'bcm.action.view_bia'|trans({}, 'bcm') }}" data-turbo-frame="_top" aria-label="{{ 'bcm.action.view_bia'|trans({}, 'bcm') }}">
                                                <i class="fa-icon fa-icon--nav-bar-chart" aria-hidden="true"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endblock %}
                    {% endembed %}
                {% else %}
                    {% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
                    {{ _fa_empty_state.render({
                        mood: 'thinking',
                        title: 'business_process.empty.title'|trans({}, 'business_process'),
                        text: 'business_process.empty.body'|trans({}, 'business_process'),
                        norm_ref: 'ISO 27001 A.5.30 · ISO 22301 Klausel 8.2.2',
                        actions: [
                            { label: 'business_process.action.create_first'|trans({}, 'business_process'), variant: 'primary', icon: 'plus', href: path('app_business_process_new') }
                        ],
                        help_link: 'business_process.help.empty_link'|trans({}, 'business_process')
                    }) }}
                {% endif %}
            {% endblock %}
        {% endembed %}
    </turbo-frame>
    </main>
</div>

{# Note: Loading indicator is now handled via CSS variable or JavaScript for i18n #}
<style>
turbo-frame[busy] {
    opacity: 0.6;
    pointer-events: none;
}
</style>
{% endblock %}
