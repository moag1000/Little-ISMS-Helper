{# Turbo Stream response for updating a BusinessProcess #}

{# Replace the updated process row in the list #}
<turbo-stream action="replace" target="business-process-{{ business_process.id }}">
    <template>
        <tr id="business-process-{{ business_process.id }}" class="table-row-highlight">
            <td>
                <a href="{{ path('app_business_process_show', {'id': business_process.id}) }}"
                   data-turbo-frame="_top">
                    {{ business_process.name }}
                </a>
            </td>
            <td>
                <span class="{{ badge_risk(business_process.criticality) }}">
                    {{ business_process.criticality }}
                </span>
            </td>
            <td>{{ business_process.rto }}h</td>
            <td>{{ business_process.rpo }}h</td>
            <td>{{ business_process.businessImpactScore }}/5</td>
            <td>{{ business_process.supportingAssets|length }}</td>
            <td>{{ business_process.identifiedRisks|length }}</td>
            <td>
                <a href="{{ path('app_business_process_show', {'id': business_process.id}) }}"
                   class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--primary" data-turbo-frame="_top" aria-label="{{ 'common.view'|trans({}, 'messages') }}">
                    <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
                </a>
                <a href="{{ path('app_business_process_edit', {'id': business_process.id}) }}"
                   class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost" data-turbo-frame="_top" aria-label="{{ 'common.edit'|trans({}, 'messages') }}">
                    <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                </a>
            </td>
        </tr>
    </template>
</turbo-stream>

{# Update the detail page if open #}
<turbo-stream action="replace" target="business-process-details">
    <template>
        <div id="business-process-details">
            <h2>{{ business_process.name }}</h2>
            <p>{{ business_process.description }}</p>
            <div class="row">
                <div class="col-md-6">
                    <strong>Prozessverantwortlicher:</strong> {{ business_process.effectiveProcessOwner }}
                </div>
                <div class="col-md-6">
                    <strong>Kritikalität:</strong> {{ business_process.criticality }}
                </div>
            </div>
        </div>
    </template>
</turbo-stream>

{# Show success notification #}
<turbo-stream action="append" target="notifications">
    <template>
        <div class="fa-alert fa-alert--success" role="alert">
            <strong>Erfolg!</strong> Geschäftsprozess "{{ business_process.name }}" wurde aktualisiert.
            <button type="button" class="fa-alert__dismiss" data-bs-dismiss="alert" aria-label="{{ 'action.close'|trans({}, 'messages') }}">×</button>
        </div>
    </template>
</turbo-stream>

<style>
.table-row-highlight {
    animation: highlightRow 2s ease-in-out;
}

@keyframes highlightRow {
    0% { background-color: var(--warning-glow); }
    100% { background-color: transparent; }
}
</style>
