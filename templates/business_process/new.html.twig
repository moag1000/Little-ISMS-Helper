{% extends 'base.html.twig' %}
{% trans_default_domain 'business_process' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_norm_bridge.html.twig' as _fa_norm_bridge %}

{% block title %}{{ 'business_process.new'|trans({}, 'business_process') }}{% endblock %}

{% block body %}
{# Junior-ISB-Audit-2026-05-22 P-12 rollout — 9001 + 22301 norm-bridge for BP. #}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.bcm'|trans({}, 'nav'), url: path('app_business_process_index') },
            { label: 'business_process.new'|trans({}, 'business_process') }
        ]
    } %}

    {{ _fa_page_header.render({
        title: 'business_process.new'|trans({}, 'business_process'),
        badge: { icon: 'plus', label: '' },
        actions: [
            { label: 'common.back_to_list'|trans({}, 'messages'), href: path('app_business_process_index'), variant: 'ghost', icon: 'util-arrow-left' }
        ]
    }) }}

    {# 9001-bridge: Business-Process = Prozesslandkarte (9001 Cl. 4.4). P-12 rollout. #}
    {{ _fa_norm_bridge.render({
        from_norm: 'ISO 22301 8.3',
        to_norm:   'ISO 9001 4.4 / 7.1',
        bridge_text: ('iso_9001_bridge.business_process'|trans({}, 'business_process')),
        prominence: 'subtle'
    }) }}

    {#
        Junior-ISB-Audit-2026-05-22 S14 #17: BP-Tooltips Drawer Pattern.
        Wrap form + drawer in `data-controller="help-drawer"` scope so the
        single page-level fa-drawer can be opened by all "Mehr Info..."
        triggers rendered next to fields listed in `drawer_keys`.
    #}
    <div data-controller="help-drawer">
    {{ form_start(form) }}
    {% include '_components/_auto_form.html.twig' with {
        'form': form,
        'layout': 'outline-rail',
        'eyebrow': 'BCM · ISO 22301 Cl. 8.3 · Business Process Analysis',
        'title': 'business_process.new'|trans({}, 'business_process'),
        'sections': {
            'overview': {
                'label': 'form.section.overview'|trans({}, 'messages'),
                'fields': ['name', 'description', 'criticality']
            },
            'owner': {
                'label': 'form.section.owner'|trans({}, 'messages'),
                'fields': ['processOwnerUser', 'processOwnerPerson', 'processOwnerDeputyPersons', 'processOwner']
            },
            'criticality': {
                'label': 'form.section.criticality'|trans({}, 'messages'),
                'fields': ['reputationalImpact', 'regulatoryImpact', 'operationalImpact', 'financialImpactPerHour', 'financialImpactPerDay']
            },
            'recovery_targets': {
                'label': 'form.section.recovery_targets'|trans({}, 'messages'),
                'fields': ['rto', 'rpo', 'mtpd']
            },
            'dependencies': {
                'label': 'form.section.dependencies'|trans({}, 'messages'),
                'fields': ['dependenciesUpstream', 'dependenciesDownstream', 'recoveryStrategy']
            },
            'resources': {
                'label': 'form.section.resources'|trans({}, 'messages'),
                'fields': ['supportingAssets', 'identifiedRisks']
            }
        },
        'col_widths': {
            'name': 6,
            'description': 6,
            'criticality': 6,
            'processOwnerUser': 6,
            'processOwnerPerson': 6,
            'processOwnerDeputyPersons': 12,
            'processOwner': 6,
            'reputationalImpact': 4,
            'regulatoryImpact': 4,
            'operationalImpact': 4,
            'financialImpactPerHour': 6,
            'financialImpactPerDay': 6,
            'rto': 4,
            'rpo': 4,
            'mtpd': 4,
            'dependenciesUpstream': 6,
            'dependenciesDownstream': 6,
            'recoveryStrategy': 12,
            'supportingAssets': 6,
            'identifiedRisks': 6
        },
        'translation_domain': 'business_process',
        'drawer_keys': {
            'criticality':        'business_process.tooltip.criticality',
            'rto':                'business_process.tooltip.rto',
            'rpo':                'business_process.tooltip.rpo',
            'mtpd':               'business_process.tooltip.mtpd',
            'reputationalImpact': 'business_process.tooltip.reputational_impact'
        },
        'actions': {
            'close': { 'label': 'common.cancel'|trans({}, 'messages'), 'variant': 'ghost' },
            'submit': { 'label': 'common.create'|trans({}, 'messages'), 'variant': 'primary' }
        }
    } %}
    {{ form_end(form) }}
    {% include '_components/_fa_help_drawer.html.twig' %}
    </div>

    {# S14 Cluster A — C1-01 Quick-Create Asset for supportingAssets picker. #}
    <div class="quick-create-empty-state-row mt-3 d-flex flex-wrap gap-3 align-items-center" aria-label="{{ 'quick_create.cta'|trans({}, 'quick_create') }}">
        <span class="text-muted small">{{ 'quick_create.hint.missing_asset'|trans({}, 'quick_create') }}</span>
        {% include '_components/_quick_create_modal.html.twig' with {
            entityType:     'asset',
            targetSelectId: 'business_process_supportingAssets',
            modalId:        'quickCreateAssetModal',
            triggerLabel:   ('business_process.action.quick_create_asset'|trans({}, 'business_process')),
            title:          ('business_process.action.quick_create_asset'|trans({}, 'business_process')),
        } only %}
    </div>
</div>
{% endblock %}
