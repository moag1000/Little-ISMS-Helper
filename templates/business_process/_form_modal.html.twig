{# BusinessProcess create/edit rendered inside the fa-form-modal Turbo Frame.
   Explicit form action (the document URL stays on the list). On valid submit the
   controller returns a Turbo Stream (row replace/append). #}
{% trans_default_domain 'business_process' %}
{% set is_edit = business_process is defined and business_process and business_process.id is not null %}
{% set form_action = is_edit ? path('app_business_process_edit', { id: business_process.id }) : path('app_business_process_new') %}
<turbo-frame id="fa-form-modal">
    {{ form_start(form, { action: form_action, method: 'POST', attr: {
        id: 'business-process-modal-form',
        'data-turbo-frame': 'fa-form-modal'
    } }) }}
    {% include 'business_process/_form_body.html.twig' with {
        form: form,
        modal: true,
        title: is_edit ? business_process.name : 'business_process.new'|trans({}, 'business_process'),
        actions: {
            close: { label: 'common.cancel'|trans({}, 'messages'), variant: 'ghost', action: 'fa-form-modal#close' },
            submit: { label: 'common.save'|trans({}, 'messages'), variant: 'primary' }
        }
    } %}
    {{ form_end(form) }}
</turbo-frame>
