{% extends 'base.html.twig' %}

{% block title %}BIA - {{ business_process.name }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Home</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_business_process_index') }}">BCM</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_business_process_show', {'id': business_process.id}) }}">{{ business_process.name }}</a></li>
            <li class="breadcrumb-item active">Business Impact Analysis</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>{{ 'business_process.bia.title'|trans({}, 'business_process') }}</h1>
        <a href="{{ path('app_business_process_show', {'id': business_process.id}) }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left" aria-hidden="true"></i> {{ 'common.back'|trans({}, 'messages') }}
        </a>
    </div>

    <p class="mb-3 lead">{{ business_process.name }}</p>

    {# Recovery Objectives #}
    {% embed '_components/_card.html.twig' with {class: 'mb-4'} %}
        {% block card_header %}
            <div class="card-header">
                <h2 class="mb-0"><i class="bi bi-clock-history" aria-hidden="true"></i> Recovery Objectives</h2>
            </div>
        {% endblock %}
        {% block card_body %}
            <div class="row">
                <div class="col-md-4">
                    {% embed '_components/_card.html.twig' with {variant: 'light'} %}
                        {% block card_body %}
                            <div class="text-center">
                                <div class="small fw-semibold text-muted mb-1">RTO</div>
                                <p class="display-4 fw-bold mb-1">{{ bia_data.rto }}h</p>
                                <small class="text-muted">Recovery Time Objective</small>
                            </div>
                        {% endblock %}
                    {% endembed %}
                </div>
                <div class="col-md-4">
                    {% embed '_components/_card.html.twig' with {variant: 'light'} %}
                        {% block card_body %}
                            <div class="text-center">
                                <div class="small fw-semibold text-muted mb-1">RPO</div>
                                <p class="display-4 fw-bold mb-1">{{ bia_data.rpo }}h</p>
                                <small class="text-muted">Recovery Point Objective</small>
                            </div>
                        {% endblock %}
                    {% endembed %}
                </div>
                <div class="col-md-4">
                    {% embed '_components/_card.html.twig' with {variant: 'light'} %}
                        {% block card_body %}
                            <div class="text-center">
                                <div class="small fw-semibold text-muted mb-1">MTPD</div>
                                <p class="display-4 fw-bold mb-1">{{ bia_data.mtpd }}h</p>
                                <small class="text-muted">Maximum Tolerable Period</small>
                            </div>
                        {% endblock %}
                    {% endembed %}
                </div>
            </div>
        {% endblock %}
    {% endembed %}

    {# Financial Impact #}
    {% embed '_components/_card.html.twig' with {class: 'mb-4'} %}
        {% block card_header %}
            <div class="card-header">
                <h2 class="mb-0"><i class="bi bi-currency-euro" aria-hidden="true"></i> {{ 'business_process.bia.section.financial_impact'|trans({}, 'business_process') }}</h2>
            </div>
        {% endblock %}
        {% block card_body %}
            <div class="row">
                <div class="col-md-6">
                    <div class="small text-muted text-uppercase fw-semibold mb-1">{{ 'business_process.bia.field.damage_per_hour'|trans({}, 'business_process') }}</div>
                    <p class="h3">{{ bia_data.financial_impact_hour ? (bia_data.financial_impact_hour|number_format(2, ',', '.') ~ ' €') : 'business_process.bia.field.not_specified'|trans({}, 'business_process') }}</p>
                </div>
                <div class="col-md-6">
                    <div class="small text-muted text-uppercase fw-semibold mb-1">{{ 'business_process.bia.field.damage_per_day'|trans({}, 'business_process') }}</div>
                    <p class="h3">{{ bia_data.financial_impact_day ? (bia_data.financial_impact_day|number_format(2, ',', '.') ~ ' €') : 'business_process.bia.field.not_specified'|trans({}, 'business_process') }}</p>
                </div>
            </div>
            {% if bia_data.financial_impact_day %}
                <div class="alert alert-info mt-3">
                    <ul class="mb-0">
                        <li>{{ 'business_process.bia.field.projection_week'|trans({'%amount%': (bia_data.financial_impact_day * 7)|number_format(2, ',', '.')}, 'business_process') }}</li>
                        <li>{{ 'business_process.bia.field.projection_month'|trans({'%amount%': (bia_data.financial_impact_day * 30)|number_format(2, ',', '.')}, 'business_process') }}</li>
                    </ul>
                </div>
            {% endif %}
        {% endblock %}
    {% endembed %}

    {# Impact Assessment #}
    {% embed '_components/_card.html.twig' with {class: 'mb-4'} %}
        {% block card_header %}
            <div class="card-header">
                <h2 class="mb-0"><i class="bi bi-graph-up" aria-hidden="true"></i> {{ 'business_process.bia.section.impact_assessment'|trans({}, 'business_process') }}</h2>
            </div>
        {% endblock %}
        {% block card_body %}
            <div class="row">
                <div class="col-md-4">
                    <div class="small text-muted text-uppercase fw-semibold mb-2">{{ 'business_process.bia.field.reputational_impact'|trans({}, 'business_process') }}</div>
                    <div class="progress progress-h-30">
                        <div class="progress-bar bg-danger" role="progressbar"
                             style="width: {{ (bia_data.reputational_impact / 5 * 100) }}%">
                            {{ bia_data.reputational_impact }}/5
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="small text-muted text-uppercase fw-semibold mb-2">{{ 'business_process.bia.field.regulatory_impact'|trans({}, 'business_process') }}</div>
                    <div class="progress progress-h-30">
                        <div class="progress-bar bg-warning" role="progressbar"
                             style="width: {{ (bia_data.regulatory_impact / 5 * 100) }}%">
                            {{ bia_data.regulatory_impact }}/5
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="small text-muted text-uppercase fw-semibold mb-2">{{ 'business_process.bia.field.operational_impact'|trans({}, 'business_process') }}</div>
                    <div class="progress progress-h-30">
                        <div class="progress-bar bg-info" role="progressbar"
                             style="width: {{ (bia_data.operational_impact / 5 * 100) }}%">
                            {{ bia_data.operational_impact }}/5
                        </div>
                    </div>
                </div>
            </div>
            <div class="mt-3">
                <div class="small text-muted text-uppercase fw-semibold mb-2">{{ 'business_process.bia.field.business_impact_score'|trans({}, 'business_process') }}</div>
                <div class="progress progress-h-40">
                    <div class="progress-bar {% if bia_data.business_impact_score >= 4 %}bg-danger{% elseif bia_data.business_impact_score >= 3 %}bg-warning{% else %}bg-success{% endif %}"
                         role="progressbar"
                         style="width: {{ (bia_data.business_impact_score / 5 * 100) }}%">
                        <strong>{{ bia_data.business_impact_score }}/5</strong>
                    </div>
                </div>
            </div>
        {% endblock %}
    {% endembed %}

    {# Data Reuse Recommendations #}
    {% embed '_components/_card.html.twig' %}
        {% block card_header %}
            <div class="card-header">
                <h2 class="mb-0"><i class="bi bi-lightbulb" aria-hidden="true"></i> {{ 'business_process.bia.section.data_reuse_recommendations'|trans({}, 'business_process') }}</h2>
            </div>
        {% endblock %}
        {% block card_body %}
            <div class="small text-muted text-uppercase fw-semibold mb-2">{{ 'business_process.bia.field.suggested_availability'|trans({}, 'business_process') }}</div>
            <p class="lead">
                {{ 'business_process.bia.field.rto_recommendation_intro'|trans({'%rto%': bia_data.rto}, 'business_process') }}
                {% include '_components/_badge.html.twig' with { variant: 'primary', class: 'fs-5', content: bia_data.suggested_availability ~ '/5' } %}
            </p>
            <small class="text-muted">
                {{ 'business_process.bia.field.rto_consistency_hint'|trans({}, 'business_process') }}
            </small>
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
