{% trans_default_domain 'eu_authorities' %}<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <title>Verfahrensverzeichnis — Art. 30 DSGVO</title>
    <style>
        @page {
            margin: 1.5cm;
        }
        body {
            font-family: Arial, sans-serif;
            font-size: 9pt;
            line-height: 1.3;
            color: #1a1a2e;
        }
        h1 {
            font-size: 15pt;
            color: #1a1a2e;
            border-bottom: 2px solid #3b5bdb;
            padding-bottom: 6px;
            margin-bottom: 4px;
        }
        h2 {
            font-size: 11pt;
            color: #3b5bdb;
            margin-top: 16px;
            margin-bottom: 4px;
        }
        .meta {
            background: #e8f0fe;
            border: 1px solid #c5d3f0;
            border-radius: 4px;
            padding: 8px 12px;
            margin-bottom: 16px;
            font-size: 8.5pt;
        }
        .meta table { width: 100%; border-collapse: collapse; }
        .meta td { padding: 2px 4px; }
        .meta td:first-child { font-weight: bold; width: 40%; }
        table.vvt {
            width: 100%;
            border-collapse: collapse;
            margin-top: 8px;
        }
        table.vvt thead th {
            background: #3b5bdb;
            color: #ffffff;
            font-size: 8pt;
            font-weight: bold;
            text-align: left;
            padding: 4px 6px;
            border: 1px solid #2f4ac9;
        }
        table.vvt tbody td {
            font-size: 8pt;
            padding: 4px 6px;
            border: 1px solid #d0d7de;
            vertical-align: top;
        }
        table.vvt tbody tr:nth-child(even) td {
            background: #f5f7ff;
        }
        .activity-name {
            font-weight: bold;
            color: #1a1a2e;
        }
        .badge {
            display: inline-block;
            padding: 1px 5px;
            border-radius: 2px;
            font-size: 7pt;
            font-weight: bold;
        }
        .badge-yes { background: #ffd8a8; color: #b35000; }
        .badge-no  { background: #d3f9d8; color: #1a5e1a; }
        .footer {
            margin-top: 16px;
            font-size: 7.5pt;
            color: #666;
            border-top: 1px solid #ddd;
            padding-top: 6px;
        }
    </style>
</head>
<body>

<h1>Verzeichnis von Verarbeitungstätigkeiten</h1>
<p style="margin:0 0 12px; color:#555; font-size:9pt;">Art. 30 DSGVO — Muster des BfDI</p>

<div class="meta">
    <table>
        <tr><td>Verantwortlicher:</td><td>{{ tenant.name ?? '—' }}</td></tr>
        <tr><td>Datenschutzbeauftragter:</td><td>{{ tenant.dpoContactName ?? '—' }} {{ tenant.dpoContactEmail ? '(' ~ tenant.dpoContactEmail ~ ')' : '' }}</td></tr>
        <tr><td>Exportiert am:</td><td>{{ exportedAt|date('d.m.Y H:i') }}</td></tr>
        <tr><td>Anzahl Verarbeitungstätigkeiten:</td><td>{{ activities|length }}</td></tr>
    </table>
</div>

{% if activities|length == 0 %}
    <p style="color:#e03131; font-weight:bold;">Keine Verarbeitungstätigkeiten erfasst.</p>
{% else %}

<table class="vvt">
    <thead>
        <tr>
            <th style="width:12%;">Verarbeitungstätigkeit</th>
            <th style="width:12%;">Verarbeitungszweck</th>
            <th style="width:10%;">Betroffene Personen</th>
            <th style="width:10%;">Kategorien pers. Daten</th>
            <th style="width:10%;">Empfänger</th>
            <th style="width:8%;">Drittland</th>
            <th style="width:10%;">Löschfristen</th>
            <th style="width:14%;">TOMs</th>
            <th style="width:8%;">Rechtsgrundlage</th>
        </tr>
    </thead>
    <tbody>
        {% for activity in activities %}
        <tr>
            <td class="activity-name">{{ activity.name }}</td>
            <td>{{ activity.purposes|join('; ') }}</td>
            <td>{{ activity.dataSubjectCategories|join('; ') }}</td>
            <td>{{ activity.personalDataCategories|join('; ') }}</td>
            <td>
                {% if activity.recipientCategories %}
                    {{ activity.recipientCategories|join('; ') }}
                {% endif %}
                {% if activity.recipientDetails %}
                    {{ activity.recipientDetails }}
                {% endif %}
                {% if not activity.recipientCategories and not activity.recipientDetails %}—{% endif %}
            </td>
            <td>
                {% if activity.hasThirdCountryTransfer %}
                    <span class="badge badge-yes">Ja</span>
                    {% if activity.thirdCountries %}
                        <br>{{ activity.thirdCountries|join(', ') }}
                    {% endif %}
                {% else %}
                    <span class="badge badge-no">Nein</span>
                {% endif %}
            </td>
            <td>
                {{ activity.retentionPeriod ?? '—' }}
                {% if activity.retentionPeriodDays %}
                    ({{ activity.retentionPeriodDays }} Tage)
                {% endif %}
            </td>
            <td>
                {% if activity.technicalOrganizationalMeasures %}
                    {{ activity.technicalOrganizationalMeasures }}
                {% endif %}
                {% if activity.implementedControls|length > 0 %}
                    <br>Controls: {% for c in activity.implementedControls %}{{ c.identifier ?? c.id }}{% if not loop.last %}, {% endif %}{% endfor %}
                {% endif %}
                {% if not activity.technicalOrganizationalMeasures and activity.implementedControls|length == 0 %}—{% endif %}
            </td>
            <td>{{ activity.legalBasis ?? '—' }}</td>
        </tr>
        {% endfor %}
    </tbody>
</table>

{% endif %}

<div class="footer">
    Dieses Dokument wurde automatisch aus dem ISMS-Helfer generiert.
    Verantwortlich für die Richtigkeit der Daten ist der Verantwortliche (Art. 5 Abs. 2 DSGVO).
    Seite <span class="pageNumber"></span>
</div>

</body>
</html>
