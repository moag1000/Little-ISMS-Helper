{% extends 'base.html.twig' %}
{% trans_default_domain 'privacy' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'processing_activity.export.progress_title'|trans({}, 'privacy') }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'processing_activity.breadcrumb.privacy'|trans({}, 'privacy'), icon: 'shield-check' },
            { label: 'processing_activity.breadcrumb.vvt'|trans({}, 'privacy'), url: path('app_processing_activity_index') },
            { label: 'processing_activity.export.progress_title'|trans({}, 'privacy') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'nav-download', label: 'processing_activity.export.badge'|trans({}, 'privacy') },
        title: 'processing_activity.export.progress_title'|trans({}, 'privacy'),
        subtitle: 'processing_activity.export.progress_subtitle'|trans({}, 'privacy'),
    }) }}

    {# Turbo cache disabled — live status changes every 3 s #}
    <meta name="turbo-cache-control" content="no-cache">

    <div class="row justify-content-center mt-4">
        <div class="col-lg-8 col-xl-6">
            {% include '_components/_async_job_progress.html.twig' with {
                job_id:    jobId,
                job_name:  'processing_activity.vvt_export',
                job_label: 'processing_activity.export.progress_title'|trans({}, 'privacy'),
                cancel_url: cancelUrl,
                download_url: downloadUrl,
                download_label: 'processing_activity.export.download_button'|trans({}, 'privacy'),
            } %}

            <div class="mt-3 text-center text-muted small">
                <i class="fa-icon fa-icon--status-info" aria-hidden="true"></i>
                {{ 'admin.job.worker_hint'|trans({}, 'admin') }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
