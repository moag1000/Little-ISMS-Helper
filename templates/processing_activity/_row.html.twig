{# Single ProcessingActivity table row — shared by the index and the Turbo Stream
   that replaces/appends a row after an in-modal save. The title cell opens the
   read-only detail in the fa-form-modal frame; the eye/edit actions do the same. #}
{% trans_default_domain 'privacy' %}
{% import '_components/_fa_progress.html.twig' as _fa_progress %}
{% import '_components/_fa_status_chip.html.twig' as _fa_status_chip %}
<tr id="processing-activity-row-{{ pa.id }}"
    data-processing-activity-id="{{ pa.id }}">
    <td class="bulk-select-column">
        <input type="checkbox"
               class="form-check-input"
               data-bulk-actions-target="item"
               data-action="bulk-actions#selectItem"
               value="{{ pa.id }}"
               aria-label="{{ 'common.select'|trans({}, 'messages') }} {{ pa.name }}">
    </td>
    <td>
        <a href="{{ path('app_processing_activity_show', {id: pa.id}) }}"
           data-turbo-frame="fa-form-modal"
           class="fa-row-link"><strong>{{ pa.name }}</strong></a>
        <br>
        <small class="text-muted">
            {% if pa.processesSpecialCategories %}
                {% include '_components/_badge.html.twig' with { variant: 'danger', content: 'processing_activity.badge.special_categories'|trans({}, 'privacy') } %}
            {% endif %}
            {% if pa.hasThirdCountryTransfer %}
                {% include '_components/_badge.html.twig' with { variant: 'warning', content: 'processing_activity.badge.third_country'|trans({}, 'privacy') } %}
            {% endif %}
            {% if pa.requiresDPIA and not pa.dpiaCompleted %}
                {% include '_components/_badge.html.twig' with { variant: 'danger', content: 'processing_activity.badge.dpia_required'|trans({}, 'privacy') } %}
            {% endif %}
        </small>
    </td>
    <td>
        {{ ('processing_activity.legal_basis.' ~ pa.legalBasis)|trans({}, 'privacy') }}
    </td>
    <td>
        {{ pa.dataSubjectCategories|length }} {{ 'processing_activity.table.categories'|trans({}, 'privacy') }}<br>
        {% if pa.estimatedDataSubjectsCount %}
            <small class="text-muted">~{{ pa.estimatedDataSubjectsCount }} {{ 'processing_activity.table.subjects'|trans({}, 'privacy') }}</small>
        {% endif %}
    </td>
    <td>
        {% if pa.riskLevel %}
            {% set risk_class = {
                'low': 'success',
                'medium': 'info',
                'high': 'warning',
                'critical': 'danger'
            }[pa.riskLevel] %}
            {% include '_components/_badge.html.twig' with { variant: risk_class, content: ('processing_activity.risk_level.' ~ pa.riskLevel)|trans({}, 'privacy') } %}
        {% else %}
            <span class="text-muted">—</span>
        {% endif %}
    </td>
    <td>
        {{ _fa_status_chip.render({
            entity_class: 'App\\Entity\\ProcessingActivity',
            status_key: pa.status,
            label: ('processing_activity.status.' ~ pa.status)|trans({}, 'privacy')
        }) }}
    </td>
    <td>
        {% set completeness = pa.completenessPercentage %}
        {{ _fa_progress.render({ value: completeness, tone: completeness == 100 ? 'success' : (completeness >= 70 ? 'warning' : 'danger'), showText: true }) }}
    </td>
    <td>
        <div class="btn-group btn-group-sm" role="group" aria-label="{{ 'common.actions'|trans({}, 'messages') }}">
            <a href="{{ path('app_processing_activity_show', {id: pa.id}) }}"
               class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
               data-turbo-frame="fa-form-modal"
               title="{{ 'common.view'|trans({}, 'messages') }}" aria-label="{{ 'common.view'|trans({}, 'messages') }}">
                <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
            </a>
            {% if is_granted('ROLE_USER') %}
            <a href="{{ path('app_processing_activity_edit', {id: pa.id}) }}"
               class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
               data-turbo-frame="fa-form-modal"
               title="{{ 'common.edit'|trans({}, 'messages') }}" aria-label="{{ 'common.edit'|trans({}, 'messages') }}">
                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
            </a>
            {% endif %}
        </div>
    </td>
</tr>
