{% extends 'base.html.twig' %}
{% trans_default_domain 'privacy' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'processing_activity.page.new_title'|trans({}, 'privacy')}}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'processing_activity.breadcrumb.privacy'|trans({}, 'privacy'), url: path('app_processing_activity_index'), icon: 'shield-check' },
            { label: 'processing_activity.breadcrumb.vvt'|trans({}, 'privacy'), url: path('app_processing_activity_index') },
            { label: 'processing_activity.breadcrumb.new'|trans({}, 'privacy')}
        ]
    } %}

    {{ _fa_page_header.render({
        title: 'processing_activity.page.new_title'|trans({}, 'privacy'),
        subtitle: 'processing_activity.page.new_subtitle'|trans({}, 'privacy'),
        badge: { icon: 'plus', label: '' }
    }) }}

    {# Foundation P-14 — VVT Template Library (M-05). Lets the DPO start from
       a curated GDPR Art. 30 starter VVT instead of a blank form. #}
    {% set _system_templates = system_templates('App\\Entity\\ProcessingActivity') %}
    {% if _system_templates|length > 0 %}
        <div class="fa-template-cta my-3 p-3 border rounded bg-body-tertiary d-flex flex-wrap align-items-center gap-3">
            <div class="flex-grow-1">
                <div class="fw-semibold">
                    <i class="fa-icon fa-icon--nav-collection" aria-hidden="true"></i>
                    {{ 'system_templates.cta.button'|trans({}, 'system_templates') }}
                </div>
                <div class="small text-body-secondary">
                    {{ 'system_templates.cta.hint'|trans({}, 'system_templates') }}
                </div>
            </div>
            <button type="button" class="btn btn-outline-primary"
                    data-controller="fa-modal-dispatcher"
                    data-action="click->fa-modal-dispatcher#open"
                    data-fa-modal-id="systemTemplateModalVvtNew">
                {{ 'system_templates.cta.button'|trans({}, 'system_templates') }}
            </button>
        </div>
        {% include '_components/_system_template_selector.html.twig' with {
            templates: _system_templates,
            entity_class: 'App\\Entity\\ProcessingActivity',
            redirect_to: 'app_processing_activity_index',
            modal_id: 'systemTemplateModalVvtNew'
        } %}
    {% endif %}

    {{ form_start(form) }}

    {% include '_components/_auto_form.html.twig' with {
        'form': form,
        'layout': 'outline-rail',
        'eyebrow': 'DSGVO Art. 30 · Verarbeitungstätigkeit',
        'title': 'processing_activity.page.new_title'|trans({}, 'privacy'),
        'subtitle': 'processing_activity.page.new_subtitle'|trans({}, 'privacy'),
        'sections': {
            'overview': {
                'label': 'processing_activity.section.basic_info'|trans({}, 'privacy'),
                'fields': ['name', 'status', 'description', 'responsibleDepartment']
            },
            'purposes': {
                'label': 'processing_activity.section.additional'|trans({}, 'privacy'),
                'fields': ['purposes', 'dataSources', 'startDate', 'endDate', 'nextReviewDate']
            },
            'legal_basis': {
                'label': 'processing_activity.section.basic_info'|trans({}, 'privacy') ~ ' · ' ~ 'processing_activity.form.legal_basis'|trans({}, 'privacy'),
                'fields': ['legalBasis', 'legalBasisDetails', 'legalBasisSpecialCategories']
            },
            'data_categories': {
                'label': 'processing_activity.section.personal_data'|trans({}, 'privacy'),
                'fields': ['dataSubjectCategories', 'estimatedDataSubjectsCount', 'personalDataCategories', 'processesSpecialCategories', 'specialCategoriesDetails', 'processesCriminalData']
            },
            'recipients': {
                'label': 'processing_activity.section.recipients_transfers'|trans({}, 'privacy'),
                'fields': ['recipientCategories', 'recipientDetails', 'hasThirdCountryTransfer', 'thirdCountries', 'transferSafeguards', 'involvesProcessors', 'processorSuppliers', 'isJointController', 'jointControllerDetails']
            },
            'retention': {
                'label': 'processing_activity.section.retention'|trans({}, 'privacy'),
                'fields': ['retentionPeriod', 'retentionPeriodDays', 'retentionLegalBasis']
            },
            'measures': {
                'label': 'processing_activity.section.security'|trans({}, 'privacy'),
                'fields': ['technicalOrganizationalMeasures', 'implementedControls', 'assets']
            },
            'audit_metadata': {
                'label': 'processing_activity.section.risk_assessment'|trans({}, 'privacy'),
                'fields': ['isHighRisk', 'dpiaCompleted', 'dpiaDate', 'riskLevel', 'hasAutomatedDecisionMaking', 'automatedDecisionMakingDetails', 'contactPersonUser', 'contactPerson', 'contactDeputyPersons', 'dataProtectionOfficer', 'dataProtectionOfficerPerson', 'dataProtectionOfficerDeputyPersons']
            }
        },
        'col_widths': {
            'name': 6,
            'status': 6,
            'description': 12,
            'responsibleDepartment': 12,
            'purposes': 6,
            'dataSources': 6,
            'startDate': 4,
            'endDate': 4,
            'nextReviewDate': 4,
            'legalBasis': 6,
            'legalBasisDetails': 12,
            'legalBasisSpecialCategories': 12,
            'dataSubjectCategories': 8,
            'estimatedDataSubjectsCount': 4,
            'personalDataCategories': 12,
            'processesSpecialCategories': 6,
            'processesCriminalData': 6,
            'specialCategoriesDetails': 6,
            'recipientCategories': 6,
            'hasThirdCountryTransfer': 6,
            'recipientDetails': 12,
            'thirdCountries': 6,
            'transferSafeguards': 6,
            'involvesProcessors': 6,
            'processorSuppliers': 6,
            'isJointController': 6,
            'jointControllerDetails': 12,
            'retentionPeriod': 8,
            'retentionPeriodDays': 4,
            'retentionLegalBasis': 12,
            'technicalOrganizationalMeasures': 12,
            'implementedControls': 6,
            'assets': 6,
            'isHighRisk': 4,
            'dpiaCompleted': 4,
            'dpiaDate': 4,
            'riskLevel': 12,
            'hasAutomatedDecisionMaking': 12,
            'automatedDecisionMakingDetails': 12,
            'contactPersonUser': 4,
            'contactPerson': 4,
            'contactDeputyPersons': 4,
            'dataProtectionOfficer': 4,
            'dataProtectionOfficerPerson': 4,
            'dataProtectionOfficerDeputyPersons': 4
        },
        'translation_domain': 'privacy',
        'actions': {
            'close': { 'label': 'processing_activity.action.cancel'|trans({}, 'privacy'), 'variant': 'ghost' },
            'submit': { 'label': 'processing_activity.action.save'|trans({}, 'privacy'), 'variant': 'primary' }
        }
    } %}

    {{ form_end(form) }}
</div>
{% endblock %}
