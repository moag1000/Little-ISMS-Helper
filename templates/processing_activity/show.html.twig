{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% trans_default_domain 'privacy' %}
{% block title %}{{ processing_activity.name }} - Processing Activity{% endblock %}

{% block body %}
{% import '_components/_fa_alva_hint.html.twig' as _fa_alva_hint %}
{% import '_components/_fa_status_chip.html.twig' as _fa_status_chip %}
{% import '_components/_lifecycle_actions.html.twig' as _lifecycle_actions %}
{% import '_components/_lifecycle_history_tab.html.twig' as _lifecycle_history %}
<div class="container-fluid mt-4">
    {# Breadcrumb #}
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'GDPR', url: path('app_processing_activity_index'), icon: 'shield-check' },
            { label: 'VVT', url: path('app_processing_activity_index') },
            { label: processing_activity.name }
        ]
    } %}

    {% set hint = alva_hint(processing_activity) %}
    {% if hint %}{{ _fa_alva_hint.render(hint) }}{% endif %}

    {# Page Header #}
    {{ _fa_page_header.render({
        badge:    { icon: 'nav-file-earmark-text', label: 'GDPR' },
        title:    processing_activity.name,
        subtitle: 'processing_activity.show.subtitle'|trans({}, 'privacy'),
        actions: [
            { label: 'Edit',         variant: 'primary', icon: 'ui-edit',     href: path('app_processing_activity_edit', {id: processing_activity.id}) },
            { label: 'Clone',        variant: 'ghost',   icon: 'files',      href: '#', attrs: { 'data-action': 'clone' } },
            { label: 'Back to List', variant: 'ghost',   icon: 'util-arrow-left', href: path('app_processing_activity_index') }
        ]
    }) }}

    {# Lifecycle X.3 — status pill + transition dropdown #}
    <div class="d-flex align-items-center gap-2 mb-3" data-testid="lifecycle-toolbar">
        {{ _fa_status_chip.render({ entity_class: 'App\\Entity\\ProcessingActivity', status_key: processing_activity.status }) }}
        {{ _lifecycle_actions.dropdown(processing_activity, 'processing-activity', 'processing_activity_lifecycle') }}
    </div>

    {# Compliance Status Banner #}
    {% if not compliance_report.is_compliant %}
        {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning' } } %}
            {% block alert_body %}
            <div class="fa-alert__title">Compliance Issues</div>
            <p>This processing activity has {{ compliance_report.validation_errors|length }} validation error(s):</p>
            <ul>
                {% for error in compliance_report.validation_errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
            {% endblock %}
        {% endembed %}
    {% endif %}

    {# Quick Stats #}
    <div class="row mb-4">
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' %}
                {% block card_body %}
                    <div class="text-center">
                        <div class="text-muted mb-2 fw-semibold">{{ 'processing_activity.kpi.completeness'|trans({}, 'privacy') }}</div>
                        {% set completeness = compliance_report.completeness_percentage %}
                        <div class="fs-2 fw-bold mb-0 {{ completeness == 100 ? 'text-success' : 'text-warning' }}">{{ completeness }}%</div>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' %}
                {% block card_body %}
                    <div class="text-center">
                        <div class="text-muted mb-2 fw-semibold">{{ 'processing_activity.kpi.status'|trans({}, 'privacy') }}</div>
                        <div class="fs-4 fw-bold mb-0"><span class="{{ badge_status(processing_activity.status) }}">{{ processing_activity.status|upper }}</span></div>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' %}
                {% block card_body %}
                    <div class="text-center">
                        <div class="text-muted mb-2 fw-semibold">{{ 'processing_activity.kpi.risk_level'|trans({}, 'privacy') }}</div>
                        {% if processing_activity.riskLevel %}
                            <div class="fs-4 fw-bold mb-0"><span class="{{ badge_risk(processing_activity.riskLevel) }}">{{ processing_activity.riskLevel|upper }}</span></div>
                        {% else %}
                            <div class="fs-4 fw-semibold mb-0 text-muted">—</div>
                        {% endif %}
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' %}
                {% block card_body %}
                    <div class="text-center">
                        <div class="text-muted mb-2 fw-semibold">{{ 'processing_activity.kpi.dpia_status'|trans({}, 'privacy') }}</div>
                        {% if processing_activity.requiresDPIA %}
                            {% if processing_activity.dpiaCompleted %}
                                <div class="fs-4 fw-bold mb-0 text-success"><i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i></div>
                                <small class="text-muted">{{ processing_activity.dpiaDate|date('Y-m-d') }}</small>
                            {% else %}
                                <div class="fs-4 fw-bold mb-0 text-danger"><i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i></div>
                                <small class="text-danger">{{ 'processing_activity.kpi.required'|trans({}, 'privacy') }}</small>
                            {% endif %}
                        {% else %}
                            <div class="fs-4 fw-semibold mb-0 text-muted">{{ 'processing_activity.kpi.not_required'|trans({}, 'privacy') }}</div>
                        {% endif %}
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    {# Main Content Tabs #}
    <ul class="nav nav-tabs" id="processingActivityTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="overview-tab" data-bs-toggle="tab" data-bs-target="#overview" type="button" role="tab">
                <i class="fa-icon fa-icon--ui-info" aria-hidden="true"></i> Overview
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="data-tab" data-bs-toggle="tab" data-bs-target="#data" type="button" role="tab">
                <i class="fa-icon fa-icon--asset-database" aria-hidden="true"></i> {{ 'processing_activity.show.tab.data_details'|trans({}, 'privacy') }}
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="compliance-tab" data-bs-toggle="tab" data-bs-target="#compliance" type="button" role="tab">
                <i class="fa-icon fa-icon--compliance-shield" aria-hidden="true"></i> Compliance
            </button>
        </li>
        {% if processing_activity.hasThirdCountryTransfer %}
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="tia-tab" data-bs-toggle="tab" data-bs-target="#tia" type="button" role="tab"
                    aria-label="{{ 'processing_activity.tab.tia'|trans({}, 'privacy') }}"
                    title="{{ 'processing_activity.tab.tia_tooltip'|trans({}, 'privacy') }}">
                <i class="fa-icon fa-icon--globe" aria-hidden="true"></i>
                TIA
                {% if tias is defined and tias|length > 0 %}
                    <span class="badge bg-secondary ms-1">{{ tias|length }}</span>
                {% endif %}
            </button>
        </li>
        {% endif %}
    </ul>

    <div class="tab-content" id="processingActivityTabsContent">
        {# Overview Tab #}
        <div class="tab-pane fade show active" id="overview" role="tabpanel">
            {% embed '_components/_card.html.twig' %}
                {% block card_body %}
                    <h2 class="h5">{{ 'processing_activity.section.basic_info'|trans({}, 'privacy') }}</h2>
                    <dl class="row">
                        <dt class="col-sm-3">{{ 'processing_activity.field.name'|trans({}, 'privacy') }}:</dt>
                        <dd class="col-sm-9">{{ processing_activity.name }}</dd>

                        <dt class="col-sm-3">{{ 'processing_activity.field.description'|trans({}, 'privacy') }}:</dt>
                        <dd class="col-sm-9">{{ processing_activity.description ?? '—' }}</dd>

                        <dt class="col-sm-3">{{ 'processing_activity.field.purposes'|trans({}, 'privacy') }} (Art. 30(1)(a)):</dt>
                        <dd class="col-sm-9">
                            {% for purpose in processing_activity.purposes %}
                                {% include '_components/_badge.html.twig' with { variant: 'primary', content: purpose } %}
                            {% endfor %}
                        </dd>

                        <dt class="col-sm-3">{{ 'processing_activity.field.legal_basis'|trans({}, 'privacy') }} (Art. 6):</dt>
                        <dd class="col-sm-9">
                            <strong>{{ processing_activity.legalBasis }}</strong>
                            {% if processing_activity.legalBasisDetails %}
                                <br><small class="text-muted">{{ processing_activity.legalBasisDetails }}</small>
                            {% endif %}
                        </dd>

                        <dt class="col-sm-3">{{ 'processing_activity.field.responsible_department'|trans({}, 'privacy') }}:</dt>
                        <dd class="col-sm-9">
                            {% if processing_activity.responsibleDepartmentEntity %}
                                <strong>{{ processing_activity.responsibleDepartmentEntity.name }}</strong>
                                {% if processing_activity.responsibleDepartmentEntity.code %}
                                    <span class="text-muted">({{ processing_activity.responsibleDepartmentEntity.code }})</span>
                                {% endif %}
                                {% if processing_activity.responsibleDepartment %}
                                    <br><small class="text-muted">{{ 'processing_activity.field.responsible_department'|trans({}, 'privacy') }} (Legacy): {{ processing_activity.responsibleDepartment }}</small>
                                {% endif %}
                            {% else %}
                                {{ processing_activity.responsibleDepartment ?? '—' }}
                            {% endif %}
                        </dd>

                        <dt class="col-sm-3">{{ 'processing_activity.field.contact_person'|trans({}, 'privacy') }}:</dt>
                        <dd class="col-sm-9">{{ processing_activity.effectiveContactPerson ?? (processing_activity.contactPersonUser ? processing_activity.contactPersonUser.userIdentifier : '—') }}</dd>

                        <dt class="col-sm-3">{{ 'processing_activity.field.data_protection_officer'|trans({}, 'privacy') }}:</dt>
                        <dd class="col-sm-9">{{ processing_activity.dataProtectionOfficer ? processing_activity.dataProtectionOfficer.userIdentifier : '—' }}</dd>
                    </dl>
                {% endblock %}
            {% endembed %}
        </div>

        {# Data Details Tab #}
        <div class="tab-pane fade" id="data" role="tabpanel">
            {% embed '_components/_card.html.twig' %}
                {% block card_body %}
                    <h2 class="h5">{{ 'processing_activity.section.data_subjects'|trans({}, 'privacy') }}</h2>
                    <dl class="row">
                        <dt class="col-sm-3">{{ 'processing_activity.field.data_subject_categories'|trans({}, 'privacy') }}:</dt>
                        <dd class="col-sm-9">
                            {% for category in processing_activity.dataSubjectCategories %}
                                {% include '_components/_badge.html.twig' with { variant: 'info', content: category } %}
                            {% endfor %}
                        </dd>
                        <dt class="col-sm-3">{{ 'processing_activity.field.estimated_data_subjects_count'|trans({}, 'privacy') }}:</dt>
                        <dd class="col-sm-9">{{ processing_activity.estimatedDataSubjectsCount ?? '—' }}</dd>
                    </dl>

                    <hr>

                    <h2 class="h5">{{ 'processing_activity.section.personal_data'|trans({}, 'privacy') }}</h2>
                    <dl class="row">
                        <dt class="col-sm-3">{{ 'processing_activity.field.personal_data_categories'|trans({}, 'privacy') }}:</dt>
                        <dd class="col-sm-9">
                            {% for category in processing_activity.personalDataCategories %}
                                {% include '_components/_badge.html.twig' with { variant: 'secondary', content: category } %}
                            {% endfor %}
                        </dd>

                        {% if processing_activity.processesSpecialCategories %}
                            <dt class="col-sm-3">{{ 'processing_activity.field.processes_special_categories'|trans({}, 'privacy') }} (Art. 9):</dt>
                            <dd class="col-sm-9">
                                {% include '_components/_badge.html.twig' with { variant: 'danger', content: 'common.yes'|trans({}, 'messages') } %}
                                {% for detail in processing_activity.specialCategoriesDetails ?? [] %}
                                    {% include '_components/_badge.html.twig' with { variant: 'danger', content: detail } %}
                                {% endfor %}
                                {% if processing_activity.legalBasisSpecialCategories %}
                                    <br><small class="text-muted">{{ 'processing_activity.field.legal_basis'|trans({}, 'privacy') }}: {{ processing_activity.legalBasisSpecialCategories }}</small>
                                {% endif %}
                            </dd>
                        {% endif %}

                        {% if processing_activity.processesCriminalData %}
                            <dt class="col-sm-3">{{ 'processing_activity.field.processes_criminal_data'|trans({}, 'privacy') }} (Art. 10):</dt>
                            <dd class="col-sm-9">{% include '_components/_badge.html.twig' with { variant: 'warning', content: 'common.yes'|trans({}, 'messages') } %}</dd>
                        {% endif %}
                    </dl>

                    <hr>

                    <h2 class="h5">{{ 'processing_activity.section.retention'|trans({}, 'privacy') }}</h2>
                    <dl class="row">
                        <dt class="col-sm-3">{{ 'processing_activity.field.retention_period'|trans({}, 'privacy') }}:</dt>
                        <dd class="col-sm-9">{{ processing_activity.retentionPeriod ?? '—' }}</dd>
                        {% if processing_activity.retentionPeriodDays %}
                            <dt class="col-sm-3">{{ 'processing_activity.field.retention_period_days'|trans({}, 'privacy') }}:</dt>
                            <dd class="col-sm-9">{{ processing_activity.retentionPeriodDays }}</dd>
                        {% endif %}
                        {% if processing_activity.retentionLegalBasis %}
                            <dt class="col-sm-3">{{ 'processing_activity.field.legal_basis'|trans({}, 'privacy') }}:</dt>
                            <dd class="col-sm-9">{{ processing_activity.retentionLegalBasis }}</dd>
                        {% endif %}
                    </dl>
                {% endblock %}
            {% endembed %}
        </div>

        {# Compliance Tab #}
        <div class="tab-pane fade" id="compliance" role="tabpanel">
            {% embed '_components/_card.html.twig' %}
                {% block card_body %}
                    <h2 class="h5">{{ 'processing_activity.section.risk_assessment'|trans({}, 'privacy') }} (Art. 30)</h2>
                    {% embed '_components/_table.html.twig' with {
                        'noMargin': true
                    } %}
                        {% block table_head %}
                            <tr>
                                <th scope="col">{{ 'processing_activity.field.description'|trans({}, 'privacy') }}</th>
                                <th scope="col">{{ 'processing_activity.field.status'|trans({}, 'privacy') }}</th>
                            </tr>
                        {% endblock %}
                        {% block table_body %}
                            {% for check, passed in compliance_report.compliance_checks %}
                                <tr>
                                    <td>{{ check|replace({'_': ' '})|title }}</td>
                                    <td>
                                        {% if passed %}
                                            {% include '_components/_badge.html.twig' with { variant: 'success', icon: 'status-ok', content: 'Pass' } %}
                                        {% else %}
                                            {% include '_components/_badge.html.twig' with { variant: 'danger', icon: 'status-critical', content: 'Fail' } %}
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endblock %}
                    {% endembed %}</div>

                    <h2 class="h5 mt-4">{{ 'processing_activity.section.security'|trans({}, 'privacy') }}</h2>
                    <p>{{ processing_activity.technicalOrganizationalMeasures ?? 'processing_activity.show.not_documented'|trans({}, 'privacy') }}</p>

                    {% if processing_activity.implementedControls|length > 0 %}
                        <h3 class="h6">{{ 'processing_activity.show.linked_controls'|trans({}, 'privacy') }}:</h3>
                        <ul>
                            {% for control in processing_activity.implementedControls %}
                                <li>{% include '_components/_iso_reference_label.html.twig' with { control: control, separator: ' - ' } only %}</li>
                            {% endfor %}
                        </ul>
                    {% endif %}

                    {# V3 W2-Bug3: Linked Assets — drives DPIA auto-suggestion #}
                    {% if processing_activity.assets|length > 0 %}
                        <h3 class="h6 mt-3">{{ 'processing_activity.show.linked_assets'|trans({}, 'privacy') }}:</h3>
                        <ul>
                            {% for asset in processing_activity.assets %}
                                <li>
                                    <a href="{{ path('app_asset_show', {id: asset.id}) }}">{{ asset.name }}</a>
                                    {% if asset.dataClassification %}
                                        <small class="text-muted">({{ asset.dataClassification }})</small>
                                    {% endif %}
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                {% endblock %}
            {% endembed %}
        </div>
        {# TIA Tab — only shown when hasThirdCountryTransfer = true #}
        {% if processing_activity.hasThirdCountryTransfer %}
        <div class="tab-pane fade" id="tia" role="tabpanel" aria-labelledby="tia-tab">
            {% embed '_components/_card.html.twig' %}
                {% block card_body %}
                    {# ── UX tooltip: what is a TIA? ────────────────────────────────────── #}
                    <div class="alert alert-info d-flex align-items-start gap-2 mb-3" role="note">
                        <i class="fa-icon fa-icon--ui-info-circle flex-shrink-0 mt-1" aria-hidden="true"></i>
                        <div>
                            <strong>{{ 'tia.help.concept_title'|trans({}, 'tia') }}</strong>
                            {{ 'tia.help.concept_body'|trans({}, 'tia') }}
                            <br><small class="text-muted">{{ 'tia.help.norm_ref'|trans({}, 'tia') }}</small>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h5 mb-0">{{ 'processing_activity.section.tia'|trans({}, 'privacy') }}</h2>
                        <a href="{{ path('app_tia_new', {paId: processing_activity.id}) }}" class="btn btn-sm btn-primary">
                            <i class="fa-icon fa-icon--plus" aria-hidden="true"></i>
                            {{ 'tia.action.new'|trans({}, 'tia') }}
                        </a>
                    </div>

                    {% if tias is defined and tias|length > 0 %}
                        {% embed '_components/_table.html.twig' with { noMargin: true } %}
                            {% block table_head %}
                                <tr>
                                    <th scope="col">{{ 'tia.field.recipient_name'|trans({}, 'tia') }}</th>
                                    <th scope="col">{{ 'tia.field.destination_country'|trans({}, 'tia') }}</th>
                                    <th scope="col">{{ 'tia.field.transfer_mechanism'|trans({}, 'tia') }}</th>
                                    <th scope="col">{{ 'tia.field.residual_risk_rating'|trans({}, 'tia') }}</th>
                                    <th scope="col">{{ 'tia.field.status'|trans({}, 'tia') }}</th>
                                    <th scope="col"></th>
                                </tr>
                            {% endblock %}
                            {% block table_body %}
                                {% for tia in tias %}
                                    <tr>
                                        <td>{{ tia.recipientName ?? '—' }}</td>
                                        <td>{{ tia.destinationCountry ?? '—' }}</td>
                                        <td>
                                            {% if tia.transferMechanism %}
                                                {% include '_components/_badge.html.twig' with {
                                                    variant: 'info',
                                                    content: ('tia.mechanism.' ~ tia.transferMechanism)|trans({}, 'tia')
                                                } %}
                                            {% else %}—{% endif %}
                                        </td>
                                        <td>
                                            {% if tia.residualRiskRating %}
                                                {% set riskVariant = tia.residualRiskRating == 'high' ? 'danger' : (tia.residualRiskRating == 'medium' ? 'warning' : 'success') %}
                                                {% include '_components/_badge.html.twig' with {
                                                    variant: riskVariant,
                                                    content: ('tia.risk.' ~ tia.residualRiskRating)|trans({}, 'tia')
                                                } %}
                                            {% else %}—{% endif %}
                                        </td>
                                        <td>
                                            {% if tia.status == 'assessed' %}
                                                {% include '_components/_badge.html.twig' with { variant: 'success', content: 'tia.status.assessed'|trans({}, 'tia') } %}
                                            {% else %}
                                                {% include '_components/_badge.html.twig' with { variant: 'secondary', content: 'tia.status.draft'|trans({}, 'tia') } %}
                                            {% endif %}
                                        </td>
                                        <td>
                                            <a href="{{ path('app_tia_show', {paId: processing_activity.id, id: tia.id}) }}" class="btn btn-sm btn-ghost" title="{{ 'tia.action.view'|trans({}, 'tia') }}">
                                                <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
                                            </a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            {% endblock %}
                        {% endembed %}
                    {% else %}
                        <p class="text-muted">{{ 'tia.empty.body'|trans({}, 'tia') }}</p>
                    {% endif %}
                {% endblock %}
            {% endembed %}
        </div>
        {% endif %}
    </div>

    {# ── F32 DPA-Generator — Art. 28 GDPR AVV action block ───────────────── #}
    {% if is_module_active('privacy') and processing_activity.processorSuppliers|length > 0 %}
    <div class="row mb-4">
        <div class="col-12">
            <section class="fa-section">
                <header class="fa-section__header">
                    <h2 class="fa-section__title">{{ 'dpa.list.generate_avv'|trans({}, 'privacy') }}</h2>
                </header>
                <div class="fa-section__body">
                    <p class="text-muted small">
                        <i class="fa-icon fa-icon--nav-info-circle" aria-hidden="true"></i>
                        {{ 'dpa.list.generate_avv_hint'|trans({}, 'privacy') }}
                    </p>
                    <div class="d-flex flex-column gap-2">
                        {% for supplier in processing_activity.processorSuppliers %}
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-truncate flex-grow-1">{{ supplier.name }}</span>
                            <a href="{{ path('app_dpa_generate_confirm', {supplierId: supplier.id, paId: processing_activity.id}) }}"
                               class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--sm"
                               title="{{ 'dpa.list.generate_avv_hint'|trans({}, 'privacy') }}">
                                <i class="fa-icon fa-icon--nav-file-check" aria-hidden="true"></i>
                                AVV
                            </a>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </section>
        </div>
    </div>
    {% endif %}

    {# Action Forms (hidden) #}
    <form id="cloneForm" method="post" action="{{ path('app_processing_activity_clone', {id: processing_activity.id}) }}" style="display:none;">
        <input type="hidden" name="_token" value="{{ csrf_token('clone' ~ processing_activity.id) }}">
    </form>

<script>
document.querySelector('[data-action="clone"]')?.addEventListener('click', async (e) => {
    e.preventDefault();
    if (await window.faConfirm('{{ 'processing_activity.confirm.clone'|trans({}, 'privacy') }}')) {
        document.getElementById('cloneForm').submit();
    }
});
</script>

{# Lifecycle X.3 — status history tab #}
{{ _lifecycle_history.history('processing-activity', processing_activity.id) }}
{% endblock %}
