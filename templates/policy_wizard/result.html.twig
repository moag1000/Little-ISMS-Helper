{% extends 'base.html.twig' %}
{% trans_default_domain 'policy_wizard' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_section.html.twig' as _fa_section %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_status_pill.html.twig' as pill %}
{% block title %}{{ 'policy_wizard.result.title'|trans }}{% endblock %}

{% block body %}
    {% import '_components/_fa_progress.html.twig' as _fa_progress %}
<div class="container-fluid py-4 fa-aurora-surface">
    {{ _fa_page_header.render({
        badge: { icon: 'status-ok', label: ('policy_wizard.status.' ~ run.status)|trans },
        title: 'policy_wizard.result.title'|trans,
        subtitle: 'policy_wizard.result.subtitle'|trans,
        actions: [
            { label: 'policy_wizard.title'|trans,
              variant: 'ghost',
              icon: 'nav-home',
              href: path('app_policy_wizard_index') }
        ]
    }) }}

    {% if run.mode == 'sandbox' %}
        {{ _fa_alert.render({
            variant: 'info',
            body: 'policy_wizard.message.sandbox_no_persistence'|trans
        }) }}

        {% if sandbox_preview is not null %}
            {% set preview_count = sandbox_preview.documents|default([])|length %}
            {% set preview_body %}
                <p class="text-muted small mb-3">
                    {{ 'policy_wizard.result.sandbox_preview_count'|trans({'%count%': preview_count}, 'policy_wizard') }}
                </p>
                {% if preview_count > 0 %}
                    <ul class="list-group list-group-flush">
                        {% for doc in sandbox_preview.documents %}
                            <li class="list-group-item px-0">
                                <strong>{{ doc.title|default(doc.topic|default('—')) }}</strong>
                                {{ pill.render(doc.standard|default('—'), 'neutral', {size: 'sm', class: 'ms-2'}) }}
                                {% if doc.body_excerpt is defined %}
                                    <p class="small text-muted mb-0 mt-1">{{ doc.body_excerpt|slice(0, 200) }}…</p>
                                {% endif %}
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            {% endset %}
            {{ _fa_section.render({
                title: 'policy_wizard.result.sandbox_preview_heading'|trans,
                body: preview_body
            }) }}
        {% endif %}
    {% endif %}

    {# Cross-Framework-Coverage matrix — Compliance-Manager / ISB / CISO walkthrough wish #}
    {% if cross_coverage is defined and cross_coverage is not null and cross_coverage.hasAnyCoverage() %}
        {% set coverage_body %}
            <p class="text-muted small mb-3">
                {{ 'policy_wizard.result.cross_coverage.description'|trans }}
            </p>
            <div class="row g-3">
                {% for code, framework in cross_coverage.coverageByFramework %}
                    {% if framework.covered_requirements > 0 %}
                        {% set bar_variant = framework.coverage_percent >= 50 ? 'success' : (framework.coverage_percent >= 20 ? 'warning' : 'info') %}
                        <div class="col-md-6 col-xl-4">
                            <div class="card h-100">
                                <div class="card-body">
                                    <h6 class="card-title mb-1">{{ framework.label }}</h6>
                                    <p class="text-muted small mb-2">
                                        {{ 'policy_wizard.result.cross_coverage.framework_label'|trans({
                                            '%covered%': framework.covered_requirements,
                                            '%total%': framework.total_requirements
                                        }) }}
                                    </p>
                                    {{ _fa_progress.render({ value: framework.coverage_percent, tone: bar_variant, size: 'sm', label: framework.label }) }}
                                    <p class="small mb-0 mt-2">
                                        <strong>{{ framework.coverage_percent }}%</strong>
                                        {{ 'policy_wizard.result.cross_coverage.coverage_percent'|trans }}
                                    </p>
                                    {% if framework.covered_refs|length > 0 %}
                                        <details class="mt-2">
                                            <summary class="small text-muted">
                                                {{ 'policy_wizard.result.cross_coverage.show_refs'|trans({'%count%': framework.covered_refs|length}) }}
                                            </summary>
                                            <div class="mt-2 d-flex flex-wrap gap-1">
                                                {% for ref in framework.covered_refs|slice(0, 30) %}
                                                    {{ pill.render(ref, 'neutral', {size: 'sm'}) }}
                                                {% endfor %}
                                                {% if framework.covered_refs|length > 30 %}
                                                    <span class="small text-muted">+{{ framework.covered_refs|length - 30 }}</span>
                                                {% endif %}
                                            </div>
                                        </details>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        {% endset %}
        {{ _fa_section.render({
            title: 'policy_wizard.result.cross_coverage.heading'|trans,
            body: coverage_body
        }) }}
    {% endif %}

    {% set documents_body %}
        {% if document_ids|default([])|length == 0 %}
            <p class="text-muted mb-0">{{ 'policy_wizard.result.documents_empty'|trans }}</p>
        {% else %}
            <p class="text-muted small mb-3">
                {{ 'policy_wizard.result.documents_count'|trans({'%count%': document_ids|length}, 'policy_wizard') }}
            </p>
            <ul class="list-group list-group-flush">
                {% for doc in result_documents|default([]) %}
                    <li class="list-group-item px-0 flex-wrap gap-2">
                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                            <div class="me-auto">
                                <strong>{{ doc.title|default('Document #' ~ doc.id) }}</strong>
                                {% if doc.standard %}
                                    {{ pill.render(('policy_wizard.standard_badge.' ~ doc.standard)|trans({}, 'policy_wizard'), 'neutral', {size: 'sm', class: 'ms-2'}) }}
                                {% endif %}
                                {% if doc.workflow_status is defined and doc.workflow_status is not null %}
                                    {% set wf_tone = doc.workflow_status == 'approved'
                                        ? 'success'
                                        : (doc.workflow_status == 'rejected'
                                            ? 'danger'
                                            : (doc.workflow_status == 'in_progress' ? 'primary' : 'warning')) %}
                                    <a href="{{ path('app_workflow_instance_show', {id: doc.workflow_id}) }}"
                                       class="ms-2 text-decoration-none"
                                       target="_blank" rel="noopener">
                                        {{ pill.render(('policy_wizard.result.workflow.status.' ~ doc.workflow_status)|trans, wf_tone, {size: 'sm', icon: 'nav-workflow'}) }}
                                    </a>
                                {% endif %}
                            </div>
                            <div class="d-flex gap-2 align-items-center">
                                <a href="{{ path('app_document_show', {id: doc.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost btn-sm" target="_blank" rel="noopener">
                                    <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
                                    {{ 'policy_wizard.result.action.view'|trans({}, 'policy_wizard') }}
                                </a>
                                <a href="{{ path('app_document_download', {id: doc.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost btn-sm" target="_blank" rel="noopener">
                                    <i class="fa-icon fa-icon--nav-file-pdf" aria-hidden="true"></i>
                                    {{ 'policy_wizard.result.action.pdf'|trans({}, 'policy_wizard') }}
                                </a>
                            </div>
                        </div>

                        {% if doc.body_snippet is defined and doc.body_snippet is not null %}
                            <div class="mt-2 p-2 rounded bg-body-tertiary border small text-body-secondary">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="fw-semibold text-body">
                                        <i class="fa-icon fa-icon--nav-document" aria-hidden="true"></i>
                                        {{ 'policy_wizard.result.document.body_preview_heading'|trans({}, 'policy_wizard') }}
                                    </span>
                                    <span class="text-muted">
                                        {{ 'policy_wizard.result.document.body_preview_chars'|trans({'%count%': doc.body_chars}, 'policy_wizard') }}
                                    </span>
                                </div>
                                <div>{{ doc.body_snippet }}</div>
                            </div>
                        {% endif %}

                        {% if cross_coverage is defined and cross_coverage is not null
                            and cross_coverage.documentToFrameworks[doc.id] is defined
                            and cross_coverage.documentToFrameworks[doc.id]|length > 0 %}
                            <div class="mt-2 small">
                                <span class="text-muted">{{ 'policy_wizard.result.document.coverage_label'|trans }}</span>
                                {% for fw in cross_coverage.documentToFrameworks[doc.id] %}
                                    {{ pill.render(fw.code ~ ' (' ~ fw.refs|length ~ ')', 'primary', {size: 'sm', class: 'ms-1'}) }}
                                {% endfor %}
                            </div>
                        {% endif %}

                        {% if doc.approval_history is defined and doc.approval_history|length > 0 %}
                            <div class="mt-2 small">
                                <span class="text-muted">{{ 'policy_wizard.result.document.approval_chain'|trans }}:</span>
                                {% for entry in doc.approval_history|slice(0, 5) %}
                                    {% set entry_tone = (entry.action|default('') == 'approved') ? 'success'
                                        : ((entry.action|default('') == 'rejected') ? 'danger' : 'neutral') %}
                                    {{ pill.render(entry.role|default(entry.user|default('?')) ~ (entry.action is defined ? ' · ' ~ entry.action : ''), entry_tone, {size: 'sm', class: 'ms-1'}) }}
                                {% endfor %}
                                {% if doc.approval_history|length > 5 %}
                                    <span class="text-muted">+{{ doc.approval_history|length - 5 }}</span>
                                {% endif %}
                            </div>
                        {% endif %}
                    </li>
                {% else %}
                    {# Legacy fallback for callers that still pass only document_ids #}
                    {% for doc_id in document_ids %}
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <a href="{{ path('app_document_show', {id: doc_id}) }}" target="_blank" rel="noopener">Document #{{ doc_id }}</a>
                            {{ pill.render(('policy_wizard.status.' ~ run.status)|trans, 'neutral', {size: 'sm'}) }}
                        </li>
                    {% endfor %}
                {% endfor %}
            </ul>
        {% endif %}
    {% endset %}

    {{ _fa_section.render({
        title: 'policy_wizard.result.documents_heading'|trans,
        body: documents_body
    }) }}

    {% set next_steps_body %}
        <ul class="mb-0">
            <li>{{ 'policy_wizard.result.next_steps_review'|trans }}</li>
            <li>{{ 'policy_wizard.result.next_steps_translate'|trans }}</li>
        </ul>
    {% endset %}

    {{ _fa_section.render({
        title: 'policy_wizard.result.next_steps_heading'|trans,
        body: next_steps_body
    }) }}
</div>
{% endblock %}
