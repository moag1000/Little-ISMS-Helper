{% trans_default_domain 'policy_wizard' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{# W4-C — Step 0 "Bestandsaufnahme" for brownfield tenants. #}

{% set rows = inventory_rows|default([]) %}
{% set suggestions = topic_suggestions_by_doc|default({}) %}
{% set topics = available_topics|default([]) %}
{% set persisted_decisions = defaults.decisions|default({}) %}

{% if rows is empty %}
    {% include 'policy_wizard/step/_bestandsaufnahme_empty.html.twig' %}
{% else %}
    {{ _fa_alert.render({
        variant: 'info',
        title: 'policy_wizard.step.bestandsaufnahme.title'|trans,
        body: 'policy_wizard.step.bestandsaufnahme.intro'|trans
    }) }}

    {# Junior-ISB-friendly help-card explaining the 4 actions with concrete examples. #}
    <div class="alert alert-secondary border-0 mt-3 mb-0">
        <h6 class="mb-2">
            <i class="bi bi-mortarboard" aria-hidden="true"></i>
            {{ 'policy_wizard.step.bestandsaufnahme.help.title'|trans }}
        </h6>
        <ul class="mb-0 small">
            <li><strong>{{ 'policy_wizard.step.bestandsaufnahme.action.replace'|trans }}</strong> — {{ 'policy_wizard.step.bestandsaufnahme.help.replace'|trans }}</li>
            <li><strong>{{ 'policy_wizard.step.bestandsaufnahme.action.keep'|trans }}</strong> — {{ 'policy_wizard.step.bestandsaufnahme.help.keep'|trans }}</li>
            <li><strong>{{ 'policy_wizard.step.bestandsaufnahme.action.merge_into_topic'|trans }}</strong> — {{ 'policy_wizard.step.bestandsaufnahme.help.merge_into_topic'|trans }}</li>
            <li><strong>{{ 'policy_wizard.step.bestandsaufnahme.action.split_to_topics'|trans }}</strong> — {{ 'policy_wizard.step.bestandsaufnahme.help.split_to_topics'|trans }}</li>
        </ul>
    </div>

    <div class="table-responsive mt-3">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th scope="col">{{ 'policy_wizard.step.bestandsaufnahme.column.title'|trans }}</th>
                    <th scope="col">{{ 'policy_wizard.step.bestandsaufnahme.column.type'|trans }}</th>
                    <th scope="col">{{ 'policy_wizard.step.bestandsaufnahme.column.last_approved'|trans }}</th>
                    <th scope="col">{{ 'policy_wizard.step.bestandsaufnahme.column.owner'|trans }}</th>
                    <th scope="col">{{ 'policy_wizard.step.bestandsaufnahme.column.action'|trans }}</th>
                </tr>
            </thead>
            <tbody>
                {% for row in rows %}
                    {% set doc_id = row.id %}
                    {% set persisted = persisted_decisions[doc_id]|default({}) %}
                    {% set chosen_action = persisted.action|default('') %}
                    {% set chosen_target_topic = persisted.target_topic|default('') %}
                    {% set chosen_target_topics = persisted.target_topics|default([]) %}
                    {% set chosen_rationale = persisted.rationale|default('') %}
                    {% set suggested_topic_list = suggestions[doc_id]|default([]) %}
                    {% set is_top_level = suggested_topic_list|length > 0
                        and suggested_topic_list[0].topic == 'top_level'
                        and suggested_topic_list[0].confidence >= 0.7 %}
                    {# Smart default: top-level documents typically need 'replace', not merge/split. #}
                    {% if is_top_level and chosen_action == '' %}
                        {% set chosen_action = 'replace' %}
                    {% endif %}
                    <tr data-controller="bestandsaufnahme-row" data-bestandsaufnahme-row-action-value="{{ chosen_action }}">
                        <td>
                            <div class="fw-semibold">{{ row.title }}</div>
                            {% if suggested_topic_list|length > 0 %}
                                <small class="text-muted d-block mt-1">
                                    <i class="bi bi-lightbulb" aria-hidden="true"></i>
                                    {{ 'policy_wizard.step.bestandsaufnahme.suggested_topic_help'|trans }}:
                                    {% for sug in suggested_topic_list|slice(0, 3) %}
                                        <span class="badge bg-secondary-subtle text-body">
                                            {{ ('policy_wizard.topic.' ~ sug.topic)|trans({}, 'policy_wizard') }} ({{ (sug.confidence * 100)|round }}%)
                                        </span>
                                    {% endfor %}
                                </small>
                            {% endif %}
                        </td>
                        <td>
                            <span class="badge bg-light text-body">{{ row.documentType }}</span>
                        </td>
                        <td>
                            {% if row.lastApprovedAt %}
                                <small>{{ row.lastApprovedAt|date('Y-m-d') }}</small>
                            {% else %}
                                <small class="text-muted">—</small>
                            {% endif %}
                        </td>
                        <td>
                            <small>{{ row.ownerName|default('—') }}</small>
                        </td>
                        <td>
                            {% set suggestion_key = 'policy_wizard.step.bestandsaufnahme.suggestion.' ~ row.suggestedAction %}
                            <span class="badge bg-info-subtle text-body mb-2 d-inline-block">
                                <i class="bi bi-lightbulb" aria-hidden="true"></i>
                                {{ 'policy_wizard.step.bestandsaufnahme.suggestion_label'|trans }}: {{ suggestion_key|trans|default(row.suggestedAction) }}
                            </span>

                            {% if is_top_level %}
                                <div class="alert alert-warning border-0 py-2 small mb-2">
                                    <i class="bi bi-info-circle" aria-hidden="true"></i>
                                    <strong>{{ 'policy_wizard.step.bestandsaufnahme.top_level_hint.title'|trans }}.</strong>
                                    {{ 'policy_wizard.step.bestandsaufnahme.top_level_hint.body'|trans }}
                                </div>
                            {% endif %}

                            <label class="form-label small fw-semibold mb-1" for="action-{{ doc_id }}">
                                {{ 'policy_wizard.step.bestandsaufnahme.field.action.label'|trans }}
                            </label>
                            <select class="form-select form-select-sm fa-cyber-input__field mb-2"
                                    id="action-{{ doc_id }}"
                                    name="decisions[{{ doc_id }}][action]"
                                    data-bestandsaufnahme-row-target="actionSelect"
                                    data-action="change->bestandsaufnahme-row#updateVisibility"
                                    required>
                                <option value="" {% if chosen_action == '' %}selected{% endif %}>
                                    {{ 'policy_wizard.step.bestandsaufnahme.action_placeholder'|trans }}
                                </option>
                                {% for act in ['replace', 'keep', 'merge_into_topic', 'split_to_topics'] %}
                                    <option value="{{ act }}" {% if chosen_action == act %}selected{% endif %}>
                                        {{ ('policy_wizard.step.bestandsaufnahme.action.' ~ act)|trans }}
                                    </option>
                                {% endfor %}
                            </select>

                            {# merge_into_topic — single dropdown. Only relevant when action=merge_into_topic. #}
                            <div class="mb-2"
                                 data-bestandsaufnahme-row-target="mergeBlock"
                                 {% if chosen_action != 'merge_into_topic' %}hidden{% endif %}>
                                <label class="form-label small fw-semibold mb-1" for="merge-{{ doc_id }}">
                                    {{ 'policy_wizard.step.bestandsaufnahme.field.merge_topic.label'|trans }}
                                </label>
                                <small class="text-muted d-block mb-1">
                                    {{ 'policy_wizard.step.bestandsaufnahme.field.merge_topic.help'|trans }}
                                </small>
                                <select class="form-select form-select-sm fa-cyber-input__field"
                                        id="merge-{{ doc_id }}"
                                        name="decisions[{{ doc_id }}][target_topic]">
                                    <option value="">{{ 'policy_wizard.step.bestandsaufnahme.target_topic_placeholder'|trans }}</option>
                                    {% for topic_key in topics %}
                                        <option value="{{ topic_key }}"
                                            {% if chosen_target_topic == topic_key
                                                  or (chosen_target_topic == '' and suggested_topic_list|length > 0
                                                      and suggested_topic_list[0].topic == topic_key) %}
                                                selected
                                            {% endif %}>
                                            {{ ('policy_wizard.topic.' ~ topic_key)|trans({}, 'policy_wizard') }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>

                            {# split_to_topics — multi-select. Only relevant when action=split_to_topics. #}
                            <div class="mb-2"
                                 data-bestandsaufnahme-row-target="splitBlock"
                                 {% if chosen_action != 'split_to_topics' %}hidden{% endif %}>
                                <label class="form-label small fw-semibold mb-1" for="split-{{ doc_id }}">
                                    {{ 'policy_wizard.step.bestandsaufnahme.field.split_topics.label'|trans }}
                                </label>
                                <small class="text-muted d-block mb-1">
                                    {{ 'policy_wizard.step.bestandsaufnahme.field.split_topics.help'|trans }}
                                </small>
                                <select class="form-select form-select-sm fa-cyber-input__field"
                                        id="split-{{ doc_id }}"
                                        name="decisions[{{ doc_id }}][target_topics][]"
                                        multiple
                                        data-controller="tom-select"
                                        data-tom-select-placeholder-value="{{ 'policy_wizard.step.bestandsaufnahme.target_topic_placeholder'|trans }}">
                                    {% for topic_key in topics %}
                                        <option value="{{ topic_key }}"
                                            {% if topic_key in chosen_target_topics %}selected{% endif %}>
                                            {{ ('policy_wizard.topic.' ~ topic_key)|trans({}, 'policy_wizard') }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>

                            <label class="form-label small mb-1" for="rationale-{{ doc_id }}">
                                {{ 'policy_wizard.step.bestandsaufnahme.rationale_label'|trans }}
                            </label>
                            <textarea class="form-control form-control-sm fa-cyber-input__field"
                                      id="rationale-{{ doc_id }}"
                                      name="decisions[{{ doc_id }}][rationale]"
                                      rows="2"
                                      maxlength="1000"
                                      placeholder="{{ 'policy_wizard.step.bestandsaufnahme.rationale_placeholder'|trans }}">{{ chosen_rationale }}</textarea>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <p class="small text-muted mt-2 mb-0">
        <i class="bi bi-info-circle" aria-hidden="true"></i>
        {{ 'policy_wizard.step.bestandsaufnahme.continue_hint'|trans }}
    </p>
{% endif %}
