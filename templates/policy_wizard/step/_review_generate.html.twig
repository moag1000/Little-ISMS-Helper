{% trans_default_domain 'policy_wizard' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_status_pill.html.twig' as pill %}

{# Junior-ISB-friendly help-card. Aurora-DS: _fa_alert info-variant + bi-mortarboard icon. #}
{% embed '_components/_fa_alert.html.twig' with { props: {
    variant: 'info',
    icon: 'bi-mortarboard',
    class: 'mb-3'
} } %}
    {% block alert_body %}
        {% trans_default_domain 'policy_wizard' %}
        <div class="fa-alert__title">{{ 'policy_wizard.step.review_generate.help.title'|trans }}</div>
        <p class="fa-alert__message mb-2 small">{{ 'policy_wizard.step.review_generate.help.body'|trans }}</p>
        <p class="mb-2 small fst-italic text-muted">{{ 'policy_wizard.step.review_generate.help.example'|trans }}</p>
        <p class="mb-0 small">
            <i class="bi bi-archive" aria-hidden="true"></i>
            {{ 'policy_wizard.step.review_generate.help.reversibility'|trans }}
        </p>
    {% endblock %}
{% endembed %}

{# -- Sandbox banner -- non-persistence is a critical user-expectation guard.
 # When the user confirms in sandbox mode, no Documents are written; the
 # banner makes that explicit BEFORE the user clicks "Generate". #}
{% if run.mode == 'sandbox' %}
    {{ _fa_alert.render({
        variant: 'warning',
        icon: 'bi-flask',
        title: 'policy_wizard.step.review_generate.sandbox_banner.title'|trans,
        body: 'policy_wizard.step.review_generate.sandbox_banner.body'|trans
    }) }}
{% endif %}

{# -- Conflicts + consistency hints rendered ABOVE the review table so the
 # user resolves them BEFORE re-confirming the inputs. Persona-ISB Wish:
 # severity classification before data confirmation. #}
{% if hierarchy_conflicts|default([])|length > 0 %}
    {% set conflicts_body %}
        <ul class="mb-0">
            {% for conflict in hierarchy_conflicts %}
                <li>
                    <strong>{{ conflict.key }}</strong>:
                    {{ conflict.message|trans }}
                    <small class="text-muted">(parent={{ conflict.parent_value|default('—') }}, child={{ conflict.child_value|default('—') }})</small>
                </li>
            {% endfor %}
        </ul>
    {% endset %}
    {{ _fa_alert.render({
        variant: 'danger',
        icon: 'bi-exclamation-octagon',
        title: 'policy_wizard.step.review_generate.conflicts_heading'|trans ~ ' (' ~ ('policy_wizard.review.severity.blocking'|trans) ~ ')',
        body: conflicts_body
    }) }}
{% else %}
    {{ _fa_alert.render({
        variant: 'success',
        icon: 'bi-check-circle',
        body: 'policy_wizard.step.review_generate.conflicts_empty'|trans
    }) }}
{% endif %}

{# Cross-step consistency warnings (NON-blocking informational nudges).
 # Junior-ISB Wish #6 — each warning is a CLICKABLE alert that
 # navigates to the warning's `target_step`. The CrossStepConsistencyValidator
 # stamps every DTO with target_step. #}
{% if consistency_warnings|default([])|length > 0 %}
    <h3 class="h6 mb-2">
        {{ 'policy_wizard.step.review_generate.consistency_heading'|trans }}
        {{ pill.render('policy_wizard.review.severity.non_blocking'|trans, 'warning', {size: 'sm', class: 'ms-1'}) }}
    </h3>
    {% for w in consistency_warnings %}
        {% set target = w.target_step|default('review_generate') %}
        {% set step_title = ('policy_wizard.step.' ~ target ~ '.title')|trans %}
        {# TODO: refactor alert-link pattern #}
        <a href="{{ path('app_policy_wizard_step_show', {runId: run.id, step: target}) }}"
           class="d-block fa-alert fa-alert--warning text-decoration-none mb-2"
           data-target-step="{{ target }}">
            <div class="d-flex align-items-start gap-2">
                <i class="bi bi-arrow-right-circle mt-1 flex-shrink-0" aria-hidden="true"></i>
                <div>
                    <div>{{ w.message_key|trans(w.params|default({})) }}</div>
                    <small class="text-muted d-block mt-1">
                        {{ 'policy_wizard.warning.click_to_jump'|trans({'%step%': step_title}) }}
                    </small>
                </div>
            </div>
        </a>
    {% endfor %}
{% endif %}

{# -- Curated review summary table (replaces the legacy raw-JSON dump).
 # The view-model is built server-side in PolicyWizardController::buildReviewSummary
 # and resolves all User-ID / Person-ID references to "Full Name <email>"
 # so auditors can read the summary without cross-referencing the user table. #}
<h3 class="h6 mb-3 mt-4">{{ 'policy_wizard.step.review_generate.summary_heading'|trans }}</h3>

<dl class="row mb-4">
    <dt class="col-sm-3">{{ ('policy_wizard.mode.' ~ run.mode ~ '.label')|trans }}</dt>
    <dd class="col-sm-9">{{ ('policy_wizard.mode.' ~ run.mode ~ '.description')|trans }}</dd>
</dl>

{% if review_summary|default([])|length == 0 %}
    {{ _fa_alert.render({
        variant: 'info',
        body: 'policy_wizard.review.no_inputs_yet'|trans
    }) }}
{% else %}
    {% for section in review_summary %}
        <div class="card mb-3">
            <div class="card-header py-2 d-flex align-items-center justify-content-between">
                <h4 class="h6 mb-0">{{ section.title_key|trans }}</h4>
                <a href="{{ path('app_policy_wizard_step_show', {runId: run.id, step: section.step_key}) }}"
                   class="small text-decoration-none"
                   title="{{ 'policy_wizard.review.edit_step'|trans }}">
                    <i class="bi bi-pencil-square" aria-hidden="true"></i>
                    {{ 'policy_wizard.review.edit_step'|trans }}
                </a>
            </div>
            <div class="card-body py-2">
                {% if section.rows|length == 0 %}
                    <p class="mb-0 small text-muted">{{ 'policy_wizard.review.no_inputs_in_step'|trans }}</p>
                {% else %}
                    <dl class="row mb-0 small">
                        {% for row in section.rows %}
                            <dt class="col-sm-4 fw-medium">{{ row.label_key|trans }}</dt>
                            <dd class="col-sm-8">
                                {% if row.value_type == 'badges' %}
                                    {% if row.value|length == 0 %}
                                        <span class="text-muted">—</span>
                                    {% else %}
                                        {% for v in row.value %}
                                            {{ pill.render(v, 'neutral', {size: 'sm', class: 'me-1'}) }}
                                        {% endfor %}
                                    {% endif %}
                                {% elseif row.value_type == 'list' %}
                                    {% if row.value|length == 0 %}
                                        <span class="text-muted">—</span>
                                    {% else %}
                                        <ol class="mb-0 ps-3">
                                            {% for v in row.value %}
                                                <li>{{ v }}</li>
                                            {% endfor %}
                                        </ol>
                                    {% endif %}
                                {% elseif row.value_type == 'bool' %}
                                    {% if row.value %}
                                        {{ pill.render('policy_wizard.review.value.yes'|trans, 'success', {size: 'sm', icon: 'bi-check-circle'}) }}
                                    {% else %}
                                        {{ pill.render('policy_wizard.review.value.no'|trans, 'neutral', {size: 'sm', icon: 'bi-x-circle'}) }}
                                    {% endif %}
                                {% elseif row.value_type == 'count' %}
                                    {{ 'policy_wizard.review.value.count'|trans({'%count%': row.value}) }}
                                {% elseif row.value_type == 'count_of' %}
                                    {{ 'policy_wizard.review.value.count_of'|trans(
                                        (row.params|default({}))|merge({'%count%': row.value})
                                    ) }}
                                {% elseif row.value_type == 'hours' %}
                                    {{ 'policy_wizard.review.value.hours'|trans({'%count%': row.value}) }}
                                {% elseif row.value_type == 'months' %}
                                    {{ 'policy_wizard.review.value.months'|trans({'%count%': row.value}) }}
                                {% elseif row.value_type == 'months_with_label' %}
                                    {{ 'policy_wizard.review.value.months'|trans({'%count%': row.value}) }}
                                    {% if row.value == 12 %}
                                        <span class="text-muted small">({{ 'policy_wizard.review.value.months_label.yearly'|trans }})</span>
                                    {% elseif row.value == 24 %}
                                        <span class="text-muted small">({{ 'policy_wizard.review.value.months_label.biennial'|trans }})</span>
                                    {% elseif row.value == 6 %}
                                        <span class="text-muted small">({{ 'policy_wizard.review.value.months_label.semi_annual'|trans }})</span>
                                    {% elseif row.value == 3 %}
                                        <span class="text-muted small">({{ 'policy_wizard.review.value.months_label.quarterly'|trans }})</span>
                                    {% endif %}
                                {% elseif row.value_type == 'trans' %}
                                    {{ row.value|trans }}
                                {% elseif row.value_type == 'muted' %}
                                    <span class="text-muted">{{ row.value }}</span>
                                {% else %}
                                    {{ row.value }}
                                {% endif %}
                            </dd>
                        {% endfor %}
                    </dl>
                {% endif %}
            </div>
        </div>
    {% endfor %}
{% endif %}

{# Audit-trail hint — explicit promise that the generation event is logged
 # with wizard run id + approver names + timestamp. ISO 27001 Clause 7.5.3. #}
<p class="text-muted small mt-3 d-flex align-items-start gap-2">
    <i class="bi bi-shield-lock mt-1 flex-shrink-0" aria-hidden="true"></i>
    <span>{{ 'policy_wizard.step.review_generate.audit_trail_hint'|trans({'%run_id%': run.id}) }}</span>
</p>

<p class="text-muted small mt-2">{{ 'policy_wizard.step.review_generate.generate_hint'|trans }}</p>
