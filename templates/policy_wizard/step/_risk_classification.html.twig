{% trans_default_domain 'policy_wizard' %}
{% set tier_default = defaults.risk_appetite_tier|default(3) %}
{% set data_levels_default = defaults.data_classification_levels|default(3) %}
{% set schutzbedarf_default = defaults.schutzbedarf_levels|default(3) %}
{% set review_interval_default = defaults.review_interval_months|default(12) %}

<div class="row g-3">
    <div class="col-md-12">
        <fieldset>
            <legend class="h6">{{ 'policy_wizard.step.risk_classification.tier_label'|trans }}</legend>
            <p class="text-muted small mb-3">{{ 'policy_wizard.step.risk_classification.direction_hint'|trans }}</p>
            {% for tier in [1, 2, 3, 4, 5] %}
                <div class="form-check">
                    <input class="form-check-input"
                           type="radio"
                           id="tier-{{ tier }}"
                           name="risk_appetite_tier"
                           value="{{ tier }}"
                           {% if tier_default == tier %}checked{% endif %}>
                    <label class="form-check-label" for="tier-{{ tier }}">
                        {{ ('policy_wizard.step.risk_classification.tier_' ~ tier)|trans }}
                    </label>
                </div>
            {% endfor %}
        </fieldset>
    </div>

    <div class="col-md-4">
        <label class="form-label" for="data-classification-levels">Data classification levels</label>
        <select class="form-select fa-cyber-input__field"
                id="data-classification-levels"
                name="data_classification_levels">
            <option value="3" {% if data_levels_default == 3 %}selected{% endif %}>3 levels</option>
            <option value="4" {% if data_levels_default == 4 %}selected{% endif %}>4 levels</option>
        </select>
    </div>

    <div class="col-md-4">
        <label class="form-label" for="schutzbedarf-levels">Schutzbedarf levels (BSI)</label>
        <select class="form-select fa-cyber-input__field"
                id="schutzbedarf-levels"
                name="schutzbedarf_levels">
            <option value="3" {% if schutzbedarf_default == 3 %}selected{% endif %}>3 (BSI default)</option>
            <option value="4" {% if schutzbedarf_default == 4 %}selected{% endif %}>4</option>
        </select>
    </div>

    <div class="col-md-4">
        <label class="form-label" for="review-interval">Review interval (months)</label>
        <input type="number"
               class="form-control fa-cyber-input__field"
               id="review-interval"
               name="review_interval_months"
               min="1"
               max="24"
               value="{{ review_interval_default }}">
        <div class="form-text">{{ 'policy_wizard.error.review_interval_max'|trans }}</div>
    </div>
</div>
