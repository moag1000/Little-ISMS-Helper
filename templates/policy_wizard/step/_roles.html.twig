{% trans_default_domain 'policy_wizard' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% set roles_default = defaults.roles|default({}) %}
{% set function_owners_default = defaults.function_owners|default({}) %}
{% set approval_chain_default = defaults.approval_chain|default([]) %}

{# Junior-ISB-friendly help-card. Plain-language framing of which
 # roles are mandatory in which scope.
 # Aurora-DS: _fa_alert info-variant + bi-mortarboard icon. #}
{% embed '_components/_fa_alert.html.twig' with { props: {
    variant: 'info',
    icon: 'bi-mortarboard',
    class: 'mb-3'
} } %}
    {% block alert_body %}
        <div class="fa-alert__title">{{ 'policy_wizard.step.roles.help.title'|trans }}</div>
        <p class="fa-alert__message mb-2 small">{{ 'policy_wizard.step.roles.help.body'|trans }}</p>
        <p class="mb-0 small fst-italic text-muted">{{ 'policy_wizard.step.roles.help.example'|trans }}</p>
    {% endblock %}
{% endembed %}

{# W2 Gap-A — Krisen-Team RACI hint card. Senior-Consultant
 # "Hand-holding content" Step 3 (07-phase4-sprint-reconciliation.md
 # line 204). Surfaces the default RACI assignment so first-time users
 # don't have to look up BCM-Roles separately. The card is purely
 # informational — no input wiring. #}
{% embed '_components/_fa_alert.html.twig' with { props: {
    variant: 'info',
    icon: 'status-info',
    class: 'mb-3'
} } %}
    {% block alert_body %}
        <div class="fa-alert__title">{{ 'policy_wizard.roles.raci_hint.title'|trans }}</div>
        <p class="fa-alert__message mb-2">{{ 'policy_wizard.roles.raci_hint.intro'|trans }}</p>
        <ul class="list-unstyled small mb-0">
            <li>
                <strong>R</strong>
                <i class="bi bi-info-circle text-muted"
                   data-bs-toggle="tooltip"
                   title="{{ 'policy_wizard.step.roles.tooltip.raci_r'|trans }}"
                   aria-label="{{ 'policy_wizard.step.roles.tooltip.raci_r'|trans }}"></i>
                — {{ 'policy_wizard.roles.raci_hint.r'|trans }}
            </li>
            <li>
                <strong>A</strong>
                <i class="bi bi-info-circle text-muted"
                   data-bs-toggle="tooltip"
                   title="{{ 'policy_wizard.step.roles.tooltip.raci_a'|trans }}"
                   aria-label="{{ 'policy_wizard.step.roles.tooltip.raci_a'|trans }}"></i>
                — {{ 'policy_wizard.roles.raci_hint.a'|trans }}
            </li>
            <li>
                <strong>C</strong>
                <i class="bi bi-info-circle text-muted"
                   data-bs-toggle="tooltip"
                   title="{{ 'policy_wizard.step.roles.tooltip.raci_c'|trans }}"
                   aria-label="{{ 'policy_wizard.step.roles.tooltip.raci_c'|trans }}"></i>
                — {{ 'policy_wizard.roles.raci_hint.c'|trans }}
            </li>
            <li>
                <strong>I</strong>
                <i class="bi bi-info-circle text-muted"
                   data-bs-toggle="tooltip"
                   title="{{ 'policy_wizard.step.roles.tooltip.raci_i'|trans }}"
                   aria-label="{{ 'policy_wizard.step.roles.tooltip.raci_i'|trans }}"></i>
                — {{ 'policy_wizard.roles.raci_hint.i'|trans }}
            </li>
        </ul>
    {% endblock %}
{% endembed %}

<div class="row g-3">
    {% for role_key, label_key in {
        'ciso': 'policy_wizard.step.roles.ciso_label',
        'isb': 'policy_wizard.step.roles.isb_label',
        'dpo': 'policy_wizard.step.roles.dpo_label',
        'bcm_officer': 'policy_wizard.step.roles.bcm_officer_label'
    } %}
        <div class="col-md-6">
            <label class="form-label" for="role-{{ role_key }}">
                {{ label_key|trans }}
                <i class="bi bi-info-circle text-muted ms-1"
                   data-bs-toggle="tooltip"
                   data-bs-placement="right"
                   title="{{ ('policy_wizard.step.roles.tooltip.' ~ role_key)|trans }}"
                   aria-label="{{ ('policy_wizard.step.roles.tooltip.' ~ role_key)|trans }}"></i>
            </label>
            <input type="number"
                   class="form-control fa-cyber-input__field"
                   id="role-{{ role_key }}"
                   name="roles[{{ role_key }}]"
                   min="1"
                   step="1"
                   value="{{ roles_default[role_key]|default('') }}">
        </div>
    {% endfor %}

    <div class="col-12">
        <p class="small text-muted mb-0">
            <i class="bi bi-person-plus" aria-hidden="true"></i>
            {{ 'policy_wizard.step.roles.help.missing_user_link'|trans }}
            <a href="{{ path('user_management_index') }}" target="_blank" rel="noopener">
                {{ 'policy_wizard.step.roles.help.missing_user_link_cta'|trans }}
                <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i>
            </a>
        </p>
    </div>

    <div class="col-12 mt-2">
        <h3 class="h6 mb-2">{{ 'policy_wizard.step.roles.function_owners_label'|trans }}</h3>
        <p class="text-muted small mb-3">{{ 'policy_wizard.step.roles.function_owners_help'|trans }}</p>
        <div class="row g-2">
            {% for fn_key in ['sales', 'operations', 'rnd', 'hr', 'it_operations', 'finance'] %}
                <div class="col-md-4">
                    <label class="form-label small text-muted" for="fn-{{ fn_key }}">
                        {{ fn_key|replace({'_': ' '})|capitalize }}
                    </label>
                    <input type="number"
                           class="form-control fa-cyber-input__field"
                           id="fn-{{ fn_key }}"
                           name="function_owners[{{ fn_key }}]"
                           min="0"
                           step="1"
                           value="{{ function_owners_default[fn_key]|default('') }}">
                </div>
            {% endfor %}
        </div>
    </div>

    <div class="col-12">
        <label class="form-label" for="approval-chain">Approval chain (User-IDs, comma-separated)</label>
        <input type="text"
               class="form-control fa-cyber-input__field"
               id="approval-chain-csv"
               value="{{ approval_chain_default|join(',') }}">
        {% for uid in approval_chain_default %}
            <input type="hidden" name="approval_chain[]" value="{{ uid }}">
        {% endfor %}
    </div>
</div>
