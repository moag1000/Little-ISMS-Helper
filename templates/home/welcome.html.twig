{% extends 'base.html.twig' %}

{% block title %}{{ 'welcome.title'|trans({}, 'welcome') }}{% endblock %}

{% block body %}
<div class="container-fluid welcome-page">
    {# Urgent Tasks Alert (if any) - shown ABOVE hero for maximum visibility #}
    {% if urgent_tasks|length > 0 %}
        <div class="row justify-content-center mb-4" id="urgent-tasks">
            <div class="col-lg-10 col-xl-8">
                {% embed '_components/_card.html.twig' with {borderColor: 'warning', class: 'shadow-sm', urgent_tasks: urgent_tasks, total_urgent_count: total_urgent_count} only %}
                    {% block card_header %}
                        <div class="card-header bg-warning-subtle d-flex align-items-center">
                            <i class="bi bi-bell-fill text-warning me-2" aria-hidden="true"></i>
                            <h2 class="h5 mb-0">{{ 'welcome.urgent_tasks.title'|trans({}, 'welcome') }}</h2>
                            {% include '_components/_badge.html.twig' with { variant: 'warning', class: 'ms-auto', content: total_urgent_count } only %}
                        </div>
                    {% endblock %}
                    {% block card_body %}
                        <div class="row g-3">
                            {% for task in urgent_tasks %}
                                <div class="col-md-6">
                                    <a href="{{ path(task.route, task.route_params|default({})) }}" class="text-decoration-none">
                                        <div class="d-flex align-items-center p-3 rounded border border-{{ task.color }}-subtle bg-{{ task.color }}-subtle hover-lift">
                                            <div class="flex-shrink-0 me-3">
                                                {% include '_components/_badge.html.twig' with {
                                                    variant: task.color,
                                                    icon: task.icon,
                                                    pill: true,
                                                    class: 'p-2'
                                                } only %}
                                            </div>
                                            <div class="flex-grow-1">
                                                <div class="fw-semibold">
                                                    {{ task.title|trans({'%count%': task.count}, 'welcome') }}
                                                </div>
                                                {% if task.top_item_name is defined and task.top_item_name %}
                                                    <small class="d-block text-muted mt-1">
                                                        {{ task.top_item_name }}
                                                        {% if task.top_item_overdue_days is defined %}
                                                            — {{ task.top_item_overdue_days }} {{ 'welcome.days_overdue'|trans({}, 'welcome') }}
                                                        {% elseif task.top_item_days_left is defined %}
                                                            — {{ task.top_item_days_left }} {{ 'welcome.days_left'|trans({}, 'welcome') }}
                                                        {% endif %}
                                                    </small>
                                                {% else %}
                                                    <small class="text-muted">
                                                        {{ 'welcome.urgent_tasks.click_to_view'|trans({}, 'welcome') }}
                                                    </small>
                                                {% endif %}
                                            </div>
                                            <div class="flex-shrink-0">
                                                {% include '_components/_badge.html.twig' with { variant: task.color, class: 'fs-6', content: task.count } only %}
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            {% endfor %}
                        </div>
                    {% endblock %}
                {% endembed %}
            </div>
        </div>
    {% endif %}

    {# Hero Section with Alva — inline SVG reagiert auf Mode-Switch #}
    {% import '_components/_alva.html.twig' as alva %}
    <div class="row justify-content-center mb-5">
        <div class="col-lg-10 col-xl-8">
            <div class="welcome-hero text-center py-5">
                <div class="welcome-logo mb-4 d-flex justify-content-center">
                    {{ alva.render('happy', { size: 180, ariaLabel: 'welcome.logo_alt'|trans({}, 'welcome') })|raw }}
                </div>
                <h1 class="h3 mb-3 welcome-hero__title">{{ 'welcome.headline'|trans({}, 'welcome') }}</h1>
                <p class="lead mb-2 welcome-hero__lead">
                    {{ 'welcome.tagline'|trans({}, 'welcome') }}
                </p>

                {# Dynamic Compliance Status Line #}
                {% if overall_compliance is defined and overall_compliance > 0 %}
                    <p class="lead mb-4 welcome-hero__lead">
                        {{ 'welcome.hero.status'|trans({
                            '%compliance%': overall_compliance,
                            '%urgent%': total_urgent_count|default(0),
                            '%risks%': risks_total|default(0)
                        }, 'welcome') }}
                    </p>
                {% else %}
                    <div class="mb-4"></div>
                {% endif %}

                {# Quick Action Buttons #}
                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a href="{{ path('app_dashboard') }}" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--lg">
                        <i class="bi bi-speedometer2 me-2" aria-hidden="true"></i>
                        {{ 'welcome.action.dashboard'|trans({}, 'welcome') }}
                    </a>
                    {% if total_urgent_count > 0 %}
                        <a href="#urgent-tasks" class="fa-cyber-btn fa-cyber-btn--warning fa-cyber-btn--lg">
                            <i class="fa-icon fa-icon--status-warning me-2" aria-hidden="true"></i>
                            {{ 'welcome.action.urgent_tasks'|trans({'%count%': total_urgent_count}, 'welcome') }}
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    {# Compliance Wizards Section (only if incomplete) #}
    {% if compliance_wizards|length > 0 %}
        <div class="row justify-content-center mb-5" id="compliance-wizards">
            <div class="col-lg-10 col-xl-8">
                {% embed '_components/_card.html.twig' with {borderColor: 'info', class: 'shadow-sm', compliance_wizards: compliance_wizards} only %}
                    {% block card_header %}
                        <div class="card-header bg-info-subtle d-flex align-items-center">
                            <i class="fa-icon fa-icon--audit-internal text-info me-2" aria-hidden="true"></i>
                            <h2 class="h5 mb-0">{{ 'welcome.wizards.title'|trans({}, 'welcome') }}</h2>
                            <a href="{{ path('app_compliance_wizard_index') }}" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--sm ms-auto">
                                {{ 'welcome.wizards.view_all'|trans({}, 'welcome') }}
                            </a>
                        </div>
                    {% endblock %}
                    {% block card_body %}
                        <p class="text-muted mb-3">{{ 'welcome.wizards.description'|trans({}, 'welcome') }}</p>
                        <div class="row g-3">
                            {% for wizard in compliance_wizards %}
                                <div class="col-md-6 col-lg-4">
                                    <a href="{{ path(wizard.route, wizard.route_params) }}" class="text-decoration-none">
                                        <div class="card fa-section h-100 hover-lift border-{{ wizard.color }}">
                                            <div class="card-body">
                                                <div class="d-flex align-items-center mb-2">
                                                    <i class="bi {{ wizard.icon }} text-{{ wizard.color }} me-2 fa-glyph-size-sm" aria-hidden="true"></i>
                                                    <h3 class="h6 mb-0">{{ wizard.code }}</h3>
                                                </div>
                                                <div class="progress progress-h-8 mb-2">
                                                    <div class="progress-bar bg-{{ wizard.color }}"
                                                         role="progressbar"
                                                         style="width: {{ wizard.score }}%"
                                                         aria-valuenow="{{ wizard.score }}"
                                                         aria-valuemin="0"
                                                         aria-valuemax="100"></div>
                                                </div>
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <small class="text-muted">{{ wizard.score }}% {{ 'welcome.wizards.complete'|trans({}, 'welcome') }}</small>
                                                    {% if wizard.critical_gaps > 0 %}
                                                        {% include '_components/_badge.html.twig' with {
                                                            variant: 'danger-subtle',
                                                            class: 'text-danger',
                                                            icon: 'bi-exclamation-circle',
                                                            content: wizard.critical_gaps
                                                        } only %}
                                                    {% endif %}
                                                </div>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            {% endfor %}
                        </div>
                    {% endblock %}
                {% endembed %}
            </div>
        </div>
    {% endif %}

    {# Active Modules Section (with integrated create actions) #}
    <div class="row justify-content-center mb-5">
        <div class="col-lg-10 col-xl-8">
            <h2 class="h4 mb-4 text-center">
                <i class="bi bi-grid-3x3-gap me-2" aria-hidden="true"></i>
                {{ 'welcome.modules.title'|trans({}, 'welcome') }}
            </h2>
            <div class="row g-3">
                {% for module in active_modules %}
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="card fa-section h-100 text-center module-card hover-lift border-0 shadow-sm position-relative">
                            {% if module.create_route is defined %}
                                {# TODO Aurora Sprint E5+: module.color is fully dynamic (any Bootstrap color); map to fa-cyber-btn variant when Aurora has a dynamic-variant API #}
                                <a href="{{ path(module.create_route) }}"
                                   class="btn btn-sm btn-outline-{{ module.color }} position-absolute top-0 end-0 m-2 module-create-btn"
                                   title="{{ 'welcome.create_new'|trans({}, 'welcome') }}">
                                    <i class="bi bi-plus" aria-hidden="true"></i>
                                </a>
                            {% endif %}
                            <a href="{{ path(module.route) }}" class="text-decoration-none">
                                <div class="card-body py-4">
                                    <div class="module-icon mb-3">
                                        {% include '_components/_badge.html.twig' with {
                                            variant: module.color ~ '-subtle',
                                            class: 'text-' ~ module.color ~ ' rounded-circle p-3',
                                            icon: module.icon
                                        } only %}
                                    </div>
                                    <h3 class="h6 mb-2">{{ module.name_key|trans({}, 'welcome') }}</h3>
                                    {% if module.count is not null %}
                                        {% include '_components/_badge.html.twig' with { variant: module.color, content: module.count } only %}
                                    {% endif %}
                                </div>
                            </a>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    {# Skip Welcome Preference #}
    <div class="row justify-content-center mb-4">
        <div class="col-lg-10 col-xl-8">
            {% embed '_components/_card.html.twig' with {variant: 'light', class: 'border-0', skip_welcome: skip_welcome} only %}
                {% block card_body %}
                    <form action="{{ path('app_welcome_preference') }}" method="post" class="d-flex align-items-center justify-content-center gap-3 flex-wrap py-1">
                        <input type="hidden" name="_token" value="{{ csrf_token('welcome_preference') }}">
                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="skipWelcome"
                                   name="skip_welcome"
                                   value="1"
                                   {% if skip_welcome %}checked{% endif %}
                                   onchange="this.form.submit()">
                            <label class="form-check-label" for="skipWelcome">
                                {{ 'welcome.preference.skip_next_time'|trans({}, 'welcome') }}
                            </label>
                        </div>
                        <small class="text-muted">
                            <i class="bi bi-info-circle" aria-hidden="true"></i>
                            {{ 'welcome.preference.hint'|trans({}, 'welcome') }}
                        </small>
                        <small class="text-muted d-block mt-1">
                            {{ 'welcome.preference.session_note'|trans({}, 'welcome') }}
                        </small>
                    </form>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    {# Footer with Tenant Info #}
    {% if tenant %}
        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-8">
                <div class="text-center text-muted small py-3">
                    <i class="bi bi-building me-1" aria-hidden="true"></i>
                    {{ 'welcome.footer.tenant'|trans({'%tenant%': tenant.name}, 'welcome') }}
                </div>
            </div>
        </div>
    {% endif %}
</div>

<style>
    .welcome-page {
        padding-top: 2rem;
    }

    .welcome-hero {
        /* Dezenter Aurora-Farbverlauf — gleichmäßig lesbar über ganze Breite */
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 1rem;
        padding: 3rem 2rem;
        color: var(--fg);
    }
    /* Optionaler subtiler Glow-Hint oben (kein links/rechts-Unterschied) */
    .welcome-hero {
        box-shadow: 0 0 0 1px var(--primary-glow),
                    0 6px 20px rgba(0, 0, 0, 0.04);
        position: relative;
        overflow: hidden;
    }
    .welcome-hero::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 2px;
        background: var(--brand-gradient);
        opacity: 0.6;
    }

    html[data-theme="dark"] .welcome-hero,
    [data-bs-theme="dark"] .welcome-hero {
        background: var(--surface);
        border-color: var(--border);
        color: var(--fg);
        box-shadow: 0 0 0 1px var(--primary-glow),
                    0 8px 24px rgba(0, 0, 0, 0.25);
    }

    .welcome-logo img {
        filter: drop-shadow(0 4px 6px rgba(0, 0, 0, 0.1));
    }

    .module-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .hover-lift:hover {
        transform: translateY(-4px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }

    .module-icon .badge {
        width: 60px;
        height: 60px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .module-create-btn {
        z-index: 1;
        padding: 0.15rem 0.4rem;
        font-size: 0.85rem;
        line-height: 1;
        opacity: 0.6;
        transition: opacity 0.2s ease;
    }

    .module-card:hover .module-create-btn {
        opacity: 1;
    }

    /* Purple color for compliance module — uses Aurora accent tokens */
    .bg-purple-subtle {
        background-color: var(--accent-tint) !important;
    }
    .text-purple {
        color: var(--accent) !important;
    }
    .bg-purple {
        background-color: var(--accent-strong) !important;
    }

    /* Responsive adjustments */
    @media (max-width: 768px) {
        .welcome-hero {
            padding: 2rem 1rem;
        }

        .welcome-logo img {
            max-height: 140px !important;
        }

        .h3 {
            font-size: 1.25rem;
        }
    }
</style>
{% endblock %}
