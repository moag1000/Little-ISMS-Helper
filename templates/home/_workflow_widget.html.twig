{#
 # Workflow Dashboard Widget
 #
 # Displays pending workflow approvals for the current user with:
 # - Personalized list of workflows requiring user's approval
 # - Color-coded time remaining indicators (red/yellow/green)
 # - Quick action buttons (Quick View, Approve, Reject)
 # - Empty state when no pending approvals
 #
 # Variables:
 # - pending_workflows: Array of WorkflowInstance entities pending for current user
 # - overdue_workflows: Array of all overdue WorkflowInstance entities
 # - upcoming_workflow_deadlines: Array of WorkflowInstance entities with deadlines < 24h
 #}
{% import '_components/_fa_progress.html.twig' as _fa_progress %}

{% import '_macros/workflow.html.twig' as workflow_macros %}

{% set total_pending = pending_workflows|length %}

{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}

<div class="widget-card mb-4 border-primary"
     data-widget-id="workflow-approvals"
     data-dashboard-customizer-target="widget">
    <div class="widget-header bg-primary-subtle">
        <h3 class="widget-title text-primary">
            <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
            {{ 'workflow.widget.title'|trans({}, 'workflows') }}
        </h3>
        {% if total_pending > 0 %}
            {% include '_components/_badge.html.twig' with { variant: 'primary', content: total_pending } %}
        {% endif %}
    </div>

    <div class="widget-body p-3">
        {% if total_pending > 0 %}
            {# Summary Stats Row #}
            <div class="row g-2 mb-3">
                <div class="col-4">
                    <div class="text-center p-2 bg-danger-subtle rounded">
                        <div class="fs-4 fw-bold text-danger">{{ overdue_workflows|length }}</div>
                        <div class="small text-muted">{{ 'workflow.widget.overdue'|trans({}, 'workflows') }}</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="text-center p-2 bg-warning-subtle rounded">
                        <div class="fs-4 fw-bold text-warning">{{ upcoming_workflow_deadlines|length }}</div>
                        <div class="small text-muted">{{ 'workflow.widget.due_soon'|trans({}, 'workflows') }}</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="text-center p-2 bg-primary-subtle rounded">
                        <div class="fs-4 fw-bold text-primary">{{ total_pending }}</div>
                        <div class="small text-muted">{{ 'workflow.widget.my_tasks'|trans({}, 'workflows') }}</div>
                    </div>
                </div>
            </div>

            {# Workflow List #}
            <ul class="list-unstyled mb-0">
                {% for instance in pending_workflows|slice(0, 5) %}
                    {% set workflow = instance.workflow %}
                    {% set currentStep = instance.currentStep %}
                    {% set dueDate = instance.dueDate %}
                    {% set isOverdue = instance.isOverdue %}

                    <li class="mb-3 pb-3 {% if not loop.last %}border-bottom{% endif %}">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div class="flex-grow-1">
                                {# Workflow Name #}
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    {# Entity Type Icon #}
                                    {% set entityType = instance.entityType|split('\\')|last|lower %}
                                    {% set entityIcon = {
                                        'incident': 'status-critical',
                                        'risk': 'status-warning',
                                        'asset': 'asset-server',
                                        'control': 'shield-check',
                                        'document': 'nav-file-earmark-text'
                                    }[entityType] ?? 'nav-file-earmark-text' %}

                                    <i class="fa-icon fa-icon--{{ entityIcon }}" aria-hidden="true"></i>
                                    <strong>{{ workflow.name }}</strong>
                                </div>

                                {# Current Step Info #}
                                <div class="small text-muted mb-1">
                                    <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                                    {{ 'workflow.field.current_step'|trans({}, 'workflows') }}: {{ currentStep.name }}
                                </div>

                                {# Assignee Info #}
                                {% if currentStep.approverRole %}
                                    <div class="small mb-2">
                                        <i class="fa-icon fa-icon--ui-person" aria-hidden="true"></i>
                                        <span class="text-muted">{{ 'workflow.field.assignee'|trans({}, 'workflows') }}:</span>
                                        {% include '_components/_badge.html.twig' with { variant: 'info', content: currentStep.approverRole } %}
                                        {% include '_components/_badge.html.twig' with { variant: 'primary', content: 'workflow.badge.my_task'|trans({}, 'workflows') } %}
                                    </div>
                                {% endif %}

                                {# SLA Timeline - Compact Mode #}
                                {% if dueDate %}
                                    <div class="mb-2">
                                        {{ workflow_macros.sla_timeline(dueDate, null, null, instance.startedAt, true) }}
                                    </div>
                                {% endif %}
                            </div>
                        </div>

                        {# Progress Bar #}
                        {% if dueDate %}
                            {% set now = date() %}
                            {% set isOverdue = dueDate < now %}
                            {% set totalHours = ((dueDate.timestamp - now.timestamp) / 3600)|round(1) %}
                            {% if isOverdue %}
                                {% set urgencyClass = 'danger' %}
                            {% elseif totalHours < 2 %}
                                {% set urgencyClass = 'danger' %}
                            {% elseif totalHours < 24 %}
                                {% set urgencyClass = 'warning' %}
                            {% else %}
                                {% set urgencyClass = 'success' %}
                            {% endif %}
                        {% else %}
                            {% set urgencyClass = 'neutral' %}
                        {% endif %}
                        {{ _fa_progress.render({ value: instance.progressPercentage, tone: urgencyClass, class: 'mb-2' }) }}

                        {# Quick Action Buttons #}
                        <div class="d-flex gap-2">
                            <a href="{{ path('app_workflow_instance_show', {id: instance.id}) }}"
                               class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost flex-fill"
                               title="{{ 'workflow.widget.action.quick_view'|trans({}, 'workflows') }}">
                                <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
                                {{ 'workflow.widget.action.quick_view'|trans({}, 'workflows') }}
                            </a>

                            <button type="button"
                                    class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--success" data-controller="fa-modal-dispatcher" data-action="click->fa-modal-dispatcher#open" data-fa-modal-id="approveModal{{ instance.id }}"
                                    title="{{ 'workflow.widget.action.approve'|trans({}, 'workflows') }}">
                                <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i>
                            </button>

                            <button type="button"
                                    class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--danger" data-controller="fa-modal-dispatcher" data-action="click->fa-modal-dispatcher#open" data-fa-modal-id="rejectModal{{ instance.id }}"
                                    title="{{ 'workflow.widget.action.reject'|trans({}, 'workflows') }}">
                                <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i>
                            </button>
                        </div>
                    </li>

                    {# Approve Modal #}
                    <div class="fa-modal fa-modal--confirm fa-modal--success" id="approveModal{{ instance.id }}"
                         data-controller="fa-modal" data-fa-modal-mode-value="confirm" data-fa-modal-tone-value="success"
                         role="alertdialog" aria-modal="true" aria-labelledby="approveModalLabel{{ instance.id }}" aria-hidden="true">
                        <div class="fa-modal__backdrop" data-fa-modal-target="backdrop" data-action="click->fa-modal#backdropClick" aria-hidden="true"></div>
                        <div class="fa-modal__container" data-fa-modal-target="dialog">
                            <header class="fa-modal__header">
                                <span class="fa-modal__icon" aria-hidden="true"><i class="fa-icon fa-icon--status-ok"></i></span>
                                <div class="fa-modal__heading">
                                    <h2 class="fa-modal__title" id="approveModalLabel{{ instance.id }}">
                                        {{ 'workflow.widget.action.approve'|trans({}, 'workflows') }}
                                    </h2>
                                </div>
                                <button type="button" class="fa-modal__close" data-action="fa-modal#cancel" aria-label="{{ 'common.close'|trans({}, 'messages') }}"><i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i></button>
                            </header>
                            <form method="post" action="{{ path('app_workflow_instance_approve', {id: instance.id}) }}" data-fa-modal-target="form">
                                <div class="fa-modal__body">
                                    <p>{{ 'workflow.widget.confirm.approve'|trans({workflow: workflow.name}, 'workflows') }}</p>
                                    <div class="mb-3">
                                        <label for="comments{{ instance.id }}" class="form-label">
                                            {{ 'workflow.widget.field.comments'|trans({}, 'workflows') }}
                                        </label>
                                        <textarea class="form-control fa-cyber-input__field" id="comments{{ instance.id }}" name="comments" rows="3"></textarea>
                                    </div>
                                    <input type="hidden" name="_token" value="{{ csrf_token('approve' ~ instance.id) }}">
                                </div>
                                <footer class="fa-modal__footer">
                                    <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost" data-action="fa-modal#cancel">
                                        {{ 'workflow.action.cancel'|trans({}, 'workflows') }}
                                    </button>
                                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--success">
                                        <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i>
                                        {{ 'workflow.widget.action.approve'|trans({}, 'workflows') }}
                                    </button>
                                </footer>
                            </form>
                        </div>
                    </div>

                    {# Reject Modal #}
                    <div class="fa-modal fa-modal--confirm fa-modal--danger" id="rejectModal{{ instance.id }}"
                         data-controller="fa-modal" data-fa-modal-mode-value="confirm" data-fa-modal-tone-value="danger"
                         role="alertdialog" aria-modal="true" aria-labelledby="rejectModalLabel{{ instance.id }}" aria-hidden="true">
                        <div class="fa-modal__backdrop" data-fa-modal-target="backdrop" data-action="click->fa-modal#backdropClick" aria-hidden="true"></div>
                        <div class="fa-modal__container" data-fa-modal-target="dialog">
                            <header class="fa-modal__header">
                                <span class="fa-modal__icon" aria-hidden="true"><i class="fa-icon fa-icon--status-critical"></i></span>
                                <div class="fa-modal__heading">
                                    <h2 class="fa-modal__title" id="rejectModalLabel{{ instance.id }}">
                                        {{ 'workflow.widget.action.reject'|trans({}, 'workflows') }}
                                    </h2>
                                </div>
                                <button type="button" class="fa-modal__close" data-action="fa-modal#cancel" aria-label="{{ 'common.close'|trans({}, 'messages') }}"><i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i></button>
                            </header>
                            <form method="post" action="{{ path('app_workflow_instance_reject', {id: instance.id}) }}" data-fa-modal-target="form">
                                <div class="fa-modal__body">
                                    <p>{{ 'workflow.widget.confirm.reject'|trans({workflow: workflow.name}, 'workflows') }}</p>
                                    <div class="mb-3">
                                        <label for="reason{{ instance.id }}" class="form-label">
                                            {{ 'workflow.widget.field.reason'|trans({}, 'workflows') }} <span class="text-danger">*</span>
                                        </label>
                                        <textarea class="form-control fa-cyber-input__field" id="reason{{ instance.id }}" name="reason" rows="3" required></textarea>
                                    </div>
                                    <input type="hidden" name="_token" value="{{ csrf_token('reject' ~ instance.id) }}">
                                </div>
                                <footer class="fa-modal__footer">
                                    <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost" data-action="fa-modal#cancel">
                                        {{ 'workflow.action.cancel'|trans({}, 'workflows') }}
                                    </button>
                                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger">
                                        <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i>
                                        {{ 'workflow.widget.action.reject'|trans({}, 'workflows') }}
                                    </button>
                                </footer>
                            </form>
                        </div>
                    </div>
                {% endfor %}
            </ul>

            {# View All Link #}
            {% if total_pending > 5 %}
                <div class="text-center mt-3 pt-3 border-top">
                    <a href="{{ path('app_workflow_pending') }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost">
                        <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                        {{ 'workflow.widget.view_all'|trans({count: total_pending - 5}, 'workflows') }}
                    </a>
                </div>
            {% endif %}
        {% else %}
            {# Empty State #}
            {{ _fa_empty_state.render({
                mood: 'celebrating',
                title: 'workflow.widget.no_pending'|trans({}, 'workflows'),
                text: 'workflow.widget.no_pending_desc'|trans({}, 'workflows')
            }) }}
        {% endif %}
    </div>

    {# Footer Link #}
    <div class="widget-footer">
        <a href="{{ path('app_workflow_index') }}" class="text-decoration-none d-flex align-items-center justify-content-center py-2">
            <span>{{ 'workflow.widget.view_all_workflows'|trans({}, 'workflows') }}</span>
            <i class="fa-icon fa-icon--util-arrow-right ms-2" aria-hidden="true"></i>
        </a>
    </div>
</div>
