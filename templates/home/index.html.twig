{% extends 'base.html.twig' %}
{% trans_default_domain 'messages' %}

{% block title %}{{ 'home.welcome'|trans({}, 'messages')}} - {{ 'app.title'|trans({}, 'messages')}}{% endblock %}

{% block body %}
{# Hero Section — V3 W2-M9: Aurora _fa_hero macro replaces Bootstrap hero-section #}
{% import '_components/_fa_hero.html.twig' as _fa_hero %}
<main class="fa-aurora-surface">
    <div class="container my-4">
        {{ _fa_hero.render({
            mood: 'happy',
            title: 'app.title'|trans({}, 'messages'),
            subtitle: 'home.description'|trans({}, 'messages'),
            actions: [
                { label: 'home.go_to_dashboard'|trans({}, 'messages'),
                  variant: 'primary', icon: 'bi-grid', href: path('app_dashboard') },
                { label: 'common.view_details'|trans({}, 'messages'),
                  variant: 'ghost', icon: 'bi-info-circle', href: '#features' }
            ],
            alvaSize: 160
        }) }}

        {# KPI tiles — formerly inline hero-stat blocks #}
        <div class="row g-3 mt-3">
            {% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}
            <div class="col-md-4">
                {{ _fa_feature_card.render({
                    icon: 'box',
                    label: 'assets'|trans({}, 'messages'),
                    value: stats.assets|default(0),
                    variant: 'primary',
                    href: path('app_asset_index')
                }) }}
            </div>
            <div class="col-md-4">
                {{ _fa_feature_card.render({
                    icon: 'exclamation-triangle',
                    label: 'risks'|trans({}, 'messages'),
                    value: stats.risks|default(0),
                    variant: 'warning',
                    href: path('app_risk_index')
                }) }}
            </div>
            <div class="col-md-4">
                {{ _fa_feature_card.render({
                    icon: 'shield-check',
                    label: 'controls'|trans({}, 'messages'),
                    value: stats.controls|default(0),
                    variant: 'success',
                    href: path('app_compliance_index')
                }) }}
            </div>
        </div>
    </div>
</main>

{# Features Section #}
<div class="container my-5" id="features">
    <div class="text-center mb-5">
        <h2 class="display-5 fw-bold">{{ 'home.modules'|trans({}, 'messages') }}</h2>
        <p class="lead text-muted">{{ 'home.tagline'|trans({}, 'messages') }}</p>
    </div>

    <div class="row g-4">
        {# Asset Management #}
        <div class="col-lg-3 col-md-6">
            <div class="feature-card">
                <div class="feature-icon bg-primary" aria-hidden="true">
                    <i class="fa-icon fa-icon--asset-server" aria-hidden="true"></i>
                </div>
                <h3 class="feature-title">{{ 'home.module.assets.title'|trans({}, 'messages') }}</h3>
                <p class="feature-description">
                    {{ 'home.module.assets.description'|trans({}, 'messages') }}
                </p>
                <a href="{{ path('app_asset_index') }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost mt-3">
                    {{ 'home.module.assets.action'|trans({}, 'messages') }} <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                </a>
            </div>
        </div>

        {# Risk Management #}
        <div class="col-lg-3 col-md-6">
            <div class="feature-card">
                <div class="feature-icon bg-warning" aria-hidden="true">
                    <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i>
                </div>
                <h3 class="feature-title">{{ 'home.module.risks.title'|trans({}, 'messages') }}</h3>
                <p class="feature-description">
                    {{ 'home.module.risks.description'|trans({}, 'messages') }}
                </p>
                <a href="{{ path('app_risk_index') }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--warning mt-3">
                    {{ 'home.module.risks.action'|trans({}, 'messages') }} <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                </a>
            </div>
        </div>

        {# Control Framework #}
        <div class="col-lg-3 col-md-6">
            <div class="feature-card">
                <div class="feature-icon bg-success" aria-hidden="true">
                    <i class="fa-icon fa-icon--compliance-shield" aria-hidden="true"></i>
                </div>
                <h3 class="feature-title">{{ 'home.module.compliance.title'|trans({}, 'messages') }}</h3>
                <p class="feature-description">
                    {{ 'home.module.compliance.description'|trans({}, 'messages') }}
                </p>
                <a href="{{ path('app_compliance_index') }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--success mt-3">
                    {{ 'home.module.compliance.action'|trans({}, 'messages') }} <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                </a>
            </div>
        </div>

        {# Documents Management #}
        <div class="col-lg-3 col-md-6">
            <div class="feature-card">
                <div class="feature-icon bg-info" aria-hidden="true">
                    <i class="fa-icon fa-icon--policy" aria-hidden="true"></i>
                </div>
                <h3 class="feature-title">{{ 'home.module.documents.title'|trans({}, 'messages') }}</h3>
                <p class="feature-description">
                    {{ 'home.module.documents.description'|trans({}, 'messages') }}
                </p>
                <a href="{{ path('app_document_index') }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost mt-3">
                    {{ 'home.module.documents.action'|trans({}, 'messages') }} <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                </a>
            </div>
        </div>
    </div>
</div>

{# Quick Start Guide #}
<div class="bg-body-secondary py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold">{{ 'home.quick_start'|trans({}, 'messages')}}</h2>
            <p class="lead text-muted">{{ 'home.quick_start_subtitle'|trans({}, 'messages') }}</p>
        </div>

        <div class="row">
            <div class="col-lg-8 mx-auto">
                <div class="steps-container">
                    {# Step 1 #}
                    <div class="step-item">
                        <div class="step-number">1</div>
                        <div class="step-content">
                            <h3 class="step-title">{{ 'home.step1.title'|trans({}, 'messages') }}</h3>
                            <p class="step-description">
                                {{ 'home.step1.description'|trans({}, 'messages') }}
                            </p>
                            <a href="{{ path('app_asset_new') }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--primary">{{ 'home.step1.action'|trans({}, 'messages') }}</a>
                        </div>
                    </div>

                    {# Step 2 #}
                    <div class="step-item">
                        <div class="step-number">2</div>
                        <div class="step-content">
                            <h3 class="step-title">{{ 'home.step2.title'|trans({}, 'messages') }}</h3>
                            <p class="step-description">
                                {{ 'home.step2.description'|trans({}, 'messages') }}
                            </p>
                            <a href="{{ path('app_risk_new') }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--primary">{{ 'home.step2.action'|trans({}, 'messages') }}</a>
                        </div>
                    </div>

                    {# Step 3 #}
                    <div class="step-item">
                        <div class="step-number">3</div>
                        <div class="step-content">
                            <h3 class="step-title">{{ 'home.step3.title'|trans({}, 'messages') }}</h3>
                            <p class="step-description">
                                {{ 'home.step3.description'|trans({}, 'messages') }}
                            </p>
                            <a href="{{ path('app_compliance_index') }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--primary">{{ 'home.step3.action'|trans({}, 'messages') }}</a>
                        </div>
                    </div>

                    {# Step 4 #}
                    <div class="step-item">
                        <div class="step-number">4</div>
                        <div class="step-content">
                            <h3 class="step-title">{{ 'home.step4.title'|trans({}, 'messages') }}</h3>
                            <p class="step-description">
                                {{ 'home.step4.description'|trans({}, 'messages') }}
                            </p>
                            <a href="{{ path('app_training_new') }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--primary">{{ 'home.step4.action'|trans({}, 'messages') }}</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# CTA Section #}
<div class="container my-5">
    <div class="text-center py-5">
        <h2 class="display-5 fw-bold mb-4">{{ 'home.go_to_dashboard'|trans({}, 'messages') }}</h2>
        <p class="lead text-muted mb-4">
            {{ 'app.subtitle'|trans({}, 'messages') }}
        </p>
        <a href="{{ path('app_dashboard') }}" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--lg">
            <i class="fa-icon fa-icon--nav-dashboard" aria-hidden="true"></i> {{ 'home.go_to_dashboard'|trans({}, 'messages') }}
        </a>
    </div>
</div>
{% endblock %}
