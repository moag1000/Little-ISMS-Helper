{#
 # Management KPIs Widget
 # Displays module-aware KPIs for management reports
 # Only shows KPIs for active modules
 # Sections are collapsible - danger sections auto-expand
 #}

{% if management_kpis is defined and management_kpis|length > 0 %}
<div class="widget-card mb-4"
     data-widget-id="management-kpis"
     data-dashboard-customizer-target="widget">
    <div class="widget-header">
        <h3 class="widget-title">
            <i class="bi bi-graph-up" aria-hidden="true"></i>
            {{ 'dashboard.management_kpis.title'|trans({}, 'dashboard') }}
        </h3>
        <div class="widget-actions">
            {% include '_components/_badge.html.twig' with {
                variant: 'secondary',
                title: 'dashboard.management_kpis.subtitle'|trans({}, 'dashboard'),
                content: management_kpis.active_modules|default([])|length ~ ' ' ~ 'common.modules'|trans({}, 'messages')
            } %}
        </div>
    </div>
    <div class="widget-body p-3">
        {# Define KPI sections with their metadata #}
        {% set kpi_sections = [
            { key: 'core', icon: 'bi-shield-check', title_key: 'dashboard.management_kpis.core.title', route: 'app_soa_index', col_class: 'col-6' },
            { key: 'risk_management', icon: 'bi-exclamation-triangle', title_key: 'dashboard.management_kpis.risk_management.title', route: 'app_risk_index', col_class: 'col-6 col-md-4' },
            { key: 'asset_management', icon: 'bi-server', title_key: 'dashboard.management_kpis.asset_management.title', route: 'app_asset_index', col_class: 'col-6 col-md-4' },
            { key: 'incident_management', icon: 'bi-fire', title_key: 'dashboard.management_kpis.incident_management.title', route: 'app_incident_index', col_class: 'col-6 col-md-3' },
            { key: 'business_continuity', icon: 'bi-diagram-3', title_key: 'dashboard.management_kpis.business_continuity.title', route: 'app_bcm_index', col_class: 'col-6 col-md-3' },
            { key: 'training', icon: 'bi-mortarboard', title_key: 'dashboard.management_kpis.training.title', route: 'app_training_index', col_class: 'col-6' },
            { key: 'audits', icon: 'bi-clipboard-check', title_key: 'dashboard.management_kpis.audits.title', route: 'app_audit_index', col_class: 'col-6 col-md-4' },
            { key: 'supplier_management', icon: 'bi-building', title_key: 'dashboard.management_kpis.supplier_management.title', route: 'app_supplier_index', col_class: 'col-6 col-md-3' },
            { key: 'documentation', icon: 'bi-file-text', title_key: 'dashboard.management_kpis.documentation.title', route: 'app_document_index', col_class: 'col-6 col-md-4' },
        ] %}

        <div class="accordion" id="kpiAccordion">
            {% for section in kpi_sections %}
                {% if attribute(management_kpis, section.key) is defined %}
                    {% set sectionKpis = attribute(management_kpis, section.key) %}

                    {# Check if any KPI in this section has danger status #}
                    {% set hasDanger = false %}
                    {% for key, kpi in sectionKpis %}
                        {% if kpi.status|default('') == 'danger' %}
                            {% set hasDanger = true %}
                        {% endif %}
                    {% endfor %}

                    <div class="accordion-item">
                        <h2 class="accordion-header" id="kpiHeading-{{ section.key }}">
                            <button class="accordion-button {{ hasDanger ? '' : 'collapsed' }} py-2"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#kpi-{{ section.key }}"
                                    aria-expanded="{{ hasDanger ? 'true' : 'false' }}"
                                    aria-controls="kpi-{{ section.key }}">
                                <i class="bi {{ section.icon }} me-2" aria-hidden="true"></i>
                                {{ section.title_key|trans({}, 'dashboard') }}
                                {% if hasDanger %}
                                    <span class="badge bg-danger ms-2">!</span>
                                {% endif %}
                            </button>
                        </h2>
                        <div id="kpi-{{ section.key }}"
                             class="accordion-collapse collapse {{ hasDanger ? 'show' : '' }}"
                             aria-labelledby="kpiHeading-{{ section.key }}"
                             data-bs-parent="#kpiAccordion">
                            <div class="accordion-body py-2 px-3">
                                <div class="d-flex justify-content-end mb-2">
                                    <a href="{{ path(section.route) }}" class="btn btn-sm btn-link p-0" title="{{ 'common.view_all'|trans({}, 'messages') }}">
                                        <i class="bi bi-arrow-right-circle" aria-hidden="true"></i>
                                    </a>
                                </div>
                                <div class="row g-2">
                                    {% for key, kpi in sectionKpis %}
                                    <div class="{{ section.col_class }}">
                                        {% if section.key == 'core' %}
                                        {# Core section uses the richer card style with progress bars #}
                                        <div class="kpi-card p-2 rounded border-start border-4 border-{{ kpi.status == 'good' ? 'success' : (kpi.status == 'warning' ? 'warning' : (kpi.status == 'danger' ? 'danger' : 'info')) }}">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <span class="small text-muted">{{ ('dashboard.kpi.' ~ key)|trans({}, 'dashboard') }}</span>
                                                <span>
                                                    {% set kpiVariant = kpi.status == 'good' ? 'success' : (kpi.status == 'warning' ? 'warning' : (kpi.status == 'danger' ? 'danger' : 'secondary')) %}
                                                    {% include '_components/_badge.html.twig' with {
                                                        variant: kpiVariant ~ '-subtle',
                                                        class: 'text-' ~ kpiVariant,
                                                        content: kpi.value ~ kpi.unit
                                                    } %}
                                                    {% if kpi.trend is defined and kpi.trend != 'stable' %}
                                                    <span class="kpi-trend text-{{ kpi.trend_sentiment|default('neutral') == 'good' ? 'success' : (kpi.trend_sentiment|default('neutral') == 'bad' ? 'danger' : 'muted') }}">
                                                        {% if kpi.trend == 'up' %}
                                                            <i class="bi bi-graph-up-arrow" aria-hidden="true"></i>
                                                        {% elseif kpi.trend == 'down' %}
                                                            <i class="bi bi-graph-down-arrow" aria-hidden="true"></i>
                                                        {% endif %}
                                                        {% if kpi.trend_delta is defined %}
                                                            <small>{{ kpi.trend_delta > 0 ? '+' : '' }}{{ kpi.trend_delta }}{{ kpi.unit|default('') }}</small>
                                                        {% endif %}
                                                    </span>
                                                    {% endif %}
                                                </span>
                                            </div>
                                            {% if kpi.details is defined and kpi.details.total is defined %}
                                            <div class="progress mt-1" style="height: 4px;">
                                                <div class="progress-bar bg-{{ kpi.status == 'good' ? 'success' : (kpi.status == 'warning' ? 'warning' : 'danger') }}"
                                                     role="progressbar"
                                                     style="width: {{ kpi.value }}%"
                                                     aria-valuenow="{{ kpi.value }}"
                                                     aria-valuemin="0"
                                                     aria-valuemax="100"></div>
                                            </div>
                                            {% endif %}
                                        </div>
                                        {% else %}
                                        {# Other sections use the compact mini card style #}
                                        <div class="kpi-mini p-2 rounded bg-light">
                                            <div class="small text-muted">{{ ('dashboard.kpi.' ~ key)|trans({}, 'dashboard') }}</div>
                                            <div class="fw-bold text-{{ kpi.status == 'good' ? 'success' : (kpi.status == 'warning' ? 'warning' : (kpi.status == 'danger' ? 'danger' : 'body')) }}">
                                                {{ kpi.value }}{{ kpi.unit }}
                                                {% if kpi.trend is defined and kpi.trend != 'stable' %}
                                                <span class="kpi-trend text-{{ kpi.trend_sentiment|default('neutral') == 'good' ? 'success' : (kpi.trend_sentiment|default('neutral') == 'bad' ? 'danger' : 'muted') }}">
                                                    {% if kpi.trend == 'up' %}
                                                        <i class="bi bi-graph-up-arrow" aria-hidden="true"></i>
                                                    {% elseif kpi.trend == 'down' %}
                                                        <i class="bi bi-graph-down-arrow" aria-hidden="true"></i>
                                                    {% endif %}
                                                    {% if kpi.trend_delta is defined %}
                                                        <small>{{ kpi.trend_delta > 0 ? '+' : '' }}{{ kpi.trend_delta }}{{ kpi.unit|default('') }}</small>
                                                    {% endif %}
                                                </span>
                                                {% endif %}
                                            </div>
                                        </div>
                                        {% endif %}
                                    </div>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        </div>
    </div>
</div>
<style>
    .kpi-trend {
        font-size: 0.85rem;
        margin-left: 0.25rem;
        white-space: nowrap;
    }
</style>
{% endif %}
