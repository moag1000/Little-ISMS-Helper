{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block title %}Dashboard{% endblock %}

{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}

{% block body %}
<div class="container-fluid"
     data-controller="dashboard-customizer"
     data-dashboard-customizer-api-url-value="{{ path('app_dashboard_layout_get') }}">
    {# Breadcrumb Navigation #}
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'Dashboard' }
        ]
    } %}

    {# Sprint 13 — Guided-Tour-Banner (nur wenn Tour für diese Rolle
     # noch nicht abgeschlossen ist — siehe HomeController::dashboard).
     # Der eigentliche Controller-Mount sitzt global in base.html.twig. #}
    {% include '_components/_guided_tour_banner.html.twig' with { suggested_tour: suggested_tour|default(null) } %}

    {# MRIS-Topic-Tour-Banner (themenbezogen, nicht rollenbezogen). Nur
     # ROLE_USER (nicht ROLE_AUDITOR) — siehe HomeController. #}
    {% include '_components/_guided_tour_banner.html.twig' with { suggested_tour: suggested_mris_tour|default(null) } %}

    {# Page Header with Customize Button and Role Dashboard Switcher #}
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            {% include '_components/_page_header.html.twig' with {
                title: 'dashboard.title'|trans({}, 'dashboard'),
                subtitle: 'dashboard.subtitle'|trans({}, 'dashboard'),
                icon: 'bi-speedometer2'
            } %}
        </div>
        <div class="btn-group">
            {# Role-Based Dashboard Switcher #}
            <div class="dropdown me-2">
                <button class="btn btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-grid" aria-hidden="true"></i> {{ 'dashboard.action.role_dashboards'|trans({}, 'dashboard') }}
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    {% if is_granted('ROLE_MANAGER') %}
                    <li>
                        <a class="dropdown-item" href="{{ path('app_dashboard_ciso') }}">
                            <i class="fa-icon fa-icon--control fa-icon--primary me-2" aria-hidden="true"></i>{{ 'dashboard.role.ciso'|trans({}, 'dashboard') }}
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item" href="{{ path('app_dashboard_risk_manager') }}">
                            <i class="fa-icon fa-icon--nav-bar-chart text-warning me-2" aria-hidden="true"></i>{{ 'dashboard.role.risk_manager'|trans({}, 'dashboard') }}
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item" href="{{ path('app_dashboard_board') }}">
                            <i class="bi bi-briefcase me-2" aria-hidden="true"></i>{{ 'dashboard.role.board'|trans({}, 'dashboard') }}
                        </a>
                    </li>
                    {% endif %}
                    {% if is_granted('ROLE_AUDITOR') %}
                    <li>
                        <a class="dropdown-item" href="{{ path('app_dashboard_auditor') }}">
                            <i class="fa-icon fa-icon--sop fa-icon--info me-2" aria-hidden="true"></i>{{ 'dashboard.role.auditor'|trans({}, 'dashboard') }}
                        </a>
                    </li>
                    {% endif %}
                </ul>
            </div>
            <button class="fa-cyber-btn fa-cyber-btn--ghost"
                    data-action="click->dashboard-customizer#openSettings"
                    title="{{ 'dashboard.action.customize'|trans({}, 'dashboard') }}">
                <i class="fa-icon fa-icon--nav-sliders" aria-hidden="true"></i> {{ 'dashboard.action.customize'|trans({}, 'dashboard') }}
            </button>
        </div>
    </div>

    {% import '_macros/cards.html.twig' as cards %}

    {# Urgent Tasks Alert Banner (ported from Welcome page) #}
    {% if total_urgent_count|default(0) > 0 %}
    {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'danger', class: 'mb-4' } } %}
        {% block alert_body %}
            <div class="d-flex align-items-center">
                <strong>{{ total_urgent_count }} {{ 'dashboard.urgent_items'|trans({}, 'dashboard') }}</strong>
                <div class="ms-auto">
                    {% for task in urgent_tasks|default([]) %}
                        <a href="{{ task.url }}" class="fa-cyber-btn fa-cyber-btn--danger fa-cyber-btn--sm ms-1">
                            {{ task.label }} <span class="badge bg-danger fa-status-pill fa-status-pill--danger">{{ task.count }}</span>
                        </a>
                    {% endfor %}
                </div>
            </div>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {# Prominent Workflow Approval Alert Banner #}
    {% set total_pending = pending_workflows|default([])|length %}
    {% set total_overdue = overdue_workflows|default([])|length %}
    {% if total_pending > 0 or total_overdue > 0 %}
        {% embed '_components/_fa_alert.html.twig' with { props: { variant: total_overdue > 0 ? 'danger' : 'warning', dismissible: true, class: 'mb-4' } } %}
            {% block alert_body %}
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 me-3">
                        <i class="fa-icon {% if total_overdue > 0 %}fa-icon--status-warning{% else %}bi-clock-fill{% endif %} fa-glyph-size-md" aria-hidden="true"></i>
                    </div>
                    <div class="flex-grow-1">
                        <div class="fa-alert__title">
                            {% if total_overdue > 0 %}
                                {{ 'workflow.dashboard.alert.overdue_title'|trans({'%count%': total_overdue}, 'workflows') }}
                            {% else %}
                                {{ 'workflow.dashboard.alert.pending_title'|trans({'%count%': total_pending}, 'workflows') }}
                            {% endif %}
                        </div>
                        <p class="fa-alert__message mb-2">
                            {% if total_overdue > 0 %}
                                {{ 'workflow.dashboard.alert.overdue_message'|trans({'%overdue%': total_overdue, '%total%': total_pending}, 'workflows') }}
                            {% else %}
                                {{ 'workflow.dashboard.alert.pending_message'|trans({'%count%': total_pending}, 'workflows') }}
                            {% endif %}
                        </p>
                        <a href="{{ path('app_workflow_pending') }}" class="fa-cyber-btn fa-cyber-btn--sm {% if total_overdue > 0 %}fa-cyber-btn--danger{% else %}fa-cyber-btn--warning{% endif %}">
                            <i class="fa-icon fa-icon--nav-list-check" aria-hidden="true"></i>
                            {{ 'workflow.dashboard.alert.view_all'|trans({}, 'workflows') }}
                        </a>
                    </div>
                </div>
            {% endblock %}
        {% endembed %}
    {% endif %}

    {# Stats Cards Row #}
    <div class="row mb-4"
         data-widget-id="stats-cards"
         data-dashboard-customizer-target="widget">
        {# Assets Card #}
        <div class="col-lg-3 col-md-6">
            <a href="{{ path('app_asset_index') }}" class="text-decoration-none">
            {{ cards.stat_card(
                'fa-icon fa-icon--asset-server',
                'bg-primary',
                'dashboard.stats.registered_assets'|trans({}, 'dashboard'),
                stats.assets_total|default(0),
                'bi bi-arrow-up',
                stats.assets_critical|default(0) ~ ' ' ~ 'dashboard.stats.critical'|trans({}, 'dashboard'),
                'positive'
            ) }}
            </a>
            {% if stats.assets_total|default(0) == 0 %}
                <div class="text-center mt-1">
                    <a href="{{ path('app_asset_new') }}" class="text-decoration-none small text-primary">
                        <i class="fa-icon fa-icon--ui-plus me-1" aria-hidden="true"></i>{{ 'dashboard.create_first_asset'|trans({}, 'dashboard') }}
                    </a>
                </div>
            {% endif %}
        </div>

        {# Risks Card #}
        <div class="col-lg-3 col-md-6">
            <a href="{{ path('app_risk_index') }}" class="text-decoration-none">
            {{ cards.stat_card(
                'fa-icon fa-icon--status-warning',
                'bg-warning',
                'dashboard.stats.identified_risks'|trans({}, 'dashboard'),
                stats.risks_total|default(0),
                'bi bi-arrow-up',
                stats.risks_high|default(0) ~ ' ' ~ 'dashboard.stats.high'|trans({}, 'dashboard'),
                'negative'
            ) }}
            </a>
            {% if stats.risks_total|default(0) == 0 %}
                <div class="text-center mt-1">
                    <a href="{{ path('app_risk_new') }}" class="text-decoration-none small text-warning">
                        <i class="fa-icon fa-icon--ui-plus me-1" aria-hidden="true"></i>{{ 'dashboard.create_first_risk'|trans({}, 'dashboard') }}
                    </a>
                </div>
            {% endif %}
        </div>

        {# Controls Card #}
        <div class="col-lg-3 col-md-6">
            <a href="{{ path('app_compliance_index') }}" class="text-decoration-none">
            {{ cards.stat_card(
                'fa-icon fa-icon--compliance-shield',
                'bg-success',
                'dashboard.stats.security_controls'|trans({}, 'dashboard'),
                stats.controls_implemented|default(0) ~ '/' ~ stats.controls_total|default(0),
                'fa-icon fa-icon--status-ok',
                stats.compliance_percentage|default(0) ~ '% ' ~ 'dashboard.stats.implemented'|trans({}, 'dashboard'),
                'positive'
            ) }}
            </a>
            {% if stats.controls_total|default(0) == 0 %}
                <div class="text-center mt-1">
                    <a href="{{ path('app_compliance_index') }}" class="text-decoration-none small text-success">
                        <i class="fa-icon fa-icon--compliance-shield me-1" aria-hidden="true"></i>{{ 'dashboard.review_controls'|trans({}, 'dashboard') }}
                    </a>
                </div>
            {% endif %}
        </div>

        {# Incidents Card #}
        <div class="col-lg-3 col-md-6">
            <a href="{{ path('app_incident_index') }}" class="text-decoration-none">
            {{ cards.stat_card(
                'bi bi-exclamation-circle',
                'bg-danger',
                'dashboard.stats.open_incidents'|trans({}, 'dashboard'),
                stats.incidents_open|default(0),
                'bi bi-clock-history',
                'dashboard.stats.in_progress'|trans({}, 'dashboard'),
                ''
            ) }}
            </a>
            {% if stats.incidents_open|default(0) == 0 and stats.incidents_total|default(0) == 0 %}
                <div class="text-center mt-1">
                    <a href="{{ path('app_incident_new') }}" class="text-decoration-none small text-danger">
                        <i class="fa-icon fa-icon--status-warning me-1" aria-hidden="true"></i>{{ 'dashboard.report_first_incident'|trans({}, 'dashboard') }}
                    </a>
                </div>
            {% endif %}
        </div>
    </div>


    {# R2 Ein-Zahl-KPI — Data-Reuse in FTE-Tagen (Board-tauglich) #}
    {% if reuse_fte_saved is defined and reuse_fte_saved is not null %}
        <div class="row mb-4">
            <div class="col-12">
                <a href="{{ path('app_management_reports_portfolio') }}" class="text-decoration-none">
                    <div class="card fa-section shadow-sm border-success fa-rag-card fa-rag-card--green">
                        <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-3">
                            <div>
                                <div class="small text-uppercase text-muted mb-1">
                                    <i class="fa-icon fa-icon--threat text-success" aria-hidden="true"></i>
                                    {{ 'dashboard.reuse_fte.title'|trans({}, 'dashboard') }}
                                </div>
                                <div class="display-5 fw-bold text-success">
                                    {{ reuse_fte_saved|number_format(1, '.', ',') }}
                                    <small class="fs-5 text-muted">{{ 'dashboard.reuse_fte.days_suffix'|trans({}, 'dashboard') }}</small>
                                </div>
                                <div class="small text-muted">{{ 'dashboard.reuse_fte.subtitle'|trans({}, 'dashboard') }}</div>
                            </div>
                            <div class="text-end">
                                <span class="badge bg-success-subtle text-success fs-6 fa-status-pill fa-status-pill--success">
                                    <i class="fa-icon fa-icon--nav-bar-chart" aria-hidden="true"></i>
                                    {{ 'dashboard.reuse_fte.cta'|trans({}, 'dashboard') }}
                                </span>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    {% endif %}

    {# Management KPIs Row — skeleton-first rendering for perceived performance (8H.1) #}
    {% if management_kpis is defined and management_kpis|length > 0 %}
    <div class="row mb-4">
        <div class="col-12">
            <div data-controller="skeleton" data-skeleton-duration-value="350">
                <div data-skeleton-target="skeleton">
                    {% include '_components/_skeleton.html.twig' with { type: 'kpi-grid', count: 6 } %}
                </div>
                <div data-skeleton-target="content" class="hidden">
                    {% include 'home/_management_kpis_widget.html.twig' with {
                        management_kpis: management_kpis
                    } %}
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    {# Quick Actions Row #}
    <div class="row mb-4"
         data-widget-id="quick-actions"
         data-dashboard-customizer-target="widget">
        <div class="col-12">
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <span class="text-muted small me-2">
                    <i class="fa-icon fa-icon--threat" aria-hidden="true"></i>
                    {{ 'dashboard.quick_actions.title'|trans({}, 'dashboard') }}:
                </span>
                <a href="{{ path('app_asset_new') }}" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--sm">
                    <i class="fa-icon fa-icon--ui-plus" aria-hidden="true"></i> {{ 'dashboard.quick_actions.new_asset'|trans({}, 'dashboard') }}
                </a>
                <a href="{{ path('app_risk_new') }}" class="fa-cyber-btn fa-cyber-btn--warning fa-cyber-btn--sm">
                    <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> {{ 'dashboard.quick_actions.new_risk'|trans({}, 'dashboard') }}
                </a>
                <a href="{{ path('app_compliance_index') }}" class="fa-cyber-btn fa-cyber-btn--success fa-cyber-btn--sm">
                    <i class="fa-icon fa-icon--compliance-shield" aria-hidden="true"></i> {{ 'dashboard.quick_actions.controls'|trans({}, 'dashboard') }}
                </a>
                <a href="{{ path('app_incident_new') }}" class="fa-cyber-btn fa-cyber-btn--danger fa-cyber-btn--sm">
                    <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> {{ 'dashboard.quick_actions.report_incident'|trans({}, 'dashboard') }}
                </a>
            </div>
        </div>
    </div>

    {# Charts and Activity Row #}
    <div class="row">
        {# Charts Column #}
        <div class="col-lg-8">
            {# Risk Distribution Chart #}
            <div class="widget-card mb-4"
                 data-widget-id="risk-chart"
                 data-dashboard-customizer-target="widget">
                <div class="widget-header">
                    <h3 class="widget-title">
                        <i class="fa-icon fa-icon--nav-pie-chart" aria-hidden="true"></i>
                        {{ 'dashboard.chart.risk_distribution'|trans({}, 'dashboard') }}
                    </h3>
                    <div class="widget-actions">
                        <button class="widget-action" title="{{ 'common.refresh'|trans({}, 'messages') }}" aria-label="{{ 'common.refresh'|trans({}, 'messages') }}">
                            <i class="fa-icon fa-icon--ui-refresh" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>
                <div class="chart-container">
                    <canvas data-controller="chart"
                            data-chart-type-value="doughnut"
                            data-chart-data-value='{"labels":["{{ 'risk.level.critical'|trans({}, 'messages') }}","{{ 'risk.level.high'|trans({}, 'messages') }}","{{ 'risk.level.medium'|trans({}, 'messages') }}","{{ 'risk.level.low'|trans({}, 'messages') }}"],"datasets":[{"data":[{{ risks_by_level.critical|default(0) }},{{ risks_by_level.high|default(0) }},{{ risks_by_level.medium|default(0) }},{{ risks_by_level.low|default(0) }}],"backgroundColor":["#7c3aed","#dc2626","#d97706","#059669"]}]}'
                            data-chart-options-value='{"plugins":{"legend":{"position":"bottom"}}}'></canvas>
                </div>
            </div>

            {# Assets by Category Chart #}
            <div class="widget-card"
                 data-widget-id="asset-chart"
                 data-dashboard-customizer-target="widget">
                <div class="widget-header">
                    <h3 class="widget-title">
                        <i class="fa-icon fa-icon--nav-bar-chart" aria-hidden="true"></i>
                        {{ 'dashboard.chart.assets_by_category'|trans({}, 'dashboard') }}
                    </h3>
                </div>
                <div class="chart-container">
                    {% set asset_labels = [] %}
                    {% set asset_values = [] %}
                    {% for type, count in assets_by_type|default({}) %}
                        {% set asset_labels = asset_labels|merge([type]) %}
                        {% set asset_values = asset_values|merge([count]) %}
                    {% endfor %}
                    <canvas data-controller="chart"
                            data-chart-type-value="bar"
                            data-chart-data-value='{"labels":{{ asset_labels|json_encode|raw }},"datasets":[{"label":"{{ 'dashboard.chart.asset_count'|trans({}, 'dashboard') }}","data":{{ asset_values|json_encode|raw }},"backgroundColor":"rgba(102, 126, 234, 0.7)","borderColor":"rgba(102, 126, 234, 1)","borderWidth":1}]}'
                            data-chart-options-value='{"scales":{"y":{"beginAtZero":true}}}'></canvas>
                </div>
            </div>
        </div>

        {# Activity Feed Column #}
        <div class="col-lg-4">
            {# My Tasks Today Widget #}
            <div class="widget-card mb-4"
                 data-widget-id="my-tasks"
                 data-dashboard-customizer-target="widget">
                <div class="widget-header">
                    <h3 class="widget-title">
                        <i class="fa-icon fa-icon--ui-person-check" aria-hidden="true"></i>
                        {{ 'dashboard.my_tasks.title'|trans({}, 'dashboard') }}
                    </h3>
                    {% if my_tasks|default([])|length > 0 %}
                    {% include '_components/_badge.html.twig' with {
                        variant: 'primary',
                        content: my_tasks|length
                    } %}
                    {% endif %}
                </div>
                <div class="widget-body p-3">
                    {% if my_tasks|default([])|length > 0 %}
                        <ul class="list-unstyled mb-0">
                            {% for task in my_tasks|slice(0, 7) %}
                            <li class="mb-2 pb-2 {% if not loop.last %}border-bottom{% endif %}">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div class="flex-grow-1">
                                        <a href="{{ task.url }}" class="text-decoration-none">
                                            <i class="bi {{ task.icon }} text-{{ task.priority }} me-1" aria-hidden="true"></i>
                                            {{ task.title|length > 40 ? task.title|slice(0, 40) ~ '...' : task.title }}
                                        </a>
                                        <div class="small text-muted">
                                            {% if task.type == 'treatment_plan' %}
                                                {{ 'dashboard.my_tasks.type_treatment_plan'|trans({}, 'dashboard') }}
                                            {% elseif task.type == 'workflow' %}
                                                {{ 'dashboard.my_tasks.type_workflow'|trans({}, 'dashboard') }}
                                            {% elseif task.type == 'risk_review' %}
                                                {{ 'dashboard.my_tasks.type_risk_review'|trans({}, 'dashboard') }}
                                            {% endif %}
                                        </div>
                                    </div>
                                    {% if task.overdue_days is not null %}
                                    {% include '_components/_badge.html.twig' with {
                                        variant: task.priority,
                                        class: 'ms-2',
                                        content: task.overdue_days ~ ' ' ~ 'dashboard.my_tasks.days_overdue'|trans({}, 'dashboard')
                                    } %}
                                    {% endif %}
                                </div>
                            </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        {{ _fa_empty_state.render({
                            mood: 'celebrating',
                            title: 'dashboard.my_tasks.all_done'|trans({}, 'dashboard')
                        }) }}
                    {% endif %}
                </div>
            </div>

            {# Compliance Status Widget (Overview of all frameworks) #}
            {% include 'home/_compliance_status_widget.html.twig' with {
                compliance_summary: compliance_summary|default({has_frameworks: false})
            } %}

            {# Cross-Framework Control Efficiency Widget #}
            {% include 'home/_cross_framework_widget.html.twig' with {
                cross_framework_data: cross_framework_data|default({shared_controls: 0})
            } only %}

            {# Workflow Approvals Widget (UX High Priority #1) #}
            {% include 'home/_workflow_widget.html.twig' with {
                pending_workflows: pending_workflows|default([]),
                overdue_workflows: overdue_workflows|default([]),
                upcoming_workflow_deadlines: upcoming_workflow_deadlines|default([])
            } %}

            {# Overdue Risk Reviews Widget (ISO 27001:2022 Clause 6.1.3.d) #}
            {% if overdue_reviews|default([])|length > 0 %}
            <div class="widget-card mb-4 border-warning"
                 data-widget-id="overdue-reviews"
                 data-dashboard-customizer-target="widget">
                <div class="widget-header bg-warning-subtle">
                    <h3 class="widget-title text-warning">
                        <i class="fa-icon fa-icon--ui-calendar-x" aria-hidden="true"></i>
                        {{ 'dashboard.overdue_reviews.title'|trans({}, 'dashboard') }}
                    </h3>
                    {% include '_components/_badge.html.twig' with { variant: 'warning', content: overdue_reviews|length } %}
                </div>
                <div class="widget-body p-3">
                    <p class="text-muted mb-3">
                        {{ 'dashboard.overdue_reviews.description'|trans({ '%count%': overdue_reviews|length }, 'dashboard') }}
                    </p>
                    <ul class="list-unstyled mb-0">
                        {% for risk in overdue_reviews|slice(0, 5) %}
                        <li class="mb-2 pb-2 {% if not loop.last %}border-bottom{% endif %}">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="flex-grow-1">
                                    <a href="{{ path('app_risk_show', {id: risk.id}) }}" class="text-decoration-none fw-bold">
                                        {{ risk.title }}
                                    </a>
                                    <div class="small text-muted">
                                        {% if risk.reviewDate %}
                                            <i class="fa-icon fa-icon--ui-calendar-event" aria-hidden="true"></i>
                                            {{ 'dashboard.overdue_reviews.last_review'|trans({}, 'dashboard') }}: {{ risk.reviewDate|date('d.m.Y') }}
                                        {% else %}
                                            <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i>
                                            {{ 'dashboard.overdue_reviews.never_reviewed'|trans({}, 'dashboard') }}
                                        {% endif %}
                                    </div>
                                </div>
                                {% include '_components/_badge.html.twig' with {
                                    variant: risk.probability * risk.impact >= 20 ? 'danger' : (risk.probability * risk.impact >= 12 ? 'warning' : 'info'),
                                    class: 'ms-2',
                                    content: risk.probability * risk.impact
                                } %}
                            </div>
                        </li>
                        {% endfor %}
                    </ul>
                    {% if overdue_reviews|length > 5 %}
                        <div class="text-center mt-3">
                            <a href="{{ path('app_risk_index') }}" class="fa-cyber-btn fa-cyber-btn--warning fa-cyber-btn--sm">
                                <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                                {{ 'dashboard.overdue_reviews.view_all'|trans({ '%count%': overdue_reviews|length - 5 }, 'dashboard') }}
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
            {% endif %}

            {# Upcoming Risk Reviews Widget (ISO 27001:2022 Clause 6.1.3.d) #}
            {% if upcoming_reviews|default([])|length > 0 %}
            <div class="widget-card mb-4 border-info"
                 data-widget-id="upcoming-reviews"
                 data-dashboard-customizer-target="widget">
                <div class="widget-header bg-info-subtle">
                    <h3 class="widget-title text-info">
                        <i class="fa-icon fa-icon--nav-calendar-check" aria-hidden="true"></i>
                        {{ 'dashboard.upcoming_reviews.title'|trans({}, 'dashboard') }}
                    </h3>
                    {% include '_components/_badge.html.twig' with { variant: 'info', content: upcoming_reviews|length } %}
                </div>
                <div class="widget-body p-3">
                    <p class="text-muted mb-3 small">
                        {{ 'dashboard.upcoming_reviews.description'|trans({}, 'dashboard') }}
                    </p>
                    <ul class="list-unstyled mb-0">
                        {% for risk in upcoming_reviews|slice(0, 3) %}
                        <li class="mb-2 pb-2 {% if not loop.last %}border-bottom{% endif %}">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="flex-grow-1">
                                    <a href="{{ path('app_risk_show', {id: risk.id}) }}" class="text-decoration-none">
                                        {{ risk.title|length > 40 ? risk.title|slice(0, 40) ~ '...' : risk.title }}
                                    </a>
                                    <div class="small text-muted">
                                        <i class="fa-icon fa-icon--ui-calendar-event" aria-hidden="true"></i>
                                        {{ risk.reviewDate|date('d.m.Y') }}
                                    </div>
                                </div>
                            </div>
                        </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
            {% endif %}

            {# Overdue Treatment Plans Widget (ISO 27001:2022 Clause 6.1.3 - Priority 2.4) #}
            {% if overdue_treatment_plans|default([])|length > 0 %}
            <div class="widget-card mb-4 border-danger"
                 data-widget-id="overdue-treatment-plans"
                 data-dashboard-customizer-target="widget">
                <div class="widget-header bg-danger-subtle">
                    <h3 class="widget-title text-danger">
                        <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i>
                        {{ 'dashboard.overdue_treatment_plans.title'|trans({}, 'dashboard') }}
                    </h3>
                    {% include '_components/_badge.html.twig' with { variant: 'danger', content: overdue_treatment_plans|length } %}
                </div>
                <div class="widget-body p-3">
                    <p class="text-muted mb-3 small">
                        {{ 'dashboard.overdue_treatment_plans.description'|trans({ '%count%': overdue_treatment_plans|length }, 'dashboard') }}
                    </p>
                    <ul class="list-unstyled mb-0">
                        {% for plan in overdue_treatment_plans|slice(0, 5) %}
                        <li class="mb-2 pb-2 {% if not loop.last %}border-bottom{% endif %}">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="flex-grow-1">
                                    <a href="{{ path('app_risk_treatment_plan_show', {id: plan.id}) }}" class="text-decoration-none fw-bold">
                                        {{ plan.title|length > 35 ? plan.title|slice(0, 35) ~ '...' : plan.title }}
                                    </a>
                                    <div class="small text-muted">
                                        <i class="fa-icon fa-icon--ui-calendar-x" aria-hidden="true"></i>
                                        {{ 'dashboard.overdue_treatment_plans.due_date'|trans({}, 'dashboard') }}: {{ plan.targetCompletionDate|date('d.m.Y') }}
                                        {% set daysOverdue = date().diff(plan.targetCompletionDate).days %}
                                        <span class="text-danger">({{ daysOverdue }} {{ 'dashboard.overdue_treatment_plans.days_overdue'|trans({}, 'dashboard') }})</span>
                                    </div>
                                    <div class="progress progress-h-4 mt-1">
                                        <div class="progress-bar bg-danger" role="progressbar"
                                             style="width: {{ plan.completionPercentage }}%"
                                             aria-valuenow="{{ plan.completionPercentage }}"
                                             aria-valuemin="0"
                                             aria-valuemax="100"></div>
                                    </div>
                                </div>
                                {% include '_components/_badge.html.twig' with {
                                    variant: plan.priority == 'critical' ? 'danger' : (plan.priority == 'high' ? 'warning' : 'secondary'),
                                    class: 'ms-2',
                                    content: ('risk_treatment_plan.priority.' ~ plan.priority)|trans({}, 'risk_treatment_plan')
                                } %}
                            </div>
                        </li>
                        {% endfor %}
                    </ul>
                    {% if overdue_treatment_plans|length > 5 %}
                        <div class="text-center mt-3">
                            <a href="{{ path('app_risk_treatment_plan_index') }}" class="fa-cyber-btn fa-cyber-btn--danger fa-cyber-btn--sm">
                                <i class="fa-icon fa-icon--util-arrow-right" aria-hidden="true"></i>
                                {{ 'dashboard.overdue_treatment_plans.view_all'|trans({ '%count%': overdue_treatment_plans|length - 5 }, 'dashboard') }}
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
            {% endif %}

            {# Approaching Deadline Treatment Plans Widget (ISO 27001:2022 Clause 6.1.3 - Priority 2.4) #}
            {% if approaching_treatment_plans|default([])|length > 0 %}
            <div class="widget-card mb-4 border-warning"
                 data-widget-id="approaching-treatment-plans"
                 data-dashboard-customizer-target="widget">
                <div class="widget-header bg-warning-subtle">
                    <h3 class="widget-title text-warning">
                        <i class="fa-icon fa-icon--nav-calendar-check" aria-hidden="true"></i>
                        {{ 'dashboard.approaching_treatment_plans.title'|trans({}, 'dashboard') }}
                    </h3>
                    {% include '_components/_badge.html.twig' with { variant: 'warning', content: approaching_treatment_plans|length } %}
                </div>
                <div class="widget-body p-3">
                    <p class="text-muted mb-3 small">
                        {{ 'dashboard.approaching_treatment_plans.description'|trans({}, 'dashboard') }}
                    </p>
                    <ul class="list-unstyled mb-0">
                        {% for plan in approaching_treatment_plans|slice(0, 3) %}
                        <li class="mb-2 pb-2 {% if not loop.last %}border-bottom{% endif %}">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="flex-grow-1">
                                    <a href="{{ path('app_risk_treatment_plan_show', {id: plan.id}) }}" class="text-decoration-none">
                                        {{ plan.title|length > 40 ? plan.title|slice(0, 40) ~ '...' : plan.title }}
                                    </a>
                                    <div class="small text-muted">
                                        <i class="fa-icon fa-icon--ui-calendar-event" aria-hidden="true"></i>
                                        {{ plan.targetCompletionDate|date('d.m.Y') }}
                                        {% set daysRemaining = date().diff(plan.targetCompletionDate).days %}
                                        <span>({{ daysRemaining }} {{ 'dashboard.approaching_treatment_plans.days_remaining'|trans({}, 'dashboard') }})</span>
                                    </div>
                                    <div class="progress progress-h-4 mt-1">
                                        <div class="progress-bar" role="progressbar"
                                             style="width: {{ plan.completionPercentage }}%"
                                             aria-valuenow="{{ plan.completionPercentage }}"
                                             aria-valuemin="0"
                                             aria-valuemax="100"></div>
                                    </div>
                                </div>
                            </div>
                        </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
            {% endif %}

            {# Activity Feed Widget #}
            <div class="widget-card mb-4"
                 data-widget-id="activity-feed"
                 data-dashboard-customizer-target="widget">
                <div class="widget-header">
                    <h3 class="widget-title">
                        <i class="fa-icon fa-icon--nav-activity" aria-hidden="true"></i>
                        {{ 'dashboard.activity_feed.title'|trans({}, 'dashboard') }}
                    </h3>
                    <div class="widget-actions">
                        <button class="widget-action" title="{{ 'common.view_all'|trans({}, 'messages') }}" aria-label="{{ 'common.view_all'|trans({}, 'messages') }}">
                            <i class="bi bi-arrows-fullscreen" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>
                {% include '_components/_activity_feed.html.twig' with {
                    activities: activities|default([])
                } %}
            </div>

        </div>
    </div>

    {# Last Updated Timestamp #}
    <div class="text-muted text-end small mt-3">
        {{ 'dashboard.last_updated'|trans({'%time%': 'now'|date('H:i')}, 'dashboard') }}
    </div>

    {# Restore First Steps Link (shown when first steps have been dismissed) #}
    {% if not show_first_steps|default(true) %}
    <div class="text-center mt-3">
        <a href="{{ path('app_dashboard_restore_first_steps') }}" class="text-muted small">
            <i class="fa-icon fa-icon--ui-refresh me-1" aria-hidden="true"></i>
            {{ 'dashboard.restore_first_steps'|trans({}, 'dashboard') }}
        </a>
    </div>
    {% endif %}

    {# Dashboard Settings Modal #}
    {% include '_components/_dashboard_settings_modal.html.twig' %}
</div>
{% endblock %}
