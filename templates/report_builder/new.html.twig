{% extends 'base.html.twig' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'report_builder.new.title'|trans({},'report_builder') }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% block body %}
{% import '_components/_fa_cyber_field.html.twig' as _fa_cyber %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.reports'|trans({}, 'nav'), path: path('app_reports_overview') },
            { label: 'report_builder.page.title'|trans({}, 'report_builder'), path: path('report_builder_index') },
            { label: 'report_builder.new.title'|trans({}, 'report_builder') }
        ]
    } %}

    {{ _fa_page_header.render({
        title: 'report_builder.new.title'|trans({}, 'report_builder'),
        badge: { icon: 'plus', label: '' }
    }) }}

    <div class="row justify-content-center">
        <div class="col-lg-8">
            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header">
                        <h2 class="h5 mb-0">{{ 'report_builder.new.subtitle'|trans({}, 'report_builder') }}</h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {% import '_components/_fa_cyber_field.html.twig' as _fa_cyber %}
                    <form method="post" action="{{ path('report_builder_new') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('report_builder_new') }}">
                        <div class="mb-3">
                            {{ _fa_cyber.text('name', {
                                id: 'name',
                                label: 'report_builder.form.name'|trans({}, 'report_builder'),
                                placeholder: 'report_builder.form.name_placeholder'|trans({}, 'report_builder'),
                                required: true
                            }) }}
                        </div>

                        <div class="mb-3">
                            {{ _fa_cyber.textarea('description', {
                                id: 'description',
                                label: 'report_builder.form.description'|trans({}, 'report_builder'),
                                placeholder: 'report_builder.form.description_placeholder'|trans({}, 'report_builder'),
                                rows: 3
                            }) }}
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="category" class="form-label">{{ 'report_builder.form.category'|trans({}, 'report_builder') }}</label>
                                <select class="form-select fa-cyber-input__field" id="category" name="category">
                                    {% for key, label in categories %}
                                    <option value="{{ key }}">{{ label }}</option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="layout" class="form-label">{{ 'report_builder.form.layout'|trans({}, 'report_builder') }}</label>
                                <select class="form-select fa-cyber-input__field" id="layout" name="layout">
                                    {% for key, label in layouts %}
                                    <option value="{{ key }}" {% if key == 'dashboard' %}selected{% endif %}>{{ label }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>

                        <div class="mb-4">
                            <h3 class="h6">{{ 'report_builder.form.layout_preview'|trans({}, 'report_builder') }}</h3>
                            <div class="row g-2" id="layout-preview">
                                {# 8H.4 migrated — 3 clickable layout-option cards. data-layout attr kept via card_attrs block. #}
                                <div class="col-md-4">
                                    {% embed '_components/_card.html.twig' with { class: 'text-center layout-option' } %}
                                        {% block card_attrs %}data-layout="single"{% endblock %}
                                        {% block card_body %}
                                            <div class="p-3">
                                                <div class="border rounded p-2 mb-2" style="height: 80px; background: var(--surface-2);">
                                                    <div class="bg-primary opacity-25 h-100 rounded"></div>
                                                </div>
                                                <small>{{ 'report_builder.layout.single'|trans({}, 'report_builder') }}</small>
                                            </div>
                                        {% endblock %}
                                    {% endembed %}
                                </div>
                                <div class="col-md-4">
                                    {% embed '_components/_card.html.twig' with { class: 'text-center layout-option' } %}
                                        {% block card_attrs %}data-layout="two_column"{% endblock %}
                                        {% block card_body %}
                                            <div class="p-3">
                                                <div class="border rounded p-2 mb-2 d-flex gap-1" style="height: 80px; background: var(--surface-2);">
                                                    <div class="bg-primary opacity-25 flex-grow-1 rounded"></div>
                                                    <div class="bg-primary opacity-25 flex-grow-1 rounded"></div>
                                                </div>
                                                <small>{{ 'report_builder.layout.two_column'|trans({}, 'report_builder') }}</small>
                                            </div>
                                        {% endblock %}
                                    {% endembed %}
                                </div>
                                <div class="col-md-4">
                                    {% embed '_components/_card.html.twig' with { class: 'text-center layout-option active' } %}
                                        {% block card_attrs %}data-layout="dashboard"{% endblock %}
                                        {% block card_body %}
                                            <div class="p-3">
                                                <div class="border rounded p-2 mb-2" style="height: 80px; background: var(--surface-2);">
                                                    <div class="row g-1 h-100">
                                                        <div class="col-6"><div class="bg-primary opacity-25 h-100 rounded"></div></div>
                                                        <div class="col-6"><div class="bg-primary opacity-25 h-100 rounded"></div></div>
                                                    </div>
                                                </div>
                                                <small>{{ 'report_builder.layout.dashboard'|trans({}, 'report_builder') }}</small>
                                            </div>
                                        {% endblock %}
                                    {% endembed %}
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                                <i class="fa-icon fa-icon--ui-check" aria-hidden="true"></i> {{ 'report_builder.action.create_and_design'|trans({}, 'report_builder') }}
                            </button>
                            <a href="{{ path('report_builder_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                                {{ 'report_builder.action.cancel'|trans({}, 'report_builder') }}
                            </a>
                        </div>
                    </form>
                {% endblock %}
            {% endembed %}
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const layoutSelect = document.getElementById('layout');
    const layoutOptions = document.querySelectorAll('.layout-option');

    layoutOptions.forEach(option => {
        option.addEventListener('click', function() {
            layoutOptions.forEach(o => o.classList.remove('active', 'border-primary'));
            this.classList.add('active', 'border-primary');
            layoutSelect.value = this.dataset.layout;
        });
    });

    layoutSelect.addEventListener('change', function() {
        layoutOptions.forEach(o => {
            o.classList.remove('active', 'border-primary');
            if (o.dataset.layout === this.value) {
                o.classList.add('active', 'border-primary');
            }
        });
    });
});
</script>

<style>
    .layout-option {
        cursor: pointer;
        transition: all 0.2s;
    }
    .layout-option:hover, .layout-option.active {
        border-color: var(--bs-primary) !important;
        box-shadow: 0 0 0 2px rgba(13, 110, 253, 0.25);
    }
</style>
{% endblock %}
