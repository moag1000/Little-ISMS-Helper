{% extends 'base.html.twig' %}

{% block title %}{{ 'report_builder.settings.title'|trans({}, 'report_builder') }} - {{ report.name }} - {{ parent() }}{% endblock %}

{% block body %}
{% include '_components/_breadcrumb.html.twig' with {
    breadcrumbs: [
        { label: 'nav.reports'|trans({}, 'nav'), path: path('app_reports_overview') },
        { label: 'report_builder.page.title'|trans({}, 'report_builder'), path: path('report_builder_index') },
        { label: report.name, path: path('report_builder_edit', {id: report.id}) },
        { label: 'report_builder.settings.title'|trans({}, 'report_builder') }
    ]
} %}

{% include '_components/_page_header.html.twig' with {
    title: 'report_builder.settings.title'|trans({}, 'report_builder') ~ ': ' ~ report.name,
    icon: 'nav-gear',
    actions: [
        { label: 'common.back'|trans({}, 'messages'), url: path('report_builder_edit', {id: report.id}), variant: 'secondary', icon: 'util-arrow-left' }
    ]
} %}

{% embed '_components/_card.html.twig' %}
    {% block card_body %}
        {{ form_start(form) }}
            {% include '_components/_auto_form.html.twig' with {
                'form': form,
                'sections': {
                    'basic_info': {
                        'label': 'report_builder.section.basic_info'|trans({}, 'report_builder'),
                        'fields': ['name', 'description', 'category', 'layout']
                    },
                    'ownership': {
                        'label': 'report_builder.section.ownership'|trans({}, 'report_builder'),
                        'fields': ['owner', 'ownerPerson', 'ownerDeputyPersons']
                    },
                    'sharing': {
                        'label': 'report_builder.section.sharing'|trans({}, 'report_builder'),
                        'fields': ['isShared', 'isTemplate']
                    }
                },
                'col_widths': {
                    'name': 8,
                    'description': 12,
                    'category': 6,
                    'layout': 6,
                    'owner': 6,
                    'ownerPerson': 6,
                    'ownerDeputyPersons': 12,
                    'isShared': 6,
                    'isTemplate': 6
                },
                'translation_domain': 'report_builder'
            } %}

            <div class="form-actions d-flex gap-2 justify-content-end">
                <a href="{{ path('report_builder_edit', {id: report.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                    <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i>
                    {{ 'common.cancel'|trans({}, 'messages') }}
                </a>
                <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
                    <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
                    {{ 'report_builder.action.save'|trans({}, 'report_builder') }}
                </button>
            </div>
        {{ form_end(form) }}
    {% endblock %}
{% endembed %}
{% endblock %}
