{#
 # Cross-Framework Gap Heatmap — reusable partial.
 #
 # Renders a Frameworks × Requirement-Cluster × Ampel (RAG) grid showing
 # compliance coverage at a glance via Aurora-v4 `fa-matrix-table` (mode=rag).
 # Each cell is colour-coded:
 #   green  (rag-green)  = 80%+ requirements fulfilled
 #   amber  (rag-amber)  = 40–79% fulfilled
 #   red    (rag-red)    = <40% fulfilled
 #   grey   (rag-none)   = framework not active / no data
 #
 # Parameters:
 #   heatmap_data  array — matrix: {
 #       frameworks: [{ id: int, name: string }],
 #       clusters:   [{ key: string, label: string }],
 #       cells:      { '<framework_id>_<cluster_key>': { rate: float, status: 'green'|'amber'|'red'|'none' } }
 #   }
 #
 # Usage:
 #   {% include 'compliance/_heatmap.html.twig' with { heatmap_data: myData } %}
 #}
{% trans_default_domain 'compliance' %}
{% import '_components/_fa_matrix_table.html.twig' as _fa_matrix %}

{#
 # Adapt the controller-supplied { frameworks[], clusters[], cells{key} } shape
 # into the fa-matrix-table row/col/cells[rowIdx][colIdx] structure.
 # Cluster labels are abbreviated to 8 chars in the header (full label retained
 # in the cell title attribute via cell.hint).
 #}
{% set _rowLabels = [] %}
{% for framework in heatmap_data.frameworks %}
    {% set _rowLabels = _rowLabels|merge([framework.name]) %}
{% endfor %}

{% set _colLabels = [] %}
{% for cluster in heatmap_data.clusters %}
    {% set _colLabels = _colLabels|merge([cluster.label|slice(0, 8)]) %}
{% endfor %}

{% set _cells = [] %}
{% for framework in heatmap_data.frameworks %}
    {% set _rowCells = [] %}
    {% for cluster in heatmap_data.clusters %}
        {% set _cellKey = framework.id ~ '_' ~ cluster.key %}
        {% set _cell    = heatmap_data.cells[_cellKey] ?? {rate: null, status: 'none'} %}
        {% set _rate    = _cell.rate is defined ? _cell.rate : null %}
        {% set _pctText = _rate is not null ? (_rate * 100)|number_format(0) ~ '%' : 'N/A' %}
        {% set _rowCells = _rowCells|merge([{
            status: _cell.status|default('none'),
            rate:   _rate,
            label:  framework.name ~ ', ' ~ cluster.label ~ ': ' ~ _cell.status|default('none'),
            hint:   framework.name ~ ': ' ~ cluster.label ~ ' — ' ~ _pctText,
        }]) %}
    {% endfor %}
    {% set _cells = _cells|merge([_rowCells]) %}
{% endfor %}

<div role="region" aria-label="{{ 'compliance.heatmap.title'|trans({}, 'compliance') }}" aria-live="polite">
    {% if heatmap_data.frameworks|length > 0 %}
        {{ _fa_matrix.render({
            mode:    'rag',
            title:   'compliance.heatmap.title'|trans({}, 'compliance'),
            caption: 'compliance.heatmap.caption'|trans({}, 'compliance'),
            rows:    _rowLabels,
            cols:    _colLabels,
            cells:   _cells,
            xLabel:  'compliance.heatmap.col_cluster'|trans({}, 'compliance'),
            yLabel:  'compliance.heatmap.col_framework'|trans({}, 'compliance'),
            legend:  true
        }) }}
    {% else %}
        <p class="text-center text-muted py-4">
            {{ 'compliance.heatmap.no_data'|trans({}, 'compliance') }}
        </p>
    {% endif %}
</div>
