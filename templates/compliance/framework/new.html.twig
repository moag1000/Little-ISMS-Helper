{% extends 'base.html.twig' %}

{% block title %}{{ 'compliance.framework.new.title'|trans({}, 'compliance') }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.compliance'|trans({}, 'nav'), url: path('app_compliance_index') },
            { label: 'compliance.framework.new.title'|trans({}, 'compliance') }
        ]
    } %}

    <h1><i class="fa-icon fa-icon--ui-plus" aria-hidden="true"></i> {{ 'compliance.framework.new.heading'|trans({}, 'compliance') }}</h1>

    <div class="row">
        <div class="col-lg-8">
            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header">
                        <h2 class="mb-0">
                            <i class="fa-icon fa-icon--nav-process" aria-hidden="true"></i> {{ 'compliance.framework.field.details'|trans({}, 'compliance') }}
                        </h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {{ form_start(form) }}

                    {% include '_components/_auto_form.html.twig' with {
                        'form': form,
                        'sections': {
                            'identification': {
                                'label': 'compliance.framework.section.identification'|trans({}, 'compliance'),
                                'fields': ['code', 'version', 'name']
                            },
                            'details': {
                                'label': 'compliance.framework.section.details'|trans({}, 'compliance'),
                                'fields': ['description', 'applicableIndustry', 'regulatoryBody', 'scopeDescription']
                            },
                            'configuration': {
                                'label': 'compliance.framework.section.configuration'|trans({}, 'compliance'),
                                'fields': ['mandatory', 'active']
                            }
                        },
                        'col_widths': {
                            'code': 6,
                            'version': 6,
                            'name': 12,
                            'description': 12,
                            'applicableIndustry': 6,
                            'regulatoryBody': 6,
                            'scopeDescription': 12,
                            'mandatory': 4,
                            'active': 4
                        }
                    } %}

                    <div class="d-flex gap-2 pt-3 border-top">
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--success">
                            <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i> {{ 'common.create'|trans({}, 'messages') }}
                        </button>
                        <a href="{{ path('app_compliance_framework_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                            <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i> {{ 'common.cancel'|trans({}, 'messages') }}
                        </a>
                    </div>

                    {{ form_end(form) }}
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-lg-4">
            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header">
                        <h2 class="mb-0"><i class="fa-icon fa-icon--status-info" aria-hidden="true"></i> {{ 'common.help'|trans({}, 'messages') }}</h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <h3>{{ 'compliance.framework.help.code.title'|trans({}, 'compliance') }}</h3>
                    <p class="small text-muted">{{ 'compliance.framework.help.code.text'|trans({}, 'compliance') }}</p>

                    <h3>{{ 'compliance.framework.help.mandatory.title'|trans({}, 'compliance') }}</h3>
                    <p class="small text-muted">{{ 'compliance.framework.help.mandatory.text'|trans({}, 'compliance') }}</p>

                    <h3>{{ 'compliance.framework.help.active.title'|trans({}, 'compliance') }}</h3>
                    <p class="small text-muted">{{ 'compliance.framework.help.active.text'|trans({}, 'compliance') }}</p>
                {% endblock %}
            {% endembed %}
        </div>
    </div>
</div>
{% endblock %}
