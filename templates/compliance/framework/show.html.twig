{% extends 'base.html.twig' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% trans_default_domain 'compliance' %}

{% block title %}{{ framework.name }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.compliance'|trans({}, 'nav'), url: path('app_compliance_index') },
            { label: 'nav.compliance_frameworks'|trans({}, 'nav'), url: path('app_compliance_framework_index') },
            { label: framework.name }
        ]
    } %}

    {% set _show_actions = [
        { label: 'compliance.framework.action.dashboard'|trans({}, 'compliance'), variant: 'primary', icon: 'speedometer2', href: path('app_compliance_framework', {id: framework.id}) }
    ] %}
    {% if is_granted('ROLE_MANAGER') %}
        {% set _show_actions = _show_actions|merge([{ label: 'compliance.framework.migrate.title'|trans({}, 'compliance'), variant: 'ghost', icon: 'arrow-up-circle', href: path('app_compliance_framework_migrate', {id: framework.id}) }]) %}
    {% endif %}
    {% if is_granted('ROLE_ADMIN') %}
        {% set _show_actions = _show_actions|merge([{ label: 'common.edit'|trans({}, 'messages'), variant: 'accent', icon: 'pencil', href: path('app_compliance_framework_edit', {id: framework.id}) }]) %}
    {% endif %}
    {% if is_granted('ROLE_AUDITOR') %}
        {% set _show_actions = _show_actions|merge([{ label: 'audit_workbook.action.export_xlsx'|trans({}, 'audit_workbook'), variant: 'success', icon: 'download', href: path('app_audit_workbook_compliance', {frameworkId: framework.id}) }]) %}
    {% endif %}
    {% set _show_actions = _show_actions|merge([{ label: 'common.back'|trans({}, 'messages'), variant: 'ghost', icon: 'arrow-left', href: path('app_compliance_framework_index') }]) %}
    {{ _fa_page_header.render({
        badge: { icon: 'shield-check', label: framework.code },
        title: framework.name,
        subtitle: 'compliance.framework.field.version'|trans({}, 'compliance') ~ ': ' ~ framework.version,
        actions: _show_actions
    }) }}

    {# Status badges + POST forms (toggle/duplicate) kept below header (cannot be expressed via _fa_page_header GET-only actions) #}
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div class="d-flex align-items-center gap-2">
            {% if framework.active %}
                {% include '_components/_badge.html.twig' with { variant: 'success', content: 'common.active'|trans({}, 'messages') } %}
            {% else %}
                {% include '_components/_badge.html.twig' with { variant: 'secondary', content: 'common.inactive'|trans({}, 'messages') } %}
            {% endif %}
            {% if framework.mandatory %}
                {% include '_components/_badge.html.twig' with { variant: 'danger', content: 'compliance.framework.badge.mandatory'|trans({}, 'compliance') } %}
            {% endif %}
        </div>
        {% if is_granted('ROLE_ADMIN') %}
            <div class="d-flex gap-2">
                <form method="post" action="{{ path('app_compliance_framework_toggle', {id: framework.id}) }}" class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ framework.id) }}">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--{{ framework.active ? 'ghost' : 'success' }}">
                        <i class="fa-icon fa-icon--{{ framework.active ? 'pause' : 'play' }}" aria-hidden="true"></i>
                        {{ framework.active ? 'common.deactivate'|trans({}, 'messages') : 'common.activate'|trans({}, 'messages') }}
                    </button>
                </form>
                <form method="post" action="{{ path('app_compliance_framework_duplicate', {id: framework.id}) }}" class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('duplicate' ~ framework.id) }}">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost">
                        <i class="fa-icon fa-icon--ui-copy" aria-hidden="true"></i> {{ 'common.duplicate'|trans({}, 'messages') }}
                    </button>
                </form>
            </div>
        {% endif %}
    </div>

    {# Statistics Row #}
    <div class="row mb-4">
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' with { 'class': 'bg-primary text-white' } %}
                {% block card_body %}
                    <div class="text-center">
                        <h2>{{ total_requirements }}</h2>
                        <p class="mb-0">{{ 'compliance.framework.stats.total_requirements'|trans({}, 'compliance') }}</p>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' with { 'class': 'bg-info text-white' } %}
                {% block card_body %}
                    <div class="text-center">
                        <h2>{{ applicable_requirements }}</h2>
                        <p class="mb-0">{{ 'compliance.framework.stats.applicable'|trans({}, 'compliance') }}</p>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-3">
            {% embed '_components/_card.html.twig' with { 'class': 'bg-success text-white' } %}
                {% block card_body %}
                    <div class="text-center">
                        <h2>{{ fulfilled_requirements }}</h2>
                        <p class="mb-0">{{ 'compliance.framework.stats.fulfilled'|trans({}, 'compliance') }}</p>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-md-3">
            {% set complianceColorClass = compliance_percentage >= 80 ? 'bg-success' : (compliance_percentage >= 50 ? 'bg-warning' : 'bg-danger') %}
            {% embed '_components/_card.html.twig' with { 'class': complianceColorClass ~ ' text-white' } %}
                {% block card_body %}
                    <div class="text-center">
                        <h2>{{ compliance_percentage|round }}%</h2>
                        <p class="mb-0">{{ 'compliance.framework.stats.compliance'|trans({}, 'compliance') }}</p>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            {# Framework Details #}
            {% embed '_components/_card.html.twig' with {
                'title': 'compliance.framework.details',
                'headerIcon': 'bi-info-circle',
                'class': 'mb-4'
            } %}
                {% block card_body %}
                    {% if framework.description %}
                        <h2>{{ 'compliance.framework.field.description'|trans({}, 'compliance') }}</h2>
                        <p>{{ framework.description }}</p>
                    {% endif %}

                    <div class="row">
                        <div class="col-md-6">
                            <dl>
                                <dt>{{ 'compliance.framework.field.industry'|trans({}, 'compliance') }}</dt>
                                <dd>{{ framework.applicableIndustry }}</dd>

                                <dt>{{ 'compliance.framework.field.regulatory_body'|trans({}, 'compliance') }}</dt>
                                <dd>{{ framework.regulatoryBody }}</dd>
                            </dl>
                        </div>
                        <div class="col-md-6">
                            <dl>
                                <dt>{{ 'common.created_at'|trans({}, 'messages') }}</dt>
                                <dd>{{ framework.createdAt|date('d.m.Y H:i') }}</dd>

                                <dt>{{ 'common.updated_at'|trans({}, 'messages') }}</dt>
                                <dd>{{ framework.updatedAt ? framework.updatedAt|date('d.m.Y H:i') : '-' }}</dd>
                            </dl>
                        </div>
                    </div>

                    {% if framework.scopeDescription %}
                        <h2>{{ 'compliance.framework.field.scope'|trans({}, 'compliance') }}</h2>
                        <p>{{ framework.scopeDescription }}</p>
                    {% endif %}
                {% endblock %}
            {% endembed %}

            {# Requirements by Category #}
            {% embed '_components/_card.html.twig' with {
                'title': 'compliance.framework.requirements_by_category',
                'headerIcon': 'bi-list-check',
                'actions': '<a href="' ~ path('app_compliance_requirement_index', {framework: framework.id}) ~ '" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"><i class="fa-icon fa-icon--ui-list" aria-hidden="true"></i> ' ~ 'common.view_all'|trans({}, 'messages') ~ '</a>',
                'class': 'mb-4'
            } %}
                {% block card_body %}
                    {% if requirements_by_category|length > 0 %}
                        <div class="accordion" id="categoryAccordion">
                            {% for category, requirements in requirements_by_category %}
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed" type="button"
                                                data-bs-toggle="collapse"
                                                data-bs-target="#category{{ loop.index }}">
                                            {{ category }}
                                            {% include '_components/_badge.html.twig' with { variant: 'secondary', content: requirements|length, class: 'ms-2' } %}
                                        </button>
                                    </h2>
                                    <div id="category{{ loop.index }}" class="accordion-collapse collapse"
                                         data-bs-parent="#categoryAccordion">
                                        <div class="accordion-body">
                                            <div class="list-group">
                                                {% for req in requirements %}
                                                    {% set reqFulfillment = requirement_fulfillments[req.id] %}
                                                    {% set reqPct = reqFulfillment ? reqFulfillment.fulfillmentPercentage : 0 %}
                                                    <a href="{{ path('app_compliance_requirement_show', {id: req.id}) }}"
                                                       class="list-group-item list-group-item-action">
                                                        <div class="d-flex justify-content-between align-items-center">
                                                            <div>
                                                                <strong>{{ req.requirementId }}</strong> - {{ req.title }}
                                                            </div>
                                                            <div>
                                                                <span class="{{ badge_completion(reqPct) }}">
                                                                    {{ reqPct }}%
                                                                </span>
                                                            </div>
                                                        </div>
                                                    </a>
                                                {% endfor %}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="text-center py-4">
                            <i class="fa-icon fa-icon--nav-list-check fs-1 text-muted" aria-hidden="true"></i>
                            <p class="mt-2 text-muted">{{ 'compliance.framework.no_requirements'|trans({}, 'compliance') }}</p>
                            {% if is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('app_compliance_requirement_new', {framework: framework.id}) }}" class="fa-cyber-btn fa-cyber-btn--success">
                                    <i class="fa-icon fa-icon--ui-plus" aria-hidden="true"></i> {{ 'compliance.requirement.action.new'|trans({}, 'compliance') }}
                                </a>
                            {% endif %}
                        </div>
                    {% endif %}
                {% endblock %}
            {% endembed %}
        </div>

        <div class="col-lg-4">
            {# Priority Distribution #}
            {% embed '_components/_card.html.twig' with {
                'title': 'compliance.framework.priority_distribution',
                'headerIcon': 'bi-bar-chart',
                'class': 'mb-4'
            } %}
                {% block card_body %}
    {% import '_components/_fa_progress.html.twig' as _fa_progress %}
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            {% include '_components/_badge.html.twig' with { variant: 'danger', content: 'compliance.requirement.priority.critical'|trans({}, 'compliance') } %}
                            <span>{{ priority_distribution.critical }}</span>
                        </div>
                        {{ _fa_progress.render({ value: total_requirements > 0 ? (priority_distribution.critical / total_requirements * 100) : 0, tone: 'danger' }) }}
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            {% include '_components/_badge.html.twig' with { variant: 'warning', content: 'compliance.requirement.priority.high'|trans({}, 'compliance') } %}
                            <span>{{ priority_distribution.high }}</span>
                        </div>
                        {{ _fa_progress.render({ value: total_requirements > 0 ? (priority_distribution.high / total_requirements * 100) : 0, tone: 'warning' }) }}
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            {% include '_components/_badge.html.twig' with { variant: 'info', content: 'compliance.requirement.priority.medium'|trans({}, 'compliance') } %}
                            <span>{{ priority_distribution.medium }}</span>
                        </div>
                        {{ _fa_progress.render({ value: total_requirements > 0 ? (priority_distribution.medium / total_requirements * 100) : 0, tone: 'info' }) }}
                    </div>
                    <div>
                        <div class="d-flex justify-content-between mb-1">
                            {% include '_components/_badge.html.twig' with { variant: 'secondary', content: 'compliance.requirement.priority.low'|trans({}, 'compliance') } %}
                            <span>{{ priority_distribution.low }}</span>
                        </div>
                        {{ _fa_progress.render({ value: total_requirements > 0 ? (priority_distribution.low / total_requirements * 100) : 0, tone: 'neutral' }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {# Quick Actions #}
            {% embed '_components/_card.html.twig' with {
                'title': 'common.quick_actions',
                'headerIcon': 'bi-lightning'
            } %}
                {% block card_body %}
                <div class="d-grid gap-2">
                    <a href="{{ path('app_compliance_requirement_new', {framework: framework.id}) }}" class="fa-cyber-btn fa-cyber-btn--success">
                        <i class="fa-icon fa-icon--ui-plus" aria-hidden="true"></i> {{ 'compliance.requirement.action.new'|trans({}, 'compliance') }}
                    </a>
                    <a href="{{ path('app_compliance_gaps', {id: framework.id}) }}" class="fa-cyber-btn fa-cyber-btn--warning">
                        <i class="fa-icon fa-icon--ui-search" aria-hidden="true"></i> {{ 'compliance.framework.action.gap_analysis'|trans({}, 'compliance') }}
                    </a>
                    <form method="post" action="{{ path('app_compliance_assess', {id: framework.id}) }}" style="display: inline;">
                        <input type="hidden" name="_token" value="{{ csrf_token('assess_framework') }}">
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost">
                            <i class="fa-icon fa-icon--sop" aria-hidden="true"></i> {{ 'compliance.framework.action.assess'|trans({}, 'compliance') }}
                        </button>
                    </form>
                </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>
</div>
{% endblock %}
