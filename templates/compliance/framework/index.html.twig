{% extends 'base.html.twig' %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}

{% block title %}{{ 'compliance.framework.title'|trans({}, 'compliance') }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.compliance'|trans({}, 'nav'), url: path('app_compliance_index') },
            { label: 'compliance.framework.title'|trans({}, 'compliance') }
        ]
    } %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1><i class="fa-icon fa-icon--compliance-shield" aria-hidden="true"></i> {{ 'compliance.framework.heading'|trans({}, 'compliance') }}</h1>
            <p class="text-muted">{{ 'compliance.framework.description'|trans({}, 'compliance') }}</p>
        </div>
        <div>
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_compliance_framework_new') }}" class="fa-cyber-btn fa-cyber-btn--success">
                    <i class="fa-icon fa-icon--ui-plus" aria-hidden="true"></i> {{ 'compliance.framework.action.new'|trans({}, 'compliance') }}
                </a>
            {% endif %}
            <a href="{{ path('app_compliance_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                <i class="fa-icon fa-icon--util-arrow-left" aria-hidden="true"></i> {{ 'common.back'|trans({}, 'messages') }}
            </a>
        </div>
    </div>

    {# Skip link for filters section - WCAG 2.4.1 #}
    <a href="#filter-section" class="skip-link">{{ 'accessibility.skip_to_filters'|trans({}, 'messages') }}</a>

    {# Filters #}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
        {% block card_header %}
            <div class="card-header">
                <i class="fa-icon fa-icon--ui-funnel" aria-hidden="true"></i> {{ 'common.filters'|trans({}, 'messages') }}
            </div>
        {% endblock %}
        {% block card_body %}
            <div id="filter-section" tabindex="-1">
            <form method="get" class="row g-3" role="search" aria-label="{{ 'common.filters'|trans({}, 'messages') }}">
                <div class="col-md-3">
                    <label class="form-label" for="filter-active">{{ 'compliance.framework.field.active'|trans({}, 'compliance') }}</label>
                    <select name="active" id="filter-active" class="form-select">
                        <option value="">{{ 'common.all'|trans({}, 'messages') }}</option>
                        <option value="1" {{ filters.active == '1' ? 'selected' }}>{{ 'common.yes'|trans({}, 'messages') }}</option>
                        <option value="0" {{ filters.active == '0' ? 'selected' }}>{{ 'common.no'|trans({}, 'messages') }}</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="filter-mandatory">{{ 'compliance.framework.field.mandatory'|trans({}, 'compliance') }}</label>
                    <select name="mandatory" id="filter-mandatory" class="form-select">
                        <option value="">{{ 'common.all'|trans({}, 'messages') }}</option>
                        <option value="1" {{ filters.mandatory == '1' ? 'selected' }}>{{ 'common.yes'|trans({}, 'messages') }}</option>
                        <option value="0" {{ filters.mandatory == '0' ? 'selected' }}>{{ 'common.no'|trans({}, 'messages') }}</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="filter-industry">{{ 'compliance.framework.field.industry'|trans({}, 'compliance') }}</label>
                    <select name="industry" id="filter-industry" class="form-select">
                        <option value="">{{ 'common.all'|trans({}, 'messages') }}</option>
                        {% for industry in industries %}
                            <option value="{{ industry }}" {{ filters.industry == industry ? 'selected' }}>{{ industry }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary me-2">
                        <i class="fa-icon fa-icon--ui-search" aria-hidden="true"></i> {{ 'common.filter'|trans({}, 'messages') }}
                    </button>
                    <a href="{{ path('app_compliance_framework_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                        <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i> {{ 'common.reset'|trans({}, 'messages') }}
                    </a>
                </div>
            </form>
            </div>
        {% endblock %}
    {% endembed %}

    {# Frameworks List #}
    {% embed '_components/_card.html.twig' %}
        {% block card_header %}
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fa-icon fa-icon--ui-list" aria-hidden="true"></i> {{ 'compliance.framework.list'|trans({}, 'compliance') }}</span>
                {% include '_components/_badge.html.twig' with { variant: 'primary', content: frameworks|length ~ ' ' ~ ('common.items'|trans({}, 'messages')) } %}
            </div>
        {% endblock %}
        {% block card_body %}
            {% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
            {% if frameworks|length > 0 %}
                {% embed '_components/_table.html.twig' with {
                    'noMargin': true
                } %}
                    {% block table_head %}
                        <tr>
                            <th scope="col">{{ 'compliance.framework.field.code'|trans({}, 'compliance') }}</th>
                            <th scope="col">{{ 'compliance.framework.field.name'|trans({}, 'compliance') }}</th>
                            <th scope="col">{{ 'compliance.framework.field.version'|trans({}, 'compliance') }}</th>
                            <th scope="col">{{ 'compliance.framework.field.industry'|trans({}, 'compliance') }}</th>
                            <th scope="col">{{ 'compliance.framework.field.mandatory'|trans({}, 'compliance') }}</th>
                            <th scope="col">{{ 'compliance.framework.field.status'|trans({}, 'compliance') }}</th>
                            <th scope="col">{{ 'compliance.framework.field.requirements'|trans({}, 'compliance') }}</th>
                            <th scope="col">{{ 'compliance.framework.field.compliance'|trans({}, 'compliance') }}</th>
                            <th scope="col">{{ 'common.actions'|trans({}, 'messages') }}</th>
                        </tr>
                    {% endblock %}
                    {% block table_body %}
                        {% for framework in frameworks %}
                            <tr>
                                <td><code>{{ framework.code }}</code></td>
                                <td>
                                    <a href="{{ path('app_compliance_framework_show', {id: framework.id}) }}" class="text-decoration-none fw-bold">
                                        {{ framework.name }}
                                    </a>
                                </td>
                                <td>{{ framework.version }}</td>
                                <td>{{ framework.applicableIndustry }}</td>
                                <td>
                                    {% if framework.mandatory %}
                                        {% include '_components/_badge.html.twig' with { variant: 'danger', content: 'common.yes'|trans({}, 'messages') } %}
                                    {% else %}
                                        {% include '_components/_badge.html.twig' with { variant: 'secondary', content: 'common.no'|trans({}, 'messages') } %}
                                    {% endif %}
                                </td>
                                <td>
                                    {% if framework.active %}
                                        {% include '_components/_badge.html.twig' with { variant: 'success', content: 'common.active'|trans({}, 'messages') } %}
                                    {% else %}
                                        {% include '_components/_badge.html.twig' with { variant: 'secondary', content: 'common.inactive'|trans({}, 'messages') } %}
                                    {% endif %}
                                </td>
                                <td>
                                    {% include '_components/_badge.html.twig' with { variant: 'info', content: framework.requirements|length } %}
                                </td>
                                <td>
                                    {% set percentage = framework.compliancePercentage %}
                                    <div class="progress progress-h-20">
                                        <div class="progress-bar {% if percentage >= 80 %}bg-success{% elseif percentage >= 50 %}bg-warning{% else %}bg-danger{% endif %}"
                                             role="progressbar"
                                             style="width: {{ percentage }}%"
                                             aria-valuenow="{{ percentage }}"
                                             aria-valuemin="0"
                                             aria-valuemax="100">
                                            {{ percentage|round }}%
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group" aria-label="{{ 'common.actions'|trans({}, 'messages') }}">
                                        <a href="{{ path('app_compliance_framework_show', {id: framework.id}) }}"
                                           class="fa-cyber-btn fa-cyber-btn--ghost" title="{{ 'common.view'|trans({}, 'messages') }}" aria-label="{{ 'common.view'|trans({}, 'messages') }}">
                                            <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
                                        </a>
                                        <a href="{{ path('app_compliance_framework', {id: framework.id}) }}"
                                           class="fa-cyber-btn fa-cyber-btn--ghost" title="{{ 'compliance.framework.action.dashboard'|trans({}, 'compliance') }}" aria-label="{{ 'common.view'|trans({}, 'messages') }}">
                                            <i class="fa-icon fa-icon--nav-dashboard" aria-hidden="true"></i>
                                        </a>
                                        {% if is_granted('ROLE_ADMIN') %}
                                            <a href="{{ path('app_compliance_framework_edit', {id: framework.id}) }}"
                                               class="fa-cyber-btn fa-cyber-btn--warning" title="{{ 'common.edit'|trans({}, 'messages') }}" aria-label="{{ 'common.edit'|trans({}, 'messages') }}">
                                                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                                            </a>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            {% else %}
                {{ _fa_empty_state.render({
                    mood: 'sleeping',
                    title: 'compliance.framework.empty'|trans({}, 'compliance'),
                    actions: is_granted('ROLE_ADMIN') ? [
                        { label: 'compliance.framework.action.new'|trans({}, 'compliance'), variant: 'primary', icon: 'plus-circle', href: path('app_compliance_framework_new') }
                    ] : []
                }) }}
            {% endif %}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
