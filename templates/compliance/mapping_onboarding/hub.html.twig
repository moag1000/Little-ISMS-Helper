{% extends 'base.html.twig' %}
{% trans_default_domain 'compliance' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_stepper.html.twig' as _fa_stepper %}
{% import '_components/_onboarding_fairy.html.twig' as onFairy %}

{#
 # Mapping-Onboarding Hub — Alva-led split-layout spine
 #
 # Controller vars:
 #   state      (array: step, completed, snapshot, signals)
 #   stepIndex  (int 0-3)
 #   stepIds    (['laden','reviewen','mappen','wiederverwenden'])
 #   isManager  (bool)
 #
 # Valid Alva moods: idle|happy|thinking|focused|working|scanning|warning|celebrating|sleeping
 #}

{% set stepMeta = {
    'laden':          {'route': 'app_compliance_mapping_seeds_index',  'mood': 'working',  'manager_only': true},
    'reviewen':       {'route': 'app_mapping_quality_dashboard',        'mood': 'scanning', 'manager_only': false},
    'mappen':         {'route': 'app_mapping_quality_gaps',             'mood': 'focused',  'manager_only': false},
    'wiederverwenden':{'route': 'app_compliance_cross_framework',       'mood': 'happy',    'manager_only': false}
} %}
{% set currentId = stepIds[stepIndex] %}
{% set cur = stepMeta[currentId] %}

{% block body %}
    {{ _fa_page_header.render({
        badge: { icon: 'nav-process', label: 'nav.compliance'|trans({}, 'nav') },
        title: 'onboarding.mapping.title'|trans,
        subtitle: 'onboarding.mapping.subtitle'|trans
    }) }}

    <div class="row g-4">
        {# ── Left panel: Alva fairy + coaching text + stepper ── #}
        <aside class="col-12 col-lg-4">
            <div class="card text-center">
                <div class="card-body py-4">
                    {{ onFairy.render(cur.mood) }}
                    <p class="fw-semibold mt-3 mb-1">
                        {{ ('onboarding.mapping.step.' ~ currentId ~ '.line')|trans }}
                    </p>
                    <p class="text-muted small mb-0">
                        {{ ('onboarding.mapping.step.' ~ currentId ~ '.sub')|trans }}
                    </p>
                </div>
            </div>

            <div class="mt-3">
                {{ _fa_stepper.render([
                    { label: 'onboarding.mapping.step.laden.label'|trans },
                    { label: 'onboarding.mapping.step.reviewen.label'|trans },
                    { label: 'onboarding.mapping.step.mappen.label'|trans },
                    { label: 'onboarding.mapping.step.wiederverwenden.label'|trans }
                ], stepIndex, { ariaLabel: 'onboarding.mapping.title'|trans }) }}
            </div>
        </aside>

        {# ── Right panel: current-step intro + action buttons ── #}
        <section class="col-12 col-lg-8">
            <div class="card">
                <div class="card-body">
                    <h2 class="h5 mb-2">
                        {{ ('onboarding.mapping.step.' ~ currentId ~ '.heading')|trans }}
                    </h2>
                    <p class="text-muted mb-4">
                        {{ ('onboarding.mapping.step.' ~ currentId ~ '.body')|trans }}
                    </p>

                    <div class="d-flex align-items-center flex-wrap gap-2">
                        {% if cur.manager_only and not isManager %}
                            <div class="alert alert-info mb-0 w-100">
                                {{ 'onboarding.mapping.step.laden.blocked_by_role'|trans }}
                            </div>
                        {% else %}
                            <a href="{{ path(cur.route) }}?wf=mapping-onboarding"
                               class="btn btn-primary"
                               data-controller="guided-tour"
                               data-guided-tour-role-param="mapping">
                                {{ 'onboarding.mapping.do_now'|trans }}
                            </a>
                        {% endif %}

                        <form method="post"
                              action="{{ path('app_mapping_onboarding_advance') }}"
                              class="d-inline">
                            <button type="submit" class="btn btn-outline-secondary">
                                {{ 'onboarding.mapping.check_done'|trans }}
                            </button>
                        </form>

                        {% if currentId in (state.completed|default([])) %}
                            <span class="badge text-bg-success">
                                {{ 'onboarding.mapping.step_done'|trans }}
                            </span>
                        {% endif %}
                    </div>
                </div>
            </div>

            {% if (state.step|default(0)) >= 4 %}
                <div class="alert alert-success mt-3">
                    {{ 'onboarding.mapping.all_done'|trans }}
                </div>
            {% endif %}
        </section>
    </div>
{% endblock %}
