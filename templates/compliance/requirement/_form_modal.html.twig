{# ComplianceRequirement create/edit rendered inside the fa-form-modal Turbo
   Frame. Explicit form action (the document URL stays on the list). On valid
   submit the controller returns a Turbo Stream (row replace/append). #}
{% trans_default_domain 'compliance' %}
{% set is_edit = requirement is defined and requirement and requirement.id is not null %}
{% set form_action = is_edit
    ? path('app_compliance_requirement_edit', { id: requirement.id, _locale: app.request.locale })
    : path('app_compliance_requirement_new', { _locale: app.request.locale }) %}
<turbo-frame id="fa-form-modal">
    {{ form_start(form, { action: form_action, method: 'POST', attr: {
        id: 'compliance-requirement-modal-form',
        'data-turbo-frame': 'fa-form-modal'
    } }) }}
    {% include 'compliance/requirement/_form_body.html.twig' with {
        form: form,
        modal: true,
        title: is_edit ? requirement.title : 'compliance.requirement.new.title'|trans({}, 'compliance'),
        actions: {
            close: { label: 'common.cancel'|trans({}, 'messages'), variant: 'ghost', action: 'fa-form-modal#close' },
            submit: { label: 'common.save'|trans({}, 'messages'), variant: 'primary' }
        }
    } %}
    {{ form_end(form) }}
</turbo-frame>
