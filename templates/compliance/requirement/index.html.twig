{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block title %}{{ 'compliance.requirement.index_title'|trans({}, 'compliance') }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.compliance'|trans({}, 'nav'), url: path('app_compliance_index') },
            { label: 'compliance.requirement.title'|trans({}, 'compliance') }
        ]
    } %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-list-check" aria-hidden="true"></i> {{ 'compliance.requirement.index_title'|trans({}, 'compliance') }}</h1>
        <a href="{{ path('app_compliance_requirement_new', {framework: selected_framework}) }}" class="fa-cyber-btn fa-cyber-btn--primary">
            <i class="bi bi-plus-circle" aria-hidden="true"></i> {{ 'compliance.requirement.action.new'|trans({}, 'compliance') }}
        </a>
    </div>

    {# Framework Filter #}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
        {% block card_body %}
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label for="framework" class="form-label">{{ 'compliance.requirement.filter_by_framework'|trans({}, 'compliance') }}</label>
                    <select name="framework" id="framework" class="form-select" data-controller="ui-actions" data-action="change->ui-actions#autoSubmit">
                        <option value="">{{ 'compliance.requirement.all_frameworks'|trans({}, 'compliance') }}</option>
                        {% for framework in frameworks %}
                            <option value="{{ framework.id }}" {% if selected_framework == framework.id %}selected{% endif %}>
                                {{ framework.name }} ({{ framework.code }})
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="absicherungs_stufe" class="form-label">{{ 'compliance.requirement.filter_by_absicherungs_stufe'|trans({}, 'compliance') }}</label>
                    <select name="absicherungs_stufe" id="absicherungs_stufe" class="form-select" data-controller="ui-actions" data-action="change->ui-actions#autoSubmit">
                        <option value="">{{ 'compliance.requirement.all_stufen'|trans({}, 'compliance') }}</option>
                        <option value="basis" {% if selected_absicherungs_stufe == 'basis' %}selected{% endif %}>{{ 'compliance.requirement.absicherungs_stufe.basis'|trans({}, 'compliance') }}</option>
                        <option value="standard" {% if selected_absicherungs_stufe == 'standard' %}selected{% endif %}>{{ 'compliance.requirement.absicherungs_stufe.standard'|trans({}, 'compliance') }}</option>
                        <option value="kern" {% if selected_absicherungs_stufe == 'kern' %}selected{% endif %}>{{ 'compliance.requirement.absicherungs_stufe.kern'|trans({}, 'compliance') }}</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="anforderungs_typ" class="form-label">{{ 'compliance.requirement.filter_by_anforderungs_typ'|trans({}, 'compliance') }}</label>
                    <select name="anforderungs_typ" id="anforderungs_typ" class="form-select" data-controller="ui-actions" data-action="change->ui-actions#autoSubmit">
                        <option value="">{{ 'compliance.requirement.all_typen'|trans({}, 'compliance') }}</option>
                        <option value="MUSS" {% if selected_anforderungs_typ == 'MUSS' %}selected{% endif %}>MUSS</option>
                        <option value="SOLLTE" {% if selected_anforderungs_typ == 'SOLLTE' %}selected{% endif %}>SOLLTE</option>
                        <option value="KANN" {% if selected_anforderungs_typ == 'KANN' %}selected{% endif %}>KANN</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost">
                        <i class="bi bi-funnel" aria-hidden="true"></i> {{ 'common.filter'|trans({}, 'messages') }}
                    </button>
                    {% if selected_framework or selected_absicherungs_stufe or selected_anforderungs_typ %}
                        <a href="{{ path('app_compliance_requirement_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost ms-2" title="{{ 'common.clear'|trans({}, 'messages') }}">
                            <i class="bi bi-x-circle" aria-hidden="true"></i>
                        </a>
                    {% endif %}
                </div>
            </form>
        {% endblock %}
    {% endembed %}

    {# Requirements Table #}
    {% embed '_components/_card.html.twig' with { 'noPadding': true } %}
        {% block card_header %}
            <div class="card-header">
                <h2 class="mb-0">Requirements ({{ requirements|length }})</h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% if requirements is empty %}
                {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'info', class: 'm-3' } } %}
                    {% block alert_body %}
                        No requirements found.
                        {% if selected_framework %}
                            Try selecting a different framework.
                        {% else %}
                            <a href="{{ path('admin_compliance_index') }}" class="fa-alert__link">Load frameworks</a> to get started.
                        {% endif %}
                    {% endblock %}
                {% endembed %}
            {% else %}
                {% embed '_components/_table.html.twig' with {
                    'noMargin': true,
                    'theadClass': 'table-light'
                } %}
                    {% block table_head %}
                        <tr>
                            <th scope="col">{{ 'compliance.requirement.col.id'|trans({}, 'compliance') }}</th>
                            <th scope="col">{{ 'compliance.requirement.col.title'|trans({}, 'compliance') }}</th>
                            <th scope="col">{{ 'compliance.requirement.col.framework'|trans({}, 'compliance') }}</th>
                            <th scope="col">{{ 'compliance.requirement.col.category'|trans({}, 'compliance') }}</th>
                            <th scope="col">{{ 'compliance.requirement.col.priority'|trans({}, 'compliance') }}</th>
                            <th scope="col">{{ 'compliance.requirement.col.fulfillment'|trans({}, 'compliance') }}</th>
                            <th scope="col">{{ 'compliance.requirement.col.applicable'|trans({}, 'compliance') }}</th>
                            <th scope="col">{{ 'common.actions'|trans({}, 'messages') }}</th>
                        </tr>
                    {% endblock %}
                    {% block table_body %}
                        {% for requirement in requirements %}
                            <tr>
                                <td><code>{{ requirement.requirementId }}</code></td>
                                <td>
                                    <a href="{{ path('app_compliance_requirement_show', {id: requirement.id}) }}" class="text-decoration-none">
                                        {{ requirement.title }}
                                    </a>
                                </td>
                                <td>
                                    {% include '_components/_badge.html.twig' with { variant: 'secondary', content: requirement.framework.code } %}
                                </td>
                                <td>{{ requirement.category|default('-') }}</td>
                                <td>
                                    <span class="{{ badge_priority(requirement.priority) }}">{{ requirement.priority }}</span>
                                </td>
                                <td>
                                    {% set fulfillment = fulfillments[requirement.id] %}
                                    <div class="d-flex align-items-center">
                                        <div class="progress flex-grow-1 me-2" style="height: 20px; min-width: 100px;">
                                            <div class="progress-bar {{ badge_completion(fulfillment.fulfillmentPercentage)|replace({'badge ': ''}) }}"
                                                 role="progressbar"
                                                 style="width: {{ fulfillment.fulfillmentPercentage }}%"
                                                 aria-valuenow="{{ fulfillment.fulfillmentPercentage }}"
                                                 aria-valuemin="0"
                                                 aria-valuemax="100">
                                                {{ fulfillment.fulfillmentPercentage }}%
                                            </div>
                                        </div>
                                        <small class="text-muted">{{ fulfillment.status }}</small>
                                    </div>
                                </td>
                                <td>
                                    {% if fulfillment.applicable %}
                                        {% include '_components/_badge.html.twig' with { variant: 'success', content: 'common.yes'|trans({}, 'messages') } %}
                                    {% else %}
                                        {% include '_components/_badge.html.twig' with { variant: 'secondary', content: 'common.no'|trans({}, 'messages') } %}
                                    {% endif %}
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a href="{{ path('app_compliance_requirement_show', {id: requirement.id}) }}"
                                           class="fa-cyber-btn fa-cyber-btn--ghost" title="{{ 'common.view'|trans({}, 'messages') }}" aria-label="{{ 'common.view'|trans({}, 'messages') }}">
                                            <i class="bi bi-eye" aria-hidden="true"></i>
                                        </a>
                                        <a href="{{ path('app_compliance_requirement_edit', {id: requirement.id}) }}"
                                           class="fa-cyber-btn fa-cyber-btn--ghost" title="{{ 'common.edit'|trans({}, 'messages') }}" aria-label="{{ 'common.edit'|trans({}, 'messages') }}">
                                            <i class="bi bi-pencil" aria-hidden="true"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            {% endif %}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
