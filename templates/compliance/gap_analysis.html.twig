{% extends 'base.html.twig' %}
{% trans_default_domain 'compliance' %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}

{% block title %}{{ 'compliance.title.gap_analysis'|trans({}, 'compliance') }} - Little ISMS Helper{% endblock %}

{% block body %}
<div class="page-header">
    <div>
        <h1>{{ 'compliance.title.gap_analysis'|trans({}, 'compliance') }}</h1>
        <p class="text-muted">{{ 'compliance.description.gap_analysis'|trans({}, 'compliance') }}</p>
    </div>
    <div class="button-group">
        <a href="{{ path('app_compliance_export_gaps_pdf', {id: framework.id}) }}" class="fa-cyber-btn fa-cyber-btn--danger" data-turbo="false">
            <i class="fa-icon fa-icon--nav-file-pdf" aria-hidden="true"></i> {{ 'compliance.action.export_pdf'|trans({}, 'compliance') }}
        </a>
        <a href="{{ path('app_compliance_export_gaps_excel', {id: framework.id}) }}" class="fa-cyber-btn fa-cyber-btn--success" data-turbo="false">
            <i class="bi bi-file-excel" aria-hidden="true"></i> {{ 'compliance.action.export_excel'|trans({}, 'compliance') }}
        </a>
        <a href="{{ path('app_compliance_export_gaps', {id: framework.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost" data-turbo="false">
            <i class="bi bi-file-text" aria-hidden="true"></i> {{ 'compliance.action.export_csv'|trans({}, 'compliance') }}
        </a>
    </div>
</div>

{# Statistics Cards #}
<div class="kpi-grid">
    <div class="col-auto">
        {{ _fa_feature_card.render({ label: 'compliance.stats.total_requirements'|trans({}, 'compliance'), value: total_requirements, variant: 'primary' }) }}
    </div>
    <div class="col-auto">
        {{ _fa_feature_card.render({ label: 'compliance.stats.met_requirements'|trans({}, 'compliance'), value: met_requirements, variant: 'success' }) }}
    </div>
    <div class="col-auto">
        {{ _fa_feature_card.render({ label: 'compliance.stats.gaps_identified'|trans({}, 'compliance'), value: total_gaps, variant: 'danger' }) }}
    </div>
    <div class="col-auto">
        {% set score = total_requirements > 0 ? (met_requirements / total_requirements * 100)|round : 0 %}
        {{ _fa_feature_card.render({ label: 'compliance.stats.compliance_score'|trans({}, 'compliance'), value: score ~ '%', variant: 'primary' }) }}
    </div>
</div>

{# Gap Analysis by Severity #}
<div class="module-grid mb-4">
    {% embed '_components/_card.html.twig' with { 'variant': 'bordered', 'borderColor': 'danger' } %}
        {% block card_body %}
            <div class="fs-2-mb-sm"><i class="fa-icon fa-icon--status-warning text-danger" aria-hidden="true"></i></div>
            <h2>{{ 'compliance.severity.critical'|trans({}, 'compliance') }}</h2>
            <div class="mt-2">
                <strong class="fs-15-danger">{{ gaps|filter(g => g.requirement.priority == 'critical')|length }}</strong>
            </div>
            <p class="text-muted-mt-xs">
                {{ 'compliance.description.critical_gaps'|trans({}, 'compliance') }}
            </p>
        {% endblock %}
    {% endembed %}

    {% embed '_components/_card.html.twig' with { 'variant': 'bordered', 'borderColor': 'warning' } %}
        {% block card_body %}
            <div class="fs-2-mb-sm"><i class="bi bi-circle-fill text-warning" aria-hidden="true"></i></div>
            <h2>{{ 'compliance.severity.high'|trans({}, 'compliance') }}</h2>
            <div class="mt-2">
                <strong class="fs-15-warning">{{ gaps|filter(g => g.requirement.priority == 'high')|length }}</strong>
            </div>
            <p class="text-muted-mt-xs">
                {{ 'compliance.description.high_gaps'|trans({}, 'compliance') }}
            </p>
        {% endblock %}
    {% endembed %}

    {% embed '_components/_card.html.twig' with { 'variant': 'bordered', 'borderColor': 'info' } %}
        {% block card_body %}
            <div class="fs-2-mb-sm"><i class="bi bi-circle-fill text-info" aria-hidden="true"></i></div>
            <h2>{{ 'compliance.severity.medium'|trans({}, 'compliance') }}</h2>
            <div class="mt-2">
                <strong class="fs-15-info">{{ gaps|filter(g => g.requirement.priority == 'medium')|length }}</strong>
            </div>
            <p class="text-muted-mt-xs">
                {{ 'compliance.description.medium_gaps'|trans({}, 'compliance') }}
            </p>
        {% endblock %}
    {% endembed %}

    {% embed '_components/_card.html.twig' with { 'variant': 'bordered', 'borderColor': 'secondary' } %}
        {% block card_body %}
            <div class="fs-2-mb-sm"><i class="bi bi-circle text-secondary" aria-hidden="true"></i></div>
            <h2>{{ 'compliance.severity.low'|trans({}, 'compliance') }}</h2>
            <div class="mt-2">
                <strong class="fs-4">{{ gaps|filter(g => g.requirement.priority == 'low')|length }}</strong>
            </div>
            <p class="text-muted-mt-xs">
                {{ 'compliance.description.low_gaps'|trans({}, 'compliance') }}
            </p>
        {% endblock %}
    {% endembed %}
</div>

{# Gaps Table #}
{% embed '_components/_table.html.twig' with {
    'class': 'table-container',
    'noMargin': true,
    'responsive': true
} %}
    {% block table_head %}
        <tr>
            <th scope="col">{{ 'compliance.field.requirement'|trans({}, 'compliance') }}</th>
            <th scope="col">{{ 'compliance.field.framework'|trans({}, 'compliance') }}</th>
            <th scope="col">{{ 'compliance.field.severity'|trans({}, 'compliance') }}</th>
            <th scope="col">{{ 'compliance.field.gap_description'|trans({}, 'compliance') }}</th>
            <th scope="col">{{ 'compliance.field.fulfillment'|trans({}, 'compliance') }}</th>
            <th scope="col" class="text-center">{{ 'common.actions'|trans({}, 'messages') }}</th>
        </tr>
    {% endblock %}
    {% block table_body %}
        {% for gap in gaps %}
        <tr>
            <td>
                <strong>{{ gap.requirement.requirementId }}</strong>
                <br><small class="text-muted">{{ gap.requirement.title }}</small>
            </td>
            <td>
                {% include '_components/_badge.html.twig' with { variant: 'info', content: framework.name } only %}
            </td>
            <td>
                {% set severityColors = {
                    'critical': 'danger',
                    'high': 'warning',
                    'medium': 'info',
                    'low': 'secondary'
                } %}
                {% set priority = gap.requirement.priority ?? 'low' %}
                {% include '_components/_badge.html.twig' with { variant: severityColors[priority] ?? 'secondary', content: ('compliance.severity.' ~ priority)|trans({}, 'compliance') } only %}
            </td>
            <td>
                <small>{{ gap.requirement.description|default('-') }}</small>
            </td>
            <td>
                {% set fulfillment = gap.analysis.calculated_fulfillment ?? 0 %}
                <div class="progress" style="height: 6px;" title="{{ fulfillment }}%">
                    <div class="progress-bar" role="progressbar" style="width: {{ fulfillment }}%" aria-valuenow="{{ fulfillment }}" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                <small class="text-muted">{{ fulfillment }}%</small>
            </td>
            <td class="text-center">
                <a href="{{ path('app_compliance_requirement_show', {id: gap.requirement.id}) }}" class="fa-cyber-btn fa-cyber-btn--sm fa-cyber-btn--ghost">
                    <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i> {{ 'common.view'|trans({}, 'messages') }}
                </a>
            </td>
        </tr>
        {% else %}
        <tr>
            <td colspan="6" class="text-center p-4 text-muted">
                <div class="fs-2 mb-2"><i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i></div>
                <p><strong>{{ 'compliance.message.no_gaps'|trans({}, 'compliance') }}</strong></p>
                <p class="mt-1">{{ 'compliance.message.no_gaps_desc'|trans({}, 'compliance') }}</p>
            </td>
        </tr>
        {% endfor %}
    {% endblock %}
{% endembed %}
{% endblock %}
