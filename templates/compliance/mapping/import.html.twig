{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block title %}{{ 'compliance.mapping.import.title'|trans({}, 'compliance') }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.compliance'|trans({}, 'nav'), url: path('app_compliance_index') },
            { label: 'compliance.mapping.hub.title'|trans({}, 'compliance'), url: path('app_compliance_mapping_hub') },
            { label: 'compliance.mapping.import.title'|trans({}, 'compliance') }
        ]
    } %}

    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="h3 mb-1">
                <i class="bi bi-file-earmark-arrow-up" aria-hidden="true"></i>
                {{ 'compliance.mapping.import.title'|trans({}, 'compliance') }}
            </h1>
            <p class="text-muted mb-0">{{ 'compliance.mapping.import.description'|trans({}, 'compliance') }}</p>
        </div>
    </div>

    {% include '_components/_iso9001_analogy.html.twig' with { variant: 'seeds' } %}

    {# CSV-Spezifikation — 8H.4 migrated #}
    {% embed '_components/_card.html.twig' with { class: 'shadow-sm mb-3' } %}
        {% block card_header %}
            <div class="card-header">
                <strong>{{ 'compliance.mapping.import.spec.title'|trans({}, 'compliance') }}</strong>
            </div>
        {% endblock %}
        {% block card_body %}
            <div class="small">
                <p class="mb-2">{{ 'compliance.mapping.import.spec.intro'|trans({}, 'compliance') }}</p>
                <pre class="bg-body-secondary border p-2 mb-2 rounded small"><code>source_requirement_id,target_requirement_id,mapping_type,mapping_percentage,confidence,bidirectional,rationale
A.5.1,NIS2-21.2.a,full,100,high,true,"Policies"
A.5.15,NIS2-21.2.h,full,100,high,true,"Access Control"</code></pre>
                <ul class="mb-0">
                    <li>{{ 'compliance.mapping.import.spec.required'|trans({}, 'compliance') }}</li>
                    <li>{{ 'compliance.mapping.import.spec.types'|trans({}, 'compliance') }}</li>
                    <li>{{ 'compliance.mapping.import.spec.optional'|trans({}, 'compliance') }}</li>
                    <li>{{ 'compliance.mapping.import.spec.idempotent'|trans({}, 'compliance') }}</li>
                </ul>
            </div>
        {% endblock %}
    {% endembed %}

    {% if error is not null %}
        {{ _fa_alert.render({ variant: 'danger', body: error|trans({}, 'compliance') }) }}
    {% endif %}

    {# Upload-Formular #}
    <form method="post"
          action="{{ path('app_compliance_mapping_import') }}"
          enctype="multipart/form-data"
          class="card fa-section shadow-sm mb-3">
        <input type="hidden" name="_token" value="{{ csrf_token('mapping_import') }}">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-5">
                    <label for="source-framework-code" class="form-label">
                        {{ 'compliance.mapping.import.field.source'|trans({}, 'compliance') }}
                    </label>
                    <select id="source-framework-code" name="source_framework_code" class="form-select" required>
                        <option value="">—</option>
                        {% for fw in frameworks %}
                            <option value="{{ fw.code }}" {% if fw.code == source_code %}selected{% endif %}>
                                {{ fw.code }} — {{ fw.name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-5">
                    <label for="target-framework-code" class="form-label">
                        {{ 'compliance.mapping.import.field.target'|trans({}, 'compliance') }}
                    </label>
                    <select id="target-framework-code" name="target_framework_code" class="form-select" required>
                        <option value="">—</option>
                        {% for fw in frameworks %}
                            <option value="{{ fw.code }}" {% if fw.code == target_code %}selected{% endif %}>
                                {{ fw.code }} — {{ fw.name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <div class="w-100 small text-muted">
                        {{ 'compliance.mapping.import.field.pair_hint'|trans({}, 'compliance') }}
                    </div>
                </div>
            </div>

            <div class="row g-3 mt-2">
                <div class="col-md-8">
                    <label for="csv-file" class="form-label">
                        {{ 'compliance.mapping.import.field.file'|trans({}, 'compliance') }}
                    </label>
                    <input type="file" id="csv-file" name="csv_file" class="form-control" accept=".csv,text/csv" required>
                    <div class="form-text">
                        {{ 'compliance.mapping.import.field.file_hint'|trans({}, 'compliance') }}
                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer d-flex gap-2 justify-content-between">
            <a href="{{ path('app_compliance_mapping_hub') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                {{ 'common.cancel'|trans({}, 'messages') }}
            </a>
            <div class="d-flex gap-2">
                <button type="submit" name="commit" value="0" class="fa-cyber-btn fa-cyber-btn--ghost">
                    <i class="bi bi-eye" aria-hidden="true"></i>
                    {{ 'compliance.mapping.import.action.preview'|trans({}, 'compliance') }}
                </button>
                <button type="submit" name="commit" value="1" class="fa-cyber-btn fa-cyber-btn--primary">
                    <i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i>
                    {{ 'compliance.mapping.import.action.commit'|trans({}, 'compliance') }}
                </button>
            </div>
        </div>
    </form>

    {# Ergebnis-Block — 8H.4 migrated #}
    {% if result is not null %}
        {% embed '_components/_card.html.twig' with { class: 'shadow-sm' } %}
            {% block card_header %}
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>
                        {% if was_commit %}
                            <i class="bi bi-check2-circle text-success" aria-hidden="true"></i>
                            {{ 'compliance.mapping.import.result.committed'|trans({}, 'compliance') }}
                        {% else %}
                            <i class="bi bi-eye text-primary" aria-hidden="true"></i>
                            {{ 'compliance.mapping.import.result.preview'|trans({}, 'compliance') }}
                        {% endif %}
                    </strong>
                    <span class="small text-muted">
                        {{ source_code }} → {{ target_code }}
                    </span>
                </div>
            {% endblock %}
            {% block card_body %}
                <div class="row g-2 mb-3">
                    <div class="col-6 col-md-3">
                        <div class="border rounded p-2 text-center">
                            <div class="small text-muted">{{ 'compliance.mapping.import.result.processed'|trans({}, 'compliance') }}</div>
                            <div class="h4 mb-0">{{ result.processed }}</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="border rounded p-2 text-center border-success">
                            <div class="small text-muted">{{ 'compliance.mapping.import.result.created'|trans({}, 'compliance') }}</div>
                            <div class="h4 mb-0 text-success">{{ result.created }}</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="border rounded p-2 text-center">
                            <div class="small text-muted">{{ 'compliance.mapping.import.result.skipped_existing'|trans({}, 'compliance') }}</div>
                            <div class="h4 mb-0">{{ result.skipped_existing }}</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="border rounded p-2 text-center {% if result.skipped_missing > 0 %}border-warning{% endif %}">
                            <div class="small text-muted">{{ 'compliance.mapping.import.result.skipped_missing'|trans({}, 'compliance') }}</div>
                            <div class="h4 mb-0 {% if result.skipped_missing > 0 %}text-warning{% endif %}">{{ result.skipped_missing }}</div>
                        </div>
                    </div>
                </div>

                {% if result.errors|length > 0 %}
                    <h3 class="h6 text-danger">
                        {{ 'compliance.mapping.import.result.errors_heading'|trans({'%count%': result.errors|length}, 'compliance') }}
                    </h3>
                    <ul class="small mb-3">
                        {% for err in result.errors %}
                            <li><strong>Row {{ err.row }}:</strong> {{ err.message }}</li>
                        {% endfor %}
                    </ul>
                {% endif %}

                {% if result.warnings|length > 0 %}
                    <h3 class="h6 text-warning">
                        {{ 'compliance.mapping.import.result.warnings_heading'|trans({'%count%': result.warnings|length}, 'compliance') }}
                    </h3>
                    <div class="table-responsive" style="max-height: 300px;">
                        <table class="table table-sm table-striped small mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Row</th>
                                    <th>Source</th>
                                    <th>Target</th>
                                    <th>Reason</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for w in result.warnings %}
                                    <tr>
                                        <td>{{ w.row }}</td>
                                        <td><code>{{ w.source }}</code></td>
                                        <td><code>{{ w.target }}</code></td>
                                        <td>{{ w.reason }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}

                {% if not was_commit and result.created > 0 and result.errors|length == 0 %}
                    {{ _fa_alert.render({ variant: 'info', class: 'small mt-3 mb-0', body: 'compliance.mapping.import.result.preview_ok_hint'|trans({}, 'compliance') }) }}
                {% endif %}
            {% endblock %}
        {% endembed %}
    {% endif %}
</div>
{% endblock %}
