{% extends 'base.html.twig' %}
{% trans_default_domain 'compliance' %}

{% block title %}Compliance Mappings{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.compliance'|trans({}, 'nav'), url: path('app_compliance_index') },
            { label: 'compliance.mapping.title'|trans({}, 'compliance') }
        ]
    } %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="fa-icon fa-icon--nav-workflow" aria-hidden="true"></i> Compliance Mappings</h1>
        <div class="d-flex gap-2">
            <a href="{{ path('app_compliance_mapping_hub') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                <i class="fa-icon fa-icon--util-arrow-left" aria-hidden="true"></i>
                {{ 'compliance.mapping.hub.title'|trans({}, 'compliance') }}
            </a>
            <a href="{{ path('app_compliance_mapping_seeds_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                <i class="fa-icon fa-icon--threat" aria-hidden="true"></i>
                {{ 'compliance.mapping.seeds.title'|trans({}, 'compliance')|split('—')|first|trim }}
            </a>
            <a href="{{ path('app_compliance_mapping_wizard') }}" class="fa-cyber-btn fa-cyber-btn--primary">
                <i class="fa-icon fa-icon--nav-magic" aria-hidden="true"></i>
                {{ 'compliance.mapping.wizard.title'|trans({}, 'compliance') }}
            </a>
            <a href="{{ path('app_compliance_mapping_new') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                <i class="fa-icon fa-icon--ui-plus" aria-hidden="true"></i> New Mapping
            </a>
        </div>
    </div>

    {% include '_components/_iso9001_analogy.html.twig' with { variant: 'mapping' } %}

    {% embed '_components/_card.html.twig' with { 'noPadding': true } %}
        {% block card_header %}
            <div class="card-header">
                <h2 class="mb-0">Cross-Framework Mappings ({{ mappings|length }})</h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% if mappings is empty %}
                <div class="p-4">
                    {% include '_components/_empty_state.html.twig' with {
                        icon: 'bi-diagram-2',
                        title: 'compliance.mapping.empty.title'|trans({}, 'compliance'),
                        description: 'compliance.mapping.empty.description'|trans({}, 'compliance'),
                        action: {
                            label: 'compliance.mapping.empty.action_wizard'|trans({}, 'compliance'),
                            url: path('app_compliance_mapping_wizard'),
                            icon: 'bi-magic'
                        }
                    } %}
                    <div class="text-center mt-3">
                        <a href="{{ path('app_compliance_mapping_seeds_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                            <i class="fa-icon fa-icon--threat" aria-hidden="true"></i>
                            {{ 'compliance.mapping.empty.action_seeds'|trans({}, 'compliance') }}
                        </a>
                    </div>
                </div>
            {% else %}
            {% embed '_components/_table.html.twig' with {
                'class': 'table-hover',
                'theadClass': 'table-light',
                'noMargin': true
            } %}
                {% block table_head %}
                    <tr>
                        <th scope="col">Source</th>
                        <th scope="col">Target</th>
                        <th scope="col">Type</th>
                        <th scope="col">Percentage</th>
                        <th scope="col">Confidence</th>
                        <th scope="col">Review Status</th>
                        <th scope="col">Actions</th>
                    </tr>
                {% endblock %}
                {% block table_body %}
                    {% for mapping in mappings %}
                        <tr>
                            <td>
                                <small class="text-muted">{{ mapping.sourceRequirement.framework.code }}</small><br>
                                <strong>{{ mapping.sourceRequirement.requirementId }}</strong>
                            </td>
                            <td>
                                <small class="text-muted">{{ mapping.targetRequirement.framework.code }}</small><br>
                                <strong>{{ mapping.targetRequirement.requirementId }}</strong>
                            </td>
                            <td>
                                {% include '_components/_badge.html.twig' with { variant: mapping.mappingBadgeClass, content: mapping.mappingType } %}
                            </td>
                            <td>
                                <div class="progress" style="width: 100px; height: 20px;">
                                    <div class="progress-bar bg-{{ mapping.mappingBadgeClass }}"
                                         role="progressbar"
                                         style="width: {{ mapping.finalPercentage }}%">
                                        {{ mapping.finalPercentage }}%
                                    </div>
                                </div>
                            </td>
                            <td>
                                {% include '_components/_badge.html.twig' with { variant: 'secondary', content: mapping.confidence } %}
                            </td>
                            <td>
                                {% include '_components/_badge.html.twig' with { variant: mapping.reviewStatusBadgeClass, content: mapping.reviewStatus } %}
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group" aria-label="{{ 'common.actions'|trans({}, 'messages') }}">
                                    <a href="{{ path('app_compliance_mapping_show', {id: mapping.id}) }}"
                                       class="fa-cyber-btn fa-cyber-btn--ghost" title="{{ 'common.view'|trans({}, 'messages') }}" aria-label="{{ 'common.view'|trans({}, 'messages') }}">
                                        <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
                                    </a>
                                    <a href="{{ path('app_compliance_mapping_edit', {id: mapping.id}) }}"
                                       class="fa-cyber-btn fa-cyber-btn--ghost" title="{{ 'common.edit'|trans({}, 'messages') }}" aria-label="{{ 'common.edit'|trans({}, 'messages') }}">
                                        <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                {% endblock %}
            {% endembed %}
            {% endif %}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
