{#
   Shared certificate field set — reused by new.html.twig (manual upload) and
   confirm_draft.html.twig (OCR draft review). DRY: a single source of truth for
   field markup, labels and name attributes so the manual and OCR paths can
   never drift apart.

   Params:
     frameworks  : iterable of ComplianceFramework (for the framework <select>)
     certificate : ComplianceCertificate|null — when set, fields are pre-filled
                   (OCR draft confirm flow). Null on the empty manual form.
#}
{% set c = certificate|default(null) %}

<div class="mb-3">
    <label for="cert_framework" class="form-label">{{ 'compliance.certificate.field.framework'|trans({}, 'compliance') }}</label>
    <select id="cert_framework" name="frameworkCode" class="form-select" required>
        <option value="">{{ 'compliance.certificate.new.select_framework'|trans({}, 'compliance') }}</option>
        {% for fw in frameworks %}
            <option value="{{ fw.code }}"{{ c and c.frameworkCode == fw.code ? ' selected' : '' }}>{{ fw.name }} ({{ fw.code }})</option>
        {% endfor %}
    </select>
</div>

<div class="mb-3">
    <label for="cert_body" class="form-label">{{ 'compliance.certificate.field.cert_body'|trans({}, 'compliance') }}</label>
    <input type="text" id="cert_body" name="certBody" class="form-control" value="{{ c ? c.certBody : '' }}" required>
</div>

<div class="mb-3">
    <label for="cert_number" class="form-label">{{ 'compliance.certificate.field.cert_number'|trans({}, 'compliance') }}</label>
    <input type="text" id="cert_number" name="certNumber" class="form-control" value="{{ c ? c.certNumber : '' }}">
</div>

<div class="mb-3">
    <label for="cert_holder" class="form-label">{{ 'compliance.certificate.field.holder'|trans({}, 'compliance') }}</label>
    <input type="text" id="cert_holder" name="holder" class="form-control" value="{{ c ? c.holder : '' }}">
</div>

<div class="mb-3">
    <label for="cert_class" class="form-label">{{ 'compliance.certificate.field.cert_class'|trans({}, 'compliance') }}</label>
    <input type="text" id="cert_class" name="certClass" class="form-control" value="{{ c ? c.certClass : '' }}">
</div>

<div class="mb-3">
    <label for="cert_scope_tags" class="form-label">{{ 'compliance.certificate.field.scope_tags'|trans({}, 'compliance') }}</label>
    <input type="text" id="cert_scope_tags" name="scopeTags" class="form-control"
           value="{{ c and c.scopeTags ? c.scopeTags|join(', ') : '' }}"
           placeholder="{{ 'compliance.certificate.new.scope_tags_hint'|trans({}, 'compliance') }}">
</div>

<div class="mb-3">
    <label for="cert_scope_text" class="form-label">{{ 'compliance.certificate.field.scope_text'|trans({}, 'compliance') }}</label>
    <textarea id="cert_scope_text" name="scopeText" class="form-control" rows="3">{{ c ? c.scopeText : '' }}</textarea>
</div>

<div class="row">
    <div class="col-md-6 mb-3">
        <label for="cert_issue_date" class="form-label">{{ 'compliance.certificate.field.issue_date'|trans({}, 'compliance') }}</label>
        <input type="date" id="cert_issue_date" name="issueDate" class="form-control" value="{{ c and c.issueDate ? c.issueDate|date('Y-m-d') : '' }}">
    </div>
    <div class="col-md-6 mb-3">
        <label for="cert_valid_until" class="form-label">{{ 'compliance.certificate.field.valid_until'|trans({}, 'compliance') }}</label>
        <input type="date" id="cert_valid_until" name="validUntil" class="form-control" value="{{ c and c.validUntil ? c.validUntil|date('Y-m-d') : '' }}">
    </div>
</div>
