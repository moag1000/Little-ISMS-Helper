{% extends 'base.html.twig' %}
{% trans_default_domain 'compliance' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}
{% import '_components/_fa_tabs.html.twig' as _fa_tabs %}

{% block title %}{{ 'compliance.title.transitive'|trans({}, 'compliance') }} - Little ISMS Helper{% endblock %}

{% block body %}
{{ _fa_page_header.render({
    badge: { icon: 'compliance-shield', label: 'nav.compliance'|trans({}, 'nav') },
    title: 'compliance.title.transitive'|trans({}, 'compliance'),
    subtitle: 'compliance.description.transitive'|trans({}, 'compliance'),
    actions: [
        { label: 'common.back'|trans({}, 'messages'), variant: 'ghost', icon: 'util-arrow-left', href: path('app_compliance_index') },
        { label: 'compliance.action.export_pdf'|trans({}, 'compliance'), variant: 'danger', icon: 'nav-file-pdf', href: path('app_compliance_export_transitive_pdf'), attrs: {'data-turbo': 'false'} },
        { label: 'compliance.action.export_excel'|trans({}, 'compliance'), variant: 'secondary', icon: 'nav-file-check', href: path('app_compliance_export_transitive_excel'), attrs: {'data-turbo': 'false'} },
        { label: 'compliance.action.export_csv'|trans({}, 'compliance'), variant: 'ghost', icon: 'nav-document', href: path('app_compliance_export_transitive'), attrs: {'data-turbo': 'false'} }
    ]
}) }}
{# JS action button + PDF locale switch (not supported by macro actions array) #}
<div class="d-flex justify-content-end gap-2 mb-3">
    <button id="createAllMappingsBtn" class="fa-cyber-btn fa-cyber-btn--primary">
        🔗 {{ 'compliance.action.create_missing_mappings'|trans({}, 'compliance') }}
    </button>
    {% include '_components/_fa_pdf_locale_switch.html.twig' with {route: 'app_compliance_export_transitive_pdf'} only %}
</div>

{# Statistics Cards - Prominently displayed #}
<div class="kpi-grid mb-2">
    <div class="col-auto">
        {{ _fa_feature_card.render({ label: 'compliance.stats.total_relationships'|trans({}, 'compliance'), value: total_relationships, variant: 'primary' }) }}
    </div>
    <div class="col-auto">
        {{ _fa_feature_card.render({ label: 'compliance.stats.transitive_compliance'|trans({}, 'compliance'), value: transitive_compliance, variant: 'success' }) }}
    </div>
    <div class="col-auto">
        {% set leverageRate = total_relationships > 0 ? (transitive_compliance / total_relationships * 100)|round : 0 %}
        {{ _fa_feature_card.render({ label: 'compliance.stats.leverage_rate'|trans({}, 'compliance'), value: leverageRate ~ '%', variant: 'info' }) }}
    </div>
    <div class="col-auto">
        {{ _fa_feature_card.render({ label: 'compliance.stats.frameworks_leveraged'|trans({}, 'compliance'), value: frameworks_leveraged, variant: 'warning' }) }}
    </div>
</div>

{# Tabbed Interface — _fa_tabs macro with new Stimulus targets #}
{{ _fa_tabs.render({
    id: 'transitive',
    initialTab: 'overview',
    urlHashSync: true,
    tabs: [
        {
            id: 'overview',
            label: '📊 ' ~ 'compliance.tab.overview'|trans({}, 'compliance'),
            body: include('compliance/_tab_transitive_overview.html.twig'),
        },
        {
            id: 'matrix',
            label: 'compliance.tab.matrix'|trans({}, 'compliance'),
            icon: 'heatmap',
            body: include('compliance/_tab_transitive_matrix.html.twig'),
        },
        {
            id: 'details',
            label: 'compliance.tab.details'|trans({}, 'compliance'),
            icon: 'nav-list-check',
            body: include('compliance/_tab_transitive_details.html.twig'),
        },
        {
            id: 'info',
            label: 'compliance.tab.explanation'|trans({}, 'compliance'),
            icon: 'ui-lightbulb',
            body: include('compliance/_tab_transitive_info.html.twig'),
        },
    ],
}) }}

<script>
// Turbo re-eval guard: IIFE prevents re-declare crash on body-swap navigation
(function () {
// Create Cross-Framework Mappings
function initializeMappingButton() {
    const createBtn = document.getElementById('createMappingsBtn');

    if (!createBtn) {
        return;
    }

    // Check if already initialized to prevent duplicate listeners
    if (createBtn.dataset.initialized === 'true') {
        return;
    }

    createBtn.dataset.initialized = 'true';

    const btnIcon = document.getElementById('btnIcon');
    const btnText = document.getElementById('btnText');
    const csrfToken = '{{ csrf_token('create_mappings') }}';

    createBtn.addEventListener('click', async function(e) {
        e.preventDefault();

        // Confirm action
        if (!await window.faConfirm('{{ 'compliance.confirm.create_mappings'|trans({}, 'compliance') }}')) {
            return;
        }

        // Disable button and show loading
        createBtn.disabled = true;
        btnIcon.textContent = '⏳';
        btnText.textContent = '{{ 'compliance.mapping_status.creating'|trans({}, 'compliance') }}';
        createBtn.style.opacity = '0.7';
        createBtn.style.cursor = 'not-allowed';

        try {
            const url = '{{ path('app_compliance_create_mappings') }}';

            const response = await fetch(url, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'X-CSRF-Token': csrfToken,
                    'Content-Type': 'application/json'
                }
            });

            const data = await response.json();

            if (data.success) {
                btnIcon.textContent = '✅';
                btnText.textContent = data.message;
                createBtn.style.background = 'var(--success)';
                createBtn.style.color = 'white';

                setTimeout(() => {
                    window.location.reload();
                }, 2000);
            } else {
                btnIcon.textContent = '❌';
                btnText.textContent = data.message || '{{ 'compliance.mapping_error.creating'|trans({}, 'compliance') }}';
                createBtn.style.background = 'var(--danger)';
                createBtn.style.color = 'white';

                setTimeout(() => {
                    btnIcon.textContent = '🔗';
                    btnText.textContent = '{{ 'compliance.action.create_mappings_now'|trans({}, 'compliance') }}';
                    createBtn.style.background = 'var(--surface)';
                    createBtn.style.color = 'var(--accent)';
                    createBtn.style.opacity = '1';
                    createBtn.style.cursor = 'pointer';
                    createBtn.disabled = false;
                }, 5000);
            }
        } catch (error) {
            btnIcon.textContent = '❌';
            btnText.textContent = '{{ 'common.error'|trans({}, 'messages') }}: ' + error.message;
            createBtn.style.background = 'var(--danger)';
            createBtn.style.color = 'var(--on-danger)';

            setTimeout(() => {
                btnIcon.textContent = '🔗';
                btnText.textContent = '{{ 'compliance.action.create_mappings_now'|trans({}, 'compliance') }}';
                createBtn.style.background = 'var(--surface)';
                createBtn.style.color = 'var(--accent)';
                createBtn.style.opacity = '1';
                createBtn.style.cursor = 'pointer';
                createBtn.disabled = false;
            }, 5000);
        }
    });
}

// Cleanup before Turbo caches the page to allow re-initialization on back navigation
document.addEventListener('turbo:before-cache', function() {
    const createBtn = document.getElementById('createMappingsBtn');
    if (createBtn) {
        delete createBtn.dataset.initialized;
    }
});

// Initialize on both DOMContentLoaded (first page load) and turbo:load (Turbo navigation)
document.addEventListener('DOMContentLoaded', initializeMappingButton);
document.addEventListener('turbo:load', initializeMappingButton);

// Handler for the "Fehlende Mappings ergänzen" button in the header
function initializeHeaderMappingButton() {
    const createAllMappingsBtn = document.getElementById('createAllMappingsBtn');

    if (!createAllMappingsBtn) {
        return;
    }

    // Prevent multiple initializations
    if (createAllMappingsBtn.dataset.headerInitialized === 'true') {
        return;
    }

    createAllMappingsBtn.dataset.headerInitialized = 'true';

    createAllMappingsBtn.addEventListener('click', async function() {
        const originalText = this.textContent;

        // Confirm action
        if (!await window.faConfirm('{{ 'compliance.confirm.add_missing_mappings'|trans({}, 'compliance') }}')) {
            return;
        }

        // Disable button and show loading
        createAllMappingsBtn.disabled = true;
        createAllMappingsBtn.style.opacity = '0.7';

        const csrfToken = '{{ csrf_token('create_mappings') }}';
        const url = '{{ path('app_compliance_create_mappings') }}';

        let currentBatch = 0;
        let totalCreated = 0;
        let totalSkipped = 0;

        // Recursive function to process batches
        async function processBatch() {
            try {
                createAllMappingsBtn.textContent = `⏳ Batch ${currentBatch + 1}...`;

                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'X-CSRF-Token': csrfToken,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        batch: currentBatch,
                        batch_size: 50
                    })
                });

                const data = await response.json();

                if (!data.success) {
                    throw new Error(data.message || '{{ 'common.error.unknown'|trans({}, 'messages') }}');
                }

                totalCreated += data.mappings_created || 0;
                totalSkipped += data.mappings_skipped || 0;

                // Show progress
                if (data.progress) {
                    createAllMappingsBtn.textContent = `⏳ ${data.progress.percent}% (${data.progress.processed}/${data.progress.total})`;
                }

                // Continue with next batch if there's more
                if (data.has_more) {
                    currentBatch = data.next_batch;
                    // Small delay to prevent overwhelming the server
                    await new Promise(resolve => setTimeout(resolve, 100));
                    return processBatch();
                } else {
                    // All done!
                    const message = `✅ ${totalCreated} {{ 'compliance.mapping_status.new_created'|trans({}, 'compliance') }}`;
                    createAllMappingsBtn.textContent = message;
                    createAllMappingsBtn.style.background = 'var(--success)';
                    createAllMappingsBtn.style.color = 'white';

                    // Reload page after 2 seconds
                    setTimeout(() => {
                        window.location.reload();
                    }, 2000);
                }
            } catch (error) {
                window.faToast('{{ 'compliance.mapping_error.creating'|trans({}, 'compliance') }}: ' + error.message, 'danger');
                createAllMappingsBtn.disabled = false;
                createAllMappingsBtn.textContent = originalText;
                createAllMappingsBtn.style.opacity = '1';
            }
        }

        // Start processing
        await processBatch();
    });
}

document.addEventListener('DOMContentLoaded', initializeHeaderMappingButton);
document.addEventListener('turbo:load', initializeHeaderMappingButton);
})();
</script>
{% endblock %}
