{# Single location table row — shared by the index list and the Turbo Stream
   that replaces/appends a row after an in-drawer save. #}
{% trans_default_domain 'locations' %}
{% set securityColors = {
    'public': 'secondary',
    'restricted': 'info',
    'controlled': 'warning',
    'secure': 'warning',
    'high_security': 'danger'
} %}
<tr id="location-row-{{ location.id }}">
    <td>
        <a href="{{ path('app_location_show', {id: location.id}) }}"
           data-turbo-frame="fa-drawer" class="fa-row-link">
            <strong>{{ location.name }}</strong>
        </a>
        {% if location.parentLocation %}
            <br><small class="text-muted-color">↳ {{ location.parentLocation.name }}</small>
        {% endif %}
    </td>
    <td>
        {% include '_components/_badge.html.twig' with { variant: 'info', content: ('location.type.' ~ location.locationType)|trans({}, 'locations') } %}
    </td>
    <td>
        {% if location.code %}<code>{{ location.code }}</code>{% else %}<span class="text-muted-color">-</span>{% endif %}
    </td>
    <td>
        {{ location.city ?? '-' }}
        {% if location.country %}<br><small class="text-muted-color">{{ location.country }}</small>{% endif %}
    </td>
    <td>
        {% include '_components/_badge.html.twig' with { variant: securityColors[location.securityLevel] ?? 'secondary', content: ('location.security.' ~ location.securityLevel)|trans({}, 'locations') } %}
    </td>
    <td class="text-center">
        {% if location.requiresBadgeAccess %}
            {% include '_components/_badge.html.twig' with { variant: 'success', content: '✓' } %}
        {% else %}
            {% include '_components/_badge.html.twig' with { variant: 'secondary', content: '✗' } %}
        {% endif %}
    </td>
    <td class="text-center">
        <div class="btn-group btn-group-sm" role="group" aria-label="{{ 'location.actions.label'|trans({}, 'locations') }}">
            <a href="{{ path('app_location_show', {id: location.id}) }}" data-turbo-frame="fa-drawer"
               class="fa-cyber-btn fa-cyber-btn--ghost" aria-label="{{ 'common.view'|trans({}, 'messages') }} {{ location.name }}">
                <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
            </a>
            {% if is_granted('ROLE_USER') %}
            <a href="{{ path('app_location_edit', {id: location.id}) }}" data-turbo-frame="fa-drawer"
               class="fa-cyber-btn fa-cyber-btn--ghost" aria-label="{{ 'common.edit'|trans({}, 'messages') }} {{ location.name }}">
                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
            </a>
            {% endif %}
        </div>
    </td>
</tr>
