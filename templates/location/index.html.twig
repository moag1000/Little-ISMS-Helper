{% extends 'base.html.twig' %}
{% trans_default_domain 'locations' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'location.title.list'|trans({}, 'locations') }} - Little ISMS Helper{% endblock %}

{% block body %}
{% import '_macros/cards.html.twig' as cards %}

<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.locations'|trans({}, 'nav') }
        ]
    } %}
</div>

{{ _fa_page_header.render({
    badge: { icon: 'geo-alt', label: 'nav.locations'|trans({}, 'nav') },
    title: 'location.title.list'|trans({}, 'locations'),
    subtitle: 'location.description.overview'|trans({}, 'locations'),
    actions: [
        { label: 'location.action.create'|trans({}, 'locations'), variant: 'primary', icon: 'plus-circle', href: path('app_location_new') }
    ]
}) }}

<main class="fa-aurora-surface">

{# Statistics Cards #}
<div class="kpi-grid">
    <div class="col-auto">
        {{ cards.kpi_card('location.stats.total'|trans({}, 'locations'), locations|length, null, null, null, null) }}
    </div>
    <div class="col-auto">
        {{ cards.kpi_card('location.stats.buildings'|trans({}, 'locations'), locations|filter(l => l.locationType == 'building')|length, null, null, 'primary', null) }}
    </div>
    <div class="col-auto">
        {{ cards.kpi_card('location.stats.rooms'|trans({}, 'locations'), locations|filter(l => l.locationType == 'room')|length, null, null, 'info', null) }}
    </div>
    <div class="col-auto">
        {{ cards.kpi_card('location.stats.secure'|trans({}, 'locations'), locations|filter(l => l.requiresBadgeAccess)|length, null, null, 'success', null) }}
    </div>
</div>

{# Locations Table #}
{% embed '_components/_table.html.twig' with {
    'wrapperClass': 'table-container'
} %}
    {% block table_head %}
        <tr>
            <th scope="col">{{ 'location.field.name'|trans({}, 'locations') }}</th>
            <th scope="col">{{ 'location.field.type'|trans({}, 'locations') }}</th>
            <th scope="col">{{ 'location.field.code'|trans({}, 'locations') }}</th>
            <th scope="col">{{ 'location.field.city'|trans({}, 'locations') }}</th>
            <th scope="col">{{ 'location.field.security_level'|trans({}, 'locations') }}</th>
            <th scope="col" class="text-center">{{ 'location.field.badge_access'|trans({}, 'locations') }}</th>
            <th scope="col" class="text-center">{{ 'common.actions'|trans({}, 'messages') }}</th>
        </tr>
    {% endblock %}
    {% block table_body %}
        {% for location in locations %}
        <tr>
            <td>
                <strong>{{ location.name }}</strong>
                {% if location.parentLocation %}
                    <br><small class="text-muted-color">↳ {{ location.parentLocation.name }}</small>
                {% endif %}
            </td>
            <td>
                {% include '_components/_badge.html.twig' with { variant: 'info', content: ('location.type.' ~ location.locationType)|trans({}, 'locations') } %}
            </td>
            <td>
                {% if location.code %}
                    <code>{{ location.code }}</code>
                {% else %}
                    <span class="text-muted-color">-</span>
                {% endif %}
            </td>
            <td>
                {{ location.city ?? '-' }}
                {% if location.country %}
                    <br><small class="text-muted-color">{{ location.country }}</small>
                {% endif %}
            </td>
            <td>
                {% set securityColors = {
                    'public': 'secondary',
                    'restricted': 'info',
                    'controlled': 'warning',
                    'secure': 'warning',
                    'high_security': 'danger'
                } %}
                {% include '_components/_badge.html.twig' with { variant: securityColors[location.securityLevel] ?? 'secondary', content: ('location.security.' ~ location.securityLevel)|trans({}, 'locations') } %}
            </td>
            <td class="text-center">
                {% if location.requiresBadgeAccess %}
                    {% include '_components/_badge.html.twig' with { variant: 'success', content: '✓' } %}
                {% else %}
                    {% include '_components/_badge.html.twig' with { variant: 'secondary', content: '✗' } %}
                {% endif %}
            </td>
            <td class="text-center">
                <div class="btn-group btn-group-sm" role="group" aria-label="{{ 'location.actions.label'|trans({}, 'locations') }}">
                    <a href="{{ path('app_location_show', {id: location.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost" aria-label="{{ 'common.view'|trans({}, 'messages') }} {{ location.name }}">
                        <i class="bi bi-eye" aria-hidden="true"></i>
                    </a>
                    <a href="{{ path('app_location_edit', {id: location.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost" aria-label="{{ 'common.edit'|trans({}, 'messages') }} {{ location.name }}">
                        <i class="bi bi-pencil" aria-hidden="true"></i>
                    </a>
                </div>
            </td>
        </tr>
        {% else %}
        <tr>
            <td colspan="7" class="text-center-p-xl-muted">
                {{ 'location.message.no_locations'|trans({}, 'locations') }}
            </td>
        </tr>
        {% endfor %}
    {% endblock %}
{% endembed %}
</main>
{% endblock %}
