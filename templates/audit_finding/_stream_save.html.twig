{# Turbo Stream after a successful in-modal AuditFinding save. #}
{% if is_new %}
    <turbo-stream action="append" target="audit-finding-rows">
        <template>{% include 'audit_finding/_row.html.twig' with { finding: finding } %}</template>
    </turbo-stream>
{% else %}
    <turbo-stream action="replace" target="audit-finding-row-{{ finding.id }}">
        <template>{% include 'audit_finding/_row.html.twig' with { finding: finding } %}</template>
    </turbo-stream>
{% endif %}
