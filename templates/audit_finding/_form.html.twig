{% import '_components/_fa_severity_choice.html.twig' as _fa_severity_choice %}
{% import '_components/_fa_severity_legend.html.twig' as _fa_severity_legend %}
{% import '_components/_fa_norm_bridge.html.twig' as _fa_norm_bridge %}

{# Junior-ISB-Audit P-12 — 9001-bridge for AuditFinding form (Major-NC equivalence). #}
{{ _fa_norm_bridge.render({
    from_norm: 'ISO 27001 Cl. 10.1',
    to_norm:   'ISO 9001 Cl. 10.2',
    bridge_text: ('iso_9001_bridge.major_nc'|trans({}, 'audits')),
    prominence: 'subtle'
}) }}

{{ form_start(form) }}
    <div class="row g-3">
        <div class="col-md-6">{{ form_row(form.audit) }}</div>
        <div class="col-md-6">{{ form_row(form.findingNumber) }}</div>
        <div class="col-12">{{ form_row(form.title) }}</div>
        <div class="col-12">{{ form_row(form.description) }}</div>
        <div class="col-md-4">{{ form_row(form.type) }}</div>
        <div class="col-md-12">
            {{ form_label(form.severity) }}
            {{ _fa_severity_choice.render({
                name: form.severity.vars.full_name,
                selected: form.severity.vars.value,
                translation_prefix: 'audit_finding',
                translation_domain: 'audits',
                required: form.severity.vars.required,
            }) }}
            {{ form_errors(form.severity) }}
            {% do form.severity.setRendered %}
            {{ _fa_severity_legend.render({
                translation_prefix: 'audit_finding',
                translation_domain: 'audits',
            }) }}
        </div>
        <div class="col-md-4">{{ form_row(form.status) }}</div>
        <div class="col-md-4">{{ form_row(form.source) }}</div>
        <div class="col-md-6">{{ form_row(form.clauseReference) }}</div>
        <div class="col-12">{{ form_row(form.relatedControls) }}</div>
        <div class="col-12">{{ form_row(form.evidence) }}</div>
        <div class="col-md-6">{{ form_row(form.assignedTo) }}</div>
        <div class="col-md-6">{{ form_row(form.dueDate) }}</div>
        <div class="col-md-6">{{ form_row(form.assignedPerson) }}</div>
        <div class="col-12">{{ form_row(form.assignedDeputyPersons) }}</div>
        <div class="col-md-6">{{ form_row(form.reportedByPerson) }}</div>
        <div class="col-12">{{ form_row(form.reportedByDeputyPersons) }}</div>
        <div class="col-12">{{ form_row(form.linkedRequirements) }}</div>
    </div>

    {# S17 B4 — CAPA / Nonconformity-Details (ISO 27001 Cl. 10.2 b) + d)). #}
    <fieldset class="mt-4">
        <legend class="h6">{{ 'audit_finding.section.nc_capa'|trans({}, 'audits') }}</legend>
        <div class="row g-3">
            <div class="col-12">{{ form_row(form.ncRootCauseSummary) }}</div>
            <div class="col-md-4">{{ form_row(form.ncCorrectionDueDate) }}</div>
            <div class="col-md-4">{{ form_row(form.ncVerifiedAt) }}</div>
            <div class="col-md-4">{{ form_row(form.ncVerifiedBy) }}</div>
        </div>
        {# Structured CAPA JSON-Builder is exclusive to the Aurora new/edit
           templates; this legacy `_form.html.twig` partial is unused but kept
           for parity. Mark the JSON field as rendered so Gate `form_render_completeness`
           stays green. #}
        {% do form.nonconformityDetails.setRendered %}
    </fieldset>

    <div class="mt-4">
        <button type="submit" class="fa-cyber-btn fa-cyber-btn--primary">
            <i class="fa-icon fa-icon--ui-save" aria-hidden="true"></i> {{ 'common.save'|trans({}, 'messages') }}
        </button>
        <a href="{{ path('app_audit_finding_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
            {{ 'common.cancel'|trans({}, 'messages') }}
        </a>
    </div>
{{ form_end(form) }}
