{% extends 'base.html.twig' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_filter_chip.html.twig' as _fa_filter_chip %}
{% import '_components/_fa_status_chip.html.twig' as _fa_status_chip %}
{% import '_components/_lifecycle_actions.html.twig' as _lifecycle_actions %}
{% import '_components/_lifecycle_history_tab.html.twig' as _lifecycle_history %}

{% block title %}{{ finding.title }}{% endblock %}

{% block body %}
{% import '_components/_fa_alva_hint.html.twig' as _fa_alva_hint %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'audits.page.title'|trans({}, 'audits'), url: path('app_audit_index') },
            { label: 'audit_finding.page.title'|trans({}, 'audits'), url: path('app_audit_finding_index') },
            { label: finding.title }
        ]
    } %}

    {% set hint = alva_hint(finding) %}
    {% if hint %}{{ _fa_alva_hint.render(hint) }}{% endif %}
    {{ _fa_page_header.render({
        badge:    { icon: 'status-critical', label: finding.(findingNumber ?? ('#' ~ finding.id)) },
        title:    finding.title,
        subtitle: finding.clauseReference|default(null),
        actions: [
            { label: 'common.edit'|trans({}, 'messages'),                       variant: 'ghost',   icon: 'ui-edit', href: path('app_audit_finding_edit',     {id: finding.id}) },
            { label: 'corrective_action.action.new'|trans({}, 'audits'),        variant: 'primary', icon: 'plus',   href: path('app_corrective_action_new', {findingId: finding.id}) }
        ]
    }) }}

    {# Lifecycle X.3b — status chip + transition dropdown #}
    <div class="d-flex align-items-center gap-2 mb-3" data-testid="lifecycle-toolbar">
        {{ _fa_status_chip.render({ entity_class: 'App\\Entity\\AuditFinding', status_key: finding.status }) }}
        {{ _lifecycle_actions.dropdown(finding, 'audit-finding', 'audit_finding_lifecycle') }}
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3"><strong>{{ 'audit_finding.field.type'|trans({}, 'audits') }}:</strong> {{ ('audit_finding.type.' ~ finding.type)|trans({}, 'audits') }}</div>
        <div class="col-md-3"><strong>{{ 'audit_finding.field.severity'|trans({}, 'audits') }}:</strong> {{ ('audit_finding.severity.' ~ finding.severity)|trans({}, 'audits') }}</div>
        <div class="col-md-3"><strong>{{ 'audit_finding.field.status'|trans({}, 'audits') }}:</strong> {{ ('audit_finding.status.' ~ finding.status)|trans({}, 'audits') }}</div>
        <div class="col-md-3"><strong>{{ 'audit_finding.field.due_date'|trans({}, 'audits') }}:</strong> {{ finding.dueDate ? finding.dueDate|date('Y-m-d') : '—' }}</div>
    </div>

    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
        {% block card_header %}
            <div class="card-header"><h2 class="h5 mb-0">{{ 'audit_finding.section.description'|trans({}, 'audits') }}</h2></div>
        {% endblock %}
        {% block card_body %}
            <p class="mb-0">{{ finding.description|nl2br }}</p>
            {% if finding.evidence %}
                <hr>
                <h3 class="h6">{{ 'audit_finding.field.evidence'|trans({}, 'audits') }}</h3>
                <p class="mb-0 text-muted">{{ finding.evidence|nl2br }}</p>
            {% endif %}
        {% endblock %}
    {% endembed %}

    {# F15.3 — Linked Norm Requirements as filter-chip group #}
    {% if finding.linkedRequirements|length > 0 %}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
        {% block card_header %}
            <div class="card-header"><h2 class="h5 mb-0">{{ 'audit_finding.section.linked_requirements'|trans({}, 'audits') }} ({{ finding.linkedRequirements|length }})</h2></div>
        {% endblock %}
        {% block card_body %}
            {% import '_components/_fa_filter_chip.html.twig' as _fa_filter_chip %}
            <div class="d-flex flex-wrap gap-2">
                {% for req in finding.linkedRequirements %}
                    {{ _fa_filter_chip.render((req.requirementId ?? '') ~ ' — ' ~ (req.title ?? ''), { active: false }) }}
                {% endfor %}
            </div>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {% embed '_components/_card.html.twig' %}
        {% block card_header %}
            <div class="card-header"><h2 class="h5 mb-0">{{ 'corrective_action.page.title'|trans({}, 'audits') }} ({{ finding.correctiveActions|length }})</h2></div>
        {% endblock %}
        {% block card_body %}
            {% if finding.correctiveActions|length == 0 %}
                <p class="text-muted mb-0">{{ 'corrective_action.message.none'|trans({}, 'audits') }}</p>
            {% else %}
                {% embed '_components/_fa_table.html.twig' %}
                    {% block table_head %}
                        <tr>
                            <th scope="col" class="fa-table__th">{{ 'corrective_action.field.title'|trans({}, 'audits') }}</th>
                            <th scope="col" class="fa-table__th">{{ 'corrective_action.field.status'|trans({}, 'audits') }}</th>
                            <th scope="col" class="fa-table__th">{{ 'corrective_action.field.responsible_person'|trans({}, 'audits') }}</th>
                            <th scope="col" class="fa-table__th">{{ 'corrective_action.field.planned_completion_date'|trans({}, 'audits') }}</th>
                            <th scope="col" class="fa-table__th fa-table__th--actions"></th>
                        </tr>
                    {% endblock %}
                    {% block table_body %}
                        {% for ca in finding.correctiveActions %}
                            <tr class="fa-table__row">
                                <td class="fa-table__cell">{{ ca.title }}</td>
                                <td class="fa-table__cell"><span class="fa-status-pill fa-status-pill--primary">{{ ('corrective_action.status.' ~ ca.status)|trans({}, 'audits') }}</span></td>
                                <td class="fa-table__cell">{{ ca.effectiveResponsiblePerson ?? '—' }}</td>
                                <td class="fa-table__cell">
                                    {% if ca.plannedCompletionDate %}
                                        <span {% if ca.isOverdue %}class="text-danger fw-bold"{% endif %}>
                                            {{ ca.plannedCompletionDate|date('Y-m-d') }}
                                        </span>
                                    {% else %}—{% endif %}
                                </td>
                                <td class="fa-table__cell fa-table__cell--actions"><a href="{{ path('app_corrective_action_show', {id: ca.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"><i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i></a></td>
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            {% endif %}
        {% endblock %}
    {% endembed %}

    {# V3 W2-H3: Comment-Thread adoption (C7 macro). #}
    {% include '_components/_isms_comment_thread.html.twig' with {
        comments: comments|default([]),
        entityType: 'AuditFinding',
        entityId: finding.id,
        showForm: true,
        formAction: path('app_comment_post', {entityType: 'AuditFinding', entityId: finding.id}),
        csrfToken: csrf_token('isms-comment')
    } only %}

    <form method="post" action="{{ path('app_audit_finding_delete', {id: finding.id}) }}" class="mt-4"
          data-controller="ui-actions"
          data-action="submit->ui-actions#confirm"
          data-ui-actions-message-param="{{ 'audit_finding.confirm.delete'|trans({}, 'audits') }}"
          data-ui-actions-tone-param="danger">
        <input type="hidden" name="_token" value="{{ csrf_token('delete_af_' ~ finding.id) }}">
        <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger fa-cyber-btn--sm">
            <i class="fa-icon fa-icon--ui-trash" aria-hidden="true"></i> {{ 'common.delete'|trans({}, 'messages') }}
        </button>
    </form>

    {# Lifecycle X.3b — transition history tab #}
    {{ _lifecycle_history.history('audit-finding', finding.id) }}
</div>
{% endblock %}
