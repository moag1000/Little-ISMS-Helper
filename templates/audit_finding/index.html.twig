{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block title %}{{ 'audit_finding.page.title'|trans({}, 'audits') }}{% endblock %}

{% block body %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
{{ _fa_page_header.render({
    badge: { icon: 'clipboard2-check', label: 'audit_finding.page.title'|trans({}, 'audits') },
    title: 'audit_finding.page.title'|trans({}, 'audits'),
    subtitle: 'audit_finding.page.subtitle'|trans({}, 'audits'),
    actions: [
        { label: 'audit_finding.action.new'|trans({}, 'audits'), href: path('app_audit_finding_new'), variant: 'primary', icon: 'plus-lg' }
    ]
}) }}
<main class="fa-aurora-surface">
<div class="container-fluid py-4">

    {% if overdue_count > 0 %}
        {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning', icon: 'bi-exclamation-triangle' } } %}
            {% block alert_body %}{{ 'audit_finding.alert.overdue'|trans({'%count%': overdue_count}, 'audits') }}{% endblock %}
        {% endembed %}
    {% endif %}

    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
        {% block card_body %}
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label for="status" class="form-label">{{ 'audit_finding.field.status'|trans({}, 'audits') }}</label>
                    <select name="status" id="status" class="form-select" data-controller="ui-actions" data-action="change->ui-actions#autoSubmit">
                        <option value="">{{ 'common.all'|trans({}, 'messages') }}</option>
                        <option value="open" {% if selected_status == 'open' %}selected{% endif %}>{{ 'audit_finding.status.open'|trans({}, 'audits') }}</option>
                        <option value="in_progress" {% if selected_status == 'in_progress' %}selected{% endif %}>{{ 'audit_finding.status.in_progress'|trans({}, 'audits') }}</option>
                        <option value="resolved" {% if selected_status == 'resolved' %}selected{% endif %}>{{ 'audit_finding.status.resolved'|trans({}, 'audits') }}</option>
                        <option value="verified" {% if selected_status == 'verified' %}selected{% endif %}>{{ 'audit_finding.status.verified'|trans({}, 'audits') }}</option>
                        <option value="closed" {% if selected_status == 'closed' %}selected{% endif %}>{{ 'audit_finding.status.closed'|trans({}, 'audits') }}</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label for="severity" class="form-label">{{ 'audit_finding.field.severity'|trans({}, 'audits') }}</label>
                    <select name="severity" id="severity" class="form-select" data-controller="ui-actions" data-action="change->ui-actions#autoSubmit">
                        <option value="">{{ 'common.all'|trans({}, 'messages') }}</option>
                        <option value="critical" {% if selected_severity == 'critical' %}selected{% endif %}>{{ 'audit_finding.severity.critical'|trans({}, 'audits') }}</option>
                        <option value="high" {% if selected_severity == 'high' %}selected{% endif %}>{{ 'audit_finding.severity.high'|trans({}, 'audits') }}</option>
                        <option value="medium" {% if selected_severity == 'medium' %}selected{% endif %}>{{ 'audit_finding.severity.medium'|trans({}, 'audits') }}</option>
                        <option value="low" {% if selected_severity == 'low' %}selected{% endif %}>{{ 'audit_finding.severity.low'|trans({}, 'audits') }}</option>
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    {% if selected_status or selected_severity %}
                        <a href="{{ path('app_audit_finding_index') }}" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle" aria-hidden="true"></i> {{ 'common.clear'|trans({}, 'messages') }}
                        </a>
                    {% endif %}
                </div>
            </form>
        {% endblock %}
    {% endembed %}

    {% embed '_components/_card.html.twig' with { 'noPadding': true } %}
        {% block card_body %}
            {% if findings is empty %}
                {{ _fa_empty_state.render({
                    mood: 'celebrating',
                    title: 'audit_finding.message.no_findings'|trans({}, 'audits')
                }) }}
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                        <tr>
                            <th scope="col">{{ 'audit_finding.field.finding_number'|trans({}, 'audits') }}</th>
                            <th scope="col">{{ 'audit_finding.field.title'|trans({}, 'audits') }}</th>
                            <th scope="col">{{ 'audit_finding.field.type'|trans({}, 'audits') }}</th>
                            <th scope="col">{{ 'audit_finding.field.severity'|trans({}, 'audits') }}</th>
                            <th scope="col">{{ 'audit_finding.field.status'|trans({}, 'audits') }}</th>
                            <th scope="col">{{ 'audit_finding.field.due_date'|trans({}, 'audits') }}</th>
                            <th scope="col" class="text-end">{{ 'common.actions'|trans({}, 'messages') }}</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for f in findings %}
                            <tr>
                                <td>{{ f.(findingNumber ?? ('#' ~ f.id)) }}</td>
                                <td>{{ f.title }}</td>
                                <td><span class="badge bg-secondary fa-status-pill fa-status-pill--neutral">{{ ('audit_finding.type.' ~ f.type)|trans({}, 'audits') }}</span></td>
                                <td>
                                    {% set sevClass = {critical: 'danger', high: 'warning', medium: 'info', low: 'secondary'}[f.severity] ?? 'secondary' %}
                                    {% set sevPill = {critical: 'danger', high: 'warning', medium: 'primary', low: 'neutral'}[f.severity] ?? 'neutral' %}
                                    <span class="badge bg-{{ sevClass }} fa-status-pill fa-status-pill--{{ sevPill }}">{{ ('audit_finding.severity.' ~ f.severity)|trans({}, 'audits') }}</span>
                                </td>
                                {% set _statusV = f.status == 'open' ? 'warning' : (f.status in ['verified', 'closed'] ? 'success' : 'info') %}
                                {% set _statusPill = f.status == 'open' ? 'warning' : (f.status in ['verified', 'closed'] ? 'success' : 'primary') %}
                                <td><span class="badge bg-{{ _statusV }} fa-status-pill fa-status-pill--{{ _statusPill }}">{{ ('audit_finding.status.' ~ f.status)|trans({}, 'audits') }}</span></td>
                                <td>
                                    {% if f.dueDate %}
                                        <span {% if f.isOverdue %}class="text-danger fw-bold"{% endif %}>
                                            {{ f.dueDate|date('Y-m-d') }}
                                        </span>
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    <a href="{{ path('app_audit_finding_show', {id: f.id}) }}" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye" aria-hidden="true"></i>
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        {% endblock %}
    {% endembed %}
</div>
</main>
{% endblock %}
