{% extends 'base.html.twig' %}
{% trans_default_domain 'audits' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block title %}{{ 'audit_finding.page.title'|trans({}, 'audits') }}{% endblock %}

{% block body %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
{% import '_components/_fa_alva_hint.html.twig' as _fa_alva_hint %}
{% include '_components/_breadcrumb.html.twig' with {
    breadcrumbs: [
        { label: 'audits.page.title'|trans({}, 'audits'), url: path('app_audit_index') },
        { label: 'audit_finding.page.title'|trans({}, 'audits') }
    ]
} %}
{{ _fa_page_header.render({
    badge: { icon: 'nav-clipboard-check', label: 'audit_finding.page.title'|trans({}, 'audits') },
    title: 'audit_finding.page.title'|trans({}, 'audits'),
    subtitle: 'audit_finding.page.subtitle'|trans({}, 'audits'),
    actions: [
        { label: 'audit_finding.action.new'|trans({}, 'audits'), href: path('app_audit_finding_new'), variant: 'primary', icon: 'plus', attrs: {'data-turbo-frame': 'fa-form-modal'} }
    ]|merge(is_granted('ROLE_MANAGER') ? [{ label: 'filtered_export.button.label'|trans({}, 'filtered_export'), href: path('app_filtered_export_entity', { entityType: 'audit_finding', format: 'xlsx' }) ~ (app.request.queryString ? '?' ~ app.request.queryString : ''), variant: 'ghost', icon: 'nav-file-earmark-spreadsheet', attrs: {'data-turbo-prefetch': 'false', 'data-turbo': 'false'} }] : [])
}) }}
    {% include '_components/_focus_filter_notice.html.twig' with { focus: focus|default(null), count: findings|default([])|length } %}
{% set _global_hints = alva_hints('audit_finding_index') %}
{% if _global_hints|length > 0 %}
    {% for _h in _global_hints %}
        {{ _fa_alva_hint.render(_h) }}
    {% endfor %}
{% endif %}

<main class="fa-aurora-surface">
<div class="container-fluid py-4">

    {% if overdue_count > 0 %}
        {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning', icon: 'status-warning' } } %}
            {% block alert_body %}{{ 'audit_finding.alert.overdue'|trans({'%count%': overdue_count}, 'audits') }}{% endblock %}
        {% endembed %}
    {% endif %}

    {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
        {% block card_body %}
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label for="status" class="form-label">{{ 'audit_finding.field.status'|trans({}, 'audits') }}</label>
                    <select name="status" id="status" class="form-select fa-cyber-input__field" data-controller="ui-actions" data-action="change->ui-actions#autoSubmit">
                        <option value="">{{ 'common.all'|trans({}, 'messages') }}</option>
                        <option value="open" {% if selected_status == 'open' %}selected{% endif %}>{{ 'audit_finding.status.open'|trans({}, 'audits') }}</option>
                        <option value="in_progress" {% if selected_status == 'in_progress' %}selected{% endif %}>{{ 'audit_finding.status.in_progress'|trans({}, 'audits') }}</option>
                        <option value="resolved" {% if selected_status == 'resolved' %}selected{% endif %}>{{ 'audit_finding.status.resolved'|trans({}, 'audits') }}</option>
                        <option value="verified" {% if selected_status == 'verified' %}selected{% endif %}>{{ 'audit_finding.status.verified'|trans({}, 'audits') }}</option>
                        <option value="closed" {% if selected_status == 'closed' %}selected{% endif %}>{{ 'audit_finding.status.closed'|trans({}, 'audits') }}</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label for="severity" class="form-label">{{ 'audit_finding.field.severity'|trans({}, 'audits') }}</label>
                    <select name="severity" id="severity" class="form-select fa-cyber-input__field" data-controller="ui-actions" data-action="change->ui-actions#autoSubmit">
                        <option value="">{{ 'common.all'|trans({}, 'messages') }}</option>
                        <option value="critical" {% if selected_severity == 'critical' %}selected{% endif %}>{{ 'audit_finding.severity.critical'|trans({}, 'audits') }}</option>
                        <option value="high" {% if selected_severity == 'high' %}selected{% endif %}>{{ 'audit_finding.severity.high'|trans({}, 'audits') }}</option>
                        <option value="medium" {% if selected_severity == 'medium' %}selected{% endif %}>{{ 'audit_finding.severity.medium'|trans({}, 'audits') }}</option>
                        <option value="low" {% if selected_severity == 'low' %}selected{% endif %}>{{ 'audit_finding.severity.low'|trans({}, 'audits') }}</option>
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    {% if selected_status or selected_severity %}
                        <a href="{{ path('app_audit_finding_index') }}" class="fa-cyber-btn fa-cyber-btn--ghost">
                            <i class="fa-icon fa-icon--status-critical" aria-hidden="true"></i> {{ 'common.clear'|trans({}, 'messages') }}
                        </a>
                    {% endif %}
                </div>
            </form>
        {% endblock %}
    {% endembed %}

    {% if findings is empty %}
        {{ _fa_empty_state.render({
            mood: 'celebrating',
            title: 'audit_finding.message.no_findings'|trans({}, 'audits'),
            text: 'audit_finding.empty.body'|trans({}, 'audits'),
            norm_ref: 'ISO 27001 Klausel 9.2 · ISO 19011',
            actions: [
                { label: 'audit_finding.action.new'|trans({}, 'audits'), variant: 'primary', icon: 'plus', href: path('app_audit_finding_new'), attrs: {'data-turbo-frame': 'fa-form-modal'} }
            ],
            help_link: 'audit_finding.help.empty_link'|trans({}, 'audits')
        }) }}
    {% else %}
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>{{ 'audit_finding.field.title'|trans({}, 'audits') }}</th>
                        <th>{{ 'audit_finding.field.type'|trans({}, 'audits') }}</th>
                        <th class="text-center">{{ 'audit_finding.field.severity'|trans({}, 'audits') }}</th>
                        <th class="text-center">{{ 'audit_finding.field.status'|trans({}, 'audits') }}</th>
                        <th>{{ 'audit_finding.field.audit'|trans({}, 'audits') }}</th>
                        <th>{{ 'audit_finding.field.due_date'|trans({}, 'audits') }}</th>
                        <th class="text-center">{{ 'common.actions'|trans({}, 'messages') }}</th>
                    </tr>
                </thead>
                <tbody id="audit-finding-rows">
                    {% for f in findings %}
                        {% include 'audit_finding/_row.html.twig' with { finding: f } %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
</main>
{% endblock %}
