{# Shared AuditFinding form body (outline-rail). Used full-page by new/edit and
   inside the fa-form-modal frame (modal: true). Caller wraps it in
   form_start/form_end and passes title / actions.
   Section map mirrors AuditFindingType::getSectionMap(). #}
{% trans_default_domain 'audits' %}
{% set modal = modal|default(false) %}
{% set title = title|default(finding is defined and finding and finding.title ? finding.title : ('audit_finding.page.new'|trans({}, 'audits'))) %}
{% set submit_label = submit_label|default('common.save'|trans({}, 'messages')) %}

{% set form_sections = {
    'overview': {
        'label': 'form.section.overview'|trans({}, 'messages'),
        'fields': ['audit', 'findingNumber', 'title', 'description']
    },
    'classification': {
        'label': 'form.section.classification'|trans({}, 'messages'),
        'fields': ['type', 'severity', 'status', 'source', 'clauseReference']
    },
    'root_cause': {
        'label': 'form.section.root_cause'|trans({}, 'messages'),
        'fields': ['evidence', 'relatedControls']
    },
    'corrective_action': {
        'label': 'form.section.corrective_action'|trans({}, 'messages'),
        'fields': ['assignedTo', 'assignedPerson', 'assignedDeputyPersons', 'dueDate']
    },
    'nc_capa': {
        'label': 'audit_finding.section.nc_capa'|trans({}, 'audits'),
        'fields': ['nonconformityDetails', 'ncRootCauseSummary', 'ncCorrectionDueDate', 'ncVerifiedAt', 'ncVerifiedBy']
    },
    'verification': {
        'label': 'form.section.verification'|trans({}, 'messages'),
        'fields': ['reportedByPerson', 'reportedByDeputyPersons', 'linkedRequirements']
    }
} %}

{% include '_components/_auto_form.html.twig' with {
    'form': form,
    'layout': 'outline-rail',
    'modal': modal,
    'eyebrow': 'ISO 27001 Cl. 10.1 · Audit Finding',
    'title': title,
    'sections': form_sections,
    'col_widths': {
        'audit': 6,
        'findingNumber': 6,
        'title': 12,
        'description': 12,
        'type': 6,
        'severity': 6,
        'status': 6,
        'source': 6,
        'clauseReference': 12,
        'evidence': 12,
        'relatedControls': 12,
        'assignedTo': 6,
        'assignedPerson': 6,
        'assignedDeputyPersons': 12,
        'dueDate': 6,
        'nonconformityDetails': 12,
        'ncRootCauseSummary': 12,
        'ncCorrectionDueDate': 6,
        'ncVerifiedAt': 6,
        'ncVerifiedBy': 6,
        'reportedByPerson': 6,
        'reportedByDeputyPersons': 12,
        'linkedRequirements': 12
    },
    'translation_domain': 'audits',
    'actions': actions|default({
        'close': { 'label': 'common.cancel'|trans({}, 'messages'), 'variant': 'ghost' },
        'submit': { 'label': submit_label, 'variant': 'primary' }
    })
} %}
