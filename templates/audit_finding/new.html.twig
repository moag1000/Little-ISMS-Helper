{% extends 'base.html.twig' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'audit_finding.page.new'|trans({}, 'audits') }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'audits.page.title'|trans({}, 'audits'), url: path('app_audit_index') },
            { label: 'audit_finding.page.title'|trans({}, 'audits'), url: path('app_audit_finding_index') },
            { label: 'audit_finding.page.new'|trans({}, 'audits') }
        ]
    } %}

    {{ _fa_page_header.render({
        title: 'audit_finding.page.new'|trans({}, 'audits'),
        badge: { icon: 'plus', label: '' }
    }) }}

    {# C5-03 — Severity × Type correlation help (ISO 19011 Cl. 6.4.8). #}
    {{ form_start(form, {'attr': {'data-controller': 'audit-finding-correlation-help'}}) }}
    {# Slot consumed by the audit-finding-correlation-help controller. Translated copy
       travels via data-* attributes so the JS does not need framework access. #}
    <div data-audit-finding-correlation-help-slot
         class="form-text small mb-2"
         hidden
         data-audit-finding-correlation-critical-to-major-nc-match="{{ 'audit_finding.correlation.critical_to_major_nc.match'|trans({}, 'audits') }}"
         data-audit-finding-correlation-critical-to-major-nc-suggest="{{ 'audit_finding.correlation.critical_to_major_nc.suggest'|trans({}, 'audits') }}"
         data-audit-finding-correlation-high-to-major-nc-match="{{ 'audit_finding.correlation.high_to_major_nc.match'|trans({}, 'audits') }}"
         data-audit-finding-correlation-high-to-major-nc-suggest="{{ 'audit_finding.correlation.high_to_major_nc.suggest'|trans({}, 'audits') }}"
         data-audit-finding-correlation-medium-to-minor-nc-match="{{ 'audit_finding.correlation.medium_to_minor_nc.match'|trans({}, 'audits') }}"
         data-audit-finding-correlation-medium-to-minor-nc-suggest="{{ 'audit_finding.correlation.medium_to_minor_nc.suggest'|trans({}, 'audits') }}"
         data-audit-finding-correlation-low-to-observation-match="{{ 'audit_finding.correlation.low_to_observation.match'|trans({}, 'audits') }}"
         data-audit-finding-correlation-low-to-observation-suggest="{{ 'audit_finding.correlation.low_to_observation.suggest'|trans({}, 'audits') }}"></div>
    {% include '_components/_auto_form.html.twig' with {
        'form': form,
        'layout': 'outline-rail',
        'eyebrow': 'ISO 27001 Cl. 9.2 · Audit Finding',
        'title': 'audit_finding.page.new'|trans({}, 'audits'),
        'sections': {
            'overview': {
                'label': 'form.section.overview'|trans({}, 'messages'),
                'fields': ['audit', 'findingNumber', 'title', 'description']
            },
            'classification': {
                'label': 'form.section.classification'|trans({}, 'messages'),
                'fields': ['type', 'severity', 'status', 'source', 'clauseReference']
            },
            'root_cause': {
                'label': 'form.section.root_cause'|trans({}, 'messages'),
                'fields': ['evidence', 'relatedControls']
            },
            'corrective_action': {
                'label': 'form.section.corrective_action'|trans({}, 'messages'),
                'fields': ['assignedTo', 'assignedPerson', 'assignedDeputyPersons', 'dueDate']
            },
            'verification': {
                'label': 'form.section.verification'|trans({}, 'messages'),
                'fields': ['reportedByPerson', 'reportedByDeputyPersons', 'linkedRequirements']
            }
        },
        'col_widths': {
            'audit': 6,
            'findingNumber': 6,
            'title': 12,
            'description': 12,
            'type': 4,
            'severity': 4,
            'status': 4,
            'source': 6,
            'clauseReference': 6,
            'evidence': 12,
            'relatedControls': 12,
            'assignedTo': 6,
            'assignedPerson': 6,
            'assignedDeputyPersons': 12,
            'dueDate': 6,
            'reportedByPerson': 6,
            'reportedByDeputyPersons': 12,
            'linkedRequirements': 12
        },
        'translation_domain': 'audits',
        'actions': {
            'close': { 'label': 'common.cancel'|trans({}, 'messages'), 'variant': 'ghost' },
            'submit': { 'label': 'common.save'|trans({}, 'messages'), 'variant': 'primary' }
        }
    } %}
    {{ form_end(form) }}
</div>
{% endblock %}
