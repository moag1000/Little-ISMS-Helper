{% extends 'base.html.twig' %}
{% trans_default_domain 'suppliers' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_norm_bridge.html.twig' as _fa_norm_bridge %}
{% form_theme form 'supplier/_supplier_form_theme.html.twig' %}

{% block title %}{{ 'supplier.page.edit_title'|trans({'%name%': supplier.name}, 'suppliers') }}{% endblock %}

{% block body %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.suppliers'|trans({}, 'nav'), url: path('app_supplier_index') },
            { label: supplier.name, url: path('app_supplier_show', {id: supplier.id}) },
            { label: 'common.edit'|trans({}, 'messages') }
        ]
    } %}

    {{ _fa_page_header.render({
    title: ('supplier.page.edit_title'|trans({'%name%': supplier.name}, 'suppliers')),
    badge: { icon: 'ui-edit', label: '' },
    actions: [
        { label: 'supplier.action.view'|trans({}, 'suppliers'), href: path('app_supplier_show', {id: supplier.id}), variant: 'ghost', icon: 'util-arrow-left' }
    ]
}) }}

    {# S15 A4 — 9001-bridge for Supplier form (8.4 external providers). #}
    {{ _fa_norm_bridge.render({
        from_norm: 'ISO 27001 A.5.19',
        to_norm:   'ISO 9001 Cl. 8.4',
        bridge_text: ('iso_9001_bridge.supplier'|trans({}, 'suppliers')),
        prominence: 'subtle'
    }) }}

    {{ form_start(form) }}
    {% include '_components/_auto_form.html.twig' with {
        'form': form,
        'layout': 'outline-rail',
        'eyebrow': 'DORA Art. 28 · Lieferanten-Management',
        'title': supplier.name,
        'sections': {
            'details': {
                'label': 'supplier.section.details'|trans({}, 'suppliers'),
                'fields': ['name', 'criticality', 'status', 'description', 'serviceProvided']
            },
            'contact_info': {
                'label': 'supplier.section.contact_info'|trans({}, 'suppliers'),
                'fields': ['contactPerson', 'email', 'phone', 'address']
            },
            'security_assessment': {
                'label': 'supplier.section.security_assessment'|trans({}, 'suppliers'),
                'fields': ['securityScore', 'lastSecurityAssessment', 'nextAssessmentDate', 'assessmentFindings', 'nonConformities', 'securityRequirements']
            },
            'certifications_compliance': {
                'label': 'supplier.section.certifications_compliance'|trans({}, 'suppliers'),
                'fields': ['hasISO27001', 'hasISO22301', 'hasDPA', 'dpaSignedDate', 'certifications']
            },
            'contract_info': {
                'label': 'supplier.section.contract_info'|trans({}, 'suppliers'),
                'fields': ['contractStartDate', 'contractEndDate']
            },
            'linkage': {
                'label': 'supplier.section.linkage'|trans({}, 'suppliers'),
                'fields': ['supportedAssets']
            },
            'privacy': {
                'label': 'supplier.section.privacy'|trans({}, 'suppliers'),
                'fields': ['gdprProcessorStatus', 'gdprTransferMechanism', 'gdprAvContractSigned', 'gdprAvContractDate']
            },
            'tier_classification': {
                'label': 'supplier.section.tier_classification'|trans({}, 'suppliers'),
                'fields': ['isDoraRelevant', 'leiCode', 'naceCode', 'countryOfHeadOffice', 'ictCriticality', 'ictFunctionType', 'substitutability', 'hasSubcontractors', 'subcontractorChain', 'processingLocations', 'lastDoraAuditDate', 'hasExitStrategy']
            },
            'lksg': {
                'label': 'supplier.section.lksg'|trans({}, 'suppliers'),
                'fields': ['lksgReportingObligation', 'lksgRiskCategory', 'lksgHumanRightsRiskScore', 'lksgEnvironmentalRiskScore', 'lksgRiskAnalysisDate', 'lksgComplaintMechanism', 'lksgPreventionMeasures']
            },
            'marisk': {
                'label': 'supplier.section.marisk'|trans({}, 'suppliers'),
                'fields': ['outsourcingClassification', 'outsourcingDueDiligenceCompleted', 'outsourcingDueDiligenceDate', 'outsourcingExitStrategy', 'bafinNotificationRequired', 'bafinNotificationDate', 'riskBearingCapacityImpact', 'boardLevelRiskAcceptance', 'complianceFunctionInvolvement', 'internalAuditFunctionInvolvement']
            }
        },
        'col_widths': {
            'name': 4,
            'criticality': 4,
            'status': 4,
            'description': 12,
            'serviceProvided': 12,
            'contactPerson': 4,
            'email': 4,
            'phone': 4,
            'address': 12,
            'securityScore': 4,
            'lastSecurityAssessment': 4,
            'nextAssessmentDate': 4,
            'assessmentFindings': 12,
            'nonConformities': 12,
            'securityRequirements': 12,
            'hasISO27001': 12,
            'hasISO22301': 12,
            'hasDPA': 12,
            'dpaSignedDate': 6,
            'certifications': 6,
            'contractStartDate': 6,
            'contractEndDate': 6,
            'supportedAssets': 12,
            'gdprProcessorStatus': 6,
            'gdprTransferMechanism': 6,
            'gdprAvContractSigned': 6,
            'gdprAvContractDate': 6,
            'isDoraRelevant': 4,
            'leiCode': 4,
            'naceCode': 4,
            'countryOfHeadOffice': 6,
            'ictCriticality': 6,
            'ictFunctionType': 6,
            'substitutability': 6,
            'hasSubcontractors': 6,
            'subcontractorChain': 12,
            'processingLocations': 12,
            'lastDoraAuditDate': 6,
            'hasExitStrategy': 6,
            'lksgReportingObligation': 6,
            'lksgRiskCategory': 6,
            'lksgHumanRightsRiskScore': 4,
            'lksgEnvironmentalRiskScore': 4,
            'lksgRiskAnalysisDate': 4,
            'lksgComplaintMechanism': 12,
            'lksgPreventionMeasures': 12,
            'outsourcingClassification': 6,
            'outsourcingDueDiligenceCompleted': 6,
            'outsourcingDueDiligenceDate': 6,
            'outsourcingExitStrategy': 6,
            'bafinNotificationRequired': 6,
            'bafinNotificationDate': 6,
            'riskBearingCapacityImpact': 6,
            'boardLevelRiskAcceptance': 6,
            'complianceFunctionInvolvement': 6,
            'internalAuditFunctionInvolvement': 6
        },
        'tooltips': {
            'securityScore': 'supplier.tooltip.security_score',
            'criticality': 'supplier.tooltip.criticality'
        },
        'translation_domain': 'suppliers',
        'actions': {
            'close': { 'label': 'common.cancel'|trans({}, 'messages'), 'variant': 'ghost' },
            'submit': { 'label': 'supplier.action.update'|trans({}, 'suppliers'), 'variant': 'primary' }
        }
    } %}
    {{ form_end(form) }}
</div>
{% endblock %}
