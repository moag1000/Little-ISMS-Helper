{% extends 'base.html.twig' %}
{% trans_default_domain 'suppliers' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_norm_bridge.html.twig' as _fa_norm_bridge %}
{% form_theme form 'supplier/_supplier_form_theme.html.twig' %}

{% block title %}{{ 'supplier.page.new_title'|trans({}, 'suppliers')}}{% endblock %}

{% block body %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.suppliers'|trans({}, 'nav'), url: path('app_supplier_index') },
            { label: 'supplier.page.new_title'|trans({}, 'suppliers')}
        ]
    } %}

    {{ _fa_page_header.render({
    title: ('supplier.page.new_title'|trans({}, 'suppliers')),
    badge: { icon: 'plus', label: '' },
    actions: [
        { label: 'common.back'|trans({}, 'messages'), href: path('app_supplier_index'), variant: 'ghost', icon: 'util-arrow-left' }
    ]
}) }}

    {# S15 A4 — 9001-bridge for Supplier form (8.4 external providers). #}
    {{ _fa_norm_bridge.render({
        from_norm: 'ISO 27001 A.5.19',
        to_norm:   'ISO 9001 Cl. 8.4',
        bridge_text: ('iso_9001_bridge.supplier'|trans({}, 'suppliers')),
        prominence: 'subtle'
    }) }}

    {# Foundation P-14 — Cloud-Provider Template Library (M-06). Lets the
       supplier manager start from a hyperscaler prefab (AWS, Azure, GCP,
       M365, Google Workspace) instead of a blank form. #}
    {% set _system_templates = system_templates('App\\Entity\\Supplier') %}
    {% if _system_templates|length > 0 %}
        <div class="fa-template-cta my-3 p-3 border rounded bg-body-tertiary d-flex flex-wrap align-items-center gap-3">
            <div class="flex-grow-1">
                <div class="fw-semibold">
                    <i class="fa-icon fa-icon--nav-collection" aria-hidden="true"></i>
                    {{ 'system_templates.cta.button'|trans({}, 'system_templates') }}
                </div>
                <div class="small text-body-secondary">
                    {{ 'system_templates.cta.hint'|trans({}, 'system_templates') }}
                </div>
            </div>
            <button type="button" class="btn btn-outline-primary"
                    data-controller="fa-modal-dispatcher"
                    data-action="click->fa-modal-dispatcher#open"
                    data-fa-modal-id="systemTemplateModalSupplierNew">
                {{ 'system_templates.cta.button'|trans({}, 'system_templates') }}
            </button>
        </div>
        {% include '_components/_system_template_selector.html.twig' with {
            templates: _system_templates,
            entity_class: 'App\\Entity\\Supplier',
            redirect_to: 'app_supplier_index',
            modal_id: 'systemTemplateModalSupplierNew'
        } %}
    {% endif %}

    {{ form_start(form) }}
    {% include '_components/_auto_form.html.twig' with {
        'form': form,
        'layout': 'outline-rail',
        'eyebrow': 'DORA Art. 28 · Lieferanten-Management',
        'title': 'supplier.page.new_title'|trans({}, 'suppliers'),
        'sections': {
            'details': {
                'label': 'supplier.section.details'|trans({}, 'suppliers'),
                'fields': ['name', 'criticality', 'status', 'description', 'serviceProvided']
            },
            'contact_info': {
                'label': 'supplier.section.contact_info'|trans({}, 'suppliers'),
                'fields': ['contactPerson', 'email', 'phone', 'address']
            },
            'security_assessment': {
                'label': 'supplier.section.security_assessment'|trans({}, 'suppliers'),
                'fields': ['securityScore', 'lastSecurityAssessment', 'nextAssessmentDate', 'assessmentFindings', 'nonConformities', 'securityRequirements']
            },
            'certifications': {
                'label': 'supplier.section.certifications_compliance'|trans({}, 'suppliers'),
                'fields': ['hasISO27001', 'hasISO22301', 'hasDPA', 'dpaSignedDate', 'certifications']
            },
            'contract': {
                'label': 'supplier.section.contract_info'|trans({}, 'suppliers'),
                'fields': ['contractStartDate', 'contractEndDate']
            }
        },
        'col_widths': {
            'name': 4,
            'criticality': 4,
            'status': 4,
            'description': 12,
            'serviceProvided': 12,
            'contactPerson': 4,
            'email': 4,
            'phone': 4,
            'address': 12,
            'securityScore': 4,
            'lastSecurityAssessment': 4,
            'nextAssessmentDate': 4,
            'assessmentFindings': 12,
            'nonConformities': 12,
            'securityRequirements': 12,
            'dpaSignedDate': 6,
            'certifications': 6,
            'contractStartDate': 6,
            'contractEndDate': 6
        },
        'tooltips': {
            'securityScore': 'supplier.tooltip.security_score',
            'criticality': 'supplier.tooltip.criticality'
        },
        'translation_domain': 'suppliers',
        'actions': {
            'close': { 'label': 'common.cancel'|trans({}, 'messages'), 'variant': 'ghost' },
            'submit': { 'label': 'supplier.action.create'|trans({}, 'suppliers'), 'variant': 'primary' }
        }
    } %}
    {{ form_end(form) }}
</div>
{% endblock %}
