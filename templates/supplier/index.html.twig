{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% trans_default_domain 'suppliers' %}
{% import '_macros/inheritance_badge.html.twig' as inheritance %}
{% import '_macros/cards.html.twig' as cards %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}

{% block title %}{{ 'supplier.title'|trans({}, 'suppliers') }}{% endblock %}

{% block body %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% include '_components/_breadcrumb.html.twig' with {
    breadcrumbs: [
        { label: 'nav.suppliers'|trans({}, 'nav') }
    ]
} %}

{% set supplierActions = [
    { label: 'supplier.action.add_new'|trans({}, 'suppliers'), variant: 'primary', icon: 'plus-lg', href: path('app_supplier_new') }
] %}
{% if doraActive ?? false %}
    {% set supplierActions = [{ label: 'dora.register_export.button'|trans({}, 'dora'), variant: 'ghost', icon: 'download', href: path('app_dora_register_export_csv') }] | merge(supplierActions) %}
{% endif %}
{{ _fa_page_header.render({
    badge: { icon: 'truck', label: 'nav.suppliers'|trans({}, 'nav') },
    title: 'supplier.page.title'|trans({}, 'suppliers'),
    actions: supplierActions
}) }}

<main class="fa-aurora-surface">
<div class="container">

    {% if currentTenant %}
    {% embed '_components/_card.html.twig' with { 'class': 'mb-3' } %}
        {% block card_body %}
            <div class="py-2">
                <form method="get" action="{{ path('app_supplier_index') }}" class="d-flex align-items-center gap-2">
                    <label for="view-filter" class="mb-0 fw-bold">
                        <i class="bi bi-eye" aria-hidden="true"></i> {{ 'common.view'|trans({}, 'messages') }}:
                    </label>
                    <select class="form-select form-select-sm w-auto" id="view-filter" name="view" data-controller="ui-actions" data-action="change->ui-actions#autoSubmit">
                        <option value="own" {{ inheritanceInfo.currentView == 'own' ? 'selected' : '' }}>
                            {{ 'corporate.view.own_only'|trans({}, 'messages') }}
                        </option>
                        {% if inheritanceInfo.hasParent %}
                        <option value="inherited" {{ inheritanceInfo.currentView == 'inherited' ? 'selected' : '' }}>
                            {{ 'corporate.view.including_inherited'|trans({}, 'messages') }}
                        </option>
                        {% endif %}
                        {% if inheritanceInfo.hasSubsidiaries %}
                        <option value="subsidiaries" {{ inheritanceInfo.currentView == 'subsidiaries' ? 'selected' : '' }}>
                            {{ 'corporate.view.including_subsidiaries'|trans({}, 'messages') }}
                        </option>
                        {% endif %}
                    </select>
                    <noscript>
                        <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">{{ 'common.apply'|trans({}, 'messages') }}</button>
                    </noscript>
                </form>
            </div>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {% if statistics %}
    <div class="row mb-4">
        <div class="col-md-3">
            {% if currentTenant %}
                {% set subtitle = 'corporate.stats.breakdown'|trans({'%own%': detailedStats.own, '%inherited%': detailedStats.inherited, '%subsidiaries%': detailedStats.subsidiaries}, 'tenant') %}
                {{ cards.kpi_card('supplier.statistics.total'|trans({}, 'suppliers'), detailedStats.total, subtitle, null, 'primary', null) }}
            {% else %}
                {{ cards.kpi_card('supplier.statistics.total'|trans({}, 'suppliers'), detailedStats.total, null, null, 'primary', null) }}
            {% endif %}
        </div>
        <div class="col-md-3">
            {{ cards.kpi_card('supplier.statistics.critical'|trans({}, 'suppliers'), statistics.critical, null, null, 'danger', null) }}
        </div>
        <div class="col-md-3">
            {{ cards.kpi_card('supplier.statistics.overdue_assessments'|trans({}, 'suppliers'), statistics.overdue_assessments, null, null, 'warning', null) }}
        </div>
        <div class="col-md-3">
            {{ cards.kpi_card('supplier.statistics.non_compliant'|trans({}, 'suppliers'), statistics.non_compliant, null, null, 'danger', null) }}
        </div>
    </div>
    {% endif %}

    {% if overdueAssessments|length > 0 %}
    <div class="fa-alert fa-alert--warning" role="alert">
        <i class="fa-icon fa-icon--status-warning fa-alert__icon" aria-hidden="true"></i>
        <div class="fa-alert__body"><div class="fw-bold mb-2"><i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> {{ 'supplier.alert.overdue_assessments'|trans({}, 'suppliers') }}</div>
        <ul>
            {% for supplier in overdueAssessments %}
            <li>
                <a href="{{ path('app_supplier_show', {id: supplier.id}) }}">{{ supplier.name }}</a>
                - {{ 'supplier.next_assessment'|trans({}, 'suppliers') }}: {{ supplier.nextAssessmentDate ? supplier.nextAssessmentDate|date('Y-m-d') : ('supplier.not_scheduled'|trans({}, 'suppliers')) }}
            </li>
            {% endfor %}
        </ul>
        </div>
    </div>
    {% endif %}

    {% if nonCompliant|length > 0 %}
    <div class="fa-alert fa-alert--danger" role="alert">
        <div class="fa-alert__body">
        <div class="fw-bold mb-2">🚨 {{ 'supplier.alert.non_compliant'|trans({}, 'suppliers') }}</div>
        <ul>
            {% for supplier in nonCompliant %}
            <li>
                <a href="{{ path('app_supplier_show', {id: supplier.id}) }}">{{ supplier.name }}</a>
                - {{ 'supplier.risk_score'|trans({}, 'suppliers') }}: {{ supplier.calculateRiskScore() }}
            </li>
            {% endfor %}
        </ul>
    
        </div>
    </div>
    {% endif %}

    {# Search-first Filter: URL-persisted state (UXC-11 / UXC-12) #}
    {% embed '_components/_search_filter_form.html.twig' with {
        action: path('app_supplier_index'),
        filter_keys: ['criticality', 'status', 'iso27001', 'view', 'tag'],
        form_id: 'supplier-filter-form'
    } %}
        {% block filters %}
            {% if app.request.query.get('view') %}
                <input type="hidden" name="view" value="{{ app.request.query.get('view') }}">
            {% endif %}
            <div class="col-md-4">
                <label for="filter-criticality" class="form-label">{{ 'supplier.table.criticality'|trans({}, 'suppliers') }}</label>
                <select class="form-select" id="filter-criticality" name="criticality">
                    <option value="">{{ 'common.all'|trans({}, 'messages') }}</option>
                    <option value="critical" {{ app.request.query.get('criticality') == 'critical' ? 'selected' : '' }}>{{ 'supplier.criticality.critical'|trans({}, 'suppliers') }}</option>
                    <option value="high" {{ app.request.query.get('criticality') == 'high' ? 'selected' : '' }}>{{ 'supplier.criticality.high'|trans({}, 'suppliers') }}</option>
                    <option value="medium" {{ app.request.query.get('criticality') == 'medium' ? 'selected' : '' }}>{{ 'supplier.criticality.medium'|trans({}, 'suppliers') }}</option>
                    <option value="low" {{ app.request.query.get('criticality') == 'low' ? 'selected' : '' }}>{{ 'supplier.criticality.low'|trans({}, 'suppliers') }}</option>
                </select>
            </div>
            <div class="col-md-4">
                <label for="filter-status" class="form-label">{{ 'supplier.table.status'|trans({}, 'suppliers') }}</label>
                <select class="form-select" id="filter-status" name="status">
                    <option value="">{{ 'common.all'|trans({}, 'messages') }}</option>
                    <option value="active" {{ app.request.query.get('status') == 'active' ? 'selected' : '' }}>{{ 'supplier.status.active'|trans({}, 'suppliers') }}</option>
                    <option value="inactive" {{ app.request.query.get('status') == 'inactive' ? 'selected' : '' }}>{{ 'supplier.status.inactive'|trans({}, 'suppliers') }}</option>
                    <option value="terminated" {{ app.request.query.get('status') == 'terminated' ? 'selected' : '' }}>{{ 'supplier.status.terminated'|trans({}, 'suppliers') }}</option>
                </select>
            </div>
            <div class="col-md-4">
                <label for="filter-iso27001" class="form-label">{{ 'supplier.table.iso27001'|trans({}, 'suppliers') }}</label>
                <select class="form-select" id="filter-iso27001" name="iso27001">
                    <option value="">{{ 'common.all'|trans({}, 'messages') }}</option>
                    <option value="1" {{ app.request.query.get('iso27001') == '1' ? 'selected' : '' }}>{{ 'common.yes'|trans({}, 'messages') }}</option>
                    <option value="0" {{ app.request.query.get('iso27001') == '0' ? 'selected' : '' }}>{{ 'common.no'|trans({}, 'messages') }}</option>
                </select>
            </div>
        {% endblock %}
    {% endembed %}

    {# WS-5 Bulk tag actions bar (polymorphic) #}
    {% if is_granted('TAG_APPLY') %}
        {% include '_components/_bulk_action_bar.html.twig' with {
            entity_class:   'App\\Entity\\Supplier',
            action_urls: {
                tag_add: path('admin_tag_bulk_apply', {entityClass: 'Supplier'}),
            },
            available_tags: available_tags(),
        } only %}
    {% endif %}

    {% embed '_components/_card.html.twig' %}
        {% block card_attrs %}data-controller="bulk-actions" data-bulk-actions-endpoint-value="/supplier"{% endblock %}
        {% block card_header %}
            <div class="card-header">
                {%- set supplierCount = suppliers|length -%}
                <h2>{{ 'supplier.list.title'|trans({'count': supplierCount}, 'suppliers') }}</h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
            {% if suppliers|length > 0 %}
            {% embed '_components/_table.html.twig' with {
                'wrapperClass': 'card-body',
                'noMargin': true
            } %}
                {% block table_head %}
                    <tr>
                        <th scope="col" class="w-40px">
                            <input type="checkbox"
                                   class="form-check-input"
                                   data-action="bulk-actions#selectAll"
                                   data-bulk-actions-target="selectAllCheckbox"
                                   aria-label="{{ 'common.select_all'|trans({}, 'messages') }}">
                        </th>
                        <th scope="col">{{ 'supplier.table.name'|trans({}, 'suppliers') }}</th>
                        <th scope="col">{{ 'supplier.table.service_provided'|trans({}, 'suppliers') }}</th>
                        <th scope="col">{{ 'supplier.table.criticality'|trans({}, 'suppliers') }}</th>
                        <th scope="col">{{ 'supplier.table.status'|trans({}, 'suppliers') }}</th>
                        <th scope="col">{{ 'supplier.table.risk_score'|trans({}, 'suppliers') }}</th>
                        <th scope="col">{{ 'supplier.table.iso27001'|trans({}, 'suppliers') }}</th>
                        <th scope="col">{{ 'supplier.table.actions'|trans({}, 'suppliers') }}</th>
                    </tr>
                {% endblock %}
                {% block table_body %}
                    {% import '_macros/inheritance_badge.html.twig' as inheritance %}
                    {% for supplier in suppliers %}
                    <tr data-supplier-id="{{ supplier.id }}">
                        <td>
                            <input type="checkbox"
                                   class="form-check-input"
                                   data-bulk-actions-target="item"
                                   data-action="bulk-actions#selectItem"
                                   value="{{ supplier.id }}"
                                   aria-label="{{ 'common.select'|trans({}, 'messages') }} {{ supplier.name }}">
                        </td>
                        <td>
                            <a href="{{ path('app_supplier_show', {id: supplier.id}) }}">{{ supplier.name }}</a>
                            {{ inheritance.small_badge(supplier, currentTenant) }}
                        </td>
                        <td>{{ supplier.serviceProvided|slice(0, 50) }}...</td>
                        <td>{% include '_components/_badge.html.twig' with { variant: supplier.criticality == 'critical' ? 'danger' : (supplier.criticality == 'high' ? 'warning' : (supplier.criticality == 'medium' ? 'info' : 'secondary')), content: supplier.criticality|upper } %}</td>
                        <td><span class="{{ badge_status(supplier.status) }}">{{ supplier.status }}</span></td>
                        <td>
                            {% set riskScore = supplier.calculateRiskScore() %}
                            {% include '_components/_badge.html.twig' with { variant: riskScore > 70 ? 'danger' : (riskScore > 50 ? 'warning' : (riskScore > 30 ? 'info' : 'secondary')), content: riskScore } %}
                        </td>
                        <td>{{ supplier.hasISO27001 ? '✓' : '✗' }}</td>
                        <td>
                            <a href="{{ path('app_supplier_show', {id: supplier.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">{{ 'supplier.action.view'|trans({}, 'suppliers') }}</a>
                            <a href="{{ path('app_supplier_edit', {id: supplier.id}) }}" class="fa-cyber-btn fa-cyber-btn--primary fa-cyber-btn--sm">{{ 'supplier.action.edit'|trans({}, 'suppliers') }}</a>
                        </td>
                    </tr>
                    {% endfor %}
                {% endblock %}
            {% endembed %}
            {% else %}
            {{ _fa_empty_state.render({
                mood: 'sleeping',
                title: 'supplier.empty.message'|trans({}, 'suppliers'),
                actions: [
                    { label: 'supplier.empty.add_first'|trans({}, 'suppliers'), variant: 'primary', icon: 'plus-circle', href: path('app_supplier_new') }
                ]
            }) }}
            {% endif %}

            {# Bulk Action Bar #}
            {% if suppliers|length > 0 %}
            {% include '_components/_bulk_action_bar.html.twig' with {
                actions: ['export', 'delete']
            } %}
            {% endif %}
        {% endblock %}
    {% endembed %}
</div>

<style>
.stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-top: 1rem; }
.stat-item { display: flex; flex-direction: column; padding: 1rem; background: var(--bs-tertiary-bg); border-radius: 4px; }
.stat-label { font-size: 0.875rem; color: var(--bs-secondary-color); }
.stat-value { font-size: 1.5rem; font-weight: bold; color: var(--bs-body-color); }
.stat-value.critical { color: var(--danger); }
.stat-value.warning { color: var(--warning); }
.stat-value.danger { color: var(--danger); }
</style>
</main>
{% endblock %}
