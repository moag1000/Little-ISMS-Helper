{% extends 'base.html.twig' %}
{% trans_default_domain 'dora_exit_plan' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_feature_card.html.twig' as _fa_feature_card %}

{% block title %}{{ 'dora_exit_plan.title'|trans({}, 'dora_exit_plan') }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.dora_compliance'|trans({}, 'nav'), url: path('app_dora_compliance_dashboard') },
            { label: 'dora_exit_plan.title'|trans({}, 'dora_exit_plan') }
        ]
    } %}

    {{ _fa_page_header.render({
        badge: { icon: 'nav-shield-alert', label: 'dora_exit_plan.title'|trans({}, 'dora_exit_plan') },
        title: 'dora_exit_plan.title'|trans({}, 'dora_exit_plan'),
        subtitle: 'dora_exit_plan.subtitle'|trans({}, 'dora_exit_plan'),
        actions: [
            { label: 'dora_exit_plan.action.new'|trans({}, 'dora_exit_plan'), href: path('app_dora_exit_plan_new'), variant: 'primary', icon: 'plus' }
        ]
    }) }}

    <main class="fa-aurora-surface">
        <div class="row mb-4">
            <div class="col-md-4">
                {{ _fa_feature_card.render({
                    label: 'dora_exit_plan.kpi.total'|trans({}, 'dora_exit_plan'),
                    value: total_count,
                    variant: 'primary'
                }) }}
            </div>
            <div class="col-md-4">
                {{ _fa_feature_card.render({
                    label: 'dora_exit_plan.kpi.overdue'|trans({}, 'dora_exit_plan'),
                    value: overdue_count,
                    variant: overdue_count > 0 ? 'warning' : 'success'
                }) }}
            </div>
        </div>

        {% if plans|length == 0 %}
            {% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
            {{ _fa_empty_state.render({
                mood: 'sleeping',
                title: 'dora_exit_plan.empty.title'|trans({}, 'dora_exit_plan'),
                body: 'dora_exit_plan.empty.body'|trans({}, 'dora_exit_plan'),
                actions: [
                    { label: 'dora_exit_plan.action.new'|trans({}, 'dora_exit_plan'), variant: 'primary', icon: 'plus', href: path('app_dora_exit_plan_new') }
                ]
            }) }}
        {% else %}
            {% embed '_components/_card.html.twig' %}
                {% block card_header %}
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h2 class="mb-0">{{ 'dora_exit_plan.title'|trans({}, 'dora_exit_plan') }} ({{ plans|length }})</h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {% embed '_components/_table.html.twig' with { 'noMargin': true } %}
                        {% block table_head %}
                            <tr>
                                <th scope="col">{{ 'dora_exit_plan.field.supplier'|trans({}, 'dora_exit_plan') }}</th>
                                <th scope="col">{{ 'dora_exit_plan.field.exit_trigger'|trans({}, 'dora_exit_plan') }}</th>
                                <th scope="col">{{ 'dora_exit_plan.field.tested_at'|trans({}, 'dora_exit_plan') }}</th>
                                <th scope="col">{{ 'dora_exit_plan.field.estimated_duration_days'|trans({}, 'dora_exit_plan') }}</th>
                                <th scope="col">{{ 'common.actions'|trans({}, 'messages') }}</th>
                            </tr>
                        {% endblock %}
                        {% block table_body %}
                            {% for plan in plans %}
                                <tr>
                                    <td><strong>{{ plan.supplier ? plan.supplier.name : '—' }}</strong></td>
                                    <td>
                                        {% include '_components/_badge.html.twig' with {
                                            variant: 'primary',
                                            content: ('dora_exit_plan.trigger.' ~ plan.exitTrigger)|trans({}, 'dora_exit_plan')
                                        } %}
                                    </td>
                                    <td>
                                        {% if plan.testedAt %}
                                            {{ plan.testedAt|date('Y-m-d') }}
                                            {% if plan.isRehearsalOverdue() %}
                                                {% include '_components/_badge.html.twig' with {
                                                    variant: 'warning',
                                                    content: 'dora_exit_plan.badge.overdue'|trans({}, 'dora_exit_plan')
                                                } %}
                                            {% endif %}
                                        {% else %}
                                            {% include '_components/_badge.html.twig' with {
                                                variant: 'warning',
                                                content: 'dora_exit_plan.badge.never_tested'|trans({}, 'dora_exit_plan')
                                            } %}
                                        {% endif %}
                                    </td>
                                    <td>{{ plan.estimatedDurationDays ?? '—' }}</td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group" aria-label="{{ 'common.actions'|trans({}, 'messages') }}">
                                            <a href="{{ path('app_dora_exit_plan_show', {id: plan.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost" title="{{ 'common.view'|trans({}, 'messages') }}" aria-label="{{ 'common.view'|trans({}, 'messages') }}"><i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i></a>
                                            <a href="{{ path('app_dora_exit_plan_edit', {id: plan.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost" title="{{ 'common.edit'|trans({}, 'messages') }}" aria-label="{{ 'common.edit'|trans({}, 'messages') }}"><i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i></a>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endblock %}
                    {% endembed %}
                {% endblock %}
            {% endembed %}
        {% endif %}
    </main>
</div>
{% endblock %}
