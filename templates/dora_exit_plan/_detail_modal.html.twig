{# DoraExitPlan read-only detail — rendered inside the fa-form-modal Turbo Frame.
   Uses the drawer chrome (header/body/footer/kv) which renders cleanly as a
   flex column; condensed, with a "Vollansicht" link to the full page.
   Edit button is gated on ROLE_MANAGER, matching the full-page guard. #}
{% trans_default_domain 'dora_exit_plan' %}
<turbo-frame id="fa-form-modal">
    <div class="fa-drawer__header">
        <div class="fa-drawer__header-text">
            <div class="fa-drawer__eyebrow">DORA Art. 28(8) · ICT Third-Party Exit Plan</div>
            <div class="fa-drawer__title">{{ plan.supplier ? plan.supplier.name : '—' }}</div>
        </div>
        <button type="button" class="fa-drawer__close" data-action="fa-form-modal#close"
                aria-label="{{ 'common.close'|trans({}, 'messages') }}">
            <i class="fa-icon fa-icon--ui-close" aria-hidden="true"></i>
        </button>
    </div>
    <div class="fa-drawer__body">
        <div class="fa-drawer__section">
            {% include '_components/_badge.html.twig' with {
                variant: 'primary',
                content: ('dora_exit_plan.trigger.' ~ plan.exitTrigger)|trans({}, 'dora_exit_plan')
            } %}
            {% if plan.isRehearsalOverdue() %}
                {% include '_components/_badge.html.twig' with {
                    variant: 'warning',
                    content: 'dora_exit_plan.badge.overdue'|trans({}, 'dora_exit_plan')
                } %}
            {% endif %}
        </div>

        <div class="fa-drawer__kv">
            <span class="label">{{ 'dora_exit_plan.field.supplier'|trans({}, 'dora_exit_plan') }}</span>
            <span>{{ plan.supplier ? plan.supplier.name : '—' }}</span>
        </div>
        <div class="fa-drawer__kv">
            <span class="label">{{ 'dora_exit_plan.field.exit_trigger'|trans({}, 'dora_exit_plan') }}</span>
            <span>{{ ('dora_exit_plan.trigger.' ~ plan.exitTrigger)|trans({}, 'dora_exit_plan') }}</span>
        </div>
        <div class="fa-drawer__kv">
            <span class="label">{{ 'dora_exit_plan.field.tested_at'|trans({}, 'dora_exit_plan') }}</span>
            <span>
                {% if plan.testedAt %}
                    {{ plan.testedAt|date('Y-m-d') }}
                {% else %}
                    {% include '_components/_badge.html.twig' with {
                        variant: 'warning',
                        content: 'dora_exit_plan.badge.never_tested'|trans({}, 'dora_exit_plan')
                    } %}
                {% endif %}
            </span>
        </div>
        <div class="fa-drawer__kv">
            <span class="label">{{ 'dora_exit_plan.field.estimated_duration_days'|trans({}, 'dora_exit_plan') }}</span>
            <span>{{ plan.estimatedDurationDays ?? '—' }}</span>
        </div>
        {% if plan.estimatedCost is not null %}
            <div class="fa-drawer__kv">
                <span class="label">{{ 'dora_exit_plan.field.estimated_cost'|trans({}, 'dora_exit_plan') }}</span>
                <span>{{ plan.estimatedCost }}</span>
            </div>
        {% endif %}
        <div class="fa-drawer__kv">
            <span class="label">{{ 'dora_exit_plan.field.data_deletion_confirmation'|trans({}, 'dora_exit_plan') }}</span>
            <span>
                {% include '_components/_badge.html.twig' with {
                    variant: plan.dataDeletionConfirmation ? 'success' : 'danger',
                    content: plan.dataDeletionConfirmation ? 'yes'|trans({}, 'messages') : 'no'|trans({}, 'messages')
                } %}
            </span>
        </div>
        {% if plan.migrationPath %}
            <div class="fa-drawer__section">
                <span class="label">{{ 'dora_exit_plan.field.migration_path'|trans({}, 'dora_exit_plan') }}</span>
                <p class="fa-drawer__desc">{{ plan.migrationPath|u.truncate(280, '…') }}</p>
            </div>
        {% endif %}
        <div class="fa-drawer__section">
            <a href="{{ path('app_dora_exit_plan_show', {id: plan.id}) }}" data-turbo="false" class="fa-row-link">
                {{ 'common.open_full_view'|trans({}, 'messages') }} →
            </a>
        </div>
    </div>
    <div class="fa-drawer__footer" style="display:flex;gap:10px;justify-content:flex-end">
        <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--md" data-action="fa-form-modal#close">
            <span class="fa-cyber-btn__label">{{ 'common.close'|trans({}, 'messages') }}</span>
        </button>
        {% if is_granted('ROLE_MANAGER') %}
            <a href="{{ path('app_dora_exit_plan_edit', {id: plan.id}) }}" data-turbo-frame="fa-form-modal"
               class="fa-cyber-btn fa-cyber-btn--md">
                <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                <span class="fa-cyber-btn__label">{{ 'common.edit'|trans({}, 'messages') }}</span>
            </a>
        {% endif %}
    </div>
</turbo-frame>
