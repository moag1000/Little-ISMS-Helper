{% extends 'base.html.twig' %}
{% trans_default_domain 'dora_exit_plan' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_alva_hint.html.twig' as _fa_alva_hint %}

{% block title %}{{ plan.supplier ? plan.supplier.name : 'dora_exit_plan.title'|trans }} - {{ 'app.title'|trans({}, 'messages') }}{% endblock %}

{% block body %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'dora_exit_plan.title'|trans({}, 'dora_exit_plan'), url: path('app_dora_exit_plan_index') },
            { label: plan.supplier ? plan.supplier.name : '—' }
        ]
    } %}

    {% set hint = alva_hint(plan) %}
    {% if hint %}{{ _fa_alva_hint.render(hint) }}{% endif %}

    {{ _fa_page_header.render({
        badge: { icon: 'nav-shield-alert', label: 'dora_exit_plan.title'|trans({}, 'dora_exit_plan') },
        title: plan.supplier ? plan.supplier.name : '—',
        subtitle: ('dora_exit_plan.trigger.' ~ plan.exitTrigger)|trans({}, 'dora_exit_plan'),
        actions: [
            { label: 'common.edit'|trans({}, 'messages'), variant: 'primary', icon: 'ui-edit', href: path('app_dora_exit_plan_edit', {id: plan.id}) },
            { label: 'common.back'|trans({}, 'messages'), variant: 'ghost', icon: 'util-arrow-left', href: path('app_dora_exit_plan_index') }
        ]
    }) }}

    {% embed '_components/_card.html.twig' %}
        {% block card_body %}
            <dl class="row">
                <dt class="col-sm-4">{{ 'dora_exit_plan.field.supplier'|trans({}, 'dora_exit_plan') }}</dt>
                <dd class="col-sm-8">{{ plan.supplier ? plan.supplier.name : '—' }}</dd>

                <dt class="col-sm-4">{{ 'dora_exit_plan.field.exit_trigger'|trans({}, 'dora_exit_plan') }}</dt>
                <dd class="col-sm-8">
                    {% include '_components/_badge.html.twig' with {
                        variant: 'primary',
                        content: ('dora_exit_plan.trigger.' ~ plan.exitTrigger)|trans({}, 'dora_exit_plan')
                    } %}
                </dd>

                <dt class="col-sm-4">{{ 'dora_exit_plan.field.data_return_format'|trans({}, 'dora_exit_plan') }}</dt>
                <dd class="col-sm-8">{{ plan.dataReturnFormat|default('—')|nl2br }}</dd>

                <dt class="col-sm-4">{{ 'dora_exit_plan.field.data_deletion_confirmation'|trans({}, 'dora_exit_plan') }}</dt>
                <dd class="col-sm-8">
                    {% include '_components/_badge.html.twig' with {
                        variant: plan.dataDeletionConfirmation ? 'success' : 'danger',
                        content: plan.dataDeletionConfirmation ? 'yes'|trans({}, 'messages') : 'no'|trans({}, 'messages')
                    } %}
                </dd>

                {% if plan.deletionCertificateDoc %}
                    <dt class="col-sm-4">{{ 'dora_exit_plan.field.deletion_certificate_doc'|trans({}, 'dora_exit_plan') }}</dt>
                    <dd class="col-sm-8">{{ plan.deletionCertificateDoc.originalFilename ?? plan.deletionCertificateDoc.filename ?? '—' }}</dd>
                {% endif %}

                <dt class="col-sm-4">{{ 'dora_exit_plan.field.migration_path'|trans({}, 'dora_exit_plan') }}</dt>
                <dd class="col-sm-8">{{ plan.migrationPath|default('—')|nl2br }}</dd>

                <dt class="col-sm-4">{{ 'dora_exit_plan.field.tested_at'|trans({}, 'dora_exit_plan') }}</dt>
                <dd class="col-sm-8">
                    {% if plan.testedAt %}
                        {{ plan.testedAt|date('Y-m-d H:i') }}
                        {% if plan.isRehearsalOverdue() %}
                            {% include '_components/_badge.html.twig' with {
                                variant: 'warning',
                                content: 'dora_exit_plan.badge.overdue'|trans({}, 'dora_exit_plan')
                            } %}
                        {% endif %}
                    {% else %}
                        {% include '_components/_badge.html.twig' with {
                            variant: 'warning',
                            content: 'dora_exit_plan.badge.never_tested'|trans({}, 'dora_exit_plan')
                        } %}
                    {% endif %}
                </dd>

                <dt class="col-sm-4">{{ 'dora_exit_plan.field.estimated_duration_days'|trans({}, 'dora_exit_plan') }}</dt>
                <dd class="col-sm-8">{{ plan.estimatedDurationDays ?? '—' }}</dd>

                <dt class="col-sm-4">{{ 'dora_exit_plan.field.estimated_cost'|trans({}, 'dora_exit_plan') }}</dt>
                <dd class="col-sm-8">{{ plan.estimatedCost ?? '—' }}</dd>
            </dl>
        {% endblock %}
    {% endembed %}

    <form method="post" action="{{ path('app_dora_exit_plan_delete', {id: plan.id}) }}" class="mt-3" onsubmit="return confirm('{{ 'common.confirm_delete'|trans({}, 'messages') }}');">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ plan.id) }}">
        <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger fa-cyber-btn--ghost">
            <i class="fa-icon fa-icon--ui-trash" aria-hidden="true"></i>
            {{ 'common.delete'|trans({}, 'messages') }}
        </button>
    </form>
</div>
{% endblock %}
