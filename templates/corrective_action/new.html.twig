{% extends 'base.html.twig' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'corrective_action.page.new'|trans({}, 'audits') }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'audit_finding.page.title'|trans({}, 'audits'), url: path('app_audit_finding_index') },
            { label: 'corrective_action.page.title'|trans({}, 'audits'), url: path('app_corrective_action_index') },
            { label: 'corrective_action.page.new'|trans({}, 'audits') }
        ]
    } %}
    {{ _fa_page_header.render({
        title: 'corrective_action.page.new'|trans({}, 'audits'),
        badge: { icon: 'plus', label: '' }
    }) }}
    {% if finding %}
        <p class="text-muted mb-3">
            {{ 'corrective_action.message.for_finding'|trans({}, 'audits') }}:
            <a href="{{ path('app_audit_finding_show', {id: finding.id}) }}">{{ finding.(findingNumber ?? ('#' ~ finding.id)) }} — {{ finding.title }}</a>
        </p>
    {% endif %}
    {% embed '_components/_card.html.twig' %}
        {% block card_body %}
            {% include 'corrective_action/_form.html.twig' with {form: form} %}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
