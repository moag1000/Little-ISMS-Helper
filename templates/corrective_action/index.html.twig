{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}

{% block title %}{{ 'corrective_action.page.title'|trans({}, 'audits') }}{% endblock %}

{% block body %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
{% include '_components/_breadcrumb.html.twig' with {
    breadcrumbs: [
        { label: 'audit_finding.page.title'|trans({}, 'audits'), url: path('app_audit_finding_index') },
        { label: 'corrective_action.page.title'|trans({}, 'audits') }
    ]
} %}
{{ _fa_page_header.render({
    badge: { icon: 'tools', label: 'corrective_action.page.title'|trans({}, 'audits') },
    title: 'corrective_action.page.title'|trans({}, 'audits'),
    actions: [
        { label: 'corrective_action.action.new'|trans({}, 'audits'), href: path('app_corrective_action_new'), variant: 'primary', icon: 'plus-lg' }
    ]
}) }}
<main class="fa-aurora-surface">
<div class="container-fluid py-4">

    {% if overdue_count > 0 %}
        {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning', icon: 'bi-exclamation-triangle' } } %}
            {% block alert_body %}{{ 'corrective_action.alert.overdue'|trans({'%count%': overdue_count}, 'audits') }}{% endblock %}
        {% endembed %}
    {% endif %}

    {% embed '_components/_card.html.twig' with { 'noPadding': true } %}
        {% block card_body %}
            {% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
            {% if actions is empty %}
                {{ _fa_empty_state.render({
                    mood: 'sleeping',
                    title: 'corrective_action.message.none'|trans({}, 'audits')
                }) }}
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                        <tr>
                            <th scope="col">{{ 'corrective_action.field.title'|trans({}, 'audits') }}</th>
                            <th scope="col">{{ 'corrective_action.field.finding'|trans({}, 'audits') }}</th>
                            <th scope="col">{{ 'corrective_action.field.status'|trans({}, 'audits') }}</th>
                            <th scope="col">{{ 'corrective_action.field.responsible_person'|trans({}, 'audits') }}</th>
                            <th scope="col">{{ 'corrective_action.field.planned_completion_date'|trans({}, 'audits') }}</th>
                            <th scope="col" class="text-end">{{ 'common.actions'|trans({}, 'messages') }}</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for a in actions %}
                            <tr>
                                <td>{{ a.title }}</td>
                                <td>{% if a.finding %}<a href="{{ path('app_audit_finding_show', {id: a.finding.id}) }}">{{ a.finding.(findingNumber ?? ('#' ~ a.finding.id)) }}</a>{% else %}—{% endif %}</td>
                                {% set _csp = a.status in ['verified_effective'] ? 'success' : (a.status == 'verified_ineffective' ? 'danger' : 'primary') %}
                                <td><span class="fa-status-pill fa-status-pill--{{ _csp }}">{{ ('corrective_action.status.' ~ a.status)|trans({}, 'audits') }}</span></td>
                                <td>{{ a.responsiblePerson ? a.responsiblePerson.fullName : '—' }}</td>
                                <td>
                                    {% if a.plannedCompletionDate %}
                                        <span {% if a.isOverdue %}class="text-danger fw-bold"{% endif %}>
                                            {{ a.plannedCompletionDate|date('Y-m-d') }}
                                        </span>
                                    {% else %}—{% endif %}
                                </td>
                                <td class="text-end">
                                    <a href="{{ path('app_corrective_action_show', {id: a.id}) }}" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">
                                        <i class="bi bi-eye" aria-hidden="true"></i>
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        {% endblock %}
    {% endembed %}
</div>
</main>
{% endblock %}
