{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% import '_components/_fa_entity_card.html.twig' as _fa_entity_card %}

{% block title %}{{ 'corrective_action.page.title'|trans({}, 'audits') }}{% endblock %}

{% block body %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}
{% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
{% include '_components/_breadcrumb.html.twig' with {
    breadcrumbs: [
        { label: 'audit_finding.page.title'|trans({}, 'audits'), url: path('app_audit_finding_index') },
        { label: 'corrective_action.page.title'|trans({}, 'audits') }
    ]
} %}
{{ _fa_page_header.render({
    badge: { icon: 'tools', label: 'corrective_action.page.title'|trans({}, 'audits') },
    title: 'corrective_action.page.title'|trans({}, 'audits'),
    actions: [
        { label: 'corrective_action.action.new'|trans({}, 'audits'), href: path('app_corrective_action_new'), variant: 'primary', icon: 'plus-lg' }
    ]
}) }}
<main class="fa-aurora-surface">
<div class="container-fluid py-4">

    {% if overdue_count > 0 %}
        {% embed '_components/_fa_alert.html.twig' with { props: { variant: 'warning', icon: 'bi-exclamation-triangle' } } %}
            {% block alert_body %}{{ 'corrective_action.alert.overdue'|trans({'%count%': overdue_count}, 'audits') }}{% endblock %}
        {% endembed %}
    {% endif %}

    {% if actions is empty %}
        {{ _fa_empty_state.render({
            mood: 'sleeping',
            title: 'corrective_action.message.none'|trans({}, 'audits')
        }) }}
    {% else %}
        <div class="d-flex flex-column gap-2">
            {% for a in actions %}
                {% set _statusVariant = a.status == 'verified_effective' ? 'success'
                    : (a.status == 'verified_ineffective' ? 'danger'
                    : (a.status in ['completed', 'closed'] ? 'success'
                    : (a.status == 'in_progress' ? 'warning'
                    : (a.status == 'planned' ? 'info' : 'neutral')))) %}
                {% set _meta = [] %}
                {% if a.finding %}
                    {% set _meta = _meta|merge([a.finding.findingNumber ?? ('#' ~ a.finding.id)]) %}
                {% endif %}
                {% if a.effectiveResponsiblePerson %}
                    {% set _meta = _meta|merge([a.effectiveResponsiblePerson]) %}
                {% endif %}
                {% if a.plannedCompletionDate %}
                    {% set _meta = _meta|merge([
                        (a.isOverdue ? '⚠ ' : '') ~ a.plannedCompletionDate|date('Y-m-d')
                    ]) %}
                {% endif %}
                {{ _fa_entity_card.render({
                    type:   'nonconformity',
                    icon:   'nonconformity',
                    title:  a.title,
                    meta:   _meta,
                    href:   path('app_corrective_action_show', {id: a.id}),
                    status: { variant: _statusVariant, label: ('corrective_action.status.' ~ a.status)|trans({}, 'audits') }
                }) }}
            {% endfor %}
        </div>
    {% endif %}
</div>
</main>
{% endblock %}
