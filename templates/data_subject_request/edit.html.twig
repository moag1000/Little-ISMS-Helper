{% extends 'base.html.twig' %}
{% trans_default_domain 'data_subject_request' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'dsr.page.edit_title'|trans({}, 'data_subject_request') }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'dsr.breadcrumb.privacy'|trans({}, 'data_subject_request'), icon: 'nav-shield-lock' },
            { label: 'dsr.breadcrumb.data_subject_requests'|trans({}, 'data_subject_request'), url: path('app_data_subject_request_index') },
            { label: '#' ~ dsr.id, url: path('app_data_subject_request_show', {id: dsr.id}) },
            { label: 'dsr.page.edit_title'|trans({}, 'data_subject_request') }
        ]
    } only %}

    {{ _fa_page_header.render({
        title: 'dsr.page.edit_title'|trans({}, 'data_subject_request'),
        subtitle: dsr.dataSubjectName ~ ' - ' ~ ('dsr.type.' ~ dsr.requestType)|trans({}, 'data_subject_request'),
        badge: { icon: 'ui-edit', label: '' },
        actions: [
            { label: 'common.cancel'|trans({}, 'messages'), href: path('app_data_subject_request_show', {id: dsr.id}), variant: 'secondary', icon: 'ui-close' }
        ]
    }) }}

    {{ form_start(form) }}
    {% include '_components/_auto_form.html.twig' with {
        'form': form,
        'layout': 'outline-rail',
        'eyebrow': 'GDPR · Art. 12-22 · Data Subject Rights',
        'title': 'dsr.page.edit_title'|trans({}, 'data_subject_request'),
        'subtitle': dsr.dataSubjectName ~ ' - ' ~ ('dsr.type.' ~ dsr.requestType)|trans({}, 'data_subject_request'),
        'sections': {
            'request_details': {
                'label': 'dsr.section.request_details'|trans({}, 'data_subject_request'),
                'fields': ['requestType', 'receivedAt', 'description']
            },
            'data_subject_info': {
                'label': 'dsr.section.data_subject_info'|trans({}, 'data_subject_request'),
                'fields': ['dataSubjectName', 'dataSubjectEmail', 'dataSubjectIdentifier']
            },
            'identity_verification': {
                'label': 'dsr.section.identity_verification'|trans({}, 'data_subject_request'),
                'fields': ['identityVerified', 'identityVerificationMethod']
            },
            'assignment': {
                'label': 'dsr.section.assignment'|trans({}, 'data_subject_request'),
                'fields': ['assignedTo', 'assignedPerson', 'assignedDeputyPersons', 'dpoPerson', 'processingActivity']
            },
            'response_tracking': {
                'label': 'dsr.section.response_tracking'|trans({}, 'data_subject_request'),
                'fields': ['responseAt', 'responseMethod', 'responseDocument', 'extendedDeadlineAt', 'extensionReason', 'rejectionReason']
            },
            'internal': {
                'label': 'dsr.section.internal_notes'|trans({}, 'data_subject_request'),
                'fields': ['notes']
            }
        },
        'col_widths': {
            'requestType': 6,
            'receivedAt': 6,
            'description': 12,
            'dataSubjectName': 4,
            'dataSubjectEmail': 4,
            'dataSubjectIdentifier': 4,
            'identityVerified': 6,
            'identityVerificationMethod': 6,
            'assignedTo': 6,
            'assignedPerson': 6,
            'assignedDeputyPersons': 12,
            'dpoPerson': 6,
            'processingActivity': 6,
            'responseAt': 6,
            'responseMethod': 6,
            'responseDocument': 12,
            'extendedDeadlineAt': 6,
            'extensionReason': 6,
            'rejectionReason': 12,
            'notes': 12
        },
        'translation_domain': 'data_subject_request',
        'actions': {
            'close': { 'label': 'common.cancel'|trans({}, 'messages'), 'variant': 'ghost' },
            'submit': { 'label': 'dsr.action.save'|trans({}, 'data_subject_request'), 'variant': 'primary' }
        }
    } %}
    {{ form_end(form) }}
</div>
{% endblock %}
