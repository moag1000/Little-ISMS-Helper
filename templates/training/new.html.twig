{% extends 'base.html.twig' %}
{% trans_default_domain 'training' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{#
    Field renamed: 'duration' -> 'durationMinutes' to match TrainingType.
    TODO: SOLUTIONS_P0 P0-11 — re-add 'location' to schedule-section once the
    field is added to TrainingType. Translation keys retained as anchors.
#}

{% block title %}{{ 'training.new'|trans({}, 'training') }}{% endblock %}

{% block body %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.training'|trans({}, 'nav'), url: path('app_training_index') },
            { label: 'training.new'|trans({}, 'training') }
        ]
    } %}

    {{ _fa_page_header.render({
        title: 'training.new'|trans({}, 'training'),
        badge: { icon: 'plus', label: '' },
        actions: [
            { label: 'common.back_to_list'|trans({}, 'messages'), href: path('app_training_index'), variant: 'ghost', icon: 'util-arrow-left' }
        ]
    }) }}

    {# P-19 — Form-Step-Inline-Hint controller. See assets/controllers/alva_hint_in_form_controller.js. #}
    {{ form_start(form, {'attr': {
        'data-controller': 'alva-hint-in-form',
        'data-alva-hint-in-form-entity-type-value': 'training',
        'data-alva-hint-in-form-form-name-value': 'training',
        'data-alva-hint-in-form-endpoint-value': path('api_alva_hint_form_evaluate', {'entityType': 'training'}),
        'data-alva-hint-in-form-csrf-token-value': csrf_token('alva_hint_form'),
        'data-action': 'input->alva-hint-in-form#scheduleEvaluate change->alva-hint-in-form#scheduleEvaluate',
    }}) }}
    {% include '_components/_auto_form.html.twig' with {
        'form': form,
        'layout': 'outline-rail',
        'eyebrow': 'ISO 27001 Cl. 7.2 · Awareness Training',
        'title': 'training.new'|trans({}, 'training'),
        'sections': {
            'overview': {
                'label': 'form.section.overview'|trans({}, 'messages'),
                'fields': ['title', 'description', 'trainingType', 'deliveryMethod']
            },
            'schedule': {
                'label': 'form.section.schedule'|trans({}, 'messages'),
                'fields': ['scheduledDate', 'durationMinutes', 'completionDate']
            },
            'audience': {
                'label': 'form.section.audience'|trans({}, 'messages'),
                'fields': ['targetAudience', 'participantUsers', 'participants']
            },
            'team': {
                'label': 'form.section.team'|trans({}, 'messages'),
                'fields': ['trainerUser', 'trainerPerson', 'trainerDeputyPersons', 'trainer']
            },
            'verification': {
                'label': 'form.section.verification'|trans({}, 'messages'),
                'fields': ['status', 'mandatory', 'coveredControls', 'complianceRequirements']
            },
            'resources': {
                'label': 'form.section.resources'|trans({}, 'messages'),
                'fields': ['materialFiles', 'materials', 'feedback']
            }
        },
        'col_widths': {
            'title': 12,
            'description': 12,
            'trainingType': 6,
            'deliveryMethod': 6,
            'scheduledDate': 6,
            'durationMinutes': 6,
            'completionDate': 6,
            'targetAudience': 6,
            'participantUsers': 12,
            'participants': 12,
            'trainerUser': 6,
            'trainerPerson': 6,
            'trainerDeputyPersons': 12,
            'trainer': 6,
            'status': 6,
            'mandatory': 6,
            'coveredControls': 12,
            'complianceRequirements': 12,
            'materialFiles': 12,
            'materials': 12,
            'feedback': 12
        },
        'actions': {
            'close': { 'label': 'common.cancel'|trans({}, 'messages'), 'variant': 'ghost' },
            'submit': { 'label': 'training.create'|trans({}, 'training'), 'variant': 'primary' }
        }
    } %}
    {{ form_end(form) }}
</div>
{% endblock %}
