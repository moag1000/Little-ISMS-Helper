{% extends 'base.html.twig' %}
{% trans_default_domain 'training' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'training.edit'|trans({}, 'training') }} - {{ training.title }}{% endblock %}

{% block body %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.training'|trans({}, 'nav'), url: path('app_training_index') },
            { label: training.title, url: path('app_training_show', {id: training.id}) },
            { label: 'common.edit'|trans({}, 'messages') }
        ]
    } %}

    {{ _fa_page_header.render({
        title: 'training.edit'|trans({}, 'training') ~ ': ' ~ training.title,
        badge: { icon: 'ui-edit', label: '' },
        actions: [
            { label: 'common.back'|trans({}, 'messages'), href: path('app_training_show', {id: training.id}), variant: 'ghost', icon: 'util-arrow-left' }
        ]
    }) }}

    {{ form_start(form) }}
    {% include '_components/_auto_form.html.twig' with {
        'form': form,
        'layout': 'outline-rail',
        'eyebrow': 'ISO 27001 Cl. 7.2 · Awareness Training',
        'title': training.title,
        'sections': {
            'overview': {
                'label': 'form.section.overview'|trans({}, 'messages'),
                'fields': ['title', 'description', 'trainingType', 'deliveryMethod']
            },
            'schedule': {
                'label': 'form.section.schedule'|trans({}, 'messages'),
                'fields': ['scheduledDate', 'durationMinutes', 'completionDate']
            },
            'audience': {
                'label': 'form.section.audience'|trans({}, 'messages'),
                'fields': ['targetAudience', 'participantUsers', 'participants']
            },
            'team': {
                'label': 'form.section.team'|trans({}, 'messages'),
                'fields': ['trainerUser', 'trainerPerson', 'trainerDeputyPersons', 'trainer']
            },
            'verification': {
                'label': 'form.section.verification'|trans({}, 'messages'),
                'fields': ['status', 'mandatory', 'coveredControls', 'complianceRequirements']
            },
            'resources': {
                'label': 'form.section.resources'|trans({}, 'messages'),
                'fields': ['materialFiles', 'materials', 'feedback']
            }
        },
        'col_widths': {
            'title': 12,
            'description': 12,
            'trainingType': 6,
            'deliveryMethod': 6,
            'scheduledDate': 6,
            'durationMinutes': 6,
            'completionDate': 6,
            'targetAudience': 6,
            'participantUsers': 12,
            'participants': 12,
            'trainerUser': 6,
            'trainerPerson': 6,
            'trainerDeputyPersons': 12,
            'trainer': 6,
            'status': 6,
            'mandatory': 6,
            'coveredControls': 12,
            'complianceRequirements': 12,
            'materialFiles': 12,
            'materials': 12,
            'feedback': 12
        },
        'actions': {
            'close': { 'label': 'common.cancel'|trans({}, 'messages'), 'variant': 'ghost' },
            'submit': { 'label': 'common.save_changes'|trans({}, 'messages'), 'variant': 'primary' }
        }
    } %}
    {{ form_end(form) }}
</div>
{% endblock %}
