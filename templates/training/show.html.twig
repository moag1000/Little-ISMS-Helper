{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% trans_default_domain 'training' %}

{% block title %}{{ training.title }} - {{ parent() }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="{{ path('app_training_index') }}" data-turbo-action="advance">
                    <i class="fa-icon fa-icon--training" aria-hidden="true"></i> {{ 'training.title'|trans({}, 'training')}}
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">{{ training.title }}</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-8">
            {# Main Training Information #}
            {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
                {% block card_header %}
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <h1 class="mb-0 h2">
                            <i class="fa-icon fa-icon--training" aria-hidden="true"></i> {{ training.title }}
                        </h1>
                        <span class="{{ badge_status(training.status) }} fs-6">
                            {{ ('training.status.' ~ training.status)|trans({}, 'training') }}
                        </span>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {# Mandatory Warning Banner #}
                    {% if training.mandatory %}
                    {{ _fa_alert.render({ variant: 'warning', icon: 'status-warning', class: 'mb-4', body: '<div class="alert-heading fw-bold"> <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> {{ \'training.mandatory_training\'|trans({}, \'training\')}} </div> <p class="mb-0">{{ \'training.mandatory_info\'|trans({}, \'training\')}}</p>' }) }}
                    {% endif %}

                    {# Description #}
                    {% if training.description %}
                    <div class="mb-4">
                        <h2><i class="bi bi-file-text" aria-hidden="true"></i> {{ 'training.description'|trans({}, 'training')}}</h2>
                        <p class="text-muted">{{ training.description|nl2br }}</p>
                    </div>
                    <hr>
                    {% endif %}

                    {# Training Details #}
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="text-muted mb-2 fw-semibold">{{ 'training.type_label'|trans({}, 'training')}}</div>
                            <p>
                                {% include '_components/_badge.html.twig' with { variant: 'secondary', class: 'fs-6', content: ('training.type.' ~ training.trainingType)|trans({}, 'training') } %}
                            </p>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted mb-2 fw-semibold">{{ 'training.delivery_method'|trans({}, 'training')}}</div>
                            <p>
                                {% if training.deliveryMethod %}
                                {% include '_components/_badge.html.twig' with { variant: 'info', class: 'fs-6', content: ('training.delivery.' ~ training.deliveryMethod)|trans({}, 'training') } %}
                                {% else %}
                                <span class="text-muted">-</span>
                                {% endif %}
                            </p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="text-muted mb-2 fw-semibold">
                                <i class="bi bi-calendar-event" aria-hidden="true"></i> {{ 'training.scheduled_date'|trans({}, 'training')}}
                            </div>
                            <p class="fs-5">{{ training.scheduledDate|date('d.m.Y') }}</p>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted mb-2 fw-semibold">
                                <i class="fa-icon fa-icon--status-pending" aria-hidden="true"></i> {{ 'training.duration'|trans({}, 'training')}}
                            </div>
                            <p class="fs-5">{{ training.durationMinutes ?? '-' }} {{ 'training.minutes'|trans({}, 'training')}}</p>
                        </div>
                    </div>

                    {% if training.targetAudience %}
                    <div class="mb-3">
                        <div class="text-muted mb-2 fw-semibold">
                            <i class="bi bi-bullseye" aria-hidden="true"></i> {{ 'training.target_audience'|trans({}, 'training')}}
                        </div>
                        <p>{{ training.targetAudience }}</p>
                    </div>
                    {% endif %}

                    {% if training.trainer %}
                    <div class="mb-3">
                        <div class="text-muted mb-2 fw-semibold">
                            <i class="fa-icon fa-icon--role" aria-hidden="true"></i> {{ 'training.trainer'|trans({}, 'training')}}
                        </div>
                        <p>{{ training.effectiveTrainer }}</p>
                    </div>
                    {% endif %}
                {% endblock %}
            {% endembed %}

            {# Participants Section #}
            {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
                {% block card_header %}
                    <div class="card-header bg-body-secondary">
                        <h2 class="mb-0">
                            <i class="fa-icon fa-icon--group" aria-hidden="true"></i> {{ 'training.participants'|trans({}, 'training')}}
                            {% include '_components/_badge.html.twig' with { variant: 'primary', content: training.attendeeCount ?? 0 } %}
                        </h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    {% if training.participants %}
                    <p>{{ training.participants|nl2br }}</p>
                    {% else %}
                    <p class="text-muted mb-0">
                        <i class="bi bi-info-circle" aria-hidden="true"></i> {{ 'training.no_participants'|trans({}, 'training')}}
                    </p>
                    {% endif %}
                {% endblock %}
            {% endembed %}

            {# Materials Section #}
            {% if training.materials %}
            {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
                {% block card_header %}
                    <div class="card-header bg-body-secondary">
                        <h2 class="mb-0">
                            <i class="fa-icon fa-icon--policy" aria-hidden="true"></i> {{ 'training.materials'|trans({}, 'training')}}
                        </h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <p>{{ training.materials|nl2br }}</p>
                {% endblock %}
            {% endembed %}
            {% endif %}

            {# Feedback Section #}
            {% if training.feedback %}
            {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
                {% block card_header %}
                    <div class="card-header bg-body-secondary">
                        <h2 class="mb-0">
                            <i class="bi bi-chat-left-text" aria-hidden="true"></i> {{ 'training.feedback'|trans({}, 'training')}}
                        </h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <p>{{ training.feedback|nl2br }}</p>
                {% endblock %}
            {% endembed %}
            {% endif %}
        </div>

        <div class="col-lg-4">
            {# Action Buttons #}
            {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
                {% block card_header %}
                    <div class="card-header bg-body-secondary">
                        <h2 class="mb-0"><i class="bi bi-tools" aria-hidden="true"></i> {{ 'common.actions'|trans({}, 'messages') }}</h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="d-grid gap-2">
                        {% if is_granted('ROLE_USER') %}
                        <a href="{{ path('app_training_edit', {id: training.id}) }}"
                           class="fa-cyber-btn fa-cyber-btn--primary"
                           data-turbo-action="advance">
                            <i class="bi bi-pencil" aria-hidden="true"></i> {{ 'common.edit'|trans({}, 'messages') }}
                        </a>
                        {% endif %}

                        <a href="{{ path('app_training_index') }}"
                           class="fa-cyber-btn fa-cyber-btn--ghost"
                           data-turbo-action="advance">
                            <i class="bi bi-arrow-left" aria-hidden="true"></i> {{ 'common.back_to_list'|trans({}, 'messages') }}
                        </a>

                        {% if is_granted('ROLE_ADMIN') %}
                        <hr>
                        <button type="button"
                                class="fa-cyber-btn fa-cyber-btn--danger"
                                data-bs-toggle="modal"
                                data-bs-target="#deleteModal">
                            <i class="bi bi-trash" aria-hidden="true"></i> {{ 'common.delete'|trans({}, 'messages') }}
                        </button>
                        {% endif %}
                    </div>
                {% endblock %}
            {% endembed %}

            {# Data Reuse: Covered Controls #}
            {% if training.coveredControls is defined and training.coveredControls|length > 0 %}
            {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
                {% block card_header %}
                    <div class="card-header bg-body-secondary">
                        <h2 class="mb-0">
                            <i class="fa-icon fa-icon--compliance-shield" aria-hidden="true"></i> {{ 'training.covered_controls'|trans({}, 'training')}}
                            {% include '_components/_badge.html.twig' with { variant: 'primary', content: training.coveredControls|length } %}
                        </h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="list-group list-group-flush">
                        {% for control in training.coveredControls %}
                        <div class="list-group-item px-0">
                            <div class="d-flex w-100 justify-content-between align-items-start">
                                <div>
                                    <div class="mb-1">{% include '_components/_iso_reference_label.html.twig' with { control: control, show_name: false, code_class: 'fw-bold' } only %}</div>
                                    <p class="mb-1 small text-muted">{{ control.name }}</p>
                                </div>
                                <span class="{{ badge_status(control.implementationStatus) }} rounded-pill">
                                    {{ control.implementationStatus|upper }}
                                </span>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                {% endblock %}
            {% endembed %}
            {% endif %}

            {# Data Reuse: Compliance Coverage #}
            {% if training.complianceRequirements is defined and training.complianceRequirements|length > 0 %}
            {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
                {% block card_header %}
                    <div class="card-header bg-body-secondary">
                        <h2 class="mb-0">
                            <i class="fa-icon fa-icon--audit-internal" aria-hidden="true"></i> {{ 'training.compliance_coverage'|trans({}, 'training') }}
                            {% include '_components/_badge.html.twig' with { variant: 'success', content: training.complianceRequirements|length } %}
                        </h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <p class="small text-muted mb-2">{{ 'training.compliance_coverage_info'|trans({}, 'training') }}</p>
                    <div class="d-flex flex-wrap gap-2">
                        {% for requirement in training.complianceRequirements %}
                            {% include '_components/_badge.html.twig' with { variant: 'info', content: (requirement.framework ? requirement.framework.name : 'N/A') ~ ' ' ~ requirement.requirementId } %}
                        {% endfor %}
                    </div>
                {% endblock %}
            {% endembed %}
            {% endif %}

            {# Data Reuse: Training Statistics #}
            {% if training.status == 'completed' %}
            {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
                {% block card_header %}
                    <div class="card-header bg-body-secondary">
                        <h2 class="mb-0">
                            <i class="bi bi-graph-up" aria-hidden="true"></i> {{ 'training.statistics'|trans({}, 'training') }}
                        </h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="small text-muted">{{ 'training.completion_rate'|trans({}, 'training') }}</span>
                            <span class="small fw-bold">100%</span>
                        </div>
                        <div class="progress progress-h-8">
                            <div class="progress-bar bg-success" style="width: 100%"></div>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between small">
                        <span class="text-muted">{{ 'training.attendee_count'|trans({}, 'training') }}:</span>
                        <span class="fw-bold">{{ training.attendeeCount ?? 0 }}</span>
                    </div>
                    {% if training.completionDate %}
                    <div class="d-flex justify-content-between small mt-2">
                        <span class="text-muted">{{ 'training.completed_on'|trans({}, 'training') }}:</span>
                        <span class="fw-bold">{{ training.completionDate|date('d.m.Y') }}</span>
                    </div>
                    {% endif %}
                {% endblock %}
            {% endembed %}
            {% endif %}

            {# Metadata #}
            {% embed '_components/_card.html.twig' with { 'class': 'mb-4' } %}
                {% block card_header %}
                    <div class="card-header bg-body-secondary">
                        <h2 class="mb-0"><i class="bi bi-info-circle" aria-hidden="true"></i> {{ 'common.metadata'|trans({}, 'messages') }}</h2>
                    </div>
                {% endblock %}
                {% block card_body %}
                    <dl class="row mb-0 small">
                        <dt class="col-sm-5 text-muted">{{ 'common.created_at'|trans({}, 'messages') }}</dt>
                        <dd class="col-sm-7">{{ training.createdAt|date('d.m.Y H:i') }}</dd>

                        {% if training.updatedAt %}
                        <dt class="col-sm-5 text-muted">{{ 'common.updated_at'|trans({}, 'messages') }}</dt>
                        <dd class="col-sm-7">{{ training.updatedAt|date('d.m.Y H:i') }}</dd>
                        {% endif %}
                    </dl>
                {% endblock %}
            {% endembed %}
        </div>
    </div>
</div>

{# Delete Confirmation Modal #}
{% if is_granted('ROLE_ADMIN') %}
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h2 class="modal-title h5" id="deleteModalLabel">
                    <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> {{ 'training.confirm_delete'|trans({}, 'training')}}
                </h2>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="{{ 'common.close'|trans({}, 'messages') }}"></button>
            </div>
            <div class="modal-body">
                <p>{{ 'training.delete_warning'|trans({'%title%': training.title}, 'training') }}</p>
                <p class="text-muted"><small>{{ 'common.action_irreversible'|trans({}, 'messages') }}</small></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    {{ 'common.cancel'|trans({}, 'messages') }}
                </button>
                <form method="post" action="{{ path('app_training_delete', {id: training.id}) }}" class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ training.id) }}">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash" aria-hidden="true"></i> {{ 'common.delete'|trans({}, 'messages') }}
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endif %}
{% endblock %}
