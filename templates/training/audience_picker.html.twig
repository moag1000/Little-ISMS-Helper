{% extends 'base.html.twig' %}
{% trans_default_domain 'alva' %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% block title %}{{ 'training.mandatory_audience.picker_title'|trans({}, 'alva') }}{% endblock %}

{% block body %}
<div class="container">
    {% include '_components/_breadcrumb.html.twig' with {
        breadcrumbs: [
            { label: 'nav.training'|trans({}, 'nav'), url: path('app_training_index') },
            { label: training.title, url: path('app_training_show', {id: training.id}) },
            { label: 'training.mandatory_audience.picker_breadcrumb'|trans({}, 'alva') }
        ]
    } %}

    {{ _fa_page_header.render({
        title: 'training.mandatory_audience.picker_title'|trans({}, 'alva'),
        subtitle: 'training.mandatory_audience.picker_subtitle'|trans({}, 'alva'),
        actions: [
            { label: 'action.back_to_list'|trans({}, 'messages'), variant: 'ghost', href: path('app_training_show', {id: training.id}) }
        ]
    }) }}

    <form method="post" action="{{ path('app_training_audience_picker', {id: training.id}) }}">
        <section class="fa-section">
            <header class="fa-section__header">
                <h2 class="fa-section__title">{{ 'training.mandatory_audience.picker_section_title'|trans({}, 'alva') }}</h2>
            </header>
            <div class="fa-section__body">
                {% if candidates is empty %}
                    <p class="text-muted">{{ 'training.mandatory_audience.no_candidates'|trans({}, 'alva') }}</p>
                {% else %}
                    <div class="mb-2">
                        <input type="text" id="audience-filter" class="form-control form-control-sm"
                               placeholder="{{ 'training.mandatory_audience.filter_placeholder'|trans({}, 'alva') }}">
                    </div>
                    <div class="d-flex flex-column gap-2" id="audience-list">
                    {% for u in candidates %}
                        <label class="d-flex align-items-start gap-2 audience-row"
                               data-haystack="{{ (u.email ~ ' ' ~ (u.fullName ?? ''))|lower }}">
                            <input type="checkbox" name="user_ids[]" value="{{ u.id }}"
                                   {% if u.id in already_assigned_ids %}checked disabled{% endif %}>
                            <span>
                                <strong>{{ u.email }}</strong>
                                {% if u.fullName is defined and u.fullName %}
                                    <span class="text-muted ms-2">{{ u.fullName }}</span>
                                {% endif %}
                                {% if u.id in already_assigned_ids %}
                                    <span class="badge bg-secondary ms-2">
                                        {{ 'training.mandatory_audience.already_assigned'|trans({}, 'alva') }}
                                    </span>
                                {% endif %}
                            </span>
                        </label>
                    {% endfor %}
                    </div>
                    <div class="mt-3">
                        <button class="fa-cyber-btn fa-cyber-btn--primary" type="submit">
                            {{ 'training.mandatory_audience.save'|trans({}, 'alva') }}
                        </button>
                    </div>
                {% endif %}
            </div>
        </section>
    </form>
</div>

<script>
(() => {
    const input = document.getElementById('audience-filter');
    if (!input) return;
    input.addEventListener('input', () => {
        const needle = input.value.trim().toLowerCase();
        document.querySelectorAll('.audience-row').forEach(row => {
            const hay = row.getAttribute('data-haystack') || '';
            row.style.display = (needle === '' || hay.includes(needle)) ? '' : 'none';
        });
    });
})();
</script>
{% endblock %}
