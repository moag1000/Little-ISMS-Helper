{% extends 'base.html.twig' %}
{% import '_components/_fa_alert.html.twig' as _fa_alert %}
{% trans_default_domain 'training' %}
{% import '_macros/inheritance_badge.html.twig' as inheritance %}

{% block title %}{{ 'training.title'|trans({}, 'training') }} - {{ parent() }}{% endblock %}

{% block body %}
{% import '_components/_fa_page_header.html.twig' as _fa_page_header %}

{% include '_components/_breadcrumb.html.twig' with {
    breadcrumbs: [
        { label: 'training.title'|trans({}, 'training') }
    ]
} %}

{{ _fa_page_header.render({
    badge: { icon: 'mortarboard', label: 'nav.training'|trans({}, 'nav') },
    title: 'training.title'|trans({}, 'training'),
    actions: is_granted('ROLE_USER') ? [
        { label: 'training.new'|trans({}, 'training'), variant: 'primary', icon: 'plus-lg', href: path('app_training_new') }
    ] : []
}) }}

<main class="fa-aurora-surface">
<div class="container-fluid py-4">

    {# View Filter #}
    {% if currentTenant %}
    {% embed '_components/_card.html.twig' with {
        'class': 'mb-3'
    } %}
        {% block card_body %}
            <form method="get" action="{{ path('app_training_index') }}" class="d-flex align-items-center gap-2">
                <label for="view-filter" class="mb-0 fw-bold">
                    <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i> {{ 'common.view'|trans({}, 'messages') }}:
                </label>
                <select class="form-select form-select-sm w-auto" id="view-filter" name="view" data-controller="ui-actions" data-action="change->ui-actions#autoSubmit">
                    <option value="own" {{ inheritanceInfo.currentView == 'own' ? 'selected' : '' }}>
                        {{ 'corporate.view.own_only'|trans({}, 'messages') }}
                    </option>
                    {% if inheritanceInfo.hasParent %}
                    <option value="inherited" {{ inheritanceInfo.currentView == 'inherited' ? 'selected' : '' }}>
                        {{ 'corporate.view.including_inherited'|trans({}, 'messages') }}
                    </option>
                    {% endif %}
                    {% if inheritanceInfo.hasSubsidiaries %}
                    <option value="subsidiaries" {{ inheritanceInfo.currentView == 'subsidiaries' ? 'selected' : '' }}>
                        {{ 'corporate.view.including_subsidiaries'|trans({}, 'messages') }}
                    </option>
                    {% endif %}
                </select>
                <noscript>
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm">{{ 'common.apply'|trans({}, 'messages') }}</button>
                </noscript>
            </form>
        {% endblock %}
    {% endembed %}
    {% endif %}

    {# Statistics Cards #}
    <turbo-frame id="training-stats">
        <div class="row mb-4">
            <div class="col-md-3 mb-3">
                {% embed '_components/_card.html.twig' with {borderColor: 'primary'} %}
                    {% block card_body %}
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <i class="fa-icon fa-icon--nav-collection text-primary icon-2rem" aria-hidden="true"></i>
                            </div>
                            <div class="ms-3">
                                <div class="text-muted mb-1 fw-semibold">{{ 'training.stats.total'|trans({}, 'training') }}</div>
                                <div class="h2 mb-0">
                                    <span id="training-total-count">{{ detailedStats.total }}</span>
                                </div>
                                {% if currentTenant %}
                                    <small class="text-muted d-block small opacity-75">
                                        {{ 'corporate.stats.breakdown'|trans({'%own%': detailedStats.own, '%inherited%': detailedStats.inherited, '%subsidiaries%': detailedStats.subsidiaries}, 'messages') }}
                                    </small>
                                {% endif %}
                            </div>
                        </div>
                    {% endblock %}
                {% endembed %}
            </div>

            <div class="col-md-3 mb-3">
                {% embed '_components/_card.html.twig' with {borderColor: 'info'} %}
                    {% block card_body %}
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <i class="fa-icon fa-icon--nav-calendar-check text-info icon-2rem" aria-hidden="true"></i>
                            </div>
                            <div class="ms-3">
                                <div class="text-muted mb-1 fw-semibold">{{ 'training.stats.upcoming'|trans({}, 'training') }}</div>
                                <div class="h3 mb-0">
                                    <span id="training-upcoming-count">{{ statistics.upcoming ?? 0 }}</span>
                                </div>
                            </div>
                        </div>
                    {% endblock %}
                {% endembed %}
            </div>

            <div class="col-md-3 mb-3">
                {% embed '_components/_card.html.twig' with {borderColor: 'success'} %}
                    {% block card_body %}
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <i class="fa-icon fa-icon--status-ok icon-2rem" aria-hidden="true"></i>
                            </div>
                            <div class="ms-3">
                                <div class="text-muted mb-1 fw-semibold">{{ 'training.stats.completed'|trans({}, 'training') }}</div>
                                <div class="h3 mb-0">
                                    <span id="training-completed-count">{{ statistics.completed ?? 0 }}</span>
                                </div>
                            </div>
                        </div>
                    {% endblock %}
                {% endembed %}
            </div>

            <div class="col-md-3 mb-3">
                {% embed '_components/_card.html.twig' with {borderColor: 'warning'} %}
                    {% block card_body %}
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <i class="fa-icon fa-icon--status-warning icon-2rem" aria-hidden="true"></i>
                            </div>
                            <div class="ms-3">
                                <div class="text-muted mb-1 fw-semibold">{{ 'training.stats.mandatory'|trans({}, 'training') }}</div>
                                <div class="h3 mb-0">
                                    <span id="training-mandatory-count">{{ statistics.mandatory ?? 0 }}</span>
                                </div>
                            </div>
                        </div>
                    {% endblock %}
                {% endembed %}
            </div>
        </div>
    </turbo-frame>

    {# Upcoming Trainings Section #}
    {% if upcoming|length > 0 %}
    {% embed '_components/_card.html.twig' with {class: 'mb-4', borderColor: 'info'} %}
        {% block card_header %}
            <div class="card-header bg-info text-white">
                <h2 class="mb-0"><i class="fa-icon fa-icon--ui-calendar-event" aria-hidden="true"></i> {{ 'training.upcoming_trainings'|trans({}, 'training') }}</h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% embed '_components/_table.html.twig' with {
                'noMargin': false
            } %}
                {% import '_macros/inheritance_badge.html.twig' as inheritance %}
                {% block table_head %}
                    <tr>
                        <th scope="col">{{ 'training.title'|trans({}, 'training') }}</th>
                        <th scope="col">{{ 'training.type_label'|trans({}, 'training') }}</th>
                        <th scope="col">{{ 'training.scheduled_date'|trans({}, 'training') }}</th>
                        <th scope="col">{{ 'training.delivery_method'|trans({}, 'training') }}</th>
                        <th scope="col">{{ 'training.mandatory'|trans({}, 'training') }}</th>
                        <th scope="col">{{ 'common.actions'|trans({}, 'messages') }}</th>
                    </tr>
                {% endblock %}
                {% block table_body %}
                    {% for training in upcoming %}
                    <tr>
                        <td>
                            <strong>{{ training.title }}</strong>
                            {{ inheritance.small_badge(training, currentTenant) }}
                            {% if training.mandatory %}
                            {% include '_components/_badge.html.twig' with { variant: 'warning', icon: 'bi-exclamation-circle', content: 'training.mandatory_label'|trans({}, 'training'), class: 'ms-1' } %}
                            {% endif %}
                        </td>
                        <td>
                            {% include '_components/_badge.html.twig' with { variant: 'secondary', content: ('training.type.' ~ training.trainingType)|trans({}, 'training') } %}
                        </td>
                        <td>
                            <i class="fa-icon fa-icon--ui-clock" aria-hidden="true"></i>
                            {{ training.scheduledDate|date('d.m.Y') }}
                        </td>
                        <td>{{ ('training.delivery.' ~ training.deliveryMethod)|trans({}, 'training') }}</td>
                        <td>
                            {% if training.mandatory %}
                            <span class="text-warning"><i class="fa-icon fa-icon--status-ok" aria-hidden="true"></i> {{ 'common.yes'|trans({}, 'messages') }}</span>
                            {% else %}
                            <span class="text-muted">{{ 'common.no'|trans({}, 'messages') }}</span>
                            {% endif %}
                        </td>
                        <td>
                            <a href="{{ path('app_training_show', {id: training.id}) }}"
                               class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
                               data-turbo-action="advance">
                                <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i> {{ 'common.view'|trans({}, 'messages') }}
                            </a>
                        </td>
                    </tr>
                    {% endfor %}
                {% endblock %}
            {% endembed %}
        {% endblock %}
    {% endembed %}
    {% endif %}

    {# All Trainings Section #}
    {% embed '_components/_card.html.twig' %}
        {% block card_attrs %}data-controller="bulk-actions" data-bulk-actions-endpoint-value="/training"{% endblock %}
        {% block card_header %}
            <div class="card-header bg-primary text-white">
                <h2 class="mb-0"><i class="fa-icon fa-icon--ui-list" aria-hidden="true"></i> {{ 'training.all_trainings'|trans({}, 'training') }}</h2>
            </div>
        {% endblock %}
        {% block card_body %}
            {% if trainings|length == 0 %}
            {% import '_components/_fa_empty_state.html.twig' as _fa_empty_state %}
            {{ _fa_empty_state.render({
                mood: 'sleeping',
                title: 'training.no_trainings'|trans({}, 'training'),
                actions: is_granted('ROLE_USER') ? [
                    { label: 'training.create_first'|trans({}, 'training'), variant: 'primary', icon: 'plus-lg', href: path('app_training_new') }
                ] : []
            }) }}
            {% else %}
            {% embed '_components/_table.html.twig' with {
                'variant': 'striped'
            } %}
                {% import '_macros/inheritance_badge.html.twig' as inheritance %}
                {% block table_head %}
                    <tr>
                        <th scope="col" class="w-40px">
                            <input type="checkbox"
                                   class="form-check-input"
                                   data-action="bulk-actions#selectAll"
                                   data-bulk-actions-target="selectAllCheckbox"
                                   aria-label="{{ 'common.select_all'|trans({}, 'messages') }}">
                        </th>
                        <th scope="col">{{ 'training.title'|trans({}, 'training') }}</th>
                        <th scope="col">{{ 'training.type_label'|trans({}, 'training') }}</th>
                        <th scope="col">{{ 'training.scheduled_date'|trans({}, 'training') }}</th>
                        <th scope="col">{{ 'training.duration'|trans({}, 'training') }}</th>
                        <th scope="col">{{ 'training.status_label'|trans({}, 'training') }}</th>
                        <th scope="col">{{ 'training.participants_count'|trans({}, 'training') }}</th>
                        <th scope="col">{{ 'common.actions'|trans({}, 'messages') }}</th>
                    </tr>
                {% endblock %}
                {% block table_body %}
                    {% for training in trainings %}
                    <tr data-training-id="{{ training.id }}">
                        <td>
                            <input type="checkbox"
                                   class="form-check-input"
                                   data-bulk-actions-target="item"
                                   data-action="bulk-actions#selectItem"
                                   value="{{ training.id }}">
                        </td>
                        <td>
                            <strong>{{ training.title }}</strong>
                            {{ inheritance.small_badge(training, currentTenant) }}
                            {% if training.mandatory %}
                            {% include '_components/_badge.html.twig' with { variant: 'warning', icon: 'bi-exclamation-circle', class: 'ms-1', content: '' } %}
                            {% endif %}
                        </td>
                        <td>
                            {% include '_components/_badge.html.twig' with { variant: 'secondary', content: ('training.type.' ~ training.trainingType)|trans({}, 'training') } %}
                        </td>
                        <td>{{ training.scheduledDate|date('d.m.Y') }}</td>
                        <td>{{ training.durationMinutes ?? '-' }} {{ 'training.minutes'|trans({}, 'training') }}</td>
                        <td>
                            <span class="{{ badge_status(training.status) }}">
                                {{ ('training.status.' ~ training.status)|trans({}, 'training') }}
                            </span>
                        </td>
                        <td>
                            <i class="fa-icon fa-icon--group" aria-hidden="true"></i>
                            {{ training.attendeeCount ?? 0 }}
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm" role="group">
                                <a href="{{ path('app_training_show', {id: training.id}) }}"
                                   class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
                                   data-turbo-action="advance"
                                   title="{{ 'common.view'|trans({}, 'messages') }}" aria-label="{{ 'common.view'|trans({}, 'messages') }}">
                                    <i class="fa-icon fa-icon--ui-eye" aria-hidden="true"></i>
                                </a>
                                {% if is_granted('ROLE_USER') %}
                                <a href="{{ path('app_training_edit', {id: training.id}) }}"
                                   class="fa-cyber-btn fa-cyber-btn--ghost fa-cyber-btn--sm"
                                   data-turbo-action="advance"
                                   title="{{ 'common.edit'|trans({}, 'messages') }}" aria-label="{{ 'common.edit'|trans({}, 'messages') }}">
                                    <i class="fa-icon fa-icon--ui-edit" aria-hidden="true"></i>
                                </a>
                                {% endif %}
                                {% if is_granted('ROLE_ADMIN') %}
                                <button type="button"
                                        class="fa-cyber-btn fa-cyber-btn--danger fa-cyber-btn--sm"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteModal{{ training.id }}"
                                        title="{{ 'common.delete'|trans({}, 'messages') }}" aria-label="{{ 'common.delete'|trans({}, 'messages') }}">
                                    <i class="fa-icon fa-icon--ui-trash" aria-hidden="true"></i>
                                </button>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                {% endblock %}
            {% endembed %}
            {% endif %}
        {% endblock %}
        {% block card_footer %}
            {# Bulk Action Bar #}
            {% if trainings|length > 0 %}
            {% include '_components/_bulk_action_bar.html.twig' with {
                actions: ['export', 'assign', 'delete']
            } %}
            {% endif %}
        {% endblock %}
    {% endembed %}
</div>

{# Delete Modals #}
{% for training in trainings %}
<div class="modal fade" id="deleteModal{{ training.id }}" tabindex="-1" aria-labelledby="deleteModalLabel{{ training.id }}" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h3 class="modal-title h5" id="deleteModalLabel{{ training.id }}">
                    <i class="fa-icon fa-icon--status-warning" aria-hidden="true"></i> {{ 'training.confirm_delete'|trans({}, 'training') }}
                </h3>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="{{ 'common.close'|trans({}, 'messages') }}"></button>
            </div>
            <div class="modal-body">
                <p>{{ 'training.delete_warning'|trans({'%title%': training.title}, 'training') }}</p>
                <p class="text-muted"><small>{{ 'common.action_irreversible'|trans({}, 'messages') }}</small></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="fa-cyber-btn fa-cyber-btn--ghost" data-bs-dismiss="modal">
                    {{ 'common.cancel'|trans({}, 'messages') }}
                </button>
                <form method="post" action="{{ path('app_training_delete', {id: training.id}) }}" class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ training.id) }}">
                    <button type="submit" class="fa-cyber-btn fa-cyber-btn--danger">
                        <i class="fa-icon fa-icon--ui-trash" aria-hidden="true"></i> {{ 'common.delete'|trans({}, 'messages') }}
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endfor %}
</main>
{% endblock %}
