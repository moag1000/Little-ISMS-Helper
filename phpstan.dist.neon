includes:
    # Pre-existing level-5 violations are frozen here so the higher bar applies
    # to NEW code immediately while the backlog is burned down over time.
    # Regenerate after fixing some: vendor/bin/phpstan analyse --generate-baseline
    - phpstan-baseline.neon

parameters:
    paths:
        - src/

    # Raised from 1 → 5 (with a baseline for the existing backlog). Level 5 adds
    # undefined method/property detection on resolved types and argument-type
    # checks — the class of static bug that previously slipped through.
    level: 5

    # The prod image runs PHP 8.5 while CI analyses on PHP 8.4, so a few
    # version-specific findings (e.g. postInc.type "++ on literal-string") land
    # in the baseline on one version but not the other. Tolerate unmatched
    # baseline entries — genuinely NEW errors still fail the build.
    reportUnmatchedIgnoredErrors: false

    # Exclude paths that are allowed to call setStatus() directly
    excludePaths:
        - src/Entity/
        - src/Lifecycle/

services:
    # X.5b — Prevents `setStatus()` outside src/Entity/ and src/Lifecycle/
    -
        class: App\Tests\PHPStan\Rule\NoDirectSetStatusRule
        tags:
            - phpstan.rules.rule

    # Y.4 — Prevents `new App\Entity\Workflow()` / `new App\Entity\WorkflowStep()`
    # in src/ code outside Repository and Command namespaces.
    -
        class: App\Tests\PHPStan\Rule\NoNewWorkflowOrWorkflowStepRule
        tags:
            - phpstan.rules.rule

    # Marks constants consumed only outside analysed PHP (CI gate scripts,
    # reflection in tests) as always-used — e.g. BackupService::EXCLUDED_FROM_BACKUP
    # (parsed by Gate 43's Python + read via reflection in BackupServiceTest).
    -
        class: App\Tests\PHPStan\Constant\ExternallyConsumedConstantExtension
        tags:
            - phpstan.constants.alwaysUsedClassConstantsExtension

    # Narrow getUser() → App\Entity\User|null (single user entity). Kills the
    # ~190 false method.notFound/argument.type against ?UserInterface.
    -
        class: App\Tests\PHPStan\Type\GetUserReturnTypeExtension
        arguments:
            forClass: Symfony\Bundle\SecurityBundle\Security
        tags:
            - phpstan.broker.dynamicMethodReturnTypeExtension
    -
        class: App\Tests\PHPStan\Type\GetUserReturnTypeExtension
        arguments:
            forClass: Symfony\Bundle\FrameworkBundle\Controller\AbstractController
        tags:
            - phpstan.broker.dynamicMethodReturnTypeExtension
