    {
      "nis2": "21.2.a",
      "baustein": "ORP.5",
      "state": "panel_discovered",
      "mappingPercentage": 40,
      "refutationSurvived": true,
      "relation": "partial",
      "rationale": "21.2.a's 'information security policies' pillar requires a governance framework that systematically identifies and enforces legal/regulatory security requirements (ISO A.5.31/A.5.36 -> ORP.5); not covered by ISMS.1, ORP.1, CON.2 or DER.3.1, though it also overlaps 21.2.f."
    },
    {
      "nis2": "21.2.b",
      "baustein": "DER.4",
      "state": "panel_discovered",
      "mappingPercentage": 50,
      "refutationSurvived": true,
      "relation": "partial",
      "rationale": "Art.21(2)(b) explicitly names 'crisis management' as part of incident handling; DER.4 (Notfallmanagement) is the BSI building block for crisis/emergency response, covering the escalation-to-crisis leg the DER.2.x blocks do not (overlap with 21.2.c keeps it partial)."
    },
    {
      "nis2": "21.2.b",
      "baustein": "OPS.1.1.5",
      "state": "panel_discovered",
      "mappingPercentage": 40,
      "refutationSurvived": true,
      "relation": "supports",
      "rationale": "Incident detection (DER.1) and the analysis/response steps of DER.2.1 are functionally impossible without logging; OPS.1.1.5 (Protokollierung) is the evidentiary and detection foundation that incident handling consumes."
    },
    {
      "nis2": "21.2.c",
      "baustein": "SYS.1.8",
      "state": "panel_discovered",
      "mappingPercentage": 40,
      "refutationSurvived": true,
      "relation": "related",
      "rationale": "Speicherloesungen sind das Ziel von Datensicherungen und tragen via Redundanz/Replikation/Snapshots unmittelbar zur Backup- und Wiederanlauf-Faehigkeit bei."
    },
    {
      "nis2": "21.2.e",
      "baustein": "OPS.1.1.3",
      "state": "panel_discovered",
      "mappingPercentage": 90,
      "refutationSurvived": true,
      "relation": "strong",
      "rationale": "Patch- und Aenderungsmanagement is the core anchor for the 'maintenance + vulnerability handling' half of 21.2(e) (ISO A.8.8 technical vulns, A.8.9 config mgmt, A.8.32 change mgmt) and is entirely absent from the list."
    },
    {
      "nis2": "21.2.e",
      "baustein": "APP.7",
      "state": "panel_discovered",
      "mappingPercentage": 80,
      "refutationSurvived": true,
      "relation": "strong",
      "rationale": "Entwicklung von Individualsoftware covers secure development of custom/in-house software (ISO A.8.25-A.8.28), a development pillar of 21.2(e) only partially covered by CON.8 (generic) and CON.10 (web-only)."
    },
    {
      "nis2": "21.2.e",
      "baustein": "APP.3.1",
      "state": "panel_discovered",
      "mappingPercentage": 65,
      "refutationSurvived": true,
      "relation": "moderate",
      "rationale": "Webanwendungen und Webservices anchors application security requirements (ISO A.8.26), the 'security in acquisition/use of network and information systems' aspect of 21.2(e) not represented by CON.10 (which only covers web-app development)."
    },
    {
